// ============================================
// Raft Consensus - Main Simulator
// ============================================
// 전체 Raft 분산 시스템 시뮬레이션
// 3-node cluster 구성 및 실행
//
// 작성: Claude Code AI (2026-03-02)
// 난이도: ⭐⭐⭐⭐⭐ 박사 수준
// ============================================

// ============================================
// Part 1: Cluster 초기화
// ============================================

/// Cluster 구성 정보
struct ClusterConfig {
  node_count: int,
  nodes: [int],
  tick_interval: int,        // 메인 루프 간격 (ms)
  election_timeout: int,     // 선거 타임아웃 (ms)
  heartbeat_interval: int    // 하트비트 간격 (ms)
}

/// Raft Cluster 시뮬레이션 상태
struct RaftCluster {
  config: ClusterConfig,
  nodes: {int: RaftNode},
  term: int,
  leader_id: int?,
  total_elections: int,
  total_logs_applied: int
}

/// Cluster 초기화
fn init_cluster(node_count: int) -> RaftCluster {
  println()
  println("🚀 Initializing Raft Cluster")
  println("═══════════════════════════════")

  // 노드 생성
  nodes = {}
  node_ids = []

  for i = 0; i < node_count; i = i + 1 {
    node_ids = node_ids + [i]
  }

  for i = 0; i < node_count; i = i + 1 {
    node = create_raft_node(i, node_ids)
    nodes[i] = node
  }

  config = ClusterConfig {
    node_count: node_count,
    nodes: node_ids,
    tick_interval: 10,
    election_timeout: 150,
    heartbeat_interval: 50
  }

  cluster = RaftCluster {
    config: config,
    nodes: nodes,
    term: 0,
    leader_id: null,
    total_elections: 0,
    total_logs_applied: 0
  }

  println("✅ Cluster initialized with " + to_string(node_count) + " nodes")
  println()

  return cluster
}

// ============================================
// Part 2: Cluster 이벤트 루프
// ============================================

/// 모든 노드의 선거 타임아웃 확인
fn tick_election_timeouts(cluster: RaftCluster) -> RaftCluster {
  for node_id in cluster.config.nodes {
    node = cluster.nodes[node_id]

    // Follower/Candidate의 타임아웃 확인
    if node.state != NodeState.Leader {
      if election_timeout_expired(node) {
        println("⏰ Election timeout on Node " + to_string(node_id))

        // 선거 시작
        (node, req) = start_election(node)
        cluster.nodes[node_id] = node
        cluster.total_elections = cluster.total_elections + 1

        // 모든 피어에게 RequestVote 브로드캐스트
        node = broadcast_request_vote(node, req)
        cluster.nodes[node_id] = node
      }
    }
  }

  return cluster
}

/// 모든 Leader의 하트비트 전송
fn tick_heartbeats(cluster: RaftCluster) -> RaftCluster {
  for node_id in cluster.config.nodes {
    node = cluster.nodes[node_id]

    // Leader만 하트비트 전송
    if node.state == NodeState.Leader {
      if node.heartbeatTimer != null && timer_expired(node.heartbeatTimer) {
        println("💓 Heartbeat from Leader " + to_string(node_id))

        // 모든 팔로워에게 AppendEntries 전송
        node = broadcast_append_entries(node)
        cluster.nodes[node_id] = node
      }
    }
  }

  return cluster
}

/// 로그 적용 (각 노드)
fn tick_apply_logs(cluster: RaftCluster) -> RaftCluster {
  total_applied = 0

  for node_id in cluster.config.nodes {
    node = cluster.nodes[node_id]

    // commitIndex > lastApplied이면 적용
    pending = get_committed_entries(node)

    if len(pending) > 0 {
      node = apply_log_entries(node)
      total_applied = total_applied + len(pending)
    }

    cluster.nodes[node_id] = node
  }

  if total_applied > 0 {
    cluster.total_logs_applied = cluster.total_logs_applied + total_applied
  }

  return cluster
}

/// 메인 시뮬레이션 루프
fn run_simulation(cluster: RaftCluster, ticks: int) -> RaftCluster {
  println()
  println("🎬 Starting simulation (" + to_string(ticks) + " ticks)")
  println("═══════════════════════════════")

  for tick = 0; tick < ticks; tick = tick + 1 {
    // 1. 선거 타임아웃 확인
    cluster = tick_election_timeouts(cluster)

    // 2. 하트비트 전송
    cluster = tick_heartbeats(cluster)

    // 3. 로그 적용
    cluster = tick_apply_logs(cluster)

    // 4. 현재 Leader 확인
    leader = null
    for node_id in cluster.config.nodes {
      node = cluster.nodes[node_id]
      if node.state == NodeState.Leader {
        leader = node_id
      }
    }

    if leader != cluster.leader_id {
      if leader != null {
        println("👑 NEW LEADER: Node " + to_string(leader) +
                " (term " + to_string(cluster.nodes[leader].currentTerm) + ")")
      }
      cluster.leader_id = leader
    }
  }

  return cluster
}

// ============================================
// Part 3: Cluster 상태 조회
// ============================================

/// Cluster 전체 통계
fn get_cluster_stats(cluster: RaftCluster) -> {string: int} {
  stats = {}

  total_logs = 0
  total_committed = 0
  total_applied = 0

  for node_id in cluster.config.nodes {
    node = cluster.nodes[node_id]

    total_logs = total_logs + len(node.log)
    total_committed = total_committed + node.commitIndex
    total_applied = total_applied + node.lastApplied
  }

  stats["total_nodes"] = cluster.config.node_count
  stats["leader_id"] = cluster.leader_id == null ? -1 : cluster.leader_id
  stats["total_elections"] = cluster.total_elections
  stats["total_logs"] = total_logs
  stats["total_committed"] = total_committed
  stats["total_applied"] = total_applied

  return stats
}

/// Cluster 상태 출력
fn print_cluster_status(cluster: RaftCluster) {
  println()
  println("📊 Cluster Status")
  println("═══════════════════════════════")

  for node_id in cluster.config.nodes {
    node = cluster.nodes[node_id]

    state_str = ""
    if node.state == NodeState.Leader {
      state_str = "👑 LEADER"
    } else if node.state == NodeState.Candidate {
      state_str = "🗳️  CANDIDATE"
    } else {
      state_str = "📚 FOLLOWER"
    }

    println()
    println("Node " + to_string(node_id) + ": " + state_str)
    println("├─ Term: " + to_string(node.currentTerm))
    println("├─ Log Size: " + to_string(len(node.log)))
    println("├─ CommitIndex: " + to_string(node.commitIndex))
    println("├─ LastApplied: " + to_string(node.lastApplied))
    println("└─ Applied Commands: " + to_string(node.appliedCommandCount))
  }

  println()
  println("📈 Cluster Totals:")
  println("├─ Total Elections: " + to_string(cluster.total_elections))
  println("├─ Total Logs Applied: " + to_string(cluster.total_logs_applied))
  println("└─ Current Leader: Node " +
          to_string(cluster.leader_id == null ? -1 : cluster.leader_id))
}

// ============================================
// Part 4: Cluster 명령 실행
// ============================================

/// Leader에 명령 추가
fn add_command_to_leader(
  cluster: RaftCluster,
  command: string
) -> RaftCluster {
  if cluster.leader_id == null {
    println("❌ No leader available")
    return cluster
  }

  leader_id = cluster.leader_id
  leader = cluster.nodes[leader_id]

  leader = append_to_log(leader, command)
  cluster.nodes[leader_id] = leader

  println("✅ Command added to leader: " + command)

  return cluster
}

// ============================================
// Part 5: 테스트 시나리오
// ============================================

/// Test 1: 기본 선거
fn test_basic_election() {
  println()
  println("📝 Test 1: Basic Leader Election")
  println("════════════════════════════════════")

  cluster = init_cluster(3)

  // 100 tick 실행 (충분한 시간동안 선거)
  cluster = run_simulation(cluster, 100)

  print_cluster_status(cluster)

  // Leader가 선출되었는지 확인
  has_leader = cluster.leader_id != null
  assert has_leader == true

  println()
  println("✅ test_basic_election passed")
}

/// Test 2: 명령 추가 및 복제
fn test_command_replication() {
  println()
  println("📝 Test 2: Command Replication")
  println("════════════════════════════════════")

  cluster = init_cluster(3)

  // 선거 진행
  cluster = run_simulation(cluster, 50)

  if cluster.leader_id != null {
    // Leader에 명령 추가
    cluster = add_command_to_leader(cluster, "transfer 100")
    cluster = add_command_to_leader(cluster, "withdraw 50")

    // 복제 및 적용 진행
    cluster = run_simulation(cluster, 50)

    print_cluster_status(cluster)

    println()
    println("✅ test_command_replication passed")
  } else {
    println("⚠️  test_command_replication skipped (no leader)")
  }
}

/// Test 3: 장기 실행
fn test_long_running() {
  println()
  println("📝 Test 3: Long Running Cluster")
  println("════════════════════════════════════")

  cluster = init_cluster(3)

  // 500 tick 장기 실행
  cluster = run_simulation(cluster, 500)

  print_cluster_status(cluster)

  println()
  println("✅ test_long_running passed")
}

// ============================================
// 메인 실행
// ============================================

fn main() {
  println("🌐 Raft Cluster Simulator")
  println("═════════════════════════════════════════")

  test_basic_election()
  test_command_replication()
  test_long_running()

  println()
  println("🎉 All simulation tests completed!")
}

// 실행
main()
