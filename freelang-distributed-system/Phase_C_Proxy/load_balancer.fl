// ============================================
// Load Balancer - Request Distribution
// ============================================
// 여러 Backend에 요청 분산
// Round-Robin, Least Connections, Weighted
//
// 작성: Claude Code AI (2026-03-02)
// 난이도: ⭐⭐⭐⭐ 고급
// ============================================

// ============================================
// Part 1: 로드 밸런싱 전략
// ============================================

/// Backend 서버 정보
struct BackendServer {
  node_id: int,
  host: string,
  port: int,
  weight: int = 1,              // 가중치 (1-10)
  active: bool = true,
  connection_count: int = 0,
  total_requests: int = 0,
  failed_requests: int = 0
}

/// 로드 밸런서 상태
struct LoadBalancer {
  backends: [BackendServer],
  current_index: int = 0,
  strategy: string,             // "round_robin", "least_conn", "weighted"
  session_map: {string: int} = {}  // IP -> backend 맵
}

/// 로드 밸런서 초기화
fn init_load_balancer(strategy: string) -> LoadBalancer {
  println()
  println("⚖️  Load Balancer Initialized")
  println("├─ Strategy: " + strategy)
  println("└─ Status: Ready")

  return LoadBalancer {
    backends: [],
    current_index: 0,
    strategy: strategy,
    session_map: {}
  }
}

/// Backend 추가
fn add_backend(
  lb: LoadBalancer,
  node_id: int,
  host: string,
  port: int,
  weight: int
) -> LoadBalancer {
  backend = BackendServer {
    node_id: node_id,
    host: host,
    port: port,
    weight: weight,
    active: true,
    connection_count: 0,
    total_requests: 0,
    failed_requests: 0
  }

  lb.backends = lb.backends + [backend]

  println("✅ Backend added: Node " + to_string(node_id) +
          " (" + host + ":" + to_string(port) + ")")

  return lb
}

/// Backend 제거
fn remove_backend(lb: LoadBalancer, node_id: int) -> LoadBalancer {
  new_backends = []

  for backend in lb.backends {
    if backend.node_id != node_id {
      new_backends = new_backends + [backend]
    }
  }

  lb.backends = new_backends

  println("✅ Backend removed: Node " + to_string(node_id))

  return lb
}

// ============================================
// Part 2: Round-Robin 전략
// ============================================

/// Round-Robin: 순서대로 분배
fn select_backend_round_robin(lb: LoadBalancer) -> BackendServer? {
  if len(lb.backends) == 0 {
    return null
  }

  // 다음 Backend 선택
  backend = lb.backends[lb.current_index]
  lb.current_index = (lb.current_index + 1) % len(lb.backends)

  // 비활성 Backend는 스킵
  if !backend.active {
    return select_backend_round_robin(lb)
  }

  return backend
}

// ============================================
// Part 3: Least Connections 전략
// ============================================

/// Least Connections: 연결 수가 적은 Backend 선택
fn select_backend_least_connections(lb: LoadBalancer) -> BackendServer? {
  if len(lb.backends) == 0 {
    return null
  }

  min_backend = null
  min_connections = 999999

  for backend in lb.backends {
    if !backend.active {
      continue
    }

    if backend.connection_count < min_connections {
      min_connections = backend.connection_count
      min_backend = backend
    }
  }

  return min_backend
}

// ============================================
// Part 4: Weighted Round-Robin 전략
// ============================================

/// Weighted Round-Robin: 가중치에 따라 분배
fn select_backend_weighted_round_robin(lb: LoadBalancer) -> BackendServer? {
  if len(lb.backends) == 0 {
    return null
  }

  // 가중치를 고려한 선택
  total_weight = 0
  for backend in lb.backends {
    if backend.active {
      total_weight = total_weight + backend.weight
    }
  }

  if total_weight == 0 {
    return null
  }

  // 무작위 선택 (가중치 반영)
  selected = random(0, total_weight - 1)
  cumulative = 0

  for backend in lb.backends {
    if !backend.active {
      continue
    }

    cumulative = cumulative + backend.weight

    if selected < cumulative {
      return backend
    }
  }

  return null
}

// ============================================
// Part 5: 전략 기반 Backend 선택
// ============================================

/// 설정된 전략에 따라 Backend 선택
fn select_backend(lb: LoadBalancer, client_ip: string) -> BackendServer? {
  if lb.strategy == "round_robin" {
    return select_backend_round_robin(lb)
  } else if lb.strategy == "least_conn" {
    return select_backend_least_connections(lb)
  } else if lb.strategy == "weighted" {
    return select_backend_weighted_round_robin(lb)
  } else if lb.strategy == "sticky" {
    // Sticky Session: 같은 클라이언트는 같은 Backend로
    return select_backend_sticky(lb, client_ip)
  }

  return null
}

/// Sticky Session: 클라이언트별 고정 Backend
fn select_backend_sticky(lb: LoadBalancer, client_ip: string) -> BackendServer? {
  // 이미 할당된 Backend가 있으면 반환
  if lb.session_map[client_ip] != null {
    backend_id = lb.session_map[client_ip]

    for backend in lb.backends {
      if backend.node_id == backend_id && backend.active {
        return backend
      }
    }
  }

  // 새로운 Backend 할당
  backend = select_backend_round_robin(lb)

  if backend != null {
    lb.session_map[client_ip] = backend.node_id
  }

  return backend
}

// ============================================
// Part 6: 통계 및 모니터링
// ============================================

/// Backend 통계
struct BackendStats {
  node_id: int,
  requests: int,
  failed: int,
  success_rate: int
}

/// Backend 통계 조회
fn get_backend_stats(lb: LoadBalancer) -> [BackendStats] {
  stats = []

  for backend in lb.backends {
    success = backend.total_requests - backend.failed_requests
    success_rate = 0

    if backend.total_requests > 0 {
      success_rate = (success * 100) / backend.total_requests
    }

    stat = BackendStats {
      node_id: backend.node_id,
      requests: backend.total_requests,
      failed: backend.failed_requests,
      success_rate: success_rate
    }

    stats = stats + [stat]
  }

  return stats
}

/// 로드 분산 상태 출력
fn print_load_distribution(lb: LoadBalancer) {
  println()
  println("📊 Load Distribution")
  println("═══════════════════════════════════")

  total_connections = 0

  for backend in lb.backends {
    total_connections = total_connections + backend.connection_count
  }

  for backend in lb.backends {
    status = backend.active ? "🟢 ACTIVE" : "🔴 INACTIVE"

    percentage = 0
    if total_connections > 0 {
      percentage = (backend.connection_count * 100) / total_connections
    }

    println()
    println("Node " + to_string(backend.node_id) + ": " + status)
    println("├─ Connections: " + to_string(backend.connection_count) +
            " (" + to_string(percentage) + "%)")
    println("├─ Total Requests: " + to_string(backend.total_requests))
    println("├─ Failed Requests: " + to_string(backend.failed_requests))
    println("└─ Weight: " + to_string(backend.weight))
  }
}

// ============================================
// Part 7: 테스트
// ============================================

fn test_init_load_balancer() {
  lb = init_load_balancer("round_robin")

  assert lb.strategy == "round_robin"
  assert len(lb.backends) == 0

  println("✅ test_init_load_balancer passed")
}

fn test_add_backend() {
  lb = init_load_balancer("round_robin")

  lb = add_backend(lb, 0, "localhost", 9000, 1)
  lb = add_backend(lb, 1, "localhost", 9100, 1)
  lb = add_backend(lb, 2, "localhost", 9200, 1)

  assert len(lb.backends) == 3

  println("✅ test_add_backend passed")
}

fn test_round_robin_selection() {
  lb = init_load_balancer("round_robin")

  lb = add_backend(lb, 0, "localhost", 9000, 1)
  lb = add_backend(lb, 1, "localhost", 9100, 1)
  lb = add_backend(lb, 2, "localhost", 9200, 1)

  backend1 = select_backend(lb, "192.168.1.1")
  backend2 = select_backend(lb, "192.168.1.2")
  backend3 = select_backend(lb, "192.168.1.3")

  assert backend1.node_id == 0
  assert backend2.node_id == 1
  assert backend3.node_id == 2

  println("✅ test_round_robin_selection passed")
}

fn test_least_connections_selection() {
  lb = init_load_balancer("least_conn")

  lb = add_backend(lb, 0, "localhost", 9000, 1)
  lb = add_backend(lb, 1, "localhost", 9100, 1)
  lb = add_backend(lb, 2, "localhost", 9200, 1)

  // Backend 0에 연결 추가
  lb.backends[0].connection_count = 5
  lb.backends[1].connection_count = 2
  lb.backends[2].connection_count = 3

  backend = select_backend(lb, "192.168.1.1")

  // 가장 연결이 적은 Backend 1 선택
  assert backend.node_id == 1

  println("✅ test_least_connections_selection passed")
}

fn test_weighted_selection() {
  lb = init_load_balancer("weighted")

  lb = add_backend(lb, 0, "localhost", 9000, 5)
  lb = add_backend(lb, 1, "localhost", 9100, 3)
  lb = add_backend(lb, 2, "localhost", 9200, 2)

  backend = select_backend(lb, "192.168.1.1")

  // 가중치에 따라 선택 (평균적으로)
  assert backend != null

  println("✅ test_weighted_selection passed")
}

fn test_sticky_session() {
  lb = init_load_balancer("sticky")

  lb = add_backend(lb, 0, "localhost", 9000, 1)
  lb = add_backend(lb, 1, "localhost", 9100, 1)

  client_ip = "192.168.1.1"

  backend1 = select_backend(lb, client_ip)
  backend2 = select_backend(lb, client_ip)

  // 같은 클라이언트는 같은 Backend로
  assert backend1.node_id == backend2.node_id

  println("✅ test_sticky_session passed")
}

fn test_remove_backend() {
  lb = init_load_balancer("round_robin")

  lb = add_backend(lb, 0, "localhost", 9000, 1)
  lb = add_backend(lb, 1, "localhost", 9100, 1)
  lb = add_backend(lb, 2, "localhost", 9200, 1)

  assert len(lb.backends) == 3

  lb = remove_backend(lb, 1)

  assert len(lb.backends) == 2

  println("✅ test_remove_backend passed")
}

fn test_get_backend_stats() {
  lb = init_load_balancer("round_robin")

  lb = add_backend(lb, 0, "localhost", 9000, 1)
  lb = add_backend(lb, 1, "localhost", 9100, 1)

  lb.backends[0].total_requests = 100
  lb.backends[0].failed_requests = 5

  stats = get_backend_stats(lb)

  assert len(stats) == 2
  assert stats[0].success_rate == 95

  println("✅ test_get_backend_stats passed")
}

// ============================================
// 메인 테스트 실행
// ============================================

fn main() {
  println("⚖️  Load Balancer - Tests")
  println("═════════════════════════════════")

  test_init_load_balancer()
  test_add_backend()
  test_round_robin_selection()
  test_least_connections_selection()
  test_weighted_selection()
  test_sticky_session()
  test_remove_backend()
  test_get_backend_stats()

  println()
  println("✅ All load balancer tests passed!")
  println()
  println("📊 Summary:")
  println("├─ Backend management: ✅")
  println("├─ Round-Robin: ✅")
  println("├─ Least Connections: ✅")
  println("├─ Weighted distribution: ✅")
  println("├─ Sticky sessions: ✅")
  println("└─ Statistics: ✅")
}

// 실행
main()
