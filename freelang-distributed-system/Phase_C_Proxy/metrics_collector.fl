// ============================================
// Metrics Collector - System Monitoring
// ============================================
// 시스템 메트릭 수집 및 분석
// 요청 통계, 성능 지표, 경보 관리
//
// 작성: Claude Code AI (2026-03-02)
// 난이도: ⭐⭐⭐⭐ 고급
// ============================================

// ============================================
// Part 1: 메트릭 기본 구조
// ============================================

/// 요청 메트릭
struct RequestMetrics {
  total_requests: int,
  successful_requests: int,
  failed_requests: int,
  rate_limited_requests: int,
  average_latency: int,  // ms
  min_latency: int,
  max_latency: int
}

/// 시스템 메트릭
struct SystemMetrics {
  timestamp: int,
  cpu_usage: int,        // percentage (0-100)
  memory_usage: int,     // percentage (0-100)
  network_in: int,       // bytes/sec
  network_out: int,      // bytes/sec
  active_connections: int,
  error_rate: int        // percentage
}

/// 경보 수준
enum AlertLevel {
  Info,
  Warning,
  Critical
}

/// 경보
struct Alert {
  alert_id: int,
  level: AlertLevel,
  message: string,
  timestamp: int,
  metric_name: string,
  metric_value: int
}

/// 메트릭 수집기 설정
struct MetricsConfig {
  collection_interval: int,  // 초
  retention_period: int,     // 초
  alert_thresholds: {string: int}
}

/// 메트릭 수집기
struct MetricsCollector {
  config: MetricsConfig,
  request_metrics: RequestMetrics,
  system_metrics: [SystemMetrics],
  alerts: [Alert],
  alert_counter: int,
  last_collection_time: int
}

/// 메트릭 수집기 초기화
fn init_metrics_collector() -> MetricsCollector {
  println()
  println("📊 Metrics Collector Initialized")
  println("├─ Collection Interval: 10s")
  println("├─ Retention Period: 3600s")
  println("└─ Status: Ready")

  config = MetricsConfig {
    collection_interval: 10,
    retention_period: 3600,
    alert_thresholds: {
      "error_rate": 5,
      "cpu_usage": 80,
      "memory_usage": 85,
      "latency": 1000
    }
  }

  return MetricsCollector {
    config: config,
    request_metrics: RequestMetrics {
      total_requests: 0,
      successful_requests: 0,
      failed_requests: 0,
      rate_limited_requests: 0,
      average_latency: 0,
      min_latency: 999999,
      max_latency: 0
    },
    system_metrics: [],
    alerts: [],
    alert_counter: 0,
    last_collection_time: 0
  }
}

// ============================================
// Part 2: 요청 메트릭
// ============================================

/// 요청 기록
fn record_request(
  collector: MetricsCollector,
  is_successful: bool,
  latency: int,
  is_rate_limited: bool
) -> MetricsCollector {
  collector.request_metrics.total_requests =
    collector.request_metrics.total_requests + 1

  if is_successful {
    collector.request_metrics.successful_requests =
      collector.request_metrics.successful_requests + 1
  } else {
    collector.request_metrics.failed_requests =
      collector.request_metrics.failed_requests + 1
  }

  if is_rate_limited {
    collector.request_metrics.rate_limited_requests =
      collector.request_metrics.rate_limited_requests + 1
  }

  // 지연시간 추적
  if latency < collector.request_metrics.min_latency {
    collector.request_metrics.min_latency = latency
  }

  if latency > collector.request_metrics.max_latency {
    collector.request_metrics.max_latency = latency
  }

  // 평균 계산
  total_latency = collector.request_metrics.average_latency *
                 (collector.request_metrics.total_requests - 1) +
                 latency

  collector.request_metrics.average_latency =
    total_latency / collector.request_metrics.total_requests

  return collector
}

/// 성공률 계산
fn calculate_success_rate(collector: MetricsCollector) -> int {
  if collector.request_metrics.total_requests == 0 {
    return 0
  }

  success_rate = (collector.request_metrics.successful_requests * 100) /
                 collector.request_metrics.total_requests

  return success_rate
}

/// 에러율 계산
fn calculate_error_rate(collector: MetricsCollector) -> int {
  return 100 - calculate_success_rate(collector)
}

// ============================================
// Part 3: 시스템 메트릭
// ============================================

/// 시스템 메트릭 수집
fn collect_system_metrics(
  collector: MetricsCollector,
  current_time: int
) -> MetricsCollector {
  println()
  println("📈 Collecting system metrics")

  // 시뮬레이션: 메트릭 생성
  metrics = SystemMetrics {
    timestamp: current_time,
    cpu_usage: 45 + random(0, 20),      // 45-65%
    memory_usage: 60 + random(0, 15),   // 60-75%
    network_in: 1000000 + random(0, 500000),  // 1-1.5 MB/s
    network_out: 500000 + random(0, 250000),  // 0.5-0.75 MB/s
    active_connections: 150 + random(0, 50),
    error_rate: calculate_error_rate(collector)
  }

  collector.system_metrics = collector.system_metrics + [metrics]
  collector.last_collection_time = current_time

  println("   ✅ Metrics collected")
  println("   ├─ CPU: " + to_string(metrics.cpu_usage) + "%")
  println("   ├─ Memory: " + to_string(metrics.memory_usage) + "%")
  println("   ├─ Error Rate: " + to_string(metrics.error_rate) + "%")
  println("   └─ Active Connections: " + to_string(metrics.active_connections))

  return collector
}

// ============================================
// Part 4: 경보 관리
// ============================================

/// 경보 생성
fn create_alert(
  collector: MetricsCollector,
  level: AlertLevel,
  message: string,
  metric_name: string,
  metric_value: int,
  current_time: int
) -> MetricsCollector {
  alert = Alert {
    alert_id: collector.alert_counter,
    level: level,
    message: message,
    timestamp: current_time,
    metric_name: metric_name,
    metric_value: metric_value
  }

  collector.alerts = collector.alerts + [alert]
  collector.alert_counter = collector.alert_counter + 1

  level_str = ""
  if level == AlertLevel.Info {
    level_str = "ℹ️  INFO"
  } else if level == AlertLevel.Warning {
    level_str = "⚠️  WARNING"
  } else {
    level_str = "🔴 CRITICAL"
  }

  println()
  println(level_str + ": " + message)
  println("   Metric: " + metric_name + " = " + to_string(metric_value))

  return collector
}

/// 경보 임계값 확인
fn check_thresholds(
  collector: MetricsCollector,
  current_time: int
) -> MetricsCollector {
  if len(collector.system_metrics) == 0 {
    return collector
  }

  latest = collector.system_metrics[len(collector.system_metrics) - 1]

  // CPU 사용량 확인
  cpu_threshold = collector.config.alert_thresholds["cpu_usage"]
  if latest.cpu_usage > cpu_threshold {
    collector = create_alert(
      collector,
      AlertLevel.Warning,
      "High CPU usage detected",
      "cpu_usage",
      latest.cpu_usage,
      current_time
    )
  }

  // 메모리 사용량 확인
  memory_threshold = collector.config.alert_thresholds["memory_usage"]
  if latest.memory_usage > memory_threshold {
    collector = create_alert(
      collector,
      AlertLevel.Warning,
      "High memory usage detected",
      "memory_usage",
      latest.memory_usage,
      current_time
    )
  }

  // 에러율 확인
  error_threshold = collector.config.alert_thresholds["error_rate"]
  if latest.error_rate > error_threshold {
    collector = create_alert(
      collector,
      AlertLevel.Critical,
      "High error rate detected",
      "error_rate",
      latest.error_rate,
      current_time
    )
  }

  return collector
}

// ============================================
// Part 5: 보고 및 통계
// ============================================

/// 메트릭 보고서
fn print_metrics_report(collector: MetricsCollector) {
  println()
  println("📊 Metrics Report")
  println("═══════════════════════════════════")

  println()
  println("Request Metrics:")
  println("├─ Total: " + to_string(collector.request_metrics.total_requests))
  println("├─ Successful: " + to_string(collector.request_metrics.successful_requests))
  println("├─ Failed: " + to_string(collector.request_metrics.failed_requests))
  println("├─ Rate Limited: " + to_string(collector.request_metrics.rate_limited_requests))
  println("├─ Success Rate: " + to_string(calculate_success_rate(collector)) + "%")
  println("├─ Avg Latency: " + to_string(collector.request_metrics.average_latency) + "ms")
  println("├─ Min Latency: " + to_string(collector.request_metrics.min_latency) + "ms")
  println("└─ Max Latency: " + to_string(collector.request_metrics.max_latency) + "ms")

  if len(collector.system_metrics) > 0 {
    latest = collector.system_metrics[len(collector.system_metrics) - 1]

    println()
    println("Latest System Metrics:")
    println("├─ CPU: " + to_string(latest.cpu_usage) + "%")
    println("├─ Memory: " + to_string(latest.memory_usage) + "%")
    println("├─ Network In: " + to_string(latest.network_in) + " bytes/sec")
    println("├─ Network Out: " + to_string(latest.network_out) + " bytes/sec")
    println("├─ Active Connections: " + to_string(latest.active_connections))
    println("└─ Error Rate: " + to_string(latest.error_rate) + "%")
  }

  println()
  println("Recent Alerts: " + to_string(len(collector.alerts)))

  for i = 0; i < len(collector.alerts); i = i + 1 {
    if i < 5 {
      alert = collector.alerts[i]
      println("  " + to_string(alert.alert_id) + ": " + alert.message)
    }
  }
}

// ============================================
// Part 6: 테스트
// ============================================

fn test_init_metrics_collector() {
  collector = init_metrics_collector()

  assert collector.request_metrics.total_requests == 0
  assert len(collector.alerts) == 0

  println("✅ test_init_metrics_collector passed")
}

fn test_record_request() {
  collector = init_metrics_collector()

  collector = record_request(collector, true, 50, false)
  collector = record_request(collector, true, 60, false)
  collector = record_request(collector, false, 100, false)

  assert collector.request_metrics.total_requests == 3
  assert collector.request_metrics.successful_requests == 2
  assert collector.request_metrics.failed_requests == 1

  println("✅ test_record_request passed")
}

fn test_calculate_success_rate() {
  collector = init_metrics_collector()

  collector = record_request(collector, true, 50, false)
  collector = record_request(collector, true, 50, false)
  collector = record_request(collector, false, 50, false)

  success_rate = calculate_success_rate(collector)

  assert success_rate == 66  // 2/3

  println("✅ test_calculate_success_rate passed")
}

fn test_calculate_error_rate() {
  collector = init_metrics_collector()

  collector = record_request(collector, true, 50, false)
  collector = record_request(collector, false, 50, false)

  error_rate = calculate_error_rate(collector)

  assert error_rate == 50  // 1/2

  println("✅ test_calculate_error_rate passed")
}

fn test_collect_system_metrics() {
  collector = init_metrics_collector()

  collector = collect_system_metrics(collector, 1000)

  assert len(collector.system_metrics) == 1
  assert collector.last_collection_time == 1000

  println("✅ test_collect_system_metrics passed")
}

fn test_create_alert() {
  collector = init_metrics_collector()

  collector = create_alert(
    collector,
    AlertLevel.Warning,
    "Test alert",
    "test_metric",
    42,
    1000
  )

  assert len(collector.alerts) == 1
  assert collector.alerts[0].metric_value == 42

  println("✅ test_create_alert passed")
}

fn test_check_thresholds() {
  collector = init_metrics_collector()

  collector = collect_system_metrics(collector, 1000)
  collector = check_thresholds(collector, 1000)

  // 임계값에 따라 경보가 생성될 수 있음
  assert collector.alert_counter >= 0

  println("✅ test_check_thresholds passed")
}

fn test_latency_tracking() {
  collector = init_metrics_collector()

  collector = record_request(collector, true, 30, false)
  collector = record_request(collector, true, 50, false)
  collector = record_request(collector, true, 70, false)

  assert collector.request_metrics.min_latency == 30
  assert collector.request_metrics.max_latency == 70

  println("✅ test_latency_tracking passed")
}

fn test_rate_limited_tracking() {
  collector = init_metrics_collector()

  collector = record_request(collector, true, 50, false)
  collector = record_request(collector, true, 50, true)  // rate limited
  collector = record_request(collector, true, 50, true)  // rate limited

  assert collector.request_metrics.rate_limited_requests == 2

  println("✅ test_rate_limited_tracking passed")
}

// ============================================
// 메인 테스트 실행
// ============================================

fn main() {
  println("📊 Metrics Collector - Tests")
  println("═════════════════════════════════")

  test_init_metrics_collector()
  test_record_request()
  test_calculate_success_rate()
  test_calculate_error_rate()
  test_collect_system_metrics()
  test_create_alert()
  test_check_thresholds()
  test_latency_tracking()
  test_rate_limited_tracking()

  println()
  println("✅ All metrics collector tests passed!")
  println()
  println("📊 Summary:")
  println("├─ Request tracking: ✅")
  println("├─ Success/Error rate: ✅")
  println("├─ Latency analysis: ✅")
  println("├─ System metrics: ✅")
  println("├─ Alert management: ✅")
  println("├─ Threshold checking: ✅")
  println("└─ Rate limiting tracking: ✅")
}

// 실행
main()
