// ============================================
// Request Router - Pattern-Based Routing
// ============================================
// 경로 및 헤더 기반 요청 라우팅
// 동적 라우팅 규칙 설정 및 우선순위 관리
//
// 작성: Claude Code AI (2026-03-02)
// 난이도: ⭐⭐⭐⭐ 고급
// ============================================

// ============================================
// Part 1: 라우팅 규칙 정의
// ============================================

/// 경로 매칭 타입
enum PathMatchType {
  Exact,       // 정확히 일치
  Prefix,      // 접두어 일치
  Wildcard     // 와일드카드
}

/// 경로 매칭 규칙
struct PathMatcher {
  pattern: string,
  match_type: PathMatchType
}

/// 헤더 매칭 규칙
struct HeaderMatcher {
  header_name: string,
  header_value: string
}

/// 라우팅 규칙
struct RouteRule {
  rule_id: int,
  path_matcher: PathMatcher,
  header_matchers: [HeaderMatcher],
  target_backend: int,    // 대상 Backend ID
  priority: int,          // 우선순위 (높을수록 먼저 확인)
  enabled: bool
}

/// 요청 라우터
struct RequestRouter {
  rules: [RouteRule],
  default_backend: int,   // 규칙 일치 없을 때
  rule_counter: int
}

/// 라우터 초기화
fn init_request_router(default_backend: int) -> RequestRouter {
  println()
  println("🛣️  Request Router Initialized")
  println("├─ Default Backend: " + to_string(default_backend))
  println("└─ Status: Ready")

  return RequestRouter {
    rules: [],
    default_backend: default_backend,
    rule_counter: 0
  }
}

// ============================================
// Part 2: 경로 매칭
// ============================================

/// 경로 패턴과 요청 경로 비교
fn match_path(pattern: string, request_path: string, match_type: PathMatchType) -> bool {
  if match_type == PathMatchType.Exact {
    // 정확히 일치
    return pattern == request_path

  } else if match_type == PathMatchType.Prefix {
    // 접두어 일치 (/api/* -> /api/users, /api/products)
    if len(request_path) < len(pattern) {
      return false
    }

    for i = 0; i < len(pattern); i = i + 1 {
      if pattern[i] != request_path[i] {
        return false
      }
    }
    return true

  } else {
    // 와일드카드: 간단히 항상 일치 (실제로는 정규식 필요)
    return true
  }
}

// ============================================
// Part 3: 헤더 매칭
// ============================================

/// 요청 헤더가 규칙과 일치하는지 확인
fn match_headers(
  rule_headers: [HeaderMatcher],
  request_headers: {string: string}
) -> bool {
  if len(rule_headers) == 0 {
    // 헤더 조건이 없으면 일치
    return true
  }

  // 모든 헤더가 일치해야 함
  for rule_header in rule_headers {
    header_value = request_headers[rule_header.header_name]

    if header_value == null {
      // 헤더가 없음
      return false
    }

    if header_value != rule_header.header_value {
      // 값이 일치하지 않음
      return false
    }
  }

  return true
}

// ============================================
// Part 4: 라우팅 규칙 관리
// ============================================

/// 라우팅 규칙 추가
fn add_route(
  router: RequestRouter,
  path_pattern: string,
  match_type: PathMatchType,
  target_backend: int,
  priority: int
) -> RequestRouter {
  rule = RouteRule {
    rule_id: router.rule_counter,
    path_matcher: PathMatcher {
      pattern: path_pattern,
      match_type: match_type
    },
    header_matchers: [],
    target_backend: target_backend,
    priority: priority,
    enabled: true
  }

  router.rules = router.rules + [rule]
  router.rule_counter = router.rule_counter + 1

  println("✅ Route added: " + path_pattern + " → Backend " +
          to_string(target_backend) + " (priority: " +
          to_string(priority) + ")")

  return router
}

/// 헤더 조건을 포함한 라우팅 규칙 추가
fn add_route_with_headers(
  router: RequestRouter,
  path_pattern: string,
  match_type: PathMatchType,
  header_conditions: [HeaderMatcher],
  target_backend: int,
  priority: int
) -> RequestRouter {
  rule = RouteRule {
    rule_id: router.rule_counter,
    path_matcher: PathMatcher {
      pattern: path_pattern,
      match_type: match_type
    },
    header_matchers: header_conditions,
    target_backend: target_backend,
    priority: priority,
    enabled: true
  }

  router.rules = router.rules + [rule]
  router.rule_counter = router.rule_counter + 1

  println("✅ Route added with headers: " + path_pattern +
          " → Backend " + to_string(target_backend))

  return router
}

/// 규칙 활성화/비활성화
fn enable_rule(router: RequestRouter, rule_id: int, enabled: bool) -> RequestRouter {
  for i = 0; i < len(router.rules); i = i + 1 {
    if router.rules[i].rule_id == rule_id {
      router.rules[i].enabled = enabled

      status = enabled ? "enabled" : "disabled"
      println("✅ Rule " + to_string(rule_id) + " " + status)

      break
    }
  }

  return router
}

// ============================================
// Part 5: 요청 라우팅
// ============================================

/// 요청에 맞는 라우팅 규칙 선택
fn select_route(
  router: RequestRouter,
  request_path: string,
  request_headers: {string: string}
) -> int {
  println()
  println("🛣️  Selecting route for: " + request_path)

  best_rule = null
  best_priority = -1

  // 우선순위가 높은 규칙부터 확인
  for rule in router.rules {
    if !rule.enabled {
      continue
    }

    // 경로 매칭
    if !match_path(rule.path_matcher.pattern, request_path,
                   rule.path_matcher.match_type) {
      continue
    }

    // 헤더 매칭
    if !match_headers(rule.header_matchers, request_headers) {
      continue
    }

    // 우선순위 확인
    if rule.priority > best_priority {
      best_priority = rule.priority
      best_rule = rule
    }
  }

  if best_rule != null {
    println("   ✅ Matched rule ID " + to_string(best_rule.rule_id) +
            " → Backend " + to_string(best_rule.target_backend))
    return best_rule.target_backend
  } else {
    println("   ⚠️  No rule matched, using default backend " +
            to_string(router.default_backend))
    return router.default_backend
  }
}

// ============================================
// Part 6: 통계 및 모니터링
// ============================================

/// 라우팅 규칙 목록 출력
fn print_routes(router: RequestRouter) {
  println()
  println("📋 Routing Rules")
  println("═══════════════════════════════════")

  for rule in router.rules {
    status = rule.enabled ? "✅ ENABLED" : "❌ DISABLED"

    println()
    println("Rule " + to_string(rule.rule_id) + ": " + status)
    println("├─ Path: " + rule.path_matcher.pattern)
    println("├─ Type: " + to_string(rule.path_matcher.match_type))
    println("├─ Target: Backend " + to_string(rule.target_backend))
    println("├─ Priority: " + to_string(rule.priority))
    println("└─ Headers: " + to_string(len(rule.header_matchers)))
  }

  println()
  println("Default Backend: " + to_string(router.default_backend))
}

// ============================================
// Part 7: 테스트
// ============================================

fn test_init_router() {
  router = init_request_router(0)

  assert router.default_backend == 0
  assert len(router.rules) == 0

  println("✅ test_init_router passed")
}

fn test_add_route() {
  router = init_request_router(0)

  router = add_route(router, "/api/users", PathMatchType.Exact, 1, 10)
  router = add_route(router, "/api/products", PathMatchType.Exact, 2, 10)

  assert len(router.rules) == 2

  println("✅ test_add_route passed")
}

fn test_match_path_exact() {
  // Exact match
  result = match_path("/api/users", "/api/users", PathMatchType.Exact)
  assert result == true

  result = match_path("/api/users", "/api/products", PathMatchType.Exact)
  assert result == false

  println("✅ test_match_path_exact passed")
}

fn test_match_path_prefix() {
  // Prefix match
  result = match_path("/api/", "/api/users", PathMatchType.Prefix)
  assert result == true

  result = match_path("/api/", "/api/products", PathMatchType.Prefix)
  assert result == true

  result = match_path("/api/", "/admin/", PathMatchType.Prefix)
  assert result == false

  println("✅ test_match_path_prefix passed")
}

fn test_select_route_exact_match() {
  router = init_request_router(0)

  router = add_route(router, "/api/users", PathMatchType.Exact, 1, 10)
  router = add_route(router, "/api/products", PathMatchType.Exact, 2, 10)

  backend_id = select_route(router, "/api/users", {})
  assert backend_id == 1

  backend_id = select_route(router, "/api/products", {})
  assert backend_id == 2

  println("✅ test_select_route_exact_match passed")
}

fn test_select_route_prefix_match() {
  router = init_request_router(0)

  router = add_route(router, "/api/", PathMatchType.Prefix, 1, 10)

  backend_id = select_route(router, "/api/users/123", {})
  assert backend_id == 1

  backend_id = select_route(router, "/api/products/456", {})
  assert backend_id == 1

  println("✅ test_select_route_prefix_match passed")
}

fn test_select_route_default() {
  router = init_request_router(5)

  router = add_route(router, "/api/", PathMatchType.Prefix, 1, 10)

  // 규칙 일치 없음 → 기본값
  backend_id = select_route(router, "/admin/", {})
  assert backend_id == 5

  println("✅ test_select_route_default passed")
}

fn test_select_route_priority() {
  router = init_request_router(0)

  // 낮은 우선순위
  router = add_route(router, "/api/", PathMatchType.Prefix, 1, 5)
  // 높은 우선순위 (같은 패턴)
  router = add_route(router, "/api/", PathMatchType.Prefix, 2, 10)

  backend_id = select_route(router, "/api/users", {})
  // 높은 우선순위 규칙 선택
  assert backend_id == 2

  println("✅ test_select_route_priority passed")
}

fn test_enable_disable_rule() {
  router = init_request_router(0)

  router = add_route(router, "/api/users", PathMatchType.Exact, 1, 10)
  router = add_route(router, "/api/admin", PathMatchType.Exact, 2, 20)

  // 첫 번째 규칙 비활성화
  router = enable_rule(router, 0, false)

  backend_id = select_route(router, "/api/users", {})
  // 규칙이 비활성화되어 기본값 반환
  assert backend_id == 0

  backend_id = select_route(router, "/api/admin", {})
  // 이 규칙은 활성화되어 있음
  assert backend_id == 2

  println("✅ test_enable_disable_rule passed")
}

fn test_route_with_headers() {
  router = init_request_router(0)

  headers = [
    HeaderMatcher {
      header_name: "X-Client-Type",
      header_value: "mobile"
    }
  ]

  router = add_route_with_headers(
    router,
    "/api/users",
    PathMatchType.Exact,
    headers,
    1,
    10
  )

  // 헤더 일치
  request_headers = { "X-Client-Type": "mobile" }
  backend_id = select_route(router, "/api/users", request_headers)
  assert backend_id == 1

  // 헤더 불일치
  request_headers = { "X-Client-Type": "web" }
  backend_id = select_route(router, "/api/users", request_headers)
  assert backend_id == 0  // 기본값

  println("✅ test_route_with_headers passed")
}

// ============================================
// 메인 테스트 실행
// ============================================

fn main() {
  println("🛣️  Request Router - Tests")
  println("═════════════════════════════════")

  test_init_router()
  test_add_route()
  test_match_path_exact()
  test_match_path_prefix()
  test_select_route_exact_match()
  test_select_route_prefix_match()
  test_select_route_default()
  test_select_route_priority()
  test_enable_disable_rule()
  test_route_with_headers()

  println()
  println("✅ All request router tests passed!")
  println()
  println("📊 Summary:")
  println("├─ Route management: ✅")
  println("├─ Path matching (exact): ✅")
  println("├─ Path matching (prefix): ✅")
  println("├─ Priority handling: ✅")
  println("├─ Header matching: ✅")
  println("├─ Rule enable/disable: ✅")
  println("└─ Default routing: ✅")
}

// 실행
main()
