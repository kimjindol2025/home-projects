// ============================================
// Circuit Breaker - Cascading Failure Prevention
// ============================================
// 장애 전파 방지 패턴
// CLOSED → OPEN → HALF_OPEN → CLOSED
//
// 작성: Claude Code AI (2026-03-02)
// 난이도: ⭐⭐⭐⭐ 고급
// ============================================

// ============================================
// Part 1: 기본 구조
// ============================================

/// 서킷 브레이커 상태
enum CircuitBreakerState {
  Closed,      // 정상 - 모든 요청 통과
  Open,        // 장애 - 요청 차단
  HalfOpen     // 복구 시도 - 제한된 요청 통과
}

/// 서킷 브레이커 상태 추적
struct CircuitBreakerStatus {
  state: CircuitBreakerState,
  failure_count: int,
  success_count: int,
  last_failure_time: int,
  total_failures: int,
  total_successes: int
}

/// 서킷 브레이커 설정
struct CircuitBreakerConfig {
  failure_threshold: int,    // 몇 번 실패하면 OPEN?
  success_threshold: int,    // HALF_OPEN에서 몇 번 성공하면 CLOSED?
  timeout: int,              // OPEN 상태 유지 시간 (ms)
  name: string               // 서킷 브레이커 이름
}

/// 서킷 브레이커 상태 객체
struct CircuitBreaker {
  config: CircuitBreakerConfig,
  status: CircuitBreakerStatus,
  last_state_change_time: int
}

/// 서킷 브레이커 초기화
fn init_circuit_breaker(name: string) -> CircuitBreaker {
  println()
  println("⚡ Circuit Breaker Initialized: \" + name + "\"")
  println("├─ Failure Threshold: 5")
  println("├─ Success Threshold: 2")
  println("└─ Timeout: 30000ms\"")

  config = CircuitBreakerConfig {
    failure_threshold: 5,
    success_threshold: 2,
    timeout: 30000,
    name: name
  }

  status = CircuitBreakerStatus {
    state: CircuitBreakerState.Closed,
    failure_count: 0,
    success_count: 0,
    last_failure_time: 0,
    total_failures: 0,
    total_successes: 0
  }

  return CircuitBreaker {
    config: config,
    status: status,
    last_state_change_time: 0
  }
}

// ============================================
// Part 2: 상태 전환
// ============================================

/// 상태를 OPEN으로 변경
fn transition_to_open(cb: CircuitBreaker, current_time: int) -> CircuitBreaker {
  println()
  println("🔴 Circuit Breaker \" + cb.config.name + "\" CLOSED → OPEN\"")

  cb.status.state = CircuitBreakerState.Open
  cb.last_state_change_time = current_time

  return cb
}

/// 상태를 HALF_OPEN으로 변경
fn transition_to_half_open(cb: CircuitBreaker, current_time: int) -> CircuitBreaker {
  println()
  println("🟡 Circuit Breaker \" + cb.config.name + "\" OPEN → HALF_OPEN\"")

  cb.status.state = CircuitBreakerState.HalfOpen
  cb.status.failure_count = 0
  cb.status.success_count = 0
  cb.last_state_change_time = current_time

  return cb
}

/// 상태를 CLOSED로 변경 (복구)
fn transition_to_closed(cb: CircuitBreaker, current_time: int) -> CircuitBreaker {
  println()
  println("🟢 Circuit Breaker \" + cb.config.name + "\" HALF_OPEN → CLOSED\"")

  cb.status.state = CircuitBreakerState.Closed
  cb.status.failure_count = 0
  cb.status.success_count = 0
  cb.last_state_change_time = current_time

  return cb
}

// ============================================
// Part 3: 성공/실패 기록
// ============================================

/// 성공 기록
fn record_success(cb: CircuitBreaker, current_time: int) -> CircuitBreaker {
  cb.status.total_successes = cb.status.total_successes + 1

  if cb.status.state == CircuitBreakerState.Closed {
    // CLOSED 상태에서 성공: 실패 카운트 리셋
    cb.status.failure_count = 0
    println("   ✅ Success (CLOSED) - failure_count reset to 0\"")

  } else if cb.status.state == CircuitBreakerState.HalfOpen {
    // HALF_OPEN 상태에서 성공: 성공 카운트 증가
    cb.status.success_count = cb.status.success_count + 1
    println("   ✅ Success (HALF_OPEN) - success_count: \" +
            to_string(cb.status.success_count) + \"/\" +
            to_string(cb.config.success_threshold) + "\"")

    // 성공 threshold 도달하면 CLOSED로 복구
    if cb.status.success_count >= cb.config.success_threshold {
      cb = transition_to_closed(cb, current_time)
    }
  }

  return cb
}

/// 실패 기록
fn record_failure(cb: CircuitBreaker, current_time: int) -> CircuitBreaker {
  cb.status.total_failures = cb.status.total_failures + 1
  cb.status.last_failure_time = current_time

  if cb.status.state == CircuitBreakerState.Closed {
    // CLOSED 상태에서 실패: 실패 카운트 증가
    cb.status.failure_count = cb.status.failure_count + 1
    println("   ❌ Failure (CLOSED) - failure_count: \" +
            to_string(cb.status.failure_count) + \"/\" +
            to_string(cb.config.failure_threshold) + "\"")

    // 실패 threshold 도달하면 OPEN으로
    if cb.status.failure_count >= cb.config.failure_threshold {
      cb = transition_to_open(cb, current_time)
    }

  } else if cb.status.state == CircuitBreakerState.HalfOpen {
    // HALF_OPEN 상태에서 실패: 다시 OPEN으로
    println("   ❌ Failure (HALF_OPEN) - back to OPEN\"")
    cb = transition_to_open(cb, current_time)

  } else {
    // OPEN 상태에서 실패: 이미 차단 중
    println("   ❌ Failure (OPEN) - request blocked\"")
  }

  return cb
}

// ============================================
// Part 4: 요청 처리
// ============================================

/// 요청이 통과 가능한지 확인
fn is_request_allowed(cb: CircuitBreaker, current_time: int) -> bool {
  if cb.status.state == CircuitBreakerState.Closed {
    return true
  } else if cb.status.state == CircuitBreakerState.HalfOpen {
    // HALF_OPEN: 제한된 요청만 통과 (시뮬레이션: 모두 통과)
    return true
  } else {
    // OPEN: 타임아웃 확인
    time_since_open = current_time - cb.last_state_change_time
    if time_since_open >= cb.config.timeout {
      // 타임아웃 경과 → HALF_OPEN으로 전환하고 요청 허용
      return true
    }
    return false
  }
}

/// 타임아웃 확인 및 상태 업데이트
fn check_timeout(cb: CircuitBreaker, current_time: int) -> CircuitBreaker {
  if cb.status.state == CircuitBreakerState.Open {
    time_since_open = current_time - cb.last_state_change_time

    if time_since_open >= cb.config.timeout {
      println()
      println("⏱️  Timeout reached (\" + to_string(time_since_open) + \"ms)\"")
      cb = transition_to_half_open(cb, current_time)
    }
  }

  return cb
}

// ============================================
// Part 5: 상태 조회 및 모니터링
// ============================================

/// 서킷 브레이커 상태 출력
fn print_circuit_breaker_status(cb: CircuitBreaker) {
  println()
  println("📊 Circuit Breaker: \" + cb.config.name + "\"")

  state_str = \"\"
  if cb.status.state == CircuitBreakerState.Closed {
    state_str = \"🟢 CLOSED\"
  } else if cb.status.state == CircuitBreakerState.Open {
    state_str = \"🔴 OPEN\"
  } else {
    state_str = \"🟡 HALF_OPEN\"
  }

  println(\"├─ State: \" + state_str)
  println(\"├─ Failures: \" + to_string(cb.status.failure_count) + \"/\" +
          to_string(cb.config.failure_threshold))
  println(\"├─ Successes: \" + to_string(cb.status.success_count) + \"/\" +
          to_string(cb.config.success_threshold))
  println(\"├─ Total: \" + to_string(cb.status.total_failures) + \" failures, \" +
          to_string(cb.status.total_successes) + \" successes\")
  println(\"└─ Last Failure: \" + to_string(cb.status.last_failure_time))
}

/// 서킷 브레이커 리셋
fn reset_circuit_breaker(cb: CircuitBreaker, current_time: int) -> CircuitBreaker {
  println()
  println(\"🔄 Resetting Circuit Breaker: \" + cb.config.name)

  cb.status.state = CircuitBreakerState.Closed
  cb.status.failure_count = 0
  cb.status.success_count = 0
  cb.last_state_change_time = current_time

  return cb
}

// ============================================
// Part 6: 테스트
// ============================================

fn test_init_circuit_breaker() {
  cb = init_circuit_breaker(\"test_breaker\")

  assert cb.config.failure_threshold == 5
  assert cb.config.success_threshold == 2
  assert cb.status.state == CircuitBreakerState.Closed

  println(\"✅ test_init_circuit_breaker passed\")
}

fn test_closed_to_open() {
  cb = init_circuit_breaker(\"test_breaker\")

  // 5번 실패
  for i = 0; i < 5; i = i + 1 {
    cb = record_failure(cb, 0)
  }

  assert cb.status.state == CircuitBreakerState.Open
  assert cb.status.failure_count == 5

  println(\"✅ test_closed_to_open passed\")
}

fn test_open_to_half_open() {
  cb = init_circuit_breaker(\"test_breaker\")

  // OPEN 상태로 전환
  for i = 0; i < 5; i = i + 1 {
    cb = record_failure(cb, 0)
  }

  assert cb.status.state == CircuitBreakerState.Open

  // 타임아웃 경과 후 check_timeout 호출
  cb = check_timeout(cb, 30001)

  assert cb.status.state == CircuitBreakerState.HalfOpen

  println(\"✅ test_open_to_half_open passed\")
}

fn test_half_open_to_closed() {
  cb = init_circuit_breaker(\"test_breaker\")

  // OPEN으로 전환
  for i = 0; i < 5; i = i + 1 {
    cb = record_failure(cb, 0)
  }

  // HALF_OPEN으로 전환
  cb = check_timeout(cb, 30001)

  assert cb.status.state == CircuitBreakerState.HalfOpen

  // 2번 성공
  cb = record_success(cb, 30001)
  cb = record_success(cb, 30001)

  assert cb.status.state == CircuitBreakerState.Closed

  println(\"✅ test_half_open_to_closed passed\")
}

fn test_half_open_back_to_open() {
  cb = init_circuit_breaker(\"test_breaker\")

  // OPEN → HALF_OPEN
  for i = 0; i < 5; i = i + 1 {
    cb = record_failure(cb, 0)
  }

  cb = check_timeout(cb, 30001)

  assert cb.status.state == CircuitBreakerState.HalfOpen

  // HALF_OPEN에서 실패 → 다시 OPEN
  cb = record_failure(cb, 30001)

  assert cb.status.state == CircuitBreakerState.Open

  println(\"✅ test_half_open_back_to_open passed\")
}

fn test_is_request_allowed() {
  cb = init_circuit_breaker(\"test_breaker\")

  // CLOSED: 요청 허용
  assert is_request_allowed(cb, 0) == true

  // OPEN: 요청 차단
  for i = 0; i < 5; i = i + 1 {
    cb = record_failure(cb, 0)
  }

  assert is_request_allowed(cb, 0) == false

  // 타임아웃 후: 요청 허용 (HALF_OPEN)
  allowed = is_request_allowed(cb, 30001)
  assert allowed == true

  println(\"✅ test_is_request_allowed passed\")
}

fn test_failure_count_reset_on_success() {
  cb = init_circuit_breaker(\"test_breaker\")

  // 2번 실패
  cb = record_failure(cb, 0)
  cb = record_failure(cb, 0)

  assert cb.status.failure_count == 2

  // 1번 성공 → 실패 카운트 리셋
  cb = record_success(cb, 0)

  assert cb.status.failure_count == 0

  println(\"✅ test_failure_count_reset_on_success passed\")
}

// ============================================
// 메인 테스트 실행
// ============================================

fn main() {
  println(\"⚡ Circuit Breaker - Tests\")
  println(\"═════════════════════════════════\")

  test_init_circuit_breaker()
  test_closed_to_open()
  test_open_to_half_open()
  test_half_open_to_closed()
  test_half_open_back_to_open()
  test_is_request_allowed()
  test_failure_count_reset_on_success()

  println()
  println(\"✅ All circuit breaker tests passed!\")
  println()
  println(\"📊 Summary:\")
  println(\"├─ State management: ✅\")
  println(\"├─ Failure detection: ✅\")
  println(\"├─ Timeout recovery: ✅\")
  println(\"├─ Success counting: ✅\")
  println(\"├─ Request blocking: ✅\")
  println(\"└─ State transitions: ✅\")
}

// 실행
main()
