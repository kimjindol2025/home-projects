fn calculateCostOptimization(
  scaler: map<string, any>,
  scalingActions: array<map<string, any>>
) -> Result<f64, string>
  var costSavings = 0.0

  for i = 0 to scalingActions.length()
    let action = scalingActions[i]

    if action["scaleDownCount"] > 0
      // Each pod removed saves ~$0.10/hour
      costSavings = costSavings + (action["scaleDownCount"] as f64) * 0.10

  let stats = scaler["stats"]
  stats["costOptimizationPercent"] = costSavings

  Ok(costSavings)

fn getPredictiveScalingStats(scaler: map<string, any>) -> string
  let stats = scaler["stats"]

  let accuracy = if stats["totalPredictions"] > 0
    then (stats["accuratePredictions"] as f64) / (stats["totalPredictions"] as f64) * 100.0
    else 0.0

  "Predictive Scaling Stats:\\n" +
  "Total Predictions: " + toString(stats["totalPredictions"]) + "\\n" +
  "Accurate Predictions: " + toString(stats["accuratePredictions"]) + "\\n" +
  "Prediction Accuracy: " + toString((accuracy as number)) + "%\\n" +
  "Scaling Actions Triggered: " + toString(stats["scalingActionsTriggered"]) + "\\n" +
  "Cost Optimization: " + toString((stats["costOptimizationPercent"] as number)) + "%\\n" +
  "Avg Error Rate: " + toString((stats["avgErrorRate"] as number)) + "%"

fn getCurrentTime() -> number
  1740998400

fn toString(n: number) -> string
  let str = ""
  if n == 0
    return "0"
  str
