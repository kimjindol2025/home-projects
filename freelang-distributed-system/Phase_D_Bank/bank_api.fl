// ============================================
// Distributed Bank API - Core Banking
// ============================================
// 분산 은행 시스템 - 핵심 기능
// 계좌 관리, 송금, 거래 기록
//
// 작성: Claude Code AI (2026-03-02)
// 난이도: ⭐⭐⭐⭐⭐ 박사 수준
// ============================================

// ============================================
// Part 1: 은행 데이터 구조
// ============================================

/// 계좌 상태
enum AccountStatus {
  Active,
  Frozen,
  Closed
}

/// 거래 타입
enum TransactionType {
  Deposit,
  Withdrawal,
  Transfer,
  Fee
}

/// 거래
struct Transaction {
  transaction_id: string,
  from_account: string,
  to_account: string,
  amount: int,        // 센트 단위
  transaction_type: TransactionType,
  timestamp: int,
  status: string,     // "pending", "completed", "failed"
  description: string
}

/// 계좌
struct Account {
  account_id: string,
  owner_name: string,
  balance: int,       // 센트 단위
  status: AccountStatus,
  created_at: int,
  last_transaction: int,
  transaction_count: int,
  daily_limit: int,
  daily_spent: int
}

/// 은행 상태
struct BankState {
  accounts: {string: Account},
  transactions: [Transaction],
  transaction_counter: int,
  total_deposits: int,
  total_withdrawals: int
}

/// 은행 API
struct BankAPI {
  state: BankState,
  config: BankConfig
}

/// 은행 설정
struct BankConfig {
  min_balance: int,
  max_transfer: int,
  transaction_fee: int,
  daily_withdrawal_limit: int
}

/// 은행 초기화
fn init_bank() -> BankAPI {
  println()
  println("🏦 Bank System Initialized")
  println("├─ Min Balance: $0.01")
  println("├─ Max Transfer: $100,000.00")
  println("├─ Transaction Fee: $0.50")
  println("└─ Daily Withdrawal Limit: $10,000.00")

  config = BankConfig {
    min_balance: 1,           // 0.01달러
    max_transfer: 10000000,   // 100,000달러
    transaction_fee: 50,      // 0.50달러
    daily_withdrawal_limit: 1000000  // 10,000달러
  }

  state = BankState {
    accounts: {},
    transactions: [],
    transaction_counter: 0,
    total_deposits: 0,
    total_withdrawals: 0
  }

  return BankAPI {
    state: state,
    config: config
  }
}

// ============================================
// Part 2: 계좌 관리
// ============================================

/// 계좌 생성
fn create_account(
  bank: BankAPI,
  account_id: string,
  owner_name: string,
  initial_balance: int,
  current_time: int
) -> BankAPI {
  println()
  println("📋 Creating account: " + account_id)

  if bank.state.accounts[account_id] != null {
    println("   ❌ Account already exists")
    return bank
  }

  account = Account {
    account_id: account_id,
    owner_name: owner_name,
    balance: initial_balance,
    status: AccountStatus.Active,
    created_at: current_time,
    last_transaction: current_time,
    transaction_count: 0,
    daily_limit: bank.config.daily_withdrawal_limit,
    daily_spent: 0
  }

  bank.state.accounts[account_id] = account

  println("   ✅ Account created")
  println("   ├─ Owner: " + owner_name)
  println("   ├─ Balance: $" + to_string(initial_balance / 100) + "." +
          to_string(initial_balance % 100))
  println("   └─ Status: Active")

  return bank
}

/// 계좌 조회
fn get_account(bank: BankAPI, account_id: string) -> Account {
  account = bank.state.accounts[account_id]

  if account == null {
    println("   ❌ Account not found: " + account_id)
    return null
  }

  return account
}

/// 계좌 상태 변경
fn update_account_status(
  bank: BankAPI,
  account_id: string,
  new_status: AccountStatus
) -> BankAPI {
  account = bank.state.accounts[account_id]

  if account == null {
    return bank
  }

  old_status = account.status
  account.status = new_status

  status_str = ""
  if new_status == AccountStatus.Active {
    status_str = "Active"
  } else if new_status == AccountStatus.Frozen {
    status_str = "Frozen"
  } else {
    status_str = "Closed"
  }

  println()
  println("⚙️  Account status updated: " + account_id)
  println("   └─ New status: " + status_str)

  return bank
}

// ============================================
// Part 3: 거래 처리
// ============================================

/// 거래 생성
fn create_transaction(
  bank: BankAPI,
  from_account: string,
  to_account: string,
  amount: int,
  tx_type: TransactionType,
  description: string,
  current_time: int
) -> Transaction {
  transaction_id = "tx_" + from_account + "_" +
                   to_string(bank.state.transaction_counter)

  bank.state.transaction_counter = bank.state.transaction_counter + 1

  return Transaction {
    transaction_id: transaction_id,
    from_account: from_account,
    to_account: to_account,
    amount: amount,
    transaction_type: tx_type,
    timestamp: current_time,
    status: "pending",
    description: description
  }
}

/// 입금
fn deposit(
  bank: BankAPI,
  account_id: string,
  amount: int,
  current_time: int
) -> BankAPI {
  println()
  println("💰 Deposit to account: " + account_id)

  account = bank.state.accounts[account_id]

  if account == null {
    println("   ❌ Account not found")
    return bank
  }

  if account.status != AccountStatus.Active {
    println("   ❌ Account is not active")
    return bank
  }

  // 거래 생성 및 기록
  tx = create_transaction(bank, "system", account_id, amount,
                         TransactionType.Deposit, "Deposit", current_time)
  bank.state.transactions = bank.state.transactions + [tx]

  // 잔액 업데이트
  account.balance = account.balance + amount
  account.last_transaction = current_time
  account.transaction_count = account.transaction_count + 1

  bank.state.total_deposits = bank.state.total_deposits + amount

  println("   ✅ Deposit successful")
  println("   ├─ Amount: $" + to_string(amount / 100) + "." +
          to_string(amount % 100))
  println("   └─ New Balance: $" + to_string(account.balance / 100) + "." +
          to_string(account.balance % 100))

  return bank
}

/// 출금
fn withdraw(
  bank: BankAPI,
  account_id: string,
  amount: int,
  current_time: int
) -> BankAPI {
  println()
  println("🏧 Withdraw from account: " + account_id)

  account = bank.state.accounts[account_id]

  if account == null {
    println("   ❌ Account not found")
    return bank
  }

  if account.status != AccountStatus.Active {
    println("   ❌ Account is not active")
    return bank
  }

  // 일일 한도 확인
  if account.daily_spent + amount > account.daily_limit {
    println("   ❌ Daily limit exceeded")
    return bank
  }

  // 잔액 확인
  if account.balance < amount {
    println("   ❌ Insufficient balance")
    return bank
  }

  // 거래 생성
  tx = create_transaction(bank, account_id, "system", amount,
                         TransactionType.Withdrawal, "Withdrawal", current_time)
  bank.state.transactions = bank.state.transactions + [tx]

  // 잔액 업데이트
  account.balance = account.balance - amount
  account.daily_spent = account.daily_spent + amount
  account.last_transaction = current_time
  account.transaction_count = account.transaction_count + 1

  bank.state.total_withdrawals = bank.state.total_withdrawals + amount

  println("   ✅ Withdrawal successful")
  println("   ├─ Amount: $" + to_string(amount / 100) + "." +
          to_string(amount % 100))
  println("   └─ New Balance: $" + to_string(account.balance / 100) + "." +
          to_string(account.balance % 100))

  return bank
}

/// 송금 (계좌 간)
fn transfer(
  bank: BankAPI,
  from_account: string,
  to_account: string,
  amount: int,
  current_time: int
) -> BankAPI {
  println()
  println("💸 Transfer: " + from_account + " → " + to_account)

  from = bank.state.accounts[from_account]
  to = bank.state.accounts[to_account]

  if from == null {
    println("   ❌ Source account not found")
    return bank
  }

  if to == null {
    println("   ❌ Destination account not found")
    return bank
  }

  if from.status != AccountStatus.Active {
    println("   ❌ Source account is not active")
    return bank
  }

  // 거래 수수료
  total_amount = amount + bank.config.transaction_fee

  // 잔액 확인
  if from.balance < total_amount {
    println("   ❌ Insufficient balance (including fee)")
    return bank
  }

  // 거래 생성
  tx = create_transaction(bank, from_account, to_account, amount,
                         TransactionType.Transfer, "Transfer", current_time)
  bank.state.transactions = bank.state.transactions + [tx]

  // 발신자 잔액 업데이트
  from.balance = from.balance - total_amount
  from.last_transaction = current_time
  from.transaction_count = from.transaction_count + 1

  // 수신자 잔액 업데이트
  to.balance = to.balance + amount
  to.last_transaction = current_time
  to.transaction_count = to.transaction_count + 1

  println("   ✅ Transfer successful")
  println("   ├─ Amount: $" + to_string(amount / 100) + "." +
          to_string(amount % 100))
  println("   ├─ Fee: $" + to_string(bank.config.transaction_fee / 100) + "." +
          to_string(bank.config.transaction_fee % 100))
  println("   └─ From Balance: $" + to_string(from.balance / 100) + "." +
          to_string(from.balance % 100))

  return bank
}

// ============================================
// Part 4: 통계 및 조회
// ============================================

/// 계좌 정보 출력
fn print_account_info(account: Account) {
  println()
  println("📊 Account: " + account.account_id)
  println("├─ Owner: " + account.owner_name)
  println("├─ Balance: $" + to_string(account.balance / 100) + "." +
          to_string(account.balance % 100))
  println("├─ Status: " + (account.status == AccountStatus.Active ? "Active" :
          account.status == AccountStatus.Frozen ? "Frozen" : "Closed"))
  println("├─ Created: " + to_string(account.created_at))
  println("├─ Transactions: " + to_string(account.transaction_count))
  println("└─ Daily Spent: $" + to_string(account.daily_spent / 100) + "." +
          to_string(account.daily_spent % 100))
}

/// 거래 기록 조회
fn get_transaction_history(bank: BankAPI, account_id: string) -> [Transaction] {
  history = []

  for tx in bank.state.transactions {
    if tx.from_account == account_id || tx.to_account == account_id {
      history = history + [tx]
    }
  }

  return history
}

// ============================================
// Part 5: 테스트
// ============================================

fn test_init_bank() {
  bank = init_bank()

  assert bank.config.min_balance == 1
  assert bank.config.transaction_fee == 50

  println("✅ test_init_bank passed")
}

fn test_create_account() {
  bank = init_bank()

  bank = create_account(bank, "acc001", "Alice", 50000, 1000)

  assert bank.state.accounts["acc001"] != null

  println("✅ test_create_account passed")
}

fn test_deposit() {
  bank = init_bank()
  bank = create_account(bank, "acc001", "Alice", 50000, 1000)

  bank = deposit(bank, "acc001", 10000, 1000)

  account = bank.state.accounts["acc001"]
  assert account.balance == 60000

  println("✅ test_deposit passed")
}

fn test_withdraw() {
  bank = init_bank()
  bank = create_account(bank, "acc001", "Alice", 50000, 1000)

  bank = withdraw(bank, "acc001", 10000, 1000)

  account = bank.state.accounts["acc001"]
  assert account.balance == 40000

  println("✅ test_withdraw passed")
}

fn test_transfer() {
  bank = init_bank()
  bank = create_account(bank, "acc001", "Alice", 50000, 1000)
  bank = create_account(bank, "acc002", "Bob", 30000, 1000)

  bank = transfer(bank, "acc001", "acc002", 10000, 1000)

  alice = bank.state.accounts["acc001"]
  bob = bank.state.accounts["acc002"]

  // Alice: 50000 - (10000 + 50) = 39950
  assert alice.balance == 39950
  // Bob: 30000 + 10000 = 40000
  assert bob.balance == 40000

  println("✅ test_transfer passed")
}

fn test_insufficient_balance() {
  bank = init_bank()
  bank = create_account(bank, "acc001", "Alice", 5000, 1000)

  bank = withdraw(bank, "acc001", 10000, 1000)

  account = bank.state.accounts["acc001"]
  // 출금 실패, 잔액 유지
  assert account.balance == 5000

  println("✅ test_insufficient_balance passed")
}

fn test_get_transaction_history() {
  bank = init_bank()
  bank = create_account(bank, "acc001", "Alice", 50000, 1000)
  bank = create_account(bank, "acc002", "Bob", 30000, 1000)

  bank = deposit(bank, "acc001", 10000, 1000)
  bank = transfer(bank, "acc001", "acc002", 10000, 1000)

  history = get_transaction_history(bank, "acc001")

  assert len(history) >= 2

  println("✅ test_get_transaction_history passed")
}

// ============================================
// 메인 테스트 실행
// ============================================

fn main() {
  println("🏦 Bank API - Tests")
  println("═════════════════════════════════")

  test_init_bank()
  test_create_account()
  test_deposit()
  test_withdraw()
  test_transfer()
  test_insufficient_balance()
  test_get_transaction_history()

  println()
  println("✅ All bank API tests passed!")
  println()
  println("📊 Summary:")
  println("├─ Account creation: ✅")
  println("├─ Deposit: ✅")
  println("├─ Withdraw: ✅")
  println("├─ Transfer: ✅")
  println("├─ Balance validation: ✅")
  println("├─ Transaction history: ✅")
  println("└─ Fee calculation: ✅")
}

// 실행
main()
