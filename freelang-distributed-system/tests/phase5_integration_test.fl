  if testBatchingWithGateway() { passedTests = passedTests + 1 }
  totalTests = totalTests + 1

  if testFullPipeline() { passedTests = passedTests + 1 }
  totalTests = totalTests + 1

  if testPerformanceOptimization() { passedTests = passedTests + 1 }
