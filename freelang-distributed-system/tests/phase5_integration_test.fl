  if testBulkProcessing() { passedTests = passedTests + 1 }
  totalTests = totalTests + 1

  if testErrorIsolation() { passedTests = passedTests + 1 }
  totalTests = totalTests + 1

  if testBatchOptimization() { passedTests = passedTests + 1 }
