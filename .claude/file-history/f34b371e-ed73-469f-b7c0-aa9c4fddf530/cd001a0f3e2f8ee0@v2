## 📝 실습: 은행 계좌 시스템

```python
class BankAccount:
    """은행 계좌"""

    def __init__(self, account_holder, initial_balance=0):
        self.account_holder = account_holder
        self.balance = initial_balance
        print(f"{account_holder}님 계좌 개설 (잔액: {self.balance}원)")

    def deposit(self, amount):
        """입금"""
        self.balance += amount
        print(f"💰 입금: {amount}원 → 현재 잔액: {self.balance}원")

    def withdraw(self, amount):
        """출금"""
        if self.balance >= amount:
            self.balance -= amount
            print(f"💸 출금: {amount}원 → 현재 잔액: {self.balance}원")
        else:
            print(f"❌ 잔액 부족! (현재: {self.balance}원)")

# 사용
account1 = BankAccount("설계자", 10000)
account1.deposit(5000)
account1.withdraw(3000)

account2 = BankAccount("클로드", 0)
account2.deposit(1000)
account2.withdraw(500)
```

