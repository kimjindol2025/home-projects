## 📝 실습: 로봇 시스템 설계

```python
class GogsRobot:
    """실험 데이터를 수집하는 로봇"""

    def __init__(self, name, model_id):
        self.name = name
        self.model_id = model_id
        self.data_count = 0
        print(f"🤖 로봇 [{self.name}] 가동 시작")

    def collect_data(self):
        """데이터 수집"""
        self.data_count += 1
        print(f"  {self.name}: 데이터 {self.data_count}건 수집")

    def report_status(self):
        """상태 보고"""
        print(f"로봇: {self.name} | 누적 데이터: {self.data_count}")

# 로봇 생성
robot_a = GogsRobot("알파", "v1.0")
robot_b = GogsRobot("베타", "v2.0")

# 작업 지시
robot_a.collect_data()
robot_a.collect_data()
robot_b.collect_data()

# 상태 보고
robot_a.report_status()  # 로봇: 알파 | 누적 데이터: 2
robot_b.report_status()  # 로봇: 베타 | 누적 데이터: 1
```

