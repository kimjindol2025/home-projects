def test_dynamic_typing():
    """변수는 런타임에 타입 결정"""
    x = 42
    assert ObjectAnalyzer.analyze(x).type_name == "int"

    x = "hello"
    assert ObjectAnalyzer.analyze(x).type_name == "str"

    x = [1, 2, 3]
    assert ObjectAnalyzer.analyze(x).type_name == "list"


def test_runtime_type_check():
    """타입 검사는 런타임에 발생"""
    def add(a, b):
        return a + b

    # 정수 더하기
    assert add(1, 2) == 3

    # 문자열 연결
    assert add("hello", " world") == "hello world"


def test_type_flexibility():
    """같은 함수가 다양한 타입 처리"""
    def get_length(obj):
        return len(obj)

    assert get_length("hello") == 5
    assert get_length([1, 2, 3]) == 3
    assert get_length({"a": 1, "b": 2}) == 2


def test_late_binding():
    """Late binding: 타입이 나중에 결정"""
    values = [42, "hello", [1, 2, 3]]

    for val in values:
        info = ObjectAnalyzer.analyze(val)
        # 각 객체의 타입이 실행 중에 결정됨
        assert info.type_name in ["int", "str", "list"]
