def test_object_id_is_hex_string():
    """객체 ID는 16진수 문자열"""
    info = ObjectAnalyzer.analyze([1, 2, 3])
    assert info.memory_address.startswith("0x")
    assert isinstance(info.memory_address, str)


def test_same_variable_same_id():
    """같은 변수는 같은 ID"""
    obj = [1, 2, 3]
    info1 = ObjectAnalyzer.analyze(obj)
    info2 = ObjectAnalyzer.analyze(obj)
    assert info1.memory_address == info2.memory_address


def test_different_objects_different_id():
    """다른 객체는 다른 ID"""
    list1 = [1, 2, 3]
    list2 = [1, 2, 3]
    info1 = ObjectAnalyzer.analyze(list1)
    info2 = ObjectAnalyzer.analyze(list2)
    assert info1.memory_address != info2.memory_address


def test_id_immutable_integer():
    """Small Integer는 캐시되어 같은 ID"""
    a = 100
    b = 100
    # -5 ~ 256 범위의 정수는 캐시됨
    assert id(a) == id(b)


def test_id_large_integer():
    """큰 정수는 캐시되지 않음"""
    a = 257
    b = 257
    # 256 초과 정수는 캐시되지 않음
    assert id(a) != id(b)


