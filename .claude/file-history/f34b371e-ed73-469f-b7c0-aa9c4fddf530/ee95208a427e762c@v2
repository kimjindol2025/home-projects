# 카테고리 3: Identity (is) vs Equality (==) (5개 테스트)
# ============================================================================

def test_identity_same_variable():
    """같은 변수는 Identity 만족"""
    obj = [1, 2, 3]
    assert obj is obj


def test_equality_different_lists():
    """서로 다른 리스트는 값은 같지만 Identity는 다름"""
    list1 = [1, 2, 3]
    list2 = [1, 2, 3]
    assert list1 == list2  # 값이 같음
    assert not (list1 is list2)  # 객체는 다름


def test_identity_after_assignment():
    """할당 후 Identity는 유지"""
    obj = [1, 2, 3]
    ref = obj
    assert ref is obj
    assert ref == obj


def test_equality_same_integer():
    """작은 정수는 캐시되어 Identity까지 만족"""
    a = 100
    b = 100
    assert a == b
    assert a is b


def test_identity_none():
    """None은 싱글톤이므로 항상 is로 비교"""
    a = None
    b = None
    assert a is b
    assert a == b


