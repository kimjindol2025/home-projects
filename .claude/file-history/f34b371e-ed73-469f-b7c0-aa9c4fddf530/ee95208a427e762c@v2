# 카테고리 7: Small Integer Caching (5개 테스트)
# ============================================================================

def test_small_integer_cached():
    """-5 ~ 256 범위의 정수는 캐시됨"""
    for i in range(-5, 257):
        a = i
        b = i
        assert id(a) == id(b), f"정수 {i}는 캐시되어야 함"


def test_large_integer_not_cached():
    """256 초과 정수는 캐시되지 않음"""
    a = 257
    b = 257
    assert id(a) != id(b)


def test_negative_integer_cached_boundary():
    """-5는 캐시, -6은 아님"""
    # -5는 캐시
    a = -5
    b = -5
    assert id(a) == id(b)

    # -6은 캐시 안 됨
    c = -6
    d = -6
    assert id(c) != id(d)


def test_positive_integer_cached_boundary():
    """256은 캐시, 257은 아님"""
    # 256은 캐시
    a = 256
    b = 256
    assert id(a) == id(b)

    # 257은 캐시 안 됨
    c = 257
    d = 257
    assert id(c) != id(d)


def test_string_interning():
    """일부 문자열은 Intern됨"""
    # 간단한 식별자는 intern됨
    a = "hello"
    b = "hello"
    # Python 구현에 따라 다르지만, 종종 intern됨
    # 이 테스트는 정보 제공 목적
    assert a == b


