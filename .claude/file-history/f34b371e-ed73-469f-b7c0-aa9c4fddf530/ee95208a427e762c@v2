def test_size_zero_integer():
    """정수의 메모리 크기"""
    info = ObjectAnalyzer.analyze(0)
    assert info.size_bytes > 0


def test_size_string_increases():
    """문자열은 길수록 크기 증가"""
    small = ObjectAnalyzer.analyze("x")
    large = ObjectAnalyzer.analyze("x" * 100)
    assert large.size_bytes > small.size_bytes


def test_size_empty_list():
    """빈 리스트도 메타데이터 차지"""
    info = ObjectAnalyzer.analyze([])
    assert info.size_bytes > 0


def test_size_list_capacity():
    """리스트는 원소 수보다 많은 메모리 할당"""
    info1 = ObjectAnalyzer.analyze([1])
    info2 = ObjectAnalyzer.analyze([1, 2, 3])
    # 정확한 크기는 Python 구현에 따라 다르지만,
    # info2가 더 커야 함
    assert info2.size_bytes >= info1.size_bytes


def test_size_dict():
    """딕셔너리의 메모리 크기"""
    info = ObjectAnalyzer.analyze({"key": "value"})
    assert info.size_bytes > 0


def test_size_bytes_always_positive():
    """모든 객체의 메모리 크기는 양수"""
    objects = [42, 3.14, "test", [1, 2], {"a": 1}, (1, 2), True, None]
    for obj in objects:
        info = ObjectAnalyzer.analyze(obj)
        assert info.size_bytes > 0


