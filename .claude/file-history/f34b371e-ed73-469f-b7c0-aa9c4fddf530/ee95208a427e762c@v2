def test_type_name_extraction():
    """타입 이름 추출"""
    assert ObjectAnalyzer.analyze(42).type_name == "int"
    assert ObjectAnalyzer.analyze("str").type_name == "str"
    assert ObjectAnalyzer.analyze([]).type_name == "list"
    assert ObjectAnalyzer.analyze({}).type_name == "dict"
    assert ObjectAnalyzer.analyze(()).type_name == "tuple"


def test_type_object_is_type():
    """타입 객체는 실제 타입"""
    info = ObjectAnalyzer.analyze(42)
    assert info.type_object is int
    assert isinstance(42, info.type_object)


def test_type_object_list():
    """리스트 타입 객체"""
    info = ObjectAnalyzer.analyze([])
    assert info.type_object is list


def test_type_object_consistency():
    """같은 값의 타입 객체는 동일"""
    info1 = ObjectAnalyzer.analyze(42)
    info2 = ObjectAnalyzer.analyze(99)
    assert info1.type_object is info2.type_object


def test_type_object_different_types():
    """다른 타입은 다른 타입 객체"""
    int_info = ObjectAnalyzer.analyze(42)
    str_info = ObjectAnalyzer.analyze("42")
    assert int_info.type_object is not str_info.type_object


