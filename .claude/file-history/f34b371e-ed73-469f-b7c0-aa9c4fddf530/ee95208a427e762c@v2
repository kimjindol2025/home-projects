def test_integer_object_analysis():
    """정수 객체 분석"""
    info = ObjectAnalyzer.analyze(42)
    assert info.type_name == "int"
    assert info.value == 42
    assert info.is_mutable is False
    assert info.size_bytes > 0


def test_string_object_analysis():
    """문자열 객체 분석"""
    info = ObjectAnalyzer.analyze("hello")
    assert info.type_name == "str"
    assert info.value == "hello"
    assert info.is_mutable is False
    assert info.size_bytes > 0


def test_list_object_analysis():
    """리스트 객체 분석"""
    test_list = [1, 2, 3]
    info = ObjectAnalyzer.analyze(test_list)
    assert info.type_name == "list"
    assert info.value == [1, 2, 3]
    assert info.is_mutable is True
