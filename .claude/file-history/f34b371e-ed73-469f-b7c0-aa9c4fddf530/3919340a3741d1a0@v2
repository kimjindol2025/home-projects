## 플러그인 시스템

### 1. 플러그인 인터페이스 정의

```python
from abc import ABC, abstractmethod

class PluginInterface(ABC):
    """모든 플러그인이 따를 계약"""

    @abstractmethod
    def get_plugin_name(self) -> str:
        pass

    @abstractmethod
    def get_plugin_version(self) -> str:
        pass

    @abstractmethod
    def execute(self):
        pass
```

### 2. 플러그인 구현

```python
class HelloPlugin(PluginInterface):
    def get_plugin_name(self) -> str:
        return "Hello Plugin"

    def get_plugin_version(self) -> str:
        return "1.0.0"

    def execute(self):
        return "Hello from plugin!"


class CalculatorPlugin(PluginInterface):
    def get_plugin_name(self) -> str:
        return "Calculator Plugin"

    def get_plugin_version(self) -> str:
        return "2.0.0"

    def execute(self):
        return {"1+1": 2, "2*3": 6}
```

### 3. 플러그인 시스템 관리

```python
class PluginSystem:
    def __init__(self):
        self.plugins = {}

    def register_plugin(self, name: str, plugin: PluginInterface) -> bool:
        """플러그인 등록"""
        if not isinstance(plugin, PluginInterface):
            return False
        self.plugins[name] = plugin
        return True

    def execute_plugin(self, name: str):
        """플러그인 실행"""
        if name not in self.plugins:
            return None
        return self.plugins[name].execute()

    def list_plugins(self):
        """플러그인 목록"""
        return [
            {
                "name": plugin.get_plugin_name(),
                "version": plugin.get_plugin_version(),
            }
            for plugin in self.plugins.values()
        ]
```

### 4. 사용 예제

```python
system = PluginSystem()

# 플러그인 등록
system.register_plugin("hello", HelloPlugin())
system.register_plugin("calculator", CalculatorPlugin())

# 플러그인 목록
print(system.list_plugins())

# 플러그인 실행
print(system.execute_plugin("hello"))
print(system.execute_plugin("calculator"))
```

