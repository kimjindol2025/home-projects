"""
v1.3 테스트: 첫 번째 리스트
"""

from src.v1_3_my_first_list import my_first_list


def test_my_first_list_returns_list():
    """반환값이 리스트"""
    result = my_first_list()
    assert isinstance(result, list)


def test_initial_equipment():
    """초기 장비 3개"""
    result = my_first_list()
    assert len(result) == 4  # append() 후이므로 4개
    assert result[0] == "현미경"
    assert result[2] == "시험관"


def test_list_indexing_zero_based():
    """0번 인덱싱"""
    result = my_first_list()
    assert result[0] == "현미경"


def test_list_append():
    """append() 추가 후 4개"""
    result = my_first_list()
    # equipment.append("온도계")가 실행되었으므로
    assert len(result) == 4
    assert result[3] == "온도계"


def test_list_modification():
    """값 수정 (비커 → 전자저울)"""
    result = my_first_list()
    # equipment[1] = "전자저울"이 실행되었으므로
    assert result[1] == "전자저울"


def test_list_length():
    """len() 함수 동작"""
    result = my_first_list()
    assert len(result) == 4


def test_final_equipment_list():
    """최종 리스트 상태"""
    result = my_first_list()
    expected = ["현미경", "전자저울", "시험관", "온도계"]
    assert result == expected


def test_list_contains_strings():
    """리스트의 모든 원소가 문자열"""
    result = my_first_list()
    for item in result:
        assert isinstance(item, str)
