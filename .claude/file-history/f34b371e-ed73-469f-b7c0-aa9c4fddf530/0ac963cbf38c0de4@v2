"""
v5.2 직접 SQL 쿼리 실행 예제
배운 개념을 SQL로 실제 구현하기
"""

import sqlite3


def run_sql_examples():
    """SQL 쿼리 예제 실행"""
    conn = sqlite3.connect('gogs_research.db')
    cursor = conn.cursor()

    print("=" * 70)
    print("📊 SQL 쿼리 실행 예제")
    print("=" * 70)

    # 【 예제 1: 기본 SELECT 】
    print("\n【 예제 1: 모든 연구자 조회 】")
    print("SQL: SELECT * FROM researchers;")
    cursor.execute('SELECT * FROM researchers')
    rows = cursor.fetchall()
    for row in rows:
        print(f"  ID: {row[0]}, 이름: {row[1]}, 이메일: {row[2]}")

    # 【 예제 2: WHERE 조건 】
    print("\n【 예제 2: 완료된 실험만 조회 】")
    print("SQL: SELECT subject, result FROM experiments WHERE status = 'completed';")
    cursor.execute("SELECT subject, result FROM experiments WHERE status = 'completed'")
    rows = cursor.fetchall()
    for subject, result in rows:
        print(f"  ✓ {subject}: {result}점")

    # 【 예제 3: JOIN - 여러 테이블 결합 】
    print("\n【 예제 3: 실험과 연구자 정보 함께 조회 (JOIN) 】")
    print("""SQL: SELECT e.subject, e.result, r.name
         FROM experiments e
         JOIN researchers r ON e.researcher_id = r.id
         WHERE e.status = 'completed';""")
    cursor.execute('''
        SELECT e.subject, e.result, r.name
        FROM experiments e
        JOIN researchers r ON e.researcher_id = r.id
        WHERE e.status = 'completed'
    ''')
    rows = cursor.fetchall()
    for subject, result, name in rows:
        print(f"  {subject}: {result}점 (연구자: {name})")

    # 【 예제 4: COUNT - 개수 세기 】
    print("\n【 예제 4: 연구자별 실험 개수 세기 】")
    print("""SQL: SELECT r.name, COUNT(*) as exp_count
         FROM experiments e
         JOIN researchers r ON e.researcher_id = r.id
         GROUP BY r.name;""")
    cursor.execute('''
        SELECT r.name, COUNT(*) as exp_count
        FROM experiments e
        JOIN researchers r ON e.researcher_id = r.id
        GROUP BY r.name
    ''')
    rows = cursor.fetchall()
    for name, count in rows:
        print(f"  {name}: {count}개 실험")

    # 【 예제 5: ORDER BY - 정렬 】
    print("\n【 예제 5: 실험 결과 상위 3개 (정렬) 】")
    print("""SQL: SELECT subject, result
         FROM experiments
         WHERE result IS NOT NULL
         ORDER BY result DESC
         LIMIT 3;""")
    cursor.execute('''
        SELECT subject, result
        FROM experiments
        WHERE result IS NOT NULL
        ORDER BY result DESC
        LIMIT 3
    ''')
    rows = cursor.fetchall()
    for i, (subject, result) in enumerate(rows, 1):
        print(f"  {i}. {subject}: {result}점")

    # 【 예제 6: AVG - 평균 계산 】
    print("\n【 예제 6: 평균 실험 결과 계산 】")
    print("""SQL: SELECT AVG(result) as avg_result
         FROM experiments
         WHERE result IS NOT NULL;""")
    cursor.execute('''
        SELECT AVG(result) as avg_result
        FROM experiments
        WHERE result IS NOT NULL
    ''')
    row = cursor.fetchone()
    avg_result = row[0]
    print(f"  평균: {avg_result:.2f}점")

    # 【 예제 7: UPDATE - 데이터 수정 】
    print("\n【 예제 7: 실험 결과 업데이트 】")
    print("SQL: UPDATE experiments SET result = 97.5 WHERE id = 1;")
    cursor.execute('UPDATE experiments SET result = 97.5 WHERE id = 1')
    conn.commit()
    print(f"  ✓ {cursor.rowcount}개 행 업데이트됨")

    # 확인
    cursor.execute('SELECT result FROM experiments WHERE id = 1')
    new_result = cursor.fetchone()[0]
    print(f"  확인: ID 1의 새 결과 = {new_result}")

    # 【 예제 8: 상태별 실험 개수 】
    print("\n【 예제 8: 상태별 실험 개수 (GROUP BY) 】")
    print("""SQL: SELECT status, COUNT(*) as count
         FROM experiments
         GROUP BY status;""")
    cursor.execute('''
        SELECT status, COUNT(*) as count
        FROM experiments
        GROUP BY status
    ''')
    rows = cursor.fetchall()
    for status, count in rows:
        if status == 'completed':
            print(f"  ✅ {status}: {count}개")
        elif status == 'in_progress':
            print(f"  ⏳ {status}: {count}개")
        else:
            print(f"  ❓ {status}: {count}개")

    # 【 예제 9: IN 연산자 - 여러 조건 】
    print("\n【 예제 9: 특정 연구자의 실험 조회 (IN 연산자) 】")
    print("SQL: SELECT subject FROM experiments WHERE researcher_id IN (1, 2);")
    cursor.execute('SELECT subject FROM experiments WHERE researcher_id IN (1, 2)')
    rows = cursor.fetchall()
    for subject, in rows:
        print(f"  - {subject}")

    # 【 예제 10: LIKE - 텍스트 검색 】
    print("\n【 예제 10: 제목에 '테스트' 포함된 실험 검색 】")
    print("SQL: SELECT subject FROM experiments WHERE subject LIKE '%테스트%';")
    cursor.execute("SELECT subject FROM experiments WHERE subject LIKE '%테스트%'")
    rows = cursor.fetchall()
    for subject, in rows:
        print(f"  🔍 {subject}")

    conn.close()

    print("\n" + "=" * 70)
    print("저장 필수 너는 기록이 증명이다 gogs")
    print("=" * 70)


if __name__ == '__main__':
    run_sql_examples()
