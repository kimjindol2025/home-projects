"""
v1.4 Arithmetic Operators: 수학적 마법

매직 메소드를 통해 사용자 정의 객체에 산술 연산 능력을 부여합니다.

a + b → a.__add__(b)
a - b → a.__sub__(b)
a * b → a.__mul__(b)
a / b → a.__truediv__(b)
등등...
"""

from typing import Union
import math


class GogsVector:
    """
    파이썬 v1.4의 교육용 벡터 클래스

    매직 메소드를 통해 파이썬의 연산자들과 통합됩니다.
    """

    def __init__(self, x: float, y: float):
        """벡터 초기화"""
        self.x = x
        self.y = y

    def __repr__(self) -> str:
        """개발자 표현"""
        return f"GogsVector({self.x}, {self.y})"

    def __str__(self) -> str:
        """사용자 표현"""
        return f"({self.x}, {self.y})"

    # ========== 산술 연산자 ==========

    def __add__(self, other: 'GogsVector') -> 'GogsVector':
        """
        + 연산자: 벡터 덧셈

        v1 + v2 → v1.__add__(v2)
        """
        if isinstance(other, GogsVector):
            return GogsVector(self.x + other.x, self.y + other.y)
        return NotImplemented

    def __sub__(self, other: 'GogsVector') -> 'GogsVector':
        """
        - 연산자: 벡터 뺄셈

        v1 - v2 → v1.__sub__(v2)
        """
        if isinstance(other, GogsVector):
            return GogsVector(self.x - other.x, self.y - other.y)
        return NotImplemented

    def __mul__(self, scalar: Union[int, float]) -> 'GogsVector':
        """
        * 연산자: 스칼라 곱셈

        v * 2 → v.__mul__(2)
        """
        if isinstance(scalar, (int, float)):
            return GogsVector(self.x * scalar, self.y * scalar)
        return NotImplemented

    def __rmul__(self, scalar: Union[int, float]) -> 'GogsVector':
        """
        역방향 * 연산자: 스칼라가 왼쪽에 올 때

        2 * v → v.__rmul__(2)
        """
        return self.__mul__(scalar)

    def __truediv__(self, scalar: Union[int, float]) -> 'GogsVector':
        """
        / 연산자: 스칼라 나눗셈

        v / 2 → v.__truediv__(2)
        """
        if isinstance(scalar, (int, float)):
            if scalar == 0:
                raise ValueError("Cannot divide by zero")
            return GogsVector(self.x / scalar, self.y / scalar)
        return NotImplemented

    def __floordiv__(self, scalar: Union[int, float]) -> 'GogsVector':
        """
        // 연산자: 정수 나눗셈

        v // 2 → v.__floordiv__(2)
        """
        if isinstance(scalar, (int, float)):
            if scalar == 0:
                raise ValueError("Cannot divide by zero")
            return GogsVector(self.x // scalar, self.y // scalar)
        return NotImplemented

    def __mod__(self, scalar: Union[int, float]) -> 'GogsVector':
        """
        % 연산자: 나머지

        v % 2 → v.__mod__(2)
        """
        if isinstance(scalar, (int, float)):
            if scalar == 0:
                raise ValueError("Cannot divide by zero")
            return GogsVector(self.x % scalar, self.y % scalar)
        return NotImplemented

    def __pow__(self, power: Union[int, float]) -> 'GogsVector':
        """
        ** 연산자: 거듭제곱

        v ** 2 → v.__pow__(2)
        """
        if isinstance(power, (int, float)):
            return GogsVector(self.x ** power, self.y ** power)
        return NotImplemented

    # ========== 일원 연산자 ==========

    def __neg__(self) -> 'GogsVector':
        """
        단항 - 연산자: 음수화

        -v → v.__neg__()
        """
        return GogsVector(-self.x, -self.y)

    def __pos__(self) -> 'GogsVector':
        """
        단항 + 연산자: 양수화

        +v → v.__pos__()
        """
        return GogsVector(self.x, self.y)

    def __abs__(self) -> float:
        """
        abs() 함수: 벡터의 크기

        abs(v) → v.__abs__()
        """
        return math.sqrt(self.x ** 2 + self.y ** 2)

    # ========== 길이와 인덱싱 ==========

    def __len__(self) -> int:
        """
        len() 함수: 벡터의 크기를 정수로

        len(v) → v.__len__()
        """
        return int(abs(self))

    def __getitem__(self, index: int) -> float:
        """
        인덱싱: v[0], v[1]

        v[0] → v.__getitem__(0)
        """
        if index == 0:
            return self.x
        elif index == 1:
            return self.y
        else:
            raise IndexError(f"Vector index out of range")

    def __setitem__(self, index: int, value: float) -> None:
        """
        인덱싱 할당: v[0] = 5

        v[0] = 5 → v.__setitem__(0, 5)
        """
        if index == 0:
            self.x = value
        elif index == 1:
            self.y = value
        else:
            raise IndexError(f"Vector index out of range")


class GogsComplex:
    """복소수 클래스"""

    def __init__(self, real: float, imag: float):
        self.real = real
        self.imag = imag

    def __repr__(self) -> str:
        sign = "+" if self.imag >= 0 else "-"
        return f"GogsComplex({self.real}{sign}{abs(self.imag)}i)"

    def __add__(self, other: 'GogsComplex') -> 'GogsComplex':
        """복소수 덧셈"""
        if isinstance(other, GogsComplex):
            return GogsComplex(
                self.real + other.real,
                self.imag + other.imag
            )
        return NotImplemented

    def __mul__(self, other: Union['GogsComplex', int, float]) -> 'GogsComplex':
        """복소수 곱셈"""
        if isinstance(other, GogsComplex):
            # (a+bi)(c+di) = (ac-bd) + (ad+bc)i
            real = self.real * other.real - self.imag * other.imag
            imag = self.real * other.imag + self.imag * other.real
            return GogsComplex(real, imag)
        elif isinstance(other, (int, float)):
            return GogsComplex(self.real * other, self.imag * other)
        return NotImplemented

    def __rmul__(self, other: Union[int, float]) -> 'GogsComplex':
        """역방향 곱셈"""
        return self.__mul__(other)


def demonstrate_arithmetic_operators():
    """산술 연산자 시연"""
    print("\n" + "="*70)
    print("산술 연산자: 수학적 마법")
    print("="*70)

    # 벡터 덧셈
    print("\n  [1. 벡터 덧셈 (+)]")
    v1 = GogsVector(3, 4)
    v2 = GogsVector(1, 2)
    v3 = v1 + v2
    print(f"    v1 = {v1}")
    print(f"    v2 = {v2}")
    print(f"    v1 + v2 = {v3}")
    print(f"    (내부: v1.__add__(v2))")

    # 벡터 뺄셈
    print("\n  [2. 벡터 뺄셈 (-)]")
    v4 = v1 - v2
    print(f"    v1 - v2 = {v4}")

    # 스칼라 곱셈
    print("\n  [3. 스칼라 곱셈 (*)]")
    v5 = v1 * 2
    v6 = 3 * v1
    print(f"    v1 * 2 = {v5}")
    print(f"    3 * v1 = {v6}  (역방향 곱셈)")

    # 스칼라 나눗셈
    print("\n  [4. 스칼라 나눗셈 (/)]")
    v7 = v1 / 2
    print(f"    v1 / 2 = {v7}")

    # 단항 연산자
    print("\n  [5. 단항 연산자]")
    v8 = -v1
    print(f"    -v1 = {v8}  (음수화)")
    print(f"    abs(v1) = {abs(v1):.2f}  (벡터의 크기)")

    # 길이
    print("\n  [6. len() 함수]")
    print(f"    len(v1) = {len(v1)}  (크기를 정수로)")

    # 인덱싱
    print("\n  [7. 인덱싱]")
    print(f"    v1[0] = {v1[0]}  (x좌표)")
    print(f"    v1[1] = {v1[1]}  (y좌표)")

    # 인덱싱 할당
    print("\n  [8. 인덱싱 할당]")
    v1[0] = 10
    print(f"    v1[0] = 10")
    print(f"    v1 = {v1}")

    # 복소수
    print("\n  [9. 복소수 연산]")
    c1 = GogsComplex(1, 2)
    c2 = GogsComplex(3, 4)
    print(f"    c1 = {c1}")
    print(f"    c2 = {c2}")
    print(f"    c1 + c2 = {c1 + c2}")
    print(f"    c1 * c2 = {c1 * c2}")

    print("\n" + "="*70)


class Rational:
    """유리수 클래스"""

    def __init__(self, numerator: int, denominator: int):
        if denominator == 0:
            raise ValueError("Denominator cannot be zero")
        # 최대공약수로 약분
        from math import gcd
        g = gcd(abs(numerator), abs(denominator))
        self.numerator = numerator // g
        self.denominator = denominator // g

    def __repr__(self) -> str:
        return f"Rational({self.numerator}, {self.denominator})"

    def __str__(self) -> str:
        return f"{self.numerator}/{self.denominator}"

    def __add__(self, other: 'Rational') -> 'Rational':
        """유리수 덧셈"""
        if isinstance(other, Rational):
            num = self.numerator * other.denominator + other.numerator * self.denominator
            denom = self.denominator * other.denominator
            return Rational(num, denom)
        return NotImplemented

    def __sub__(self, other: 'Rational') -> 'Rational':
        """유리수 뺄셈"""
        if isinstance(other, Rational):
            num = self.numerator * other.denominator - other.numerator * self.denominator
            denom = self.denominator * other.denominator
            return Rational(num, denom)
        return NotImplemented

    def __mul__(self, other: 'Rational') -> 'Rational':
        """유리수 곱셈"""
        if isinstance(other, Rational):
            return Rational(
                self.numerator * other.numerator,
                self.denominator * other.denominator
            )
        return NotImplemented

    def __truediv__(self, other: 'Rational') -> 'Rational':
        """유리수 나눗셈"""
        if isinstance(other, Rational):
            return Rational(
                self.numerator * other.denominator,
                self.denominator * other.numerator
            )
        return NotImplemented


def demonstrate_rational():
    """유리수 시연"""
    print("\n" + "="*70)
    print("유리수 연산: 산술의 우아함")
    print("="*70)

    r1 = Rational(1, 2)
    r2 = Rational(1, 3)

    print(f"\n  r1 = {r1}")
    print(f"  r2 = {r2}")
    print(f"  r1 + r2 = {r1 + r2}")
    print(f"  r1 - r2 = {r1 - r2}")
    print(f"  r1 * r2 = {r1 * r2}")
    print(f"  r1 / r2 = {r1 / r2}")

    print("\n" + "="*70)


