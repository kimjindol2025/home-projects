def exercise_3_1_gogs_statistics():
    """
    Exercise 3.1: Gogs 통계 계산

    요청: Gogs의 학습 진도 통계를 계산하세요.
    - 총 13단계가 있습니다.
    - 현재 v1.1까지 완료했습니다. (1 단계)
    - 완료한 단계의 비율(%)을 계산하세요
    """
    total_levels = 13
    completed_levels = 1

    completion_percentage = (completed_levels / total_levels) * 100
    remaining_levels = total_levels - completed_levels

    return completion_percentage, remaining_levels, total_levels


def exercise_3_2_student_grades():
    """
    Exercise 3.2: 학생 성적 계산

    요청: 학생 4명의 점수의 평균을 계산하세요.
    """
    student_1_score = 85
    student_2_score = 90
    student_3_score = 78
    student_4_score = 92

    total_score = student_1_score + student_2_score + student_3_score + student_4_score
    average_score = total_score / 4

    return average_score, total_score


def exercise_3_3_price_calculation():
    """
    Exercise 3.3: 가격 계산

    요청: 물품 구매 시 최종 가격을 계산하세요.
    - 책: 20,000원 (3권)
    - 펜: 2,000원 (10개)
    - 할인율: 10%
    """
    book_price = 20000
    book_quantity = 3
    pen_price = 2000
    pen_quantity = 10

    book_total = book_price * book_quantity
    pen_total = pen_price * pen_quantity
    subtotal = book_total + pen_total

    discount_rate = 0.10  # 10%
    discount_amount = subtotal * discount_rate
    final_price = subtotal - discount_amount

    return final_price, discount_amount, subtotal


def exercise_3_4_distance_calculation():
    """
    Exercise 3.4: 거리 계산

    요청: 두 점 사이의 거리를 계산하세요 (유클리드 거리 공식)
    - 점 A: (3, 4)
    - 점 B: (0, 0)
    - 거리 = √((x2-x1)² + (y2-y1)²)
    """
    x1, y1 = 0, 0  # 점 A
    x2, y2 = 3, 4  # 점 B

    # 거리 계산
    distance_squared = (x2 - x1) ** 2 + (y2 - y1) ** 2
    distance = distance_squared ** 0.5

    return distance, distance_squared


