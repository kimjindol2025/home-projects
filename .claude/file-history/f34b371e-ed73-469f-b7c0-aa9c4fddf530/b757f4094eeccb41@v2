def exercise_2_1_arithmetic():
    """
    Exercise 2.1: 변수를 이용한 산술 계산

    요청: 변수를 만들고 계산하세요.
    - x = 10, y = 3이 주어졌을 때
    - x + y, x - y, x * y, x / y를 계산하세요
    """
    x = 10
    y = 3

    sum_result = x + y
    diff_result = x - y
    product_result = x * y
    division_result = x / y

    return sum_result, diff_result, product_result, division_result


