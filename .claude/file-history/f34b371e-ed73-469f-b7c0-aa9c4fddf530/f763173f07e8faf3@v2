# 6. SQL Injection & XSS Prevention (웹 보안)
# =============================================================================

class SQLSafeQuery:
    """SQL Injection 방지"""

    @staticmethod
    def safe_query(template: str, params: Dict[str, Any]) -> str:
        """매개변수화 쿼리 (교육용 예제)"""
        # 실무: ORM이나 매개변수화 쿼리 사용
        query = template

        for key, value in params.items():
            # 문자열은 따옴표로 감싸고 이스케이프
            if isinstance(value, str):
                escaped = value.replace("'", "''")
                query = query.replace(f":{key}", f"'{escaped}'")
            else:
                query = query.replace(f":{key}", str(value))

        return query

    @staticmethod
    def demo() -> Dict[str, Any]:
        """SQL Injection 방지 데모"""
        # 안전한 쿼리
        safe = SQLSafeQuery.safe_query(
            "SELECT * FROM users WHERE id = :id AND name = :name",
            {"id": 1, "name": "O'Brien"}  # 작은따옴표 포함
        )

        # ❌ 위험한 쿼리 (연결)
        unsafe = f"SELECT * FROM users WHERE id = 1 AND name = 'O'Brien'"

        return {
            "engine": "SQLSafeQuery",
            "safe_query": safe,
            "has_escaping": "''" in safe,
        }


class XSSPrevention:
    """XSS (Cross-Site Scripting) 방지"""

    @staticmethod
    def escape_html(text: str) -> str:
        """HTML 이스케이프"""
        replacements = {
            '&': '&amp;',
            '<': '&lt;',
            '>': '&gt;',
            '"': '&quot;',
            "'": '&#39;',
        }

        for char, escaped in replacements.items():
            text = text.replace(char, escaped)

        return text

    @staticmethod
    def demo() -> Dict[str, Any]:
        """XSS 방지 데모"""
        user_input = '<script>alert("Hacked!")</script>'
        escaped = XSSPrevention.escape_html(user_input)

        return {
            "engine": "XSSPrevention",
            "original": user_input,
            "escaped": escaped,
            "safe": "<script>" not in escaped,
        }


