# 2. Authentication (인증: 당신이 정말 본인입니까?)
# =============================================================================

class User:
    """사용자 모델"""

    def __init__(self, username: str, email: str):
        self.username = username
        self.email = email
        self.password_hash = None
        self.created_at = datetime.now()
        self.last_login = None
        self.failed_attempts = 0
        self.locked_until = None


class AuthenticationEngine:
    """사용자 인증 엔진"""

    def __init__(self):
        self.users: Dict[str, User] = {}

    def register(self, username: str, email: str, password: str) -> Tuple[bool, str]:
        """회원가입"""
        # 1. 입력 검증
        if not self._validate_password(password):
            return False, "Password must be 8+ chars with uppercase, lowercase, number"

        if username in self.users:
            return False, "Username already exists"

        # 2. 사용자 생성
        user = User(username, email)
        user.password_hash, _ = HashingEngine.pbkdf2(password)

        self.users[username] = user
        return True, "Registration successful"

    def login(self, username: str, password: str) -> Tuple[bool, str]:
        """로그인"""
        if username not in self.users:
            return False, "User not found"

        user = self.users[username]

        # 1. 계정 잠금 확인 (Brute-force 방지)
        if user.locked_until and datetime.now() < user.locked_until:
            return False, "Account locked due to failed attempts"

        # 2. 비밀번호 검증
        if not HashingEngine.verify_pbkdf2(user.password_hash, password):
            user.failed_attempts += 1

            # 5회 이상 실패 시 계정 잠금 (15분)
            if user.failed_attempts >= 5:
                user.locked_until = datetime.now() + timedelta(minutes=15)
                return False, "Account locked (too many failed attempts)"

            return False, f"Invalid password ({user.failed_attempts}/5)"

        # 3. 로그인 성공
        user.failed_attempts = 0
        user.locked_until = None
        user.last_login = datetime.now()

        return True, "Login successful"

    @staticmethod
    def _validate_password(password: str) -> bool:
        """비밀번호 검증"""
        if len(password) < 8:
            return False
        if not re.search(r'[A-Z]', password):  # 대문자
            return False
        if not re.search(r'[a-z]', password):  # 소문자
            return False
        if not re.search(r'[0-9]', password):  # 숫자
            return False
        return True

    def demo(self) -> Dict[str, Any]:
        """인증 데모"""
        # 회원가입
        reg_ok, reg_msg = self.register("alice", "alice@example.com", "SecurePass123")

        # 로그인 성공
        login_ok, login_msg = self.login("alice", "SecurePass123")

        # 로그인 실패
        login_fail, fail_msg = self.login("alice", "WrongPassword")

        return {
            "engine": "Authentication",
            "registration": reg_ok,
            "login_success": login_ok,
            "login_fail": not login_fail,
        }


# =============================================================================
# 3. Authorization (인가: 당신이 이를 할 권한이 있습니까?)
# =============================================================================

class Permission(Enum):
    """권한 정의"""
    READ = "read"
    WRITE = "write"
    DELETE = "delete"
    ADMIN = "admin"


class Role(Enum):
    """역할 정의"""
    USER = "user"
    MODERATOR = "moderator"
    ADMIN = "admin"


class RBAC:
    """Role-Based Access Control (역할 기반 접근 제어)"""

    # 역할별 권한 매핑
    ROLE_PERMISSIONS = {
        Role.USER: [Permission.READ],
        Role.MODERATOR: [Permission.READ, Permission.WRITE],
        Role.ADMIN: [Permission.READ, Permission.WRITE, Permission.DELETE, Permission.ADMIN],
    }

    @staticmethod
    def has_permission(role: Role, permission: Permission) -> bool:
        """권한 확인"""
        return permission in RBAC.ROLE_PERMISSIONS.get(role, [])

    @staticmethod
    def get_permissions(role: Role) -> List[Permission]:
        """역할의 모든 권한 조회"""
        return RBAC.ROLE_PERMISSIONS.get(role, [])


class ABAC:
    """Attribute-Based Access Control (속성 기반 접근 제어)"""

    @staticmethod
    def can_access(
        user_attributes: Dict[str, Any],
        resource_attributes: Dict[str, Any],
        policy: Dict[str, Any]
    ) -> bool:
        """
        속성 기반 접근 제어
        예: user.department == resource.department and user.level >= resource.level
        """
        for condition in policy.get("conditions", []):
            attr = condition["attribute"]
            op = condition["operator"]
            value = condition["value"]

            user_val = user_attributes.get(attr)

            if op == "==":
                if user_val != value:
                    return False
            elif op == ">=":
                if user_val < value:
                    return False
            elif op == "in":
                if user_val not in value:
                    return False

        return True

    @staticmethod
    def demo() -> Dict[str, Any]:
        """ABAC 데모"""
        user = {
            "id": "user_123",
            "department": "engineering",
            "level": 3,
        }
        resource = {
            "id": "resource_456",
            "department": "engineering",
            "level": 2,
        }
        policy = {
            "conditions": [
                {"attribute": "department", "operator": "==", "value": "engineering"},
                {"attribute": "level", "operator": ">=", "value": 2},
            ]
        }

        can_access = ABAC.can_access(user, resource, policy)
        return {
            "engine": "ABAC",
            "user": user,
            "resource": resource,
            "can_access": can_access,
        }


