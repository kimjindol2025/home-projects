# 5. Audit Logging (감사: 누가, 언제, 무엇을 했는가)
# =============================================================================

class AuditLog:
    """감사 로그"""

    def __init__(self, user_id: str, action: str, resource: str, result: str, details: Optional[Dict] = None):
        self.user_id = user_id
        self.action = action
        self.resource = resource
        self.result = result
        self.timestamp = datetime.now()
        self.details = details or {}

    def to_dict(self) -> Dict[str, Any]:
        return {
            "user_id": self.user_id,
            "action": self.action,
            "resource": self.resource,
            "result": self.result,
            "timestamp": self.timestamp.isoformat(),
            "details": self.details,
        }


class AuditEngine:
    """감사 엔진: 모든 중요 사건을 기록"""

    def __init__(self):
        self.logs: List[AuditLog] = []

    def log(self, user_id: str, action: str, resource: str, result: str, details: Optional[Dict] = None):
        """감사 로그 기록"""
        log = AuditLog(user_id, action, resource, result, details)
        self.logs.append(log)

    def get_logs(self, user_id: Optional[str] = None) -> List[Dict]:
        """감사 로그 조회"""
        filtered = self.logs

        if user_id:
            filtered = [log for log in filtered if log.user_id == user_id]

        return [log.to_dict() for log in filtered]

    def demo(self) -> Dict[str, Any]:
        """감사 엔진 데모"""
        # 사용자 로그인
        self.log("user_123", "LOGIN", "auth_system", "SUCCESS")

        # 파일 접근
        self.log("user_123", "READ", "file_456", "SUCCESS")

        # 권한 없는 삭제 시도
        self.log("user_123", "DELETE", "file_789", "DENIED", {"reason": "no_permission"})

        logs = self.get_logs()
        return {
            "engine": "AuditEngine",
            "total_logs": len(logs),
            "logs": logs[:2],  # 처음 2개만 표시
        }


