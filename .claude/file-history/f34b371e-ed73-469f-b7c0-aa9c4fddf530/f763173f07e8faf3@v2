# =============================================================================
# 1. Hashing & Encryption (데이터 보호)
# =============================================================================

class HashingEngine:
    """단방향 암호화: 비밀번호 저장용"""

    @staticmethod
    def sha256(data: str) -> str:
        """SHA-256 해시 (기본 용도)"""
        return hashlib.sha256(data.encode()).hexdigest()

    @staticmethod
    def pbkdf2(password: str, salt: Optional[bytes] = None, iterations: int = 100000) -> Tuple[str, str]:
        """
        PBKDF2: 비밀번호 저장의 표준
        - iterations가 높을수록 Brute-force 공격 시간 증가
        - Salt로 Rainbow Table 공격 방지
        """
        if salt is None:
            salt = os.urandom(16)

        hash_obj = hashlib.pbkdf2_hmac(
            'sha256',
            password.encode('utf-8'),
            salt,
            iterations
        )

        # salt + hash 반환 (저장용)
        salt_b64 = base64.b64encode(salt).decode()
        hash_b64 = base64.b64encode(hash_obj).decode()
        return f"{salt_b64}${hash_b64}", salt_b64

    @staticmethod
    def verify_pbkdf2(stored: str, input_password: str, iterations: int = 100000) -> bool:
        """PBKDF2 검증"""
        try:
            salt_b64, hash_b64 = stored.split('$')
            salt = base64.b64decode(salt_b64)

            # 입력받은 비밀번호 재해싱
            check_hash = hashlib.pbkdf2_hmac(
                'sha256',
                input_password.encode('utf-8'),
                salt,
                iterations
            )
            check_b64 = base64.b64encode(check_hash).decode()

            # 상수 시간 비교 (타이밍 공격 방지)
            return hmac.compare_digest(check_b64, hash_b64)
        except Exception:
            return False

    @staticmethod
    def demo() -> Dict[str, Any]:
        """해싱 데모"""
        password = "secure_password_2024"

        # PBKDF2로 비밀번호 저장
        stored_hash, salt = HashingEngine.pbkdf2(password)

        # 로그인 시도
        login_correct = HashingEngine.verify_pbkdf2(stored_hash, password)
        login_wrong = HashingEngine.verify_pbkdf2(stored_hash, "wrong_password")

        return {
            "engine": "Hashing",
            "password_stored": bool(stored_hash),
            "login_correct": login_correct,
            "login_wrong": login_wrong,
        }


class EncryptionEngine:
    """양방향 암호화: 토큰, 민감 데이터 암호화"""

    @staticmethod
    def simple_xor_cipher(data: str, key: str) -> str:
        """XOR 기반 암호화 (교육용, 실무는 cryptography 라이브러리 사용)"""
        result = []
        for i, char in enumerate(data):
            key_char = key[i % len(key)]
            xor_val = ord(char) ^ ord(key_char)
            result.append(chr(xor_val))
        return ''.join(result)

    @staticmethod
    def demo() -> Dict[str, Any]:
        """암호화 데모"""
        plaintext = "sensitive_data"
        key = "secret_key_2024"

        # 암호화
        encrypted = EncryptionEngine.simple_xor_cipher(plaintext, key)

        # 복호화 (XOR는 대칭이므로)
        decrypted = EncryptionEngine.simple_xor_cipher(encrypted, key)

        return {
            "engine": "Encryption",
            "plaintext": plaintext,
            "encrypted_length": len(encrypted),
            "decrypted": decrypted,
            "match": plaintext == decrypted,
        }


