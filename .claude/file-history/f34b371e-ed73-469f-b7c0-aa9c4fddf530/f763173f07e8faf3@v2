# 7. Token Generation (세션 & JWT 기초)
# =============================================================================

class TokenEngine:
    """토큰 생성 및 검증 (기초)"""

    def __init__(self, secret_key: str):
        self.secret_key = secret_key

    def generate_token(self, data: Dict[str, Any], expires_in: int = 3600) -> str:
        """토큰 생성 (간단한 예제)"""
        # 실무: JWT 라이브러리 사용
        expiry = int(time.time()) + expires_in

        payload = json.dumps({
            "data": data,
            "exp": expiry,
        })

        # HMAC 서명
        signature = hmac.new(
            self.secret_key.encode(),
            payload.encode(),
            hashlib.sha256
        ).hexdigest()

        return f"{payload}.{signature}"

    def verify_token(self, token: str) -> Optional[Dict[str, Any]]:
        """토큰 검증"""
        try:
            payload_str, signature = token.rsplit(".", 1)

            # 서명 검증
            expected_sig = hmac.new(
                self.secret_key.encode(),
                payload_str.encode(),
                hashlib.sha256
            ).hexdigest()

            if not hmac.compare_digest(signature, expected_sig):
                return None

            # 만료 시간 확인
            payload = json.loads(payload_str)

            if payload["exp"] < time.time():
                return None

            return payload["data"]

        except Exception:
            return None

    def demo(self) -> Dict[str, Any]:
        """토큰 생성/검증 데모"""
        token = self.generate_token({"user_id": "user_123", "role": "admin"})

        # 토큰 검증
        data = self.verify_token(token)

        # 잘못된 토큰
        invalid_data = self.verify_token("invalid_token")

        return {
            "engine": "TokenEngine",
            "token_created": bool(token),
            "token_verified": data is not None,
            "user_id": data.get("user_id") if data else None,
            "invalid_rejected": invalid_data is None,
        }


# =============================================================================
# 통합 Security Framework
# =============================================================================

class SecurityFramework:
    """통합 보안 프레임워크"""

    def __init__(self, secret_key: str):
        self.auth = AuthenticationEngine()
        self.audit = AuditEngine()
        self.rate_limiter = RateLimiter(max_requests=100, window_seconds=60)
        self.token_engine = TokenEngine(secret_key)

    def secure_login(self, username: str, password: str, client_ip: str) -> Tuple[bool, Optional[str]]:
        """보안이 강화된 로그인"""
        # 1. Rate Limiting 확인
        if not self.rate_limiter.is_allowed(client_ip):
            self.audit.log("UNKNOWN", "LOGIN_ATTEMPT", username, "RATE_LIMITED", {"ip": client_ip})
            return False, None

        # 2. 인증
        ok, msg = self.auth.login(username, password)

        if ok:
            # 3. 토큰 생성
            token = self.token_engine.generate_token({"username": username})

            # 4. 감사 로그
            self.audit.log(username, "LOGIN", "auth", "SUCCESS", {"ip": client_ip})

            return True, token
        else:
            # 5. 실패 로그
            self.audit.log(username, "LOGIN", "auth", "FAILED", {"ip": client_ip, "reason": msg})

            return False, None

    def demo(self) -> Dict[str, Any]:
        """통합 보안 프레임워크 데모"""
        # 회원가입
        self.auth.register("bob", "bob@example.com", "TestPass123")

        # 보안 로그인
        ok, token = self.secure_login("bob", "TestPass123", "192.168.1.100")

        # 토큰 검증
        token_data = self.token_engine.verify_token(token) if token else None

        # 감사 로그
        audit_logs = self.audit.get_logs("bob")

        return {
            "framework": "SecurityFramework",
            "login_success": ok,
            "token_valid": token_data is not None,
            "audit_logs_count": len(audit_logs),
        }


