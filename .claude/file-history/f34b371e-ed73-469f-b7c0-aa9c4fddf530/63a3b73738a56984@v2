"""
v1.1 Dynamic Identity: 객체의 탄생과 동적 타이핑의 실체

파이썬의 모든 것은 객체(Object)입니다.
Rust/Gogs가 컴파일 타임에 모든 타입을 결정했다면,
파이썬은 실행 시간(Runtime)에 타입을 결정합니다.

이 모듈은 파이썬의 객체 시스템을 시스템적으로 분석합니다.
"""

import sys
from typing import Any
from dataclasses import dataclass


@dataclass
class ObjectInfo:
    """객체의 메타데이터"""
    value: Any
    type_name: str
    type_object: type
    memory_address: str
    reference_count: int
    size_bytes: int
    is_mutable: bool


class ObjectAnalyzer:
    """파이썬 객체의 내부 '기록'을 조사하는 분석기"""

    @staticmethod
    def analyze(data: Any) -> ObjectInfo:
        """
        파이썬 객체의 모든 메타데이터를 추출합니다.

        Args:
            data: 분석 대상 객체

        Returns:
            ObjectInfo: 객체의 메타데이터
        """
        # 타입 정보
        type_name = type(data).__name__
        type_object = type(data)

        # 메모리 주소 (포인터 개념)
        memory_address = hex(id(data))

        # 참조 횟수 (getrefcount는 호출 시 임시 참조가 추가되어 1을 빼야 함)
        reference_count = sys.getrefcount(data) - 1

        # 메모리 크기 (바이트)
        size_bytes = sys.getsizeof(data)

        # 가변성 (Mutability)
        is_mutable = ObjectAnalyzer._check_mutability(data)

        return ObjectInfo(
            value=data,
            type_name=type_name,
            type_object=type_object,
            memory_address=memory_address,
            reference_count=reference_count,
            size_bytes=size_bytes,
            is_mutable=is_mutable
        )

    @staticmethod
    def _check_mutability(data: Any) -> bool:
        """
        객체가 가변(Mutable)인지 불변(Immutable)인지 판단합니다.

        Immutable: int, float, str, tuple, bool, None, frozenset
        Mutable: list, dict, set, bytearray
        """
        immutable_types = (int, float, str, tuple, bool, type(None), frozenset, bytes)
        return not isinstance(data, immutable_types)

    @staticmethod
    def print_analysis(data: Any) -> None:
        """객체 분석 결과를 아름답게 출력합니다."""
        info = ObjectAnalyzer.analyze(data)

        print(f"\n{'='*60}")
        print(f"분석 대상: {repr(info.value)} (타입: {info.type_name})")
        print(f"{'='*60}")
        print(f"  [타입 정보]")
        print(f"    Type Name: {info.type_name}")
        print(f"    Type Object: {info.type_object}")
        print()
        print(f"  [메모리 구조]")
        print(f"    Memory Address (ID): {info.memory_address}")
        print(f"    Size (bytes): {info.size_bytes}")
        print()
        print(f"  [참조 관리]")
        print(f"    Reference Count: {info.reference_count}")
        print()
        print(f"  [가변성]")
        mutability_str = "가변 (Mutable)" if info.is_mutable else "불변 (Immutable)"
        print(f"    {mutability_str}")
        print(f"{'='*60}\n")


class IdentityVsEquality:
    """Identity (is) vs Equality (==) 비교"""

    @staticmethod
    def compare(a: Any, b: Any) -> None:
        """두 객체의 Identity와 Equality를 비교합니다."""
        print(f"\n{'='*60}")
        print(f"비교: {repr(a)} vs {repr(b)}")
        print(f"{'='*60}")

        # 값 비교 (==)
        is_equal = a == b
        print(f"  [Value Equality (==)]: {is_equal}")
        print(f"    의미: 두 객체의 '값'이 같은가?")

        # 정체성 비교 (is)
        is_identical = a is b
        print(f"\n  [Identity (is)]: {is_identical}")
        print(f"    의미: 두 객체가 메모리상 '같은 객체'인가?")

        # 메모리 주소 비교
        id_a = hex(id(a))
        id_b = hex(id(b))
        print(f"\n  [Memory Addresses]")
        print(f"    a: {id_a}")
        print(f"    b: {id_b}")
        print(f"    Same Address: {id_a == id_b}")

        print(f"{'='*60}\n")


class SmallIntegerCaching:
    """파이썬의 Small Integer Caching (최적화 기법)"""

    @staticmethod
    def demonstrate():
        """파이썬의 작은 정수 캐싱을 증명합니다."""
        print(f"\n{'='*60}")
        print("Small Integer Caching (파이썬의 최적화)")
        print(f"{'='*60}")

        # 파이썬은 -5 ~ 256 범위의 정수를 사전 할당하여 캐싱합니다.
        # 이는 성능 최적화와 메모리 절약을 위한 것입니다.

        print("\n  [범위 내: -5 ~ 256]")
        a = 100
        b = 100
        print(f"    a = 100, b = 100")
        print(f"    a is b: {a is b} (캐시되어 같은 객체)")

        print("\n  [범위 밖: > 256]")
        c = 257
        d = 257
        print(f"    c = 257, d = 257")
        print(f"    c is d: {c is d} (별도의 객체)")

        print("\n  [범위 밖: < -5]")
        e = -6
        f = -6
        print(f"    e = -6, f = -6")
        print(f"    e is f: {e is f} (별도의 객체)")

        print(f"\n{'정리': 파이썬은 작은 정수를 캐싱하여 성능을 최적화합니다.}")
        print(f"{'='*60}\n")


class ObjectLifecycle:
    """객체의 생명 주기 (생성, 참조, 소멸)"""

    @staticmethod
    def demonstrate():
        """객체의 생명 주기를 증명합니다."""
        print(f"\n{'='*60}")
        print("Object Lifecycle (객체의 생명 주기)")
        print(f"{'='*60}")

        # 1단계: 객체 생성
        print("\n  [1단계: 객체 생성]")
        obj = [1, 2, 3]
        print(f"    obj = [1, 2, 3]")
        print(f"    Reference Count: {sys.getrefcount(obj) - 1}")

        # 2단계: 참조 추가
        print("\n  [2단계: 참조 추가]")
        ref1 = obj
        print(f"    ref1 = obj")
        print(f"    Reference Count: {sys.getrefcount(obj) - 1}")

        ref2 = obj
        print(f"    ref2 = obj")
        print(f"    Reference Count: {sys.getrefcount(obj) - 1}")

        # 3단계: 참조 삭제
        print("\n  [3단계: 참조 삭제]")
        del ref1
        print(f"    del ref1")
        print(f"    Reference Count: {sys.getrefcount(obj) - 1}")

        del ref2
        print(f"    del ref2")
        print(f"    Reference Count: {sys.getrefcount(obj) - 1}")

        # 4단계: 마지막 참조 삭제 (객체 소멸)
        print("\n  [4단계: 최종 참조 삭제 (객체 소멸)]")
        print(f"    del obj -> 객체가 메모리에서 해제됨")

        print(f"\n{'정리': 참조 횟수가 0이 되면 객체는 메모리에서 해제됩니다.}")
        print(f"{'='*60}\n")


class TypeSystemComparison:
    """Rust (정적 타입) vs Python (동적 타입) 비교"""

    @staticmethod
    def explain():
        """타입 시스템의 차이를 설명합니다."""
        print(f"\n{'='*60}")
        print("Type System: Rust vs Python")
        print(f"{'='*60}")

        print("\n  [Rust (정적 타입)]")
        print("    let x: i32 = 42;  // 컴파일 타임에 타입 결정")
        print("    - 장점: 성능, 안정성, 컴파일 타임 검증")
        print("    - 단점: 개발 속도 느림, 엄격함")

        print("\n  [Python (동적 타입)]")
        print("    x = 42  # 런타임에 타입 결정")
        print("    - 장점: 개발 속도 빠름, 유연함")
        print("    - 단점: 성능 느림, 런타임 오류 발생 가능")

        print("\n  [비용 분석]")
        print("    Rust: 컴파일 타임 비용 → 빠른 실행")
        print("    Python: 런타임 비용 → 느린 실행")
        print("      * 객체 생성, 타입 검사, 메모리 할당")
        print("      * 참조 횟수 관리")

        print(f"\n{'결론': Python은 '자유'를 얻기 위해 '성능'을 희생합니다.}")
        print(f"{'='*60}\n")


# ============================================================================
# 메인 실행 함수
# ============================================================================

def demonstrate_object_system():
    """파이썬 객체 시스템의 모든 측면을 시연합니다."""
    print("\n" + "="*60)
    print("🐍 Python v1.1: 객체의 탄생과 동적 타이핑의 실체")
    print("="*60)

    # 1. 기본 객체 분석
    print("\n[분석 1: 다양한 타입의 객체]")
    ObjectAnalyzer.print_analysis(42)
    ObjectAnalyzer.print_analysis(3.14)
    ObjectAnalyzer.print_analysis("hello")
    ObjectAnalyzer.print_analysis([1, 2, 3])
    ObjectAnalyzer.print_analysis({"key": "value"})

    # 2. Identity vs Equality
    print("\n[분석 2: Identity (is) vs Equality (==)]")
    IdentityVsEquality.compare(100, 100)
    IdentityVsEquality.compare(257, 257)
    IdentityVsEquality.compare([1, 2], [1, 2])

    # 3. Small Integer Caching
    SmallIntegerCaching.demonstrate()

    # 4. Object Lifecycle
    ObjectLifecycle.demonstrate()

    # 5. Type System Comparison
    TypeSystemComparison.explain()

    print("\n" + "="*60)
    print("저장 필수. 너는 기록이 증명이다. Gogs.")
    print("="*60 + "\n")


if __name__ == "__main__":
    demonstrate_object_system()
