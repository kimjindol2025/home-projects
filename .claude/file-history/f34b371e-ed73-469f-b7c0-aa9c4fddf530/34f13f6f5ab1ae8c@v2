# ============================================================================
# 2. 변수 생성: 데이터 올리기 + 이름표 붙이기
# ============================================================================

def demonstrate_variable_creation():
    """
    변수를 만드는 과정:
    1. 파이썬이 메모리의 어딘가에 데이터를 올립니다.
    2. 그 위치에 변수명이라는 이름표를 붙입니다.
    """
    # age = 25 가 할 일:
    # Step 1: 메모리에 정수 25를 올립니다. (주소: 0x1000이라고 가정)
    # Step 2: 그 위치에 "age"라는 이름표를 붙입니다.
    age = 25

    # name = "Alice" 가 할 일:
    # Step 1: 메모리에 문자열 "Alice"를 올립니다. (주소: 0x1010)
    # Step 2: 그 위치에 "name"이라는 이름표를 붙입니다.
    name = "Alice"

    # pi = 3.14 가 할 일:
    # Step 1: 메모리에 실수 3.14를 올립니다. (주소: 0x1008)
    # Step 2: 그 위치에 "pi"라는 이름표를 붙입니다.
    pi = 3.14

    return age, name, pi


# ============================================================================
# 3. 파이썬의 id() 함수 - 메모리 주소 확인
# ============================================================================

def demonstrate_id_function():
    """
    id()는 메모리 주소(실제로는 내부 객체 ID)를 보여줍니다.

    (주의: 파이썬의 id()는 메모리 주소가 아니라 객체 식별자이지만,
     초보자 수준에서는 "메모리 위치"로 생각해도 됩니다.)
    """
    age = 25
    height = 1.72
    name = "Alice"

    # id()로 각 변수가 가리키는 위치(ID)를 확인합니다.
    age_id = id(age)
    height_id = id(height)
    name_id = id(name)

    # 각각은 다른 위치입니다!
    are_different = (age_id != height_id) and (height_id != name_id)

    return {
        "age_id": age_id,
        "height_id": height_id,
        "name_id": name_id,
        "are_different": are_different,
    }


# ============================================================================
# 4. 같은 데이터 = 같은 메모리 위치?
# ============================================================================

def demonstrate_object_reuse():
    """
    파이썬은 효율적입니다!
    같은 값을 가진 작은 데이터는 메모리를 공유합니다.
    """
    # 작은 정수: 메모리를 공유할 가능성이 높습니다.
    a = 10
    b = 10
    # a와 b가 같은 메모리 위치를 가리킬 수도 있습니다!
    # (파이썬의 정수 캐싱 때문)

    # 큰 정수: 다른 메모리를 사용합니다.
    x = 10000
    y = 10000
    # x와 y는 다른 메모리 위치입니다.

    # 문자열: 작은 것은 공유, 큰 것은 따로입니다.
    s1 = "hello"
    s2 = "hello"
    # s1과 s2가 같은 메모리를 가리킬 수도 있습니다.

    return {
        "a_id": id(a),
        "b_id": id(b),
        "a_and_b_same": id(a) == id(b),
        "x_id": id(x),
        "y_id": id(y),
        "x_and_y_same": id(x) == id(y),
    }


# ============================================================================
# 5. 이름표 재붙이기 (변수 재할당)
# ============================================================================

def demonstrate_relabeling():
    """
    변수 재할당은 "이름표를 다른 위치로 옮기는 것"입니다.
    """
    # Step 1: "count"라는 이름표를 메모리의 10이 있는 곳에 붙입니다.
    count = 10
    first_id = id(count)

    # Step 2: "count"라는 이름표를 떼어내고, 20이 있는 곳에 붙입니다.
    count = 20
    second_id = id(count)

    # 같은 이름인데 다른 위치를 가리킵니다!
    are_different_locations = (first_id != second_id)

    return {
        "initial_count": 10,
        "initial_id": first_id,
        "new_count": 20,
        "new_id": second_id,
        "different_locations": are_different_locations,
    }


# ============================================================================
# 6. 여러 이름표, 한 데이터
# ============================================================================

def demonstrate_multiple_labels():
    """
    하나의 데이터에 여러 이름표를 붙일 수 있습니다!
    """
    # 메모리의 10에 "age"라는 이름표를 붙입니다.
    age = 10

    # 같은 메모리의 10에 "years"라는 또 다른 이름표를 붙입니다.
    years = age  # 이것은 값을 복사하는 게 아니라, 같은 객체를 가리킵니다.

    age_id = id(age)
    years_id = id(years)

    # 같은 위치? 아니면 다른 위치?
    # (정수의 경우 캐싱 때문에 같을 가능성이 높습니다.)

    return {
        "age": age,
        "years": years,
        "age_id": age_id,
        "years_id": years_id,
        "same_location": age_id == years_id,
    }


# ============================================================================
# 7. 리스트: 컨테이너의 이름표
# ============================================================================

def demonstrate_list_labels():
    """
    리스트도 메모리의 어딘가에 있는 객체입니다!
    """
    # 리스트는 메모리의 어딘가에 만들어집니다.
    numbers = [1, 2, 3]
    numbers_id = id(numbers)

    # 같은 리스트를 다른 이름으로 가리킵니다.
    another_name = numbers  # 복사가 아니라 같은 객체를 가리킵니다!
    another_name_id = id(another_name)

    # 같은 리스트입니다!
    same_list = (numbers_id == another_name_id)

    # 그래서 한 쪽을 수정하면...
    numbers.append(4)  # 리스트에 4를 추가합니다.

    # 다른 쪽도 수정됩니다!
    another_modified = another_name  # [1, 2, 3, 4]

    return {
        "numbers": numbers,
        "another_name": another_name,
        "same_object": same_list,
        "both_modified": (len(numbers) == 4 and len(another_name) == 4),
    }


