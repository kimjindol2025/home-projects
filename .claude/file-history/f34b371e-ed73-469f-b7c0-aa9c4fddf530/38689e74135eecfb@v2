// ============================================================================
// Value: 런타임 값 표현
// ============================================================================

use crate::gc_object::{GcRef, ObjectHeap, GcData};
use std::fmt;

/// 런타임 값
#[derive(Debug, Clone, PartialEq)]
pub enum Value {
    /// 정수
    Int(i64),

    /// 불리언
    Bool(bool),

    /// null
    Null,

    /// 배열 (GC 참조)
    Array(GcRef),

    /// 해시맵 (GC 참조)
    HashMap(GcRef),
}

impl Value {
    /// 값이 참인지 판단
    pub fn is_truthy(&self) -> bool {
        match self {
            Value::Bool(b) => *b,
            Value::Int(0) => false,
            Value::Int(_) => true,
            Value::Null => false,
            Value::Array(_) => true,
            Value::HashMap(_) => true,
        }
    }

    /// GC 참조 추출 (Array 또는 HashMap이면 Some)
    pub fn as_gc_ref(&self) -> Option<GcRef> {
        match self {
            Value::Array(gc_ref) | Value::HashMap(gc_ref) => Some(*gc_ref),
            _ => None,
        }
    }

    /// 힙을 사용하여 값을 문자열로 표시 (GC 참조 역참조)
    pub fn display_with_heap(&self, heap: &ObjectHeap) -> String {
        match self {
            Value::Int(n) => n.to_string(),
            Value::Bool(b) => b.to_string(),
            Value::Null => "null".to_string(),
            Value::Array(gc_ref) => {
                match heap.get(*gc_ref) {
                    Some(obj) => {
                        match &obj.data {
                            GcData::Array(arr) => {
                                let elements: Vec<String> = arr
                                    .iter()
                                    .map(|v| v.display_with_heap(heap))
                                    .collect();
                                format!("[{}]", elements.join(", "))
                            }
                            _ => "[invalid]".to_string(),
                        }
                    }
                    None => "[dangling]".to_string(),
                }
            }
            Value::HashMap(gc_ref) => {
                match heap.get(*gc_ref) {
                    Some(obj) => {
                        match &obj.data {
                            GcData::HashMap(map) => {
                                let mut pairs: Vec<String> = map
                                    .iter()
                                    .map(|(k, v)| format!("{}: {}", k, v.display_with_heap(heap)))
                                    .collect();
                                pairs.sort(); // 일관된 출력
                                format!("{{{}}}", pairs.join(", "))
                            }
                            _ => "{invalid}".to_string(),
                        }
                    }
                    None => "{dangling}".to_string(),
                }
            }
        }
    }
}

impl fmt::Display for Value {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        match self {
            Value::Int(n) => write!(f, "{}", n),
            Value::Bool(b) => write!(f, "{}", b),
            Value::Null => write!(f, "null"),
            Value::Array(gc_ref) => write!(f, "[array:{}]", gc_ref),
            Value::HashMap(gc_ref) => write!(f, "{{hash:{}}}", gc_ref),
        }
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_is_truthy_bool() {
        assert!(Value::Bool(true).is_truthy());
        assert!(!Value::Bool(false).is_truthy());
    }

    #[test]
    fn test_is_truthy_int() {
        assert!(!Value::Int(0).is_truthy());
        assert!(Value::Int(1).is_truthy());
        assert!(Value::Int(-1).is_truthy());
    }

    #[test]
    fn test_is_truthy_null() {
        assert!(!Value::Null.is_truthy());
    }

    #[test]
    fn test_is_truthy_array() {
        // Array는 GcRef이므로 항상 참 (GC 객체 존재하면)
        assert!(Value::Array(0).is_truthy());
    }

    #[test]
    fn test_as_gc_ref() {
        assert_eq!(Value::Array(42).as_gc_ref(), Some(42));
        assert_eq!(Value::HashMap(99).as_gc_ref(), Some(99));
        assert_eq!(Value::Int(10).as_gc_ref(), None);
        assert_eq!(Value::Bool(true).as_gc_ref(), None);
        assert_eq!(Value::Null.as_gc_ref(), None);
    }

    #[test]
    fn test_display_with_heap() {
        let mut heap = ObjectHeap::new();
        let arr_ref = heap.alloc(GcData::Array(vec![
            Value::Int(1),
            Value::Int(2),
            Value::Int(3),
        ]));

        let value = Value::Array(arr_ref);
        let display = value.display_with_heap(&heap);
        assert_eq!(display, "[1, 2, 3]");
    }

    #[test]
    fn test_display_simple_values() {
        assert_eq!(Value::Int(42).to_string(), "42");
        assert_eq!(Value::Bool(true).to_string(), "true");
        assert_eq!(Value::Null.to_string(), "null");
    }

    #[test]
    fn test_display_with_dangling_reference() {
        let heap = ObjectHeap::new();
        let value = Value::Array(999); // 존재하지 않는 참조
        let display = value.display_with_heap(&heap);
        assert_eq!(display, "[dangling]");
    }
}
