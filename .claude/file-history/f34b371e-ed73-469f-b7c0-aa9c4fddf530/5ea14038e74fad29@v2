class TestPackageManager:
    """패키지 관리자 테스트"""

    def test_initialization(self):
        """초기화"""
        pm = PackageManager()
        assert len(pm.installed_packages) == 0

    def test_install_valid_package(self):
        """유효한 패키지 설치"""
        pm = PackageManager()
        success, msg = pm.install("numpy", "1.24.0")
        assert success is True
        assert "numpy" in pm.installed_packages

    def test_install_invalid_package(self):
        """유효하지 않은 패키지 설치"""
        pm = PackageManager()
        success, msg = pm.install("nonexistent_package", "1.0.0")
        assert success is False

    def test_install_invalid_version(self):
        """유효하지 않은 버전 설치"""
        pm = PackageManager()
        success, msg = pm.install("numpy", "99.99.99")
        assert success is False

    def test_install_latest_version(self):
        """최신 버전 설치"""
        pm = PackageManager()
        success, msg = pm.install("numpy")
        assert success is True
        assert pm.installed_packages["numpy"].version == "1.24.0"

    def test_uninstall_package(self):
        """패키지 제거"""
        pm = PackageManager()
        pm.install("numpy", "1.24.0")
        success, msg = pm.uninstall("numpy")
        assert success is True
        assert "numpy" not in pm.installed_packages

    def test_uninstall_nonexistent(self):
        """존재하지 않는 패키지 제거"""
        pm = PackageManager()
        success, msg = pm.uninstall("nonexistent")
        assert success is False

    def test_list_installed(self):
        """설치된 패키지 목록"""
        pm = PackageManager()
        pm.install("numpy", "1.24.0")
        pm.install("pandas", "1.5.0")
        installed = pm.list_installed()
        assert len(installed) == 2
        assert installed["numpy"] == "1.24.0"

    def test_show_package(self):
        """패키지 정보"""
        pm = PackageManager()
        pm.install("numpy", "1.24.0")
        info = pm.show_package("numpy")
        assert info is not None
        assert info["name"] == "numpy"
        assert info["installed"] is True

    def test_get_total_size(self):
        """전체 용량"""
        pm = PackageManager()
        pm.install("numpy", "1.24.0")
        size = pm.get_total_size()
        assert size > 0

    def test_get_packages_for_requirements(self):
        """requirements용 패키지 목록"""
        pm = PackageManager()
        pm.install("numpy", "1.24.0")
        pm.install("pandas", "1.5.0")
        req_list = pm.get_packages_for_requirements()
        assert len(req_list) == 2


