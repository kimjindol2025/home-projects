class TestEdgeCases:
    """엣지 케이스 테스트"""

    def test_empty_requirements(self):
        """빈 requirements"""
        handler = RequirementsHandler()
        content = handler.generate_content()
        assert content == ""

    def test_multiple_install_same_package(self):
        """같은 패키지 여러 번 설치"""
        pm = PackageManager()
        pm.install("numpy", "1.24.0")
        pm.install("numpy", "1.20.0")
        # 버전이 업그레이드됨
        assert pm.installed_packages["numpy"].version == "1.20.0"

    def test_large_requirements_file(self):
        """큰 requirements 파일"""
        handler = RequirementsHandler()
        for i in range(50):
            pkg_name = f"package_{i:03d}"
            handler.requirements.append(Package(pkg_name, "1.0.0"))

        content = handler.generate_content()
        lines = content.split("\n")
        assert len(lines) >= 50

    def test_venv_lifecycle(self):
        """venv 라이프사이클"""
        venv = VirtualEnvironment(".venv_lifecycle")

        # 생성 → 활성화 → 비활성화
        assert venv.create() is True
        assert venv.activate() is True
        assert venv.deactivate() is True
        assert venv.get_status()["created"] is True


