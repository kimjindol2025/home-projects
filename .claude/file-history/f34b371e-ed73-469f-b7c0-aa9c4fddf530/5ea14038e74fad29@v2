class TestRequirementsHandler:
    """requirements.txt 처리 테스트"""

    def test_initialization(self):
        """초기화"""
        handler = RequirementsHandler()
        assert len(handler.requirements) == 0

    def test_parse_valid_line(self):
        """유효한 라인 파싱"""
        handler = RequirementsHandler()
        pkg = handler.parse_line("numpy==1.24.0")
        assert pkg is not None
        assert pkg.name == "numpy"
        assert pkg.version == "1.24.0"

    def test_parse_comment_line(self):
        """주석 라인 파싱"""
        handler = RequirementsHandler()
        pkg = handler.parse_line("# This is a comment")
        assert pkg is None

    def test_parse_empty_line(self):
        """빈 라인 파싱"""
        handler = RequirementsHandler()
        pkg = handler.parse_line("")
        assert pkg is None

    def test_load_from_content(self):
        """content에서 로드"""
        handler = RequirementsHandler()
        content = """numpy==1.24.0
pandas==1.5.0
requests==2.28.0
"""
        packages = handler.load_from_content(content)
        assert len(packages) == 3

    def test_generate_content(self):
        """content 생성"""
        handler = RequirementsHandler()
        handler.add_package(Package("numpy", "1.24.0"))
        handler.add_package(Package("pandas", "1.5.0"))
        content = handler.generate_content()
        assert "numpy==1.24.0" in content
        assert "pandas==1.5.0" in content

    def test_add_package(self):
        """패키지 추가"""
        handler = RequirementsHandler()
        handler.add_package(Package("numpy", "1.24.0"))
        assert len(handler.requirements) == 1

    def test_remove_package(self):
        """패키지 제거"""
        handler = RequirementsHandler()
        handler.add_package(Package("numpy", "1.24.0"))
        result = handler.remove_package("numpy")
        assert result is True
        assert len(handler.requirements) == 0

    def test_find_package(self):
        """패키지 찾기"""
        handler = RequirementsHandler()
        pkg = Package("numpy", "1.24.0")
        handler.add_package(pkg)
        found = handler.find_package("numpy")
        assert found is not None
        assert found.name == "numpy"


