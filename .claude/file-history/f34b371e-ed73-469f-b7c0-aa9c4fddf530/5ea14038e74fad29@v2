class TestVirtualEnvironment:
    """가상 환경 관리 테스트"""

    def test_creation(self):
        """가상 환경 생성"""
        venv = VirtualEnvironment(".venv_test")
        assert venv.path == ".venv_test"
        assert not venv.is_created

    def test_create_venv(self):
        """가상 환경 생성 실행"""
        venv = VirtualEnvironment(".venv_test")
        result = venv.create()
        assert result is True
        assert venv.is_created

    def test_create_duplicate(self):
        """중복 생성 방지"""
        venv = VirtualEnvironment(".venv_test")
        venv.create()
        result = venv.create()
        assert result is False

    def test_activate_venv(self):
        """가상 환경 활성화"""
        venv = VirtualEnvironment(".venv_test")
        venv.create()
        result = venv.activate()
        assert result is True
        assert venv.info.is_active

    def test_deactivate_venv(self):
        """가상 환경 비활성화"""
        venv = VirtualEnvironment(".venv_test")
        venv.create()
        venv.activate()
        result = venv.deactivate()
        assert result is True
        assert not venv.info.is_active

    def test_get_status(self):
        """상태 조회"""
        venv = VirtualEnvironment(".venv_test")
        venv.create()
        status = venv.get_status()
        assert status["created"] is True

    def test_get_info(self):
        """상세 정보"""
        venv = VirtualEnvironment(".venv_test")
        venv.create()
        info = venv.get_info()
        assert "path" in info
        assert "created_at" in info


