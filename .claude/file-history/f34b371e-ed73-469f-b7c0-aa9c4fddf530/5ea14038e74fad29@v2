class TestRealWorldScenarios:
    """실제 사용 시나리오"""

    def test_data_science_project(self):
        """데이터 과학 프로젝트"""
        project = ProjectEnvironment("data_science_project")
        project.setup_development()

        # 필수 패키지 설치 확인
        installed = project.package_manager.list_installed()
        assert "numpy" in installed
        assert "pandas" in installed

    def test_web_development_project(self):
        """웹 개발 프로젝트"""
        project = ProjectEnvironment("web_app")
        project.setup_development()

        # 웹 프레임워크 확인 가능
        pm = project.package_manager
        assert len(pm.installed_packages) > 0

    def test_multi_environment_project(self):
        """다중 환경 프로젝트"""
        # 개발 환경
        dev = ProjectEnvironment("myapp_dev")
        dev.setup_development()
        dev_req = dev.generate_requirements_file()

        # 운영 환경
        prod = ProjectEnvironment("myapp_prod")
        prod.setup_production()
        prod_req = prod.generate_requirements_file()

        # 두 환경 모두 공통 패키지 포함
        assert "numpy" in dev_req
        assert "numpy" in prod_req
        # 개발 환경은 테스트 도구 포함
        assert len(dev.package_manager.installed_packages) >= len(
            prod.package_manager.installed_packages
        )

    def test_dependency_management(self):
        """의존성 관리"""
        pm = PackageManager()
        pm.install("numpy", "1.24.0")
        pm.install("pandas", "1.5.0")
        pm.install("scikit-learn", "1.2.0")

        # 의존성 확인
        deps = DependencyResolver.get_dependencies("scikit-learn")
        assert "numpy" in deps

        # 호환성 확인
        installed = pm.list_installed()
        compatible, msgs = DependencyResolver.check_compatibility(
            "matplotlib", "3.7.0", installed
        )
        assert isinstance(compatible, bool)


