class TestEnvironmentPhilosophy:
    """환경 철학 테스트"""

    def test_core_principles(self):
        """핵심 원칙 조회"""
        principles = EnvironmentPhilosophy.get_core_principles()
        assert len(principles) == 4
        assert "격리 (Isolation)" in principles
        assert "재현성 (Reproducibility)" in principles

    def test_why_venv(self):
        """왜 venv가 필요한가"""
        reasons = EnvironmentPhilosophy.why_virtual_environment()
        assert len(reasons) >= 3
        assert "문제 1" in reasons
        assert "해결책" in reasons

    def test_global_vs_venv(self):
        """전역 vs 가상 환경 비교"""
        comparison = EnvironmentPhilosophy.global_vs_venv()
        assert "전역 환경" in comparison
        assert "가상 환경" in comparison
        assert comparison["전역 환경"]["격리"] == "없음"
        assert comparison["가상 환경"]["격리"] == "완전 격리"


