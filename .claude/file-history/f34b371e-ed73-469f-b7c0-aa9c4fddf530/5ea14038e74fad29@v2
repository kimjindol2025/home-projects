class TestIntegration:
    """통합 테스트"""

    def test_full_workflow(self):
        """전체 워크플로우"""
        # 프로젝트 생성
        project = ProjectEnvironment("gogs_lab")

        # 개발 환경 설정
        dev_setup = project.setup_development()
        assert dev_setup["environment"] == "development"

        # requirements.txt 생성
        req_content = project.generate_requirements_file()
        assert len(req_content) > 0

        # 새 프로젝트에서 복원
        project2 = ProjectEnvironment("gogs_lab_restored")
        restore_results = project2.restore_from_requirements(req_content)
        assert len(restore_results) > 0

        # 두 프로젝트의 패키지 비교
        info1 = project.get_project_info()
        info2 = project2.get_project_info()
        assert len(info1["packages"]) == len(info2["packages"])

    def test_environment_validation_workflow(self):
        """환경 검증 워크플로우"""
        project = ProjectEnvironment("validation_test")
        project.setup_development()

        # 건강 상태 체크
        health = EnvironmentValidator.get_health_check(
            project.venv, project.package_manager
        )
        assert health["venv_created"] is True
        assert health["package_count"] > 0

        # Requirements 검증
        requirements = list(project.package_manager.installed_packages.values())
        installed = project.package_manager.list_installed()
        valid, msgs = EnvironmentValidator.validate_requirements(
            requirements, installed
        )
        assert valid is True


