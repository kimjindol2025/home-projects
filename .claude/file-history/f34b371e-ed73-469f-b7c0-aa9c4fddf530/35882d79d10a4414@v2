class TestGeneratorExpressions:
    """제너레이터 표현식 테스트"""

    def test_generator_expression_vs_list(self):
        """제너레이터 표현식과 리스트 컴프리헨션"""
        result = demonstrate_generator_expressions()
        assert "list_comprehension" in result
        assert "generator_expression" in result
        assert result["list_comprehension_type"] == "list"
        assert result["generator_expression_type"] == "generator"

    def test_generator_expression_lazy(self):
        """제너레이터 표현식의 게으른 연산"""
        gen_expr = (x * 2 for x in range(5))
        result = list(gen_expr)
        assert result == [0, 2, 4, 6, 8]

    def test_generator_expression_memory_efficient(self):
        """제너레이터 표현식이 메모리 효율적"""
        list_comp_size = sys.getsizeof([x for x in range(10000)])
        gen_expr_size = sys.getsizeof((x for x in range(10000)))
        assert gen_expr_size < list_comp_size


