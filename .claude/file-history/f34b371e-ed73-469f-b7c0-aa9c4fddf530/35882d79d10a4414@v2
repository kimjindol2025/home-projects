    def test_flatten_single_level(self):
        """단일 레벨"""
        nested = [1, 2, 3]
        result = list(flatten_with_yield_from(nested))
        assert result == [1, 2, 3]

    def test_flatten_empty(self):
        """빈 리스트"""
        nested = []
        result = list(flatten_with_yield_from(nested))
        assert result == []

    def test_merge_generators(self):
        """제너레이터 병합"""
        gen1 = simple_generator(3)  # 0, 1, 2
        gen2 = simple_generator(3)  # 0, 1, 2
        result = list(merge_generators(gen1, gen2))
        assert result == [0, 1, 2, 0, 1, 2]


