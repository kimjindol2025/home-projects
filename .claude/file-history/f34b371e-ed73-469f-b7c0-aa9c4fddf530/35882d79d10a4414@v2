class TestBasicGenerators:
    """기본 제너레이터 테스트"""

    def test_simple_generator(self):
        """간단한 제너레이터"""
        gen = simple_generator(5)
        result = list(gen)
        assert result == [0, 1, 2, 3, 4]

    def test_simple_generator_is_generator(self):
        """반환값이 제너레이터인가"""
        gen = simple_generator(3)
        assert hasattr(gen, '__iter__')
        assert hasattr(gen, '__next__')

    def test_range_generator(self):
        """range 제너레이터"""
        gen = range_generator(2, 8, 2)
        result = list(gen)
        assert result == [2, 4, 6]

    def test_range_generator_default_step(self):
        """기본 step 값"""
        gen = range_generator(0, 3)
        result = list(gen)
        assert result == [0, 1, 2]

    def test_fibonacci_generator(self):
        """피보나치 제너레이터"""
        gen = fibonacci_generator(20)
        result = list(gen)
        assert result == [0, 1, 1, 2, 3, 5, 8, 13]

    def test_fibonacci_infinite(self):
        """피보나치 무한 제너레이터"""
        gen = fibonacci_generator(None)
        # 처음 10개만 가져오기
        result = [next(gen) for _ in range(10)]
        assert len(result) == 10
        assert result[0] == 0
        assert result[1] == 1


