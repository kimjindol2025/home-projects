class TestYieldFrom:
    """yield from 테스트"""

    def test_flatten_nested_list(self):
        """중첩 리스트 평탄화"""
        nested = [1, [2, 3], [4, [5, 6]]]
        result = list(flatten_with_yield_from(nested))
