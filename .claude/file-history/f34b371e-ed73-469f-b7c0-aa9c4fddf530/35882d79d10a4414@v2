        assert result["공간 복잡도"] == "O(n) - 모든 데이터 메모리 보유"

    def test_solution_with_generators(self):
        """제너레이터의 해결책"""
        result = GeneratorPhilosophy.solution_with_generators()
        assert "해결" in result
        assert "메모리" in result
