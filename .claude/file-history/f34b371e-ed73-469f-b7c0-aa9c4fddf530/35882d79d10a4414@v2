        gen_gen = MemoryComparison.generator_approach(1000000)

        list_size = sys.getsizeof(list_gen)
        gen_size = sys.getsizeof(gen_gen)

        # 리스트가 1000배 이상 크다
        assert list_size / gen_size > 1000


