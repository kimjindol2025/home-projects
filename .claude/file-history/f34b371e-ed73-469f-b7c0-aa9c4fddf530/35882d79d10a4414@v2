class TestMemoryComparison:
    """메모리 효율성 테스트"""

    def test_memory_comparison_structure(self):
        """메모리 비교 결과 구조"""
        result = MemoryComparison.compare_memory(1000)
        assert "n" in result
        assert result["n"] == 1000
        assert "list_size_bytes" in result
        assert "generator_size_bytes" in result
        assert "efficiency_ratio" in result

    def test_list_larger_than_generator(self):
        """리스트가 제너레이터보다 크다"""
        result = MemoryComparison.compare_memory(10000)
        assert result["list_size_bytes"] > result["generator_size_bytes"]

    def test_efficiency_ratio_high(self):
        """효율성 비율이 높다"""
        result = MemoryComparison.compare_memory(100000)
        assert result["efficiency_ratio"] > 100

    def test_generator_size_constant(self):
        """제너레이터 크기는 거의 동일"""
        result1 = MemoryComparison.compare_memory(1000)
        result2 = MemoryComparison.compare_memory(100000)
        # 제너레이터 크기는 n과 무관하게 거의 동일
        assert abs(result1["generator_size_bytes"] - result2["generator_size_bytes"]) < 100


