class TestInfiniteSequences:
    """무한 수열 테스트"""

    def test_infinite_counter(self):
        """무한 카운터"""
        counter = infinite_counter(10)
        result = [next(counter) for _ in range(5)]
        assert result == [10, 11, 12, 13, 14]

    def test_infinite_fibonacci(self):
        """무한 피보나치"""
        fib = infinite_fibonacci()
        result = [next(fib) for _ in range(8)]
        assert result == [0, 1, 1, 2, 3, 5, 8, 13]

    def test_cycle_repeats(self):
        """무한 반복"""
        cycler = cycle([1, 2, 3])
        result = [next(cycler) for _ in range(9)]
        assert result == [1, 2, 3, 1, 2, 3, 1, 2, 3]

    def test_demonstrate_infinite_sequence(self):
        """무한 수열 데모"""
        result = demonstrate_infinite_sequence()
        assert "first_10" in result
        assert len(result["first_10"]) == 10
        assert result["first_10"] == list(range(10))


