class TestCoroutines:
    """코루틴 테스트"""

    def test_accumulator_basic(self):
        """기본 누적"""
        acc = accumulator()
        next(acc)  # 초기화
        total1 = acc.send(10)
        total2 = acc.send(20)
        total3 = acc.send(30)
        assert total1 == 10  # 10 누적
        assert total2 == 30  # 10+20
        assert total3 == 60  # 10+20+30

    def test_average_calculator(self):
        """평균 계산"""
        avg_calc = average_calculator()
        next(avg_calc)  # 초기화
        avg1 = avg_calc.send(10)
        avg2 = avg_calc.send(20)
        avg3 = avg_calc.send(30)
        assert abs(avg1 - 10.0) < 0.01  # 10 / 1
        assert abs(avg2 - 15.0) < 0.01  # (10+20) / 2
        assert abs(avg3 - 20.0) < 0.01  # (10+20+30) / 3


