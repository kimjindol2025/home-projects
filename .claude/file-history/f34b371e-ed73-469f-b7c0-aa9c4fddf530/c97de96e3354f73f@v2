"""
v1.7 테스트: 딕셔너리
"""

from src.v1_7_my_first_dictionary import my_first_dictionary


def test_my_first_dictionary_returns_dict():
    """반환값이 딕셔너리"""
    result = my_first_dictionary()
    assert isinstance(result, dict)


def test_dictionary_basic_structure():
    """딕셔너리 기본 구조"""
    result = my_first_dictionary()
    assert "name" in result
    assert "level" in result
    assert "major" in result
    assert "point" in result


def test_dictionary_access_by_key():
    """키로 값 접근"""
    result = my_first_dictionary()
    assert result["name"] == "설계자"
    assert result["level"] == "중학생"
    assert result["major"] == "시스템 공학"


def test_dictionary_value_modification():
    """값 수정"""
    result = my_first_dictionary()
    # point는 150으로 수정됨
    assert result["point"] == 150


def test_dictionary_value_addition():
    """새로운 키-값 추가"""
    result = my_first_dictionary()
    # is_active가 추가됨
    assert "is_active" in result
    assert result["is_active"] == True


def test_dictionary_keys():
    """키 목록 가져오기"""
    result = my_first_dictionary()
    keys = list(result.keys())
    assert "name" in keys
    assert "level" in keys
    assert "major" in keys
    assert "point" in keys
    assert "is_active" in keys


def test_dictionary_key_uniqueness():
    """같은 키를 두 번 설정하면 나중 값으로 덮어써짐"""
    test_dict = {"age": 20}
    test_dict["age"] = 25
    assert test_dict["age"] == 25


def test_dictionary_with_different_value_types():
    """서로 다른 타입의 값"""
    student = {
        "name": "Alice",
        "age": 20,
        "gpa": 3.8,
        "is_active": True
    }
    assert isinstance(student["name"], str)
    assert isinstance(student["age"], int)
    assert isinstance(student["gpa"], float)
    assert isinstance(student["is_active"], bool)


def test_dictionary_length():
    """딕셔너리의 길이"""
    result = my_first_dictionary()
    assert len(result) == 5  # name, level, major, point, is_active


def test_dictionary_get_all_values():
    """모든 값 가져오기"""
    result = my_first_dictionary()
    values = list(result.values())
    assert "설계자" in values
    assert "중학생" in values
    assert "시스템 공학" in values
    assert 150 in values
    assert True in values


def test_dictionary_iteration():
    """딕셔너리 순회"""
    result = my_first_dictionary()
    keys_collected = []
    for key in result.keys():
        keys_collected.append(key)
    assert len(keys_collected) == 5
    assert "name" in keys_collected
