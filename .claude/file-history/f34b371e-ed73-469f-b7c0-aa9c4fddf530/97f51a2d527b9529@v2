class TestObserverPattern(unittest.TestCase):
    """옵저버 패턴 테스트"""

    def test_observer_notification(self):
        """옵저버 알림"""
        result = ObserverPattern.demo()
        self.assertEqual(result["pattern"], "Observer")
        self.assertEqual(result["observer1_state"], "New State")
        self.assertEqual(result["observer2_state"], "New State")

    def test_observer_multiple_observers(self):
        """여러 옵저버"""
        subject = ObserverPattern.Subject()
        obs1 = ObserverPattern.ConcreteObserver("O1")
        obs2 = ObserverPattern.ConcreteObserver("O2")
        obs3 = ObserverPattern.ConcreteObserver("O3")

        subject.attach(obs1)
        subject.attach(obs2)
        subject.attach(obs3)
        subject.set_state("Update")

        self.assertEqual(obs1.state, "Update")
        self.assertEqual(obs2.state, "Update")
        self.assertEqual(obs3.state, "Update")

    def test_observer_detach(self):
        """옵저버 제거"""
        subject = ObserverPattern.Subject()
        obs = ObserverPattern.ConcreteObserver("O1")
        subject.attach(obs)
        subject.detach(obs)
        subject.set_state("Update")

        self.assertIsNone(obs.state)


