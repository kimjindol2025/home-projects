class TestPatternIntegration(unittest.TestCase):
    """패턴 통합 테스트"""

    def test_all_patterns_callable(self):
        """모든 패턴 호출 가능"""
        demo_results = demonstrate_all_patterns()
        self.assertIn("SOLID", demo_results)
        self.assertIn("Singleton", demo_results)
        self.assertIn("Factory", demo_results)

    def test_pattern_count(self):
        """패턴 개수"""
        demo_results = demonstrate_all_patterns()
        # 5 SOLID + 5 Creational + 7 Structural + 11 Behavioral + 1 CleanCode
        self.assertGreaterEqual(len(demo_results), 20)

    def test_pattern_consistency(self):
        """패턴 일관성"""
        demo_results = demonstrate_all_patterns()

        for pattern_name, result in demo_results.items():
            if pattern_name not in ["SOLID", "CleanCode"]:
                self.assertIn("pattern", result)

    def test_singleton_thread_safety(self):
        """싱글톤 스레드 안전성"""
        instances = []
        for _ in range(10):
            instances.append(SingletonPattern())

        ids = set(id(inst) for inst in instances)
        self.assertEqual(len(ids), 1)

    def test_factory_encapsulation(self):
        """팩토리 캡슐화"""
        factory = FactoryPattern.DatabaseFactory()
        self.assertIsNotNone(factory)

        mysql = factory.create(FactoryPattern.DatabaseType.MYSQL)
        self.assertIsNotNone(mysql.connect())

    def test_builder_immutability(self):
        """빌더 불변성"""
        builder1 = BuilderPattern.ComputerBuilder()
        builder1.set_cpu("Intel i9")

        builder2 = BuilderPattern.ComputerBuilder()
        builder2.set_cpu("AMD Ryzen")

        comp1 = builder1.build()
        comp2 = builder2.build()

        self.assertNotEqual(comp1.cpu, comp2.cpu)

    def test_pattern_combination_factory_singleton(self):
        """팩토리 + 싱글톤"""
        # Singleton이 팩토리를 제공하는 경우
        singleton = SingletonPattern()
        singleton.set_config("db_type", "mysql")
        self.assertEqual(singleton.get_config("db_type"), "mysql")

    def test_pattern_combination_decorator_strategy(self):
        """데코레이터 + 전략"""
        # 데코레이터로 감싼 객체에 전략 적용
        coffee = DecoratorPattern.MilkDecorator(DecoratorPattern.SimpleCoffee())
        self.assertIn("Milk", coffee.get_description())

    def test_observer_subject_state(self):
        """옵저버 주체 상태"""
        subject = ObserverPattern.Subject()
        obs = ObserverPattern.ConcreteObserver("TestObs")

        subject.attach(obs)
        subject.set_state("Final State")

        self.assertEqual(subject.get_state(), "Final State")
        self.assertEqual(obs.state, "Final State")

    def test_all_patterns_no_exception(self):
