class TestMessageSerializer:
    """메시지 직렬화 테스트"""

    def test_serialize_simple_dict(self):
        """간단한 딕셔너리 직렬화"""
        data = {"message": "hello"}
        serialized = MessageSerializer.serialize(data)
        assert isinstance(serialized, bytes)
        assert b'hello' in serialized

    def test_serialize_complex_dict(self):
        """복잡한 딕셔너리 직렬화"""
        data = {
            "username": "alice",
            "message": "Hello, Network!",
            "timestamp": 1234567890
        }
        serialized = MessageSerializer.serialize(data)
        assert isinstance(serialized, bytes)

    def test_deserialize_valid_bytes(self):
        """유효한 바이트 역직렬화"""
        data = {"key": "value"}
        serialized = MessageSerializer.serialize(data)
        deserialized = MessageSerializer.deserialize(serialized)
        assert deserialized == data

    def test_deserialize_invalid_bytes(self):
        """유효하지 않은 바이트 역직렬화"""
        invalid_bytes = b'not json {]'
        result = MessageSerializer.deserialize(invalid_bytes)
        assert result is None

    def test_serialize_deserialize_roundtrip(self):
        """직렬화-역직렬화 왕복"""
        original = {
            "id": 1,
            "name": "test",
            "values": [1, 2, 3]
        }
        serialized = MessageSerializer.serialize(original)
        deserialized = MessageSerializer.deserialize(serialized)
        assert deserialized == original

    def test_serialize_empty_dict(self):
        """빈 딕셔너리 직렬화"""
        data = {}
        serialized = MessageSerializer.serialize(data)
        deserialized = MessageSerializer.deserialize(serialized)
        assert deserialized == {}

    def test_serialize_nested_dict(self):
        """중첩된 딕셔너리 직렬화"""
        data = {
            "user": {
                "name": "alice",
                "profile": {
                    "age": 30,
                    "city": "Seoul"
                }
            }
        }
        serialized = MessageSerializer.serialize(data)
        deserialized = MessageSerializer.deserialize(serialized)
        assert deserialized == data

    def test_demo(self):
        """데모 메서드"""
        result = MessageSerializer.demo()
        assert isinstance(result, dict)
        assert "original" in result
        assert "serialized_type" in result
        assert "deserialized" in result
        assert result["match"] is True


