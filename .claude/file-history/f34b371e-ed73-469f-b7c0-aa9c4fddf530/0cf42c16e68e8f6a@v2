class TestTCPServer:
    """TCP 서버 테스트"""

    def test_tcp_server_init(self):
        """TCP 서버 초기화"""
        server = TCPServer(host='localhost', port=9999, backlog=5)
        assert server.host == 'localhost'
        assert server.port == 9999
        assert server.backlog == 5
        assert server.is_running is False
        assert server.server_socket is None

    def test_tcp_server_start(self):
        """TCP 서버 시작"""
        server = TCPServer(host='localhost', port=9990)
        result = server.start()
        assert result is True
        assert server.is_running is True
        assert server.server_socket is not None
        server.stop()

    def test_tcp_server_stop(self):
        """TCP 서버 종료"""
        server = TCPServer(host='localhost', port=9991)
        server.start()
        assert server.is_running is True
        server.stop()
        assert server.is_running is False

    def test_tcp_server_setsockopt_reuse(self):
        """TCP 서버 SO_REUSEADDR 옵션"""
        server1 = TCPServer(host='localhost', port=9992)
        result1 = server1.start()
        assert result1 is True

        # SO_REUSEADDR가 설정되어 있으므로 같은 포트로 재시작 가능
        # (하지만 첫 번째 서버와 동시에는 어려울 수 있음)
        server1.stop()
        time.sleep(0.1)

        server2 = TCPServer(host='localhost', port=9992)
        result2 = server2.start()
        assert result2 is True

        server2.stop()

    def test_tcp_server_accept_client_without_connection(self):
        """클라이언트 연결 없을 때 accept"""
        server = TCPServer(host='localhost', port=9993)
        server.start()

        # 타임아웃 설정 후 accept 시도
        server.server_socket.settimeout(0.5)
        result = server.accept_client()

        # 연결 없으면 None 반환해야 함
        assert result is None
        server.stop()


