class TestHTTPRequest:
    """HTTP 요청 테스트"""

    def test_http_request_init(self):
        """HTTP 요청 초기화"""
        request = HTTPRequest("GET", "/api/users")
        assert request.method == "GET"
        assert request.path == "/api/users"
        assert request.headers == {}
        assert request.body == ""

    def test_http_request_with_headers(self):
        """헤더를 포함한 HTTP 요청"""
        headers = {"Host": "example.com", "Content-Type": "application/json"}
        request = HTTPRequest("POST", "/api/data", headers=headers)
        assert request.headers == headers

    def test_http_request_with_body(self):
        """바디를 포함한 HTTP 요청"""
        request = HTTPRequest("POST", "/api/users", body='{"name":"alice"}')
        assert request.body == '{"name":"alice"}'

    def test_http_request_to_bytes(self):
        """HTTP 요청을 바이트로 변환"""
        request = HTTPRequest("GET", "/api/users", headers={"Host": "example.com"})
        data = request.to_bytes()
        assert isinstance(data, bytes)
        assert b"GET" in data
        assert b"/api/users" in data
        assert b"HTTP/1.1" in data

    def test_http_request_from_bytes(self):
        """바이트에서 HTTP 요청 파싱"""
        request_bytes = b"GET /api/users HTTP/1.1\r\nHost: example.com\r\n\r\n"
        request = HTTPRequest.from_bytes(request_bytes)
        assert request is not None
        assert request.method == "GET"
        assert request.path == "/api/users"

    def test_http_request_from_bytes_with_body(self):
        """바디를 포함한 HTTP 요청 파싱"""
        request_bytes = b"POST /api/data HTTP/1.1\r\nHost: example.com\r\nContent-Type: application/json\r\n\r\n{\"key\":\"value\"}"
        request = HTTPRequest.from_bytes(request_bytes)
        assert request is not None
        assert request.method == "POST"

    def test_http_request_from_invalid_bytes(self):
        """유효하지 않은 바이트 파싱"""
        request = HTTPRequest.from_bytes(b"invalid")
        assert request is None


