"""
v2.1 테스트: 예외 처리
"""

from src.v2_1_exception_handling import gogs_divider, exception_handling_demo


def test_exception_handling_demo_returns_dict():
    """반환값이 딕셔너리"""
    result = exception_handling_demo()
    assert isinstance(result, dict)


def test_normal_division():
    """정상 작동: 10 / 2 = 5"""
    result = gogs_divider(10, 2)
    assert result == 5.0


def test_zero_division_error():
    """0으로 나누기 예외 처리: 0을 반환"""
    result = gogs_divider(10, 0)
    assert result == 0


def test_type_error():
    """타입 에러 예외 처리: None을 반환"""
    result = gogs_divider(10, "gogs")
    assert result is None


def test_normal_with_float():
    """부동소수점 나눗셈"""
    result = gogs_divider(7, 2)
    assert result == 3.5


def test_negative_division():
    """음수 나눗셈"""
    result = gogs_divider(-10, 2)
    assert result == -5.0


def test_zero_dividend():
    """0을 나누기: 0 / 5 = 0"""
    result = gogs_divider(0, 5)
    assert result == 0.0


def test_type_error_with_list():
    """리스트와 숫자의 나눗셈 시도"""
    result = gogs_divider([1, 2, 3], 2)
    assert result is None


def test_multiple_operations():
    """여러 연산 수행"""
    result_dict = exception_handling_demo()
    assert result_dict["normal"] == 5.0
    assert result_dict["zero_division"] == 0
    assert result_dict["type_error"] is None


def test_exception_robustness():
    """프로그램이 예외에도 불구하고 계속 실행"""
    # 정상 작동
    r1 = gogs_divider(20, 4)
    assert r1 == 5.0

    # 에러 발생해도 다음 연산 진행
    r2 = gogs_divider(20, 0)
    assert r2 == 0

    # 또 다른 정상 작동
    r3 = gogs_divider(15, 3)
    assert r3 == 5.0

    # 프로그램이 죽지 않고 계속됨을 증명
    assert r1 is not None and r2 is not None and r3 is not None


def test_complex_division_chain():
    """연쇄 나눗셈 연산"""
    # 1단계: 100 / 2 = 50
    result1 = gogs_divider(100, 2)

    # 2단계: 결과 나누기 5 = 10
    result2 = gogs_divider(result1, 5)

    # 3단계: 결과 나누기 2 = 5
    result3 = gogs_divider(result2, 2)

    assert result1 == 50.0
    assert result2 == 10.0
    assert result3 == 5.0
