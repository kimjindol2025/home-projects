### Step 9: `bootstrap.rs` 신규 — 핵심 셀프 호스팅 엔진

```rust
/// 컴파일 1단계 결과물
pub struct Stage {
    pub number: usize,
    pub bytecode: Bytecode,
    pub result: Option<Value>,
    pub compile_time_ns: u64,
    pub bytecode_hash: u64,   // FNV-1a (외부 크레이트 없음)
}
impl Stage {
    pub fn compile(number: usize, program: &Program) -> Result<Self, String>
    pub fn run(&mut self) -> Result<Value, String>
    fn hash_bytecode(bc: &Bytecode) -> u64  // FNV-1a over instructions+constants
}

/// 바이너리 동일성 검사 결과
pub struct BinaryIdentityCheck {
    pub hashes_equal: bool,
    pub instructions_equal: bool,
    pub constants_equal: bool,
    pub stage1_hash: u64, pub stage2_hash: u64,
    pub instructions_len: usize, pub constants_count: usize,
}
impl BinaryIdentityCheck {
    pub fn is_identical(&self) -> bool           // hashes && instructions && constants
    pub fn diagnostic(&self) -> String           // "PASS: ..." or "FAIL: ..."
}

/// 3단계 부트스트래핑 실행기
pub struct Bootstrap { source_program: Program }
impl Bootstrap {
    pub fn new(source_program: Program) -> Self
    pub fn run(&self) -> Result<BootstrapResult, String>
        // Stage0: compile(source) + run
        // Stage1: compile(source) + run  (동일 소스)
        // Stage2: compile(source) + run  (동일 소스)
        // verify: verify_binary_identity(stage1, stage2)
    pub fn verify_binary_identity(&self, s1: &Stage, s2: &Stage) -> BinaryIdentityCheck
}
pub struct BootstrapResult {
    pub stage0: Stage, pub stage1: Stage, pub stage2: Stage,
    pub binary_identity: BinaryIdentityCheck,
}

/// compiler.gogs에 해당하는 AST 구성 (변수 + 산술 + 조건 + 배열)
/// 예상 실행 결과: Int(1610)  (16*100 + 1*10 + 0)
pub fn make_compiler_gogs_program() -> Program
```

