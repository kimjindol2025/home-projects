"""
v1.2 Lazy Evaluation: 제너레이터 기초

파이썬의 yield 키워드는 함수를 일시정지(Suspend)했다가
다시 시작(Resume)하는 코루틴(Coroutine)의 기초입니다.

"필요할 때만 생성하는 지능형 흐름"
"""

from typing import Generator, Any, Iterator
import sys


class GeneratorBasics:
    """제너레이터의 기본 개념"""

    @staticmethod
    def simple_generator() -> Generator[int, None, None]:
        """
        가장 간단한 제너레이터: 0, 1, 2를 하나씩 산출

        yield: 함수의 실행을 일시 정지하고 값을 반환
        """
        print("  [제너레이터 시작]")
        yield 0
        print("  [첫 번째 yield 후]")
        yield 1
        print("  [두 번째 yield 후]")
        yield 2
        print("  [제너레이터 종료]")

    @staticmethod
    def count_up(n: int) -> Generator[int, None, None]:
        """
        0부터 n-1까지 세기

        Args:
            n: 최대값

        Yields:
            0부터 n-1까지의 정수
        """
        for i in range(n):
            yield i

    @staticmethod
    def infinite_counter() -> Generator[int, None, None]:
        """
        무한 수열: 0, 1, 2, 3, ...

        무한이지만, 제너레이터는 필요할 때마다 하나씩만 생성하므로 메모리 문제 없음
        """
        i = 0
        while True:
            yield i
            i += 1

    @staticmethod
    def fibonacci() -> Generator[int, None, None]:
        """
        피보나치 수열: 0, 1, 1, 2, 3, 5, 8, 13, ...
        """
        a, b = 0, 1
        while True:
            yield a
            a, b = b, a + b

    @staticmethod
    def demonstrate_basic():
        """제너레이터의 기본 동작 시연"""
        print("\n" + "="*60)
        print("제너레이터 기초: yield와 일시정지")
        print("="*60)

        print("\n  [1단계: 제너레이터 객체 생성]")
        gen = GeneratorBasics.simple_generator()
        print(f"    gen = simple_generator()")
        print(f"    type(gen): {type(gen)}")
        print(f"    gen은 아직 실행되지 않음!")

        print("\n  [2단계: next() 호출 - 첫 번째 yield까지 실행]")
        value1 = next(gen)
        print(f"    next(gen) → {value1}")

        print("\n  [3단계: next() 호출 - 두 번째 yield까지 실행]")
        value2 = next(gen)
        print(f"    next(gen) → {value2}")

        print("\n  [4단계: next() 호출 - 세 번째 yield까지 실행]")
        value3 = next(gen)
        print(f"    next(gen) → {value3}")

        print("\n  [5단계: next() 호출 - StopIteration 발생]")
        try:
            next(gen)
        except StopIteration:
            print(f"    next(gen) → StopIteration (제너레이터 종료)")

        print("\n" + "="*60)

    @staticmethod
    def demonstrate_for_loop():
        """제너레이터와 for 루프"""
        print("\n" + "="*60)
        print("제너레이터와 for 루프")
        print("="*60)

        print("\n  [for 루프 사용 (내부적으로 next() 호출)]")
        print("    for value in count_up(3):")
        for value in GeneratorBasics.count_up(3):
            print(f"      {value}")

        print("\n" + "="*60)

    @staticmethod
    def demonstrate_infinite():
        """무한 수열의 현실성"""
        print("\n" + "="*60)
        print("무한 수열: 논리적으로 무한한 기록")
        print("="*60)

        print("\n  [무한 수열 생성]")
        inf = GeneratorBasics.infinite_counter()
        print(f"    inf = infinite_counter()")
        print(f"    메모리 크기: {sys.getsizeof(inf)} bytes (고정!)")

        print("\n  [필요한 만큼만 꺼내기]")
        for i in range(5):
            value = next(inf)
            print(f"    next(inf) → {value}")

        print("\n  [결론: 메모리는 일정하지만, 무한하게 생성 가능]")

        print("\n" + "="*60)

    @staticmethod
    def demonstrate_fibonacci():
        """피보나치 수열"""
        print("\n" + "="*60)
        print("피보나치 수열: 상태 유지 제너레이터")
        print("="*60)

        print("\n  [피보나치 수열 (처음 10개)]")
        fib = GeneratorBasics.fibonacci()
        values = [next(fib) for _ in range(10)]
        print(f"    {values}")

        print("\n" + "="*60)


class GeneratorState:
    """제너레이터의 상태 추적"""

    @staticmethod
    def analyze_generator(gen: Generator) -> None:
        """제너레이터의 상태를 분석"""
        print(f"\n제너레이터 분석:")
        print(f"  Type: {type(gen)}")
        print(f"  Size: {sys.getsizeof(gen)} bytes")

        # 제너레이터의 내부 상태 확인
        if hasattr(gen, 'gi_frame'):
            frame = gen.gi_frame
            if frame:
                print(f"  Current Frame: {frame.f_lineno}")
                print(f"  Local Variables: {frame.f_locals}")
            else:
                print(f"  Current Frame: None (Generator 종료)")

    @staticmethod
    def demonstrate_state():
        """제너레이터의 상태 변화"""
        print("\n" + "="*60)
        print("제너레이터 상태 추적")
        print("="*60)

        gen = GeneratorBasics.count_up(3)

        print("\n  [초기 상태]")
        GeneratorState.analyze_generator(gen)

        print("\n  [첫 번째 next() 후]")
        next(gen)
        GeneratorState.analyze_generator(gen)

        print("\n  [두 번째 next() 후]")
        next(gen)
        GeneratorState.analyze_generator(gen)

        print("\n  [제너레이터 완료]")
        next(gen)
        try:
            next(gen)
        except StopIteration:
            pass
        GeneratorState.analyze_generator(gen)

        print("\n" + "="*60)


class GeneratorExpression:
    """제너레이터 표현식 (한 줄 제너레이터)"""

    @staticmethod
    def demonstrate():
        """제너레이터 표현식 시연"""
        print("\n" + "="*60)
        print("제너레이터 표현식")
        print("="*60)

        print("\n  [리스트 컴프리헨션 vs 제너레이터 표현식]")
        print("    List Comp: [x*2 for x in range(5)]")
        print("    Gen Expr:  (x*2 for x in range(5))")

        print("\n  [문법 비교]")
        print("    [] → 리스트 (eager)")
        print("    () → 제너레이터 (lazy)")

        print("\n  [사용 예]")
        gen_expr = (x*2 for x in range(5))
        print(f"    gen_expr = (x*2 for x in range(5))")
        print(f"    메모리 크기: {sys.getsizeof(gen_expr)} bytes")
        print(f"    값들: {list(gen_expr)}")

        print("\n" + "="*60)


# ============================================================================
# 메인 실행 함수
# ============================================================================

def demonstrate_generators():
    """제너레이터의 모든 측면을 시연합니다"""
    print("\n" + "="*60)
    print("🐍 Python v1.2: 제너레이터 기초")
    print("="*60)

    GeneratorBasics.demonstrate_basic()
    GeneratorBasics.demonstrate_for_loop()
    GeneratorBasics.demonstrate_infinite()
    GeneratorBasics.demonstrate_fibonacci()
    GeneratorState.demonstrate_state()
    GeneratorExpression.demonstrate()

    print("\n" + "="*60)
    print("저장 필수. 너는 기록이 증명이다. Gogs.")
    print("="*60 + "\n")


if __name__ == "__main__":
    demonstrate_generators()
