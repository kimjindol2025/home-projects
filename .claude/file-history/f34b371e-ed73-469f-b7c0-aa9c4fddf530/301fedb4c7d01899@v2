### 질문 2️⃣: Zero-Cost DSL with Procedural Macros

#### 목표
사용자가 실수로 스택 순서를 틀리지 않도록 Procedural Macro로 가상 머신 명령어를 안전하게 래핑하기.
예: `gogs_asm!( PUSH(5), ADD )` → 스택 깊이를 미리 계산

#### 구현 1: Macro 정의 (proc-macro 크레이트)

```rust
// [v20.1-dsl-01] proc-macro/src/lib.rs
// Procedural Macro: gogs_asm! DSL

use proc_macro::TokenStream;
use quote::quote;
use syn::{parse_macro_input, Expr};

/// gogs_asm! - Zero-Cost Assembly Language DSL
///
/// # 예제
/// ```ignore
/// gogs_asm! {
///     PUSH(5),
///     PUSH(3),
///     ADD,
///     PRINT
/// }
/// ```
///
/// # 컴파일 타임 검증
/// - 스택 깊이 계산
/// - 타입 검증
/// - 명령어 유효성 검사
#[proc_macro]
pub fn gogs_asm(input: TokenStream) -> TokenStream {
    let input_str = input.to_string();

    // 1단계: 명령어 파싱
    let instructions = parse_instructions(&input_str);

    // 2단계: 스택 깊이 검증 (컴파일 타임)
    let stack_analysis = analyze_stack_depth(&instructions);

    // 3단계: 에러 감지
    for error in &stack_analysis.errors {
        // 컴파일 타임 에러 생성
        return syn::Error::new_spanned(
            &syn::parse::<Expr>(input).unwrap(),
            format!("Invalid bytecode: {}", error)
        ).to_compile_error().into();
    }

    // 4단계: 바이트코드 생성
    let bytecode = generate_bytecode(&instructions);

    // 5단계: Rust 코드로 변환 (Zero-Cost)
    let output = quote! {
        {
            // 이 블록은 컴파일 타임에 완전히 최적화됨
            let mut bytecode_buffer = Vec::new();
            #(
                bytecode_buffer.push(#bytecode);
            )*
            Bytecode::from_buffer(bytecode_buffer)
        }
    };

    output.into()
}

/// 명령어 파싱 함수
fn parse_instructions(input: &str) -> Vec<Instruction> {
    // PUSH(5), ADD, PRINT 등을 파싱
    vec![
        // 실제 구현에서는 문자열을 파싱하여 Instruction enum으로 변환
    ]
}

/// 스택 깊이 분석 (컴파일 타임)
#[derive(Debug)]
struct StackAnalysis {
    max_depth: usize,
    final_depth: usize,
    errors: Vec<String>,
}

fn analyze_stack_depth(instructions: &[Instruction]) -> StackAnalysis {
    let mut stack_depth = 0;
    let mut max_depth = 0;
    let mut errors = Vec::new();

    for (i, instr) in instructions.iter().enumerate() {
        match instr {
            Instruction::Push(_) => {
                stack_depth += 1;
                max_depth = max_depth.max(stack_depth);
            }
            Instruction::Pop => {
                if stack_depth == 0 {
                    errors.push(format!(
                        "Instruction {}: POP on empty stack",
                        i
                    ));
                } else {
                    stack_depth -= 1;
                }
            }
            Instruction::Add => {
                if stack_depth < 2 {
                    errors.push(format!(
                        "Instruction {}: ADD requires 2 stack elements, have {}",
                        i, stack_depth
                    ));
                } else {
                    stack_depth -= 1;  // 두 개를 소비해서 하나를 생성
                }
            }
            _ => {}
        }
    }

    StackAnalysis {
        max_depth,
        final_depth: stack_depth,
        errors,
    }
}

enum Instruction {
    Push(i64),
    Pop,
    Add,
    Sub,
    Print,
    // ...
}

fn generate_bytecode(instructions: &[Instruction]) -> Vec<u8> {
    let mut bytecode = Vec::new();
    for instr in instructions {
        match instr {
            Instruction::Push(val) => {
                bytecode.push(0x01);  // OpCode::PUSH
                bytecode.extend_from_slice(&val.to_le_bytes());
            }
            Instruction::Add => {
                bytecode.push(0x02);  // OpCode::ADD
            }
            // ...
        }
    }
    bytecode
}
```

