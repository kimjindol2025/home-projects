### 질문 3️⃣: Async Memory Safety with Pin<P> & Arc

#### 목표
비동기 태스크가 살아있는 동안, 그 태스크가 사용하는 메모리 버퍼가 GC에 의해 해제되거나 이동되지 않도록
`Pin<P>`와 `Arc`를 결합하여 gogs 런타임에 이식하기.

#### 구현 1: 비동기 안전 버퍼 구조

```rust
// [v20.1-async-01] Pin-Based Async-Safe Buffers

use std::sync::Arc;
use std::pin::Pin;
use std::task::{Context, Poll};
use std::future::Future;

/// Gogs 런타임의 비동기 안전 메모리 버퍼
///
/// # 설계 원칙
/// - Pin<Arc<RwLock<T>>>로 메모리 이동 방지
/// - GC는 이 버퍼를 건드릴 수 없음 (고정됨)
/// - 비동기 태스크가 살아있는 동안 유효성 보증
#[derive(Clone)]
pub struct AsyncSafeBuffer {
    /// 실제 데이터는 Pin+Arc로 관리 (이동 불가, 다중 소유)
    data: Arc<std::sync::RwLock<Vec<u8>>>,
    /// Pinning 마커: 이 구조체 자체는 Unpin이지만,
    /// 메모리 주소는 변하지 않음을 보증
    _pinned: std::marker::PhantomPinned,
}

impl AsyncSafeBuffer {
    /// 생성: 초기 용량으로 버퍼 할당
    pub fn new(capacity: usize) -> Self {
        AsyncSafeBuffer {
            data: Arc::new(std::sync::RwLock::new(Vec::with_capacity(capacity))),
            _pinned: std::marker::PhantomPinned,
        }
    }

    /// 데이터 쓰기 (비동기 안전)
    pub async fn write(&self, chunk: &[u8]) -> Result<(), String> {
        // Arc를 통해 여러 비동기 태스크가 동일 버퍼 공유 가능
        let mut buffer = self.data.write().unwrap();
        buffer.extend_from_slice(chunk);
        Ok(())
    }

    /// 데이터 읽기 (비동기 안전)
    pub async fn read(&self) -> Result<Vec<u8>, String> {
        let buffer = self.data.read().unwrap();
        Ok(buffer.clone())
    }

    /// 버퍼 크기 조회
    pub fn len(&self) -> usize {
        self.data.read().unwrap().len()
    }
}

/// 중요: AsyncSafeBuffer는 Unpin이 아니므로 이동할 수 없음
impl !std::marker::Unpin for AsyncSafeBuffer {}
```

#### 구현 2: 비동기 태스크 관리

```rust
// [v20.1-async-02] Async Task Runtime with GC-Safe Buffers

use std::pin::Pin;
use std::task::{Context, Poll};
use std::future::Future;

/// Gogs 비동기 런타임의 태스크 핸들
pub struct GogsAsyncTask<F: Future> {
    /// 태스크가 사용하는 버퍼들
    buffers: Vec<AsyncSafeBuffer>,
    /// 실제 Future
    future: Pin<Box<F>>,
    /// GC에서 보호 여부
    gc_protected: bool,
}

impl<F: Future> GogsAsyncTask<F> {
    /// 새 태스크 생성 (Arc 기반)
    pub fn new(future: F, buffers: Vec<AsyncSafeBuffer>) -> Pin<Arc<Self>> {
        Pin::from(Arc::new(GogsAsyncTask {
            buffers,
            future: Box::pin(future),
            gc_protected: true,  // GC에서 이 태스크 보호
        }))
    }

    /// 태스크가 살아있는 동안 버퍼 접근
    pub fn get_buffer(&self, index: usize) -> Option<AsyncSafeBuffer> {
        self.buffers.get(index).cloned()
    }
}

// 비동기 Future 구현
impl<F: Future + Unpin> Future for GogsAsyncTask<F> {
    type Output = F::Output;

    fn poll(mut self: Pin<&mut Self>, cx: &mut Context<'_>) -> Poll<Self::Output> {
        // self는 Pin<Arc<...>>이므로, 메모리 이동 불가능
        // 따라서 GC가 이 태스크를 이동할 수 없음
        self.future.as_mut().poll(cx)
    }
}
