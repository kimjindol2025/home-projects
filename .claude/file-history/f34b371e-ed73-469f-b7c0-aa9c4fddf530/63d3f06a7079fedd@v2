class UDPServer:
    """UDP 서버 - 빠르지만 신뢰성 없음"""

    def __init__(self, host: str = "127.0.0.1", port: int = 9998):
        self.host = host
        self.port = port
        self.socket = None

    def start(self):
        """서버 시작"""
        self.socket = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        self.socket.bind((self.host, self.port))
        print(f"📡 UDP 서버 시작: {self.host}:{self.port}")

    def receive_once(self, bufsize: int = 1024) -> Tuple[str, Tuple]:
        """한 번 수신"""
        data, address = self.socket.recvfrom(bufsize)
        message = data.decode("utf-8")
        print(f"📥 UDP 수신: {address} → {message}")
        return message, address

    def send_to(self, message: str, address: Tuple):
        """특정 주소로 전송"""
        self.socket.sendto(message.encode("utf-8"), address)
        print(f"📤 UDP 송신: {address} ← {message}")

    def close(self):
        """서버 종료"""
        if self.socket:
            self.socket.close()
            print("🛑 UDP 서버 종료")


class UDPClient:
    """UDP 클라이언트"""

    def __init__(self, server_host: str = "127.0.0.1", server_port: int = 9998):
        self.server_address = (server_host, server_port)
        self.socket = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)

    def send_message(self, message: str):
        """메시지 전송"""
        self.socket.sendto(message.encode("utf-8"), self.server_address)
        print(f"📤 UDP 송신: {message}")

    def receive_message(self, bufsize: int = 1024) -> Optional[str]:
        """메시지 수신"""
        try:
            data, _ = self.socket.recvfrom(bufsize)
            message = data.decode("utf-8")
            print(f"📥 UDP 수신: {message}")
            return message
        except Exception as e:
            print(f"❌ 오류: {e}")
            return None

    def close(self):
        """클라이언트 종료"""
        self.socket.close()


