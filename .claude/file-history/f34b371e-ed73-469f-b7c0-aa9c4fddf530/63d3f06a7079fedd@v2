class SimpleTCPServer:
    """기본 TCP 서버 - 한 번에 한 명의 클라이언트 처리"""

    def __init__(self, host: str = "127.0.0.1", port: int = 9999):
        self.host = host
        self.port = port
        self.socket = None
        self.running = False

    def start(self):
        """서버 시작"""
        self.socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        self.socket.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        self.socket.bind((self.host, self.port))
        self.socket.listen(1)
        self.running = True
        print(f"📡 서버 시작: {self.host}:{self.port}")

    def accept_connection(self):
        """클라이언트 연결 수락"""
        if not self.running:
            return None, None

        try:
            client_socket, address = self.socket.accept()
            print(f"🤝 클라이언트 연결: {address}")
            return client_socket, address
        except Exception as e:
            print(f"❌ 연결 수락 오류: {e}")
            return None, None

    def send_message(self, client_socket, message: str):
        """메시지 전송"""
        try:
            client_socket.sendall(message.encode("utf-8"))
        except Exception as e:
            print(f"❌ 전송 오류: {e}")

    def receive_message(self, client_socket, bufsize: int = 1024) -> Optional[str]:
        """메시지 수신"""
        try:
            data = client_socket.recv(bufsize)
            if not data:
                return None
            return data.decode("utf-8")
        except Exception as e:
            print(f"❌ 수신 오류: {e}")
            return None

    def close(self):
        """서버 종료"""
        if self.socket:
            self.socket.close()
            self.running = False
            print("🛑 서버 종료")


