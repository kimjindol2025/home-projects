# ============================================================================

class NonBlockingServer(SimpleTCPServer):
    """논블로킹 소켓 - CPU가 계속 다른 일을 함"""

    def __init__(self, host: str = "127.0.0.1", port: int = 9997):
        super().__init__(host, port)
        self.clients = {}

    def start(self):
        """서버 시작 (논블로킹 모드)"""
        super().start()
        self.socket.setblocking(False)
        print("⚡ 논블로킹 모드 활성화")

    def handle_connections(self, timeout: float = 1.0):
        """연결 처리 (타임아웃 내에서)"""
        start_time = time.time()

        while time.time() - start_time < timeout:
            try:
                # 새 연결 시도
                client_socket, address = self.socket.accept()
                client_socket.setblocking(False)
                self.clients[address] = client_socket
                print(f"🤝 클라이언트 추가: {address}")
            except BlockingIOError:
                pass  # 연결 없음, 계속 진행
            except Exception as e:
                print(f"❌ 오류: {e}")

            # 기존 클라이언트로부터 데이터 수신 시도
            for address, client_socket in list(self.clients.items()):
                try:
                    data = client_socket.recv(1024)
                    if data:
                        message = data.decode("utf-8")
                        print(f"📥 [{address}] {message}")
                        client_socket.sendall(data)  # Echo
                    else:
                        # 연결 종료
                        client_socket.close()
                        del self.clients[address]
                        print(f"👋 [{address}] 연결 종료")
                except BlockingIOError:
                    pass  # 데이터 없음, 계속
                except Exception as e:
                    print(f"❌ [{address}] 오류: {e}")
                    client_socket.close()
                    del self.clients[address]


