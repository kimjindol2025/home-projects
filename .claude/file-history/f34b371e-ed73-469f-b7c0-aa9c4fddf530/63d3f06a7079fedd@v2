class FileTransferServer:
    """파일 전송 서버"""

    def __init__(self, host: str = "127.0.0.1", port: int = 9995):
        self.host = host
        self.port = port
        self.socket = None

    def start(self):
        """서버 시작"""
        self.socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        self.socket.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        self.socket.bind((self.host, self.port))
        self.socket.listen(1)
        print(f"📡 파일 전송 서버 시작: {self.host}:{self.port}")

    def receive_file(self, filename: str, bufsize: int = 4096) -> bool:
        """파일 수신"""
        try:
            client_socket, address = self.socket.accept()
            print(f"🤝 클라이언트 연결: {address}")

            with open(filename, "wb") as f:
                while True:
                    data = client_socket.recv(bufsize)
                    if not data:
                        break
                    f.write(data)

            print(f"✅ 파일 수신 완료: {filename}")
            client_socket.close()
            return True
        except Exception as e:
            print(f"❌ 오류: {e}")
            return False

    def close(self):
        """서버 종료"""
        if self.socket:
            self.socket.close()


class FileTransferClient:
    """파일 전송 클라이언트"""

    def __init__(self, server_host: str = "127.0.0.1", server_port: int = 9995):
        self.server_address = (server_host, server_port)
        self.socket = None

    def send_file(self, filename: str, bufsize: int = 4096) -> bool:
        """파일 전송"""
        try:
            self.socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            self.socket.connect(self.server_address)
            print(f"🤝 서버에 연결: {self.server_address}")

            with open(filename, "rb") as f:
                while True:
                    data = f.read(bufsize)
                    if not data:
                        break
                    self.socket.sendall(data)

            print(f"✅ 파일 전송 완료: {filename}")
            self.socket.close()
            return True
        except Exception as e:
            print(f"❌ 오류: {e}")
            return False


