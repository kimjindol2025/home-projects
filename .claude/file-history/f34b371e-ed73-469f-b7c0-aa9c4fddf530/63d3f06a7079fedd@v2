# [4] 멀티스레드 서버 - 동시 연결 처리
# ============================================================================

class MultiThreadedServer(SimpleTCPServer):
    """멀티스레드 서버 - 여러 클라이언트 동시 처리"""

    def __init__(self, host: str = "127.0.0.1", port: int = 9999):
        super().__init__(host, port)
        self.clients = []
        self.lock = threading.Lock()

    def handle_client(self, client_socket, address):
        """클라이언트 처리 (스레드마다 실행)"""
        try:
            while True:
                data = client_socket.recv(1024)
                if not data:
                    break
                message = data.decode("utf-8")
                print(f"📥 [{address}] {message}")
                # Echo
                client_socket.sendall(data)
        except Exception as e:
            print(f"❌ [{address}] 오류: {e}")
        finally:
            client_socket.close()
            with self.lock:
                self.clients.remove(address)
            print(f"👋 [{address}] 연결 종료")

    def run(self, max_clients: int = 5):
        """서버 실행"""
        self.start()
        print(f"👥 최대 {max_clients}명의 클라이언트 수락 준비")

        try:
            while self.running and len(self.clients) < max_clients:
                try:
                    # 타임아웃 설정
                    self.socket.settimeout(1.0)
                    client_socket, address = self.socket.accept()

                    with self.lock:
                        self.clients.append(address)

                    # 새 스레드에서 클라이언트 처리
                    thread = threading.Thread(
                        target=self.handle_client, args=(client_socket, address)
                    )
                    thread.daemon = True
                    thread.start()
                    print(f"🔄 스레드 생성: {address}")

                except socket.timeout:
                    continue
                except Exception as e:
                    print(f"❌ 오류: {e}")
                    break

        finally:
            self.close()


