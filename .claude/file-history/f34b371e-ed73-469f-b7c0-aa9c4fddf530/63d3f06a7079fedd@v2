class ServerWithTimeout:
    """타임아웃이 있는 서버"""

    def __init__(self, host: str = "127.0.0.1", port: int = 9996, timeout: float = 5.0):
        self.host = host
        self.port = port
        self.timeout = timeout
        self.socket = None

    def start(self):
        """서버 시작"""
        self.socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        self.socket.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        self.socket.bind((self.host, self.port))
        self.socket.listen(1)
        self.socket.settimeout(self.timeout)
        print(f"📡 서버 시작: {self.host}:{self.port} (타임아웃: {self.timeout}초)")

    def accept_with_timeout(self):
        """타임아웃 있이 연결 수락"""
        try:
            client_socket, address = self.socket.accept()
            print(f"🤝 클라이언트 연결: {address}")
            return client_socket, address
        except socket.timeout:
            print("⏰ 타임아웃: 클라이언트가 연결하지 않음")
            return None, None
        except Exception as e:
            print(f"❌ 오류: {e}")
            return None, None

    def close(self):
        """서버 종료"""
        if self.socket:
            self.socket.close()


