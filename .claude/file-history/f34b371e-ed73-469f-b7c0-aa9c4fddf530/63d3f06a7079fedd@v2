# [3] Echo 서버 - 메아리
# ============================================================================

class EchoServer(SimpleTCPServer):
    """Echo 서버 - 받은 메시지를 그대로 돌려줌"""

    def handle_client(self, client_socket, address):
        """클라이언트 처리"""
        try:
            data = client_socket.recv(1024)
            if data:
                message = data.decode("utf-8")
                print(f"📥 수신: {address} → {message}")
                # Echo: 그대로 돌려줌
                client_socket.sendall(data)
                print(f"📤 송신: {address} ← {message}")
        except Exception as e:
            print(f"❌ 오류: {e}")
        finally:
            client_socket.close()

    def run_once(self):
        """한 번의 에코"""
        self.start()
        client_socket, address = self.accept_connection()
        if client_socket:
            self.handle_client(client_socket, address)
        self.close()


