def test_virtual_environment_independence():
    """가상 환경 독립성 개념 이해"""
    # 이것은 개념 테스트
    # 실제로 여러 venv를 만들었다고 가정

    # 시나리오: 프로젝트 A와 B가 다른 버전의 패키지 필요
    project_a_requirements = {
        "pandas": "2.0.0",
        "numpy": "1.20.0",
    }

    project_b_requirements = {
        "pandas": "1.5.0",
        "numpy": "1.18.0",
    }

    # A와 B는 같은 패키지이지만 버전이 다름
    assert project_a_requirements["pandas"] != project_b_requirements["pandas"]
    assert project_a_requirements["numpy"] != project_b_requirements["numpy"]

    # 각 프로젝트의 venv에서는 자신의 버전만 설치됨
    # → 버전 충돌 없음 ✅


def test_requirements_txt_concept():
    """requirements.txt 개념"""
    # requirements.txt 샘플 생성
    requirements = [
        "pandas==2.1.4",
        "numpy==1.26.4",
        "requests==2.31.0",
    ]

    # 각 요소가 올바른 형식
    for req in requirements:
        assert "==" in req, "버전을 명시해야 함"
        package, version = req.split("==")
        assert package.strip(), "패키지 이름 필요"
        assert version.strip(), "버전 명시 필요"


def test_gitignore_concept():
    """gitignore 개념"""
    # .gitignore에 포함될 항목들
    ignore_patterns = [
        "venv/",
        "__pycache__/",
        "*.pyc",
        ".env",
    ]

    # 포함되지 않을 항목들 (저장소에 올림)
    include_patterns = [
        "requirements.txt",
        ".gitignore",
        "src/",
        "tests/",
        "README.md",
    ]

    # 교집합이 없어야 함 (중복 제외)
    ignore_set = set(ignore_patterns)
    include_set = set(include_patterns)

    # 일반적으로 겹치지 않음
    for pattern in include_patterns:
        assert not pattern.startswith("venv/"), "venv는 제외해야 함"
        assert not pattern.endswith(".pyc"), ".pyc는 제외해야 함"


def test_environment_recreation():
    """환경 재구성 시뮬레이션"""
    # 원본 requirements.txt
    original_requirements = """
pandas==2.1.4
numpy==1.26.4
requests==2.31.0
"""

    # 파싱
    packages = [line.strip() for line in original_requirements.strip().split('\n') if line.strip()]

    assert len(packages) == 3
    assert all("==" in pkg for pkg in packages)

    # 모든 패키지가 정확한 버전을 가짐
    for pkg in packages:
        name, version = pkg.split("==")
        assert len(version.split(".")) >= 2, "유효한 버전 형식"


