def test_circle_area_calculation():
    """원의 넓이 계산"""
    radius = 10
    area = math.pi * (radius ** 2)
    assert area > 314.1
    assert area < 314.2


def test_multiple_module_usage():
    """여러 모듈 동시 사용"""
    # 현재 시각 기록
    now = datetime.now()

    # 수학 계산
    value = math.sqrt(100)
    assert value == 10.0

    # 난수 생성
    rand_num = random.randint(1, 100)
    assert 1 <= rand_num <= 100

    # 경로 확인
    path = os.getcwd()
    assert os.path.exists(path)

    # 모두 작동해야 함
    assert isinstance(now, datetime)
    assert isinstance(value, float)
    assert isinstance(rand_num, int)
    assert isinstance(path, str)


def test_standard_library_availability():
    """표준 라이브러리 이용 가능 확인"""
    # 모든 표준 라이브러리가 import 가능해야 함
    assert hasattr(math, "pi")
    assert hasattr(math, "sqrt")
    assert hasattr(os, "getcwd")
    assert hasattr(os.path, "exists")
    assert callable(random.randint)
    assert callable(datetime.now)
