import math
import os
from datetime import datetime
import random

from src.v2_4_modules_and_packages import modules_and_packages_demo


def test_modules_and_packages_demo_returns_dict():
    """반환값이 딕셔너리"""
    result = modules_and_packages_demo()
    assert isinstance(result, dict)


def test_math_module_pi():
    """math 모듈의 pi 상수"""
    assert math.pi > 3.14
    assert math.pi < 3.15


def test_math_module_functions():
    """math 모듈의 함수들"""
    assert math.sqrt(16) == 4.0
    assert math.sqrt(25) == 5.0
    assert math.ceil(3.2) == 4
    assert math.floor(3.9) == 3


def test_datetime_now():
    """datetime.now() 작동"""
    now = datetime.now()
    assert isinstance(now, datetime)


def test_datetime_formatting():
    """datetime 포맷팅"""
    now = datetime.now()
    formatted = now.strftime("%Y-%m-%d %H:%M:%S")
    assert isinstance(formatted, str)
    assert len(formatted) == 19  # "YYYY-MM-DD HH:MM:SS"
    assert "-" in formatted
    assert ":" in formatted


def test_os_getcwd():
    """os.getcwd() 현재 경로 반환"""
    path = os.getcwd()
    assert isinstance(path, str)
    assert len(path) > 0


def test_os_path_exists():
    """os.path.exists() 경로 확인"""
    current_path = os.getcwd()
    assert os.path.exists(current_path)


def test_random_randint():
    """random.randint() 범위 내 난수"""
    for _ in range(10):
        num = random.randint(1000, 9999)
        assert 1000 <= num <= 9999


