## 📝 실습: 안전한 나눗셈

```python
def safe_divider(a, b):
    """
    0으로 나누기 에러를 처리하는 안전한 나눗셈
    """
    try:
        result = a / b
        return result
    except ZeroDivisionError:
        print("[ERROR] 0으로 나눌 수 없습니다!")
        return 0  # 기본값 반환
    except TypeError:
        print("[ERROR] 숫자가 아닙니다!")
        return None
    finally:
        print("나눗셈 시도 완료")

# 테스트
print(safe_divider(10, 2))    # 5.0
print(safe_divider(10, 0))    # 0 (에러 처리됨)
print(safe_divider(10, "5"))  # None (에러 처리됨)
```

