## 📝 실습: 파일 안전하게 읽기

```python
def read_file_safely(filename):
    """
    파일 읽기 중 에러 처리
    """
    try:
        with open(filename, "r", encoding="utf-8") as file:
            content = file.read()
        return content
    except FileNotFoundError:
        print(f"[ERROR] '{filename}' 파일을 찾을 수 없습니다.")
        return None
    except IOError as e:
        print(f"[ERROR] 파일 읽기 실패: {e}")
        return None
    finally:
        print(f"파일 '{filename}' 처리 완료")

# 사용
data = read_file_safely("mydata.txt")
if data:
    print(data)
```

