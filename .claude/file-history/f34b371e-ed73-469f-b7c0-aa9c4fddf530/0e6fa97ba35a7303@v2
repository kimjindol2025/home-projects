"""
v5.1-Audit: 파이썬 통합 문법 정밀 진단 - 수정 버전

대학 3학년 수준의 시스템 통합 논리 점검
클래스(v2.2) + 데코레이터(v3.1) + 제너레이터(v3.2) + 비동기(v4.1)

【 3가지 핵심 오류 수정 】
1. 비동기 함수와 일반 데코레이터의 불일치
   → async wrapper + await 추가

2. 제너레이터의 소모성
   → list()로 변환하여 재사용 가능하게

3. 데코레이터가 함수 메타데이터를 보존하지 않음
   → @functools.wraps 추가

기록이 증명이다 - gogs
"""

import asyncio
import time
import functools
from typing import Generator, List, Coroutine, Any

# =============================================================================
# 【오류 1 해결】비동기 데코레이터 + @functools.wraps
# =============================================================================

def gogs_timer(func):
    """
    비동기 함수의 실행 시간을 측정하는 데코레이터

    설계 개선:
    1. @functools.wraps: 원본 함수의 메타데이터 보존
    2. async wrapper: 비동기 함수 지원
    3. await func(): 코루틴을 실제로 실행

    사용 예:
        @gogs_timer
        async def process():
            await asyncio.sleep(1)
            return "완료"

    주의사항:
    - 비동기 함수만 지원 (일반 함수는 TypeError)
    - 정확한 시간 측정 보장
    """

    @functools.wraps(func)
    async def async_wrapper(*args, **kwargs) -> Any:
        """
        비동기 함수 래퍼

        흐름:
        1. start 시간 기록
        2. await func()로 비동기 함수 실행
        3. 경과 시간 출력
        4. 결과 반환
        """
        start = time.time()
        try:
            # ✅ 오류 1 해결: await로 코루틴 실제 실행
            result = await func(*args, **kwargs)
            return result
        finally:
            # finally로 예외 발생해도 시간 측정
            elapsed = time.time() - start
            print(f"⏱️  {func.__name__} 실행 시간: {elapsed:.4f}s")

    return async_wrapper


# =============================================================================
# 【클래스 설계】GogsDataSystem (v2.2)
# =============================================================================

class GogsDataSystem:
    """
    Gogs 실험 데이터 처리 시스템

    책임:
    - 비동기로 여러 노드의 데이터 분석
    - 처리 통계 관리
    - 개별 노드 처리

    설계 패턴:
    - 데코레이터: 성능 측정 자동화
    - 비동기: 동시 처리
    - 클래스: 상태 관리 (processed_count)
    """

    def __init__(self, data_stream: List[int]) -> None:
        """
        시스템 초기화

        Args:
            data_stream: 처리할 데이터 리스트
        """
        self.data_stream = data_stream
        self.processed_count = 0
        self.results: List[str] = []

    @gogs_timer
    async def analyze_node(self, node_id: int) -> str:
        """
        개별 노드를 비동기로 분석

        처리 흐름:
        1. 시뮬레이션: 0.5초 대기 (네트워크 I/O)
        2. processed_count 증가
        3. 결과 반환

        Args:
            node_id: 분석할 노드 ID

        Returns:
            분석 결과 메시지

        예외:
            - 모든 예외는 caller의 asyncio.gather()에서 처리
        """
        # 네트워크 I/O 시뮬레이션
        await asyncio.sleep(0.5)

        # 상태 업데이트 (스레드 안전하지 않지만, 단일 스레드이므로 OK)
        self.processed_count += 1

        result = f"Node-{node_id} Complete"
        self.results.append(result)
        return result

    def get_statistics(self) -> dict:
        """통계 반환"""
        return {
            'processed_count': self.processed_count,
            'total_nodes': len(self.data_stream),
            'results': self.results
        }


# =============================================================================
# 【오류 2 해결】제너레이터 → 리스트 변환
# =============================================================================

def data_generator(limit: int) -> Generator[int, None, None]:
    """
    데이터 제너레이터

    특성:
    - yield: 요구할 때마다 하나씩 반환 (메모리 효율)
    - 일회용: 한 번 순회하면 소진됨
    - 지연 평가: 필요할 때까지 계산 미루기

    Args:
        limit: 생성할 데이터 개수 (0 ~ limit-1)

    Yields:
        정수 (0부터 limit-1까지)

    주의:
        제너레이터는 소진 후 재사용 불가
        재사용 필요 시 list()로 변환하거나 다시 생성
    """
    for i in range(limit):
        yield i


# =============================================================================
# 【메인 실행】완벽한 통합
# =============================================================================

async def main() -> None:
    """
    메인 실행 함수

    처리 과정:
    1. 제너레이터 생성
    2. 리스트로 변환 (재사용 가능하게)
    3. 시스템 초기화
    4. 비동기 작업 생성
    5. 동시 실행 (asyncio.gather)
    6. 결과 출력

    성능:
    - 순차 처리: 5개 × 0.5초 = 2.5초
    - 비동기 처리: 최대 0.5초 + 오버헤드 ≈ 0.5초
    - 성능 향상: 약 5배
    """

    print("\n" + "="*70)
    print("🛠️  Gogs 실험 데이터 처리 시스템")
    print("="*70)

    # 【오류 2 해결】제너레이터를 리스트로 변환
    # ✅ 목표: 재사용 가능한 형태로 변환
    print("\n【 Step 1: 데이터 제너레이션 】")
    nodes_gen = data_generator(5)
    print(f"제너레이터 생성: {nodes_gen}")

    # ✅ 핵심 수정: list()로 변환
    nodes_list = list(nodes_gen)
    print(f"리스트로 변환: {nodes_list}")
    print(f"노드 개수: {len(nodes_list)}")

    # 제너레이터는 이제 소진됨 (재사용 불가)
    print(f"제너레이터 소진 확인: list(nodes_gen) = {list(nodes_gen)}")

    # 【시스템 초기화】
    print("\n【 Step 2: 시스템 초기화 】")
    system = GogsDataSystem(nodes_list)
    print(f"시스템 초기화 완료")
    print(f"초기 처리된 노드: {system.processed_count}개")

    # 【비동기 작업 생성】
    print("\n【 Step 3: 비동기 작업 생성 】")
    tasks: List[Coroutine[Any, Any, str]] = [
        system.analyze_node(n) for n in nodes_list
    ]
    print(f"생성된 코루틴: {len(tasks)}개")

    # 【동시 실행】
    print("\n【 Step 4: 동시 실행 (asyncio.gather) 】")
    print("처리 중...\n")

    # asyncio.gather(): 모든 코루틴을 동시에 실행
    # - 순차 실행: await system.analyze_node(0), then (1), ...
    #   → 5 × 0.5 = 2.5초
    # - 비동기 실행: 모두 동시 실행
    #   → 약 0.5초 (최장 작업)
    results = await asyncio.gather(*tasks)

    # 【결과 출력】
    print("\n【 Step 5: 결과 처리 】")
    print(f"\n✅ 처리 완료!")
    print(f"\n처리 결과:")
    for i, result in enumerate(results, 1):
        print(f"  {i}. {result}")

    # 【통계】
    print("\n【 Step 6: 통계 】")
    stats = system.get_statistics()
    print(f"\n📊 통계:")
    print(f"  - 총 처리된 노드: {stats['processed_count']}개")
    print(f"  - 전체 노드: {stats['total_nodes']}개")
    print(f"  - 성공률: {stats['processed_count'] / stats['total_nodes'] * 100:.1f}%")

    print("\n" + "="*70 + "\n")


# =============================================================================
# 【부가 테스트】오류 상황 시뮬레이션
# =============================================================================

def test_generator_exhaustion():
    """
    제너레이터 소모성 테스트

    학습 목표:
    제너레이터는 한 번 순회하면 비워지는 특성 이해
    """

    print("\n" + "="*70)
    print("🔬 테스트: 제너레이터 소모성")
    print("="*70 + "\n")

    gen = data_generator(3)
    print(f"생성된 제너레이터: {gen}")

    print("\n【 첫 번째 순회 】")
    result1 = list(gen)
    print(f"list(gen) = {result1}")

    print("\n【 두 번째 순회 】")
    result2 = list(gen)
    print(f"list(gen) = {result2}  ← 비어있음!")

    print("\n【 해결책 】")
    print("Option 1: 새로 생성")
    gen_new = data_generator(3)
    result3 = list(gen_new)
    print(f"  list(data_generator(3)) = {result3}")

    print("\nOption 2: 미리 리스트로 변환")
    gen_list = list(data_generator(3))
    result4a = list(gen_list)
    result4b = list(gen_list)
    print(f"  첫 번째: {result4a}")
    print(f"  두 번째: {result4b}")

    print("\n" + "="*70 + "\n")


def test_decorator_metadata():
    """
    데코레이터 메타데이터 보존 테스트

    학습 목표:
    @functools.wraps의 중요성 이해
    """

    print("="*70)
    print("🔬 테스트: 데코레이터 메타데이터")
    print("="*70 + "\n")

    @gogs_timer
    async def sample_function(x: int) -> str:
        """샘플 함수의 설명"""
        await asyncio.sleep(0.1)
        return f"Result: {x}"

    print("【 @functools.wraps 적용 후 】")
    print(f"함수 이름: {sample_function.__name__}")
    print(f"함수 설명: {sample_function.__doc__}")
    print(f"함수 모듈: {sample_function.__module__}")

    print("\n【 메타데이터가 없으면 】")
    print("함수 이름: async_wrapper")
    print("함수 설명: None")
    print("→ 디버깅, IDE 자동완성, 문서화 영향")

    print("\n" + "="*70 + "\n")


async def run_all_tests():
    """모든 테스트 실행"""

    # 1. 메인 테스트
    await main()

    # 2. 제너레이터 소모성 테스트
    test_generator_exhaustion()

    # 3. 메타데이터 테스트
    test_decorator_metadata()


if __name__ == "__main__":
    # 비동기 이벤트 루프 실행
    asyncio.run(run_all_tests())

    # 최종 메시지
    print("\n" + "="*70)
    print("🎓 TEST v5.1-Audit 완료")
    print("="*70)
    print("\n【 학습 성과 】")
    print("✅ 비동기 데코레이터 이해")
    print("✅ 제너레이터 소모성 인식")
    print("✅ 메타데이터 보존 중요성 인식")
    print("\n기록이 증명이다 - gogs\n")
