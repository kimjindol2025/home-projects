## 모니터링과 관찰성

### 1. 메트릭 수집

```python
import time
from dataclasses import dataclass
from typing import List

@dataclass
class ServiceMetric:
    timestamp: float
    service_name: str
    cpu_usage: float        # 0-100%
    memory_usage: float     # MB
    response_time_ms: float
    error_count: int
    request_count: int

    @property
    def error_rate(self):
        return self.error_count / self.request_count if self.request_count > 0 else 0

    @property
    def availability(self):
        return (1 - self.error_rate) * 100

class DistributedMonitor:
    """분산 시스템 모니터링"""

    def __init__(self):
        self.metrics: List[ServiceMetric] = []

    def record(self, metric: ServiceMetric):
        """메트릭 기록"""
        self.metrics.append(metric)

    def get_sla_compliance(self, service_name: str):
        """SLA 준수율 계산"""
        # SLA: 99.9% 가용성, 평균 응답시간 < 100ms

        service_metrics = [
            m for m in self.metrics
            if m.service_name == service_name
        ]

        avg_availability = sum(m.availability for m in service_metrics) / len(service_metrics)
        avg_response_time = sum(m.response_time_ms for m in service_metrics) / len(service_metrics)

        return {
            'availability': avg_availability,
            'availability_sla': avg_availability >= 99.9,
            'response_time_ms': avg_response_time,
            'response_time_sla': avg_response_time < 100,
            'overall_sla_met': avg_availability >= 99.9 and avg_response_time < 100
        }

# 사용:
monitor = DistributedMonitor()

for i in range(10):
    metric = ServiceMetric(
        timestamp=time.time(),
        service_name='payment-service',
        cpu_usage=45.2,
        memory_usage=512.0,
        response_time_ms=45 + i * 5,
        error_count=1 if i % 5 == 0 else 0,
        request_count=100
    )
    monitor.record(metric)

compliance = monitor.get_sla_compliance('payment-service')
print(f"가용성: {compliance['availability']:.2f}%")
print(f"SLA 준수: {compliance['overall_sla_met']}")
```

### 2. 분산 추적 (Distributed Tracing)

```python
import uuid

class TraceContext:
    """요청 추적"""

    def __init__(self):
        self.trace_id = str(uuid.uuid4())[:8]
        self.spans = []

    def start_span(self, operation: str):
        """작업 시작"""
        span = {
            'trace_id': self.trace_id,
            'operation': operation,
            'start_time': time.time(),
            'service': None
        }
        self.spans.append(span)
        return span

    def end_span(self, span: dict, duration: float):
        """작업 종료"""
        span['duration_ms'] = duration * 1000

class DistributedTracer:
    """전체 요청 흐름 추적"""

    def trace_request(self, request_id: str):
        """요청 흐름:

        User Request
        ├─ [1] API Gateway (2ms)
        ├─ [2] Order Service (50ms)
        │   └─ [2.1] Database Query (30ms)
        ├─ [3] Payment Service (100ms)
        │   └─ [3.1] External API Call (80ms)
        └─ [4] Response (152ms total)
        """

        trace = TraceContext()

        # Span 1: API Gateway
        span1 = trace.start_span('API Gateway')
        time.sleep(0.002)
        trace.end_span(span1, 0.002)

        # Span 2: Order Service
        span2 = trace.start_span('Order Service')

        # Span 2.1: DB Query
        span2_1 = trace.start_span('DB Query')
        time.sleep(0.030)
        trace.end_span(span2_1, 0.030)

        time.sleep(0.020)
        trace.end_span(span2, 0.050)

        # Span 3: Payment Service
        span3 = trace.start_span('Payment Service')

        # Span 3.1: External API
        span3_1 = trace.start_span('External API')
        time.sleep(0.080)
        trace.end_span(span3_1, 0.080)

        time.sleep(0.020)
        trace.end_span(span3, 0.100)

        # 출력
        print(f"\n🔍 Trace ID: {trace.trace_id}")
        for i, span in enumerate(trace.spans):
            indent = "  " if span['operation'] in ['DB Query', 'External API'] else ""
            print(f"{indent}└─ {span['operation']}: {span['duration_ms']:.1f}ms")
