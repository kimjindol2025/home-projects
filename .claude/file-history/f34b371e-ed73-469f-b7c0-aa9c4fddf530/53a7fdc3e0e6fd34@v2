## 실전 문제 해결

### 문제 1: 데드레터 큐 (Dead Letter Queue)

```python
# 문제: 메시지 처리 실패 후 무한 재시도
# 해결: 일정 횟수 실패하면 별도 큐로 이동

class RobustBroker:
    def __init__(self):
        self.main_queue = Queue()
        self.dead_letter_queue = Queue()  # 처리 불가능한 메시지
        self.max_retries = 3

    def process_with_dlq(self):
        msg = self.main_queue.get()

        for attempt in range(self.max_retries + 1):
            try:
                self.process(msg)
                return True
            except Exception as e:
                if attempt == self.max_retries:
                    # 마지막 시도 실패 → DLQ로 이동
                    print(f"⚠️ 메시지 DLQ 이동: {msg}")
                    self.dead_letter_queue.put({
                        'message': msg,
                        'error': str(e),
                        'failed_at': time.time()
                    })
                    return False
                else:
                    # 재시도 전 대기
                    wait_time = 2 ** attempt  # 지수 백오프
                    time.sleep(wait_time)
```

### 문제 2: 분산 트랜잭션 (Saga Pattern)

```python
# 문제: 여러 서비스 걸친 트랜잭션 관리
# 해결: Saga Pattern - 각 단계마다 보상 트랜잭션 정의

class SagaOrchestrator:
    """Saga 패턴 구현"""

    def process_order(self, order):
        """주문 처리 - Saga 실행"""
        saga_id = str(uuid.uuid4())
        steps = []

        try:
            # Step 1: 결제
            print(f"[Saga {saga_id}] Step 1: 결제 처리")
            payment = self.process_payment(order)
            steps.append(('payment', payment))

            # Step 2: 재고 예약
            print(f"[Saga {saga_id}] Step 2: 재고 예약")
            reservation = self.reserve_inventory(order)
            steps.append(('inventory', reservation))

            # Step 3: 배송 생성
            print(f"[Saga {saga_id}] Step 3: 배송 생성")
            shipment = self.create_shipment(order)
            steps.append(('shipment', shipment))

            print(f"✅ [Saga {saga_id}] 완료")
            return True

        except Exception as e:
            # 보상 트랜잭션 (역순)
            print(f"❌ [Saga {saga_id}] 실패: {e}. 보상 시작...")

            for step_name, step_data in reversed(steps):
                if step_name == 'payment':
                    self.refund_payment(step_data)
                    print(f"  → 결제 환불")
                elif step_name == 'inventory':
                    self.release_inventory(step_data)
                    print(f"  → 재고 해제")
                elif step_name == 'shipment':
                    self.cancel_shipment(step_data)
                    print(f"  → 배송 취소")

            return False
