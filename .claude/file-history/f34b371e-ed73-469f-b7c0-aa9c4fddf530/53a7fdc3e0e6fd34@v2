### 2. 헬스 체크

```python
import requests

class ServiceRegistry:
    """헬스 체크 기능 추가"""

    def __init__(self, health_check_interval=30):
        self.services = {}
        self.health_check_interval = health_check_interval
        self.monitoring = threading.Thread(
            target=self._health_check_loop,
            daemon=True
        )
        self.monitoring.start()

    def _health_check_loop(self):
        """주기적 헬스 체크"""
        while True:
            time.sleep(self.health_check_interval)

            for service_name in list(self.services.keys()):
                for service in self.services[service_name]:
                    if not self._is_healthy(service):
                        # 비활성 서비스 제거
                        self.services[service_name].remove(service)
                        print(f"⚠️ 서비스 제거: {service_name} @ {service['host']}")

    def _is_healthy(self, service):
        """서비스 헬스 상태 확인"""
        try:
            url = f"{service['url']}/health"
            response = requests.get(url, timeout=2)
            return response.status_code == 200
        except:
            return False

# 사용:
registry = ServiceRegistry()
registry.register('api-service', 'localhost', 5001)
# → 30초마다 /health 엔드포인트 호출
# → 실패하면 자동으로 제거
```

