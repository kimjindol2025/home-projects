## 분산 시스템 설계 사례

### 사례: 전자상거래 플랫폼

```python
"""
시나리오: 주문 처리 시스템
┌─────────────────────────────────────────────────────┐
│                    User Request                      │
│              (주문: Product-123, 수량: 2)             │
└──────────────────────┬────────────────────────────────┘
                       │
        ┌──────────────▼──────────────┐
        │   API Gateway              │
        │  (요청 라우팅)              │
        └──────────────┬──────────────┘
                       │
        ┌──────────────▼──────────────┐
        │  Order Service            │
        │  (주문 생성 & 검증)         │
        └──────────────┬──────────────┘
                       │ [메시지 발행]
        ┌──────────────▼──────────────┐
        │  Message Broker            │
        │  ("OrderCreated" 이벤트)    │
        └──────────────┬──────────────┘
                       │
           ┌───────────┼────────────┐
           │           │            │
    ┌──────▼────┐ ┌────▼─────┐ ┌───▼──────┐
    │ Payment   │ │ Inventory│ │ Shipping │
    │ Service   │ │ Service  │ │ Service  │
    └──────┬────┘ └────┬─────┘ └───┬──────┘
           │           │            │
    [결제 처리]  [재고 업데이트] [배송 준비]
"""

import threading
import time
from queue import Queue

class OrderProcessingSystem:
    def __init__(self):
        self.message_broker = Queue()
        self.orders = []
        self.payments = []
        self.inventory = {'Product-123': 100}
        self.shipments = []

    def order_service(self):
        """주문 서비스"""
        while True:
            # 사용자 요청 수신 (여기서는 시뮬레이션)
            order = {
                'order_id': f"ORD-{len(self.orders)+1}",
                'product': 'Product-123',
                'quantity': 2,
                'timestamp': time.time()
            }

            # 1. 주문 검증
            if self.inventory.get('Product-123', 0) >= order['quantity']:
                self.orders.append(order)
                print(f"📦 [Order Service] 주문 생성: {order['order_id']}")

                # 2. 메시지 발행
                self.message_broker.put({
                    'event': 'OrderCreated',
                    'data': order
                })

            time.sleep(5)

    def payment_service(self):
        """결제 서비스"""
        while True:
            try:
                msg = self.message_broker.get(timeout=2)
                if msg['event'] == 'OrderCreated':
                    order = msg['data']
                    payment = {
                        'order_id': order['order_id'],
                        'amount': order['quantity'] * 100,  # 각 상품 100원
                        'status': 'completed'
                    }
                    self.payments.append(payment)
                    print(f"💳 [Payment Service] 결제 완료: {order['order_id']}")
            except:
                pass
            time.sleep(1)

    def inventory_service(self):
        """재고 서비스"""
        while True:
            try:
                msg = self.message_broker.get(timeout=2)
                if msg['event'] == 'OrderCreated':
                    order = msg['data']
                    # 재고 감소
                    self.inventory['Product-123'] -= order['quantity']
                    print(f"📊 [Inventory] 재고 업데이트: {self.inventory['Product-123']}개 남음")
            except:
                pass
            time.sleep(1)

    def shipping_service(self):
        """배송 서비스"""
        while True:
            try:
                msg = self.message_broker.get(timeout=2)
                if msg['event'] == 'OrderCreated':
                    order = msg['data']
                    shipment = {
                        'order_id': order['order_id'],
                        'status': 'preparing',
                        'estimated_delivery': 'Tomorrow'
                    }
                    self.shipments.append(shipment)
                    print(f"🚚 [Shipping] 배송 준비: {order['order_id']}")
            except:
                pass
            time.sleep(1)

    def run(self):
        """모든 서비스 병렬 실행"""
        threads = [
            threading.Thread(target=self.order_service, daemon=True),
            threading.Thread(target=self.payment_service, daemon=True),
            threading.Thread(target=self.inventory_service, daemon=True),
            threading.Thread(target=self.shipping_service, daemon=True),
        ]

        for t in threads:
            t.start()

        # 10초 동안 실행
        for _ in range(10):
            time.sleep(1)

        print("\n📊 최종 상태:")
        print(f"  총 주문: {len(self.orders)}")
        print(f"  완료된 결제: {len(self.payments)}")
        print(f"  남은 재고: {self.inventory['Product-123']}개")
        print(f"  준비 중인 배송: {len(self.shipments)}")

# 실행
