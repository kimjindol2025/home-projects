## Service Registry와 동적 발견

### 1. 문제: 서비스 위치 찾기

```python
# ❌ 나쁜 방식: 하드코딩
class PaymentClient:
    def __init__(self):
        # 서버가 이전하면? 코드 변경 필요!
        self.url = "192.168.1.10:5002"  # 하드코딩

    def make_payment(self, amount):
        return requests.post(self.url + "/pay", json={"amount": amount})

# ✅ 좋은 방식: Registry 사용
class ServiceRegistry:
    """서비스 위치 중앙 관리"""

    def __init__(self):
        self.services = {}
        self.lock = threading.Lock()

    def register(self, name, host, port, metadata=None):
        """서비스 등록"""
        with self.lock:
            if name not in self.services:
                self.services[name] = []

            self.services[name].append({
                'host': host,
                'port': port,
                'url': f"http://{host}:{port}",
                'metadata': metadata or {},
                'registered_at': time.time()
            })

    def discover(self, name):
        """서비스 발견"""
        with self.lock:
            if name in self.services:
                # 여러 인스턴스 중 첫 번째 반환 (실제로는 로드밸런싱)
                return self.services[name][0]
            return None

    def deregister(self, name, host):
        """서비스 등록 해제"""
        with self.lock:
            if name in self.services:
                self.services[name] = [
                    s for s in self.services[name]
                    if s['host'] != host
                ]

# 사용:
registry = ServiceRegistry()

# 시작 시 등록
registry.register('payment-service', '192.168.1.10', 5002)
registry.register('payment-service', '192.168.1.11', 5002)  # 백업

# 필요할 때 발견
payment_service = registry.discover('payment-service')
print(f"결제 서비스: {payment_service['url']}")

# 종료 시 등록 해제
registry.deregister('payment-service', '192.168.1.10')
