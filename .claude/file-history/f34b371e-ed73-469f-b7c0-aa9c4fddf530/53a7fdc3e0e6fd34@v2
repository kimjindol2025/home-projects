## Circuit Breaker 심화

### 1. 3가지 상태 머신

```python
from enum import Enum
import time

class CircuitState(Enum):
    CLOSED = "정상"      # 모든 요청 통과
    OPEN = "차단"        # 모든 요청 실패
    HALF_OPEN = "회복시도" # 일부 요청 시도

class AdvancedCircuitBreaker:
    """프로덕션 수준의 Circuit Breaker"""

    def __init__(self,
                 failure_threshold=5,      # 실패 횟수
                 timeout=60,                # OPEN → HALF_OPEN 대기시간
                 success_threshold=2):      # HALF_OPEN → CLOSED 성공 횟수
        self.state = CircuitState.CLOSED
        self.failure_count = 0
        self.success_count = 0
        self.last_failure_time = None
        self.failure_threshold = failure_threshold
        self.timeout = timeout
        self.success_threshold = success_threshold

    def call(self, func, *args, **kwargs):
        """Circuit Breaker 래퍼"""

        # 1. OPEN → HALF_OPEN 전환
        if self.state == CircuitState.OPEN:
            if time.time() - self.last_failure_time > self.timeout:
                self.state = CircuitState.HALF_OPEN
                self.success_count = 0
                print(f"⚡ 상태 변화: OPEN → HALF_OPEN")
            else:
                # 아직 타임아웃 안 됨
                raise Exception("Circuit breaker is OPEN")

        # 2. 요청 실행
        try:
            result = func(*args, **kwargs)

            # 성공
            if self.state == CircuitState.HALF_OPEN:
                self.success_count += 1
                if self.success_count >= self.success_threshold:
                    self.state = CircuitState.CLOSED
                    self.failure_count = 0
                    print(f"✅ 상태 변화: HALF_OPEN → CLOSED (복구됨)")
            elif self.state == CircuitState.CLOSED:
                self.failure_count = 0

            return result

        except Exception as e:
            # 실패
            self.failure_count += 1
            self.last_failure_time = time.time()

            if self.failure_count >= self.failure_threshold:
                self.state = CircuitState.OPEN
                print(f"🔴 상태 변화: CLOSED → OPEN (너무 많은 실패)")

            raise

# 상태 전환 다이어그램:
#
# ┌──────────────────────────────────────────────┐
# │                                              │
# │  ┌────────────┐     timeout     ┌──────────┐ │
# │  │  CLOSED    │──────────────▶  │ HALF_OPEN│ │
# │  │ (정상)     │                 │(회복시도)│ │
# │  └─────▲──────┘                 └────┬─────┘ │
# │        │                             │       │
# │        │ success_threshold           │       │
# │        │ 달성 시 복구                failure │
# │        │                             │       │
# │        │                    ┌────────▼─────┐ │
# │        └────────────────────│   OPEN       │ │
# │                             │ (차단)       │ │
# │                             └──────────────┘ │
# │                                              │
# └──────────────────────────────────────────────┘

# 예제:
cb = AdvancedCircuitBreaker(failure_threshold=3, timeout=5)

def unreliable_api():
    import random
    if random.random() < 0.7:  # 70% 실패
        raise Exception("API Error")
    return "Success"

# 사용:
for i in range(10):
    try:
        result = cb.call(unreliable_api)
        print(f"✅ {i}: {result} (상태: {cb.state.value})")
    except Exception as e:
        print(f"❌ {i}: {e} (상태: {cb.state.value})")
    time.sleep(1)

# 출력 예:
# ❌ 0: API Error (상태: 정상)
# ❌ 1: API Error (상태: 정상)
# ❌ 2: API Error (상태: 차단) ← OPEN 상태 전환
# 🔴 상태 변화: CLOSED → OPEN
# ❌ 3: Circuit breaker is OPEN (상태: 차단)
# ✅ 4: Success (상태: 회복시도) ← HALF_OPEN으로 시도
# ⚡ 상태 변화: OPEN → HALF_OPEN
# ...
```

