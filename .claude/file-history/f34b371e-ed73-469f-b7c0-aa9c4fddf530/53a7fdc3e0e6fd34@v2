## Message Broker 패턴의 실체

### 1. Broker의 역할

```python
# Message Broker는 "비동기 우체국"
#
# 동기식 (문제: 블로킹)
# Client → Server1 → wait → Server2 → wait → Client
#          (느림)        (느림)
#
# 비동기식 (Broker)
# Client → Broker → immediately returns to Client
#          ↓
#    Server1 processes when ready
#    Server2 processes when ready

# 장점:
# 1. Non-blocking: 발신자가 기다리지 않음
# 2. Resilience: 수신자 다운 → 메시지 큐에 대기
# 3. Scalability: 여러 Consumer 추가 가능
# 4. Decoupling: Producer/Consumer 독립적
```

### 2. 큐(Queue) 메커니즘

```python
import queue
import threading
import time

class DistributedBroker:
    """프로덕션 메시지 브로커 시뮬레이션"""

    def __init__(self, max_size=1000):
        self.messages = queue.Queue(maxsize=max_size)
        self.processed = []
        self.lock = threading.Lock()

    def publish(self, message):
        """메시지 발행 (블로킹 없음, 즉시 반환)"""
        try:
            self.messages.put_nowait(message)
            return True
        except queue.Full:
            # 큐가 가득 참 → 백프레셔(backpressure)
            return False

    def subscribe(self, timeout=5.0):
        """메시지 구독 (타임아웃 지원)"""
        try:
            return self.messages.get(timeout=timeout)
        except queue.Empty:
            return None

    def acknowledge(self, message):
        """메시지 처리 완료 표시"""
        with self.lock:
            self.processed.append(message)
        return True

# 실제 사용:
broker = DistributedBroker()

# Producer Thread
def producer():
    for i in range(5):
        broker.publish(f"Order-{i+1}")
        print(f"📬 주문 생성: Order-{i+1}")
        time.sleep(0.1)

# Consumer Thread
def consumer():
    for _ in range(5):
        msg = broker.subscribe()
        if msg:
            print(f"💳 주문 처리: {msg}")
            time.sleep(0.2)  # 처리 시간

p = threading.Thread(target=producer)
c = threading.Thread(target=consumer)

p.start()
c.start()
p.join()
c.join()

# 출력:
# 📬 주문 생성: Order-1
# 📬 주문 생성: Order-2
# 💳 주문 처리: Order-1
# 📬 주문 생성: Order-3
# 💳 주문 처리: Order-2
# ...

# 핵심: Producer와 Consumer의 속도가 다르지만 시스템이 안정적
```

### 3. 메시지 신뢰성

```python
class ReliableBroker:
    """신뢰성 있는 메시지 전달"""

    # 메시지 상태
    # pending → processing → completed
    #              ↓
    #           (fail) → retry

    def __init__(self):
        self.queue = queue.Queue()
        self.retry_queue = queue.Queue()
        self.max_retries = 3

    def publish_with_ack(self, message):
        """발행 후 확인대기"""
        self.queue.put({
            'data': message,
            'status': 'pending',
            'retries': 0
        })

    def consume_with_retry(self):
        """소비 후 실패시 재시도"""
        msg = self.queue.get()

        try:
            # 처리 시도
            self.process_message(msg['data'])
            msg['status'] = 'completed'
            return True
        except Exception as e:
            # 실패 → 재시도
            if msg['retries'] < self.max_retries:
                msg['retries'] += 1
                self.retry_queue.put(msg)
                return False
            else:
                # 최대 재시도 초과 → 데드레터 큐
                self.dead_letter_queue(msg)
                return False

    def process_message(self, data):
        # 실제 처리 로직
        if 'ERROR' in data:
            raise Exception(f"Processing failed: {data}")
        return data
