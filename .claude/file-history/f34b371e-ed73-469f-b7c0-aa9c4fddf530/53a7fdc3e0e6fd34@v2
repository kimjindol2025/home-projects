## 성능 최적화 전략

### 1. 캐싱 전략 (LRU + TTL)

```python
import time
from collections import OrderedDict

class OptimizedCache:
    """LRU + TTL 캐시"""

    def __init__(self, max_size=100, ttl=300):
        self.cache = OrderedDict()
        self.timestamps = {}
        self.max_size = max_size
        self.ttl = ttl
        self.hits = 0
        self.misses = 0

    def get(self, key):
        # TTL 확인
        if key in self.timestamps:
            if time.time() - self.timestamps[key] > self.ttl:
                del self.cache[key]
                del self.timestamps[key]
                self.misses += 1
                return None

        # 캐시 히트
        if key in self.cache:
            self.cache.move_to_end(key)  # LRU 업데이트
            self.hits += 1
            return self.cache[key]

        self.misses += 1
        return None

    def set(self, key, value):
        # LRU: 새로운 항목이면 맨 뒤에 추가
        if key in self.cache:
            self.cache.move_to_end(key)
            self.cache[key] = value
        else:
            if len(self.cache) >= self.max_size:
                # 가장 오래된 항목 제거
                oldest = next(iter(self.cache))
                del self.cache[oldest]
                del self.timestamps[oldest]

            self.cache[key] = value

        self.timestamps[key] = time.time()

    def hit_ratio(self):
        total = self.hits + self.misses
        return self.hits / total if total > 0 else 0

# 사용:
cache = OptimizedCache(max_size=5, ttl=10)
cache.set('user:123', {'name': 'Alice'})
print(cache.get('user:123'))  # {'name': 'Alice'} - 히트
print(cache.hit_ratio())      # 1.0 (100% 히트율)
```

### 2. 배치 처리

```python
import time
from typing import List

class BatchProcessor:
    """배치 처리로 처리량 증가"""

    def __init__(self, batch_size=100, timeout=5.0):
        self.batch_size = batch_size
        self.timeout = timeout
        self.batch = []
        self.last_flush = time.time()

    def add(self, item):
        """항목 추가"""
        self.batch.append(item)

        # 조건 1: 배치 크기 도달
        if len(self.batch) >= self.batch_size:
            self.flush()

        # 조건 2: 타임아웃 도달
        elif time.time() - self.last_flush > self.timeout:
            self.flush()

    def flush(self):
        """배치 처리"""
        if not self.batch:
            return

        # 한 번에 많은 항목 처리 (DB 쿼리 최소화)
        print(f"⚡ 배치 처리: {len(self.batch)}개 항목")
        self._bulk_insert(self.batch)

        self.batch = []
        self.last_flush = time.time()

    def _bulk_insert(self, items: List):
        """DB에 한 번에 삽입 (시뮬레이션)"""
        # INSERT INTO table VALUES (...), (...), (...)
        pass

