class TestDatabaseLayer(unittest.TestCase):
    """데이터베이스 계층 테스트"""

    def setUp(self):
        """테스트 전 설정"""
        self.db_file = tempfile.mktemp(suffix='.db')
        self.db = GogsDatabase(self.db_file)

    def tearDown(self):
        """테스트 후 정리"""
        if os.path.exists(self.db_file):
            os.remove(self.db_file)

    def test_1_create_researcher(self):
        """연구자 생성"""
        researcher = self.db.create_researcher('테스트', 'test@gogs.io', 'researcher')
        self.assertIsNotNone(researcher)
        self.assertEqual(researcher['name'], '테스트')
        self.assertEqual(researcher['email'], 'test@gogs.io')

    def test_2_get_researcher(self):
        """연구자 조회"""
        created = self.db.create_researcher('테스트2', 'test2@gogs.io')
        retrieved = self.db.get_researcher(created['id'])
        self.assertEqual(retrieved['name'], '테스트2')

    def test_3_get_all_researchers(self):
        """모든 연구자 조회"""
        self.db.create_researcher('연구자1', 'r1@gogs.io')
        self.db.create_researcher('연구자2', 'r2@gogs.io')
        all_researchers = self.db.get_all_researchers()
        self.assertGreaterEqual(len(all_researchers), 2)

    def test_4_update_researcher(self):
        """연구자 정보 수정"""
        researcher = self.db.create_researcher('원본', 'original@gogs.io')
        updated = self.db.update_researcher(researcher['id'], name='수정됨')
        self.assertEqual(updated['name'], '수정됨')

    def test_5_delete_researcher(self):
        """연구자 삭제"""
        researcher = self.db.create_researcher('삭제대상', 'delete@gogs.io')
        success = self.db.delete_researcher(researcher['id'])
        self.assertTrue(success)
        self.assertIsNone(self.db.get_researcher(researcher['id']))

    def test_6_create_experiment(self):
        """실험 생성"""
        researcher = self.db.create_researcher('테스트', 'test@gogs.io')
        experiment = self.db.create_experiment(
            researcher['id'],
            '테스트 실험',
            '설명'
        )
        self.assertIsNotNone(experiment)
        self.assertEqual(experiment['subject'], '테스트 실험')

    def test_7_get_experiment(self):
        """실험 조회"""
        researcher = self.db.create_researcher('테스트', 'test@gogs.io')
        experiment = self.db.create_experiment(researcher['id'], '테스트')
        retrieved = self.db.get_experiment(experiment['id'])
        self.assertEqual(retrieved['subject'], '테스트')

    def test_8_get_researcher_experiments(self):
        """연구자의 실험 조회"""
        researcher = self.db.create_researcher('테스트', 'test@gogs.io')
        self.db.create_experiment(researcher['id'], '실험1')
        self.db.create_experiment(researcher['id'], '실험2')
        experiments = self.db.get_researcher_experiments(researcher['id'])
        self.assertEqual(len(experiments), 2)

    def test_9_update_experiment(self):
        """실험 수정"""
        researcher = self.db.create_researcher('테스트', 'test@gogs.io')
        experiment = self.db.create_experiment(researcher['id'], '원본')
        updated = self.db.update_experiment(
            experiment['id'],
            subject='수정됨',
            result=95.5
        )
        self.assertEqual(updated['subject'], '수정됨')
        self.assertEqual(updated['result'], 95.5)

    def test_10_statistics(self):
        """통계 조회"""
        researcher = self.db.create_researcher('테스트', 'test@gogs.io')
        exp = self.db.create_experiment(researcher['id'], '실험', status='completed')
        self.db.update_experiment(exp['id'], result=100)
        stats = self.db.get_statistics()
        self.assertIn('researcher_count', stats)
        self.assertIn('experiment_count', stats)
        self.assertGreater(stats['experiment_count'], 0)


class TestAuthenticationLayer(unittest.TestCase):
    """인증 계층 테스트"""

    def setUp(self):
        """테스트 전 설정"""
        self.db_file = tempfile.mktemp(suffix='.db')
        self.db = GogsDatabase(self.db_file)
        self.auth = AuthManager(self.db)

    def tearDown(self):
        """테스트 후 정리"""
        if os.path.exists(self.db_file):
            os.remove(self.db_file)

    def test_1_generate_token(self):
        """토큰 생성"""
        token = self.auth.generate_token()
        self.assertIsNotNone(token)
        self.assertGreater(len(token), 20)

    def test_2_authenticate(self):
        """인증"""
        self.db.create_researcher('테스트', 'test@gogs.io')
        token = self.auth.authenticate('test@gogs.io', 'test@gogs.io')
        self.assertIsNotNone(token)

    def test_3_verify_token(self):
        """토큰 검증"""
        self.db.create_researcher('테스트', 'test@gogs.io')
        token = self.auth.authenticate('test@gogs.io', 'test@gogs.io')
        verified = self.auth.verify_token(token)
        self.assertIsNotNone(verified)

    def test_4_logout(self):
        """로그아웃"""
        self.db.create_researcher('테스트', 'test@gogs.io')
        token = self.auth.authenticate('test@gogs.io', 'test@gogs.io')
        self.auth.logout(token)
        verified = self.auth.verify_token(token)
        self.assertIsNone(verified)

    def test_5_get_researcher_role(self):
        """연구자 역할 조회"""
        researcher = self.db.create_researcher('테스트', 'test@gogs.io', 'admin')
        role = self.auth.get_researcher_role(researcher['id'])
        self.assertEqual(role, Role.ADMIN)


class TestAPIHandler(unittest.TestCase):
    """API 핸들러 테스트"""

    def setUp(self):
        """테스트 전 설정"""
        self.db_file = tempfile.mktemp(suffix='.db')
        self.db = GogsDatabase(self.db_file)
        self.auth = AuthManager(self.db)
        self.api = APIHandler(self.db, self.auth)

    def tearDown(self):
        """테스트 후 정리"""
        if os.path.exists(self.db_file):
            os.remove(self.db_file)

    def test_1_health_check(self):
        """헬스 체크"""
        status, response = self.api.handle_health({})
        self.assertEqual(status, HTTPStatusCode.OK)
        data = json.loads(response)
        self.assertEqual(data['status'], 200)

    def test_2_create_researcher_via_api(self):
        """API를 통한 연구자 생성"""
