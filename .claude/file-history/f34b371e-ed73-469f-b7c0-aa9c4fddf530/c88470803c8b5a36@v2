        self.assertIsNotNone(data['data'])

    def test_3_list_researchers_via_api(self):
        """API를 통한 연구자 목록"""
        self.db.create_researcher('테스트', 'test@gogs.io')
        status, response = self.api.handle_researchers_list({})
        self.assertEqual(status, HTTPStatusCode.OK)
        data = json.loads(response)
        self.assertGreater(len(data['data']), 0)

    def test_4_create_experiment_via_api(self):
        """API를 통한 실험 생성"""
        researcher = self.db.create_researcher('테스트', 'test@gogs.io')
        body = json.dumps({
            'researcher_id': researcher['id'],
            'subject': '테스트 실험'
        })
        status, response = self.api.handle_experiments_create({}, body)
        self.assertEqual(status, HTTPStatusCode.CREATED)

    def test_5_login_via_api(self):
        """API를 통한 로그인"""
        self.db.create_researcher('테스트', 'test@gogs.io')
        body = json.dumps({
            'email': 'test@gogs.io',
            'password': 'test@gogs.io'
        })
        status, response = self.api.handle_auth_login({}, body)
        self.assertEqual(status, HTTPStatusCode.OK)
        data = json.loads(response)
        self.assertIn('token', data['data'])

    def test_6_route_matching(self):
        """라우트 매칭"""
        route_name, params = self.api.match_route('GET', '/api/researchers')
        self.assertEqual(route_name, 'researchers_list')

        route_name, params = self.api.match_route('GET', '/api/researchers/123')
        self.assertEqual(route_name, 'researchers_get')
        self.assertEqual(params['id'], '123')


class TestHTTPLayer(unittest.TestCase):
    """HTTP 계층 테스트"""

    def test_1_parse_get_request(self):
        """GET 요청 파싱"""
        raw = 'GET /api/researchers HTTP/1.1\r\nHost: localhost\r\n\r\n'
        req = HTTPRequest(raw)
        self.assertEqual(req.method, 'GET')
        self.assertEqual(req.path, '/api/researchers')

    def test_2_parse_post_request(self):
        """POST 요청 파싱"""
        body = json.dumps({'name': 'test'})
        raw = f'POST /api/researchers HTTP/1.1\r\nContent-Length: {len(body)}\r\n\r\n{body}'
        req = HTTPRequest(raw)
        self.assertEqual(req.method, 'POST')
        self.assertEqual(req.body, body)

    def test_3_parse_headers(self):
        """헤더 파싱"""
        raw = 'GET / HTTP/1.1\r\nHost: localhost\r\nAuthorization: Bearer token123\r\n\r\n'
        req = HTTPRequest(raw)
        self.assertEqual(req.headers.get('Host'), 'localhost')
        self.assertEqual(req.headers.get('Authorization'), 'Bearer token123')

    def test_4_http_response(self):
        """HTTP 응답 생성"""
        resp = HTTPResponse(200, 'OK', body='{"status": "ok"}')
        response_bytes = resp.to_bytes()
        self.assertIn(b'200 OK', response_bytes)
        self.assertIn(b'application/json', response_bytes)

    def test_5_extract_token_from_header(self):
        """헤더에서 토큰 추출"""
        db_file = tempfile.mktemp(suffix='.db')
        db = GogsDatabase(db_file)
        auth = AuthManager(db)
        middleware = AuthMiddleware(auth)

        token = middleware.extract_token_from_header('Bearer abc123')
        self.assertEqual(token, 'abc123')

        token = middleware.extract_token_from_header('Invalid abc123')
        self.assertIsNone(token)

        if os.path.exists(db_file):
            os.remove(db_file)


class TestIntegration(unittest.TestCase):
    """통합 테스트"""

    def setUp(self):
        """테스트 전 설정"""
        self.db_file = tempfile.mktemp(suffix='.db')
        self.db = GogsDatabase(self.db_file)
        self.auth = AuthManager(self.db)
        self.api = APIHandler(self.db, self.auth)

    def tearDown(self):
        """테스트 후 정리"""
        if os.path.exists(self.db_file):
            os.remove(self.db_file)

    def test_1_full_workflow(self):
        """전체 워크플로우"""
        # 1. 연구자 생성
        researcher = self.db.create_researcher('연구자1', 'r1@gogs.io', 'admin')
        self.assertIsNotNone(researcher)

        # 2. 로그인
        token = self.auth.authenticate('r1@gogs.io', 'r1@gogs.io')
        self.assertIsNotNone(token)

        # 3. 실험 생성
        experiment = self.db.create_experiment(
            researcher['id'],
            '테스트 실험',
            '설명'
        )
        self.assertIsNotNone(experiment)

        # 4. 실험 로그 추가
        log = self.db.add_experiment_log(experiment['id'], '테스트 시작')
        self.assertIsNotNone(log)

        # 5. 실험 결과 업데이트
        updated = self.db.update_experiment(
            experiment['id'],
            result=95.5,
            status='completed'
        )
        self.assertEqual(updated['result'], 95.5)

        # 6. 통계 확인
        stats = self.db.get_statistics()
        self.assertEqual(stats['researcher_count'], 1)
        self.assertEqual(stats['experiment_count'], 1)

    def test_2_permission_control(self):
        """권한 제어"""
        # Admin 생성
        admin = self.db.create_researcher('Admin', 'admin@gogs.io', 'admin')
        admin_token = self.auth.authenticate('admin@gogs.io', 'admin@gogs.io')

        # Researcher 생성
        researcher = self.db.create_researcher('Researcher', 'r@gogs.io', 'researcher')

        # Admin은 모든 실험 조회 가능
        experiment = self.db.create_experiment(researcher['id'], '실험1')
        can_view = self.auth.can_view_experiment(admin_token, experiment['id'])
        self.assertTrue(can_view)

    def test_3_data_consistency(self):
        """데이터 일관성"""
        r1 = self.db.create_researcher('연구자1', 'r1@gogs.io')
        r2 = self.db.create_researcher('연구자2', 'r2@gogs.io')

        e1 = self.db.create_experiment(r1['id'], '실험1')
        e2 = self.db.create_experiment(r2['id'], '실험2')

        # 각 연구자의 실험 수가 정확한지 확인
        r1_exps = self.db.get_researcher_experiments(r1['id'])
        r2_exps = self.db.get_researcher_experiments(r2['id'])

        self.assertEqual(len(r1_exps), 1)
        self.assertEqual(len(r2_exps), 1)


def run_tests():
    """테스트 실행"""
    print('\n' + '=' * 70)
    print('🧪 v5.5 Capstone Integration Tests')
    print('=' * 70)

    loader = unittest.TestLoader()
    suite = unittest.TestSuite()

    suite.addTests(loader.loadTestsFromTestCase(TestDatabaseLayer))
    suite.addTests(loader.loadTestsFromTestCase(TestAuthenticationLayer))
    suite.addTests(loader.loadTestsFromTestCase(TestAPIHandler))
    suite.addTests(loader.loadTestsFromTestCase(TestHTTPLayer))
    suite.addTests(loader.loadTestsFromTestCase(TestIntegration))

    runner = unittest.TextTestRunner(verbosity=2)
    result = runner.run(suite)

    print('\n' + '=' * 70)
    if result.wasSuccessful():
        print(f'✅ 모든 테스트 통과 ({result.testsRun}/{ result.testsRun})')
    else:
        print(f'❌ 테스트 실패 ({len(result.failures)}/{result.testsRun})')
    print('=' * 70)

    return result.wasSuccessful()


if __name__ == '__main__':
    success = run_tests()
    exit(0 if success else 1)
