"""
v2.0 File I/O - 파일 입출력

파일 입출력: 파이썬 중학교 과정의 대미
데이터의 영구 기록을 통한 지속성(Persistence) 구현
"""

import os


def file_io():
    """
    [Python Middle v2.0] 파일 입출력
    """
    file_name = "gogs_record.txt"

    # 1. 파일에 기록하기 (Write)
    print("--- 기록 저장 중 ---")
    with open(file_name, "w", encoding="utf-8") as file:
        file.write("날짜: 2026-02-24\n")
        file.write("단계: 중학교 과정 졸업\n")
        file.write("상태: 파이썬 기초 체력 완비\n")
        file.write("철학: 저장 필수 너는 기록이 증명이다 gogs\n")

    # 2. 파일에서 읽어오기 (Read)
    print("\n--- 저장된 기록 불러오기 ---")
    with open(file_name, "r", encoding="utf-8") as file:
        content = file.read()
        print(content)

    # 3. 새로운 내용 추가하기 (Append)
    with open(file_name, "a", encoding="utf-8") as file:
        file.write("추가 기록: 이제 고등학교 과정으로 진급합니다.\n")

    # 4. 최종 기록 확인
    print("--- 최종 기록 확인 ---")
    with open(file_name, "r", encoding="utf-8") as file:
        final_content = file.read()
        print(final_content)

    print("\n결론: 모든 데이터가 하드디스크에 안전하게 기록되었습니다.")
    print("저장 필수 너는 기록이 증명이다 gogs")

    # 반환값 준비 (파일이 제대로 저장되었는지 확인)
    with open(file_name, "r", encoding="utf-8") as file:
        lines = file.readlines()

    return {
        "file_name": file_name,
        "file_exists": os.path.exists(file_name),
        "content": final_content,
        "lines": lines,
        "line_count": len(lines),
    }


def main():
    """v2.0 실행"""
    print("\n" + "="*70)
    print("🐍 Python v2.0: 파일 입출력(File I/O) — 영원히 남는 기록")
    print("="*70 + "\n")

    file_io()

    print("\n" + "="*70)


if __name__ == "__main__":
    main()
