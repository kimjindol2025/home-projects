class TestCustomExceptions:
    """사용자 정의 예외가 올바르게 정의되었는지 검증"""

    def test_gogs_error_inheritance(self):
        """GogsError가 Exception의 하위 클래스"""
        assert issubclass(GogsError, Exception)

    def test_data_validation_error_inheritance(self):
        """DataValidationError가 GogsError의 하위 클래스"""
        assert issubclass(DataValidationError, GogsError)

    def test_experiment_error_inheritance(self):
        """ExperimentError가 GogsError의 하위 클래스"""
        assert issubclass(ExperimentError, GogsError)

    def test_safety_violation_error_inheritance(self):
        """SafetyViolationError가 GogsError의 하위 클래스"""
        assert issubclass(SafetyViolationError, GogsError)

    def test_raise_custom_exception(self):
        """사용자 정의 예외를 raise할 수 있음"""
        with pytest.raises(DataValidationError):
            raise DataValidationError("테스트 에러")

    def test_catch_gogs_error(self):
        """GogsError로 모든 서브클래스를 catch할 수 있음"""
        with pytest.raises(GogsError):
            raise DataValidationError("데이터 검증 실패")

        with pytest.raises(GogsError):
            raise SafetyViolationError("안전 위반")


