class TestLBYLvsEAFP:
    """LBYL vs EAFP 방식 비교"""

    def test_lbyl_valid_input(self, capsys):
        """LBYL: 유효한 입력"""
        result = method_lbyl(50)
        assert result == 100 / 50

    def test_lbyl_invalid_type(self, capsys):
        """LBYL: 잘못된 타입"""
        result = method_lbyl("gogs")
        assert result is None

    def test_lbyl_zero_input(self, capsys):
        """LBYL: 0 입력"""
        result = method_lbyl(0)
        assert result == 0

    def test_lbyl_out_of_range(self, capsys):
        """LBYL: 범위 초과"""
        result = method_lbyl(2000)
        assert result is None

    def test_eafp_valid_input(self, capsys):
        """EAFP: 유효한 입력"""
        result = method_eafp(50)
        assert result == 100 / 50

    def test_eafp_invalid_type(self, capsys):
        """EAFP: 잘못된 타입"""
        result = method_eafp("gogs")
        assert result is None

    def test_eafp_zero_input(self, capsys):
        """EAFP: 0 입력"""
        result = method_eafp(0)
        assert result is None

    def test_eafp_same_result_as_lbyl(self):
        """EAFP와 LBYL의 결과가 같음 (유효한 입력)"""
        test_values = [1, 5, 50, 100, 999]
        for val in test_values:
            lbyl_result = method_lbyl(val)
            eafp_result = method_eafp(val)
            assert lbyl_result == eafp_result


