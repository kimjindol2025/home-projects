class TestResearchDataValidator:
    """연구 데이터 검증 시스템"""

    @pytest.fixture
    def validator(self):
        """테스트용 검증자"""
        log_file = "test_validator_log.txt"
        logger = ErrorLogger(log_file)
        yield ResearchDataValidator(logger)
        # 테스트 후 정리
        if os.path.exists(log_file):
            os.remove(log_file)

    def test_validate_temperature_valid(self, validator):
        """유효한 온도 데이터"""
        assert validator.validate_temperature(298.15) is True
        assert validator.validate_temperature("273.15") is True
        assert validator.validate_temperature(500) is True

    def test_validate_temperature_invalid_type(self, validator):
        """무효한 타입의 온도"""
        assert validator.validate_temperature("not_a_number") is False

    def test_validate_temperature_below_absolute_zero(self, validator):
        """절대영도 이하"""
        assert validator.validate_temperature(-300) is False

    def test_validate_pressure_valid(self, validator):
        """유효한 기압 데이터"""
        assert validator.validate_pressure(101325) is True
        assert validator.validate_pressure("50000") is True

    def test_validate_pressure_negative(self, validator):
        """음수 기압"""
        assert validator.validate_pressure(-100) is False

    def test_process_experiment_data_all_valid(self, validator):
        """모든 데이터가 유효한 경우"""
        data = {
            "exp_001": (298.15, 101325),
            "exp_002": (373.15, 101325),
            "exp_003": (500, 101325),
        }
        results = validator.process_experiment_data(data)

        assert results["summary"]["total"] == 3
        assert results["summary"]["valid_count"] == 3
        assert results["summary"]["invalid_count"] == 0

    def test_process_experiment_data_partial_valid(self, validator):
        """일부 데이터만 유효한 경우"""
        data = {
            "exp_001": (298.15, 101325),      # 유효
            "exp_002": ("invalid_temp", 101325),  # 온도 에러
            "exp_003": (373.15, -1),          # 기압 에러
            "exp_004": (500, 101325),         # 유효
        }
        results = validator.process_experiment_data(data)

        assert results["summary"]["total"] == 4
        assert results["summary"]["valid_count"] == 2
        assert results["summary"]["invalid_count"] == 2

    def test_process_experiment_data_all_invalid(self, validator):
        """모든 데이터가 무효한 경우"""
        data = {
            "exp_001": ("bad", 101325),
            "exp_002": (-300, 101325),
            "exp_003": (298.15, -100),
        }
        results = validator.process_experiment_data(data)

        assert results["summary"]["total"] == 3
        assert results["summary"]["valid_count"] == 0
        assert results["summary"]["invalid_count"] == 3

    def test_success_rate_calculation(self, validator):
        """성공률 계산"""
        data = {
            "exp_001": (298.15, 101325),
            "exp_002": ("bad", 101325),
        }
        results = validator.process_experiment_data(data)

        assert "50.0%" in results["summary"]["success_rate"]

    def test_valid_records_structure(self, validator):
        """유효한 기록 구조"""
        data = {
            "exp_001": (298.15, 101325),
        }
        results = validator.process_experiment_data(data)

        assert len(results["valid"]) == 1
        record = results["valid"][0]
        assert record["id"] == "exp_001"
        assert record["temp"] == 298.15
        assert record["pressure"] == 101325

    def test_invalid_records_structure(self, validator):
        """무효한 기록 구조"""
        data = {
            "exp_001": ("bad", 101325),
        }
        results = validator.process_experiment_data(data)

        assert len(results["invalid"]) == 1
        record = results["invalid"][0]
        assert record["id"] == "exp_001"
        assert "reason" in record


