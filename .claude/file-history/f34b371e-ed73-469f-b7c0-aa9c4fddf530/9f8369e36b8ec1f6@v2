class TestErrorLogger:
    """에러 로그 기록 시스템 검증"""

    @pytest.fixture
    def logger(self):
        """테스트용 로거"""
        log_file = "test_logger.txt"
        yield ErrorLogger(log_file)
        # 테스트 후 정리
        if os.path.exists(log_file):
            os.remove(log_file)

    def test_logger_initialization(self, logger):
        """로거가 올바르게 초기화됨"""
        assert hasattr(logger, 'log_file')
        assert hasattr(logger, 'error_records')
        assert len(logger.error_records) == 0

    def test_log_error_records(self, logger):
        """에러 기록이 저장됨"""
        logger.log_error("TestError", "테스트 에러 메시지", {"data": "test"})
        assert len(logger.error_records) == 1

    def test_log_error_structure(self, logger):
        """에러 기록의 구조가 올바름"""
        logger.log_error("TestError", "메시지", 42)
        record = logger.error_records[0]

        assert "timestamp" in record
        assert record["error_type"] == "TestError"
        assert record["message"] == "메시지"
        assert record["data"] == 42

    def test_multiple_error_records(self, logger):
        """여러 에러 기록"""
        logger.log_error("Error1", "메시지1", None)
        logger.log_error("Error2", "메시지2", None)
        logger.log_error("Error3", "메시지3", None)

        assert len(logger.error_records) == 3

    def test_get_error_summary(self, logger):
        """에러 요약"""
        logger.log_error("E1", "m1", None)
        logger.log_error("E2", "m2", None)

        summary = logger.get_error_summary()
        assert summary["total_errors"] == 2
        assert len(summary["records"]) == 2


