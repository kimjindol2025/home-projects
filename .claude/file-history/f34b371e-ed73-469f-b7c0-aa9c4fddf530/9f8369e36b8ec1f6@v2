class TestFourStageExceptionHandling:
    """try-except-else-finally의 4단계 처리 검증"""

    @pytest.fixture
    def logger(self):
        """테스트용 로거"""
        log_file = "test_experiment_log.txt"
        yield ErrorLogger(log_file)
        # 테스트 후 로그 파일 삭제
        if os.path.exists(log_file):
            os.remove(log_file)

    def test_normal_case_returns_result(self, logger):
        """정상 케이스: else 블록이 실행되고 결과 반환"""
        result = run_experiment(50, logger)
        assert result is not None
        assert isinstance(result, float)
        assert result == 100 / 50  # 정확한 계산

    def test_zero_division_catches_error(self, logger):
        """0으로 나누기: ZeroDivisionError 처리"""
        result = run_experiment(0, logger)
        assert result == 0  # 기본값 반환

    def test_invalid_type_catches_error(self, logger):
        """잘못된 타입: DataValidationError 처리"""
        result = run_experiment("gogs", logger)
        assert result is None

    def test_safety_violation_catches_error(self, logger):
        """안전 범위 위반: SafetyViolationError 처리"""
        result = run_experiment(2000, logger)
        assert result is None

    def test_finally_always_executes(self, capsys, logger):
        """finally 블록은 성공/실패 무관하게 실행"""
        run_experiment(50, logger)
        captured = capsys.readouterr()
        assert "시스템 유지보수" in captured.out or "정리" in captured.out

        run_experiment(0, logger)
        captured = capsys.readouterr()
        assert "시스템 유지보수" in captured.out or "정리" in captured.out


