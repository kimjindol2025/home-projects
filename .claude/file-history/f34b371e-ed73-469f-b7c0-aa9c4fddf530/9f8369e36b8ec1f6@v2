class TestIntegration:
    """통합 테스트: 전체 시스템이 함께 동작"""

    def test_full_pipeline(self):
        """전체 파이프라인 테스트"""
        logger = ErrorLogger("test_integration.txt")

        # 정상 케이스
        result1 = run_experiment(50, logger)
        assert result1 is not None

        # 에러 케이스
        result2 = run_experiment(0, logger)
        assert result2 == 0

        # 로그 확인
        summary = logger.get_error_summary()
        assert summary["total_errors"] >= 1

        # 정리
        if os.path.exists("test_integration.txt"):
            os.remove("test_integration.txt")

    def test_data_validation_complete_workflow(self):
        """데이터 검증 완전 워크플로우"""
        logger = ErrorLogger("test_workflow.txt")
        validator = ResearchDataValidator(logger)

        # 다양한 데이터 검증
        data = {
            "exp_001": (298.15, 101325),
            "exp_002": ("error", 101325),
            "exp_003": (-300, 101325),
        }

        results = validator.process_experiment_data(data)

        # 결과 확인
        assert "valid" in results
        assert "invalid" in results
        assert "summary" in results
        assert results["summary"]["valid_count"] >= 0

        # 정리
        for f in ["test_workflow.txt", "experiment_log.txt"]:
            if os.path.exists(f):
                os.remove(f)


