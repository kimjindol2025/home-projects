class TestEdgeCases:
    """엣지 케이스 테스트"""

    def test_float_infinity(self):
        """float 무한대"""
        result = method_eafp(float('inf'))
        assert result == 0  # TypeError 발생 → None 반환

    def test_very_small_number(self):
        """매우 작은 숫자"""
        result = run_experiment(0.0001)
        assert result is not None
        assert result == 100 / 0.0001

    def test_negative_number(self):
        """음수"""
        result = run_experiment(-50)
        assert result is not None
        assert result == 100 / -50

    def test_none_input(self):
        """None 입력"""
        result = run_experiment(None)
        assert result is None

    def test_boolean_input(self):
        """Boolean 입력 (파이썬에서는 숫자로 처리)"""
        # 파이썬에서는 bool이 int의 서브클래스
        result = run_experiment(True)
        assert result is not None  # True == 1이므로 가능


