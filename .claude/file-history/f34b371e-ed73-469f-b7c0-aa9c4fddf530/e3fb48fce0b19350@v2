def test_multiplier_callable():
    """Multiplier 호출"""
    mul5 = Multiplier(5)
    assert mul5(3) == 15
    assert mul5(10) == 50


def test_multiplier_zero():
    """Multiplier 0"""
    mul0 = Multiplier(0)
    assert mul0(100) == 0


def test_counter_callable():
    """Counter 호출"""
    counter = Counter()
    assert counter() == 1
    assert counter() == 2
    assert counter() == 3


def test_counter_reset():
    """Counter 리셋"""
    counter = Counter()
    counter()
    counter()
    counter.reset()
    assert counter() == 1


