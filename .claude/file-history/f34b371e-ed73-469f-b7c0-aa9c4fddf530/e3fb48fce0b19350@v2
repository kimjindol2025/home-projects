# 카테고리 2: 비교 연산 (8개 테스트)
# ============================================================================

def test_person_equality():
    """사람 동등성"""
    p1 = Person("Alice", 25)
    p2 = Person("Alice", 25)
    p3 = Person("Bob", 30)
    assert p1 == p2
    assert p1 != p3


def test_person_comparison():
    """사람 나이 비교"""
    p1 = Person("Alice", 25)
    p2 = Person("Bob", 30)
    assert p1 < p2
    assert p2 > p1
    assert p1 <= p2


def test_version_equality():
    """버전 동등성"""
    v1 = Version(1, 2, 3)
    v2 = Version(1, 2, 3)
    assert v1 == v2


def test_version_comparison():
    """버전 비교"""
    v1 = Version(1, 2, 3)
    v2 = Version(1, 3, 0)
    v3 = Version(2, 0, 0)
    assert v1 < v2 < v3
    assert v3 > v2 > v1


def test_version_sorting():
    """버전 정렬"""
    versions = [Version(2, 0, 0), Version(1, 5, 0), Version(1, 2, 3)]
    sorted_versions = sorted(versions)
    assert str(sorted_versions[0]) == "1.2.3"
    assert str(sorted_versions[2]) == "2.0.0"


def test_rational_equality():
    """유리수 동등성"""
    r1 = Rational(1, 2)
    r2 = Rational(2, 4)
    assert r1 == r2  # 약분됨


def test_rational_addition():
    """유리수 덧셈"""
    r1 = Rational(1, 2)
    r2 = Rational(1, 3)
    r3 = r1 + r2
    assert r3.numerator == 5 and r3.denominator == 6


def test_rational_multiplication():
    """유리수 곱셈"""
    r1 = Rational(2, 3)
    r2 = Rational(3, 4)
    r3 = r1 * r2
    assert r3.numerator == 1 and r3.denominator == 2


