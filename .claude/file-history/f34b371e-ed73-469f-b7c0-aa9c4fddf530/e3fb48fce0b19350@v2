def test_vector_zero_division():
    """0으로 나누기"""
    v = GogsVector(1, 2)
    with pytest.raises(ValueError):
        v / 0


def test_rational_reduction():
    """유리수 자동 약분"""
    r = Rational(4, 8)
    assert r.numerator == 1 and r.denominator == 2


def test_rational_zero_denominator():
    """분모가 0"""
    with pytest.raises(ValueError):
        Rational(1, 0)


def test_matrix_out_of_bounds():
    """Matrix 범위 초과"""
    m = Matrix(2, 2)
    with pytest.raises(IndexError):
        m[5, 5]


def test_simplelist_negative_index():
    """SimpleList 음수 인덱싱"""
    sl = SimpleList([1, 2, 3])
    # Python의 list처럼 동작하지 않음 (실제로는 ValueError)
    with pytest.raises(IndexError):
        sl[-1]


def test_custom_range_backward():
    """CustomRange 역방향"""
    cr = CustomRange(5, 0, -1)
    result = list(cr)
    assert result == [5, 4, 3, 2, 1]


def test_vector_chain_operations():
    """벡터 연쇄 연산"""
    v1 = GogsVector(1, 0)
    v2 = GogsVector(0, 1)
    result = (v1 + v2) * 2
    assert result.x == 2 and result.y == 2


def test_version_string_representation():
    """버전 문자열 표현"""
    v = Version(1, 2, 3)
    assert str(v) == "1.2.3"
    assert "Version" in repr(v)


def test_money_format_variations():
    """Money 다양한 포맷"""
    m = Money(100, "USD")
    assert format(m, "int") == "100"
    assert "e+" in format(m, "scientific").lower()


def test_person_same_age_different_names():
    """사람 같은 나이, 다른 이름"""
    p1 = Person("Alice", 25)
    p2 = Person("Bob", 25)
    assert p1 != p2
    assert not (p1 < p2)
    assert not (p1 > p2)


