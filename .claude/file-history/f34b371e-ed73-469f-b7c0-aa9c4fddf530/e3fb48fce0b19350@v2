def test_simplelist_len():
    """SimpleList 길이"""
    sl = SimpleList([1, 2, 3])
    assert len(sl) == 3


def test_simplelist_getitem():
    """SimpleList 인덱싱 읽기"""
    sl = SimpleList([10, 20, 30])
    assert sl[0] == 10
    assert sl[2] == 30


def test_simplelist_setitem():
    """SimpleList 인덱싱 쓰기"""
    sl = SimpleList([1, 2, 3])
    sl[1] = 20
    assert sl[1] == 20


def test_simplelist_contains():
    """SimpleList 멤버십"""
    sl = SimpleList([1, 2, 3])
    assert 2 in sl
    assert 5 not in sl


def test_simplelist_iteration():
    """SimpleList 반복"""
    sl = SimpleList([1, 2, 3])
    result = [x for x in sl]
    assert result == [1, 2, 3]


def test_custom_range():
    """CustomRange"""
    cr = CustomRange(1, 6, 2)
    assert len(cr) == 3
    assert list(cr) == [1, 3, 5]
    assert cr[0] == 1


def test_custom_range_contains():
    """CustomRange 멤버십"""
    cr = CustomRange(0, 10, 2)
    assert 2 in cr
    assert 3 not in cr


def test_matrix_indexing():
    """Matrix 2D 인덱싱"""
    m = Matrix(2, 2)
    m[0, 0] = 1
    m[1, 1] = 4
    assert m[0, 0] == 1
    assert m[1, 1] == 4


