def test_point_str():
    """Point str()"""
    p = Point(3, 4)
    assert str(p) == "(3, 4)"


def test_point_repr():
    """Point repr()"""
    p = Point(3, 4)
    assert repr(p) == "Point(3, 4)"


def test_money_str():
    """Money str()"""
    m = Money(1000.5, "USD")
    assert "USD" in str(m)
    assert "1,000.50" in str(m)


def test_color_hex_format():
    """Color hex 포맷"""
    c = Color(255, 128, 0)
    assert format(c, "hex") == "#ff8000"


def test_point_polar_format():
    """Point polar 포맷"""
    p = Point(3, 4)
    result = format(p, "polar")
    assert "5.00" in result


def test_f_string_format():
    """f-string 포맷"""
    p = Point(1, 2)
    result = f"{p}"
    assert result == "(1, 2)"


