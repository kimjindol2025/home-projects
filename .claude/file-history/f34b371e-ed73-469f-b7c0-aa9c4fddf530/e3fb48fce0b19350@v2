"""
v1.4 테스트: 매직 메소드

산술 연산, 비교, 시퀀스, 호출 가능, 컨텍스트를 검증합니다.
"""

import pytest
import time
from src.v1_4_magic_methods import (
    GogsVector, GogsComplex, Rational,
    Person, Version,
    SimpleList, CustomRange, Matrix,
    Point, Money, Color,
    Multiplier, Counter, Timer,
)


# ============================================================================
# 카테고리 1: 산술 연산 (10개 테스트)
# ============================================================================

def test_vector_addition():
    """벡터 덧셈"""
    v1 = GogsVector(1, 2)
    v2 = GogsVector(3, 4)
    v3 = v1 + v2
    assert v3.x == 4 and v3.y == 6


def test_vector_subtraction():
    """벡터 뺄셈"""
    v1 = GogsVector(5, 7)
    v2 = GogsVector(2, 3)
    v3 = v1 - v2
    assert v3.x == 3 and v3.y == 4


def test_vector_scalar_multiplication():
    """스칼라 곱셈"""
    v = GogsVector(2, 3)
    v2 = v * 3
    assert v2.x == 6 and v2.y == 9


def test_vector_reverse_multiplication():
    """역방향 스칼라 곱셈"""
    v = GogsVector(2, 3)
    v2 = 2 * v
    assert v2.x == 4 and v2.y == 6


def test_vector_division():
    """벡터 나눗셈"""
    v = GogsVector(6, 8)
    v2 = v / 2
    assert v2.x == 3 and v2.y == 4


def test_vector_abs():
    """벡터의 크기"""
    v = GogsVector(3, 4)
    assert abs(v) == 5.0


def test_vector_neg():
    """벡터 음수화"""
    v = GogsVector(3, 4)
    v2 = -v
    assert v2.x == -3 and v2.y == -4


def test_vector_len():
    """len(): 벡터의 크기를 정수로"""
    v = GogsVector(3, 4)
    assert len(v) == 5


def test_complex_addition():
    """복소수 덧셈"""
    c1 = GogsComplex(1, 2)
    c2 = GogsComplex(3, 4)
    c3 = c1 + c2
    assert c3.real == 4 and c3.imag == 6


def test_complex_multiplication():
    """복소수 곱셈"""
    c1 = GogsComplex(2, 3)
    c2 = GogsComplex(1, 1)
    c3 = c1 * c2
    assert c3.real == -1 and c3.imag == 5


