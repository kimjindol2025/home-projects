def test_multiple_vector_operations():
    """여러 벡터 연산"""
    v1 = GogsVector(1, 2)
    v2 = GogsVector(3, 4)
    v3 = GogsVector(5, 6)

    result = (v1 + v2) - v3
    assert result.x == -1 and result.y == 0


def test_sequence_protocol_complete():
    """완전한 시퀀스 프로토콜"""
    sl = SimpleList([10, 20, 30, 40, 50])
    assert len(sl) == 5
    assert 20 in sl
    assert sl[2] == 30

    sl[1] = 200
    assert sl[1] == 200

    items = [x for x in sl]
    assert len(items) == 5


def test_comparison_sorting_complex():
    """복잡한 정렬"""
    people = [
        Person("Alice", 30),
        Person("Bob", 25),
        Person("Carol", 28),
    ]
    sorted_people = sorted(people)
    assert sorted_people[0].name == "Bob"
    assert sorted_people[2].name == "Alice"
