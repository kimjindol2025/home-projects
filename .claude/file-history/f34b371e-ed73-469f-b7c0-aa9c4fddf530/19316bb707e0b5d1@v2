class TestQueryOptimizer(unittest.TestCase):
    """쿼리 최적화기 테스트"""

    def setUp(self):
        """각 테스트마다 새 QueryOptimizer 생성"""
        self.optimizer = QueryOptimizer()

    def test_6_1_analyze_select_query(self):
        """SELECT 쿼리 분석"""
        plan = self.optimizer.analyze_query('SELECT * FROM users')

        self.assertEqual(plan['type'], 'SELECT')
        self.assertIn('optimization_suggestions', plan)

    def test_6_2_missing_where_optimization(self):
        """WHERE 절 최적화 제안"""
        plan = self.optimizer.analyze_query('SELECT * FROM users')

        self.assertIn('WHERE 절 추가하면 성능 향상', plan['optimization_suggestions'])

    def test_6_3_order_by_optimization(self):
        """ORDER BY 최적화 제안"""
        plan = self.optimizer.analyze_query('SELECT * FROM users ORDER BY name')

        self.assertIn('ORDER BY 칼럼에 인덱스 생성', plan['optimization_suggestions'])

    def test_6_4_join_optimization(self):
        """JOIN 최적화 제안"""
        plan = self.optimizer.analyze_query('SELECT * FROM users JOIN accounts')

        self.assertIn('JOIN 순서 재정렬 고려', plan['optimization_suggestions'])

