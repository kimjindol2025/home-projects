class TestDatabaseIntegration(unittest.TestCase):
    """통합 테스트"""

    def test_10_1_full_banking_workflow(self):
        """은행 업무 완전 워크플로우"""
        # 1. 트랜잭션 시작
        tx = TransactionManager()

        # 2. 사용자 및 계좌 생성
        user1 = tx.insert_user('설계자', 'designer@gogs.io')
        user2 = tx.insert_user('개발자', 'dev@gogs.io')

        acc1 = tx.insert_account(user1, 'savings', 100000)
        acc2 = tx.insert_account(user2, 'checking', 50000)

        # 3. 송금
        tx.transfer_money(acc1, acc2, 20000)

        # 4. 일관성 검사
        checker = DataConsistencyChecker(tx)
        results = checker.verify_all()

        # 5. 백업
        backup_mgr = BackupManager(tx)
        backup_mgr.create_backup('day1')

        # 검증
        self.assertTrue(results['referential_integrity'])
        self.assertTrue(results['balance_consistency'])
        self.assertEqual(tx.get_balance(acc1), 80000)
        self.assertEqual(tx.get_balance(acc2), 70000)

    def test_10_2_nosql_document_management(self):
        """NoSQL 문서 관리"""
        store = NoSQLStore()

        # 여러 문서 삽입
        for i in range(5):
            store.insert_document('posts', f'post_{i}', {
                'title': f'Post {i}',
                'author': f'Author {i % 2}',
                'views': 100 + i * 10
            })

        # 검색
        posts = store.find_in_collection('posts', {'author': 'Author 0'})

        # 업데이트
        store.update_document('post_0', {'views': 200})

        # 검증
        self.assertEqual(store.count_collection('posts'), 5)
        self.assertGreater(len(posts), 0)

    def test_10_3_indexing_performance_comparison(self):
        """인덱싱 성능 비교"""
        index_mgr = IndexManager()

        # 1,000개 레코드
        data = [(i, f'User_{i % 100}') for i in range(1000)]
        index_mgr.create_index('name', data)

        # 인덱스 검색
        start = time.time()
        for _ in range(100):
            index_mgr.search_by_index('name', 'User_50')
        index_time = time.time() - start

        # 전체 스캔
        start = time.time()
        for _ in range(100):
            index_mgr.full_scan('name', 'User_50', data)
        scan_time = time.time() - start

        # 인덱스가 더 빠름
        self.assertLess(index_time, scan_time)


