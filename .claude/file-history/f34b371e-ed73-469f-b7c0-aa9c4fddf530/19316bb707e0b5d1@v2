class TestConnectionPool(unittest.TestCase):
    """연결 풀 테스트"""

    def setUp(self):
        """각 테스트마다 새 ConnectionPool 생성"""
        self.pool = ConnectionPool(pool_size=5)

    def test_9_1_acquire_connection(self):
        """연결 획득"""
        conn = self.pool.acquire()

        self.assertIsNotNone(conn)

    def test_9_2_release_connection(self):
        """연결 반환"""
        conn = self.pool.acquire()

        self.pool.release(conn)

        stats = self.pool.get_stats()
        self.assertEqual(stats['available'], 5)

    def test_9_3_pool_stats_initial(self):
        """풀 통계 초기 상태"""
        stats = self.pool.get_stats()

        self.assertEqual(stats['total_connections'], 5)
        self.assertEqual(stats['available'], 5)
        self.assertEqual(stats['in_use'], 0)

    def test_9_4_pool_stats_after_acquire(self):
        """획득 후 풀 통계"""
        self.pool.acquire()
        self.pool.acquire()

        stats = self.pool.get_stats()

        self.assertEqual(stats['available'], 3)
        self.assertEqual(stats['in_use'], 2)

    def test_9_5_multiple_acquire_release_cycles(self):
        """여러 번의 획득/반환 사이클"""
        conn1 = self.pool.acquire()
        conn2 = self.pool.acquire()

        self.pool.release(conn1)
        stats1 = self.pool.get_stats()
        self.assertEqual(stats1['in_use'], 1)

        self.pool.release(conn2)
        stats2 = self.pool.get_stats()
        self.assertEqual(stats2['in_use'], 0)

    def test_9_6_pool_exhaustion(self):
        """풀 소진"""
        conns = []
        for _ in range(5):
            conn = self.pool.acquire()
            conns.append(conn)

        # 모든 연결을 사용 중
        stats = self.pool.get_stats()
        self.assertEqual(stats['available'], 0)
        self.assertEqual(stats['in_use'], 5)

        # 추가 요청 시 None 반환
        extra = self.pool.acquire()
        self.assertIsNone(extra)


