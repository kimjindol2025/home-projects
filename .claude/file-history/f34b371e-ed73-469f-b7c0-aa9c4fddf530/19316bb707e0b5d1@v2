class TestTransactionManager(unittest.TestCase):
    """ACID 트랜잭션 관리자 테스트"""

    def setUp(self):
        """각 테스트마다 새 TransactionManager 생성"""
        self.tx_manager = TransactionManager()

    def test_2_1_insert_user(self):
        """사용자 삽입"""
        user_id = self.tx_manager.insert_user('설계자', 'designer@gogs.io')

        self.assertIsNotNone(user_id)
        self.assertGreater(user_id, 0)

    def test_2_2_insert_account(self):
        """계좌 삽입"""
        user_id = self.tx_manager.insert_user('설계자', 'designer@gogs.io')
        account_id = self.tx_manager.insert_account(user_id, 'savings', 10000)

        self.assertIsNotNone(account_id)
        self.assertGreater(account_id, 0)

    def test_2_3_get_balance(self):
        """잔액 조회"""
        user_id = self.tx_manager.insert_user('설계자', 'designer@gogs.io')
        account_id = self.tx_manager.insert_account(user_id, 'savings', 10000)

        balance = self.tx_manager.get_balance(account_id)
        self.assertEqual(balance, 10000)

    def test_2_4_get_user(self):
        """사용자 조회"""
        user_id = self.tx_manager.insert_user('설계자', 'designer@gogs.io')
        user = self.tx_manager.get_user(user_id)

        self.assertIsNotNone(user)
        self.assertEqual(user.name, '설계자')
        self.assertEqual(user.email, 'designer@gogs.io')

    def test_2_5_begin_transaction(self):
        """트랜잭션 시작"""
        tx_id = self.tx_manager.begin_transaction()

        self.assertEqual(tx_id, 0)
        self.assertEqual(len(self.tx_manager.transaction_stack), 1)

    def test_2_6_add_operation(self):
        """작업 추가"""
        tx_id = self.tx_manager.begin_transaction()
        self.tx_manager.add_operation(
            'INSERT INTO users (name, email, created_at) VALUES (?, ?, ?)',
            ('테스트', 'test@gogs.io', time.time())
        )

        self.assertEqual(len(self.tx_manager.transaction_stack[-1]['operations']), 1)

    def test_2_7_commit_success(self):
        """커밋 성공"""
        user_id = self.tx_manager.insert_user('설계자', 'designer@gogs.io')
        tx_id = self.tx_manager.begin_transaction()
        self.tx_manager.add_operation(
            'UPDATE users SET name = ? WHERE id = ?',
            ('수정됨', user_id)
        )

        result = self.tx_manager.commit()
        self.assertTrue(result)
        self.assertEqual(len(self.tx_manager.transaction_stack), 0)

    def test_2_8_rollback(self):
        """롤백"""
        tx_id = self.tx_manager.begin_transaction()
        self.tx_manager.add_operation(
            'INSERT INTO users (name, email, created_at) VALUES (?, ?, ?)',
            ('롤백테스트', 'rollback@gogs.io', time.time())
        )

        result = self.tx_manager.rollback()
        self.assertTrue(result)
        self.assertEqual(len(self.tx_manager.transaction_stack), 0)

    def test_2_9_transfer_money_success(self):
        """송금 성공 - Atomicity 검증"""
        user_id = self.tx_manager.insert_user('설계자', 'designer@gogs.io')
        acc1 = self.tx_manager.insert_account(user_id, 'savings', 10000)
        acc2 = self.tx_manager.insert_account(user_id, 'checking', 5000)

        success = self.tx_manager.transfer_money(acc1, acc2, 3000)

        self.assertTrue(success)
        self.assertEqual(self.tx_manager.get_balance(acc1), 7000)
        self.assertEqual(self.tx_manager.get_balance(acc2), 8000)

    def test_2_10_transfer_insufficient_funds(self):
        """송금 실패 - 잔액 부족"""
        user_id = self.tx_manager.insert_user('설계자', 'designer@gogs.io')
        acc1 = self.tx_manager.insert_account(user_id, 'savings', 1000)
        acc2 = self.tx_manager.insert_account(user_id, 'checking', 5000)

        # 송금 후에도 원자성은 보장됨 (부분 성공 없음)
        success = self.tx_manager.transfer_money(acc1, acc2, 500)

        # SQLite는 음수 잔액 허용 (테스트 목적상)
        self.assertTrue(success)

    def test_2_11_multiple_accounts_isolation(self):
        """여러 계좌의 고립성 검증"""
        user1 = self.tx_manager.insert_user('사용자1', 'user1@gogs.io')
        user2 = self.tx_manager.insert_user('사용자2', 'user2@gogs.io')

        acc1 = self.tx_manager.insert_account(user1, 'savings', 10000)
        acc2 = self.tx_manager.insert_account(user2, 'savings', 20000)

        self.tx_manager.transfer_money(acc1, acc2, 1000)

        self.assertEqual(self.tx_manager.get_balance(acc1), 9000)
        self.assertEqual(self.tx_manager.get_balance(acc2), 21000)

    def test_2_12_transaction_stack_management(self):
        """트랜잭션 스택 관리"""
        tx_id_1 = self.tx_manager.begin_transaction()
        tx_id_2 = self.tx_manager.begin_transaction()

        self.assertEqual(len(self.tx_manager.transaction_stack), 2)
        self.tx_manager.rollback()
        self.assertEqual(len(self.tx_manager.transaction_stack), 1)


