class TestNoSQLStore(unittest.TestCase):
    """NoSQL 문서 저장소 테스트"""

    def setUp(self):
        """각 테스트마다 새 NoSQLStore 생성"""
        self.store = NoSQLStore()

    def test_5_1_insert_document(self):
        """문서 삽입"""
        result = self.store.insert_document('users', 'user1', {
            'name': '설계자',
            'email': 'designer@gogs.io'
        })

        self.assertTrue(result)

    def test_5_2_find_by_id(self):
        """ID로 검색"""
        self.store.insert_document('users', 'user1', {
            'name': '설계자'
        })

        doc = self.store.find_by_id('user1')

        self.assertIsNotNone(doc)
        self.assertEqual(doc.doc_id, 'user1')

    def test_5_3_find_in_collection(self):
        """컬렉션에서 쿼리"""
        self.store.insert_document('users', 'user1', {'age': 25, 'name': '설계자'})
        self.store.insert_document('users', 'user2', {'age': 28, 'name': '개발자'})

        result = self.store.find_in_collection('users', {'age': 25})

        self.assertEqual(len(result), 1)
        self.assertEqual(result[0].doc_id, 'user1')

    def test_5_4_update_document(self):
        """문서 업데이트"""
        self.store.insert_document('users', 'user1', {'name': '설계자', 'age': 25})

        result = self.store.update_document('user1', {'age': 26})

        self.assertTrue(result)
        doc = self.store.find_by_id('user1')
        self.assertEqual(doc.data['age'], 26)

    def test_5_5_delete_document(self):
        """문서 삭제"""
        self.store.insert_document('users', 'user1', {'name': '설계자'})

        result = self.store.delete_document('user1')

        self.assertTrue(result)
        self.assertIsNone(self.store.find_by_id('user1'))

    def test_5_6_count_collection(self):
        """컬렉션 크기"""
        self.store.insert_document('users', 'user1', {'name': '사용자1'})
        self.store.insert_document('users', 'user2', {'name': '사용자2'})
        self.store.insert_document('users', 'user3', {'name': '사용자3'})

        count = self.store.count_collection('users')

        self.assertEqual(count, 3)

    def test_5_7_multiple_collections(self):
        """여러 컬렉션"""
        self.store.insert_document('users', 'user1', {'name': '설계자'})
        self.store.insert_document('posts', 'post1', {'title': '첫 번째 글'})

        user_count = self.store.count_collection('users')
        post_count = self.store.count_collection('posts')

        self.assertEqual(user_count, 1)
        self.assertEqual(post_count, 1)

    def test_5_8_complex_query(self):
        """복합 쿼리"""
        self.store.insert_document('users', 'user1', {
            'name': '설계자',
            'age': 25,
            'city': 'Seoul'
        })
        self.store.insert_document('users', 'user2', {
            'name': '개발자',
            'age': 25,
            'city': 'Busan'
        })

        result = self.store.find_in_collection('users', {'age': 25, 'city': 'Seoul'})

        self.assertEqual(len(result), 1)

    def test_5_9_update_nonexistent(self):
        """존재하지 않는 문서 업데이트"""
        result = self.store.update_document('nonexistent', {'name': 'test'})

        self.assertFalse(result)

    def test_5_10_delete_nonexistent(self):
        """존재하지 않는 문서 삭제"""
        result = self.store.delete_document('nonexistent')

        self.assertFalse(result)

    def test_5_11_aggregate_pipeline(self):
        """집계 파이프라인"""
        self.store.insert_document('users', 'user1', {'department': 'IT', 'salary': 5000})
        self.store.insert_document('users', 'user2', {'department': 'IT', 'salary': 6000})
        self.store.insert_document('users', 'user3', {'department': 'HR', 'salary': 4000})

        pipeline = [{'$match': {'department': 'IT'}}]
        result = self.store.aggregate('users', pipeline)

        self.assertEqual(len(result), 2)

    def test_5_12_document_metadata(self):
        """문서 메타데이터"""
        self.store.insert_document('users', 'user1', {'name': '설계자'})
        doc = self.store.find_by_id('user1')

        self.assertEqual(doc.collection, 'users')
        self.assertIsNotNone(doc.created_at)
        self.assertIsNotNone(doc.updated_at)


