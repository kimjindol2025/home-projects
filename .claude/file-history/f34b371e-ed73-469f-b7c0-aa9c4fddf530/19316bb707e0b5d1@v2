class TestIndexManager(unittest.TestCase):
    """인덱스 관리자 테스트"""

    def setUp(self):
        """각 테스트마다 새 IndexManager 생성"""
        self.index_mgr = IndexManager()

    def test_3_1_create_index(self):
        """인덱스 생성"""
        data = [(1, 'Alice'), (2, 'Bob'), (3, 'Alice')]
        self.index_mgr.create_index('name', data)

        self.assertIn('name', self.index_mgr.indexes)
        self.assertIn('Alice', self.index_mgr.indexes['name'])

    def test_3_2_search_by_index(self):
        """인덱스로 검색"""
        data = [(1, 'Alice'), (2, 'Bob'), (3, 'Alice')]
        self.index_mgr.create_index('name', data)

        result = self.index_mgr.search_by_index('name', 'Alice')

        self.assertEqual(len(result), 2)
        self.assertIn(1, result)
        self.assertIn(3, result)

    def test_3_3_full_scan(self):
        """전체 스캔"""
        data = [(1, 'Alice'), (2, 'Bob'), (3, 'Alice')]

        result = self.index_mgr.full_scan('name', 'Alice', data)

        self.assertEqual(len(result), 2)

    def test_3_4_index_hit_count(self):
        """인덱스 히트 카운트"""
        data = [(1, 'Alice'), (2, 'Bob'), (3, 'Alice')]
        self.index_mgr.create_index('name', data)

        # 여러 번 검색
        for _ in range(3):
            self.index_mgr.search_by_index('name', 'Alice')

        stats = self.index_mgr.get_stats()
        self.assertEqual(stats['hit_count'], 3)

    def test_3_5_full_scan_count(self):
        """전체 스캔 카운트"""
        data = [(1, 'Alice'), (2, 'Bob'), (3, 'Alice')]

        for _ in range(2):
            self.index_mgr.full_scan('name', 'Alice', data)

        stats = self.index_mgr.get_stats()
        self.assertEqual(stats['full_scan_count'], 2)

    def test_3_6_hit_ratio(self):
        """히트 레이션"""
        data = [(1, 'Alice'), (2, 'Bob'), (3, 'Alice')]
        self.index_mgr.create_index('name', data)

        # 인덱스 히트 2번
        for _ in range(2):
            self.index_mgr.search_by_index('name', 'Alice')

        # 전체 스캔 2번
        for _ in range(2):
            self.index_mgr.full_scan('name', 'Bob', data)

        stats = self.index_mgr.get_stats()
        self.assertEqual(stats['hit_ratio'], 0.5)

    def test_3_7_multiple_columns_index(self):
        """여러 컬럼 인덱싱"""
        user_data = [(1, 'Alice'), (2, 'Bob'), (3, 'Alice')]
        email_data = [(1, 'alice@gogs.io'), (2, 'bob@gogs.io'), (3, 'alice2@gogs.io')]

        self.index_mgr.create_index('name', user_data)
        self.index_mgr.create_index('email', email_data)

        stats = self.index_mgr.get_stats()
        self.assertEqual(stats['index_count'], 2)

    def test_3_8_search_nonexistent_value(self):
        """존재하지 않는 값 검색"""
        data = [(1, 'Alice'), (2, 'Bob')]
        self.index_mgr.create_index('name', data)

        result = self.index_mgr.search_by_index('name', 'Charlie')

        self.assertEqual(len(result), 0)

    def test_3_9_large_dataset_indexing(self):
        """대용량 데이터 인덱싱 성능"""
        # 10,000개 레코드
        data = [(i, f'User_{i % 100}') for i in range(10000)]

        start = time.time()
        self.index_mgr.create_index('name', data)
        index_time = time.time() - start

        start = time.time()
        result = self.index_mgr.search_by_index('name', 'User_50')
        search_time = time.time() - start

        self.assertLess(search_time, 0.01)  # 10ms 이내

    def test_3_10_index_creation_tracking(self):
        """인덱스 생성 횟수 추적"""
        data = [(1, 'Alice'), (2, 'Bob')]

        self.index_mgr.create_index('name', data)
        self.index_mgr.create_index('email', data)

        stats = self.index_mgr.get_stats()
        self.assertEqual(stats['index_count'], 2)


