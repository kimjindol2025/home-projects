class TestNormalizationDemo(unittest.TestCase):
    """정규화 데모 테스트"""

    def test_4_1_denormalized_structure(self):
        """비정규화 구조"""
        data = NormalizationDemo.denormalized_data()

        self.assertEqual(len(data), 1)
        self.assertIn('accounts', data[0])

    def test_4_2_first_normal_form(self):
        """1NF - 원자값만"""
        data = NormalizationDemo.first_normal_form()

        self.assertIn('users', data)
        self.assertIn('accounts', data)
        # 각 행은 독립적
        self.assertEqual(len(data['users']), 1)
        self.assertEqual(len(data['accounts']), 2)

    def test_4_3_1nf_atomicity(self):
        """1NF - 원자값 검증"""
        data = NormalizationDemo.first_normal_form()
        users = data['users']

        # 각 필드는 원자값 (리스트 아님)
        for user in users:
            self.assertIsInstance(user['user_id'], int)
            self.assertIsInstance(user['name'], str)
            self.assertIsInstance(user['email'], str)

    def test_4_4_second_normal_form(self):
        """2NF - 부분 종속 제거"""
        data = NormalizationDemo.second_normal_form()

        self.assertIn('users', data)
        self.assertIn('accounts', data)
        self.assertIn('balances', data)
        # 잔액은 별도 테이블
        self.assertEqual(len(data['balances']), 2)

    def test_4_5_third_normal_form(self):
        """3NF - 이행 종속 제거"""
        data = NormalizationDemo.third_normal_form()

        self.assertIn('users', data)
        self.assertIn('user_emails', data)
        self.assertIn('accounts', data)
        self.assertIn('balances', data)

    def test_4_6_3nf_structure_validation(self):
        """3NF 구조 검증"""
        data = NormalizationDemo.third_normal_form()

        # 사용자와 이메일 분리
        users = data['users']
        emails = data['user_emails']

        self.assertEqual(len(users), 1)
        self.assertEqual(len(emails), 1)
        self.assertNotIn('email', users[0])

    def test_4_7_normalization_progression(self):
        """정규화 단계별 진행"""
        denorm = NormalizationDemo.denormalized_data()
        norm1 = NormalizationDemo.first_normal_form()
        norm2 = NormalizationDemo.second_normal_form()
        norm3 = NormalizationDemo.third_normal_form()

        # 각 단계는 테이블이 더 많음
        self.assertEqual(len(denorm[0]), 5)  # 필드 수
        self.assertEqual(len(norm1), 2)  # 테이블 수
        self.assertEqual(len(norm2), 3)  # 테이블 수
        self.assertEqual(len(norm3), 4)  # 테이블 수

    def test_4_8_redundancy_reduction(self):
        """중복성 감소 검증"""
        norm1 = NormalizationDemo.first_normal_form()
        norm3 = NormalizationDemo.third_normal_form()

        # 3NF에서 이메일이 별도 테이블
        users_3nf = norm3['users']
        self.assertNotIn('email', users_3nf[0])


