class TestDatabasePhilosophy(unittest.TestCase):
    """데이터베이스 철학 테스트"""

    def test_1_1_acid_principles(self):
        """ACID 원칙 정의"""
        principles = DatabasePhilosophy.acid_principles()

        self.assertIn('원자성 (Atomicity)', principles)
        self.assertIn('일관성 (Consistency)', principles)
        self.assertIn('고립성 (Isolation)', principles)
        self.assertIn('지속성 (Durability)', principles)
        self.assertEqual(len(principles), 4)

    def test_1_2_normalization_levels(self):
        """정규화 레벨 정의"""
        levels = DatabasePhilosophy.normalization_levels()

        self.assertIn('1NF (First Normal Form)', levels)
        self.assertIn('2NF (Second Normal Form)', levels)
        self.assertIn('3NF (Third Normal Form)', levels)
        self.assertIn('BCNF', levels)
        self.assertEqual(len(levels), 4)

    def test_1_3_rdbms_vs_nosql(self):
        """RDBMS vs NoSQL 비교"""
        comparison = DatabasePhilosophy.rdbms_vs_nosql()

        self.assertIn('RDBMS', comparison)
        self.assertIn('NoSQL', comparison)
        self.assertIn('특징', comparison['RDBMS'])
        self.assertIn('확장', comparison['NoSQL'])

    def test_1_4_user_dataclass(self):
        """User 데이터 모델"""
        user = User(id=1, name='설계자', email='designer@gogs.io')

        self.assertEqual(user.id, 1)
        self.assertEqual(user.name, '설계자')
        self.assertEqual(user.email, 'designer@gogs.io')
        self.assertIsNotNone(user.created_at)

    def test_1_5_account_dataclass(self):
        """Account 데이터 모델"""
        account = Account(id=1, user_id=1, balance=10000, account_type='savings')

        self.assertEqual(account.balance, 10000)
        self.assertEqual(account.account_type, 'savings')
        self.assertEqual(account.user_id, 1)


