/// 프로그램을 컴파일하고 실행
pub fn compile_and_run(program: &Program) -> Result<Value, String> {
    let mut compiler = Compiler::new();
    compiler.compile(program)?;
    let bytecode = compiler.bytecode();

    let mut vm = VM::new(bytecode);
    vm.run()
}

/// 디버그 모드로 컴파일하고 실행
pub fn compile_and_run_debug(program: &Program) -> Result<Value, String> {
    let mut compiler = Compiler::new().with_debug(true);
    compiler.compile(program)?;
    let bytecode = compiler.bytecode();

    println!("{}", disassembler::Disassembler::disassemble(&bytecode));

    let mut vm = VM::new(bytecode);
    vm.run()
}
