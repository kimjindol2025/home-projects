class TestIntrospectionMeta:
    """인트로스펙션 메타클래스 테스트"""

    def test_method_collection(self):
        """메서드 수집"""

        class MyClass(metaclass=IntrospectionMeta):
            def method1(self):
                pass

            def method2(self):
                pass

        assert hasattr(MyClass, "__methods__")
        assert "method1" in MyClass.__methods__
        assert "method2" in MyClass.__methods__

    def test_metadata_retrieval(self):
        """메타데이터 조회"""

        class TestClass(metaclass=IntrospectionMeta):
            def test_method(self):
                pass

        metadata = IntrospectionMeta.get_metadata(TestClass)
        assert metadata["name"] == "TestClass"
        assert "test_method" in metadata["methods"]


