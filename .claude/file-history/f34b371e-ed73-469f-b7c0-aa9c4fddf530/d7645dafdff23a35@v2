class TestMethodInjectionMeta:
    """메서드 주입 메타클래스 테스트"""

    def test_to_dict_method(self):
        """to_dict 메서드 주입"""

        class Person(metaclass=MethodInjectionMeta):
            def __init__(self, name, age):
                self.name = name
                self.age = age

        person = Person("Alice", 30)
        data = person.to_dict()

        assert data["name"] == "Alice"
        assert data["age"] == 30

    def test_to_str_method(self):
        """__str__ 메서드 주입"""

        class User(metaclass=MethodInjectionMeta):
            def __init__(self, username):
                self.username = username

        user = User("bob")
        s = str(user)

        assert "User" in s
        assert "bob" in s


