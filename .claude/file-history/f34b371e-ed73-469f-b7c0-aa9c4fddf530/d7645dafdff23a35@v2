class TestORMMeta:
    """ORM 메타클래스 테스트"""

    def test_orm_class_creation(self):
        """ORM 클래스 생성"""

        class User(metaclass=ORMMeta):
            name = Field(str)
            age = Field(int)

        assert hasattr(User, "__fields__")
        assert "name" in User.__fields__

    def test_orm_instance_creation(self):
        """ORM 인스턴스 생성"""

        class Product(metaclass=ORMMeta):
            title = Field(str)
            price = Field(float)

        product = Product(title="Book", price=9.99)
        assert product.title == "Book"
        assert product.price == 9.99

    def test_orm_missing_field(self):
        """필수 필드 누락"""

        class Item(metaclass=ORMMeta):
            name = Field(str)

        with pytest.raises(TypeError):
            Item()


