class TestRegistryMeta:
    """레지스트리 메타클래스 테스트"""

    def test_auto_registration(self):
        """자동 등록"""

        class Animal(metaclass=RegistryMeta):
            pass

        class Dog(Animal):
            pass

        registry = RegistryMeta.get_registry()
        assert "Dog" in registry

    def test_get_class_from_registry(self):
        """레지스트리에서 클래스 조회"""

        class Animal(metaclass=RegistryMeta):
            pass

        class Cat(Animal):
            pass

        cls = RegistryMeta.get_class("Cat")
        assert cls is Cat

    def test_list_plugins(self):
        """등록된 클래스 나열"""

        class Plugin(metaclass=RegistryMeta):
            pass

        class Plugin1(Plugin):
            pass

        class Plugin2(Plugin):
            pass

        registry = RegistryMeta.get_registry()
        assert len(registry) >= 2


