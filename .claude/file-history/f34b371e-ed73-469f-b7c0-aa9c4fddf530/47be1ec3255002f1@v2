{% extends "base.html" %}

{% block title %}대시보드 - Gogs{% endblock %}

{% block content %}
<div class="card">
    <h2>📊 대시보드</h2>
    <p style="color: #999; margin: 10px 0;">{{ researcher.name }}님 환영합니다!</p>

    <div class="grid" style="margin-top: 20px;">
        <div class="stat-box">
            <div class="number">{{ stats.researcher_count }}</div>
            <div class="label">📌 총 연구자</div>
        </div>
        <div class="stat-box">
            <div class="number">{{ stats.experiment_count }}</div>
            <div class="label">🧪 총 실험</div>
        </div>
        <div class="stat-box">
            <div class="number">{{ stats.status_counts.get('completed', 0) }}</div>
            <div class="label">✅ 완료된 실험</div>
        </div>
        <div class="stat-box">
            <div class="number">{{ "%.1f"|format(stats.avg_result or 0) }}</div>
            <div class="label">📈 평균 점수</div>
        </div>
    </div>
</div>

<div class="grid">
    <div class="card">
        <h2>🏆 상위 실험</h2>
        {% if top_experiments %}
            <table>
                <thead>
                    <tr>
                        <th>제목</th>
                        <th>점수</th>
                        <th>상태</th>
                    </tr>
                </thead>
                <tbody>
                    {% for exp in top_experiments[:5] %}
                    <tr>
                        <td>{{ exp.subject }}</td>
                        <td>
                            {% if exp.result %}
                                <strong>{{ "%.1f"|format(exp.result) }} 점</strong>
                            {% else %}
                                <span style="color: #999;">-</span>
                            {% endif %}
                        </td>
                        <td>
                            <span class="badge badge-{{ exp.status }}">{{ exp.status }}</span>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% else %}
            <p style="color: #999; text-align: center; padding: 20px;">완료된 실험이 없습니다</p>
        {% endif %}
    </div>

    <div class="card">
        <h2>📊 상태 분포</h2>
        <div style="padding: 20px;">
            {% for status, count in stats.status_counts.items() %}
            <div style="margin: 15px 0;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                    <span style="font-weight: 500; text-transform: capitalize;">{{ status }}</span>
                    <strong>{{ count }} 개</strong>
                </div>
                <div style="background: #e2e8f0; height: 8px; border-radius: 4px; overflow: hidden;">
                    <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); height: 100%; width: {{ (count / stats.experiment_count * 100) if stats.experiment_count > 0 else 0 }}%;"></div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</div>

<div class="card">
    <h2>📌 빠른 작업</h2>
    <div style="display: flex; gap: 10px; flex-wrap: wrap;">
        <a href="{{ url_for('researchers') }}" class="btn btn-primary">👥 연구자 관리</a>
        <a href="{{ url_for('experiments') }}" class="btn btn-primary">🧪 실험 관리</a>
        <button class="btn btn-secondary" onclick="createExperiment()">➕ 새 실험 생성</button>
    </div>
</div>

<!-- 모달 -->
<div id="experimentModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
    <div class="card" style="width: 100%; max-width: 500px; margin: 0;">
        <h2>새 실험 생성</h2>
        <form id="experimentForm">
            <div class="form-group">
                <label for="expSubject">제목 *</label>
                <input type="text" id="expSubject" required>
            </div>
            <div class="form-group">
                <label for="expDescription">설명</label>
                <textarea id="expDescription"></textarea>
            </div>
            <div style="display: flex; gap: 10px;">
                <button type="submit" class="btn btn-primary" style="flex: 1;">생성</button>
                <button type="button" class="btn btn-secondary" style="flex: 1;" onclick="closeModal()">취소</button>
            </div>
        </form>
    </div>
</div>

<script>
    function createExperiment() {
        document.getElementById('experimentModal').style.display = 'flex';
    }

    function closeModal() {
        document.getElementById('experimentModal').style.display = 'none';
    }

    document.getElementById('experimentForm').addEventListener('submit', async (e) => {
        e.preventDefault();

        const subject = document.getElementById('expSubject').value;
        const description = document.getElementById('expDescription').value;
        const researcherId = {{ researcher.id }};

        try {
            const response = await fetch('/api/v1/experiments', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    researcher_id: researcherId,
                    subject: subject,
                    description: description,
                    status: 'pending'
                })
            });

            const data = await response.json();

            if (data.success) {
                alert('실험이 생성되었습니다!');
                closeModal();
                location.reload();
            } else {
                alert('오류: ' + data.message);
            }
        } catch (error) {
            alert('오류가 발생했습니다');
        }
    });
</script>
{% endblock %}
