## 동시성: 락 관리

### 락 컨텍스트 매니저

```python
import threading

class LockManager:
    def __init__(self, lock, name='락'):
        self.lock = lock
        self.name = name

    def __enter__(self):
        print(f"🔐 [{self.name}] 락 획득 시도...")
        self.lock.acquire()
        print(f"🔓 [{self.name}] 락 획득")
        return self

    def __exit__(self, exc_type, exc_val, exc_tb):
        self.lock.release()
        print(f"🔓 [{self.name}] 락 해제")
        return False

# 사용: 스레드 안전 보장
lock = threading.Lock()

def critical_section():
    with LockManager(lock, "중요 섹션"):
        # 이 블록 내에서는 다른 스레드가 진입 불가
        print("  임계 영역 실행 중")
```

