## 파일 처리

### 커스텀 파일 매니저

```python
class FileManager:
    def __init__(self, filepath, mode='r'):
        self.filepath = filepath
        self.mode = mode
        self.file = None

    def __enter__(self):
        self.file = open(self.filepath, self.mode)
        print(f"📂 파일 열음: {self.filepath}")
        return self.file

    def __exit__(self, exc_type, exc_val, exc_tb):
        if self.file:
            self.file.close()
            print(f"📂 파일 닫음: {self.filepath}")

        if exc_type:
            print(f"⚠️ 파일 처리 중 오류: {exc_val}")

        return False

# 사용
with FileManager('data.txt', 'r') as f:
    content = f.read()
    print(content)
```

