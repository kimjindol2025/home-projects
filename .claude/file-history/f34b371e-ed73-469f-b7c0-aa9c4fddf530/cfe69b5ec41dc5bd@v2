## 성능 측정

### 타이머 컨텍스트 매니저

```python
import time

class Timer:
    def __init__(self, name='작업'):
        self.name = name
        self.start = None

    def __enter__(self):
        self.start = time.time()
        print(f"⏱️ [{self.name}] 시작...")
        return self

    def __exit__(self, exc_type, exc_val, exc_tb):
        elapsed = time.time() - self.start

        if exc_type:
            print(f"❌ [{self.name}] 실패 ({elapsed:.4f}초)")
        else:
            print(f"✅ [{self.name}] 완료 ({elapsed:.4f}초)")

        return False

# 사용
with Timer('데이터 처리') as timer:
    time.sleep(1)
    # 자동으로 시간 측정 및 출력
```

