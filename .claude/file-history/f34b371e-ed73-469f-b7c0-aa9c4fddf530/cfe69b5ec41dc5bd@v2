## 데이터베이스 연결

### 데이터베이스 커넥션 매니저

```python
class DatabaseConnection:
    def __init__(self, db_url):
        self.db_url = db_url
        self.conn = None

    def __enter__(self):
        self.conn = self.connect()
        print(f"🔌 DB 연결: {self.db_url}")
        return self

    def __exit__(self, exc_type, exc_val, exc_tb):
        if self.conn:
            if exc_type:
                self.conn.rollback()  # 롤백
                print(f"⚠️ 트랜잭션 롤백: {exc_val}")
            else:
                self.conn.commit()  # 커밋
                print("✅ 트랜잭션 커밋")

            self.conn.close()
            print("🔌 DB 연결 해제")

        return False

    def execute(self, query):
        return f"Result: {query}"

# 사용: 자동 커밋/롤백
try:
    with DatabaseConnection('localhost/mydb') as db:
        result = db.execute('SELECT * FROM users')
        print(result)
        # 에러 발생 시 자동 롤백, 정상이면 자동 커밋
except Exception as e:
    print(f"에러: {e}")
```

