def demonstrate_pipeline():
    """Pipeline 패턴 시연"""
    print("\n" + "="*70)
    print("1️⃣  Pipeline Pattern 시연")
    print("="*70)

    # 간단한 파이프라인
    result = (
        Pipeline(10)
        .pipe(lambda x: x * 2)
        .pipe(lambda x: x + 5)
        .pipe(lambda x: x / 3)
        .execute()
    )
    print(f"✅ 계산 결과: {result:.2f}")

    # 데이터 변환 파이프라인
    experiments = [
        {'id': 1, 'status': 'completed', 'result': 95},
        {'id': 2, 'status': 'completed', 'result': 88},
        {'id': 3, 'status': 'completed', 'result': 92},
        {'id': 4, 'status': 'completed', 'result': 75},
        {'id': 5, 'status': 'pending', 'result': 50},
    ]

    top_experiments = DataTransformationPipeline.process(experiments)
    print(f"\n✅ 상위 성적 실험들:")
    for exp in top_experiments:
        print(f"   - 점수: {exp['result']}, 등급: {exp['grade']}")

    print("\n💡 핵심: Pipeline을 통해 복잡한 변환을 단계별로 명시!")


def demonstrate_specification():
    """Specification 패턴 시연"""
    print("\n" + "="*70)
    print("2️⃣  Specification Pattern 시연")
    print("="*70)

    experiments = [
        {'id': 1, 'researcher_id': 1, 'status': 'completed', 'result': 95},
        {'id': 2, 'researcher_id': 2, 'status': 'completed', 'result': 75},
        {'id': 3, 'researcher_id': 1, 'status': 'pending', 'result': 50},
        {'id': 4, 'researcher_id': 3, 'status': 'completed', 'result': 88},
    ]

    repo = SpecificationRepository(experiments)

    # 1. 간단한 조건
    print("\n✅ 완료된 실험:")
    completed_spec = CompletedExperimentSpec()
    for exp in repo.find_all_matching(completed_spec):
        print(f"   - {exp['id']}: 점수 {exp['result']}")

    # 2. AND 조건
    print("\n✅ 완료되고 점수 80 이상:")
    high_score_spec = HighScoreSpec(80)
    combined = completed_spec.and_spec(high_score_spec)
    for exp in repo.find_all_matching(combined):
        print(f"   - {exp['id']}: 점수 {exp['result']}")

    # 3. OR 조건
    print("\n✅ (완료되고 점수 90 이상) 또는 (연구자 1번):")
    researcher_1_spec = SpecificResearcherSpec(1)
    high_complete_spec = completed_spec.and_spec(HighScoreSpec(90))
    complex_spec = high_complete_spec.or_spec(researcher_1_spec)
    for exp in repo.find_all_matching(complex_spec):
        print(f"   - {exp['id']}: 점수 {exp['result']}")

    print("\n💡 핵심: Specification을 조합하면 복잡한 조건을 우아하게 표현!")


def demonstrate_result_monad():
    """Result 모나드 시연"""
    print("\n" + "="*70)
    print("3️⃣  Result Monad 시연")
    print("="*70)

    # 성공 케이스: 95 → A → 훌륭합니다!
    print("✅ 성공 케이스 (점수 95):")
    result = (
        validate_score(95)
        .flat_map(calculate_grade)
        .flat_map(get_compliment)
    )
    print(f"   결과: {result.get()}")

    # 실패 케이스: 잘못된 점수
    print("\n❌ 실패 케이스 (점수 150):")
    result = (
        validate_score(150)
        .flat_map(calculate_grade)
        .flat_map(get_compliment)
    )
    print(f"   에러: {result.get_error()}")
    print(f"   복구: {result.get_or_recover(lambda err: '다시 시도해주세요')}")

    # map을 사용한 체이닝
    print("\n✅ map 사용:")
    result = validate_score(88).map(lambda s: f"점수: {s}점")
    print(f"   {result.get()}")

    print("\n💡 핵심: Result로 에러 처리를 타입 안전하고 명시적으로!")


def demonstrate_decorator_composition():
    """Decorator 조합 시연"""
    print("\n" + "="*70)
    print("4️⃣  Decorator Composition 시연")
    print("="*70)

    # 첫 번째 호출 (실제 계산)
    print("✅ 첫 번째 호출:")
    result1 = expensive_calculation(5)

    # 두 번째 호출 (캐시에서)
    print("\n✅ 두 번째 호출 (캐시 사용):")
    result2 = expensive_calculation(5)

    print(f"\n결과: {result1} == {result2}")
    print("\n💡 핵심: 데코레이터를 조합하여 횡단 관심사(caching, logging)를 분리!")


if __name__ == '__main__':
    demonstrate_pipeline()
    demonstrate_specification()
    demonstrate_result_monad()
    demonstrate_decorator_composition()
    print("\n" + "="*70)
    print("✅ Functional Patterns 시연 완료!")
    print("="*70)
