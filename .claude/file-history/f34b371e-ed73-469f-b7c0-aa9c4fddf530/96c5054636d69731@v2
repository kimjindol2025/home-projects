"""
v6.1 Design Patterns Advanced - Functional Programming Patterns
===============================================================

함수형 프로그래밍의 패턴들:
1. Pipeline Pattern   — 함수 합성으로 데이터 변환
2. Specification Pattern — 복잡한 조건을 객체로 캡슐화
3. Result Monad      — 에러 처리를 타입 안전하게
4. Decorator Composition — 고차 함수의 조합

철학: "데이터의 변환 과정을 명시적으로 표현한다"
       → 부작용 최소화, 테스트 용이
"""

from abc import ABC, abstractmethod
from typing import Any, Callable, List, Optional, Dict, TypeVar, Generic
from dataclasses import dataclass
from functools import wraps

T = TypeVar('T')
U = TypeVar('U')


# =============================================================================
# 1. Pipeline Pattern — 함수 합성
# =============================================================================

class Pipeline:
    """
    Pipeline 패턴: 데이터를 일련의 변환 함수를 통해 전달

    예:
    Pipeline(10)
        .pipe(lambda x: x * 2)        # 20
        .pipe(lambda x: x + 5)        # 25
        .pipe(lambda x: str(x))       # "25"
        .execute()                     # "25"
    """

    def __init__(self, value: Any):
        self._value = value

    def pipe(self, func: Callable[[Any], Any]) -> 'Pipeline':
        """
        함수를 통해 현재 값을 변환하고 새로운 Pipeline 반환

        이를 통해 메서드 체이닝이 가능해짐
        """
        return Pipeline(func(self._value))

    def execute(self) -> Any:
        """최종 값 반환"""
        return self._value

    def __repr__(self) -> str:
        return f"Pipeline({self._value})"


class DataTransformationPipeline:
    """
    실제 데이터 변환 파이프라인
    실험 데이터를 처리하는 예제
    """

    @staticmethod
    def filter_experiments(experiments: List[Dict], status: str) -> List[Dict]:
        """상태별 필터링"""
        return [e for e in experiments if e.get('status') == status]

    @staticmethod
    def add_grade(experiments: List[Dict]) -> List[Dict]:
        """점수에 따라 등급 추가"""
        for exp in experiments:
            score = exp.get('result', 0)
            if score >= 90:
                exp['grade'] = 'A'
            elif score >= 80:
                exp['grade'] = 'B'
            elif score >= 70:
                exp['grade'] = 'C'
            else:
                exp['grade'] = 'F'
        return experiments

    @staticmethod
    def sort_by_score(experiments: List[Dict]) -> List[Dict]:
        """점수순 정렬"""
        return sorted(experiments, key=lambda x: x.get('result', 0), reverse=True)

    @staticmethod
    def limit(experiments: List[Dict], count: int) -> List[Dict]:
        """상위 N개만 선택"""
        return experiments[:count]

    @classmethod
    def process(cls, experiments: List[Dict]) -> List[Dict]:
        """
        전체 파이프라인 실행
        1. 완료된 실험만 필터링
        2. 등급 추가
        3. 점수순 정렬
        4. 상위 5개만 선택
        """
        return (
            Pipeline(experiments)
            .pipe(lambda e: cls.filter_experiments(e, 'completed'))
            .pipe(cls.add_grade)
            .pipe(cls.sort_by_score)
            .pipe(lambda e: cls.limit(e, 5))
            .execute()
        )


# =============================================================================
# 2. Specification Pattern — 비즈니스 조건 캡슐화
# =============================================================================

class Specification(ABC):
    """
    Specification 패턴: 비즈니스 조건을 객체로 표현

    복잡한 조건: if (status == 'completed' AND score >= 80) OR researcher_id == 1
    → 이를 조합 가능한 Spec 객체로 표현
    """

    @abstractmethod
    def is_satisfied_by(self, candidate: Any) -> bool:
        """후보 객체가 조건을 만족하는지 확인"""
        pass

    def and_spec(self, other: 'Specification') -> 'Specification':
        """AND 조합"""
        return AndSpecification(self, other)

    def or_spec(self, other: 'Specification') -> 'Specification':
        """OR 조합"""
        return OrSpecification(self, other)

    def not_spec(self) -> 'Specification':
        """NOT 반전"""
        return NotSpecification(self)


class CompletedExperimentSpec(Specification):
    """완료된 실험"""
    def is_satisfied_by(self, candidate: Dict) -> bool:
        return candidate.get('status') == 'completed'


class HighScoreSpec(Specification):
    """높은 점수 (기준점 이상)"""
    def __init__(self, min_score: float):
        self.min_score = min_score

    def is_satisfied_by(self, candidate: Dict) -> bool:
        return (candidate.get('result') or 0) >= self.min_score


class SpecificResearcherSpec(Specification):
    """특정 연구자"""
    def __init__(self, researcher_id: int):
        self.researcher_id = researcher_id

    def is_satisfied_by(self, candidate: Dict) -> bool:
        return candidate.get('researcher_id') == self.researcher_id


class AndSpecification(Specification):
    """AND 조합 (양쪽 다 만족)"""
    def __init__(self, left: Specification, right: Specification):
        self.left = left
        self.right = right

    def is_satisfied_by(self, candidate: Any) -> bool:
        return (self.left.is_satisfied_by(candidate) and
                self.right.is_satisfied_by(candidate))


class OrSpecification(Specification):
    """OR 조합 (둘 중 하나 만족)"""
    def __init__(self, left: Specification, right: Specification):
        self.left = left
        self.right = right

    def is_satisfied_by(self, candidate: Any) -> bool:
        return (self.left.is_satisfied_by(candidate) or
                self.right.is_satisfied_by(candidate))


class NotSpecification(Specification):
    """NOT 반전"""
    def __init__(self, spec: Specification):
        self.spec = spec

    def is_satisfied_by(self, candidate: Any) -> bool:
        return not self.spec.is_satisfied_by(candidate)


class SpecificationRepository:
    """Specification을 사용한 저장소 조회"""
    def __init__(self, data: List[Dict]):
        self.data = data

    def find_all_matching(self, spec: Specification) -> List[Dict]:
        """Specification을 만족하는 데이터 조회"""
        return [item for item in self.data if spec.is_satisfied_by(item)]


# =============================================================================
# 3. Result Monad — 에러 처리
# =============================================================================

@dataclass
class Success:
    """성공 결과"""
    value: Any

    def __repr__(self) -> str:
        return f"Success({self.value})"


@dataclass
class Failure:
    """실패 결과"""
    error: str

    def __repr__(self) -> str:
        return f"Failure({self.error})"


class Result(Generic[T]):
    """
    Result 모나드: 에러 처리를 타입 안전하게

    일반 함수:
    def divide(a, b):
        if b == 0:
            return None  # 에러를 모르게 됨
        return a / b

    Result 모나드:
    def divide(a, b) -> Result:
        return Result.ok(a / b) if b != 0 else Result.err("0으로 나눌 수 없음")
    """

    def __init__(self, data):
        self._data = data

    @classmethod
    def ok(cls, value: T) -> 'Result[T]':
        """성공 결과 생성"""
        return cls(Success(value))

    @classmethod
    def err(cls, error: str) -> 'Result':
        """실패 결과 생성"""
        return cls(Failure(error))

    def is_success(self) -> bool:
        """성공 여부"""
        return isinstance(self._data, Success)

    def is_failure(self) -> bool:
        """실패 여부"""
        return isinstance(self._data, Failure)

    def get(self) -> T:
        """값 추출 (성공 시에만 호출)"""
        if self.is_success():
            return self._data.value
        raise ValueError(f"실패: {self._data.error}")

    def get_error(self) -> str:
        """에러 메시지 추출"""
        if self.is_failure():
            return self._data.error
        return ""

    def map(self, func: Callable[[T], U]) -> 'Result[U]':
        """값을 변환 (성공 시에만 적용, 실패는 그대로 전파)"""
        if self.is_success():
            try:
                return Result.ok(func(self._data.value))
            except Exception as e:
                return Result.err(str(e))
        return Result.err(self._data.error)

    def flat_map(self, func: Callable[[T], 'Result[U]']) -> 'Result[U]':
        """Result를 반환하는 함수 적용"""
        if self.is_success():
            return func(self._data.value)
        return Result.err(self._data.error)

    def get_or_else(self, default: T) -> T:
        """값 또는 기본값"""
        return self._data.value if self.is_success() else default

    def get_or_recover(self, recovery_func: Callable[[str], T]) -> T:
        """값 또는 복구 함수 적용"""
        if self.is_success():
            return self._data.value
        return recovery_func(self._data.error)

    def __repr__(self) -> str:
        return str(self._data)


# =============================================================================
# 실전 예제: Result Monad 활용
# =============================================================================

def validate_score(score: float) -> Result[float]:
    """점수 검증"""
    if isinstance(score, (int, float)) and 0 <= score <= 100:
        return Result.ok(score)
    return Result.err(f"유효하지 않은 점수: {score}")


def calculate_grade(score: float) -> Result[str]:
    """점수 → 등급 변환"""
    if score >= 90:
        return Result.ok('A')
    elif score >= 80:
        return Result.ok('B')
    elif score >= 70:
        return Result.ok('C')
    else:
        return Result.ok('F')


def get_compliment(grade: str) -> Result[str]:
    """등급 → 칭찬"""
    compliments = {
        'A': '훌륭합니다!',
        'B': '잘하셨습니다!',
        'C': '괜찮습니다',
        'F': '노력이 필요합니다'
    }
    if grade in compliments:
        return Result.ok(compliments[grade])
    return Result.err(f"알 수 없는 등급: {grade}")


# =============================================================================
# 4. Decorator Composition — 고차 함수의 조합
# =============================================================================

def memoize(func: Callable) -> Callable:
    """
    결과 캐싱 데코레이터

    비싼 계산을 반복하지 않기 위해 결과를 저장
    """
    cache = {}

    @wraps(func)
    def wrapper(*args):
        if args not in cache:
            cache[args] = func(*args)
        return cache[args]

    return wrapper


def validate_input(validator: Callable) -> Callable:
    """입력 검증 데코레이터"""
    def decorator(func: Callable) -> Callable:
        @wraps(func)
        def wrapper(*args, **kwargs):
            validator(*args, **kwargs)
            return func(*args, **kwargs)
        return wrapper
    return decorator


def log_execution(func: Callable) -> Callable:
    """실행 로깅 데코레이터"""
    @wraps(func)
    def wrapper(*args, **kwargs):
        print(f"🔄 실행: {func.__name__}{args}")
        result = func(*args, **kwargs)
        print(f"✅ 결과: {result}")
        return result
    return wrapper


# 데코레이터 조합 예제
@memoize
@log_execution
def expensive_calculation(n: int) -> int:
    """비싼 계산 함수"""
    print(f"   (실제 계산 중... n={n})")
    return n * n


