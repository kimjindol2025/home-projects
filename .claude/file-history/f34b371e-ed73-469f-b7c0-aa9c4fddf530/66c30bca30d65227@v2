class TestGogsStorage:
    """GogsStorage 클래스 테스트"""

    def test_initialization(self):
        """저장소 초기화"""
        storage = GogsStorage("테스트 사용자", capacity=10)
        assert storage.owner == "테스트 사용자"
        assert storage.capacity == 10
        assert storage.get_size() == 0

    def test_save_single_data(self):
        """단일 데이터 저장"""
        storage = GogsStorage("사용자", capacity=5)
        result = storage.save("데이터1")
        assert result is True
        assert storage.get_size() == 1

    def test_save_multiple_data(self):
        """여러 데이터 저장"""
        storage = GogsStorage("사용자", capacity=5)
        for i in range(3):
            result = storage.save(f"데이터{i+1}")
            assert result is True
        assert storage.get_size() == 3

    def test_save_exceeds_capacity(self):
        """용량 초과 테스트"""
        storage = GogsStorage("사용자", capacity=2)
        storage.save("데이터1")
        storage.save("데이터2")
        result = storage.save("데이터3")  # 용량 초과
        assert result is False
        assert storage.get_size() == 2

    def test_is_full(self):
        """저장소 가득 찬 상태 확인"""
        storage = GogsStorage("사용자", capacity=2)
        assert storage.is_full() is False
        storage.save("데이터1")
        assert storage.is_full() is False
        storage.save("데이터2")
        assert storage.is_full() is True

    def test_is_empty(self):
        """저장소 비어있는 상태 확인"""
        storage = GogsStorage("사용자", capacity=5)
        assert storage.is_empty() is True
        storage.save("데이터1")
        assert storage.is_empty() is False

    def test_clear(self):
        """저장소 비우기"""
        storage = GogsStorage("사용자", capacity=5)
        storage.save("데이터1")
        storage.save("데이터2")
        assert storage.get_size() == 2
        storage.clear()
        assert storage.get_size() == 0
        assert storage.is_empty() is True

    def test_get_statistics(self):
        """저장소 통계"""
        storage = GogsStorage("사용자", capacity=10)
        storage.save("데이터1")
        storage.save("데이터2")

        stats = storage.get_statistics()
        assert stats["owner"] == "사용자"
        assert stats["capacity"] == 10
        assert stats["current_size"] == 2
        assert stats["usage_percent"] == 20.0

    def test_instance_independence(self):
        """인스턴스 독립성: 각 저장소가 독립적으로 데이터 유지"""
        storage_a = GogsStorage("사용자A", capacity=5)
        storage_b = GogsStorage("사용자B", capacity=5)

        storage_a.save("A의 데이터1")
        storage_a.save("A의 데이터2")
        storage_b.save("B의 데이터1")

        assert storage_a.get_size() == 2
        assert storage_b.get_size() == 1
        assert storage_a.stored_data != storage_b.stored_data


