class TestClassVsInstanceVariables:
    """클래스 변수 vs 인스턴스 변수 테스트"""

    def test_class_variable_shared(self):
        """클래스 변수는 모든 인스턴스가 공유"""
        # 처음에 클래스 변수 초기화
        StorageWithStats.total_instances = 0
        StorageWithStats.total_data_saved = 0

        s1 = StorageWithStats("사용자1", capacity=5)
        s2 = StorageWithStats("사용자2", capacity=5)
        s3 = StorageWithStats("사용자3", capacity=5)

        assert StorageWithStats.get_total_instances() == 3

    def test_instance_variable_independent(self):
        """인스턴스 변수는 각 인스턴스별 독립"""
        StorageWithStats.total_instances = 0
        StorageWithStats.total_data_saved = 0

        s1 = StorageWithStats("사용자1", capacity=5)
        s2 = StorageWithStats("사용자2", capacity=5)

        s1.save("데이터1")
        s1.save("데이터2")
        s2.save("데이터3")

        assert s1.get_instance_saved() == 2
        assert s2.get_instance_saved() == 1
        assert StorageWithStats.get_total_saved() == 3

    def test_total_data_saved(self):
        """전체 저장된 데이터 수 (클래스 변수)"""
        StorageWithStats.total_instances = 0
        StorageWithStats.total_data_saved = 0

        s1 = StorageWithStats("사용자1", capacity=10)
        s1.save("데이터1")
        s1.save("데이터2")

        assert StorageWithStats.get_total_saved() == 2


