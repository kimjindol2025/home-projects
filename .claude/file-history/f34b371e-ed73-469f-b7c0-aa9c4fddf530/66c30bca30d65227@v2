class TestMagicMethods:
    """매직 메서드 테스트"""

    def test_str_representation(self):
        """__str__: print() 출력"""
        storage = SmartStorage("테스트 저장소", capacity=5)
        storage.save("데이터1")
        result = str(storage)
        assert "테스트 저장소" in result
        assert "1/5" in result

    def test_repr_representation(self):
        """__repr__: 개발자용 표현"""
        storage = SmartStorage("저장소", capacity=5)
        result = repr(storage)
        assert "SmartStorage" in result
        assert "저장소" in result

    def test_len(self):
        """__len__: len() 지원"""
        storage = SmartStorage("저장소", capacity=5)
        storage.save("데이터1")
        storage.save("데이터2")
        assert len(storage) == 2

    def test_getitem(self):
        """__getitem__: [] 연산자 지원"""
        storage = SmartStorage("저장소", capacity=5)
        storage.save("데이터1")
        storage.save("데이터2")
        assert storage[0] == "데이터1"
        assert storage[1] == "데이터2"
        assert storage[-1] == "데이터2"

    def test_contains(self):
        """__contains__: in 연산자 지원"""
        storage = SmartStorage("저장소", capacity=5)
        storage.save("데이터1")
        storage.save("데이터2")
        assert "데이터1" in storage
        assert "데이터2" in storage
        assert "데이터3" not in storage

    def test_equality(self):
        """__eq__: == 연산자 지원"""
        storage1 = SmartStorage("저장소1", capacity=5)
        storage2 = SmartStorage("저장소2", capacity=5)

        storage1.save("데이터1")
        storage2.save("데이터1")

        assert storage1 == storage2

    def test_iter(self):
        """__iter__: for 루프 지원"""
        storage = SmartStorage("저장소", capacity=5)
        storage.save("데이터1")
        storage.save("데이터2")
        storage.save("데이터3")

        items = [item for item in storage]
        assert items == ["데이터1", "데이터2", "데이터3"]


