class TestAdvancedStorage:
    """AdvancedStorage 클래스 테스트"""

    def test_inheritance(self):
        """상속: AdvancedStorage는 GogsStorage의 하위 클래스"""
        storage = AdvancedStorage("사용자", capacity=10)
        assert isinstance(storage, GogsStorage)
        assert hasattr(storage, 'save')
        assert hasattr(storage, 'get_size')

    def test_save_with_category(self):
        """카테고리와 함께 저장"""
        storage = AdvancedStorage("사용자", capacity=10)
        result = storage.save_with_category("데이터1", "카테고리A")
        assert result is True
        assert len(storage.categories["카테고리A"]) == 1

    def test_multiple_categories(self):
        """여러 카테고리 관리"""
        storage = AdvancedStorage("사용자", capacity=10)
        storage.save_with_category("데이터1", "카테고리A")
        storage.save_with_category("데이터2", "카테고리A")
        storage.save_with_category("데이터3", "카테고리B")

        assert len(storage.categories["카테고리A"]) == 2
        assert len(storage.categories["카테고리B"]) == 1

    def test_search(self):
        """키워드 검색"""
        storage = AdvancedStorage("사용자", capacity=10)
        storage.save_with_category("Python 학습", "프로그래밍")
        storage.save_with_category("JavaScript 학습", "프로그래밍")
        storage.save_with_category("선형대수", "수학")

        results = storage.search("학습")
        assert len(results) == 2

        results = storage.search("Python")
        assert len(results) == 1

    def test_get_category_data(self):
        """카테고리별 데이터 조회"""
        storage = AdvancedStorage("사용자", capacity=10)
        storage.save_with_category("데이터1", "A")
        storage.save_with_category("데이터2", "A")
        storage.save_with_category("데이터3", "B")

        data_a = storage.get_category_data("A")
        assert len(data_a) == 2
        assert "데이터1" in data_a

    def test_history_tracking(self):
        """작업 히스토리 추적"""
        storage = AdvancedStorage("사용자", capacity=10)
        storage.save_with_category("데이터1", "카테고리A")
        storage.save_with_category("데이터2", "카테고리B")

        assert len(storage.history) == 2
        assert storage.history[0]["data"] == "데이터1"
        assert storage.history[1]["data"] == "데이터2"


