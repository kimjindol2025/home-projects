class TestEdgeCases:
    """엣지 케이스"""

    def test_zero_capacity(self):
        """용량이 0인 저장소"""
        storage = GogsStorage("저장소", capacity=0)
        result = storage.save("데이터")
        assert result is False

    def test_single_capacity(self):
        """용량이 1인 저장소"""
        storage = GogsStorage("저장소", capacity=1)
        assert storage.save("데이터1") is True
        assert storage.save("데이터2") is False

    def test_large_capacity(self):
        """큰 용량의 저장소"""
        storage = GogsStorage("저장소", capacity=1000)
        for i in range(100):
            result = storage.save(f"데이터{i}")
            assert result is True
        assert storage.get_size() == 100

    def test_none_data(self):
        """None 값 저장"""
        storage = GogsStorage("저장소", capacity=5)
        result = storage.save(None)
        assert result is True
        assert storage.get_size() == 1

    def test_mixed_data_types(self):
        """혼합 데이터 타입"""
        storage = GogsStorage("저장소", capacity=5)
        storage.save(42)
        storage.save("문자열")
        storage.save([1, 2, 3])
        storage.save({"키": "값"})
        assert storage.get_size() == 4


