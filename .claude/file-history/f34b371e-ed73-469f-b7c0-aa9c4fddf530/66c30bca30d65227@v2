class TestEncapsulation:
    """캡슐화 테스트"""

    def test_save_method(self):
        """save() 메서드로만 데이터 저장"""
        storage = SecureStorage("저장소", capacity=5)
        result = storage.save("데이터1")
        assert result is True
        assert storage.get_size() == 1

    def test_get_data_returns_copy(self):
        """get_data()는 복사본 반환 (원본 보호)"""
        storage = SecureStorage("저장소", capacity=5)
        storage.save("데이터1")
        storage.save("데이터2")

        data = storage.get_data()
        assert len(data) == 2

        # 반환된 복사본을 수정해도 원본은 영향 없음
        data.append("조작된 데이터")
        assert storage.get_size() == 2  # 원본은 여전히 2개

    def test_capacity_protection(self):
        """용량은 get_capacity()로만 조회 가능"""
        storage = SecureStorage("저장소", capacity=10)
        assert storage.get_capacity() == 10

    def test_access_log(self):
        """접근 기록 조회"""
        storage = SecureStorage("저장소", capacity=5)
        storage.save("데이터1")
        storage.get_data()
        storage.save("데이터2")

        logs = storage.get_access_log()
        assert len(logs) >= 3  # save, read, save

    def test_cannot_modify_directly(self):
        """직접 수정 방지 (private 속성)"""
        storage = SecureStorage("저장소", capacity=5)
        storage.save("데이터1")

        # private 속성은 접근 불가능 (관례)
        # storage.__stored_data는 이름 맹글링으로 인해 직접 접근 불가
        # 따라서 get_data()를 통해서만 조회 가능
        data = storage.get_data()
        assert len(data) == 1


