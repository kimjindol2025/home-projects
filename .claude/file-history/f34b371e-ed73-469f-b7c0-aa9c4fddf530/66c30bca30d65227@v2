class TestIntegration:
    """통합 테스트"""

    def test_storage_workflow(self):
        """저장소 전체 워크플로우"""
        storage = GogsStorage("사용자", capacity=5)

        # 저장
        assert storage.save("데이터1") is True
        assert storage.save("데이터2") is True
        assert storage.save("데이터3") is True

        # 조회
        assert storage.get_size() == 3
        assert storage.is_empty() is False
        assert storage.is_full() is False

        # 통계
        stats = storage.get_statistics()
        assert stats["current_size"] == 3
        assert stats["usage_percent"] == 60.0

    def test_advanced_workflow(self):
        """고급 저장소 워크플로우"""
        storage = AdvancedStorage("사용자", capacity=10)

        # 카테고리별 저장
        storage.save_with_category("Python 1강", "프로그래밍")
        storage.save_with_category("Python 2강", "프로그래밍")
        storage.save_with_category("선형대수", "수학")

        # 검색
        results = storage.search("Python")
        assert len(results) == 2

        # 카테고리 조회
        prog = storage.get_category_data("프로그래밍")
        assert len(prog) == 2

    def test_multiple_storages_independence(self):
        """여러 저장소의 완전한 독립성"""
        s1 = GogsStorage("사용자1", capacity=5)
        s2 = GogsStorage("사용자2", capacity=5)
        s3 = GogsStorage("사용자3", capacity=5)

        # 각각 다른 데이터 저장
        s1.save("A-1")
        s1.save("A-2")
        s2.save("B-1")
        s3.save("C-1")
        s3.save("C-2")
        s3.save("C-3")

        # 독립 확인
        assert s1.get_size() == 2
        assert s2.get_size() == 1
        assert s3.get_size() == 3


