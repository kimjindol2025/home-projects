class TestBackupSecureGogsStorage:
    """백업 저장소 클래스 테스트 (2단계 상속)"""

    def test_is_subclass_of_secure(self):
        """BackupSecureGogsStorage는 SecureGogsStorage의 하위"""
        assert issubclass(BackupSecureGogsStorage, SecureGogsStorage)

    def test_is_subclass_of_basic(self):
        """BackupSecureGogsStorage는 GogsStorage의 하위"""
        assert issubclass(BackupSecureGogsStorage, GogsStorage)

    def test_initialization(self):
        """초기화: 부모들의 속성 모두 포함"""
        backup = BackupSecureGogsStorage("사용자", capacity=5, password="test")
        assert backup.owner == "사용자"
        assert backup.password == "test"
        assert len(backup.backup_data) == 0

    def test_auto_backup_on_save(self):
        """저장 시 자동 백업"""
        backup = BackupSecureGogsStorage("사용자", capacity=5, password="test")
        backup.save("데이터1", password="test")
        backup.save("데이터2", password="test")

        assert backup.get_size() == 2
        assert len(backup.backup_data) == 2

    def test_no_backup_on_failed_save(self):
        """저장 실패 시 백업 안 됨"""
        backup = BackupSecureGogsStorage("사용자", capacity=2, password="test")
        backup.save("데이터1", password="test")
        backup.save("데이터2", password="test")
        backup.save("데이터3", password="test")  # 용량 초과

        assert len(backup.backup_data) == 2  # 실패한 데이터는 백업 안 됨

    def test_restore_from_backup(self):
        """백업에서 복구"""
        backup = BackupSecureGogsStorage("사용자", capacity=5, password="test")
        backup.save("데이터1", password="test")
        backup.save("데이터2", password="test")

        # 데이터 삭제 (시뮬레이션)
        backup.stored_data.clear()
        assert backup.get_size() == 0

        # 백업에서 복구
        backup.restore_from_backup()
        assert backup.get_size() == 2

    def test_restore_no_backup(self):
        """백업이 없을 때 복구 불가"""
        backup = BackupSecureGogsStorage("사용자", password="test")
        result = backup.restore_from_backup()
        assert result is False

    def test_multilevel_inheritance_chain(self):
        """다단계 상속 체인: save() 호출이 부모들을 거쳐감"""
        backup = BackupSecureGogsStorage("사용자", capacity=5, password="secure")
        backup.save("중요 데이터", password="secure")

        # 모든 단계가 동작하는지 확인
        assert backup.get_size() == 1  # GogsStorage.save()
        assert len(backup.access_logs) == 1  # SecureGogsStorage.save()
        assert len(backup.backup_data) == 1  # BackupSecureGogsStorage.save()


