class TestAdvancedStorage:
    """다중 상속 저장소 테스트"""

    def test_is_instance_of_all_parents(self):
        """다중 상속: 모든 부모 클래스의 인스턴스"""
        advanced = AdvancedStorage("사용자", capacity=5)
        assert isinstance(advanced, GogsStorage)
        assert isinstance(advanced, LoggingMixin)
        assert isinstance(advanced, CacheMixin)

    def test_logging_functionality(self):
        """로깅 기능 작동"""
        advanced = AdvancedStorage("사용자", capacity=5)
        advanced.save("데이터")
        assert len(advanced.logs) > 0

    def test_cache_functionality(self):
        """캐시 기능 작동"""
        advanced = AdvancedStorage("사용자", capacity=5)
        advanced.save("데이터A")
        advanced.save("데이터B")

        # 캐시에 저장됨
        assert advanced.cache_get("data_1") == "데이터A"
        assert advanced.cache_get("data_2") == "데이터B"

    def test_combined_functionality(self):
        """통합 기능: 저장 + 로깅 + 캐시"""
        advanced = AdvancedStorage("사용자", capacity=5)
        advanced.save("테스트")

        assert advanced.get_size() == 1
        assert len(advanced.logs) > 0
        assert "data_1" in advanced.cache


