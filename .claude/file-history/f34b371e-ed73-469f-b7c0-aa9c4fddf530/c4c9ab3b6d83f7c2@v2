class TestCloudBackupSecureGogsStorage:
    """클라우드 저장소 클래스 테스트 (3단계 상속)"""

    def test_full_inheritance_chain(self):
        """완전한 상속 체인 확인"""
        assert issubclass(CloudBackupSecureGogsStorage, BackupSecureGogsStorage)
        assert issubclass(CloudBackupSecureGogsStorage, SecureGogsStorage)
        assert issubclass(CloudBackupSecureGogsStorage, GogsStorage)

    def test_initialization(self):
        """초기화: 모든 부모의 속성 포함"""
        cloud = CloudBackupSecureGogsStorage(
            "사용자",
            capacity=5,
            password="test",
            cloud_id="cloud123"
        )
        assert cloud.cloud_id == "cloud123"
        assert len(cloud.cloud_data) == 0

    def test_cloud_sync_on_save(self):
        """저장 시 클라우드 동기화"""
        cloud = CloudBackupSecureGogsStorage("사용자", capacity=5, password="test", cloud_id="id1")
        cloud.save("데이터1", password="test")
        cloud.save("데이터2", password="test")

        assert cloud.get_size() == 2
        assert len(cloud.backup_data) == 2
        assert len(cloud.cloud_data) == 2

    def test_sync_with_cloud(self):
        """명시적 클라우드 동기화"""
        cloud = CloudBackupSecureGogsStorage("사용자", password="test", cloud_id="id1")
        cloud.save("데이터", password="test")
        cloud.stored_data.append("추가 데이터")

        # 명시적 동기화
        cloud.sync_with_cloud()
        assert len(cloud.cloud_data) == 2

    def test_full_multilevel_chain(self):
        """완전한 다단계 체인: 모든 기능 동작"""
        cloud = CloudBackupSecureGogsStorage("사용자", capacity=5, password="secure", cloud_id="gogs_001")
        cloud.save("프로젝트 A", password="secure")

        # 모든 단계 확인
        assert cloud.get_size() == 1           # GogsStorage
        assert len(cloud.access_logs) == 1    # SecureGogsStorage
        assert len(cloud.backup_data) == 1    # BackupSecureGogsStorage
        assert len(cloud.cloud_data) == 1     # CloudBackupSecureGogsStorage


