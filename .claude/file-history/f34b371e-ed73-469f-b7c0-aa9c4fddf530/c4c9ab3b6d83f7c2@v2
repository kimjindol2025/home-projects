# [6] isinstance() / issubclass() 통합 테스트
# ============================================================================

class TestInheritanceValidation:
    """상속 관계 검증 테스트"""

    def test_isinstance_single_inheritance(self):
        """단일 상속의 isinstance 검증"""
        secure = SecureGogsStorage("사용자", password="test")
        assert isinstance(secure, SecureGogsStorage)
        assert isinstance(secure, GogsStorage)

    def test_isinstance_multilevel_inheritance(self):
        """다단계 상속의 isinstance 검증"""
        cloud = CloudBackupSecureGogsStorage("사용자", password="test", cloud_id="id")
        assert isinstance(cloud, CloudBackupSecureGogsStorage)
        assert isinstance(cloud, BackupSecureGogsStorage)
        assert isinstance(cloud, SecureGogsStorage)
        assert isinstance(cloud, GogsStorage)

    def test_issubclass_relationships(self):
        """issubclass 검증"""
        assert issubclass(SecureGogsStorage, GogsStorage)
        assert issubclass(BackupSecureGogsStorage, GogsStorage)
        assert issubclass(CloudBackupSecureGogsStorage, GogsStorage)
        assert not issubclass(GogsStorage, SecureGogsStorage)

    def test_object_type_checking(self):
        """type()로 정확한 클래스 확인"""
        basic = GogsStorage("기본", capacity=5)
        secure = SecureGogsStorage("보안", capacity=5, password="test")

        assert type(basic).__name__ == "GogsStorage"
        assert type(secure).__name__ == "SecureGogsStorage"


