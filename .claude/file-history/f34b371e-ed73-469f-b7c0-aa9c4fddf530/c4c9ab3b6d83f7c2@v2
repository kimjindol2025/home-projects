class TestGogsStorage:
    """기본 저장소 클래스 테스트"""

    def test_initialization(self):
        """저장소 초기화"""
        storage = GogsStorage("테스트", capacity=10)
        assert storage.owner == "테스트"
        assert storage.capacity == 10
        assert storage.get_size() == 0

    def test_save(self):
        """데이터 저장"""
        storage = GogsStorage("테스트", capacity=5)
        result = storage.save("데이터1")
        assert result is True
        assert storage.get_size() == 1

    def test_is_full(self):
        """저장소 가득 차는지 확인"""
        storage = GogsStorage("테스트", capacity=2)
        storage.save("데이터1")
        assert storage.is_full() is False
        storage.save("데이터2")
        assert storage.is_full() is True


# ============================================================================
# [2] 1단계 상속 테스트 (보안 저장소)
# ============================================================================

class TestSecureGogsStorage:
    """보안 저장소 클래스 테스트 (1단계 상속)"""

    def test_is_subclass(self):
        """SecureGogsStorage는 GogsStorage의 하위 클래스"""
        assert issubclass(SecureGogsStorage, GogsStorage)

    def test_inheritance_initialization(self):
        """상속된 초기화: 부모의 속성도 가짐"""
        secure = SecureGogsStorage("사용자", capacity=10, password="test123")
        assert secure.owner == "사용자"
        assert secure.capacity == 10
        assert secure.password == "test123"

    def test_verify_password(self):
        """비밀번호 검증"""
        secure = SecureGogsStorage("사용자", password="secret")
        assert secure.verify_password("secret") is True
        assert secure.verify_password("wrong") is False

    def test_save_with_correct_password(self):
        """정확한 비밀번호로 저장"""
        secure = SecureGogsStorage("사용자", capacity=5, password="abc123")
        result = secure.save("데이터", password="abc123")
        assert result is True
        assert secure.get_size() == 1

    def test_save_with_wrong_password(self):
        """잘못된 비밀번호로 저장 실패"""
        secure = SecureGogsStorage("사용자", capacity=5, password="abc123")
        result = secure.save("데이터", password="wrong")
        assert result is False
        assert secure.get_size() == 0

    def test_access_logs(self):
        """접근 로그 기록"""
        secure = SecureGogsStorage("사용자", capacity=5, password="test")
        secure.save("데이터", password="test")
        assert len(secure.access_logs) == 1
        assert "✅" in secure.access_logs[0]

    def test_failed_access_logs(self):
        """실패 로그 기록"""
        secure = SecureGogsStorage("사용자", password="test")
        secure.save("데이터", password="wrong")
        assert len(secure.access_logs) == 1
        assert "❌" in secure.access_logs[0]

    def test_method_overriding_works(self):
        """Method Overriding: 부모의 메서드가 덮어 써짐"""
        basic = GogsStorage("기본", capacity=5)
        secure = SecureGogsStorage("보안", capacity=5, password="test")

        # 기본 저장소: save()는 비밀번호 없음
        basic.save("데이터")
        assert basic.get_size() == 1

        # 보안 저장소: save()는 비밀번호 필요 (오버라이딩됨)
        secure.save("데이터", password="test")
        assert secure.get_size() == 1

    def test_super_call_works(self):
        """super() 호출: 부모의 메서드도 사용"""
        secure = SecureGogsStorage("사용자", capacity=5, password="test")
        # super().save()를 통해 부모의 저장 로직 사용
        result = secure.save("데이터", password="test")
        assert result is True
        assert len(secure.access_logs) > 0


