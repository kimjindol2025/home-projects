class TestRealWorldScenarios:
    """실제 사용 시나리오"""

    def test_password_protected_save(self):
        """비밀번호 보호된 저장"""
        secure = SecureGogsStorage("실험실", capacity=10, password="lab_2024")

        # 여러 저장 시도
        results = []
        results.append(secure.save("데이터1", password="lab_2024"))  # 성공
        results.append(secure.save("데이터2", password="wrong"))     # 실패
        results.append(secure.save("데이터3", password="lab_2024"))  # 성공

        assert sum(results) == 2  # 2개 성공
        assert secure.get_size() == 2

    def test_disaster_recovery_scenario(self):
        """재해 복구 시나리오"""
        backup = BackupSecureGogsStorage("회사", capacity=10, password="company_secure")

        # 중요 데이터 저장
        backup.save("고객 정보", password="company_secure")
        backup.save("재무 정보", password="company_secure")

        # 재해 발생 (데이터 손실)
        backup.stored_data.clear()
        assert backup.get_size() == 0

        # 복구
        backup.restore_from_backup()
        assert backup.get_size() == 2

    def test_enterprise_grade_storage(self):
        """엔터프라이즈급 저장소"""
        cloud = CloudBackupSecureGogsStorage(
            "엔터프라이즈",
            capacity=100,
            password="enterprise_2024",
            cloud_id="aws_s3_prod"
        )

        # 여러 데이터 저장
        for i in range(5):
            cloud.save(f"프로젝트_{i}", password="enterprise_2024")

        # 모든 기능 확인
        assert cloud.get_size() == 5           # 저장됨
        assert len(cloud.access_logs) == 5    # 로그됨
        assert len(cloud.backup_data) == 5    # 백업됨
        assert len(cloud.cloud_data) == 5     # 클라우드 동기화됨


