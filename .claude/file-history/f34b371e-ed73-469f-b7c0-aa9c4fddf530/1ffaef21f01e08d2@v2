## 실전 설계 사례

### 사례: 소셜 미디어 피드 시스템

```python
"""
수백만 사용자, 수십억 게시물
"친구의 최신 게시물" → 빠르게 표시해야 함
"""

【 설계 1: 관계형 DB만 사용 】

# 테이블:
# users: user_id, name
# posts: post_id, user_id, content, created_at
# follows: follower_id, following_id
# feeds: post_id, viewer_id, created_at

# 피드 조회 쿼리:
SELECT p.content, u.name, p.created_at
FROM feeds f
JOIN posts p ON f.post_id = p.post_id
JOIN users u ON p.user_id = u.user_id
WHERE f.viewer_id = 1
ORDER BY p.created_at DESC
LIMIT 20;

# 문제:
# - JOIN 3개 = 느림
# - 매 요청마다 계산
# - 확장 어려움

【 설계 2: 하이브리드 (추천!) 】

# 1. DB: 사용자 정보, 관계 저장
CREATE TABLE users (user_id PRIMARY KEY, name, ...);
CREATE TABLE follows (follower_id, following_id, PRIMARY KEY(follower_id, following_id));

# 2. 캐시 (Redis): 피드 미리 계산
# user:1:feed = [post_100, post_99, post_98, ...]  (최근순)

# 피드 조회:
def get_feed(user_id):
    # 1. Redis에서 즉시 반환
    feed_ids = redis.lrange(f'user:{user_id}:feed', 0, 19)  # 1ms

    if not feed_ids:
        # 2. 캐시 없으면 계산
        feed_ids = compute_feed(user_id)  # 100ms
        redis.setex(f'user:{user_id}:feed', 3600, feed_ids)  # 1시간 캐시

    # 3. 게시물 상세 조회
    posts = db.query(f'SELECT * FROM posts WHERE id IN ({feed_ids})')
    return posts

# 게시물 작성 시:
def post_new(user_id, content):
    # 1. DB에 저장
    post_id = db.insert('INSERT INTO posts (...) VALUES (...)', user_id, content)

    # 2. 팔로워의 캐시 업데이트
    followers = db.query('SELECT follower_id FROM follows WHERE following_id = ?', user_id)
    for follower in followers:
        redis.lpush(f'user:{follower}:feed', post_id)  # 앞에 추가
        redis.ltrim(f'user:{follower}:feed', 0, 100)   # 최대 100개 유지

# 성능:
# - 피드 조회: 1ms (캐시 히트)
# - 게시물 작성: 10ms (비동기로 백그라운드)
# - 확장 가능: 캐시는 수평 확장 가능
```

### 사례: 실시간 모니터링 시스템

```python
"""
1000개 서버, 초당 100만 메트릭
시계열 데이터 최적화
"""

【 설계: Time-Series DB + 집계 】

# 1. Raw 메트릭 저장 (InfluxDB 스타일)
measurement: cpu_usage
tags: {host: "server-001", region: "us-west"}
field: value=45.2
timestamp: 2024-01-15T10:00:00Z

# 2. 자동 집계 (Downsampling)
# 1분마다 원본 저장
# 1시간마다 1분 데이터 평균
# 1일마다 1시간 데이터 평균
# 1년 후 삭제

# 쿼리:
# 최근 1시간: 원본 데이터 (정확)
# 최근 1주: 1시간 집계 (중간 정확)
# 최근 1년: 1일 집계 (개략)

# 쿼리 예:
SELECT AVG(value) as avg_cpu
FROM cpu_usage
WHERE host = 'server-001' AND time > now() - 7d
GROUP BY time(1h);

# 결과: 그래프 그리기에 딱 적합

# 저장 공간:
# 원본: 100만 메트릭/초 × 86400초 × 1년 = 31억 개
#     → 수 TB 필요
# 집계 후: 1000 서버 × 365일 × 24 = 876만 개
#        → 수 GB (1000배 감소!)

# 성능:
# 원본 조회: 느림 (수십억 행)
# 집계 조회: 빠름 (수천 행)
