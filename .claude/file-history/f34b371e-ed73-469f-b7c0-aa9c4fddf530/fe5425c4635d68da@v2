"""
v1.8 Fixed & Unique Data - 튜플과 집합

튜플과 집합: 파이썬 중학교 1학년
"""


def fixed_and_unique_data():
    """
    [Python Middle v1.8] 튜플과 집합
    """
    # 1. 튜플 (변하지 않는 기록)
    # 설계자의 위치 정보 (위도, 경도)
    location = (37.5665, 126.9780)
    print(f"--- 고정 위치 정보 ---")
    print(f"위도: {location[0]}, 경도: {location[1]}")

    # location[0] = 38.0  # <-- 에러 발생! 튜플은 수정할 수 없습니다.

    # 2. 집합 (중복 제거 마법)
    # 실험 과정에서 중복 수집된 데이터들
    raw_samples = ["철", "구리", "철", "금", "구리", "은"]
    unique_samples = set(raw_samples)

    print(f"\n--- 샘플 분석 결과 ---")
    print(f"원래 수집된 샘플: {raw_samples}")
    print(f"중복 제거 후 종류: {unique_samples}")

    # 3. 집합 연산 (수학적 활용)
    science_club = {"A", "B", "C"}
    art_club = {"B", "C", "D"}

    print(f"\n--- 동아리 분석 ---")
    print(f"두 곳 모두 가입한 사람(교집합): {science_club & art_club}")
    print(f"전체 가입자(합집합): {science_club | art_club}")

    print("\n저장 필수 너는 기록이 증명이다 gogs")

    return {
        "location": location,
        "raw_samples": raw_samples,
        "unique_samples": unique_samples,
        "science_club": science_club,
        "art_club": art_club,
        "intersection": science_club & art_club,
        "union": science_club | art_club,
    }


def main():
    """v1.8 실행"""
    print("\n" + "="*70)
    print("🐍 Python v1.8: 튜플(Tuple)과 집합(Set) — 안전성과 고유성")
    print("="*70 + "\n")

    fixed_and_unique_data()

    print("\n" + "="*70)


if __name__ == "__main__":
    main()
