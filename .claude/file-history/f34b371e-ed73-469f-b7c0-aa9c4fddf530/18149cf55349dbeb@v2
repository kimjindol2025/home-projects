"""
v1.4 테스트: 자동 반복문
"""

from src.v1_4_automatic_loop import automatic_loop


def test_automatic_loop_returns_dict():
    """반환값이 딕셔너리"""
    result = automatic_loop()
    assert isinstance(result, dict)


def test_fruits_list():
    """과일 리스트가 4개"""
    result = automatic_loop()
    assert len(result["fruits"]) == 4
    assert result["fruits"][0] == "사과"
    assert result["fruits"][1] == "바나나"
    assert result["fruits"][2] == "포도"
    assert result["fruits"][3] == "딸기"


def test_numbers_list():
    """숫자 리스트가 3개"""
    result = automatic_loop()
    assert len(result["numbers"]) == 3
    assert result["numbers"] == [10, 20, 30]


def test_total_sum():
    """합계: 10 + 20 + 30 = 60"""
    result = automatic_loop()
    assert result["total"] == 60


def test_sum_calculation_logic():
    """누적 합계 계산 검증"""
    numbers = [10, 20, 30]
    total = 0
    for num in numbers:
        total = total + num
    assert total == 60


def test_range_iteration():
    """range(1, 6) 동작 검증"""
    results = []
    for i in range(1, 6):
        results.append(i)
    assert results == [1, 2, 3, 4, 5]


def test_list_iteration():
    """리스트 반복 순회"""
    fruits = ["사과", "바나나", "포도", "딸기"]
    collected = []
    for fruit in fruits:
        collected.append(fruit)
    assert collected == fruits


def test_for_loop_multiple_operations():
    """for 루프에서 여러 작업"""
    items = [1, 2, 3]
    results = []
    for item in items:
        results.append(item * 2)
    assert results == [2, 4, 6]
