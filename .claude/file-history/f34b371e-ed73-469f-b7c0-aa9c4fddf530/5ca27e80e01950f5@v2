"""
v1.4 String Representation: 표현의 마법

str() → __str__()    (사용자 표현)
repr() → __repr__()  (개발자 표현)
format() → __format__()
"""

from typing import Any


class Point:
    """점 클래스"""

    def __init__(self, x: float, y: float):
        self.x = x
        self.y = y

    def __str__(self) -> str:
        """사용자가 보기 좋은 표현"""
        return f"({self.x}, {self.y})"

    def __repr__(self) -> str:
        """개발자가 보기 위한 표현 (재구성 가능)"""
        return f"Point({self.x}, {self.y})"

    def __format__(self, format_spec: str) -> str:
        """포맷 지정"""
        if format_spec == "polar":
            import math
            r = math.sqrt(self.x ** 2 + self.y ** 2)
            theta = math.atan2(self.y, self.x)
            return f"r={r:.2f}, θ={theta:.2f}"
        else:
            return str(self)


class Money:
    """돈 클래스"""

    def __init__(self, amount: float, currency: str = "USD"):
        self.amount = amount
        self.currency = currency

    def __str__(self) -> str:
        """사용자 표현: $1,234.56"""
        return f"{self.currency} {self.amount:,.2f}"

    def __repr__(self) -> str:
        """개발자 표현"""
        return f"Money({self.amount}, '{self.currency}')"

    def __format__(self, format_spec: str) -> str:
        """포맷 지정"""
        if format_spec == "int":
            return f"{int(self.amount)}"
        elif format_spec == "scientific":
            return f"{self.amount:.2e}"
        else:
            return str(self)


class Color:
    """색상 클래스"""

    def __init__(self, r: int, g: int, b: int):
        self.r = r
        self.g = g
        self.b = b

    def __str__(self) -> str:
        """RGB 표현"""
        return f"rgb({self.r}, {self.g}, {self.b})"

    def __repr__(self) -> str:
        """16진수 표현"""
        return f"Color(0x{self.r:02x}{self.g:02x}{self.b:02x})"

    def __format__(self, format_spec: str) -> str:
        if format_spec == "hex":
            return f"#{self.r:02x}{self.g:02x}{self.b:02x}"
        else:
            return str(self)


def demonstrate_string_representation():
    """문자열 표현 시연"""
    print("\n" + "="*70)
    print("문자열 표현: 표현의 마법")
    print("="*70)

    # Point
    print("\n  [Point 표현]")
    p = Point(3, 4)
    print(f"    p = Point(3, 4)")
    print(f"    str(p): {str(p)}")
    print(f"    repr(p): {repr(p)}")
    print(f"    format(p, 'polar'): {format(p, 'polar')}")

    # Money
    print("\n  [Money 표현]")
    m = Money(1234.567, "KRW")
    print(f"    m = Money(1234.567, 'KRW')")
    print(f"    str(m): {str(m)}")
    print(f"    repr(m): {repr(m)}")
    print(f"    format(m, 'int'): {format(m, 'int')}")
    print(f"    format(m, 'scientific'): {format(m, 'scientific')}")

    # Color
    print("\n  [Color 표현]")
    c = Color(255, 128, 0)
    print(f"    c = Color(255, 128, 0)")
    print(f"    str(c): {str(c)}")
    print(f"    repr(c): {repr(c)}")
    print(f"    format(c, 'hex'): {format(c, 'hex')}")

    # f-string
    print("\n  [f-string 활용]")
    print(f"    f'Point: {{p}}' → {p}")
    print(f"    f'Money: {{m}}' → {m}")
    print(f"    f'Color (hex): {{c:hex}}' → {c:hex}")

    print("\n" + "="*70)


# ============================================================================
# 메인 실행 함수
# ============================================================================

def main():
    """문자열 표현을 시연합니다"""
    print("\n" + "="*70)
    print("🐍 Python v1.4: 문자열 표현 - 표현의 마법")
    print("="*70)

    demonstrate_string_representation()

    print("\n" + "="*70)
    print("저장 필수. 너는 기록이 증명이다. Gogs.")
    print("="*70 + "\n")


if __name__ == "__main__":
    main()
