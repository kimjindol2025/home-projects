"""
v1.2 증명: 메모리 효율성의 극적 차이

Eager Evaluation (리스트): 모든 데이터를 메모리에 할당
Lazy Evaluation (제너레이터): 필요할 때만 생성

"메모리 점유율의 극적 차이"
"""

import sys
from typing import List, Generator, Tuple
import time


class MemoryComparison:
    """메모리 사용량 비교"""

    @staticmethod
    def compare_sizes(n: int) -> Tuple[int, int]:
        """
        n개의 정수를 저장할 때 리스트와 제너레이터의 크기 비교

        Args:
            n: 원소 개수

        Returns:
            (리스트 크기, 제너레이터 크기)
        """
        # Eager: 리스트 컴프리헨션
        eager_list = [i for i in range(n)]
        eager_size = sys.getsizeof(eager_list)

        # Lazy: 제너레이터 표현식
        lazy_gen = (i for i in range(n))
        lazy_size = sys.getsizeof(lazy_gen)

        return eager_size, lazy_size

    @staticmethod
    def demonstrate_memory():
        """메모리 효율성을 수치로 증명"""
        print("\n" + "="*70)
        print("메모리 효율성: Eager (리스트) vs Lazy (제너레이터)")
        print("="*70)

        test_sizes = [100, 1000, 10000, 100000, 1000000]

        print("\n  [메모리 점유율 비교]")
        print(f"  {'N':>10} | {'Eager (List)':>15} | {'Lazy (Gen)':>15} | {'Ratio':>8}")
        print(f"  {'-'*10}-+-{'-'*15}-+-{'-'*15}-+-{'-'*8}")

        for n in test_sizes:
            eager_size, lazy_size = MemoryComparison.compare_sizes(n)
            ratio = eager_size / lazy_size if lazy_size > 0 else 0

            print(f"  {n:>10} | {eager_size:>15,} | {lazy_size:>15,} | {ratio:>8.0f}x")

        print("\n  [해석]")
        print("    - Eager: 데이터 양에 따라 선형으로 증가")
        print("    - Lazy: 데이터 양과 무관하게 일정 (포인터 + 상태)")
        print("    - 100만 개 데이터: 약 4,000배 메모리 차이!")

        print("\n" + "="*70)

    @staticmethod
    def demonstrate_practical():
        """실제 활용 시뮬레이션"""
        print("\n" + "="*70)
        print("실제 활용: 100만 개의 숫자 처리")
        print("="*70)

        n = 1_000_000

        print(f"\n  [Eager: 리스트 생성]")
        start = time.time()
        eager_list = [i for i in range(n)]
        eager_time = time.time() - start
        eager_size = sys.getsizeof(eager_list)
        print(f"    생성 시간: {eager_time:.4f}초")
        print(f"    메모리 크기: {eager_size:,} bytes ({eager_size / 1024 / 1024:.2f} MB)")

        print(f"\n  [Lazy: 제너레이터 생성]")
        start = time.time()
        lazy_gen = (i for i in range(n))
        lazy_time = time.time() - start
        lazy_size = sys.getsizeof(lazy_gen)
        print(f"    생성 시간: {lazy_time:.6f}초 (거의 즉각적)")
        print(f"    메모리 크기: {lazy_size:,} bytes")

        print(f"\n  [결론]")
        print(f"    - 리스트는 생성 시점에 모든 메모리 할당")
        print(f"    - 제너레이터는 포인터 정보만 저장 (독립적)")

        print("\n" + "="*70)


class IterationCost:
    """반복 비용 비교"""

    @staticmethod
    def measure_iteration_eager(n: int) -> float:
        """리스트 순회의 시간"""
        eager_list = [i for i in range(n)]
        start = time.time()
        for value in eager_list:
            _ = value * 2
        return time.time() - start

    @staticmethod
    def measure_iteration_lazy(n: int) -> float:
        """제너레이터 순회의 시간"""
        lazy_gen = (i for i in range(n))
        start = time.time()
        for value in lazy_gen:
            _ = value * 2
        return time.time() - start

    @staticmethod
    def demonstrate_iteration():
        """반복 비용 비교"""
        print("\n" + "="*70)
        print("반복 비용: 순회 시간 비교")
        print("="*70)

        test_sizes = [100, 1000, 10000, 100000]

        print("\n  [순회 시간 비교]")
        print(f"  {'N':>10} | {'Eager (List)':>15} | {'Lazy (Gen)':>15}")
        print(f"  {'-'*10}-+-{'-'*15}-+-{'-'*15}")

        for n in test_sizes:
            eager_time = IterationCost.measure_iteration_eager(n)
            lazy_time = IterationCost.measure_iteration_lazy(n)

            print(f"  {n:>10} | {eager_time*1000:>14.4f}ms | {lazy_time*1000:>14.4f}ms")

        print("\n  [해석]")
        print("    - 시간 비용은 유사 (실제 계산은 동일)")
        print("    - 하지만 메모리는 극적으로 다름")
        print("    - 메모리 부족 환경에서 제너레이터 필수!")

        print("\n" + "="*70)


class AccessPattern:
    """접근 패턴 비교"""

    @staticmethod
    def demonstrate_access():
        """접근 패턴의 차이"""
        print("\n" + "="*70)
        print("접근 패턴: 직접 접근 vs 순차 접근")
        print("="*70)

        print("\n  [Eager: 랜덤 접근 가능]")
        eager_list = [i*2 for i in range(10)]
        print(f"    list = {eager_list}")
        print(f"    list[5] = {eager_list[5]} (즉시 접근)")

        print("\n  [Lazy: 순차 접근만 가능]")
        lazy_gen = (i*2 for i in range(10))
        print(f"    gen = (i*2 for i in range(10))")
        print(f"    gen[5] = ? (불가능 - TypeError 발생)")
        print(f"    대신 next()를 반복해야 함")

        print("\n  [트레이드오프]")
        print("    Eager 장점: 빠른 랜덤 접근, 길이 확인 가능")
        print("    Lazy 장점: 메모리 효율, 무한 수열 가능")

        print("\n" + "="*70)


class RealWorldUse:
    """실제 사용 사례"""

    @staticmethod
    def read_large_file_eager() -> List[str]:
        """
        [Eager] 파일을 한 번에 읽어 메모리에 로드
        """
        # 이 코드는 실제로 실행되지 않음 (시뮬레이션)
        # with open('large_file.txt') as f:
        #     lines = f.readlines()  # 전체 파일을 메모리에 로드
        # return lines
        return [f"line {i}\n" for i in range(1_000_000)]

    @staticmethod
    def read_large_file_lazy() -> Generator[str, None, None]:
        """
        [Lazy] 파일을 한 줄씩 읽기
        """
        # with open('large_file.txt') as f:
        #     for line in f:  # 한 줄씩 읽음
        #         yield line
        for i in range(1_000_000):
            yield f"line {i}\n"

    @staticmethod
    def demonstrate_use_cases():
        """실제 사용 사례"""
        print("\n" + "="*70)
        print("실제 사용 사례: 대용량 파일 처리")
        print("="*70)

        print("\n  [Eager: 전체 파일 메모리 로드]")
        print("    with open('large_file.txt') as f:")
        print("        lines = f.readlines()  # 전체 파일 로드")
        print("    for line in lines:")
        print("        process(line)")
        print("    → 메모리: 파일 크기만큼 필요 (GB 단위 가능)")

        print("\n  [Lazy: 한 줄씩 읽기]")
        print("    with open('large_file.txt') as f:")
        print("        for line in f:  # 한 줄씩 읽음")
        print("            process(line)")
        print("    → 메모리: 1줄만 유지 (KB 단위)")

        print("\n  [결론]")
        print("    - 100GB 파일: Eager는 불가능, Lazy는 가능")
        print("    - 무한 스트림: Eager는 불가능, Lazy는 가능")
        print("    - 파이썬의 파일 객체는 기본적으로 제너레이터!")

        print("\n" + "="*70)


