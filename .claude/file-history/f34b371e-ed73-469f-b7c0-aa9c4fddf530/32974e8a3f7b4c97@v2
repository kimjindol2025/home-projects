/// v30.1: 신경 분기 예측 (실행 타임, 학습 기반)
#[derive(Clone)]
pub struct PredictiveBranch {
    /// 조건 평가 (기존 로직)
    pub condition: Box<dyn Fn(&SystemContext) -> bool>,

    /// 분기 선택 가중치 (신경망)
    pub branch_a_weight: f32,
    pub branch_b_weight: f32,

    /// 실행 이력
    pub history: Vec<BranchOutcome>,

    /// 신경망 신뢰도
    pub confidence: f32,
}

#[derive(Debug, Clone)]
pub struct BranchOutcome {
    pub branch_taken: BranchChoice,
    pub actual_condition: bool,
    pub correct: bool,
    pub latency_impact: i32,
}

#[derive(Debug, Clone, PartialEq)]
pub enum BranchChoice {
    A,
    B,
}

impl PredictiveBranch {
    /// 신경망 기반 분기 예측
    pub fn predict_branch(&self) -> BranchChoice {
        if self.branch_a_weight > self.branch_b_weight {
            BranchChoice::A
        } else {
            BranchChoice::B
        }
    }

    /// CPU 캐시 미리 로드 (예측 기반)
    pub fn prefetch_for_prediction(&self) {
        let predicted = self.predict_branch();
        println!("  [PREFETCH] 분기 예측: {:?} (신뢰도: {:.1}%)",
            predicted,
            self.confidence * 100.0);

        // 예측된 분기의 명령어를 L1 캐시에 로드
        match predicted {
            BranchChoice::A => {
                println!("    → A 분기 코드를 캐시에 미리 로드");
            }
            BranchChoice::B => {
                println!("    → B 분기 코드를 캐시에 미리 로드");
            }
        }
    }

    /// 실제 분기 결과로 신경망 학습
    pub fn learn_from_branch(&mut self, actual: bool) {
        let predicted = self.predict_branch();
        let actual_choice = if actual { BranchChoice::A } else { BranchChoice::B };
        let correct = predicted == actual_choice;

        let outcome = BranchOutcome {
            branch_taken: predicted,
            actual_condition: actual,
            correct,
            latency_impact: if correct { -10 } else { 20 },  // 예측 실패 시 페널티
        };

        self.history.push(outcome.clone());

        // 신경망 가중치 업데이트
        if correct {
            // 맞춘 분기의 가중치 증가
            if predicted == BranchChoice::A {
                self.branch_a_weight += 0.05;
            } else {
                self.branch_b_weight += 0.05;
            }
        } else {
            // 틀린 분기의 가중치 감소
            if predicted == BranchChoice::A {
                self.branch_a_weight -= 0.05;
            } else {
                self.branch_b_weight -= 0.05;
            }
        }

        // 신뢰도 업데이트: 최근 100회 정확도
        let recent = self.history.iter().rev().take(100);
        let correct_count = recent.filter(|o| o.correct).count();
        self.confidence = correct_count as f32 / self.history.len().min(100) as f32;

        println!("  [LEARNING] 분기 예측 학습: {:?} (정확도: {:.1}%)",
            outcome.branch_taken,
            self.confidence * 100.0);
    }

    /// 분기 예측 성능 보고
    pub fn report_accuracy(&self) {
        let total = self.history.len();
        let correct = self.history.iter().filter(|o| o.correct).count();

        println!("\n  [BRANCH PREDICTION REPORT]");
        println!("    총 분기 수: {}", total);
        println!("    정확한 예측: {}", correct);
        println!("    실패한 예측: {}", total - correct);
        println!("    정확도: {:.1}%", (correct as f32 / total.max(1) as f32) * 100.0);

        if correct as f32 / total.max(1) as f32 > 0.99 {
            println!("    🎯 뛰어난 성과: 99% 이상의 분기 예측 정확도!");
        }
    }
}
