### B. NIS의 동작 원리

```rust
/// 신경 명령어의 학습 기반 실행
impl NeuralInstruction {
    /// 가중치 기반 최적 경로 결정
    pub fn predict_next_instruction(&self) -> usize {
        self.next_instruction_weights
            .iter()
            .max_by(|a, b| a.1.partial_cmp(b.1).unwrap())
            .map(|(idx, _)| *idx)
            .unwrap_or(0)
    }

    /// 캐시 힌트: 신경망이 예측한 다음 명령어를 미리 로드
    pub fn prefetch_hint(&self) -> PrefetchHint {
        let next_idx = self.predict_next_instruction();
        PrefetchHint {
            instruction_index: next_idx,
            confidence: self.next_instruction_weights[&next_idx],
        }
    }

    /// 실행 결과를 바탕으로 가중치 갱신
    pub fn learn_from_execution(&mut self, metric: ExecutionMetric) {
        self.execution_history.push(metric.clone());

        // Exponential Moving Average (EMA)
        let alpha = 0.1;  // 학습률
        self.execution_weight = (1.0 - alpha) * self.execution_weight
                             + alpha * metric.performance_score;

        self.branch_success_rate = self.execution_history
            .iter()
            .filter(|m| m.branch_taken_correctly)
            .count() as f32
            / self.execution_history.len() as f32;
    }

    /// 신경망의 "생각": 현재 상태에서 최적 선택
    pub fn infer_best_action(&self, system_state: &SystemContext) -> Action {
        let confidence = self.execution_weight;
        let success_history = self.branch_success_rate;

        if confidence > 0.8 && success_history > 0.95 {
            Action::FastPath  // 최적화된 경로 (99% 확률)
        } else if confidence > 0.5 {
            Action::NormalPath  // 표준 경로 (50% 확률)
        } else {
            Action::ExploreNewPath  // 새 경로 탐색 (학습 모드)
        }
    }
}

