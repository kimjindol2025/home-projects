class DynamicProgramming:
    """동적 계획법"""

    @staticmethod
    def fibonacci_naive(n: int) -> Tuple[int, int]:
        """나이브 피보나치 O(2^n)"""
        calls = [0]

        def fib(n):
            calls[0] += 1
            if n <= 1:
                return n
            return fib(n - 1) + fib(n - 2)

        return fib(n), calls[0]

    @staticmethod
    def fibonacci_dp(n: int) -> Tuple[int, int]:
        """동적 계획법 피보나치 O(n)"""
        if n <= 1:
            return n, 1

        dp = [0] * (n + 1)
        dp[1] = 1

        for i in range(2, n + 1):
            dp[i] = dp[i - 1] + dp[i - 2]

        return dp[n], n

    @staticmethod
    def knapsack_01(weights: List[int], values: List[int], capacity: int) -> int:
        """0/1 냅색 문제 O(n * W)"""
        n = len(weights)
        dp = [[0] * (capacity + 1) for _ in range(n + 1)]

        for i in range(1, n + 1):
            for w in range(capacity + 1):
                if weights[i - 1] <= w:
                    dp[i][w] = max(
                        values[i - 1] + dp[i - 1][w - weights[i - 1]],
                        dp[i - 1][w]
                    )
                else:
                    dp[i][w] = dp[i - 1][w]

        return dp[n][capacity]

    @staticmethod
    def longest_common_subsequence(s1: str, s2: str) -> int:
        """최장 공통 부분수열 (LCS) O(m * n)"""
        m, n = len(s1), len(s2)
        dp = [[0] * (n + 1) for _ in range(m + 1)]

        for i in range(1, m + 1):
            for j in range(1, n + 1):
                if s1[i - 1] == s2[j - 1]:
                    dp[i][j] = dp[i - 1][j - 1] + 1
                else:
                    dp[i][j] = max(dp[i - 1][j], dp[i][j - 1])

        return dp[m][n]


