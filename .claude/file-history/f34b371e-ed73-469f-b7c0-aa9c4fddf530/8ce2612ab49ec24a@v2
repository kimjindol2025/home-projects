def demonstrate_sorting():
    """정렬 알고리즘 시연"""
    data = [64, 34, 25, 12, 22, 11, 90]

    bubble, bubble_comps = SortingAlgorithms.bubble_sort(data)
    merge, merge_comps = SortingAlgorithms.merge_sort(data)

    return {
        'bubble_sort': {'result': bubble, 'comparisons': bubble_comps},
        'merge_sort': {'result': merge, 'comparisons': merge_comps}
    }


def demonstrate_searching():
    """검색 알고리즘 시연"""
    data = sorted(list(range(1, 1001)))
    target = 500

    linear_idx, linear_comps = SearchAlgorithms.linear_search(data, target)
    binary_idx, binary_comps = SearchAlgorithms.binary_search(data, target)

    return {
        'linear_search': {'index': linear_idx, 'comparisons': linear_comps},
        'binary_search': {'index': binary_idx, 'comparisons': binary_comps},
        'speedup': linear_comps / binary_comps
    }


def demonstrate_dynamic_programming():
    """동적 계획법 시연"""
    n = 10

    naive_result, naive_calls = DynamicProgramming.fibonacci_naive(n)
    dp_result, dp_calls = DynamicProgramming.fibonacci_dp(n)

    return {
        'naive_fibonacci': {'result': naive_result, 'calls': naive_calls},
        'dp_fibonacci': {'result': dp_result, 'calls': dp_calls},
        'improvement': naive_calls / dp_calls
    }


def demonstrate_graph_algorithms():
    """그래프 알고리즘 시연"""
    g = Graph()

    # 간선 추가
    edges = [(0, 1, 4), (0, 2, 2), (1, 2, 1), (1, 3, 5), (2, 3, 8), (2, 4, 10), (3, 4, 2)]
    for u, v, w in edges:
        g.add_edge(u, v, w)

    dfs_result = g.dfs(0)
    bfs_result = g.bfs(0)
    dijkstra_result = g.dijkstra(0)

    return {
        'dfs': dfs_result,
        'bfs': bfs_result,
        'dijkstra_shortest_paths': dijkstra_result
    }


