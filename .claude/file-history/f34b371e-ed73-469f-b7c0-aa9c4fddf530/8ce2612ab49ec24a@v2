class ComplexityAnalysis:
    """복잡도 분석 및 성능 비교"""

    @staticmethod
    def compare_algorithms(name1: str, func1: Callable, name2: str, func2: Callable) -> Dict[str, Any]:
        """두 알고리즘 성능 비교"""
        # 작은 데이터
        small_data = list(range(1000, 0, -1))

        start1 = time.perf_counter()
        result1 = func1(small_data)
        time1 = time.perf_counter() - start1

        start2 = time.perf_counter()
        result2 = func2(small_data)
        time2 = time.perf_counter() - start2

        return {
            'algorithm1': name1,
            'algorithm2': name2,
            'time1': time1,
            'time2': time2,
            'speedup': time1 / time2 if time2 > 0 else 0,
            'faster': name1 if time1 < time2 else name2
        }

    @staticmethod
    def growth_analysis(n_values: List[int]) -> Dict[str, List[float]]:
        """n에 따른 복잡도 성장 분석"""
        results = {
            'O(1)': [],
            'O(log n)': [],
            'O(n)': [],
            'O(n log n)': [],
            'O(n²)': []
        }

        import math

        for n in n_values:
            results['O(1)'].append(1)
            results['O(log n)'].append(math.log2(n) if n > 0 else 0)
            results['O(n)'].append(n)
            results['O(n log n)'].append(n * math.log2(n) if n > 0 else 0)
            results['O(n²)'].append(n * n)

        return results


