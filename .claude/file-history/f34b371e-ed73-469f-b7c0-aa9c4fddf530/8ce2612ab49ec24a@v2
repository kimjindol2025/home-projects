class SearchAlgorithms:
    """검색 알고리즘"""

    @staticmethod
    def linear_search(arr: List[int], target: int) -> Tuple[int, int]:
        """선형 탐색 O(n)"""
        comparisons = 0
        for i in range(len(arr)):
            comparisons += 1
            if arr[i] == target:
                return i, comparisons
        return -1, comparisons

    @staticmethod
    def binary_search(arr: List[int], target: int) -> Tuple[int, int]:
        """이진 탐색 O(log n)"""
        comparisons = 0
        low = 0
        high = len(arr) - 1

        while low <= high:
            comparisons += 1
            mid = (low + high) // 2

            if arr[mid] == target:
                return mid, comparisons
            elif arr[mid] < target:
                low = mid + 1
            else:
                high = mid - 1

        return -1, comparisons

    @staticmethod
    def jump_search(arr: List[int], target: int) -> Tuple[int, int]:
        """점프 탐색 O(√n)"""
        comparisons = 0
        n = len(arr)
        step = int(n ** 0.5)
        prev = 0

        # 점프하며 범위 찾기
        while arr[min(step, n) - 1] < target:
            comparisons += 1
            prev = step
            step += int(n ** 0.5)
            if prev >= n:
                return -1, comparisons

        # 선형 탐색
        while arr[prev] < target:
            comparisons += 1
            prev += 1
            if prev == min(step, n):
                return -1, comparisons

        # 찾기
        if arr[prev] == target:
            comparisons += 1
            return prev, comparisons

        return -1, comparisons


