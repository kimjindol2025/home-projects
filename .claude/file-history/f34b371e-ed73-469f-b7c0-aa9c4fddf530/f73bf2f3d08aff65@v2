"""
v5.2 실전: 대화형 SQL 쉘
직접 SQL 쿼리를 실행해보기!

【 사용 예 】
> SELECT * FROM researchers;
> SELECT COUNT(*) FROM experiments;
> SELECT * FROM experiments WHERE status = 'completed';
> UPDATE experiments SET result = 99.9 WHERE id = 1;
> exit
"""

import sqlite3
from typing import List, Tuple


class InteractiveSQLShell:
    """대화형 SQL 실행 도구"""

    def __init__(self, db_file: str = 'gogs_research.db'):
        self.db_file = db_file
        self.conn = sqlite3.connect(db_file)
        self.cursor = self.conn.cursor()
        self.running = True

    def print_welcome(self):
        print("=" * 70)
        print("🗄️  Gogs 연구 기록 시스템 - 대화형 SQL 쉘")
        print("=" * 70)
        print("SQL 명령어를 입력하세요. (exit로 종료)")
        print()
        print("【 도움말 】")
        print("  SELECT * FROM researchers;     # 모든 연구자 조회")
        print("  SELECT * FROM experiments;     # 모든 실험 조회")
        print("  .tables                        # 테이블 목록")
        print("  .schema experiments            # 테이블 구조")
        print("  exit                           # 종료")
        print("=" * 70)
        print()

    def print_help(self):
        """도움말 출력"""
        print("""
【 SQL 기초 명령어 】

1. SELECT: 데이터 조회
   SELECT * FROM researchers;
   SELECT name, email FROM researchers WHERE id = 1;
   SELECT COUNT(*) FROM experiments;
   SELECT * FROM experiments ORDER BY result DESC;

2. INSERT: 데이터 추가
   INSERT INTO researchers (name, email) VALUES ('테스트', 'test@gogs.io');

3. UPDATE: 데이터 수정
   UPDATE experiments SET result = 99.9 WHERE id = 1;
   UPDATE experiments SET status = 'completed' WHERE status = 'pending';

4. DELETE: 데이터 삭제
   DELETE FROM experiments WHERE id = 5;

5. JOIN: 여러 테이블 결합
   SELECT e.subject, r.name FROM experiments e JOIN researchers r ON e.researcher_id = r.id;

6. GROUP BY: 그룹화
   SELECT researcher_id, COUNT(*) FROM experiments GROUP BY researcher_id;

【 메타 명령어 】
.tables         # 모든 테이블 목록
.schema TABLE   # 테이블 구조 보기
.help           # 도움말 보기
.exit           # 종료
        """)

    def execute_query(self, query: str):
        """SQL 쿼리 실행"""
        try:
            # SELECT 쿼리
            if query.upper().startswith('SELECT'):
                self.cursor.execute(query)
                rows = self.cursor.fetchall()

                if not rows:
                    print("(결과 없음)")
                    return

                # 컬럼 이름 가져오기
                columns = [description[0] for description in self.cursor.description]

                # 테이블 형식으로 출력
                self._print_table(columns, rows)

            # INSERT/UPDATE/DELETE 쿼리
            elif query.upper().startswith(('INSERT', 'UPDATE', 'DELETE')):
                self.cursor.execute(query)
                self.conn.commit()
                print(f"✅ 쿼리 실행 완료 ({self.cursor.rowcount}개 행 영향)")

            # 기타 쿼리
            else:
                self.cursor.execute(query)
                self.conn.commit()
                print(f"✅ 쿼리 실행 완료")

        except sqlite3.Error as e:
            print(f"❌ SQL 오류: {e}")
        except Exception as e:
            print(f"❌ 오류: {e}")

    def execute_meta_command(self, command: str):
        """메타 명령어 실행"""
        cmd = command.lower().strip()

        if cmd == '.tables':
            self.cursor.execute(
                "SELECT name FROM sqlite_master WHERE type='table' ORDER BY name"
            )
            tables = self.cursor.fetchall()
            print("\n【 테이블 목록 】")
            for table in tables:
                print(f"  - {table[0]}")

        elif cmd.startswith('.schema'):
            parts = cmd.split()
            if len(parts) < 2:
                print("사용법: .schema TABLE_NAME")
                return

            table_name = parts[1]
            self.cursor.execute(f"PRAGMA table_info({table_name})")
            columns = self.cursor.fetchall()

            if not columns:
                print(f"❌ 테이블 '{table_name}'을 찾을 수 없습니다")
                return

            print(f"\n【 테이블: {table_name} 】")
            for col in columns:
                cid, name, ctype, notnull, dflt_value, pk = col
                null_str = "NOT NULL" if notnull else "NULL"
                pk_str = "PRIMARY KEY" if pk else ""
                print(f"  {name:20} {ctype:10} {null_str:10} {pk_str}")

        elif cmd == '.help':
            self.print_help()

        elif cmd in ['.exit', '.quit']:
            self.running = False
            print("👋 SQL 쉘을 종료합니다.")

        else:
            print(f"❌ 알 수 없는 명령어: {command}")
            print("   .help 또는 ? 를 입력하세요.")

    def _print_table(self, columns: List[str], rows: List[Tuple]):
        """테이블 형식으로 출력"""
        # 컬럼 너비 계산
        col_widths = [len(col) for col in columns]
        for row in rows:
            for i, cell in enumerate(row):
                col_widths[i] = max(col_widths[i], len(str(cell)))

        # 헤더 출력
        header = " | ".join(
            col.ljust(col_widths[i]) for i, col in enumerate(columns)
        )
        print()
        print(header)
        print("-" * len(header))

        # 행 출력
        for row in rows:
            line = " | ".join(
                str(cell).ljust(col_widths[i]) for i, cell in enumerate(row)
            )
            print(line)

        print(f"\n({len(rows)}개 행)")

    def run(self):
        """대화형 쉘 시작"""
        self.print_welcome()

        while self.running:
            try:
                # 사용자 입력
                user_input = input("\n> ").strip()

                if not user_input:
                    continue

                # 메타 명령어
                if user_input.startswith('.'):
                    self.execute_meta_command(user_input)

                # 종료
                elif user_input.lower() in ['exit', 'quit']:
                    self.running = False
                    print("👋 SQL 쉘을 종료합니다.")

                # SQL 쿼리
                else:
                    # 쿼리가 ;로 끝나지 않으면 추가
                    if not user_input.endswith(';'):
                        user_input += ';'

                    self.execute_query(user_input)

            except KeyboardInterrupt:
                print("\n\n👋 SQL 쉘을 종료합니다.")
                self.running = False
            except Exception as e:
                print(f"❌ 오류: {e}")

        self.conn.close()


def main():
    shell = InteractiveSQLShell('gogs_research.db')
    shell.run()


if __name__ == '__main__':
    main()
