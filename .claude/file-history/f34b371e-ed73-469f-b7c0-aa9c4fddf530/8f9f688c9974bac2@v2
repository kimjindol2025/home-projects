## 섹션 4: 실전 통합 예제 - 전자상거래 시스템

### 4.1 요구사항
```
1. 사용자가 상품을 카트에 담음
2. 결제 (신용카드, 페이팔, 암호화폐)
3. 결제 실패 시 자동 재시도
4. 주문 상태 변경 시 알림
5. 주문 이력 저장
```

### 4.2 패턴 적용 설계

```python
from abc import ABC, abstractmethod
from typing import List
from enum import Enum
from datetime import datetime

# ===== Strategy 패턴: 결제 방식 =====
class PaymentStrategy(ABC):
    @abstractmethod
    def pay(self, amount: float) -> bool:
        pass

class CreditCardPayment(PaymentStrategy):
    def pay(self, amount: float) -> bool:
        print(f"Charging credit card for ${amount}")
        return True

class PayPalPayment(PaymentStrategy):
    def pay(self, amount: float) -> bool:
        print(f"Charging PayPal for ${amount}")
        return True

class CryptoPayment(PaymentStrategy):
    def pay(self, amount: float) -> bool:
        print(f"Charging cryptocurrency for ${amount}")
        return True

# ===== Observer 패턴: 주문 상태 변화 알림 =====
class OrderObserver(ABC):
    @abstractmethod
    def update(self, order_id: str, status: str) -> None:
        pass

class EmailNotifier(OrderObserver):
    def update(self, order_id: str, status: str) -> None:
        print(f"Email: Order {order_id} is now {status}")

class SMSNotifier(OrderObserver):
    def update(self, order_id: str, status: str) -> None:
        print(f"SMS: Order {order_id} is now {status}")

class WarehouseNotifier(OrderObserver):
    def update(self, order_id: str, status: str) -> None:
        print(f"Warehouse: Prepare order {order_id} (status: {status})")

# ===== State 패턴: 주문 상태 =====
class OrderState(ABC):
    @abstractmethod
    def process(self, order: 'Order') -> None:
        pass

class PendingState(OrderState):
    def process(self, order: 'Order') -> None:
        print(f"Processing order {order.id}")
        order.state = ProcessingState()

class ProcessingState(OrderState):
    def process(self, order: 'Order') -> None:
        print(f"Shipping order {order.id}")
        order.state = ShippedState()

class ShippedState(OrderState):
    def process(self, order: 'Order') -> None:
        print(f"Delivering order {order.id}")
        order.state = DeliveredState()

class DeliveredState(OrderState):
    def process(self, order: 'Order') -> None:
        print(f"Order {order.id} delivered")

# ===== Command 패턴: 주문 처리 명령 =====
class Command(ABC):
    @abstractmethod
    def execute(self) -> bool:
        pass

class ProcessOrderCommand(Command):
    def __init__(self, order: 'Order', payment: PaymentStrategy):
        self.order = order
        self.payment = payment

    def execute(self) -> bool:
        return self.payment.pay(self.order.total)

# ===== Memento 패턴: 주문 이력 =====
class OrderMemento:
    def __init__(self, status: str, timestamp: datetime):
        self.status = status
        self.timestamp = timestamp

class OrderCaretaker:
    def __init__(self):
        self.history: List[OrderMemento] = []

    def save(self, status: str) -> None:
        self.history.append(OrderMemento(status, datetime.now()))

    def get_history(self) -> List[OrderMemento]:
        return self.history

# ===== Facade 패턴: 복잡한 과정을 단순화 =====
class Order:
    def __init__(self, order_id: str, items: List[dict]):
        self.id = order_id
        self.items = items
        self.total = sum(item['price'] * item['qty'] for item in items)
        self.state: OrderState = PendingState()
        self.observers: List[OrderObserver] = []
        self.caretaker = OrderCaretaker()
        self.caretaker.save("created")

    def attach_observer(self, observer: OrderObserver) -> None:
        self.observers.append(observer)

    def notify_observers(self, new_status: str) -> None:
        self.caretaker.save(new_status)
        for observer in self.observers:
            observer.update(self.id, new_status)

    def process(self) -> None:
        self.state.process(self)
        self.notify_observers(self.state.__class__.__name__)

class OrderFacade:
    """복잡한 주문 처리를 단순한 인터페이스로 제공"""

    def __init__(self):
        self.orders = {}

    def create_order(self, order_id: str, items: List[dict]) -> Order:
        order = Order(order_id, items)

        # Observer 등록
        order.attach_observer(EmailNotifier())
        order.attach_observer(SMSNotifier())
        order.attach_observer(WarehouseNotifier())

        self.orders[order_id] = order
        return order

    def process_payment(self, order_id: str, payment_strategy: PaymentStrategy) -> bool:
        order = self.orders[order_id]
        command = ProcessOrderCommand(order, payment_strategy)

        # 결제 재시도 (Chain of Responsibility 패턴)
        for attempt in range(3):  # 최대 3회 재시도
            if command.execute():
                order.notify_observers("payment_successful")
                return True
            print(f"Payment failed, retrying... (attempt {attempt + 1})")

        order.notify_observers("payment_failed")
        return False

    def ship_order(self, order_id: str) -> None:
        order = self.orders[order_id]
        order.notify_observers("preparing_shipment")
        order.process()
        order.process()
        order.process()

    def get_order_history(self, order_id: str) -> List[str]:
        order = self.orders[order_id]
        return [(m.status, m.timestamp) for m in order.caretaker.get_history()]

# ===== 사용 예제 =====
facade = OrderFacade()

# 주문 생성
items = [
    {'name': 'Laptop', 'price': 1000, 'qty': 1},
