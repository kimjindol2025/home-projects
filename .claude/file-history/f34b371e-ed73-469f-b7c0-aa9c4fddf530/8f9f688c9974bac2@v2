### 1.3 DIP 위반 사례: 강한 결합

```python
# ❌ Bad: 고수준이 저수준에 의존
class SMTPEmail:
    """저수준: 구체적인 이메일 구현"""
    def send(self, to, message):
        print(f"Sending via SMTP to {to}: {message}")

class NotificationService:
    """고수준: 비즈니스 로직"""
    def __init__(self):
        self.email = SMTPEmail()  # 직접 의존!

    def notify_user(self, user_email, message):
        self.email.send(user_email, message)

# 문제: SMTPEmail을 GmailAPI로 바꾸려면?
# NotificationService를 수정해야 함 → 위험!
```

```python
# ✅ Good: 둘 다 추상화에 의존
from abc import ABC, abstractmethod

class EmailService(ABC):
    """추상화"""
    @abstractmethod
    def send(self, to, message):
        pass

class SMTPEmail(EmailService):
    """저수준 구현 1"""
    def send(self, to, message):
        print(f"Sending via SMTP to {to}")

class GmailAPI(EmailService):
    """저수준 구현 2"""
    def send(self, to, message):
        print(f"Sending via Gmail to {to}")

class SlackService(EmailService):
    """저수준 구현 3"""
    def send(self, to, message):
        print(f"Sending via Slack to {to}")

class NotificationService:
    """고수준"""
    def __init__(self, email_service: EmailService):
        self.email = email_service  # 추상화에만 의존!

    def notify_user(self, user_email, message):
        self.email.send(user_email, message)

# 사용
smtp = SMTPEmail()
notifier = NotificationService(smtp)
notifier.notify_user("user@example.com", "Hello")

# 이메일 서비스 변경 (NotificationService 수정 없음!)
gmail = GmailAPI()
notifier = NotificationService(gmail)
notifier.notify_user("user@example.com", "Hello")

# 테스트할 때 Mock 사용 가능
class MockEmail(EmailService):
    def __init__(self):
        self.sent_count = 0

    def send(self, to, message):
        self.sent_count += 1

mock = MockEmail()
notifier = NotificationService(mock)
notifier.notify_user("test@example.com", "Test")
assert mock.sent_count == 1
```

