## 섹션 7: 테스트 용이성

패턴을 잘 적용하면 테스트가 훨씬 쉬워집니다:

```python
# ❌ Hard to test (강한 결합)
class OrderService:
    def __init__(self):
        self.db = Database()  # 직접 의존성
        self.email = EmailService()  # 직접 의존성

    def create_order(self, items):
        order = self.db.save(items)  # 실제 DB 호출
        self.email.send_confirmation(order)  # 실제 이메일 발송
        return order

# 테스트: 실제 DB와 이메일 서비스 필요 → 느리고 복잡

# ✅ Easy to test (느슨한 결합)
class OrderService:
    def __init__(self, db: Database, email: EmailService):
        self.db = db
        self.email = email

    def create_order(self, items):
        order = self.db.save(items)
        self.email.send_confirmation(order)
        return order

# 테스트: Mock 객체 주입
class MockDatabase(Database):
    def save(self, items):
        return Order(id="test-123", items=items)

class MockEmail(EmailService):
    def send_confirmation(self, order):
        self.last_sent_to = order.customer_email

# 테스트 코드
def test_create_order():
    mock_db = MockDatabase()
    mock_email = MockEmail()

    service = OrderService(mock_db, mock_email)
    order = service.create_order([...])

    assert order.id == "test-123"
    assert mock_email.last_sent_to is not None  # 이메일 발송 확인
```

