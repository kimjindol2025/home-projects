    print("""
【 v5.5 원본 코드 】

class APIHandler:
    def handle_researchers_create(self, params, body):
        data = self.parse_json_body(body)
        name, email, role = data['name'], data['email'], data.get('role', 'RESEARCHER')

        # 중복 검사
        conn = self.db.get_connection()
        cursor = conn.cursor()
        cursor.execute("SELECT * FROM researchers WHERE email = ?", (email,))
        if cursor.fetchone():
            return (400, "이미 등록된 이메일")

        # 생성
        researcher = self.db.create_researcher(name, email, role)
        return (201, self.json_response(201, researcher))

문제점:
- API 핸들러에 DB 쿼리가 섞임
- 비즈니스 로직이 API와 강하게 결합
- 테스트하기 어려움 (DB 필요)

