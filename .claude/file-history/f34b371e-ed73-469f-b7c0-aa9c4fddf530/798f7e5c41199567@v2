class HTTPRequest:
    """HTTP 요청 파싱"""

    def __init__(self, raw_request: str):
        self.raw = raw_request
        self.method = ''
        self.path = ''
        self.headers = {}
        self.body = ''
        self.query_params = {}
        self._parse()

    def _parse(self):
        """요청 파싱"""
        lines = self.raw.split('\r\n')

        if not lines:
            return

        # 【 첫 줄: METHOD PATH HTTP/VERSION 】
        first_line = lines[0].split()
        if len(first_line) >= 2:
            self.method = first_line[0]
            request_target = first_line[1]

            # 쿼리 문자열 파싱
            if '?' in request_target:
                self.path, query_string = request_target.split('?', 1)
                self.query_params = parse_qs(query_string)
            else:
                self.path = request_target

        # 【 헤더 파싱 】
        header_end = -1
        for i, line in enumerate(lines[1:], 1):
            if line == '':
                header_end = i
                break
            if ':' in line:
                key, value = line.split(':', 1)
                self.headers[key.strip()] = value.strip()

        # 【 본문 파싱 】
        if header_end >= 0 and header_end < len(lines) - 1:
            self.body = '\r\n'.join(lines[header_end + 1:])


class HTTPResponse:
    """HTTP 응답 생성"""

    def __init__(self, status_code: int, reason: str, headers: Dict = None, body: str = ''):
        self.status_code = status_code
        self.reason = reason
        self.headers = headers or {}
        self.body = body

    def to_bytes(self) -> bytes:
        """응답을 바이트로 변환"""
        # 【 상태 줄 】
        status_line = f'HTTP/1.1 {self.status_code} {self.reason}\r\n'

        # 【 헤더 】
        self.headers['Content-Type'] = 'application/json; charset=utf-8'
        self.headers['Content-Length'] = str(len(self.body.encode()))
        self.headers['Connection'] = 'close'

        headers_str = '\r\n'.join([f'{k}: {v}' for k, v in self.headers.items()])

        # 【 응답 】
        response = f'{status_line}{headers_str}\r\n\r\n{self.body}'

        return response.encode('utf-8')


class GogsWebServer:
    """Gogs 웹 서버"""

    def __init__(self, host: str = '0.0.0.0', port: int = 8000, db_file: str = 'gogs_research.db'):
        self.host = host
        self.port = port
        self.running = False

        # 【 컴포넌트 초기화 】
        self.db = GogsDatabase(db_file)
        self.auth = AuthManager(self.db)
        self.api = APIHandler(self.db, self.auth)
        self.middleware = AuthMiddleware(self.auth)

        self.socket = None
        self.client_count = 0

    def start(self):
        """서버 시작"""
        self.socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        self.socket.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        self.socket.bind((self.host, self.port))
        self.socket.listen(5)
        self.running = True

        print(f'\n{"=" * 70}')
        print(f'🚀 Gogs 웹 서버 시작')
        print(f'{"=" * 70}')
        print(f'주소: http://{self.host}:{self.port}')
        print(f'데이터베이스: {self.db.db_file}')
        print(f'{"=" * 70}\n')

        try:
            while self.running:
                try:
                    client_socket, client_address = self.socket.accept()
                    self.client_count += 1

                    # 클라이언트를 별도 스레드에서 처리
                    client_thread = threading.Thread(
                        target=self._handle_client,
                        args=(client_socket, client_address, self.client_count),
                        daemon=True
                    )
                    client_thread.start()

                except KeyboardInterrupt:
                    break
                except Exception as e:
                    print(f'❌ 오류: {e}')

        except KeyboardInterrupt:
            pass
        finally:
            self.stop()

    def stop(self):
        """서버 정지"""
        self.running = False
        if self.socket:
            self.socket.close()
        print(f'\n👋 서버가 정지되었습니다.')

    def _handle_client(self, client_socket: socket.socket, client_address: Tuple,
                      client_id: int):
        """클라이언트 요청 처리"""
        try:
            # 【 요청 수신 】
            raw_request = b''
            while True:
                chunk = client_socket.recv(4096)
                if not chunk:
                    break
                raw_request += chunk

                # 헤더 끝 감지
                if b'\r\n\r\n' in raw_request:
                    break

            if not raw_request:
                return

            request_str = raw_request.decode('utf-8', errors='ignore')
            http_request = HTTPRequest(request_str)

            print(f'[{client_id}] {http_request.method} {http_request.path} (from {client_address[0]}:{client_address[1]})')

            # 【 요청 처리 】
            status, response_body = self.api.handle_request(
                http_request.method,
                http_request.path,
                http_request.headers,
                http_request.body
            )

            # 【 응답 전송 】
            http_response = HTTPResponse(
                status.code,
                status.reason,
                body=response_body
            )

            client_socket.sendall(http_response.to_bytes())
            print(f'[{client_id}] ✓ {status.code} {status.reason}')

        except Exception as e:
            print(f'[{client_id}] ❌ 오류: {e}')

            # 에러 응답 전송
            error_response = HTTPResponse(
                500,
                'Internal Server Error',
                body=self.api.json_response(
                    HTTPStatusCode.INTERNAL_SERVER_ERROR,
                    message=str(e)
                )
            )

            try:
                client_socket.sendall(error_response.to_bytes())
            except:
                pass

        finally:
            client_socket.close()

