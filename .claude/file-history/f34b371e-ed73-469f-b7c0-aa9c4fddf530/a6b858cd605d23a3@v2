"""
v2.3 테스트: 상속
"""

from src.v2_3_inheritance import GogsRobot, FlyingGogsRobot, inheritance_demo


def test_inheritance_demo_returns_dict():
    """반환값이 딕셔너리"""
    result = inheritance_demo()
    assert isinstance(result, dict)


def test_parent_class_creation():
    """부모 클래스 객체 생성"""
    bot = GogsRobot("테스트봇")
    assert bot.name == "테스트봇"
    assert hasattr(bot, "work")


def test_child_class_creation():
    """자식 클래스 객체 생성"""
    bot = FlyingGogsRobot("날아봇", 1000)
    assert bot.name == "날아봇"
    assert bot.altitude == 1000


def test_inheritance_relationship():
    """상속 관계 확인"""
    flying_bot = FlyingGogsRobot("스카이봇", 500)
    assert isinstance(flying_bot, GogsRobot)
    assert isinstance(flying_bot, FlyingGogsRobot)


def test_child_inherits_parent_attributes():
    """자식 클래스가 부모의 속성을 물려받음"""
    flying_bot = FlyingGogsRobot("스카이봇", 500)
    assert hasattr(flying_bot, "name")
    assert flying_bot.name == "스카이봇"


def test_child_inherits_parent_methods():
    """자식 클래스가 부모의 메서드를 물려받음"""
    flying_bot = FlyingGogsRobot("스카이봇", 500)
    assert hasattr(flying_bot, "work")
    assert callable(flying_bot.work)


def test_method_overriding():
    """메서드 오버라이딩: 자식의 work()는 부모와 다름"""
    basic_bot = GogsRobot("지상봇")
    flying_bot = FlyingGogsRobot("스카이봇", 500)

    # 두 로봇의 work() 메서드는 다르게 동작
    # (직접 비교는 어려우므로 type으로 확인)
    assert type(basic_bot) != type(flying_bot)
    assert callable(basic_bot.work)
    assert callable(flying_bot.work)


def test_child_class_new_method():
    """자식 클래스의 새로운 메서드"""
    flying_bot = FlyingGogsRobot("스카이봇", 500)
    assert hasattr(flying_bot, "fly")
    assert callable(flying_bot.fly)


def test_child_class_specific_attribute():
    """자식 클래스의 고유 속성"""
    flying_bot = FlyingGogsRobot("스카이봇", 500)
    assert hasattr(flying_bot, "altitude")
    assert flying_bot.altitude == 500


def test_super_initialization():
    """super()를 통한 부모 초기화"""
    flying_bot = FlyingGogsRobot("스카이봇", 500)
    # super().__init__이 제대로 호출되면 name이 설정됨
    assert flying_bot.name == "스카이봇"
    assert hasattr(flying_bot, "altitude")


def test_multiple_inheritance_instances():
    """여러 인스턴스 생성 및 독립성 확인"""
    basic1 = GogsRobot("지상1")
    basic2 = GogsRobot("지상2")
    flying1 = FlyingGogsRobot("날기1", 100)
    flying2 = FlyingGogsRobot("날기2", 200)

    assert basic1.name == "지상1"
    assert basic2.name == "지상2"
    assert flying1.altitude == 100
    assert flying2.altitude == 200

    # 각 인스턴스는 독립적
    assert basic1 is not basic2
    assert flying1 is not flying2
    assert basic1 is not flying1


def test_demo_result_structure():
    """데모 반환값 구조 확인"""
    result = inheritance_demo()

    assert "basic_bot" in result
    assert "flying_bot" in result
    assert "basic_bot_name" in result
    assert "flying_bot_name" in result
    assert "flying_bot_altitude" in result

    assert result["basic_bot_name"] == "지상봇"
    assert result["flying_bot_name"] == "스카이봇"
    assert result["flying_bot_altitude"] == 500


def test_parent_child_different_behavior():
    """부모와 자식의 다른 행동 확인"""
    basic_bot = GogsRobot("기본")
    flying_bot = FlyingGogsRobot("하늘", 750)

    # 타입 확인으로 다름을 증명
    assert type(basic_bot).__name__ == "GogsRobot"
    assert type(flying_bot).__name__ == "FlyingGogsRobot"

    # 부모 타입으로도 확인 가능
    assert isinstance(basic_bot, GogsRobot)
    assert isinstance(flying_bot, GogsRobot)
    assert not isinstance(basic_bot, FlyingGogsRobot)
    assert isinstance(flying_bot, FlyingGogsRobot)


def test_child_has_both_parent_and_child_methods():
    """자식이 부모와 자신의 메서드를 모두 가짐"""
    flying_bot = FlyingGogsRobot("스카이봇", 500)

    # 부모의 메서드 (오버라이딩됨)
    assert hasattr(flying_bot, "work")

    # 자신의 메서드
    assert hasattr(flying_bot, "fly")

    # 두 메서드 모두 호출 가능
    assert callable(flying_bot.work)
    assert callable(flying_bot.fly)
