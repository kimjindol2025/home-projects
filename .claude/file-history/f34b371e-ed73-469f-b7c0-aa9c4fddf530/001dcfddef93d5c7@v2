def read_large_file(filepath: str, chunk_size: int = 1024) -> Generator[str, None, None]:
    """대용량 파일을 청크 단위로 읽기"""
    with open(filepath, "r", errors="ignore") as f:
        while True:
            chunk = f.read(chunk_size)
            if not chunk:
                break
            yield chunk


def process_csv_records(records_gen) -> Generator[dict, None, None]:
    """CSV 레코드 처리 (헤더 스킵)"""
    header = None
    for i, record in enumerate(records_gen):
        if i == 0:
            header = record.strip().split(",")
        else:
            values = record.strip().split(",")
            if len(values) == len(header):
                yield dict(zip(header, values))


def batch_generator(iterable, batch_size: int) -> Generator[list, None, None]:
    """배치 단위로 데이터 묶기"""
    batch = []
    for item in iterable:
        batch.append(item)
        if len(batch) == batch_size:
            yield batch
            batch = []
    if batch:
        yield batch


