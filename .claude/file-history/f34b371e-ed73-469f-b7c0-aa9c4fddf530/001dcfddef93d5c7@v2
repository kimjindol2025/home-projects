def simple_generator(n: int) -> Generator[int, None, None]:
    """기본 제너레이터: 0부터 n-1까지 생성"""
    i = 0
    while i < n:
        yield i
        i += 1


def range_generator(start: int, end: int, step: int = 1) -> Generator[int, None, None]:
    """range를 제너레이터로 구현"""
    current = start
    while current < end:
        yield current
        current += step


def fibonacci_generator(max_value: int = None) -> Generator[int, None, None]:
    """피보나치 수열 제너레이터"""
    a, b = 0, 1
    while max_value is None or a <= max_value:
        yield a
        a, b = b, a + b


# ============================================================================
# [3] 메모리 효율성 증명
# ============================================================================

class MemoryComparison:
    """리스트 vs 제너레이터 메모리 비교"""

    @staticmethod
    def list_approach(n: int) -> list:
        """리스트로 숫자 생성"""
        return list(range(n))

    @staticmethod
    def generator_approach(n: int) -> Generator[int, None, None]:
        """제너레이터로 숫자 생성"""
        for i in range(n):
            yield i

    @staticmethod
    def compare_memory(n: int) -> dict:
        """메모리 사용량 비교"""
        # 리스트 크기
        list_data = MemoryComparison.list_approach(n)
        list_size = sys.getsizeof(list_data)

        # 제너레이터 크기
        gen_data = MemoryComparison.generator_approach(n)
        gen_size = sys.getsizeof(gen_data)

        return {
            "n": n,
            "list_size_bytes": list_size,
            "list_size_mb": list_size / (1024 * 1024),
            "generator_size_bytes": gen_size,
            "generator_size_mb": gen_size / (1024 * 1024),
            "efficiency_ratio": list_size / gen_size,
            "memory_saved_mb": (list_size - gen_size) / (1024 * 1024),
        }


