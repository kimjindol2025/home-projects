# [7] yield from (위임)
# ============================================================================

def flatten_with_yield_from(nested_list) -> Generator[Any, None, None]:
    """yield from으로 중첩 리스트 평탄화"""
    for item in nested_list:
        if isinstance(item, list):
            yield from flatten_with_yield_from(item)
        else:
            yield item


def merge_generators(*generators) -> Generator[Any, None, None]:
    """여러 제너레이터를 하나로 병합"""
    for gen in generators:
        yield from gen


