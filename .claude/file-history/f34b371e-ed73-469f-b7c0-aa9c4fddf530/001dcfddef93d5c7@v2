# ============================================================================
# [5] 무한 수열
# ============================================================================

def infinite_counter(start: int = 0) -> Generator[int, None, None]:
    """무한 카운터"""
    n = start
    while True:
        yield n
        n += 1


def infinite_fibonacci() -> Generator[int, None, None]:
    """무한 피보나치 수열"""
    a, b = 0, 1
    while True:
        yield a
        a, b = b, a + b


def cycle(iterable) -> Generator[Any, None, None]:
    """무한 반복"""
    while True:
        for item in iterable:
            yield item


