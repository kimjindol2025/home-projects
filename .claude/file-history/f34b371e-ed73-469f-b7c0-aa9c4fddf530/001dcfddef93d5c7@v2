def accumulator() -> Generator[int, int, int]:
    """값을 받아서 누적하는 코루틴"""
    total = 0
    while True:
        value = yield total
        if value is None:
            break
        total += value


def average_calculator() -> Generator[float, float, None]:
    """평균을 계산하는 코루틴"""
    total = 0
    count = 0
    while True:
        value = yield total / count if count > 0 else 0
        if value is None:
            break
        total += value
        count += 1


