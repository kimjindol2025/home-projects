def data_pipeline() -> dict:
    """데이터 처리 파이프라인"""

    def numbers(n):
        """숫자 생성"""
        for i in range(n):
            yield i

    def multiply_by_two(gen):
        """2배로 증가"""
        for x in gen:
            yield x * 2

    def filter_even(gen):
        """짝수만 필터링"""
        for x in gen:
            if x % 4 == 0:
                yield x

    def limit(gen, max_count):
        """개수 제한"""
        count = 0
        for x in gen:
            if count >= max_count:
                break
            yield x
            count += 1

    # 파이프라인 구성
    pipeline = limit(
        filter_even(multiply_by_two(numbers(100))),
        10
    )

    return {
        "pipeline_result": list(pipeline),
        "description": "숫자 생성 → 2배 증가 → 4의 배수 필터링 → 10개 제한",
    }


