"""
[Python High-School v2.1] 정교한 예외 처리 시스템
주제: "실패를 데이터로 전환하는 기술"

예외 처리의 4단계 구성:
1. try: 위험할 수 있는 실험 코드
2. except: 특정 사고(에러) 발생 시 구조 대처
3. else: 사고 없이 완벽히 성공했을 때만 실행
4. finally: 성공/실패 무관하게 반드시 실행 (정리)
"""

import logging
from datetime import datetime
from typing import Optional, Any


# ============================================================================
# [1] 사용자 정의 예외 (Custom Exceptions)
# ============================================================================

class GogsError(Exception):
    """모든 Gogs 시스템 에러의 기본 클래스"""
    pass


class DataValidationError(GogsError):
    """데이터 검증 실패"""
    pass


class ExperimentError(GogsError):
    """실험 수행 중 발생하는 에러"""
    pass


class SafetyViolationError(GogsError):
    """안전 규칙 위반"""
    pass


# ============================================================================
# [2] 로그 기록 시스템 (Error Logging System)
# ============================================================================

class ErrorLogger:
    """실패한 실험을 기록으로 남기는 '증명의 탑'"""

    def __init__(self, log_file: str = "experiment_log.txt"):
        self.log_file = log_file
        self.error_records = []

        # 파일 로그 설정
        logging.basicConfig(
            filename=log_file,
            level=logging.INFO,
            format='%(asctime)s | %(levelname)s | %(message)s',
            datefmt='%Y-%m-%d %H:%M:%S'
        )

    def log_success(self, message: str) -> None:
        """성공 기록"""
        logging.info(f"✅ SUCCESS: {message}")
        print(f"✅ 기록됨: {message}")

    def log_error(self, error_type: str, message: str, data: Any = None) -> None:
        """에러 기록"""
        record = {
            "timestamp": datetime.now().isoformat(),
            "error_type": error_type,
            "message": message,
            "data": data
        }
        self.error_records.append(record)

        full_message = f"{error_type}: {message}"
        if data is not None:
            full_message += f" (데이터: {data})"

        logging.error(full_message)
        print(f"🚨 기록됨: {full_message}")

    def log_warning(self, message: str) -> None:
        """경고 기록"""
        logging.warning(f"⚠️  WARNING: {message}")
        print(f"⚠️  경고 기록됨: {message}")

    def get_error_summary(self) -> dict:
        """에러 통계"""
        return {
            "total_errors": len(self.error_records),
            "records": self.error_records,
            "log_file": self.log_file
        }


# ============================================================================
# [3] 4단계 예외 처리: Try-Except-Else-Finally
# ============================================================================

def run_experiment(data_value: Any, logger: Optional[ErrorLogger] = None) -> Optional[float]:
    """
    4단계 예외 처리 데모

    try: 위험한 실험 코드
    except: 특정 에러 처리
    else: 성공했을 때만 실행
    finally: 항상 정리 작업
    """
    if logger is None:
        logger = ErrorLogger()

    try:
        print(f"\n[실험 시작] 입력 데이터: {data_value}")

        # 1단계: 데이터 검증
        if not isinstance(data_value, (int, float)):
            raise DataValidationError(f"데이터는 숫자여야 합니다 (입력: {type(data_value).__name__})")

        # 2단계: 안전 범위 검증
        if data_value > 1000:
            raise SafetyViolationError("입력값이 안전 범위(1000)를 초과했습니다")

        # 3단계: 연산 시도
        process = 100 / data_value

    except ZeroDivisionError as e:
        print("🚨 사고 발생: 0으로 나눌 수 없습니다")
        logger.log_error("ZeroDivisionError", "0으로 나누기 시도", data_value)
        return 0

    except DataValidationError as e:
        print(f"🚨 규정 위반: {e}")
        logger.log_error("DataValidationError", str(e), data_value)
        return None

    except SafetyViolationError as e:
        print(f"🚨 안전 위반: {e}")
        logger.log_error("SafetyViolationError", str(e), data_value)
        return None

    except Exception as e:
        print(f"❓ 미확인 사고: {type(e).__name__} - {e}")
        logger.log_error("UnknownError", str(e), data_value)
        return None

    else:
        # ✅ 축하! 모든 except 블록을 거치지 않고 성공했습니다
        print(f"✅ 실험 성공: 결과값은 {process:.2f}입니다")
        logger.log_success(f"100 / {data_value} = {process:.2f}")
        return process

    finally:
        # 🧹 성공/실패 무관하게 항상 정리 작업
        print("🧹 시스템 유지보수: 실험 장비를 정리합니다")


# ============================================================================
# [4] LBYL vs EAFP: 방어적 설계의 두 가지 패러다임
# ============================================================================

def method_lbyl(data_value: Any) -> Optional[float]:
    """
    LBYL (Look Before You Leap)
    "뛰기 전에 살펴라" - if문으로 먼저 체크하는 방식
    """
    print("\n--- LBYL 방식 (미리 체크) ---")

    # 문제가 될 만한 것들을 먼저 전부 체크
    if not isinstance(data_value, (int, float)):
        print("❌ 타입 체크 실패")
        return None

    if data_value > 1000:
        print("❌ 범위 체크 실패")
        return None

    if data_value == 0:
        print("❌ 0 체크 실패")
        return 0

    # 모든 체크를 통과한 후에야 실행
    result = 100 / data_value
    print(f"✅ 계산 성공: {result:.2f}")
    return result


def method_eafp(data_value: Any) -> Optional[float]:
    """
    EAFP (Easier to Ask for Forgiveness than Permission)
    "허락보다 용서 구하기가 쉽다" - try하고 실패하면 처리
    파이썬이 권장하는 방식!
    """
    print("\n--- EAFP 방식 (일단 시도) ---")

    try:
        result = 100 / data_value
        print(f"✅ 계산 성공: {result:.2f}")
        return result
    except (TypeError, ZeroDivisionError) as e:
        print(f"❌ 에러 처리됨: {type(e).__name__}")
        return None


# ============================================================================
# [5] 복잡한 데이터 처리: 예외 처리로 견고함을 증명하기
# ============================================================================

class ResearchDataValidator:
    """연구 데이터를 검증하고 기록하는 시스템"""

    def __init__(self, logger: Optional[ErrorLogger] = None):
        self.logger = logger or ErrorLogger()
        self.valid_records = []
        self.invalid_records = []

    def validate_temperature(self, temp: Any) -> bool:
        """온도 데이터 검증"""
        try:
            temp_value = float(temp)

            if temp_value < -273.15:  # 절대영도
                raise DataValidationError("절대영도보다 낮을 수 없습니다")

            if temp_value > 1000:
                self.logger.log_warning(f"매우 높은 온도: {temp_value}K")

            return True

        except ValueError:
            self.logger.log_error("ValueError", f"온도는 숫자여야 합니다", temp)
            return False
        except DataValidationError as e:
            self.logger.log_error("DataValidationError", str(e), temp)
            return False

    def validate_pressure(self, pressure: Any) -> bool:
        """기압 데이터 검증"""
        try:
            pressure_value = float(pressure)

            if pressure_value < 0:
                raise DataValidationError("기압은 음수일 수 없습니다")

            if pressure_value > 10**6:  # 1 MPa
                self.logger.log_warning(f"매우 높은 기압: {pressure_value} Pa")

            return True

        except ValueError:
            self.logger.log_error("ValueError", f"기압은 숫자여야 합니다", pressure)
            return False
        except DataValidationError as e:
            self.logger.log_error("DataValidationError", str(e), pressure)
            return False

    def process_experiment_data(self, data_dict: dict) -> dict:
        """
        실험 데이터 처리
        예외 처리로 부분 실패를 기록하면서 진행
        """
        results = {
            "valid": [],
            "invalid": [],
            "summary": {}
        }

        for idx, record in enumerate(data_dict.items()):
            try:
                key, (temp, pressure) = record

                # 개별 검증
                temp_valid = self.validate_temperature(temp)
                pressure_valid = self.validate_pressure(pressure)

                if temp_valid and pressure_valid:
                    results["valid"].append({
                        "id": key,
                        "temp": float(temp),
                        "pressure": float(pressure)
                    })
                    self.logger.log_success(f"기록 {key} 검증 완료")
                else:
                    results["invalid"].append({
                        "id": key,
                        "reason": f"temp_valid={temp_valid}, pressure_valid={pressure_valid}"
                    })

            except Exception as e:
                self.logger.log_error("ProcessingError", f"기록 처리 실패: {e}", key)
                results["invalid"].append({"id": key, "reason": str(e)})

            finally:
                # 각 기록 처리 후 정리
                pass

        # 요약
        results["summary"] = {
            "total": len(data_dict),
            "valid_count": len(results["valid"]),
            "invalid_count": len(results["invalid"]),
            "success_rate": f"{(len(results['valid']) / len(data_dict) * 100):.1f}%"
        }

        return results


# ============================================================================
# [6] 데모 실행
# ============================================================================

def advanced_exception_demo():
    """심화된 예외 처리 시스템 데모"""
    print("\n" + "="*70)
    print("🔬 [Python v2.1 심화] 정교한 예외 처리 시스템")
    print("주제: 실패를 데이터로 전환하는 기술")
    print("="*70)

    # 로거 생성
    logger = ErrorLogger("experiment_log.txt")

    # --- 1. 4단계 예외 처리 ---
    print("\n" + "─"*70)
    print("[1] 4단계 예외 처리 (try-except-else-finally)")
    print("─"*70)

    test_cases = [20, 0, "gogs", 2000, 5]
    for test in test_cases:
        run_experiment(test, logger)

    # --- 2. LBYL vs EAFP 비교 ---
    print("\n" + "─"*70)
    print("[2] LBYL vs EAFP: 방어적 설계의 두 가지 패러다임")
    print("─"*70)

    test_data = 50
    print(f"\n같은 입력 ({test_data})에 대해:")
    method_lbyl(test_data)
    method_eafp(test_data)

    # --- 3. 복잡한 데이터 검증 ---
    print("\n" + "─"*70)
    print("[3] 복잡한 데이터 검증: 온도/기압 실험 기록")
    print("─"*70)

    validator = ResearchDataValidator(logger)

    experiment_data = {
        "exp_001": (298.15, 101325),    # 정상
        "exp_002": ("25C", 101325),     # 온도 형식 에러
        "exp_003": (-300, 101325),      # 절대영도 위반
        "exp_004": (373.15, -1),        # 기압 음수
        "exp_005": (1500, 101325),      # 높은 온도 경고
        "exp_006": (500, 1000000),      # 높은 기압 경고
    }

    print("\n실험 데이터 처리 중...\n")
    results = validator.process_experiment_data(experiment_data)

    print(f"\n📊 검증 결과:")
    print(f"  총 기록: {results['summary']['total']}")
    print(f"  성공한 기록: {results['summary']['valid_count']}")
    print(f"  실패한 기록: {results['summary']['invalid_count']}")
    print(f"  성공률: {results['summary']['success_rate']}")

    print(f"\n✅ 유효한 기록:")
    for record in results["valid"]:
        print(f"  {record['id']}: {record['temp']}K, {record['pressure']} Pa")

    print(f"\n❌ 무효한 기록:")
    for record in results["invalid"]:
        print(f"  {record['id']}: {record['reason']}")

    # --- 4. 에러 로그 요약 ---
    print("\n" + "─"*70)
    print("[4] 에러 기록 요약 (저장 필수)")
    print("─"*70)

    error_summary = logger.get_error_summary()
    print(f"\n📋 총 에러 건수: {error_summary['total_errors']}")
    print(f"📁 로그 파일: {error_summary['log_file']}")
    print(f"📝 에러 기록:")
    for record in error_summary["records"]:
        print(f"  [{record['error_type']}] {record['message']}")

    print("\n저장 필수 너는 기록이 증명이다 gogs")


if __name__ == "__main__":
    advanced_exception_demo()
