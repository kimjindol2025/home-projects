class CleanCodePrinciples:
    """클린 코드: 읽기 쉽고 유지보수하기 좋은 코드"""

    @staticmethod
    def meaningful_names_example() -> Dict[str, Any]:
        """의미 있는 이름 사용"""
        # 나쁜 예
        d = []  # 날짜?
        temp = []  # 임시?

        # 좋은 예
        dates = []
        user_ids = []
        return {"principle": "Meaningful Names", "applied": True}

    @staticmethod
    def small_functions_example() -> Dict[str, Any]:
        """작은 함수 작성"""
        def validate_and_save(user_data: Dict) -> bool:
            # 하나의 책임: 유효성 검사 후 저장
            if not user_data.get("email"):
                return False
            # 저장 로직
            return True

        return {"principle": "Small Functions", "applied": True}

    @staticmethod
    def error_handling_example() -> Dict[str, Any]:
        """예외 처리"""
        try:
            data = {"value": 10}
            result = data.get("value") / 0
        except ZeroDivisionError:
            return {"error": "Division by zero"}
        except Exception as e:
            return {"error": str(e)}

        return {"principle": "Error Handling", "applied": True}

    @staticmethod
    def refactoring_example() -> Dict[str, Any]:
        """리팩토링: 기능 유지, 구조 개선"""
        # Before: 복잡한 함수
        def calculate_invoice_total_bad(items):
            total = 0
            for item in items:
                total += item['price'] * item['quantity']
            if total > 100:
                total *= 0.9
            return total

        # After: 단순하고 명확한 함수
        def calculate_subtotal(items):
            return sum(item['price'] * item['quantity'] for item in items)

        def apply_discount(total):
            return total * 0.9 if total > 100 else total

        def calculate_invoice_total_good(items):
            subtotal = calculate_subtotal(items)
            return apply_discount(subtotal)

        return {
            "principle": "Refactoring",
            "old_result": calculate_invoice_total_bad([{"price": 60, "quantity": 2}]),
            "new_result": calculate_invoice_total_good([{"price": 60, "quantity": 2}])
        }


