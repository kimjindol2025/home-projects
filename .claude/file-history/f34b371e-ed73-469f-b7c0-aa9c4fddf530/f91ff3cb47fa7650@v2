class AdapterPattern:
    """어댑터: 호환되지 않는 인터페이스를 연결"""

    class LegacyPrinter:
        def print_old(self, text: str) -> str:
            return f"[OLD] {text}"

    class ModernPrinter(ABC):
        @abstractmethod
        def print(self, text: str) -> str:
            pass

    class PrinterAdapter(ModernPrinter):
        def __init__(self, legacy: 'AdapterPattern.LegacyPrinter'):
            self.legacy = legacy

        def print(self, text: str) -> str:
            return self.legacy.print_old(text)

    @staticmethod
    def demo() -> Dict[str, Any]:
        legacy = AdapterPattern.LegacyPrinter()
        adapter = AdapterPattern.PrinterAdapter(legacy)
        return {
            "pattern": "Adapter",
            "output": adapter.print("Hello World")
        }


class BridgePattern:
    """브릿지: 추상화와 구현을 분리"""

    class Color(ABC):
        @abstractmethod
        def fill(self) -> str:
            pass

    class RedColor(Color):
        def fill(self) -> str:
            return "Red"

    class BlueColor(Color):
        def fill(self) -> str:
            return "Blue"

    class Shape(ABC):
        def __init__(self, color: 'BridgePattern.Color'):
            self.color = color

        @abstractmethod
        def draw(self) -> str:
            pass

    class Circle(Shape):
        def draw(self) -> str:
            return f"Circle filled with {self.color.fill()}"

    class Rectangle(Shape):
        def draw(self) -> str:
            return f"Rectangle filled with {self.color.fill()}"

    @staticmethod
    def demo() -> Dict[str, Any]:
        red_circle = BridgePattern.Circle(BridgePattern.RedColor())
        return {
            "pattern": "Bridge",
            "result": red_circle.draw()
        }


class CompositePattern:
    """컴포지트: 부분-전체 관계를 트리 구조로 표현"""

    class FileSystemItem(ABC):
        @abstractmethod
        def get_size(self) -> int:
            pass

    class File(FileSystemItem):
        def __init__(self, name: str, size: int):
            self.name = name
            self.size = size

        def get_size(self) -> int:
            return self.size

    class Directory(FileSystemItem):
        def __init__(self, name: str):
            self.name = name
            self.items: List['CompositePattern.FileSystemItem'] = []

        def add_item(self, item: 'CompositePattern.FileSystemItem') -> None:
            self.items.append(item)

        def get_size(self) -> int:
            return sum(item.get_size() for item in self.items)

    @staticmethod
    def demo() -> Dict[str, Any]:
        root = CompositePattern.Directory("root")
        root.add_item(CompositePattern.File("file1.txt", 100))
        root.add_item(CompositePattern.File("file2.txt", 200))
        return {
            "pattern": "Composite",
            "total_size": root.get_size()
        }


class DecoratorPattern:
    """데코레이터: 객체에 동적으로 기능 추가"""

    class Coffee(ABC):
        @abstractmethod
        def get_cost(self) -> float:
            pass

        @abstractmethod
        def get_description(self) -> str:
            pass

    class SimpleCoffee(Coffee):
        def get_cost(self) -> float:
            return 2.0

        def get_description(self) -> str:
            return "Coffee"

    class CoffeeDecorator(Coffee):
        def __init__(self, coffee: 'DecoratorPattern.Coffee'):
            self.coffee = coffee

    class MilkDecorator(CoffeeDecorator):
        def get_cost(self) -> float:
            return self.coffee.get_cost() + 0.5

        def get_description(self) -> str:
            return self.coffee.get_description() + " with Milk"

    class SugarDecorator(CoffeeDecorator):
        def get_cost(self) -> float:
            return self.coffee.get_cost() + 0.3

        def get_description(self) -> str:
            return self.coffee.get_description() + " with Sugar"

    @staticmethod
    def demo() -> Dict[str, Any]:
        coffee = (DecoratorPattern.SugarDecorator(
            DecoratorPattern.MilkDecorator(
                DecoratorPattern.SimpleCoffee()
            )
        ))
        return {
            "pattern": "Decorator",
            "description": coffee.get_description(),
            "cost": coffee.get_cost()
        }


class FacadePattern:
    """파사드: 복잡한 서브시스템을 단순한 인터페이스로 제공"""

    class CPU:
        def execute(self) -> str:
            return "CPU executing"

    class Memory:
        def allocate(self) -> str:
            return "Memory allocated"

    class HardDrive:
        def load(self) -> str:
            return "HDD loading"

    class ComputerFacade:
        def __init__(self):
            self.cpu = FacadePattern.CPU()
            self.memory = FacadePattern.Memory()
            self.hdd = FacadePattern.HardDrive()

        def start(self) -> List[str]:
            return [
                self.memory.allocate(),
                self.hdd.load(),
                self.cpu.execute()
            ]

    @staticmethod
    def demo() -> Dict[str, Any]:
        computer = FacadePattern.ComputerFacade()
        return {
            "pattern": "Facade",
            "startup": computer.start()
        }


class ProxyPattern:
    """프록시: 다른 객체에 대한 접근을 제어"""

    class Image(ABC):
        @abstractmethod
        def display(self) -> str:
            pass

    class RealImage(Image):
        def __init__(self, path: str):
            self.path = path

        def display(self) -> str:
            return f"Displaying image: {self.path}"

    class ImageProxy(Image):
        def __init__(self, path: str):
            self.path = path
            self.real_image = None

        def display(self) -> str:
            if self.real_image is None:
                self.real_image = ProxyPattern.RealImage(self.path)
            return self.real_image.display()

    @staticmethod
    def demo() -> Dict[str, Any]:
        proxy = ProxyPattern.ImageProxy("image.jpg")
        return {
            "pattern": "Proxy",
            "result": proxy.display()
        }


class FlyweightPattern:
    """플라이웨이트: 공유 가능한 상태를 분리하여 메모리 절약"""

    class Character:
        def __init__(self, name: str, font: str):
            self.name = name
            self.font = font

    class CharacterFactory:
        def __init__(self):
            self.characters: Dict[str, 'FlyweightPattern.Character'] = {}

        def get_character(self, name: str, font: str) -> 'FlyweightPattern.Character':
            key = f"{name}:{font}"
            if key not in self.characters:
                self.characters[key] = FlyweightPattern.Character(name, font)
            return self.characters[key]

        def get_count(self) -> int:
            return len(self.characters)

    @staticmethod
    def demo() -> Dict[str, Any]:
        factory = FlyweightPattern.CharacterFactory()
        c1 = factory.get_character("A", "Arial")
        c2 = factory.get_character("A", "Arial")
        c3 = factory.get_character("B", "Arial")
        return {
            "pattern": "Flyweight",
            "same_reference": c1 is c2,
            "total_unique": factory.get_count()
        }


