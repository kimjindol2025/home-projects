class ObserverPattern:
    """옵저버: 객체의 상태 변화를 여러 객체에 알림"""

    class Subject:
        def __init__(self):
            self._observers: List['ObserverPattern.Observer'] = []
            self._state = None

        def attach(self, observer: 'ObserverPattern.Observer') -> None:
            self._observers.append(observer)

        def detach(self, observer: 'ObserverPattern.Observer') -> None:
            self._observers.remove(observer)

        def notify(self) -> None:
            for observer in self._observers:
                observer.update(self._state)

        def set_state(self, state: Any) -> None:
            self._state = state
            self.notify()

        def get_state(self) -> Any:
            return self._state

    class Observer(ABC):
        @abstractmethod
        def update(self, state: Any) -> None:
            pass

    class ConcreteObserver(Observer):
        def __init__(self, name: str):
            self.name = name
            self.state = None

        def update(self, state: Any) -> None:
            self.state = state

    @staticmethod
    def demo() -> Dict[str, Any]:
        subject = ObserverPattern.Subject()
        obs1 = ObserverPattern.ConcreteObserver("Observer1")
        obs2 = ObserverPattern.ConcreteObserver("Observer2")

        subject.attach(obs1)
        subject.attach(obs2)
        subject.set_state("New State")

        return {
            "pattern": "Observer",
            "observer1_state": obs1.state,
            "observer2_state": obs2.state
        }


class StrategyPattern:
    """전략: 알고리즘을 캡슐화하여 선택 가능하게"""

    class SortStrategy(ABC):
        @abstractmethod
        def sort(self, data: List[int]) -> List[int]:
            pass

    class BubbleSort(SortStrategy):
        def sort(self, data: List[int]) -> List[int]:
            arr = data.copy()
            for i in range(len(arr)):
                for j in range(len(arr) - 1 - i):
                    if arr[j] > arr[j + 1]:
                        arr[j], arr[j + 1] = arr[j + 1], arr[j]
            return arr

    class QuickSort(SortStrategy):
        def sort(self, data: List[int]) -> List[int]:
            if len(data) <= 1:
                return data
            pivot = data[0]
            left = [x for x in data[1:] if x < pivot]
            right = [x for x in data[1:] if x >= pivot]
            return self.sort(left) + [pivot] + self.sort(right)

    class Sorter:
        def __init__(self, strategy: 'StrategyPattern.SortStrategy'):
            self.strategy = strategy

        def execute(self, data: List[int]) -> List[int]:
            return self.strategy.sort(data)

    @staticmethod
    def demo() -> Dict[str, Any]:
        data = [5, 2, 8, 1, 9]
        sorter = StrategyPattern.Sorter(StrategyPattern.QuickSort())
        return {
            "pattern": "Strategy",
            "result": sorter.execute(data)
        }


class CommandPattern:
    """커맨드: 요청을 객체로 캡슐화"""

    class Command(ABC):
        @abstractmethod
        def execute(self) -> str:
            pass

    class TurnOnCommand(Command):
        def __init__(self, device: 'CommandPattern.Device'):
            self.device = device

        def execute(self) -> str:
            return self.device.turn_on()

    class TurnOffCommand(Command):
        def __init__(self, device: 'CommandPattern.Device'):
            self.device = device

        def execute(self) -> str:
            return self.device.turn_off()

    class Device:
        def turn_on(self) -> str:
            return "Device turned on"

        def turn_off(self) -> str:
            return "Device turned off"

    class RemoteControl:
        def __init__(self):
            self.commands: List['CommandPattern.Command'] = []

        def execute_command(self, command: 'CommandPattern.Command') -> str:
            return command.execute()

    @staticmethod
    def demo() -> Dict[str, Any]:
        device = CommandPattern.Device()
        turn_on = CommandPattern.TurnOnCommand(device)
        remote = CommandPattern.RemoteControl()
        return {
            "pattern": "Command",
            "result": remote.execute_command(turn_on)
        }


class StatePattern:
    """상태: 객체의 내부 상태에 따라 행동 변경"""

    class State(ABC):
        @abstractmethod
        def handle(self, context: 'StatePattern.Context') -> str:
            pass

    class ConcreteStateA(State):
        def handle(self, context: 'StatePattern.Context') -> str:
            context.state = StatePattern.ConcreteStateB()
            return "State A handling"

    class ConcreteStateB(State):
        def handle(self, context: 'StatePattern.Context') -> str:
            return "State B handling"

    class Context:
        def __init__(self):
            self.state = StatePattern.ConcreteStateA()

        def request(self) -> str:
            return self.state.handle(self)

    @staticmethod
    def demo() -> Dict[str, Any]:
        context = StatePattern.Context()
        return {
            "pattern": "State",
            "result": context.request()
        }


class IteratorPattern:
    """반복자: 컬렉션의 요소에 순차 접근"""

    class Iterator(ABC):
        @abstractmethod
        def has_next(self) -> bool:
            pass

        @abstractmethod
        def next(self) -> Any:
            pass

    class ArrayIterator(Iterator):
        def __init__(self, array: List[Any]):
            self.array = array
            self.index = 0

        def has_next(self) -> bool:
            return self.index < len(self.array)

        def next(self) -> Any:
            value = self.array[self.index]
            self.index += 1
            return value

    class Collection:
        def __init__(self, items: List[Any]):
            self.items = items

        def create_iterator(self) -> 'IteratorPattern.Iterator':
            return IteratorPattern.ArrayIterator(self.items)

    @staticmethod
    def demo() -> Dict[str, Any]:
        collection = IteratorPattern.Collection([1, 2, 3, 4, 5])
        iterator = collection.create_iterator()
        results = []
        while iterator.has_next():
            results.append(iterator.next())
        return {
            "pattern": "Iterator",
            "result": results
        }


class TemplateMethodPattern:
    """템플릿 메서드: 알고리즘의 뼈대를 정의"""

    class DataProcessor(ABC):
        def process(self, data: List[int]) -> List[int]:
            data = self.read(data)
            data = self.transform(data)
            self.write(data)
            return data

        def read(self, data: List[int]) -> List[int]:
            return data

        @abstractmethod
        def transform(self, data: List[int]) -> List[int]:
            pass

        def write(self, data: List[int]) -> None:
            pass

    class DoubleProcessor(DataProcessor):
        def transform(self, data: List[int]) -> List[int]:
            return [x * 2 for x in data]

    @staticmethod
    def demo() -> Dict[str, Any]:
        processor = TemplateMethodPattern.DoubleProcessor()
        return {
            "pattern": "Template Method",
            "result": processor.process([1, 2, 3, 4, 5])
        }


class ChainOfResponsibilityPattern:
    """책임 연쇄: 요청을 처리할 때까지 체인을 따라 전달"""

    class Handler(ABC):
        def __init__(self, next_handler: Optional['ChainOfResponsibilityPattern.Handler'] = None):
            self.next_handler = next_handler

        @abstractmethod
        def handle(self, request: int) -> str:
            pass

    class ConcreteHandler1(Handler):
        def handle(self, request: int) -> str:
            if request < 10:
                return f"Handler1 processed request {request}"
            elif self.next_handler:
                return self.next_handler.handle(request)
            return "No handler"

    class ConcreteHandler2(Handler):
        def handle(self, request: int) -> str:
            if request < 20:
                return f"Handler2 processed request {request}"
            elif self.next_handler:
                return self.next_handler.handle(request)
            return "No handler"

    @staticmethod
    def demo() -> Dict[str, Any]:
        handler2 = ChainOfResponsibilityPattern.ConcreteHandler2()
        handler1 = ChainOfResponsibilityPattern.ConcreteHandler1(handler2)
        return {
            "pattern": "Chain of Responsibility",
            "result": handler1.handle(15)
        }


class MediatorPattern:
    """중재자: 객체 간 통신을 중재"""

    class User:
        def __init__(self, name: str, mediator: 'MediatorPattern.ChatRoom'):
            self.name = name
            self.mediator = mediator

        def send(self, message: str) -> None:
            self.mediator.show_message(self, message)

    class ChatRoom:
        def show_message(self, user: 'MediatorPattern.User', message: str) -> None:
            self.message = f"{user.name}: {message}"

    @staticmethod
    def demo() -> Dict[str, Any]:
        chat_room = MediatorPattern.ChatRoom()
        user1 = MediatorPattern.User("Alice", chat_room)
        user1.send("Hello everyone!")
        return {
            "pattern": "Mediator",
            "message": chat_room.message
        }


class MemortoPattern:
    """메멘토: 객체의 상태를 저장 및 복원"""

    class Memento:
        def __init__(self, state: Any):
            self.state = state

    class Originator:
        def __init__(self):
            self.state = None

        def set_state(self, state: Any) -> None:
            self.state = state

        def save_state_to_memento(self) -> 'MemortoPattern.Memento':
            return MemortoPattern.Memento(self.state)

        def restore_state_from_memento(self, memento: 'MemortoPattern.Memento') -> None:
            self.state = memento.state

    class Caretaker:
        def __init__(self):
            self.mementos: List['MemortoPattern.Memento'] = []

        def save(self, originator: 'MemortoPattern.Originator') -> None:
            self.mementos.append(originator.save_state_to_memento())

        def restore(self, originator: 'MemortoPattern.Originator', index: int) -> None:
            if 0 <= index < len(self.mementos):
                originator.restore_state_from_memento(self.mementos[index])

    @staticmethod
    def demo() -> Dict[str, Any]:
        originator = MemortoPattern.Originator()
        caretaker = MemortoPattern.Caretaker()

        originator.set_state("State1")
        caretaker.save(originator)
        originator.set_state("State2")
        caretaker.save(originator)

        caretaker.restore(originator, 0)
        return {
            "pattern": "Memento",
            "restored_state": originator.state
        }


class VisitorPattern:
    """방문자: 객체의 구조와 처리를 분리"""

    class Element(ABC):
        @abstractmethod
        def accept(self, visitor: 'VisitorPattern.Visitor') -> str:
            pass

    class ConcreteElementA(Element):
        def accept(self, visitor: 'VisitorPattern.Visitor') -> str:
            return visitor.visit_element_a(self)

    class ConcreteElementB(Element):
        def accept(self, visitor: 'VisitorPattern.Visitor') -> str:
            return visitor.visit_element_b(self)

    class Visitor(ABC):
        @abstractmethod
        def visit_element_a(self, element: 'VisitorPattern.ConcreteElementA') -> str:
            pass

        @abstractmethod
        def visit_element_b(self, element: 'VisitorPattern.ConcreteElementB') -> str:
            pass

    class ConcreteVisitor(Visitor):
        def visit_element_a(self, element: 'VisitorPattern.ConcreteElementA') -> str:
            return "Visiting Element A"

        def visit_element_b(self, element: 'VisitorPattern.ConcreteElementB') -> str:
            return "Visiting Element B"

    @staticmethod
    def demo() -> Dict[str, Any]:
        elements: List[VisitorPattern.Element] = [
            VisitorPattern.ConcreteElementA(),
            VisitorPattern.ConcreteElementB()
        ]
        visitor = VisitorPattern.ConcreteVisitor()
        results = [element.accept(visitor) for element in elements]
        return {
            "pattern": "Visitor",
            "results": results
        }


class InterpreterPattern:
    """해석자: 문법을 정의하고 해석"""

    class Expression(ABC):
        @abstractmethod
        def interpret(self) -> bool:
            pass

    class TerminalExpression(Expression):
        def __init__(self, value: str):
            self.value = value

        def interpret(self) -> bool:
            return self.value == "true"

    class OrExpression(Expression):
        def __init__(self, expr1: 'InterpreterPattern.Expression', expr2: 'InterpreterPattern.Expression'):
            self.expr1 = expr1
            self.expr2 = expr2

        def interpret(self) -> bool:
            return self.expr1.interpret() or self.expr2.interpret()

    @staticmethod
    def demo() -> Dict[str, Any]:
        expr1 = InterpreterPattern.TerminalExpression("true")
        expr2 = InterpreterPattern.TerminalExpression("false")
        result = InterpreterPattern.OrExpression(expr1, expr2).interpret()
        return {
            "pattern": "Interpreter",
            "result": result
        }


