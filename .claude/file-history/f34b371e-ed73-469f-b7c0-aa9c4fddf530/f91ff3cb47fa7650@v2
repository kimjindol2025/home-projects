class SOLIDPrinciples:
    """SOLID 원칙의 철학과 실천 방법"""

    @staticmethod
    def single_responsibility_example():
        """
        SRP: 클래스는 하나의 책임만 가져야 함
        나쁜 예: User 클래스가 저장/검증/로그까지 담당
        좋은 예: 각 책임을 분리하여 단일 목표로 변경
        """
        # 나쁜 예
        class BadUserManager:
            def save_user(self, user): pass
            def validate_email(self, email): pass
            def send_email(self, email, message): pass
            def log_action(self, action): pass

        # 좋은 예
        class User:
            def __init__(self, name: str, email: str):
                self.name = name
                self.email = email

        class UserValidator:
            @staticmethod
            def validate_email(email: str) -> bool:
                return "@" in email

        class UserRepository:
            @staticmethod
            def save(user: User) -> bool:
                return True

        class EmailService:
            @staticmethod
            def send_email(to: str, message: str) -> bool:
                return True

        class Logger:
            @staticmethod
            def log(action: str) -> None:
                print(f"[LOG] {action} at {datetime.now()}")

        return {"principle": "Single Responsibility", "applied": True}

    @staticmethod
    def open_closed_example():
        """
        OCP: 확장에는 열려있고 수정에는 닫혀있어야 함
        나쁜 예: 새로운 모양 추가 때마다 기존 코드 수정
        좋은 예: 추상 클래스 상속으로 새로운 모양 추가
        """
        class Shape(ABC):
            @abstractmethod
            def area(self) -> float:
                pass

        class Circle(Shape):
            def __init__(self, radius: float):
                self.radius = radius

            def area(self) -> float:
                return 3.14 * self.radius ** 2

        class Rectangle(Shape):
            def __init__(self, width: float, height: float):
                self.width = width
                self.height = height

            def area(self) -> float:
                return self.width * self.height

        class AreaCalculator:
            @staticmethod
            def total_area(shapes: List[Shape]) -> float:
                return sum(shape.area() for shape in shapes)

        shapes = [Circle(5), Rectangle(4, 6)]
        total = AreaCalculator.total_area(shapes)
        return {"principle": "Open-Closed", "total_area": total}

    @staticmethod
    def liskov_substitution_example():
        """
        LSP: 파생 클래스는 기본 클래스를 대체할 수 있어야 함
        나쁜 예: Square이 Rectangle을 상속받지만 동작이 다름
        좋은 예: 정사각형과 직사각형을 별도로 처리
        """
        class Rectangle:
            def __init__(self, width: float, height: float):
                self.width = width
                self.height = height

            def set_width(self, w: float) -> None:
                self.width = w

            def set_height(self, h: float) -> None:
                self.height = h

            def get_area(self) -> float:
                return self.width * self.height

        # LSP 준수: 별도 클래스
        class Square:
            def __init__(self, side: float):
                self.side = side

            def set_side(self, s: float) -> None:
                self.side = s

            def get_area(self) -> float:
                return self.side ** 2

        rect = Rectangle(5, 10)
        square = Square(5)
        return {
            "principle": "Liskov Substitution",
            "rect_area": rect.get_area(),
            "square_area": square.get_area()
        }

    @staticmethod
    def interface_segregation_example():
        """
        ISP: 클라이언트는 필요한 메서드만 의존해야 함
        나쁜 예: 사용하지 않는 메서드도 구현 강요
        좋은 예: 작은 인터페이스로 분리
        """
        class Printer(ABC):
            @abstractmethod
            def print(self, document: str) -> bool:
                pass

        class Scanner(ABC):
            @abstractmethod
            def scan(self) -> str:
                pass

        class Fax(ABC):
            @abstractmethod
            def fax(self, document: str) -> bool:
                pass

        class SimplePrinter(Printer):
            def print(self, document: str) -> bool:
                return True

        class MultiFunctionDevice(Printer, Scanner, Fax):
            def print(self, document: str) -> bool:
                return True

            def scan(self) -> str:
                return "Scanned document"

            def fax(self, document: str) -> bool:
                return True

        return {"principle": "Interface Segregation", "applied": True}

    @staticmethod
    def dependency_inversion_example():
        """
        DIP: 고수준 모듈은 저수준 모듈에 의존하면 안됨
        둘 다 추상화에 의존해야 함
        """
        class EmailService(ABC):
            @abstractmethod
            def send(self, to: str, message: str) -> bool:
                pass

        class SMTPEmail(EmailService):
            def send(self, to: str, message: str) -> bool:
                print(f"Sending email to {to}")
                return True

        class NotificationService:
            def __init__(self, email_service: EmailService):
                self.email_service = email_service

            def notify(self, user_email: str, msg: str) -> bool:
                return self.email_service.send(user_email, msg)

        service = SMTPEmail()
        notifier = NotificationService(service)
        return {"principle": "Dependency Inversion", "applied": True}


