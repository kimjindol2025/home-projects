class SingletonPattern:
    """싱글톤: 하나의 인스턴스만 존재"""

    _instance = None
    _lock = None

    def __new__(cls):
        if cls._instance is None:
            cls._instance = super(SingletonPattern, cls).__new__(cls)
            cls._instance.config = {}
        return cls._instance

    def set_config(self, key: str, value: Any) -> None:
        self.config[key] = value

    def get_config(self, key: str) -> Any:
        return self.config.get(key)

    @classmethod
    def demo(cls) -> Dict[str, Any]:
        s1 = SingletonPattern()
        s2 = SingletonPattern()
        s1.set_config("version", "1.0")
        return {
            "pattern": "Singleton",
            "same_instance": id(s1) == id(s2),
            "value": s2.get_config("version")
        }


class FactoryPattern:
    """팩토리: 객체 생성을 전담하는 클래스"""

    class DatabaseType(Enum):
        MYSQL = "mysql"
        POSTGRESQL = "postgresql"
        MONGODB = "mongodb"

    class Database(ABC):
        @abstractmethod
        def connect(self) -> str:
            pass

    class MySQL(Database):
        def connect(self) -> str:
            return "Connected to MySQL"

    class PostgreSQL(Database):
        def connect(self) -> str:
            return "Connected to PostgreSQL"

    class MongoDB(Database):
        def connect(self) -> str:
            return "Connected to MongoDB"

    class DatabaseFactory:
        @staticmethod
        def create(db_type: 'FactoryPattern.DatabaseType') -> 'FactoryPattern.Database':
            if db_type == FactoryPattern.DatabaseType.MYSQL:
                return FactoryPattern.MySQL()
            elif db_type == FactoryPattern.DatabaseType.POSTGRESQL:
                return FactoryPattern.PostgreSQL()
            elif db_type == FactoryPattern.DatabaseType.MONGODB:
                return FactoryPattern.MongoDB()
            raise ValueError(f"Unknown database type: {db_type}")

    @staticmethod
    def demo() -> Dict[str, Any]:
        factory = FactoryPattern.DatabaseFactory()
        db = factory.create(FactoryPattern.DatabaseType.MYSQL)
        return {
            "pattern": "Factory",
            "connection": db.connect()
        }


class BuilderPattern:
    """빌더: 복잡한 객체를 단계적으로 구성"""

    class Computer:
        def __init__(self):
            self.cpu = None
            self.ram = None
            self.storage = None
            self.gpu = None

        def __str__(self) -> str:
            return f"Computer(CPU={self.cpu}, RAM={self.ram}GB, Storage={self.storage}GB, GPU={self.gpu})"

    class ComputerBuilder:
        def __init__(self):
            self.computer = BuilderPattern.Computer()

        def set_cpu(self, cpu: str) -> 'BuilderPattern.ComputerBuilder':
            self.computer.cpu = cpu
            return self

        def set_ram(self, ram: int) -> 'BuilderPattern.ComputerBuilder':
            self.computer.ram = ram
            return self

        def set_storage(self, storage: int) -> 'BuilderPattern.ComputerBuilder':
            self.computer.storage = storage
            return self

        def set_gpu(self, gpu: str) -> 'BuilderPattern.ComputerBuilder':
            self.computer.gpu = gpu
            return self

        def build(self) -> 'BuilderPattern.Computer':
            return self.computer

    @staticmethod
    def demo() -> Dict[str, Any]:
        computer = (BuilderPattern.ComputerBuilder()
                   .set_cpu("Intel i9")
                   .set_ram(32)
                   .set_storage(1024)
                   .set_gpu("RTX 4090")
                   .build())
        return {
            "pattern": "Builder",
            "result": str(computer)
        }


class PrototypePattern:
    """프로토타입: 기존 객체를 복제하여 새 객체 생성"""

    class Shape(ABC):
        @abstractmethod
        def clone(self) -> 'PrototypePattern.Shape':
            pass

        @abstractmethod
        def describe(self) -> str:
            pass

    class Circle(Shape):
        def __init__(self, radius: float):
            self.radius = radius

        def clone(self) -> 'PrototypePattern.Circle':
            return PrototypePattern.Circle(self.radius)

        def describe(self) -> str:
            return f"Circle(radius={self.radius})"

    @staticmethod
    def demo() -> Dict[str, Any]:
        original = PrototypePattern.Circle(5.0)
        cloned = original.clone()
        return {
            "pattern": "Prototype",
            "original": original.describe(),
            "cloned": cloned.describe(),
            "same_reference": original is cloned
        }


class AbstractFactoryPattern:
    """추상 팩토리: 관련 객체 군을 생성"""

    class Button(ABC):
        @abstractmethod
        def render(self) -> str:
            pass

    class Checkbox(ABC):
        @abstractmethod
        def render(self) -> str:
            pass

    class WindowsButton(Button):
        def render(self) -> str:
            return "Windows Button"

    class WindowsCheckbox(Checkbox):
        def render(self) -> str:
            return "Windows Checkbox"

    class MacButton(Button):
        def render(self) -> str:
            return "Mac Button"

    class MacCheckbox(Checkbox):
        def render(self) -> str:
            return "Mac Checkbox"

    class GUIFactory(ABC):
        @abstractmethod
        def create_button(self) -> 'AbstractFactoryPattern.Button':
            pass

        @abstractmethod
        def create_checkbox(self) -> 'AbstractFactoryPattern.Checkbox':
            pass

    class WindowsFactory(GUIFactory):
        def create_button(self) -> 'AbstractFactoryPattern.Button':
            return AbstractFactoryPattern.WindowsButton()

        def create_checkbox(self) -> 'AbstractFactoryPattern.Checkbox':
            return AbstractFactoryPattern.WindowsCheckbox()

    class MacFactory(GUIFactory):
        def create_button(self) -> 'AbstractFactoryPattern.Button':
            return AbstractFactoryPattern.MacButton()

        def create_checkbox(self) -> 'AbstractFactoryPattern.Checkbox':
            return AbstractFactoryPattern.MacCheckbox()

    @staticmethod
    def demo() -> Dict[str, Any]:
        factory = AbstractFactoryPattern.WindowsFactory()
        button = factory.create_button()
        return {
            "pattern": "Abstract Factory",
            "button": button.render()
        }


