"""
v1.1 Data Types: 데이터의 종류 확인하기

"모든 데이터는 자신이 어떤 종류인지 알려준다: type()를 사용해보세요!"

나중에 대학 과정에서 배울 "객체(Object)"의 기초입니다.
"""


# ============================================================================
# 1. type() 함수 - 데이터의 정체 확인
# ============================================================================

def check_integer_type():
    """정수의 타입 확인"""
    age = 25
    year = 2026
    count = -5

    # type() 함수로 데이터의 종류를 확인합니다.
    age_type = type(age)  # <class 'int'>
    year_type = type(year)  # <class 'int'>

    return age_type, year_type, (age_type == int)


def check_float_type():
    """실수의 타입 확인"""
    pi = 3.14159
    height = 1.72
    temperature = -5.5

    pi_type = type(pi)  # <class 'float'>
    height_type = type(height)  # <class 'float'>

    return pi_type, height_type, (pi_type == float)


def check_string_type():
    """문자열의 타입 확인"""
    name = "Alice"
    message = "Hello, World!"
    empty_string = ""

    name_type = type(name)  # <class 'str'>
    message_type = type(message)  # <class 'str'>

    return name_type, message_type, (name_type == str)


def check_boolean_type():
    """불값(True/False)의 타입 확인"""
    is_student = True
    is_graduated = False

    bool_type_1 = type(is_student)  # <class 'bool'>
    bool_type_2 = type(is_graduated)  # <class 'bool'>

    return bool_type_1, bool_type_2, (bool_type_1 == bool)


def check_none_type():
    """None의 타입 확인 (아무것도 없음)"""
    nothing = None
    empty_value = None

    none_type = type(nothing)  # <class 'NoneType'>

    return none_type, (none_type == type(None))


# ============================================================================
# 2. 타입 이름을 문자열로 얻기
# ============================================================================

def get_type_name():
    """
    type(값).__name__으로 타입 이름을 문자열로 얻을 수 있습니다.
    """
    age = 25
    height = 1.72
    name = "Bob"
    is_active = True

    age_type_name = type(age).__name__  # "int"
    height_type_name = type(height).__name__  # "float"
    name_type_name = type(name).__name__  # "str"
    bool_type_name = type(is_active).__name__  # "bool"

    return {
        "age": age_type_name,
        "height": height_type_name,
        "name": name_type_name,
        "is_active": bool_type_name,
    }


# ============================================================================
# 3. 세 가지 기본 타입 비교
# ============================================================================

def compare_basic_types():
    """
    파이썬의 세 가지 기본 타입 비교
    """
    # 정수 (int)
    integer_value = 42
    integer_type = type(integer_value)

    # 실수 (float)
    float_value = 42.0
    float_type = type(float_value)

    # 문자열 (str)
    string_value = "42"
    string_type = type(string_value)

    # 모두 다른 타입입니다!
    are_different = (integer_type != float_type) and (float_type != string_type)

    return {
        "integer": (integer_value, integer_type.__name__),
        "float": (float_value, float_type.__name__),
        "string": (string_value, string_type.__name__),
        "are_different_types": are_different,
    }


# ============================================================================
# 4. 타입 변환 (Type Casting)
# ============================================================================

def demonstrate_type_conversion():
    """
    한 타입에서 다른 타입으로 변환하기
    """
    # 정수 → 실수
    age = 25
    age_as_float = float(age)  # 25.0

    # 실수 → 정수 (소수점 버림)
    height = 1.72
    height_as_int = int(height)  # 1

    # 정수 → 문자열
    year = 2026
    year_as_string = str(year)  # "2026"

    # 문자열 → 정수
    string_number = "100"
    number = int(string_number)  # 100

    # 문자열 → 실수
    string_float = "3.14"
    pi_value = float(string_float)  # 3.14

    # 불값 → 정수
    true_value = int(True)  # 1
    false_value = int(False)  # 0

    return {
        "age_as_float": (age_as_float, type(age_as_float).__name__),
        "height_as_int": (height_as_int, type(height_as_int).__name__),
        "year_as_string": (year_as_string, type(year_as_string).__name__),
        "number": (number, type(number).__name__),
        "pi_value": (pi_value, type(pi_value).__name__),
    }


# ============================================================================
# 5. 타입 확인하기: isinstance()
# ============================================================================

def demonstrate_isinstance():
    """
    isinstance()로 값이 특정 타입인지 확인하기
    """
    age = 25
    height = 1.72
    name = "Alice"

    # isinstance(값, 타입)
    is_age_int = isinstance(age, int)  # True
    is_age_string = isinstance(age, str)  # False
    is_height_float = isinstance(height, float)  # True
    is_name_string = isinstance(name, str)  # True

    return {
        "age_is_int": is_age_int,
        "age_is_string": is_age_string,
        "height_is_float": is_height_float,
        "name_is_string": is_name_string,
    }


# ============================================================================
# 6. 실습: Gogs 데이터 타입 확인
# ============================================================================

def gogs_data_types():
    """
    Gogs 프로젝트의 다양한 데이터 타입 확인
    """
    # 정수 데이터
    version_major = 1  # int
    version_minor = 1  # int
    total_lessons = 13  # int

    # 실수 데이터
    progress = 7.69  # float (1/13)
    achievement = 100.0  # float

    # 문자열 데이터
    project_name = "Gogs-Python"  # str
    current_level = "Elementary School Grade 1"  # str
    developer = "Kim"  # str

    # 불값
    is_complete = False  # bool
    is_learning = True  # bool

    # None
    future_data = None  # NoneType

    data = {
        "version_major": version_major,
        "version_minor": version_minor,
        "total_lessons": total_lessons,
        "progress": progress,
        "project_name": project_name,
        "current_level": current_level,
        "is_complete": is_complete,
        "is_learning": is_learning,
        "future_data": future_data,
    }

    return data


def get_gogs_data_types_info():
    """
    Gogs 데이터의 타입과 값을 함께 반환
    """
    data = gogs_data_types()
    type_info = {}

    for key, value in data.items():
        type_name = type(value).__name__
        type_info[key] = {
            "value": value,
            "type": type_name,
            "type_object": type(value),
        }

    return type_info


