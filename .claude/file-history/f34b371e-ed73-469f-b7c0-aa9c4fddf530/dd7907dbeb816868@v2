"""Lexer (어휘 분석기) - FSM 기반 토큰 추출기"""

from src.token import Token, TokenType, Position
from typing import List, Optional


class Lexer:
    """
    FSM 기반 어휘 분석기

    기능:
    - 소스 코드를 토큰 스트림으로 변환
    - 행/열 위치 추적
    - 주석 자동 제거
    - 40개 토큰 타입 지원
    """

    # 키워드 매핑
    KEYWORDS = {
        'let': TokenType.LET,
        'fn': TokenType.FN,
        'if': TokenType.IF,
        'else': TokenType.ELSE,
        'return': TokenType.RETURN,
        'while': TokenType.WHILE,
        'true': TokenType.TRUE,
        'false': TokenType.FALSE,
        'null': TokenType.NULL,
    }

    def __init__(self, input_str: str):
        """
        Lexer 초기화

        Args:
            input_str: 파싱할 소스 코드
        """
        self.input = input_str
        self.position = 0
        self.line = 1
        self.column = 1
        self.byte_offset = 0

    def read_char(self) -> str:
        """
        다음 문자를 읽고 위치 업데이트

        Returns:
            다음 문자, 끝이면 ''
        """
        if self.position >= len(self.input):
            return ''

        ch = self.input[self.position]
        self.position += 1
        self.byte_offset += 1

        if ch == '\n':
            self.line += 1
            self.column = 1
        else:
            self.column += 1

        return ch

    def peek_char(self, offset: int = 0) -> str:
        """
        현재 위치에서 offset만큼 떨어진 문자 미리 보기

        Args:
            offset: 보려는 위치 (기본값: 현재)

        Returns:
            문자, 범위 밖이면 ''
        """
        pos = self.position + offset
        if pos >= len(self.input):
            return ''
        return self.input[pos]

    def skip_whitespace_and_comments(self) -> None:
        """공백과 주석 스킵"""
        while True:
            ch = self.peek_char()

            # 공백 (스페이스, 탭, \r)
            if ch in ' \t\r':
                self.read_char()
            # 한 줄 주석
            elif ch == '/' and self.peek_char(1) == '/':
                self.read_char()  # 첫 번째 /
                self.read_char()  # 두 번째 /
                while self.peek_char() and self.peek_char() != '\n':
                    self.read_char()
            # 블록 주석
            elif ch == '/' and self.peek_char(1) == '*':
                self.read_char()  # /
                self.read_char()  # *
                while True:
                    if not self.peek_char():
                        break
                    if self.peek_char() == '*' and self.peek_char(1) == '/':
                        self.read_char()  # *
                        self.read_char()  # /
                        break
                    self.read_char()
            else:
                break

    def read_identifier(self) -> str:
        """
        식별자 읽기: [a-zA-Z_][a-zA-Z0-9_]*

        Returns:
            식별자 문자열
        """
        start = self.position

        while self.position < len(self.input):
            ch = self.input[self.position]
            if ch.isalnum() or ch == '_':
                self.read_char()
            else:
                break

        return self.input[start:self.position]

    def read_number(self) -> tuple[str, bool]:
        """
        숫자 읽기: 정수 또는 실수

        Returns:
            (숫자 문자열, 실수 여부)
        """
        start = self.position
        is_float = False

        # 정수 부분
        while self.position < len(self.input) and self.input[self.position].isdigit():
            self.read_char()

        # 소수점 체크
        if (self.position < len(self.input) and
            self.input[self.position] == '.' and
            self.position + 1 < len(self.input) and
            self.input[self.position + 1].isdigit()):
            is_float = True
            self.read_char()  # .
            while self.position < len(self.input) and self.input[self.position].isdigit():
                self.read_char()

        return self.input[start:self.position], is_float

    def read_string(self, quote: str) -> str:
        """
        문자열 읽기 (이스케이프 시퀀스 처리)

        Args:
            quote: 따옴표 문자 (' 또는 ")

        Returns:
            파싱된 문자열 (이스케이프 처리됨)
        """
        self.read_char()  # 시작 따옴표 스킵
        result = []

        while True:
            ch = self.peek_char()

            if not ch or ch == quote:
                break

            if ch == '\\':
                self.read_char()
                next_ch = self.peek_char()
                if next_ch == 'n':
                    result.append('\n')
                    self.read_char()
                elif next_ch == 't':
                    result.append('\t')
                    self.read_char()
                elif next_ch == 'r':
                    result.append('\r')
                    self.read_char()
                elif next_ch == '\\':
                    result.append('\\')
                    self.read_char()
                elif next_ch == quote:
                    result.append(quote)
                    self.read_char()
                elif next_ch == '0':
                    result.append('\0')
                    self.read_char()
                else:
                    result.append(next_ch)
                    self.read_char()
            else:
                result.append(ch)
                self.read_char()

        if self.peek_char() == quote:
            self.read_char()  # 종료 따옴표

        return ''.join(result)

    def next_token(self) -> Token:
        """
        다음 토큰 추출

        Returns:
            Token 객체
        """
        self.skip_whitespace_and_comments()

        pos = Position(
            line=self.line,
            column=self.column,
            byte_offset=self.byte_offset
        )

        ch = self.peek_char()

        # EOF
        if not ch:
            return Token(TokenType.EOF, None, pos)

        # 개행
        if ch == '\n':
            self.read_char()
            return Token(TokenType.NEWLINE, '\n', pos)

        # 문자열
        if ch in ('"', "'"):
            value = self.read_string(ch)
            return Token(TokenType.STRING, value, pos)

        # 식별자/키워드
        if ch.isalpha() or ch == '_':
            ident = self.read_identifier()
            token_type = self.KEYWORDS.get(ident, TokenType.IDENT)
            literal = ident if token_type == TokenType.IDENT else ident
            return Token(token_type, literal, pos)

        # 숫자
        if ch.isdigit():
            num_str, is_float = self.read_number()
            if is_float:
                return Token(TokenType.FLOAT, float(num_str), pos)
            else:
                return Token(TokenType.INT, int(num_str), pos)

        # 단일/이중 문자 연산자
        self.read_char()
        next_ch = self.peek_char()
        two_char = ch + next_ch

        # 두 글자 연산자
        if two_char == '==':
            self.read_char()
            return Token(TokenType.EQUAL, '==', pos)
        elif two_char == '!=':
            self.read_char()
            return Token(TokenType.NOT_EQUAL, '!=', pos)
        elif two_char == '<=':
            self.read_char()
            return Token(TokenType.LESS_EQUAL, '<=', pos)
        elif two_char == '>=':
            self.read_char()
            return Token(TokenType.GREATER_EQUAL, '>=', pos)
        elif two_char == '->':
            self.read_char()
            return Token(TokenType.ARROW, '->', pos)
        elif two_char == '=>':
            self.read_char()
            return Token(TokenType.FAT_ARROW, '=>', pos)
        elif two_char == '<<':
            self.read_char()
            return Token(TokenType.LESS_THAN, '<<', pos)  # 비트시프트
        elif two_char == '>>':
            self.read_char()
            return Token(TokenType.GREATER_THAN, '>>', pos)  # 비트시프트
        elif two_char == '+=':
            self.read_char()
            return Token(TokenType.PLUS, '+=', pos)
        elif two_char == '-=':
            self.read_char()
            return Token(TokenType.MINUS, '-=', pos)
        elif two_char == '*=':
            self.read_char()
            return Token(TokenType.ASTERISK, '*=', pos)
        elif two_char == '/=':
            self.read_char()
            return Token(TokenType.SLASH, '/=', pos)
        elif two_char == '..':
            if self.peek_char(1) == '.':
                self.read_char()
                self.read_char()
                return Token(TokenType.ELLIPSIS, '...', pos)
            # 두 글자 .. 는 지원하지 않음

        # 단일 문자 연산자/구분자
        token_map = {
            '+': TokenType.PLUS,
            '-': TokenType.MINUS,
            '*': TokenType.ASTERISK,
            '/': TokenType.SLASH,
            '%': TokenType.PERCENT,
            '!': TokenType.BANG,
            '&': TokenType.AMPERSAND,
            '|': TokenType.PIPE,
            '^': TokenType.CARET,
            '=': TokenType.ASSIGN,
            '<': TokenType.LESS_THAN,
            '>': TokenType.GREATER_THAN,
            '(': TokenType.LPAREN,
            ')': TokenType.RPAREN,
            '{': TokenType.LBRACE,
            '}': TokenType.RBRACE,
            '[': TokenType.LBRACKET,
            ']': TokenType.RBRACKET,
            ';': TokenType.SEMICOLON,
            ':': TokenType.COLON,
            ',': TokenType.COMMA,
            '.': TokenType.DOT,
        }

        if ch in token_map:
            return Token(token_map[ch], ch, pos)

        # 알 수 없는 문자
        return Token(TokenType.UNKNOWN, ch, pos)

    def tokenize(self) -> List[Token]:
        """
        모든 토큰 추출

        Returns:
            토큰 리스트 (EOF 포함)
        """
        tokens: List[Token] = []

        while True:
            token = self.next_token()
            tokens.append(token)

            if token.type == TokenType.EOF:
                break

        return tokens
