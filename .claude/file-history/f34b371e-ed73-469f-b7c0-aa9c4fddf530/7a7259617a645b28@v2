    """메모리 효율적: 한 줄씩 처리"""
    with open(filepath) as f:
        for line in f:
            yield line.strip()

# ✅ 리스트 사용
def small_data_set():
    """재사용 필요: 여러 번 순회"""
    return [1, 2, 3, 4, 5]

# ✅ itertools.tee 사용
import itertools
def process_and_log(data):
    """제너레이터 복제: 여러 경로 필요"""
    gen1, gen2 = itertools.tee(data, 2)
    process(gen1)
    log(gen2)
