class TestAOP:
    """AOP 패턴 테스트"""

    def test_database_logging(self):
        """데이터베이스 로깅"""
        logger = DatabaseLogger()

        @with_db_logging(logger)
        def process_data():
            return "result"

        result = process_data()
        assert result == "result"
        assert len(logger.logs) >= 2

    def test_authorization_aop(self):
        """권한 관리 AOP"""
        auth = Authorization()
        auth.grant_permission("alice", "read")
        auth.grant_permission("bob", "read")
        auth.grant_permission("bob", "write")

        @require_permission(auth, "write")
        def delete_data(user):
            return "deleted"

        # bob은 write 권한이 있음
        result = delete_data("bob")
        assert result == "deleted"

        # alice는 write 권한이 없음
        with pytest.raises(PermissionError):
            delete_data("alice")


