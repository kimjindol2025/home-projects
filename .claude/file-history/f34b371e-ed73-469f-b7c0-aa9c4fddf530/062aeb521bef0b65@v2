class TestPermissionCheck:
    """권한 확인 테스트"""

    @pytest.fixture
    def user_with_permission(self):
        """권한이 있는 사용자"""
        class User:
            def __init__(self, name, permissions):
                self.name = name
                self.permissions = permissions

        return User("Admin", {"read", "write", "delete"})

    @pytest.fixture
    def user_without_permission(self):
        """권한이 없는 사용자"""
        class User:
            def __init__(self, name, permissions):
                self.name = name
                self.permissions = permissions

        return User("User", {"read"})

    def test_permission_granted(self, user_with_permission):
        """권한이 있으면 함수 실행"""

        @permission_check("write")
        def write_data(user):
            return "Data written"

        result = write_data(user_with_permission)
        assert result == "Data written"

    def test_permission_denied(self, user_without_permission):
        """권한이 없으면 에러"""

        @permission_check("write")
        def write_data(user):
            return "Data written"

        with pytest.raises(PermissionError):
            write_data(user_without_permission)


