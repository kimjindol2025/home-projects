class TestValidation:
    """검증 테스트"""

    def test_validate_positive_valid(self):
        """유효한 양수"""

        @validate_positive("x", "y")
        def add(x, y):
            return x + y

        result = add(3, 5)
        assert result == 8

    def test_validate_positive_invalid(self):
        """유효하지 않은 값"""

        @validate_positive("x", "y")
        def add(x, y):
            return x + y

        with pytest.raises(ValueError):
            add(-3, 5)

    def test_validate_positive_zero(self):
        """0은 양수가 아님"""

        @validate_positive("x")
        def process(x):
            return x

        with pytest.raises(ValueError):
            process(0)


