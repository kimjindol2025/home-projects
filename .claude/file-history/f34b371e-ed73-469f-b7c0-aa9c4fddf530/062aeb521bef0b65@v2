class TestRealWorldScenarios:
    """실제 응용 시나리오"""

    def test_logging_multiple_functions(self):
        """여러 함수에 로깅 적용"""

        @gogs_logger
        def task1():
            return "task1 done"

        @gogs_logger
        def task2():
            return "task2 done"

        result1 = task1()
        result2 = task2()

        assert result1 == "task1 done"
        assert result2 == "task2 done"

    def test_performance_analysis(self):
        """성능 분석"""

        @PerformanceMonitor
        def matrix_operation():
            total = 0
            for i in range(1000):
                total += i
            return total

        for _ in range(3):
            matrix_operation()

        stats = matrix_operation.get_stats()
        assert stats["총_호출"] == 3
        assert stats["평균_시간"] > 0
        assert stats["최대_시간"] >= stats["최소_시간"]

    def test_caching_expensive_operations(self):
        """비용이 큰 연산 캐싱"""
        call_count = [0]

        @simple_cache
        def complex_calculation(n):
            call_count[0] += 1
            total = 0
            for i in range(n):
                total += i
            return total

        # 첫 호출
        result1 = complex_calculation(1000)
        # 캐시 히트
        result2 = complex_calculation(1000)
        # 캐시 미스
        result3 = complex_calculation(2000)

        assert result1 == result2
        assert call_count[0] == 2  # 1000과 2000 두 번만

    def test_retry_network_operations(self):
        """네트워크 재시도"""
        attempt = [0]

        @retry(max_attempts=3, delay=0.01)
        def fetch_from_api():
            attempt[0] += 1
            if attempt[0] < 2:
                raise ConnectionError("Network error")
            return {"status": "ok"}

        result = fetch_from_api()
        assert result["status"] == "ok"


