class TestSingleton:
    """싱글톤 테스트"""

    def test_singleton_same_instance(self):
        """싱글톤은 같은 인스턴스 반환"""

        @singleton
        class Config:
            def __init__(self):
                self.value = 42

        config1 = Config()
        config2 = Config()

        assert config1 is config2

    def test_singleton_multiple_classes(self):
        """여러 클래스는 독립적인 싱글톤"""

        @singleton
        class Database:
            pass

        @singleton
        class Cache:
            pass

        db = Database()
        cache = Cache()

        assert db is not cache


