class TestBasicDecorators:
    """기본 데코레이터 테스트"""

    def test_logger_decorator(self, capsys):
        """로깅 데코레이터"""

        @gogs_logger
        def say_hello(name):
            return f"Hello, {name}!"

        result = say_hello("Alice")
        assert result == "Hello, Alice!"
        captured = capsys.readouterr()
        assert "LOG" in captured.out
        assert "say_hello" in captured.out

    def test_timing_decorator(self, capsys):
        """타이밍 데코레이터"""

        @timing_decorator
        def slow_function():
            time.sleep(0.1)
            return "done"

        result = slow_function()
        assert result == "done"
        captured = capsys.readouterr()
        assert "실행 시간" in captured.out or "slow_function" in captured.out

    def test_decorator_preserves_function_info(self):
        """데코레이터가 원본 함수 정보 유지"""

        @gogs_logger
        def original_function():
            """Original docstring"""
            pass

        assert original_function.__name__ == "original_function"
        assert "Original docstring" in original_function.__doc__


