class TestCaching:
    """캐싱 테스트"""

    def test_cache_hits(self):
        """캐시 히트"""
        call_count = [0]

        @simple_cache
        def expensive_function(x):
            call_count[0] += 1
            return x * 2

        result1 = expensive_function(5)
        result2 = expensive_function(5)

        assert result1 == 10
        assert result2 == 10
        assert call_count[0] == 1  # 한 번만 호출

    def test_cache_misses(self):
        """캐시 미스"""
        call_count = [0]

        @simple_cache
        def expensive_function(x):
            call_count[0] += 1
            return x * 2

        expensive_function(5)
        expensive_function(6)

        assert call_count[0] == 2  # 두 번 호출

    def test_cache_clear(self):
        """캐시 초기화"""
        call_count = [0]

        @simple_cache
        def expensive_function(x):
            call_count[0] += 1
            return x * 2

        expensive_function(5)
        expensive_function(5)
        assert call_count[0] == 1

        expensive_function.clear_cache()
        expensive_function(5)
        assert call_count[0] == 2


