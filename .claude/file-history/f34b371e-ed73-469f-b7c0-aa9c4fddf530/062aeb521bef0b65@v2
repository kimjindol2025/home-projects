class TestDecoratorChaining:
    """데코레이터 체이닝 테스트"""

    def test_chain_analysis(self):
        """체이닝 분석"""
        result = DecoratorChain.analyze_execution_order()
        assert "개념" in result
        assert "실행 순서" in result

    def test_multiple_decorators(self):
        """여러 데코레이터 적용"""
        call_log = []

        def decorator_a(func):
            def wrapper(*args, **kwargs):
                call_log.append("a_before")
                result = func(*args, **kwargs)
                call_log.append("a_after")
                return result

            return wrapper

        def decorator_b(func):
            def wrapper(*args, **kwargs):
                call_log.append("b_before")
                result = func(*args, **kwargs)
                call_log.append("b_after")
                return result

            return wrapper

        @decorator_a
        @decorator_b
        def func():
            call_log.append("func")

        func()

        # 실행 순서: a_before → b_before → func → b_after → a_after
        assert call_log == ["a_before", "b_before", "func", "b_after", "a_after"]


