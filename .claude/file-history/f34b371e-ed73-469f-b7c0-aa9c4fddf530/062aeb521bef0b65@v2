class TestAdvancedPatterns:
    """고급 패턴 테스트"""

    def test_rate_limiting(self):
        """Rate Limiting"""
        timestamps = []

        @rate_limit(calls_per_second=2)
        def api_call():
            timestamps.append(time.time())

        api_call()
        api_call()
        start = time.time()
        api_call()
        elapsed = time.time() - start

        # 2번 호출 후 3번째는 대기 (약 0.5초)
        assert elapsed >= 0.4

    def test_deprecated(self):
        """Deprecated 표시"""

        @deprecated(replacement="new_function")
        def old_function():
            return "old"

        result = old_function()
        assert result == "old"


