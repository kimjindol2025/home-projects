    def test_cap_theorem(self):
        """CAP 이론"""
        result = DistributedSystemsPhilosophy.cap_theorem()
        assert result["정의"]
        assert "Consistency (일관성)" in result
        assert "Availability (가용성)" in result
        assert "Partition Tolerance (분할 내구성)" in result

    def test_microservice_principles(self):
        """마이크로서비스 원칙"""
        result = DistributedSystemsPhilosophy.microservice_principles()
        assert "1. Single Responsibility" in result
        assert "2. Loose Coupling" in result


