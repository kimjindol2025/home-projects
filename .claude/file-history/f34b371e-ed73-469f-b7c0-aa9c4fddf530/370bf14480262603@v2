class TestMessageBroker:
    """메시지 브로커 테스트"""

    def test_broker_creation(self):
        """브로커 생성"""
        broker = MessageBroker(max_queue_size=100)
        stats = broker.get_stats()
        assert stats["queue_size"] == 0

    def test_publish_message(self):
        """메시지 발행"""
        broker = MessageBroker()
        msg = Message(
            id="msg-1",
            sender="A",
            receiver="B",
            content="Test"
        )
        result = broker.publish(msg)
        assert result == True
        assert broker.get_stats()["queue_size"] == 1

    def test_subscribe_message(self):
        """메시지 구독"""
        broker = MessageBroker()
        msg = Message(
            id="msg-1",
            sender="A",
            receiver="B",
            content="Test"
        )
        broker.publish(msg)
        received = broker.subscribe(timeout=1.0)
        assert received is not None
        assert received.content == "Test"

    def test_acknowledge_message(self):
        """메시지 수신 확인"""
        broker = MessageBroker()
        msg = Message(
            id="msg-1",
            sender="A",
            receiver="B",
            content="Test"
        )
        broker.publish(msg)
        received = broker.subscribe()
        result = broker.acknowledge(received)
        assert result == True
        assert received.status == "completed"

    def test_empty_queue_timeout(self):
        """빈 큐에서 타임아웃"""
        broker = MessageBroker()
        result = broker.subscribe(timeout=0.1)
        assert result is None


