class TestServiceRegistry:
    """서비스 레지스트리 테스트"""

    def test_registry_creation(self):
        """레지스트리 생성"""
        registry = ServiceRegistry()
        assert registry.services == {}

    def test_register_service(self):
        """서비스 등록"""
        registry = ServiceRegistry()
        registry.register("order-service", "192.168.1.1", 8001)
        assert "order-service" in registry.services

    def test_discover_service(self):
        """서비스 발견"""
        registry = ServiceRegistry()
        registry.register("order-service", "192.168.1.1", 8001)
        service = registry.discover("order-service")
        assert service is not None
        assert service["host"] == "192.168.1.1"
        assert service["port"] == 8001

    def test_list_services(self):
        """서비스 나열"""
        registry = ServiceRegistry()
        registry.register("order-service", "192.168.1.1", 8001)
        registry.register("payment-service", "192.168.1.2", 8002)
        services = registry.list_services()
        assert "order-service" in services
        assert "payment-service" in services

    def test_deregister_service(self):
        """서비스 등록 해제"""
        registry = ServiceRegistry()
        registry.register("order-service", "192.168.1.1", 8001)
        registry.deregister("order-service", "192.168.1.1")
        service = registry.discover("order-service")
        assert service is None


