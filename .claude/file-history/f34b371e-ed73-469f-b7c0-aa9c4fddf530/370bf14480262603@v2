class TestProducerConsumer:
    """Producer-Consumer 테스트"""

    def test_producer_creation(self):
        """Producer 생성"""
        broker = MessageBroker()
        producer = Producer("OrderService", broker)
        assert producer.name == "OrderService"
        assert producer.message_count == 0

    def test_producer_produce(self):
        """메시지 생산"""
        broker = MessageBroker()
        producer = Producer("OrderService", broker)
        result = producer.produce("PaymentService", "Order-001")
        assert result == True
        assert producer.message_count == 1

    def test_consumer_creation(self):
        """Consumer 생성"""
        broker = MessageBroker()
        consumer = Consumer("PaymentService", broker)
        assert consumer.name == "PaymentService"

    def test_consumer_consume(self):
        """메시지 소비"""
        broker = MessageBroker()
        producer = Producer("OrderService", broker)
        consumer = Consumer("PaymentService", broker)

        producer.produce("PaymentService", "Order-001")
        msg = consumer.consume()

        assert msg is not None
        assert consumer.processed_count == 1


