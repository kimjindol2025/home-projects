class TestLoadBalancer:
    """로드 밸런서 테스트"""

    def test_load_balancer_round_robin(self):
        """라운드 로빈"""
        lb = LoadBalancer()
        lb.add_server("server-1")
        lb.add_server("server-2")
        lb.add_server("server-3")

        # 라운드 로빈으로 순회
        s1 = lb.get_next_server()
        s2 = lb.get_next_server()
        s3 = lb.get_next_server()
        s1_again = lb.get_next_server()

        assert s1 == "server-1"
        assert s2 == "server-2"
        assert s3 == "server-3"
        assert s1_again == "server-1"


