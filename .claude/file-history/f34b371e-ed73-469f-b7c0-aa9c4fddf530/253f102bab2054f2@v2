fn section_4_allocation_and_access() {
    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
    println!("Section 4: 할당과 조회 - alloc() & get()");
    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n");

    let mut heap = ObjectHeap::new();

    // 할당
    println!("🔨 할당 (alloc):");
    let arr_ref1 = heap.alloc(GcData::Array(vec![Value::Int(1), Value::Int(2)]));
    println!("  heap.alloc(Array([1, 2])) → GcRef({})", arr_ref1);

    let arr_ref2 = heap.alloc(GcData::Array(vec![Value::Int(3)]));
    println!("  heap.alloc(Array([3]))     → GcRef({})", arr_ref2);

    println!("\n  heap.capacity() = {}", heap.capacity());
    println!("  heap.live_count() = {}\n", heap.live_count());

    // 조회
    println!("🔍 조회 (get):");
    if let Some(obj) = heap.get(arr_ref1) {
        match &obj.data {
            GcData::Array(arr) => println!("  heap.get({}) → Array with {} elements", arr_ref1, arr.len()),
            _ => {}
        }
    }

    println!("\n✅ 섹션 완료\n");
}

/// ============================================================================
/// Section 5: Mark 단계
/// ============================================================================
fn section_5_mark_phase() {
    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
    println!("Section 5: Mark 단계 - 도달 가능 객체 표시");
    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n");

    let mut heap = ObjectHeap::new();

    // 객체 생성
    let arr_ref1 = heap.alloc(GcData::Array(vec![]));
    let arr_ref2 = heap.alloc(GcData::Array(vec![]));
    let arr_ref3 = heap.alloc(GcData::Array(vec![]));

    println!("🌳 Mark 알고리즘 (Worklist DFS):");
    println!("  1. 루트 집합 준비 (스택, 전역, 환경)");
    println!("  2. reset_marks() - 모든 is_marked = false");
    println!("  3. worklist = [루트에서 나온 GcRef들]");
    println!("  4. while worklist not empty:");
    println!("     - ref = worklist.pop()");
    println!("     - if marked: continue");
    println!("     - marked = true");
    println!("     - children = ref의 자식들");
    println!("     - worklist.extend(children)\n");

    println!("📍 예시: 루트 = [arr_ref1]");
    let roots = vec![Value::Array(arr_ref1)];
    heap.mark(&roots);

    println!("  마킹 결과:");
    println!("    arr_ref1: {}", heap.get(arr_ref1).unwrap().is_marked);
    println!("    arr_ref2: {}", heap.get(arr_ref2).unwrap().is_marked);
    println!("    arr_ref3: {}\n", heap.get(arr_ref3).unwrap().is_marked);

    println!("✅ 섹션 완료\n");
}

/// ============================================================================
/// Section 6: Sweep 단계
/// ============================================================================
fn section_6_sweep_phase() {
    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
    println!("Section 6: Sweep 단계 - 도달 불가 객체 해제");
    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n");

    let mut heap = ObjectHeap::new();

    let ref1 = heap.alloc(GcData::Str("keep".to_string()));
    let ref2 = heap.alloc(GcData::Str("free".to_string()));
    let ref3 = heap.alloc(GcData::Str("also free".to_string()));

    println!("🗑️  Sweep 알고리즘:");
    println!("  for each slot in objects:");
    println!("    if slot is Some && !is_marked:");
    println!("      *slot = None              ← 해제!");
    println!("    else if slot is Some:");
    println!("      is_marked = false        ← 다음 GC 준비\n");

    println!("📍 예시: ref1만 마킹");
    heap.get_mut(ref1).unwrap().is_marked = true;

    let freed = heap.sweep();

    println!("  Sweep 결과:");
    println!("    ref1: {:?} (보존)", heap.get(ref1).is_some());
    println!("    ref2: {:?} (해제)", heap.get(ref2).is_some());
    println!("    ref3: {:?} (해제)", heap.get(ref3).is_some());
    println!("    freed = {}\n", freed);

    println!("✅ 섹션 완료\n");
}

