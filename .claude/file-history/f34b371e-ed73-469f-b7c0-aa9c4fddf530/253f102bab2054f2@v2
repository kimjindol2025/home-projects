fn section_9_vm_gc_integration() {
    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
    println!("Section 9: VM + GC 통합");
    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n");

    println!("🏗️  VM 수정 (OpArray 예시):");
    println!("  OpCode::OpArray => {{");
    println!("    let count = read_u16();");
    println!("    let mut arr = Vec::new();");
    println!("    // ... pop count items ...");
    println!("    ");
    println!("    // [NEW] GC 체크");
    println!("    if self.heap.should_collect() {{");
    println!("      stats = self.heap.collect_garbage(&self.stack);");
    println!("      eprintln!(\"[GC #{{}}: freed]\", stats.gc_count);");
    println!("    }}");
    println!("    ");
    println!("    // [NEW] 힙에 할당");
    println!("    let gc_ref = self.heap.alloc(GcData::Array(arr));");
    println!("    self.stack.push(Value::Array(gc_ref));");
    println!("  }}\n");

    println!("✨ 결과:");
    println!("  - 배열 생성 때마다 GC 체크");
    println!("  - 임계값 도달하면 자동 GC");
    println!("  - 스택에 있는 값들은 보존\n");

    println!("✅ 섹션 완료\n");
}

/// ============================================================================
/// Section 10: GC 스트레스 테스트
/// ============================================================================
fn section_10_gc_stress_test() {
    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
    println!("Section 10: GC 스트레스 테스트");
    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n");

    let mut heap = ObjectHeap::with_threshold(5);

    println!("🔥 많은 배열 생성 + GC 반복:");
    println!("  threshold = 5\n");

    for round in 1..=3 {
        println!("📍 Round {}:", round);
        for i in 0..10 {
            heap.alloc(GcData::Array(vec![Value::Int(i)]));
        }

        let roots = vec![];
        let stats = heap.collect_garbage(&roots);
        println!("  10/10 할당 후 GC: freed={}, live={}\n",
            stats.objects_freed, stats.objects_after);
    }

    println!("✅ 섹션 완료\n");
}

/// ============================================================================
/// Section 11: 중첩 배열 마킹
/// ============================================================================
fn section_11_nested_array_marking() {
    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
    println!("Section 11: 중첩 배열 마킹 - 전이적 도달성");
    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n");

    let mut heap = ObjectHeap::new();

    // inner = [1, 2]
    let inner_ref = heap.alloc(GcData::Array(vec![Value::Int(1), Value::Int(2)]));

    // outer = [inner]
    let outer_ref = heap.alloc(GcData::Array(vec![Value::Array(inner_ref)]));

    println!("🌳 구조:");
    println!("  outer[outer_ref]");
    println!("    └─ Value::Array(inner_ref)");
    println!("         └─ inner[inner_ref]");
    println!("              ├─ Value::Int(1)");
    println!("              └─ Value::Int(2)\n");

    println!("📍 Mark 과정:");
    println!("  루트 = [outer_ref]");
    println!("  1. worklist = [outer_ref]");
    println!("  2. mark(outer_ref), is_marked=true");
    println!("  3. children = [inner_ref] (outer의 Value::Array에서 추출)");
    println!("  4. worklist = [inner_ref]");
    println!("  5. mark(inner_ref), is_marked=true");
    println!("  6. children = [] (inner의 Value::Int들은 GcRef가 아님)");
    println!("  7. worklist = [] → 종료\n");

    let roots = vec![Value::Array(outer_ref)];
    heap.mark(&roots);

    println!("✅ 결과:");
    println!("  outer: marked = {}", heap.get(outer_ref).unwrap().is_marked);
    println!("  inner: marked = {}\n", heap.get(inner_ref).unwrap().is_marked);

    println!("✅ 섹션 완료\n");
}

/// ============================================================================
/// Section 12: 아키텍처 요약
