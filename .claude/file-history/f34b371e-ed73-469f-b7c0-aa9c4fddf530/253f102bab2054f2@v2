fn section_7_collect_garbage() {
    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
    println!("Section 7: collect_garbage - Mark + Sweep 통합");
    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n");

    let mut heap = ObjectHeap::new();

    let ref1 = heap.alloc(GcData::Str("a".to_string()));
    let ref2 = heap.alloc(GcData::Str("b".to_string()));
    let ref3 = heap.alloc(GcData::Str("c".to_string()));

    println!("🔧 GC 실행 전:");
    println!("  live_count = {}", heap.live_count());
    println!("  gc_count = {}\n", heap.gc_count());

    let roots = vec![Value::Array(ref1), Value::Array(ref3)];
    let stats = heap.collect_garbage(&roots);

    println!("🔧 GC 실행 후:");
    println!("  objects_before: {}", stats.objects_before);
    println!("  objects_after: {}", stats.objects_after);
    println!("  objects_freed: {}", stats.objects_freed);
    println!("  gc_count: {}\n", stats.gc_count);

    println!("✅ 섹션 완료\n");
}

/// ============================================================================
/// Section 8: GC 임계값 조절
/// ============================================================================
fn section_8_gc_threshold() {
    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
    println!("Section 8: GC 임계값 - 언제 GC를 실행할 것인가?");
    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n");

    println!("⚙️  임계값 설정:");
    println!("  should_collect() = live_count >= gc_threshold\n");

    let mut heap_small = ObjectHeap::with_threshold(2);
    let mut heap_large = ObjectHeap::with_threshold(100);

    println!("📊 threshold=2 (매우 자주 GC):");
    heap_small.alloc(GcData::Str("a".to_string()));
    println!("  할당 1개: should_collect = {}", heap_small.should_collect());
    heap_small.alloc(GcData::Str("b".to_string()));
    println!("  할당 2개: should_collect = {}\n", heap_small.should_collect());

    println!("📊 threshold=100 (드물게 GC):");
    for i in 0..50 {
        heap_large.alloc(GcData::Str(format!("obj{}", i)));
    }
    println!("  할당 50개: should_collect = {}\n", heap_large.should_collect());

    println!("💡 적응형 GC (future work):");
    println!("  - 초기: threshold = 64");
    println!("  - GC 후: threshold = live_count * 2");
    println!("  - 효과: 자주 GC하지 않으면서 메모리 낭비 방지\n");

    println!("✅ 섹션 완료\n");
}

