# 카테고리 9: 주석 처리 (4개 테스트)
# ============================================================================

def test_skip_line_comment():
    """한 줄 주석 무시"""
    lexer = Lexer("42 // this is a comment")
    tokens = lexer.tokenize()
    assert tokens[0].type == TokenType.INT
    assert tokens[0].literal == 42
    assert tokens[1].type == TokenType.EOF


def test_skip_block_comment():
    """블록 주석 무시"""
    lexer = Lexer("42 /* comment */ 99")
    tokens = lexer.tokenize()
    assert tokens[0].type == TokenType.INT
    assert tokens[0].literal == 42
    assert tokens[1].type == TokenType.INT
    assert tokens[1].literal == 99


def test_nested_block_comment():
    """블록 주석 내 코드"""
    lexer = Lexer("/* /* nested */ 42")
    tokens = lexer.tokenize()
    # 첫 번째 주석이 끝나는 부분에서 42만 남음
    # 실제로는 /* 이후 처음 */ 까지가 주석
    assert tokens[0].type == TokenType.INT
    assert tokens[0].literal == 42


def test_comment_with_special_chars():
    """주석 내 특수 문자"""
    lexer = Lexer('42 // "string" and [array] {dict}')
    tokens = lexer.tokenize()
    assert len([t for t in tokens if t.type != TokenType.EOF]) == 1


