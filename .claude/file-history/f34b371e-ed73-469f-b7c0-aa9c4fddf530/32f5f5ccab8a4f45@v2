    tokens = lexer.tokenize()
    assert tokens[0].type == TokenType.FLOAT
    assert tokens[0].literal == 0.0


def test_float_with_leading_zero():
    """선행 0 있는 실수"""
    lexer = Lexer("0.42")
    tokens = lexer.tokenize()
    assert tokens[0].type == TokenType.FLOAT
