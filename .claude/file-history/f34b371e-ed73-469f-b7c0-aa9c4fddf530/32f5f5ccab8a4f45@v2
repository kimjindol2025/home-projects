"""Lexer 테스트 - 40개 이상의 포괄적 검증"""

import pytest
from src.lexer import Lexer
from src.token import Token, TokenType, Position


# ============================================================================
# 카테고리 1: 정수 토큰 (5개 테스트)
# ============================================================================

def test_single_digit_integer():
    """단일 숫자 파싱"""
    lexer = Lexer("5")
    tokens = lexer.tokenize()
    assert len(tokens) == 2  # INT + EOF
    assert tokens[0].type == TokenType.INT
    assert tokens[0].literal == 5


def test_multi_digit_integer():
    """다자리 정수 파싱"""
    lexer = Lexer("12345")
    tokens = lexer.tokenize()
    assert tokens[0].type == TokenType.INT
    assert tokens[0].literal == 12345


def test_zero():
    """0 파싱"""
    lexer = Lexer("0")
    tokens = lexer.tokenize()
    assert tokens[0].type == TokenType.INT
    assert tokens[0].literal == 0


def test_multiple_integers():
    """여러 정수 파싱 (공백 분리)"""
    lexer = Lexer("42 99 1")
    tokens = lexer.tokenize()
    assert tokens[0].type == TokenType.INT
    assert tokens[0].literal == 42
    assert tokens[1].type == TokenType.INT
    assert tokens[1].literal == 99
    assert tokens[2].type == TokenType.INT
    assert tokens[2].literal == 1


def test_large_integer():
    """큰 정수 파싱"""
    lexer = Lexer("9999999999")
    tokens = lexer.tokenize()
    assert tokens[0].type == TokenType.INT
    assert tokens[0].literal == 9999999999


