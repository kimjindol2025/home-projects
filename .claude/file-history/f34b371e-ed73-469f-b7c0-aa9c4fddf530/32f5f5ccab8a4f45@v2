    lexer = Lexer("@")
    tokens = lexer.tokenize()
    assert tokens[0].type == TokenType.UNKNOWN
    assert tokens[0].literal == "@"


def test_mixed_case_keywords():
    """혼합 대소문자 (식별자로 인식)"""
