def test_complete_program():
    """완전한 프로그램"""
    code = """let add = fn(x, y) {
        return x + y;
    };
    add(5, 10);"""
    lexer = Lexer(code)
    tokens = lexer.tokenize()

    # 주요 토큰 확인
    types = [t.type for t in tokens]
    assert TokenType.LET in types
    assert TokenType.FN in types
    assert TokenType.RETURN in types
    assert TokenType.INT in types


def test_conditional_expression():
    """조건부 표현식"""
    code = "if (x >= 10) { y = x * 2; } else { y = x + 1; }"
    lexer = Lexer(code)
    tokens = lexer.tokenize()

    types = [t.type for t in tokens]
    assert TokenType.IF in types
    assert TokenType.ELSE in types
    assert TokenType.GREATER_EQUAL in types


