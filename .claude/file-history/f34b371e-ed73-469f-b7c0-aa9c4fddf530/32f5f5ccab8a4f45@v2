def test_expression_arithmetic():
    """산술 표현식"""
    lexer = Lexer("x + y * 2 - z / 3")
    tokens = lexer.tokenize()
    assert tokens[0].type == TokenType.IDENT
    assert tokens[1].type == TokenType.PLUS
    assert tokens[2].type == TokenType.IDENT
    assert tokens[3].type == TokenType.ASTERISK
    assert tokens[4].type == TokenType.INT


def test_expression_function_call():
    """함수 호출 표현식"""
    lexer = Lexer("add(x, y)")
    tokens = lexer.tokenize()
    assert tokens[0].type == TokenType.IDENT
    assert tokens[1].type == TokenType.LPAREN
    assert tokens[2].type == TokenType.IDENT
    assert tokens[3].type == TokenType.COMMA
    assert tokens[4].type == TokenType.IDENT
    assert tokens[5].type == TokenType.RPAREN


def test_expression_if_statement():
    """if 문 표현식"""
    lexer = Lexer("if (x > 5) { return true; }")
    tokens = lexer.tokenize()
    assert tokens[0].type == TokenType.IF
    assert tokens[1].type == TokenType.LPAREN
    types = [t.type for t in tokens]
    assert TokenType.RETURN in types
    assert TokenType.TRUE in types


def test_expression_array_indexing():
    """배열 인덱싱 표현식"""
    lexer = Lexer("arr[0]")
    tokens = lexer.tokenize()
    assert tokens[0].type == TokenType.IDENT
    assert tokens[1].type == TokenType.LBRACKET
    assert tokens[2].type == TokenType.INT
    assert tokens[3].type == TokenType.RBRACKET


