def test_position_single_token():
    """단일 토큰 위치"""
    lexer = Lexer("42")
    tokens = lexer.tokenize()
    assert tokens[0].position.line == 1
    assert tokens[0].position.column == 1


def test_position_multiple_tokens():
    """여러 토큰 위치"""
    lexer = Lexer("x + y")
    tokens = lexer.tokenize()
    assert tokens[0].position.column == 1  # x
    assert tokens[1].position.column == 3  # +
    assert tokens[2].position.column == 5  # y


def test_position_newline():
    """개행 후 위치"""
    lexer = Lexer("x\ny")
    tokens = lexer.tokenize()
    # x, \n, y, EOF
    assert tokens[0].position.line == 1
    assert tokens[1].type == TokenType.NEWLINE
    assert tokens[2].position.line == 2
    assert tokens[2].position.column == 1


def test_position_multi_line():
    """다중 라인 위치"""
    lexer = Lexer("let x = 1\nlet y = 2")
    tokens = lexer.tokenize()
    # 두 번째 let은 라인 2에 있어야 함
    let_count = sum(1 for t in tokens if t.type == TokenType.LET)
    assert let_count == 2


def test_byte_offset():
    """바이트 오프셋 추적"""
    lexer = Lexer("abc")
    tokens = lexer.tokenize()
    assert tokens[0].position.byte_offset == 0


