{% extends "base.html" %}

{% block title %}실험 관리 - Gogs{% endblock %}

{% block content %}
<div class="card">
    <h2>🧪 실험 관리</h2>
    <div style="display: flex; gap: 10px; margin-bottom: 20px;">
        <button class="btn btn-primary" onclick="showAllExperiments()">📌 모든 실험</button>
        <button class="btn btn-secondary" onclick="filterByStatus('pending')">⏳ 진행 예정</button>
        <button class="btn btn-secondary" onclick="filterByStatus('in_progress')">🔄 진행 중</button>
        <button class="btn btn-secondary" onclick="filterByStatus('completed')">✅ 완료</button>
    </div>

    {% if experiments %}
    <div class="grid">
        {% for exp in experiments %}
        <div class="card">
            <div style="display: flex; justify-content: space-between; align-items: start;">
                <div style="flex: 1;">
                    <h3 style="color: #667eea; margin: 0;">{{ exp.subject }}</h3>
                    <p style="color: #999; font-size: 12px; margin: 5px 0;">{{ exp.description }}</p>
                </div>
                <span class="badge badge-{{ exp.status }}">{{ exp.status }}</span>
            </div>

            <div style="margin: 15px 0; padding: 15px; background: #f7fafc; border-radius: 6px;">
                {% if exp.result %}
                    <div style="text-align: center;">
                        <div style="font-size: 28px; font-weight: bold; color: #667eea;">{{ "%.1f"|format(exp.result) }}</div>
                        <div style="color: #999; font-size: 12px;">점수</div>
                    </div>
                {% else %}
                    <div style="text-align: center; color: #999;">점수 미등록</div>
                {% endif %}
            </div>

            <div style="font-size: 12px; color: #999; margin: 10px 0;">
                <p>생성: {{ exp.created_at[:10] }}</p>
                <p>수정: {{ exp.updated_at[:10] }}</p>
            </div>

            <div style="display: flex; gap: 10px;">
                <button class="btn btn-primary" onclick="editExperiment({{ exp.id }}, '{{ exp.subject }}', '{{ exp.description }}', '{{ exp.status }}', {{ exp.result or 'null' }})" style="flex: 1;">수정</button>
                <button class="btn btn-danger" onclick="deleteExperiment({{ exp.id }}, '{{ exp.subject }}')" style="flex: 1;">삭제</button>
            </div>
        </div>
        {% endfor %}
    </div>
    {% else %}
    <p style="color: #999; text-align: center; padding: 40px;">실험이 없습니다</p>
    {% endif %}
</div>

<!-- 실험 수정 모달 -->
<div id="editExperimentModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
    <div class="card" style="width: 100%; max-width: 600px; margin: 0; max-height: 90vh; overflow-y: auto;">
        <h2>실험 정보 수정</h2>
        <form id="editExperimentForm">
            <input type="hidden" id="editExperimentId">
            <div class="form-group">
                <label for="editExpSubject">제목 *</label>
                <input type="text" id="editExpSubject" required>
            </div>
            <div class="form-group">
                <label for="editExpDescription">설명</label>
                <textarea id="editExpDescription"></textarea>
            </div>
            <div class="form-group">
                <label for="editExpStatus">상태</label>
                <select id="editExpStatus">
                    <option value="pending">진행 예정</option>
                    <option value="in_progress">진행 중</option>
                    <option value="completed">완료</option>
                </select>
            </div>
            <div class="form-group">
                <label for="editExpResult">점수</label>
                <input type="number" id="editExpResult" step="0.1" min="0" max="100">
            </div>
            <div style="display: flex; gap: 10px;">
                <button type="submit" class="btn btn-primary" style="flex: 1;">저장</button>
                <button type="button" class="btn btn-secondary" style="flex: 1;" onclick="closeEditExperimentModal()">취소</button>
            </div>
        </form>
    </div>
</div>

<script>
    function editExperiment(id, subject, description, status, result) {
        document.getElementById('editExperimentId').value = id;
        document.getElementById('editExpSubject').value = subject;
        document.getElementById('editExpDescription').value = description;
        document.getElementById('editExpStatus').value = status;
        document.getElementById('editExpResult').value = result !== null ? result : '';
        document.getElementById('editExperimentModal').style.display = 'flex';
    }

    function closeEditExperimentModal() {
        document.getElementById('editExperimentModal').style.display = 'none';
    }

    function deleteExperiment(id, subject) {
        if (confirm(`"${subject}" 실험을 삭제하시겠습니까?`)) {
            fetch(`/api/v1/experiments/${id}`, { method: 'DELETE' })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        alert('삭제되었습니다');
                        location.reload();
                    } else {
                        alert('오류: ' + data.message);
                    }
                });
        }
    }

    function showAllExperiments() {
        location.href = '/experiments';
    }

    function filterByStatus(status) {
        location.href = `/experiments?status=${status}`;
    }

    document.getElementById('editExperimentForm').addEventListener('submit', async (e) => {
        e.preventDefault();

        const id = document.getElementById('editExperimentId').value;
        const subject = document.getElementById('editExpSubject').value;
        const description = document.getElementById('editExpDescription').value;
        const status = document.getElementById('editExpStatus').value;
        const result = document.getElementById('editExpResult').value;

        const updateData = {
            subject: subject,
            description: description,
            status: status
        };

        if (result) {
            updateData.result = parseFloat(result);
        }

        try {
            const response = await fetch(`/api/v1/experiments/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(updateData)
            });

            const data = await response.json();

            if (data.success) {
                alert('수정되었습니다!');
                closeEditExperimentModal();
                location.reload();
            } else {
                alert('오류: ' + data.message);
            }
        } catch (error) {
            alert('오류가 발생했습니다');
        }
    });
</script>
{% endblock %}
