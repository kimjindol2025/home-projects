## 레지스트리 메타클래스

### 자동 등록

```python
class RegistryMeta(type):
    """클래스 생성 시 자동으로 레지스트리에 등록"""

    _registry = {}

    def __new__(mcs, name, bases, attrs):
        cls = super().__new__(mcs, name, bases, attrs)

        # 기본 클래스는 등록하지 않음
        if bases and bases[0] != object:
            mcs._registry[name] = cls
            print(f"📝 레지스트리 등록: {name}")

        return cls

    @classmethod
    def get_class(mcs, name):
        return mcs._registry.get(name)

    @classmethod
    def list_all(mcs):
        return list(mcs._registry.keys())

# 사용
class Animal(metaclass=RegistryMeta):
    pass

class Dog(Animal):
    def speak(self):
        return "왈왈"

class Cat(Animal):
    def speak(self):
        return "야옹"

# 동적으로 클래스 조회
Dog = RegistryMeta.get_class("Dog")
print(Dog().speak())  # 출력: 왈왈

# 모든 등록된 클래스 나열
print(RegistryMeta.list_all())  # ['Dog', 'Cat']
```

