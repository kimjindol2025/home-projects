### 1. 마이크로서비스 프레임워크

```python
class ServiceMeta(type):
    """마이크로서비스 자동 등록"""

    services = {}

    def __new__(mcs, name, bases, attrs):
        cls = super().__new__(mcs, name, bases, attrs)

        # service_name이 있으면 등록
        if hasattr(cls, 'service_name'):
            mcs.services[cls.service_name] = {
                'class': cls,
                'routes': getattr(cls, 'routes', []),
                'version': getattr(cls, 'version', '1.0'),
            }

        return cls

# 사용
class UserService(metaclass=ServiceMeta):
    service_name = "user_service"
    version = "2.0"
    routes = ["/users", "/users/<id>"]

    def get_users(self):
        pass

class OrderService(metaclass=ServiceMeta):
    service_name = "order_service"
    version = "1.0"
    routes = ["/orders", "/orders/<id>"]

    def get_orders(self):
        pass

# 서비스 관리
for name, info in ServiceMeta.services.items():
    print(f"서비스: {name} v{info['version']}")
    print(f"  라우트: {info['routes']}")
