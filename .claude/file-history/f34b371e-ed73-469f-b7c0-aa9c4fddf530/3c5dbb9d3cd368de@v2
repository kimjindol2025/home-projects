### 2. 설정 관리

```python
class ConfigMeta(type):
    """설정 클래스 검증 및 인트로스펙션"""

    def __new__(mcs, name, bases, attrs):
        # 기본값만 필수
        required = ['DEBUG', 'DATABASE_URL']

        for req in required:
            if req not in attrs:
                raise TypeError(f"❌ 필수 설정 누락: {req}")

        # 모든 설정을 대문자로 강제
        for attr_name in list(attrs.keys()):
            if not attr_name.startswith('_') and not attr_name.isupper():
                raise TypeError(f"❌ 설정명 '{attr_name}'은 대문자여야 합니다")

        return super().__new__(mcs, name, bases, attrs)

# 사용
class ProductionConfig(metaclass=ConfigMeta):
    DEBUG = False
    DATABASE_URL = "postgresql://..."
    CACHE_TIMEOUT = 3600
    SECRET_KEY = "secure-key"
```

### 3. 데이터 검증 프레임워크

```python
class ValidatorMeta(type):
    """필드 검증 자동화"""

    def __new__(mcs, name, bases, attrs):
        validators = {}

        for attr_name, attr_value in attrs.items():
            if callable(attr_value) and attr_name.startswith('validate_'):
                field_name = attr_name.replace('validate_', '')
                validators[field_name] = attr_value

        attrs['__validators__'] = validators

        return super().__new__(mcs, name, bases, attrs)

# 사용
class UserValidator(metaclass=ValidatorMeta):
    def validate_email(self, value):
        if '@' not in value:
            raise ValueError("유효한 이메일이 아닙니다")
        return value

    def validate_age(self, value):
        if not (0 <= value <= 150):
            raise ValueError("유효한 나이가 아닙니다")
        return value

# 동적 검증
for field, validator in UserValidator.__validators__.items():
    print(f"필드 '{field}'의 검증자: {validator.__name__}")
```

