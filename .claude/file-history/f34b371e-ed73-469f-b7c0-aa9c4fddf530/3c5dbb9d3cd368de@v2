## 플러그인 시스템

### 자동 플러그인 등록

```python
class PluginMeta(type):
    """플러그인 시스템 지원"""

    plugins = {}

    def __new__(mcs, name, bases, attrs):
        cls = super().__new__(mcs, name, bases, attrs)

        # plugin_name 속성이 있으면 등록
        if hasattr(cls, 'plugin_name'):
            mcs.plugins[cls.plugin_name] = cls
            print(f"🔌 플러그인 등록: {cls.plugin_name}")

        return cls

    @classmethod
    def get_plugin(mcs, name):
        """플러그인 조회"""
        return mcs.plugins.get(name)

    @classmethod
    def list_plugins(mcs):
        """모든 플러그인 나열"""
        return list(mcs.plugins.keys())

# 사용
class BasePlugin(metaclass=PluginMeta):
    def execute(self):
        raise NotImplementedError

class LoggingPlugin(BasePlugin):
    plugin_name = "logging"

    def execute(self):
        return "로깅 실행"

class DatabasePlugin(BasePlugin):
    plugin_name = "database"

    def execute(self):
        return "데이터베이스 실행"

# 동적 플러그인 사용
plugin = PluginMeta.get_plugin("logging")
print(plugin().execute())  # 로깅 실행

# 모든 플러그인 나열
print(PluginMeta.list_plugins())  # ['logging', 'database']
```

