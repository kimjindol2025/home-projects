## 기본 패턴

### 패턴 1: 검증 메타클래스

```python
class ValidationMeta(type):
    """클래스 정의 시 검증"""

    def __new__(mcs, name, bases, attrs):
        # 기본 클래스는 제외
        if name not in ("ValidatedBase",):
            if not name.startswith('Gogs'):
                raise TypeError(f"'{name}'은 'Gogs'로 시작해야 합니다")

        return super().__new__(mcs, name, bases, attrs)

# 사용
class ValidatedBase(metaclass=ValidationMeta):
    pass

class GogsRobot(ValidatedBase):  # ✅ 통과
    pass

class InvalidRobot(ValidatedBase):  # ❌ TypeError
    pass
```

### 패턴 2: 속성 자동 수집

```python
class AttributeCollectorMeta(type):
    """클래스의 모든 속성을 자동 수집"""

    def __new__(mcs, name, bases, attrs):
        methods = {}
        properties = {}

        for attr_name, attr_value in attrs.items():
            if callable(attr_value) and not attr_name.startswith('_'):
                methods[attr_name] = attr_value
            elif isinstance(attr_value, property):
                properties[attr_name] = attr_value

        attrs['__methods__'] = methods
        attrs['__properties__'] = properties

        return super().__new__(mcs, name, bases, attrs)

# 사용
class MyClass(metaclass=AttributeCollectorMeta):
    def method1(self):
        pass

    def method2(self):
        pass

    @property
    def my_prop(self):
        return "value"

print(MyClass.__methods__)    # → {'method1': ..., 'method2': ...}
print(MyClass.__properties__)  # → {'my_prop': ...}
```

