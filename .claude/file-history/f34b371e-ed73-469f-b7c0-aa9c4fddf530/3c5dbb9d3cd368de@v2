## 속성 검증

### 필수 속성 강제

```python
class PropertyValidationMeta(type):
    """필수 속성을 정의하는 클래스 확인"""

    required_attributes = []

    def __new__(mcs, name, bases, attrs):
        # 기본 클래스 제외
        if name not in ("PropertyValidatedBase",):
            for required in mcs.required_attributes:
                if required not in attrs and not any(
                    hasattr(base, required) for base in bases
                ):
                    raise TypeError(f"❌ 필수 속성 누락: {required}")

        return super().__new__(mcs, name, bases, attrs)

# 사용: 필수 속성 정의
class StrictMeta(PropertyValidationMeta):
    required_attributes = ["name", "version"]

class Package(metaclass=StrictMeta):
    name = "mypackage"
    version = "1.0.0"
    # ✅ 필수 속성 정의됨

# 실패: 필수 속성 누락
try:
    class InvalidPackage(metaclass=StrictMeta):
        name = "invalid"
        # ❌ version이 없음
except TypeError as e:
    print(e)  # ❌ 필수 속성 누락: version
```

