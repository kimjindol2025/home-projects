## 불변성 메타클래스

### 클래스 수정 금지

```python
class ImmutableMeta(type):
    """클래스의 속성을 수정할 수 없도록 함"""

    def __setattr__(cls, name, value):
        raise TypeError(f"❌ 불변 클래스 '{cls.__name__}'은 수정할 수 없습니다")

# 사용
class ImmutableClass(metaclass=ImmutableMeta):
    pass

# 원래 정의할 때는 가능
class Config(metaclass=ImmutableMeta):
    VERSION = "1.0"

# 하지만 이후 수정은 불가능
try:
    Config.VERSION = "2.0"  # ❌ TypeError
except TypeError as e:
    print(e)

# 동적 속성 추가도 불가능
try:
    Config.new_attr = "value"  # ❌ TypeError
except TypeError as e:
    print(e)
```

