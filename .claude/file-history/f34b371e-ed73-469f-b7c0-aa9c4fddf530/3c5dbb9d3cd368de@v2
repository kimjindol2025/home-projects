## 싱글톤 메타클래스

### 구현

```python
class SingletonMeta(type):
    """싱글톤 패턴을 강제"""

    _instances = {}

    def __call__(cls, *args, **kwargs):
        # 이미 인스턴스가 있으면 그것을 반환
        if cls not in cls._instances:
            cls._instances[cls] = super().__call__(*args, **kwargs)
        return cls._instances[cls]

# 사용
class DatabaseConnection(metaclass=SingletonMeta):
    def __init__(self):
        self.connection_id = id(self)

db1 = DatabaseConnection()
db2 = DatabaseConnection()

assert db1 is db2, "같은 인스턴스여야 함"
print(f"db1과 db2는 동일한 인스턴스: {db1 is db2}")  # True

# 다른 클래스는 다른 싱글톤
class CacheConnection(metaclass=SingletonMeta):
    pass

cache1 = CacheConnection()
cache2 = CacheConnection()

assert cache1 is cache2  # True (CacheConnection의 싱글톤)
assert db1 is not cache1  # True (서로 다른 싱글톤)
```

