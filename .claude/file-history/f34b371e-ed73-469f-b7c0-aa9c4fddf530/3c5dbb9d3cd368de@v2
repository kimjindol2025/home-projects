## 검증 메타클래스

### 클래스 이름 검증

```python
class GogsValidationMeta(type):
    """클래스 이름이 'Gogs'로 시작하는지 검증"""

    def __new__(mcs, name, bases, attrs):
        if name not in ("GogsBase",):
            if not name.startswith("Gogs"):
                raise TypeError(f"❌ 규정 위반: '{name}'은 'Gogs'로 시작해야 합니다")

        print(f"✅ 클래스 '{name}' 생성 허용됨")
        return super().__new__(mcs, name, bases, attrs)

class GogsBase(metaclass=GogsValidationMeta):
    pass

# 성공
class GogsRobot(GogsBase):
    pass

# 실패
try:
    class Robot(GogsBase):
        pass
except TypeError as e:
    print(e)  # ❌ 규정 위반: 'Robot'은 'Gogs'로 시작해야 합니다
```

### 필수 메서드 검증

```python
class AbstractMeta(type):
    """필수 메서드 구현을 강제"""

    def __call__(cls, *args, **kwargs):
        # 추상 메서드를 가진 클래스는 인스턴스화 불가
        abstract_methods = getattr(cls, '__abstractmethods__', set())
        if abstract_methods:
            raise TypeError(
                f"❌ 추상 메서드 미구현: {', '.join(abstract_methods)}"
            )
        return super().__call__(*args, **kwargs)

# 사용
class Animal(metaclass=AbstractMeta):
    __abstractmethods__ = frozenset(['speak', 'move'])

    def speak(self):
        pass

    def move(self):
        pass

class Dog(Animal):
    def speak(self):
        return "왈왈"

    def move(self):
        return "뛰어다님"

dog = Dog()  # ✅ 모든 추상 메서드 구현됨
```

