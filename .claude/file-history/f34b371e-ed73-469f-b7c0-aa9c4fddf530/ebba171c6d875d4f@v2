# 6. 멀티쓰레드 서버 (여러 클라이언트 동시 처리)
# =============================================================================

class MultiThreadServer:
    """여러 클라이언트를 동시에 처리하는 서버"""

    def __init__(self, host: str = 'localhost', port: int = 9999, max_workers: int = 10):
        self.host = host
        self.port = port
        self.max_workers = max_workers
        self.server_socket = None
        self.is_running = False
        self.client_count = 0
        self.threads: List[threading.Thread] = []

    def start(self) -> bool:
        """서버 시작"""
        try:
            self.server_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            self.server_socket.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
            self.server_socket.bind((self.host, self.port))
            self.server_socket.listen(self.max_workers)
            self.is_running = True
            return True
        except Exception:
            return False

    def handle_client(self, conn: socket.socket, addr: Tuple[str, int]):
        """클라이언트 처리 (스레드에서 실행)"""
        try:
            with conn:
                data = conn.recv(1024)
                if data:
                    # 데이터를 받아서 처리 후 돌려보냄
                    conn.sendall(data)
        except Exception:
            pass

    def accept_loop(self):
        """클라이언트 수락 루프"""
        while self.is_running:
            try:
                conn, addr = self.server_socket.accept()

                # 클라이언트 처리용 스레드 시작
                client_thread = threading.Thread(
                    target=self.handle_client,
                    args=(conn, addr),
                    daemon=True
                )
                client_thread.start()
                self.threads.append(client_thread)
                self.client_count += 1

            except Exception:
                if self.is_running:
                    continue
                break

    def start_async(self) -> bool:
        """비동기로 서버 시작"""
        if not self.start():
            return False

        accept_thread = threading.Thread(target=self.accept_loop, daemon=True)
        accept_thread.start()
        self.threads.append(accept_thread)

        return True

    def stop(self):
        """서버 종료"""
        self.is_running = False
        if self.server_socket:
            try:
                self.server_socket.close()
            except Exception:
                pass


