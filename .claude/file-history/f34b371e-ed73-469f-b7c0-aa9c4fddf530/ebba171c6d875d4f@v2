# 7. 프로토콜 정의 (Protocol Layer)
# =============================================================================

class Protocol(ABC):
    """네트워크 프로토콜 기본 인터페이스"""

    @abstractmethod
    def encode(self, data: Dict[str, Any]) -> bytes:
        """데이터를 네트워크 형식으로 인코딩"""
        pass

    @abstractmethod
    def decode(self, data: bytes) -> Optional[Dict[str, Any]]:
        """네트워크 데이터를 디코딩"""
        pass


class SimpleProtocol(Protocol):
    """간단한 프로토콜: JSON + 길이 접두사"""

    def encode(self, data: Dict[str, Any]) -> bytes:
        """
        Format: [길이(4바이트)][JSON 데이터]
        """
        json_data = json.dumps(data).encode('utf-8')
        length = len(json_data)

        # 길이를 4바이트 big-endian으로 인코딩
        length_bytes = length.to_bytes(4, byteorder='big')

        return length_bytes + json_data

    def decode(self, data: bytes) -> Optional[Dict[str, Any]]:
        """길이 접두사를 읽고 JSON 파싱"""
        try:
            if len(data) < 4:
                return None

            # 길이 읽기
            length = int.from_bytes(data[:4], byteorder='big')

            if len(data) < 4 + length:
                return None

            # JSON 파싱
            json_data = data[4:4 + length]
            return json.loads(json_data.decode('utf-8'))

        except Exception:
            return None


