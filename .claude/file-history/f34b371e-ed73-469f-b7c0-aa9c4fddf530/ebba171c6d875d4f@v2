# =============================================================================
# 1. TCP 기본 패턴 (Transmission Control Protocol)
# =============================================================================

class TCPServer:
    """TCP 서버: 클라이언트 요청을 받아 처리"""

    def __init__(self, host: str = 'localhost', port: int = 9999, backlog: int = 5):
        self.host = host
        self.port = port
        self.backlog = backlog
        self.server_socket = None
        self.is_running = False

    def start(self) -> bool:
        """서버 시작"""
        try:
            # 소켓 생성 (IPv4, TCP)
            self.server_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            self.server_socket.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)

            # 포트에 바인드
            self.server_socket.bind((self.host, self.port))

            # 클라이언트 요청 대기
            self.server_socket.listen(self.backlog)
            self.is_running = True

            return True
        except Exception as e:
            return False

    def accept_client(self) -> Optional[Tuple[socket.socket, Tuple[str, int]]]:
        """클라이언트 연결 수락"""
        try:
            if not self.is_running or not self.server_socket:
                return None

            conn, addr = self.server_socket.accept()
            return conn, addr
        except Exception:
            return None

    def stop(self):
        """서버 종료"""
        self.is_running = False
        if self.server_socket:
            self.server_socket.close()


class TCPClient:
    """TCP 클라이언트: 서버에 접속하여 데이터 송수신"""

    def __init__(self, host: str = 'localhost', port: int = 9999):
        self.host = host
        self.port = port
        self.socket = None

    def connect(self) -> bool:
        """서버에 연결"""
        try:
            self.socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            self.socket.connect((self.host, self.port))
            return True
        except Exception:
            return False

    def send(self, data: bytes) -> bool:
        """데이터 전송"""
        try:
            if not self.socket:
                return False
            self.socket.sendall(data)
            return True
        except Exception:
            return False

    def recv(self, buffer_size: int = 1024) -> Optional[bytes]:
        """데이터 수신"""
        try:
            if not self.socket:
                return None
            return self.socket.recv(buffer_size)
        except Exception:
            return None

    def close(self):
        """연결 종료"""
        if self.socket:
            self.socket.close()


# =============================================================================
# 2. UDP 패턴 (User Datagram Protocol) - 빠르지만 신뢰성 낮음
# =============================================================================

class UDPServer:
    """UDP 서버: 빠른 데이터그램 전송"""

    def __init__(self, host: str = 'localhost', port: int = 9998):
        self.host = host
        self.port = port
        self.socket = None

    def start(self) -> bool:
        """서버 시작"""
        try:
            self.socket = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            self.socket.bind((self.host, self.port))
            return True
        except Exception:
            return False

    def recv_from(self, buffer_size: int = 1024) -> Optional[Tuple[bytes, Tuple[str, int]]]:
        """데이터 수신"""
        try:
            if not self.socket:
                return None
            return self.socket.recvfrom(buffer_size)
        except Exception:
            return None

    def send_to(self, data: bytes, addr: Tuple[str, int]) -> bool:
        """데이터 전송"""
        try:
            if not self.socket:
                return False
            self.socket.sendto(data, addr)
            return True
        except Exception:
            return False

    def close(self):
        """종료"""
        if self.socket:
            self.socket.close()


class UDPClient:
    """UDP 클라이언트"""

    def __init__(self, host: str = 'localhost', port: int = 9998):
        self.host = host
        self.port = port
        self.socket = None

    def start(self) -> bool:
        """시작"""
        try:
            self.socket = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            return True
        except Exception:
            return False

    def send(self, data: bytes) -> bool:
        """데이터 전송"""
        try:
            if not self.socket:
                return False
            self.socket.sendto(data, (self.host, self.port))
            return True
        except Exception:
            return False

    def recv(self, buffer_size: int = 1024) -> Optional[bytes]:
        """데이터 수신"""
        try:
            if not self.socket:
                return None
            data, _ = self.socket.recvfrom(buffer_size)
            return data
        except Exception:
            return None

    def close(self):
        """종료"""
        if self.socket:
            self.socket.close()


# =============================================================================
# 3. Echo Server & Client (데이터를 받아서 그대로 돌려보냄)
# =============================================================================

class EchoServer(TCPServer):
    """에코 서버: 클라이언트가 보낸 데이터를 그대로 돌려보냄"""

    def __init__(self, host: str = 'localhost', port: int = 9999):
        super().__init__(host, port)
        self.echo_count = 0

    def handle_client(self, conn: socket.socket, addr: Tuple[str, int]) -> int:
        """클라이언트 처리"""
        count = 0
        try:
            with conn:
                while True:
                    data = conn.recv(1024)
                    if not data:
                        break

                    count += 1
                    # 그대로 돌려보냄
                    conn.sendall(data)

        except Exception:
            pass
        finally:
            self.echo_count += count

        return count


class EchoClient(TCPClient):
    """에코 클라이언트"""

    def send_and_receive(self, message: str) -> Optional[str]:
        """메시지 전송 후 응답 수신"""
        try:
            self.send(message.encode('utf-8'))
            response = self.recv(1024)

            if response:
                return response.decode('utf-8')
            return None
        except Exception:
            return None


