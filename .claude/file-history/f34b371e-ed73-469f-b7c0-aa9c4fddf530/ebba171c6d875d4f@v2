# 4. 직렬화 & 역직렬화 (Serialization)
# =============================================================================

class MessageSerializer:
    """메시지 직렬화/역직렬화"""

    @staticmethod
    def serialize(data: Dict[str, Any]) -> bytes:
        """딕셔너리를 JSON 바이트로 변환"""
        json_str = json.dumps(data)
        return json_str.encode('utf-8')

    @staticmethod
    def deserialize(data: bytes) -> Optional[Dict[str, Any]]:
        """바이트를 딕셔너리로 변환"""
        try:
            json_str = data.decode('utf-8')
            return json.loads(json_str)
        except Exception:
            return None

    @staticmethod
    def demo() -> Dict[str, Any]:
        """직렬화 데모"""
        data = {
            "username": "alice",
            "message": "Hello, Network!",
            "timestamp": 1234567890
        }

        # 직렬화
        serialized = MessageSerializer.serialize(data)

        # 역직렬화
        deserialized = MessageSerializer.deserialize(serialized)

        return {
            "original": data,
            "serialized_type": type(serialized).__name__,
            "deserialized": deserialized,
            "match": data == deserialized
        }


# =============================================================================
# 5. HTTP 기초 (Hypertext Transfer Protocol)
# =============================================================================

class HTTPRequest:
    """HTTP 요청"""

    def __init__(self, method: str, path: str, headers: Optional[Dict] = None, body: str = ""):
        self.method = method  # GET, POST, etc.
        self.path = path
        self.headers = headers or {}
        self.body = body

    def to_bytes(self) -> bytes:
        """HTTP 요청을 바이트로 변환"""
        request_line = f"{self.method} {self.path} HTTP/1.1\r\n"

        headers_str = ""
        for key, value in self.headers.items():
            headers_str += f"{key}: {value}\r\n"

        request = request_line + headers_str + "\r\n" + self.body

        return request.encode('utf-8')

    @staticmethod
    def from_bytes(data: bytes) -> Optional['HTTPRequest']:
        """바이트에서 HTTP 요청 파싱"""
        try:
            text = data.decode('utf-8')
            lines = text.split('\r\n')

            # 요청 라인 파싱
            request_line = lines[0].split()
            method = request_line[0]
            path = request_line[1]

            # 헤더 파싱
            headers = {}
            body_start = 0
            for i, line in enumerate(lines[1:], 1):
                if line == "":
                    body_start = i + 1
                    break
                if ":" in line:
                    key, value = line.split(":", 1)
                    headers[key.strip()] = value.strip()

            # 바디
            body = "\r\n".join(lines[body_start:])

            return HTTPRequest(method, path, headers, body)
        except Exception:
            return None


class HTTPResponse:
    """HTTP 응답"""

    def __init__(self, status_code: int, status_text: str, headers: Optional[Dict] = None, body: str = ""):
        self.status_code = status_code
        self.status_text = status_text
        self.headers = headers or {}
        self.body = body

    def to_bytes(self) -> bytes:
        """HTTP 응답을 바이트로 변환"""
        status_line = f"HTTP/1.1 {self.status_code} {self.status_text}\r\n"

        headers_str = ""
        for key, value in self.headers.items():
            headers_str += f"{key}: {value}\r\n"

        response = status_line + headers_str + "\r\n" + self.body

        return response.encode('utf-8')

    @staticmethod
    def ok(body: str = "") -> 'HTTPResponse':
        """200 OK 응답"""
        return HTTPResponse(200, "OK", {"Content-Type": "text/plain"}, body)

    @staticmethod
    def not_found() -> 'HTTPResponse':
        """404 Not Found 응답"""
        return HTTPResponse(404, "Not Found", {"Content-Type": "text/plain"}, "Not Found")


