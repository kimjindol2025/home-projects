"""
v1.9 List Comprehension - 리스트 컴프리헨션

리스트 컴프리헨션: 파이썬 중학교 1학년의 가장 세련된 문법
"""


def list_comprehension():
    """
    [Python Middle v1.9] 리스트 컴프리헨션
    """
    # 1. 일반적인 방식 (복습)
    numbers = [1, 2, 3, 4, 5]
    squares_old = []
    for n in numbers:
        squares_old.append(n * n)

    # 2. 리스트 컴프리헨션 방식 (중등 핵심 기술)
    # "n*n을 해라, numbers에 있는 n들에 대해서"
    squares_new = [n * n for n in numbers]

    print("--- 리스트 생성 비교 ---")
    print(f"기존 방식 결과: {squares_old}")
    print(f"새로운 방식 결과: {squares_new}")

    # 3. 응용: 조건(if)이 붙은 컴프리헨션
    # "n*n을 해라, numbers 중 n이 짝수일 때만!"
    even_squares = [n * n for n in numbers if n % 2 == 0]

    print(f"\n--- 조건부 생성 결과 ---")
    print(f"짝수 제곱 리스트: {even_squares}")

    # 4. 문자열 응용
    words = ["gogs", "python", "ai"]
    upper_words = [word.upper() for word in words]
    print(f"\n대문자 변환: {upper_words}")

    print("\n저장 필수 너는 기록이 증명이다 gogs")

    return {
        "numbers": numbers,
        "squares_old": squares_old,
        "squares_new": squares_new,
        "even_squares": even_squares,
        "words": words,
        "upper_words": upper_words,
    }


def main():
    """v1.9 실행"""
    print("\n" + "="*70)
    print("🐍 Python v1.9: 리스트 컴프리헨션(List Comprehension) — 한 줄의 미학")
    print("="*70 + "\n")

    list_comprehension()

    print("\n" + "="*70)


if __name__ == "__main__":
    main()
