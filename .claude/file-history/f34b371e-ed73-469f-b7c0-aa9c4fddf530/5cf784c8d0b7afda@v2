## 📊 VIII. 쿼리 최적화

### 8.1 QueryOptimizer - 실행 계획 분석

```python
class QueryOptimizer:
    """쿼리 실행 계획 최적화"""

    def analyze_query(self, query: str) -> Dict[str, Any]:
        """쿼리 분석 및 최적화 제안"""
        plan = {
            'query': query,
            'type': 'SELECT' if query.startswith('SELECT') else 'OTHER',
            'estimated_rows': 0,
            'estimated_cost': 0,
            'optimization_suggestions': []
        }

        # 최적화 제안
        if 'WHERE' not in query:
            plan['suggestions'].append('WHERE 절 추가하면 성능 향상')
        if 'ORDER BY' in query and 'INDEX' not in query:
            plan['suggestions'].append('ORDER BY 칼럼에 인덱스 생성')
        if 'JOIN' in query:
            plan['suggestions'].append('JOIN 순서 재정렬 고려')

        return plan

    def estimate_execution_time(self, query: str, rows: int) -> float:
        """실행 시간 추정 (밀리초)"""
        base_time = 1.0  # ms

        if 'JOIN' in query:
            base_time *= rows * 0.1        # JOIN: O(n²) 근처
        elif 'WHERE' in query:
            base_time *= rows * 0.01       # WHERE: O(n)
        else:
            base_time *= rows * 0.001      # 단순: O(n)

        return min(base_time, 1000.0)
```

