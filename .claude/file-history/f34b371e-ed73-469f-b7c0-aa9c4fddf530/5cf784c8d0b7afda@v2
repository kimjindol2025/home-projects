    start = time.time()
    for _ in range(100):
        index_mgr.search_by_index('name', 'User_50')  # 10개 레코드
    index_time = time.time() - start

    # 100회 전체 스캔
    start = time.time()
    for _ in range(100):
        index_mgr.full_scan('name', 'User_50', data)
    scan_time = time.time() - start

    # 인덱스가 전체 스캔보다 훨씬 빠름
    assert index_time < scan_time
    print(f"인덱스: {index_time:.4f}s, 전체 스캔: {scan_time:.4f}s")
    # 예상 결과: 10배 이상 차이
