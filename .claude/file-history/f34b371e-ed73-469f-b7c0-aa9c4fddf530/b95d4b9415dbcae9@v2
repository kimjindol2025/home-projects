"""
v1.4 Comparison Operators: 비교의 논리

== → __eq__()
!= → __ne__()
< → __lt__()
> → __gt__()
<= → __le__()
>= → __ge__()
"""

from typing import Union


class Person:
    """사람 클래스"""

    def __init__(self, name: str, age: int):
        self.name = name
        self.age = age

    def __repr__(self) -> str:
        return f"Person('{self.name}', {self.age})"

    def __str__(self) -> str:
        return f"{self.name} ({self.age}세)"

    # ========== 동일성/동등성 ==========

    def __eq__(self, other: 'Person') -> bool:
        """
        == 연산자: 동등성 검사

        p1 == p2 → p1.__eq__(p2)
        """
        if isinstance(other, Person):
            return self.name == other.name and self.age == other.age
        return NotImplemented

    def __ne__(self, other: 'Person') -> bool:
        """
        != 연산자: 부등식 검사

        p1 != p2 → p1.__ne__(p2)
        """
        if isinstance(other, Person):
            return not self.__eq__(other)
        return NotImplemented

    # ========== 크기 비교 ==========

    def __lt__(self, other: 'Person') -> bool:
        """
        < 연산자: 미만

        p1 < p2 → p1.__lt__(p2)  (나이로 비교)
        """
        if isinstance(other, Person):
            return self.age < other.age
        return NotImplemented

    def __le__(self, other: 'Person') -> bool:
        """
        <= 연산자: 이하
        """
        if isinstance(other, Person):
            return self.age <= other.age
        return NotImplemented

    def __gt__(self, other: 'Person') -> bool:
        """
        > 연산자: 초과
        """
        if isinstance(other, Person):
            return self.age > other.age
        return NotImplemented

    def __ge__(self, other: 'Person') -> bool:
        """
        >= 연산자: 이상
        """
        if isinstance(other, Person):
            return self.age >= other.age
        return NotImplemented


class Version:
    """버전 클래스"""

    def __init__(self, major: int, minor: int, patch: int):
        self.major = major
        self.minor = minor
        self.patch = patch

    def __repr__(self) -> str:
        return f"Version({self.major}, {self.minor}, {self.patch})"

    def __str__(self) -> str:
        return f"{self.major}.{self.minor}.{self.patch}"

    def __eq__(self, other: 'Version') -> bool:
        if isinstance(other, Version):
            return (self.major == other.major and
                    self.minor == other.minor and
                    self.patch == other.patch)
        return NotImplemented

    def __lt__(self, other: 'Version') -> bool:
        """버전 비교"""
        if isinstance(other, Version):
            if self.major != other.major:
                return self.major < other.major
            if self.minor != other.minor:
                return self.minor < other.minor
            return self.patch < other.patch
        return NotImplemented

    def __le__(self, other: 'Version') -> bool:
        return self == other or self < other

    def __gt__(self, other: 'Version') -> bool:
        return other < self

    def __ge__(self, other: 'Version') -> bool:
        return other <= self

    def __ne__(self, other: 'Version') -> bool:
        return not self == other


def demonstrate_comparison_operators():
    """비교 연산자 시연"""
    print("\n" + "="*70)
    print("비교 연산자: 논리의 마법")
    print("="*70)

    # 사람 비교
    print("\n  [Person 비교]")
    alice = Person("Alice", 25)
    bob = Person("Bob", 30)
    alice_copy = Person("Alice", 25)

    print(f"    alice = {alice}")
    print(f"    bob = {bob}")
    print(f"    alice_copy = {alice_copy}")

    print("\n  [동등성 (==)]")
    print(f"    alice == alice_copy: {alice == alice_copy}")
    print(f"    alice == bob: {alice == bob}")

    print("\n  [부등식 (!=)]")
    print(f"    alice != bob: {alice != bob}")

    print("\n  [크기 비교 (나이 기준)]")
    print(f"    alice < bob: {alice < bob}")
    print(f"    alice <= bob: {alice <= bob}")
    print(f"    alice > bob: {alice > bob}")

    # 버전 비교
    print("\n  [Version 비교]")
    v1 = Version(1, 2, 3)
    v2 = Version(1, 3, 0)
    v3 = Version(1, 2, 3)

    print(f"    v1 = {v1}")
    print(f"    v2 = {v2}")
    print(f"    v3 = {v3}")

    print("\n  [버전 비교]")
    print(f"    v1 == v3: {v1 == v3}")
    print(f"    v1 < v2: {v1 < v2}")
    print(f"    v2 > v1: {v2 > v1}")

    print("\n  [정렬]")
    versions = [Version(2, 0, 0), Version(1, 5, 0), Version(1, 2, 3)]
    sorted_versions = sorted(versions)
    print(f"    원본: {[str(v) for v in versions]}")
    print(f"    정렬: {[str(v) for v in sorted_versions]}")

    print("\n" + "="*70)


# ============================================================================
# 메인 실행 함수
# ============================================================================

def main():
    """비교 연산자를 시연합니다"""
    print("\n" + "="*70)
    print("🐍 Python v1.4: 비교 연산자 - 논리의 마법")
    print("="*70)

    demonstrate_comparison_operators()

    print("\n" + "="*70)
    print("저장 필수. 너는 기록이 증명이다. Gogs.")
    print("="*70 + "\n")


if __name__ == "__main__":
    main()
