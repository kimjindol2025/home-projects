### Step 3: `functional_patterns.py` — 함수형 패턴

```python
# Pipeline Pattern (함수 합성)
class Pipeline:
    def __init__(self, value): self._value = value
    def pipe(self, func: Callable) -> 'Pipeline':
        return Pipeline(func(self._value))
    def execute(self): return self._value

# Specification Pattern (복잡한 비즈니스 조건 캡슐화)
class Specification(ABC):
    @abstractmethod
    def is_satisfied_by(self, candidate) -> bool: ...
    def and_spec(self, other) -> 'AndSpecification': ...
    def or_spec(self, other) -> 'OrSpecification': ...

class CompletedExperimentSpec(Specification):
    def is_satisfied_by(self, exp) -> bool:
        return exp['status'] == 'completed'

class HighScoreExperimentSpec(Specification):
    def __init__(self, min_score: float): self.min_score = min_score
    def is_satisfied_by(self, exp) -> bool:
        return (exp.get('result') or 0) >= self.min_score

# Result 모나드 (에러 처리 패턴)
class Result:
    @classmethod
    def ok(cls, value) -> 'Result': ...
    @classmethod
    def err(cls, error: str) -> 'Result': ...
    def map(self, func: Callable) -> 'Result': ...
    def flat_map(self, func: Callable) -> 'Result': ...
    def get_or_else(self, default) -> Any: ...
```

