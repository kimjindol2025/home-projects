### Step 2: `ddd_patterns.py` — DDD 도메인 주도 설계

```python
# Entity: 정체성(id)으로 식별되는 객체
class Researcher:
    def __init__(self, id: int, name: str, email: str, role: Role):
        self.id = id
        self.name = name
        self.email = email
        self.role = role
    def __eq__(self, other): return self.id == other.id  # id로만 비교

# Value Object: 값으로 비교하는 불변 객체
@dataclass(frozen=True)
class Email:
    value: str
    def __post_init__(self):
        if "@" not in self.value:
            raise ValueError("유효하지 않은 이메일")

@dataclass(frozen=True)
class ExperimentScore:
    value: float
    def __post_init__(self):
        if not (0.0 <= self.value <= 100.0):
            raise ValueError("점수는 0~100 범위여야 합니다")

# Aggregate Root: 외부에서 접근하는 진입점
class ExperimentAggregate:
    def __init__(self, id: int, researcher: Researcher):
        self._id = id
        self._researcher = researcher
        self._logs = []
        self._events = []

    def add_log(self, message: str):
        # 불변식(invariant) 검사 후 로그 추가 + 이벤트 등록
        if self._status == ExperimentStatus.COMPLETED:
            raise ValueError("완료된 실험에는 로그를 추가할 수 없습니다")
        self._logs.append(message)
        self._events.append(LogAddedEvent(self._id, message))

    def complete(self, score: ExperimentScore):
        # 도메인 규칙: 완료 시 점수 필수
        self._status = ExperimentStatus.COMPLETED
        self._score = score
        self._events.append(ExperimentCompletedEvent(self._id, score))

# Domain Event
@dataclass
class ExperimentCompletedEvent(DomainEvent):
    experiment_id: int
    final_score: ExperimentScore
```

