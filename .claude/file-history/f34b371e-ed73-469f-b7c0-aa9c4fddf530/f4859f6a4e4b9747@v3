### Step 1: `enterprise_patterns.py` — Enterprise 아키텍처 패턴

```python
# ============================================================
# 1. Repository 패턴
# ============================================================
# 목적: 데이터 접근 로직을 비즈니스 로직으로부터 분리
# v5.5 db_layer.py의 GogsDatabase를 Repository 패턴으로 추상화

class Repository(ABC):
    @abstractmethod
    def find_by_id(self, id: int) -> Optional[dict]: ...
    @abstractmethod
    def find_all(self) -> List[dict]: ...
    @abstractmethod
    def save(self, entity: dict) -> dict: ...
    @abstractmethod
    def delete(self, id: int) -> bool: ...

class ResearcherRepository(Repository):
    def __init__(self, db: GogsDatabase): self.db = db
    # GogsDatabase 위에 Repository 인터페이스를 씌움

class InMemoryResearcherRepository(Repository):
    # 테스트용 인메모리 구현 (DB 없이 테스트 가능!)
    def __init__(self): self._data = {}
    ...

# ============================================================
# 2. Unit of Work 패턴
# ============================================================
# 목적: 여러 Repository 작업을 하나의 트랜잭션으로 묶기
# v5.5 GogsDatabase의 context manager 방식 → UoW로 공식화

class UnitOfWork:
    def __init__(self, db: GogsDatabase):
        self.researchers = ResearcherRepository(db)
        self.experiments = ExperimentRepository(db)
        self._db = db

    def __enter__(self): return self
    def __exit__(self, *args):
        if args[0]: self._db.rollback()
        else: self._db.commit()

# ============================================================
# 3. Service Layer 패턴
# ============================================================
# 목적: 비즈니스 로직을 Controller/API에서 분리
# v5.5 api_handler.py의 handle_* 메서드 → Service 클래스로 분리

class ResearcherService:
    def __init__(self, uow: UnitOfWork):
        self.uow = uow

    def register_researcher(self, name: str, email: str, role: str) -> dict:
        # 비즈니스 로직: 중복 검사 + 생성 + 이벤트 발생
        with self.uow:
            ...

# ============================================================
# 4. CQRS - Command Query Responsibility Segregation
# ============================================================
# 목적: 읽기(Query)와 쓰기(Command) 책임 완전 분리

@dataclass
class CreateExperimentCommand:
    researcher_id: int
    subject: str
    description: str

class ExperimentCommandHandler:
    def handle(self, cmd: CreateExperimentCommand) -> dict: ...

class ExperimentQueryHandler:
    def get_all(self) -> List[dict]: ...
    def get_by_researcher(self, researcher_id: int) -> List[dict]: ...
    def get_statistics(self) -> dict: ...

# ============================================================
# 5. Event Sourcing
# ============================================================
# 목적: 상태가 아닌 이벤트의 시퀀스로 데이터 저장

@dataclass
class DomainEvent:
    event_type: str
    timestamp: datetime
    data: dict

class ExperimentEventStore:
    def append(self, event: DomainEvent): ...
    def get_events(self, experiment_id: int) -> List[DomainEvent]: ...
    def replay(self, events: List[DomainEvent]) -> dict: ...  # 최종 상태 재구성
