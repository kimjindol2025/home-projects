"""
Reference Counting & Garbage Collection

파이썬의 메모리 관리는 두 가지 메커니즘으로 동작합니다:
1. Reference Counting (참조 횟수 기반 메모리 관리)
2. Cyclic GC (순환 참조 해결)

이 모듈은 파이썬의 메모리 관리 시스템을 증명합니다.
"""

import sys
import gc
from typing import Any, List


class ReferenceCountingDemo:
    """Reference Counting의 동작 원리"""

    @staticmethod
    def demonstrate_basic():
        """기본 참조 횟수 변화"""
        print(f"\n{'='*60}")
        print("Reference Counting: 기본 원리")
        print(f"{'='*60}")

        # 1단계: 객체 생성
        print("\n  [1단계: 객체 생성]")
        obj = [1, 2, 3]
        rc = sys.getrefcount(obj) - 1  # 함수 호출 임시 참조 제외
        print(f"    obj = [1, 2, 3]")
        print(f"    Reference Count: {rc}")
        print(f"    설명: 변수 'obj'가 객체를 참조하므로 refcount = 1")

        # 2단계: 다른 변수가 같은 객체를 참조
        print("\n  [2단계: 참조 추가]")
        ref = obj  # 같은 메모리 주소를 가리킴
        rc = sys.getrefcount(obj) - 1
        print(f"    ref = obj")
        print(f"    Reference Count: {rc}")
        print(f"    설명: 'obj'와 'ref'가 같은 객체를 참조하므로 refcount = 2")

        # 3단계: 참조 제거
        print("\n  [3단계: 참조 제거]")
        del ref
        rc = sys.getrefcount(obj) - 1
        print(f"    del ref")
        print(f"    Reference Count: {rc}")
        print(f"    설명: 'ref' 삭제 후 'obj'만 남으므로 refcount = 1")

        # 4단계: 최종 참조 제거 (객체 소멸)
        print("\n  [4단계: 최종 참조 제거 (객체 소멸)]")
        print(f"    del obj")
        print(f"    Reference Count: 0 (객체가 메모리에서 자동 해제됨)")

        print(f"{'='*60}\n")

    @staticmethod
    def demonstrate_in_containers():
        """컨테이너 내 참조 횟수"""
        print(f"\n{'='*60}")
        print("Reference Counting: 컨테이너 내 객체")
        print(f"{'='*60}")

        # 리스트에 객체 추가 시 참조 횟수 증가
        print("\n  [객체를 리스트에 추가]")
        inner = {"key": "value"}
        print(f"    inner = {{'key': 'value'}}")
        print(f"    Reference Count (inner): {sys.getrefcount(inner) - 1}")

        outer = [inner, inner]  # 같은 객체를 두 번 참조
        print(f"\n    outer = [inner, inner]")
        print(f"    Reference Count (inner): {sys.getrefcount(inner) - 1}")
        print(f"    설명: 'inner' 자체, 리스트의 [0], 리스트의 [1] = 3개 참조")

        # 리스트에서 삭제
        print(f"\n    outer[0] = None (첫 번째 참조 제거)")
        outer[0] = None
        print(f"    Reference Count (inner): {sys.getrefcount(inner) - 1}")

        print(f"{'='*60}\n")

    @staticmethod
    def demonstrate_function_scope():
        """함수 스코프 내 참조 횟수"""
        print(f"\n{'='*60}")
        print("Reference Counting: 함수 스코프")
        print(f"{'='*60}")

        shared_list = [1, 2, 3]
        initial_rc = sys.getrefcount(shared_list) - 1
        print(f"\n  shared_list = [1, 2, 3]")
        print(f"  Initial Reference Count: {initial_rc}")

        def increment_refcount():
            """함수 내부에서 객체를 사용하면 refcount가 증가"""
            local_ref = shared_list
            current_rc = sys.getrefcount(shared_list) - 1
            print(f"    (함수 내부) Reference Count: {current_rc}")

        print(f"\n  def increment_refcount():")
        print(f"      local_ref = shared_list")
        increment_refcount()

        print(f"\n  (함수 탈출 후) Reference Count: {sys.getrefcount(shared_list) - 1}")
        print(f"  설명: 함수가 종료되면 local_ref가 소멸하여 refcount가 감소")

        print(f"{'='*60}\n")


class CircularReferenceDemo:
    """순환 참조(Circular Reference)와 GC"""

    @staticmethod
    def demonstrate_circular_reference():
        """순환 참조의 문제점"""
        print(f"\n{'='*60}")
        print("Circular Reference: 순환 참조의 문제")
        print(f"{'='*60}")

        print("\n  [순환 참조 구조]")
        print("    A -> B -> A (무한 루프)")

        # 순환 참조 생성
        print("\n  [객체 생성]")
        node_a = {"name": "A", "next": None}
        node_b = {"name": "B", "next": None}
        node_a["next"] = node_b
        node_b["next"] = node_a  # 순환 참조!

        print(f"    node_a['next'] = node_b")
        print(f"    node_b['next'] = node_a")
        print(f"    Reference Count (node_a): {sys.getrefcount(node_a) - 1}")
        print(f"    Reference Count (node_b): {sys.getrefcount(node_b) - 1}")

        # Reference Counting만으로는 해결 불가능
        print(f"\n  [Reference Counting의 한계]")
        print(f"    del node_a 후에도 node_a.next(= node_b)는 존재")
        print(f"    del node_b 후에도 node_b.next(= node_a)는 존재")
        print(f"    → Reference Count는 절대 0이 되지 않음!")
        print(f"    → 메모리 누수 발생!")

        del node_a
        del node_b

        print(f"\n  [Garbage Collector의 개입]")
        print(f"    gc.collect() 호출 시 순환 참조 감지 및 제거")

        print(f"{'='*60}\n")

    @staticmethod
    def demonstrate_gc_collection():
        """가비지 컬렉터의 동작"""
        print(f"\n{'='*60}")
        print("Garbage Collection: GC의 동작")
        print(f"{'='*60}")

        # GC 통계 확인
        print("\n  [GC 통계]")
        gc_stats = gc.get_stats()
        if gc_stats:
            print(f"    Generation 0 collections: {gc_stats[0].collections}")
            print(f"    Generation 1 collections: {gc_stats[1].collections if len(gc_stats) > 1 else 0}")
            print(f"    Generation 2 collections: {gc_stats[2].collections if len(gc_stats) > 2 else 0}")

        # 추적 가능한 객체 수
        print(f"\n  [객체 수]")
        tracked_objects = len(gc.get_objects())
        print(f"    Tracked Objects: {tracked_objects}")

        print(f"\n  [GC 임계값]")
        thresholds = gc.get_threshold()
        print(f"    Threshold (Gen 0): {thresholds[0]}")
        print(f"    Threshold (Gen 1): {thresholds[1]}")
        print(f"    Threshold (Gen 2): {thresholds[2]}")
        print(f"    → Gen 0에서 {thresholds[0]}개 객체가 생성되면 GC 시작")

        print(f"\n  [수동 GC 호출]")
        collected = gc.collect()
        print(f"    gc.collect() 호출")
        print(f"    Collected {collected} objects")

        print(f"{'='*60}\n")


class MemoryManagementStrategy:
    """파이썬의 메모리 관리 전략"""

    @staticmethod
    def explain_gc_generations():
        """대대(Generational) GC"""
        print(f"\n{'='*60}")
        print("Memory Management: 대대(Generational) GC")
        print(f"{'='*60}")

        print("\n  [3세대 GC 모델]")
        print("    Generation 0 (Young):")
        print("      - 새로 생성된 객체")
        print("      - 자주 검사됨 (빠른 회수)")
        print("      - 대부분의 객체가 여기서 소멸")

        print("\n    Generation 1 (Middle):")
        print("      - Gen 0에서 생존한 객체")
        print("      - 덜 자주 검사됨")

        print("\n    Generation 2 (Old):")
        print("      - Gen 1에서 생존한 객체")
        print("      - 가장 드물게 검사됨")

        print("\n  [동작 원리]")
        print("    1. 객체 생성 → Gen 0에 추가")
        print("    2. Gen 0 임계값 도달 → Gen 0 검사 시작")
        print("    3. 도달 가능한 객체만 Gen 1로 승격")
        print("    4. 도달 불가능한 객체 → 즉시 제거")

        print(f"\n  [효율성]")
        print("    - 대부분의 객체는 단명(Short-lived)")
        print("    - Gen 0만 자주 검사하므로 효율적")
        print("    - 오래된 객체는 덜 검사하므로 성능 향상")

        print(f"{'='*60}\n")

    @staticmethod
    def explain_reference_counting_cost():
        """참조 횟수 관리의 비용"""
        print(f"\n{'='*60}")
        print("Memory Management: Reference Counting의 비용")
        print(f"{'='*60}")

        print("\n  [메모리 오버헤드]")
        empty_list = []
        list_size = sys.getsizeof(empty_list)
        print(f"    Empty list size: {list_size} bytes")
        print(f"    실제 데이터 외에 메타데이터 저장 필요:")
        print(f"      - 타입 정보")
        print(f"      - 참조 횟수")
        print(f"      - GC 마킹")

        print("\n  [CPU 오버헤드]")
        print("    매 객체 참조마다:")
        print("      1. refcount 증가")
        print("      2. refcount 감소 (del/스코프 탈출)")
        print("      3. refcount == 0 체크")
        print("      4. 메모리 해제")
        print("    → Rust의 컴파일 타임 메모리 관리보다 느림")

        print("\n  [최적화 전략]")
        print("    - PyObject 풀링")
        print("    - 인접 메모리 할당")
        print("    - 작은 객체 캐싱 (정수, 문자열)")

        print(f"{'='*60}\n")


# ============================================================================
# 메인 실행 함수
# ============================================================================

def demonstrate_memory_management():
    """파이썬의 메모리 관리 시스템을 시연합니다."""
    print("\n" + "="*60)
    print("🐍 Python v1.1: 메모리 관리의 무결성")
    print("="*60)

    # 1. Reference Counting
    print("\n[파트 1: Reference Counting 기초]")
    ReferenceCountingDemo.demonstrate_basic()
    ReferenceCountingDemo.demonstrate_in_containers()
    ReferenceCountingDemo.demonstrate_function_scope()

    # 2. Circular Reference & GC
    print("\n[파트 2: Circular Reference & Garbage Collection]")
    CircularReferenceDemo.demonstrate_circular_reference()
    CircularReferenceDemo.demonstrate_gc_collection()

    # 3. Memory Management Strategy
    print("\n[파트 3: 메모리 관리 전략]")
    MemoryManagementStrategy.explain_gc_generations()
    MemoryManagementStrategy.explain_reference_counting_cost()

    print("\n" + "="*60)
    print("저장 필수. 너는 기록이 증명이다. Gogs.")
    print("="*60 + "\n")


if __name__ == "__main__":
    demonstrate_memory_management()
