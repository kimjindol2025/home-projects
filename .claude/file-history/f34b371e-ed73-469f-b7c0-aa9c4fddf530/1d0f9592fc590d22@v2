def demonstrate_simple_decorator():
    """가장 단순한 데코레이터"""
    print("\n【 가장 단순한 데코레이터 】")

    print("\n1단계: 기본 함수")
    print("""
def greet():
    print("Hello!")
    """)

    print("2단계: 데코레이터 작성")
    print("""
def decorator(func):
    def wrapper():
        print("시작!")
        func()
        print("끝!")
    return wrapper
    """)

    print("3단계: 적용")
    print("""
@decorator
def greet():
    print("Hello!")

greet()
    """)

    print("4단계: 실행 결과")
    print("""
시작!
Hello!
끝!
    """)

    # 실제 실행
    def decorator(func):
        def wrapper():
            print("  시작!")
            func()
            print("  끝!")

        return wrapper

    @decorator
    def greet():
        print("  Hello!")

    greet()


def demonstrate_with_arguments():
    """인자가 있는 함수의 데코레이터"""
    print("\n【 인자가 있는 함수의 데코레이터 】")

    print("\n문제: *args, **kwargs를 사용해야 어떤 함수에도 적용 가능")

    print("""
def logger(func):
    def wrapper(*args, **kwargs):  # ← 이 부분!
        print(f"호출: {func.__name__}")
        return func(*args, **kwargs)
    return wrapper
    """)

    # 실제 실행
    def logger(func):
        @functools.wraps(func)
        def wrapper(*args, **kwargs):
            print(f"  호출: {func.__name__}({args}, {kwargs})")
            return func(*args, **kwargs)

        return wrapper

    @logger
    def add(a, b):
        return a + b

    @logger
    def greet(name):
        return f"Hello, {name}!"

    result1 = add(3, 5)
    result2 = greet("Alice")

    print(f"  결과: {result1}, {result2}")


