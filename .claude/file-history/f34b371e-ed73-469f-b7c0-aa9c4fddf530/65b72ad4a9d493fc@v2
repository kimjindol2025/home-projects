class TransactionManager:
    """ACID 트랜잭션 관리"""

    def __init__(self):
        self.conn = sqlite3.connect(':memory:')
        self.cursor = self.conn.cursor()
        self.lock = threading.RLock()
        self.transaction_stack = []
        self._init_tables()

    def _init_tables(self):
        """테이블 초기화"""
        with self.lock:
            # Users 테이블
            self.cursor.execute('''
                CREATE TABLE IF NOT EXISTS users (
                    id INTEGER PRIMARY KEY,
                    name TEXT NOT NULL,
                    email TEXT UNIQUE NOT NULL,
                    created_at REAL
                )
            ''')

            # Accounts 테이블
            self.cursor.execute('''
                CREATE TABLE IF NOT EXISTS accounts (
                    id INTEGER PRIMARY KEY,
                    user_id INTEGER NOT NULL,
                    balance INTEGER NOT NULL,
                    account_type TEXT,
                    created_at REAL,
                    FOREIGN KEY (user_id) REFERENCES users(id)
                )
            ''')

            # Transactions 테이블
            self.cursor.execute('''
                CREATE TABLE IF NOT EXISTS transactions (
                    id INTEGER PRIMARY KEY,
                    from_account_id INTEGER,
                    to_account_id INTEGER,
                    amount INTEGER,
                    status TEXT,
                    timestamp REAL,
                    message TEXT
                )
            ''')

            self.conn.commit()

    def begin_transaction(self):
        """트랜잭션 시작 (Atomicity)"""
        with self.lock:
            self.transaction_stack.append({
                'start_time': time.time(),
                'operations': []
            })
            return len(self.transaction_stack) - 1

    def add_operation(self, operation: str, params: Tuple = ()):
        """작업 추가 (Isolation)"""
        if self.transaction_stack:
            self.transaction_stack[-1]['operations'].append({
                'sql': operation,
                'params': params
            })

    def commit(self) -> bool:
        """커밋 (Durability)"""
        if not self.transaction_stack:
            return False

        with self.lock:
            try:
                current = self.transaction_stack[-1]

                # 모든 작업 실행
                for op in current['operations']:
                    self.cursor.execute(op['sql'], op['params'])

                self.conn.commit()
                self.transaction_stack.pop()
                return True
            except Exception as e:
                self.rollback()
                return False

    def rollback(self) -> bool:
        """롤백 (Consistency)"""
        with self.lock:
            try:
                if self.transaction_stack:
                    self.conn.rollback()
                    self.transaction_stack.pop()
                return True
            except:
                return False

    def transfer_money(self, from_id: int, to_id: int, amount: int) -> bool:
        """돈 송금 (트랜잭션 예제)"""
        tx_id = self.begin_transaction()

        try:
            # Step 1: 출금 계좌 잔액 감소
            self.add_operation(
                'UPDATE accounts SET balance = balance - ? WHERE id = ?',
                (amount, from_id)
            )

            # Step 2: 입금 계좌 잔액 증가
            self.add_operation(
                'UPDATE accounts SET balance = balance + ? WHERE id = ?',
                (amount, to_id)
            )

            # Step 3: 거래 기록
            self.add_operation(
                '''INSERT INTO transactions
                   (from_account_id, to_account_id, amount, status, timestamp)
                   VALUES (?, ?, ?, 'completed', ?)''',
                (from_id, to_id, amount, time.time())
            )

            # 모든 작업이 성공해야만 커밋
            return self.commit()

        except:
            self.rollback()
            return False

    def insert_user(self, name: str, email: str) -> int:
        """사용자 삽입"""
        with self.lock:
            self.cursor.execute(
                'INSERT INTO users (name, email, created_at) VALUES (?, ?, ?)',
                (name, email, time.time())
            )
            self.conn.commit()
            return self.cursor.lastrowid

    def insert_account(self, user_id: int, account_type: str, balance: int) -> int:
        """계좌 삽입"""
        with self.lock:
            self.cursor.execute(
                '''INSERT INTO accounts (user_id, balance, account_type, created_at)
                   VALUES (?, ?, ?, ?)''',
                (user_id, balance, account_type, time.time())
            )
            self.conn.commit()
            return self.cursor.lastrowid

    def get_balance(self, account_id: int) -> Optional[int]:
        """잔액 조회"""
        with self.lock:
            self.cursor.execute(
                'SELECT balance FROM accounts WHERE id = ?',
                (account_id,)
            )
            result = self.cursor.fetchone()
            return result[0] if result else None

    def get_user(self, user_id: int) -> Optional[User]:
        """사용자 조회"""
        with self.lock:
            self.cursor.execute(
                'SELECT id, name, email, created_at FROM users WHERE id = ?',
                (user_id,)
            )
            result = self.cursor.fetchone()
            if result:
                return User(*result)
            return None


