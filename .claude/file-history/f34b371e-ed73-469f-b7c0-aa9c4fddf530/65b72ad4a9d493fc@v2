def demonstrate_acid_transactions():
    """ACID 트랜잭션 시연"""
    tx = TransactionManager()

    # 사용자 및 계좌 생성
    user_id = tx.insert_user('설계자', 'designer@gogs.io')
    acc1 = tx.insert_account(user_id, 'savings', 10000)
    acc2 = tx.insert_account(user_id, 'checking', 5000)

    # 송금 전
    balance1_before = tx.get_balance(acc1)
    balance2_before = tx.get_balance(acc2)

    # 송금 (트랜잭션)
    success = tx.transfer_money(acc1, acc2, 3000)

    # 송금 후
    balance1_after = tx.get_balance(acc1)
    balance2_after = tx.get_balance(acc2)

    return {
        'success': success,
        'from_before': balance1_before,
        'from_after': balance1_after,
        'to_before': balance2_before,
        'to_after': balance2_after
    }


