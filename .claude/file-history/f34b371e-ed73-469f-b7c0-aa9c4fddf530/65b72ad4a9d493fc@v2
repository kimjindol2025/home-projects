class NoSQLStore:
    """NoSQL 문서 저장소 (Key-Value + Document)"""

    def __init__(self):
        self.documents = {}  # {doc_id: Document}
        self.collections = defaultdict(list)  # {collection_name: [doc_ids]}
        self.indexes = defaultdict(lambda: defaultdict(list))  # {collection: {field: [doc_ids]}}

    def insert_document(self, collection: str, doc_id: str, data: Dict[str, Any]) -> bool:
        """문서 삽입"""
        doc = Document(
            doc_id=doc_id,
            collection=collection,
            data=data
        )
        self.documents[doc_id] = doc
        self.collections[collection].append(doc_id)

        # 자동 인덱싱
        for key, value in data.items():
            self.indexes[collection][key].append((doc_id, value))

        return True

    def find_by_id(self, doc_id: str) -> Optional[Document]:
        """ID로 검색"""
        return self.documents.get(doc_id)

    def find_in_collection(self, collection: str, query: Dict[str, Any]) -> List[Document]:
        """컬렉션에서 검색 (query: {field: value})"""
        result = []
        for doc_id in self.collections[collection]:
            doc = self.documents[doc_id]
            match = True
            for key, value in query.items():
                if doc.data.get(key) != value:
                    match = False
                    break
            if match:
                result.append(doc)
        return result

    def update_document(self, doc_id: str, update_data: Dict[str, Any]) -> bool:
        """문서 업데이트"""
        if doc_id not in self.documents:
            return False

        doc = self.documents[doc_id]
        doc.data.update(update_data)
        doc.updated_at = time.time()
        return True

    def delete_document(self, doc_id: str) -> bool:
        """문서 삭제"""
        if doc_id not in self.documents:
            return False

        doc = self.documents[doc_id]
        self.collections[doc.collection].remove(doc_id)
        del self.documents[doc_id]
        return True

    def count_collection(self, collection: str) -> int:
        """컬렉션 크기"""
        return len(self.collections[collection])

    def aggregate(self, collection: str, pipeline: List[Dict[str, Any]]) -> List[Any]:
        """집계 쿼리"""
        result = []
        for stage in pipeline:
            if '$match' in stage:
                result = self.find_in_collection(collection, stage['$match'])
            elif '$group' in stage:
                # 간단한 그룹화
                groups = defaultdict(list)
                for doc in result:
                    key = doc.data.get(stage['$group'].get('_id'))
                    groups[key].append(doc)
                result = list(groups.values())

        return result


