class QueryOptimizer:
    """쿼리 실행 계획 최적화"""

    def __init__(self):
        self.query_log = []
        self.stats = {
            'total_queries': 0,
            'avg_execution_time_ms': 0
        }

    def analyze_query(self, query: str) -> Dict[str, Any]:
        """쿼리 분석"""
        plan = {
            'query': query,
            'type': 'SELECT' if query.startswith('SELECT') else 'OTHER',
            'estimated_rows': 0,
            'estimated_cost': 0,
            'optimization_suggestions': []
        }

        # 간단한 최적화 제안
        if 'WHERE' not in query:
            plan['optimization_suggestions'].append('WHERE 절 추가하면 성능 향상')
        if 'ORDER BY' in query and 'INDEX' not in query:
            plan['optimization_suggestions'].append('ORDER BY 칼럼에 인덱스 생성')
        if 'JOIN' in query:
            plan['optimization_suggestions'].append('JOIN 순서 재정렬 고려')

        return plan

    def estimate_execution_time(self, query: str, rows: int) -> float:
        """실행 시간 예측 (밀리초)"""
        # 매우 간단한 추정
        base_time = 1.0  # ms
        if 'JOIN' in query:
            base_time *= rows * 0.1
        elif 'WHERE' in query:
            base_time *= rows * 0.01
        else:
            base_time *= rows * 0.001

        return min(base_time, 1000.0)  # 최대 1초

    def log_query(self, query: str, execution_time: float):
        """쿼리 로깅"""
        self.query_log.append({
            'query': query,
            'execution_time': execution_time,
            'timestamp': time.time()
        })
        self.stats['total_queries'] += 1

    def get_slow_queries(self, threshold_ms: float = 100.0) -> List[Dict[str, Any]]:
        """느린 쿼리 찾기"""
        return [q for q in self.query_log if q['execution_time'] > threshold_ms]


