class DatabasePhilosophy:
    """데이터베이스 철학"""

    @staticmethod
    def acid_principles():
        """ACID 원칙"""
        return {
            "원자성 (Atomicity)": "모든 작업이 성공하거나 모두 실패 (all or nothing)",
            "일관성 (Consistency)": "트랜잭션 전후로 데이터베이스가 유효한 상태",
            "고립성 (Isolation)": "동시에 실행되는 트랜잭션은 서로 영향 없음",
            "지속성 (Durability)": "커밋된 데이터는 시스템 장애 후에도 유지"
        }

    @staticmethod
    def normalization_levels():
        """정규화 레벨"""
        return {
            "1NF (First Normal Form)": "각 셀에는 원자값만 (리스트 아님)",
            "2NF (Second Normal Form)": "1NF + 부분 종속 제거",
            "3NF (Third Normal Form)": "2NF + 이행 종속 제거",
            "BCNF": "3NF + 더 엄격한 규칙"
        }

    @staticmethod
    def rdbms_vs_nosql():
        """RDBMS vs NoSQL 비교"""
        return {
            "RDBMS": {
                "특징": "구조화된 데이터, 강한 일관성",
                "용도": "금융, 전자상거래 (정확성 중요)",
                "확장": "수직 확장 (한 서버를 강하게)",
                "성능": "복잡한 쿼리 최적화 가능"
            },
            "NoSQL": {
                "특징": "자유로운 구조, 최종 일관성",
                "용도": "SNS, 로그, 게임 (속도 중요)",
                "확장": "수평 확장 (여러 서버에 분산)",
