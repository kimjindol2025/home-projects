class BackupManager:
    """데이터베이스 백업/복구"""

    def __init__(self, tx_manager: TransactionManager):
        self.tx_manager = tx_manager
        self.backups = {}

    def create_backup(self, backup_name: str) -> bool:
        """백업 생성"""
        try:
            cursor = self.tx_manager.cursor
            backup_data = {
                'users': cursor.execute('SELECT * FROM users').fetchall(),
                'accounts': cursor.execute('SELECT * FROM accounts').fetchall(),
                'transactions': cursor.execute('SELECT * FROM transactions').fetchall(),
                'timestamp': time.time()
            }
            self.backups[backup_name] = backup_data
            return True
        except:
            return False

    def restore_backup(self, backup_name: str) -> bool:
        """백업 복구"""
        if backup_name not in self.backups:
            return False

        try:
            backup = self.backups[backup_name]
            cursor = self.tx_manager.cursor

            # 테이블 초기화
            cursor.execute('DELETE FROM transactions')
            cursor.execute('DELETE FROM accounts')
            cursor.execute('DELETE FROM users')

            # 데이터 복구
            for user in backup['users']:
                cursor.execute('INSERT INTO users VALUES (?, ?, ?, ?)', user)
            for account in backup['accounts']:
                cursor.execute('INSERT INTO accounts VALUES (?, ?, ?, ?, ?)', account)
            for tx in backup['transactions']:
                cursor.execute(
                    'INSERT INTO transactions VALUES (?, ?, ?, ?, ?, ?, ?)',
                    tx
                )

            self.tx_manager.conn.commit()
            return True
        except:
            self.tx_manager.conn.rollback()
            return False

    def get_backup_info(self, backup_name: str) -> Dict[str, Any]:
        """백업 정보"""
        if backup_name not in self.backups:
            return {}

        backup = self.backups[backup_name]
        return {
            'name': backup_name,
            'timestamp': backup['timestamp'],
            'users_count': len(backup['users']),
            'accounts_count': len(backup['accounts']),
            'transactions_count': len(backup['transactions'])
        }


