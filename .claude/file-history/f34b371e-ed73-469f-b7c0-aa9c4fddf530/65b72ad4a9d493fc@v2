class DataConsistencyChecker:
    """데이터 일관성 검증"""

    def __init__(self, tx_manager: TransactionManager):
        self.tx_manager = tx_manager
        self.violations = []

    def check_referential_integrity(self) -> bool:
        """참조 무결성 검사 (Foreign Key)"""
        # 모든 user_id가 users 테이블에 존재하는지 확인
        cursor = self.tx_manager.cursor
        cursor.execute('''
            SELECT COUNT(*) FROM accounts a
            WHERE NOT EXISTS (SELECT 1 FROM users u WHERE u.id = a.user_id)
        ''')
        invalid_count = cursor.fetchone()[0]
        return invalid_count == 0

    def check_balance_consistency(self) -> bool:
        """잔액 일관성 검사"""
        cursor = self.tx_manager.cursor
        cursor.execute('SELECT SUM(balance) FROM accounts')
        total = cursor.fetchone()[0] or 0
        return total >= 0  # 음수 잔액 없음

    def check_transaction_integrity(self) -> bool:
        """거래 무결성 검사"""
        cursor = self.tx_manager.cursor
        cursor.execute('''
            SELECT COUNT(*) FROM transactions
            WHERE status NOT IN ('pending', 'completed', 'failed')
        ''')
        invalid_count = cursor.fetchone()[0]
        return invalid_count == 0

    def verify_all(self) -> Dict[str, bool]:
        """모든 검사 실행"""
        return {
            'referential_integrity': self.check_referential_integrity(),
            'balance_consistency': self.check_balance_consistency(),
            'transaction_integrity': self.check_transaction_integrity()
        }


