class IndexManager:
    """인덱스 관리 (검색 속도 최적화)"""

    def __init__(self):
        self.indexes = defaultdict(dict)  # {column_name: {value: [record_ids]}}
        self.stats = {
            'index_creation_count': 0,
            'index_hit_count': 0,
            'full_scan_count': 0
        }

    def create_index(self, column_name: str, values_list: List[Tuple[int, Any]]):
        """인덱스 생성"""
        # values_list: [(record_id, value), ...]
        for record_id, value in values_list:
            if value not in self.indexes[column_name]:
                self.indexes[column_name][value] = []
            self.indexes[column_name][value].append(record_id)

        self.stats['index_creation_count'] += 1

    def search_by_index(self, column_name: str, value: Any) -> List[int]:
        """인덱스로 검색 (빠름)"""
        if column_name in self.indexes and value in self.indexes[column_name]:
            self.stats['index_hit_count'] += 1
            return self.indexes[column_name][value]
        return []

    def full_scan(self, column_name: str, value: Any, all_records: List[Tuple]) -> List[int]:
        """전체 스캔 (느림)"""
        self.stats['full_scan_count'] += 1
        result = []
        for record_id, record_value in all_records:
            if record_value == value:
                result.append(record_id)
        return result

    def get_stats(self) -> Dict[str, Any]:
        """인덱스 통계"""
        return {
            'index_count': len(self.indexes),
            'hit_count': self.stats['index_hit_count'],
            'full_scan_count': self.stats['full_scan_count'],
            'hit_ratio': self.stats['index_hit_count'] / (
                self.stats['index_hit_count'] + self.stats['full_scan_count']
            ) if (self.stats['index_hit_count'] + self.stats['full_scan_count']) > 0 else 0
        }


