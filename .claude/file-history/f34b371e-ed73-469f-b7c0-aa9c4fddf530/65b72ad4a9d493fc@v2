def demonstrate_nosql():
    """NoSQL 시연"""
    store = NoSQLStore()

    # 문서 삽입
    store.insert_document('users', 'user1', {
        'name': '설계자',
        'email': 'designer@gogs.io',
        'age': 25
    })
    store.insert_document('users', 'user2', {
        'name': '개발자',
        'email': 'dev@gogs.io',
        'age': 28
    })

    # 검색
    result = store.find_in_collection('users', {'age': 25})

    return {
        'total_documents': store.count_collection('users'),
        'found_documents': len(result),
        'document_ids': [d.doc_id for d in result]
    }


def demonstrate_indexing():
    """인덱싱 시연"""
    index_mgr = IndexManager()

    # 데이터
    data = [(1, 'Alice'), (2, 'Bob'), (3, 'Alice'), (4, 'Charlie'), (5, 'Alice')]

    # 인덱스 생성
    index_mgr.create_index('name', data)

    # 검색
    result1 = index_mgr.search_by_index('name', 'Alice')
    result2 = index_mgr.full_scan('name', 'Alice', data)

    return {
        'index_hits': result1,
        'full_scan_result': result2,
        'hit_ratio': index_mgr.get_stats()['hit_ratio']
    }


def demonstrate_consistency_check():
    """일관성 검사 시연"""
    tx = TransactionManager()

    # 데이터 생성
    user_id = tx.insert_user('설계자', 'designer@gogs.io')
    tx.insert_account(user_id, 'savings', 10000)

    # 일관성 검사
    checker = DataConsistencyChecker(tx)
    results = checker.verify_all()

    return results


