{% extends "base.html" %}

{% block title %}연구자 관리 - Gogs{% endblock %}

{% block content %}
<div class="card">
    <h2>👥 연구자 관리</h2>
    <button class="btn btn-primary" onclick="openAddResearcherModal()">➕ 새 연구자 추가</button>

    {% if researchers %}
    <table style="margin-top: 20px;">
        <thead>
            <tr>
                <th>이름</th>
                <th>이메일</th>
                <th>역할</th>
                <th>생성 일시</th>
                <th>작업</th>
            </tr>
        </thead>
        <tbody>
            {% for researcher in researchers %}
            <tr>
                <td><strong>{{ researcher.name }}</strong></td>
                <td>{{ researcher.email }}</td>
                <td>
                    <span class="badge badge-success">{{ researcher.role }}</span>
                </td>
                <td>{{ researcher.created_at[:10] }}</td>
                <td>
                    <button class="btn btn-secondary" onclick="editResearcher({{ researcher.id }}, '{{ researcher.name }}', '{{ researcher.email }}', '{{ researcher.role }}')">수정</button>
                    <button class="btn btn-danger" onclick="deleteResearcher({{ researcher.id }}, '{{ researcher.name }}')">삭제</button>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% else %}
    <p style="color: #999; text-align: center; padding: 40px;">연구자가 없습니다</p>
    {% endif %}
</div>

<!-- 연구자 추가 모달 -->
<div id="addResearcherModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
    <div class="card" style="width: 100%; max-width: 500px; margin: 0;">
        <h2>새 연구자 추가</h2>
        <form id="addResearcherForm">
            <div class="form-group">
                <label for="researcherName">이름 *</label>
                <input type="text" id="researcherName" required>
            </div>
            <div class="form-group">
                <label for="researcherEmail">이메일 *</label>
                <input type="email" id="researcherEmail" required>
            </div>
            <div class="form-group">
                <label for="researcherRole">역할</label>
                <select id="researcherRole">
                    <option value="researcher">Researcher</option>
                    <option value="admin">Admin</option>
                    <option value="viewer">Viewer</option>
                </select>
            </div>
            <div style="display: flex; gap: 10px;">
                <button type="submit" class="btn btn-primary" style="flex: 1;">추가</button>
                <button type="button" class="btn btn-secondary" style="flex: 1;" onclick="closeAddResearcherModal()">취소</button>
            </div>
        </form>
    </div>
</div>

<!-- 연구자 수정 모달 -->
<div id="editResearcherModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
    <div class="card" style="width: 100%; max-width: 500px; margin: 0;">
        <h2>연구자 정보 수정</h2>
        <form id="editResearcherForm">
            <input type="hidden" id="editResearcherId">
            <div class="form-group">
                <label for="editResearcherName">이름 *</label>
                <input type="text" id="editResearcherName" required>
            </div>
            <div class="form-group">
                <label for="editResearcherEmail">이메일 *</label>
                <input type="email" id="editResearcherEmail" required>
            </div>
            <div class="form-group">
                <label for="editResearcherRole">역할</label>
                <select id="editResearcherRole">
                    <option value="researcher">Researcher</option>
                    <option value="admin">Admin</option>
                    <option value="viewer">Viewer</option>
                </select>
            </div>
            <div style="display: flex; gap: 10px;">
                <button type="submit" class="btn btn-primary" style="flex: 1;">저장</button>
                <button type="button" class="btn btn-secondary" style="flex: 1;" onclick="closeEditResearcherModal()">취소</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openAddResearcherModal() {
        document.getElementById('addResearcherModal').style.display = 'flex';
    }

    function closeAddResearcherModal() {
        document.getElementById('addResearcherModal').style.display = 'none';
    }

    function closeEditResearcherModal() {
        document.getElementById('editResearcherModal').style.display = 'none';
    }

    function editResearcher(id, name, email, role) {
        document.getElementById('editResearcherId').value = id;
        document.getElementById('editResearcherName').value = name;
        document.getElementById('editResearcherEmail').value = email;
        document.getElementById('editResearcherRole').value = role;
        document.getElementById('editResearcherModal').style.display = 'flex';
    }

    function deleteResearcher(id, name) {
        if (confirm(`${name}을(를) 삭제하시겠습니까?`)) {
            fetch(`/api/v1/researchers/${id}`, { method: 'DELETE' })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        alert('삭제되었습니다');
                        location.reload();
                    } else {
                        alert('오류: ' + data.message);
                    }
                });
        }
    }

    document.getElementById('addResearcherForm').addEventListener('submit', async (e) => {
        e.preventDefault();

        const name = document.getElementById('researcherName').value;
        const email = document.getElementById('researcherEmail').value;
        const role = document.getElementById('researcherRole').value;

        try {
            const response = await fetch('/api/v1/researchers', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name, email, role })
            });

            const data = await response.json();

            if (data.success) {
                alert('연구자가 추가되었습니다!');
                closeAddResearcherModal();
                location.reload();
            } else {
                alert('오류: ' + data.message);
            }
        } catch (error) {
            alert('오류가 발생했습니다');
        }
    });

    document.getElementById('editResearcherForm').addEventListener('submit', async (e) => {
        e.preventDefault();

        const id = document.getElementById('editResearcherId').value;
        const name = document.getElementById('editResearcherName').value;
        const email = document.getElementById('editResearcherEmail').value;
        const role = document.getElementById('editResearcherRole').value;

        try {
            const response = await fetch(`/api/v1/researchers/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name, email, role })
            });

            const data = await response.json();

            if (data.success) {
                alert('수정되었습니다!');
                closeEditResearcherModal();
                location.reload();
            } else {
                alert('오류: ' + data.message);
            }
        } catch (error) {
            alert('오류가 발생했습니다');
        }
    });
</script>
{% endblock %}
