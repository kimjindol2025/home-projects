"""
v2.1 Exception Handling - 예외 처리

예외 처리: 파이썬 고등학교 1학년
에러를 다스리고, 실패를 기록하는 견고한 시스템
"""


def gogs_divider(a, b):
    """
    [Python High-School v2.1] 예외 처리
    안전한 나눗셈 함수
    """
    try:
        print(f"--- {a} 나누기 {b} 시도 ---")
        result = a / b
        return result
    except ZeroDivisionError:
        # 0으로 나눌 때 발생하는 특정 에러를 잡아냄
        print("[ERROR] 0으로 나눌 수 없습니다! 기본값 0을 기록합니다.")
        return 0
    except TypeError:
        # 숫자가 아닌 값이 들어왔을 때 처리
        print("[ERROR] 숫자가 아닌 입력이 감지되었습니다.")
        return None
    finally:
        # 에러 여부와 상관없이 항상 실행 (증명을 위한 기록)
        print("로그: 연산 시도가 마무리되었습니다.")


def exception_handling_demo():
    """예외 처리 데모"""
    results = {}

    # 1. 정상 작동
    print("="*60)
    print("테스트 1: 정상 작동 (10 / 2)")
    print("="*60)
    result1 = gogs_divider(10, 2)
    print(f"결과 1: {result1}")
    results["normal"] = result1

    # 2. 0으로 나누기 (에러 방어)
    print("\n" + "="*60)
    print("테스트 2: 0으로 나누기 (10 / 0)")
    print("="*60)
    result2 = gogs_divider(10, 0)
    print(f"결과 2: {result2}")
    results["zero_division"] = result2

    # 3. 잘못된 타입 입력 (에러 방어)
    print("\n" + "="*60)
    print("테스트 3: 잘못된 타입 입력 (10 / 'gogs')")
    print("="*60)
    result3 = gogs_divider(10, "gogs")
    print(f"결과 3: {result3}")
    results["type_error"] = result3

    print("\n저장 필수 너는 기록이 증명이다 gogs")

    return results


def main():
    """v2.1 실행"""
    print("\n" + "="*70)
    print("🐍 Python v2.1: 예외 처리(Exception Handling) — 에러를 다스리는 법")
    print("="*70 + "\n")

    exception_handling_demo()

    print("\n" + "="*70)


if __name__ == "__main__":
    main()
