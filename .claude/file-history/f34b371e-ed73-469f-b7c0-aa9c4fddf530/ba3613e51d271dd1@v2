class SimpleResource:
    """가장 간단한 리소스 매니저"""

    def __init__(self, name: str):
        self.name = name
        self.is_open = False

    def __enter__(self):
        """리소스 획득"""
        print(f"✅ [{self.name}] 획득함")
        self.is_open = True
        return self

    def __exit__(self, exc_type, exc_val, exc_tb):
        """리소스 정리"""
        self.is_open = False
        if exc_type:
            print(f"❌ [{self.name}] 예외 발생: {exc_type.__name__}: {exc_val}")
        print(f"🔒 [{self.name}] 해제함")
        return False  # 예외를 전파


class FileManager:
    """파일 처리 컨텍스트 매니저"""

    def __init__(self, filepath: str, mode: str = "r"):
        self.filepath = filepath
        self.mode = mode
        self.file = None

    def __enter__(self):
        """파일 열기"""
        self.file = open(self.filepath, self.mode)
        print(f"📂 파일 열음: {self.filepath}")
        return self.file

    def __exit__(self, exc_type, exc_val, exc_tb):
        """파일 닫기"""
        if self.file:
            self.file.close()
            print(f"📂 파일 닫음: {self.filepath}")
        if exc_type:
            print(f"⚠️ 파일 처리 중 오류: {exc_val}")
        return False


class DatabaseConnection:
    """데이터베이스 연결 매니저"""

    def __init__(self, db_name: str):
        self.db_name = db_name
        self.connection = None

    def __enter__(self):
        """데이터베이스 연결"""
        self.connection = f"Connection<{self.db_name}>"
        print(f"🔌 데이터베이스 연결: {self.db_name}")
        return self

    def __exit__(self, exc_type, exc_val, exc_tb):
        """데이터베이스 연결 종료"""
        if self.connection:
            self.connection = None
            print(f"🔌 데이터베이스 연결 해제: {self.db_name}")
        return False

    def execute(self, query: str) -> str:
        """쿼리 실행"""
        if not self.connection:
            raise RuntimeError("연결되지 않음")
        return f"Result: {query}"


