# [6] 데코레이터로 컨텍스트 매니저 만들기
# ============================================================================

@contextlib.contextmanager
def temporary_file(mode: str = "w") -> any:
    """임시 파일을 다루는 컨텍스트 매니저"""
    import tempfile

    file = tempfile.NamedTemporaryFile(mode=mode, delete=False)
    filepath = file.name
    try:
        print(f"📝 임시 파일 생성: {filepath}")
        yield file
    finally:
        file.close()
        Path(filepath).unlink()
        print(f"📝 임시 파일 삭제: {filepath}")


@contextlib.contextmanager
def working_directory(path: str):
    """임시로 작업 디렉토리 변경"""
    import os

    old_cwd = os.getcwd()
    try:
        os.chdir(path)
        print(f"📁 작업 디렉토리: {path}")
        yield path
    finally:
        os.chdir(old_cwd)
        print(f"📁 작업 디렉토리 복원: {old_cwd}")


