class LabEquipment:
    """연구실 정밀 장비 관리"""

    def __init__(self, device_name: str):
        self.device_name = device_name
        self.is_running = False

    def __enter__(self):
        """장비 가동"""
        print(f"🚀 [START] {self.device_name} 전원 ON. 데이터 수집을 시작합니다.")
        self.is_running = True
        return self

    def __exit__(self, exc_type, exc_val, exc_tb):
        """장비 정지 및 정리"""
        self.is_running = False
        if exc_type:
            print(f"⚠️ [ALERT] 작업 중 에러 발생: {exc_type.__name__}: {exc_val}")
            print(f"🛑 [EMERGENCY STOP] {self.device_name} 긴급 정지!")
        else:
            print(f"🛑 [STOP] {self.device_name} 전원 OFF. 시스템을 안전하게 보호합니다.")
        return False

    def collect_data(self) -> str:
        """데이터 수집"""
        if not self.is_running:
            raise RuntimeError("장비가 가동 중이 아님")
        return "데이터 수집 완료"


