    return {"results": results}


def demonstrate_exception_safety() -> dict:
    """예외 안전성 데모"""
    results = []

    try:
        with SimpleResource("리소스 B") as res:
            results.append("리소스 사용 중...")
            raise ValueError("의도적인 에러!")
    except ValueError as e:
        results.append(f"예외 처리: {e}")

    return {"results": results}


def demonstrate_timer() -> dict:
    """타이머 데모"""
    with Timer("계산 작업") as timer:
        time.sleep(0.1)

    return {"elapsed": timer.elapsed}


def demonstrate_exception_ignorer() -> dict:
    """예외 무시 데모"""
    results = []

    with ExceptionIgnorer(ValueError):
        results.append("작업 시작")
        raise ValueError("이 에러는 무시됨")

    results.append("프로그램 계속")
    return {"results": results}


