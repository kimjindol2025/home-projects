# [4] 고급 패턴: 락 (동시성)
# ============================================================================

class LockManager:
    """락 관리 컨텍스트 매니저"""

    def __init__(self, lock: threading.Lock, name: str = "락"):
        self.lock = lock
        self.name = name

    def __enter__(self):
        """락 획득"""
        print(f"🔐 [{self.name}] 락 획득 시도...")
        self.lock.acquire()
        print(f"🔓 [{self.name}] 락 획득함")
        return self

    def __exit__(self, exc_type, exc_val, exc_tb):
        """락 해제"""
        self.lock.release()
        print(f"🔓 [{self.name}] 락 해제함")
        return False


