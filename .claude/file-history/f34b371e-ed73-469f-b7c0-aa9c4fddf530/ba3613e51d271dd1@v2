class ResourcePool:
    """리소스 풀 관리"""

    def __init__(self, resource_count: int):
        self.resource_count = resource_count
        self.available = resource_count

    def __enter__(self):
        """리소스 획득"""
        if self.available <= 0:
            raise RuntimeError("사용 가능한 리소스가 없음")
        self.available -= 1
        print(f"📦 리소스 획득 (남은 리소스: {self.available}/{self.resource_count})")
        return self

    def __exit__(self, exc_type, exc_val, exc_tb):
        """리소스 반환"""
        self.available += 1
        print(f"📦 리소스 반환 (남은 리소스: {self.available}/{self.resource_count})")
        return False


