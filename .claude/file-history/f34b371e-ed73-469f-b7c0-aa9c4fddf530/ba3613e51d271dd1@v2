class Timer:
    """성능 측정 컨텍스트 매니저"""

    def __init__(self, name: str = "작업"):
        self.name = name
        self.start_time = None
        self.elapsed = None

    def __enter__(self):
        """시작 시간 기록"""
        self.start_time = time.time()
        print(f"⏱️ [{self.name}] 시작...")
        return self

    def __exit__(self, exc_type, exc_val, exc_tb):
        """경과 시간 계산 및 출력"""
        self.elapsed = time.time() - self.start_time
        if exc_type:
            print(f"❌ [{self.name}] 실패 ({self.elapsed:.4f}초)")
        else:
            print(f"✅ [{self.name}] 완료 ({self.elapsed:.4f}초)")
        return False


