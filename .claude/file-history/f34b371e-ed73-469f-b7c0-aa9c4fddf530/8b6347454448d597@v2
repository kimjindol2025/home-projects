class TestProjectArchitecture:
    """프로젝트 아키텍처 테스트"""

    def test_initialization(self):
        """아키텍처 초기화"""
        arch = ProjectArchitecture()
        assert len(arch.packages) == 4
        assert "core" in arch.packages
        assert "utils" in arch.packages
        assert "services" in arch.packages
        assert "api" in arch.packages

    def test_get_structure(self):
        """프로젝트 구조 조회"""
        arch = ProjectArchitecture()
        structure = arch.get_structure()

        assert structure["project"] == "gogs_project"
        assert "packages" in structure
        assert structure["total_packages"] == 4

    def test_package_modules(self):
        """각 패키지의 모듈"""
        arch = ProjectArchitecture()

        core_info = arch.packages["core"].get_info()
        assert "engine" in core_info["modules"]
        assert "model" in core_info["modules"]

        utils_info = arch.packages["utils"].get_info()
        assert "logger" in utils_info["modules"]
        assert "validator" in utils_info["modules"]

    def test_get_dependency_graph(self):
        """모듈 의존성 그래프"""
        arch = ProjectArchitecture()
        graph = arch.get_dependency_graph()

        assert "api" in graph
        assert "services" in graph["api"]
        assert "utils" in graph["api"]

    def test_validate_imports(self):
        """import 규칙 검증"""
        arch = ProjectArchitecture()
        validation = arch.validate_imports()

        # 상위 계층이 하위 계층 import 가능
        assert validation["api_imports_services"] is True
        assert validation["services_imports_core"] is True

        # 하위 계층이 상위 계층 import 불가
        assert validation["core_imports_api"] is False
        assert validation["utils_imports_api"] is False

    def test_get_architecture_diagram(self):
        """아키텍처 다이어그램"""
        arch = ProjectArchitecture()
        diagram = arch.get_architecture_diagram()

        assert "API Layer" in diagram
        assert "Services Layer" in diagram
        assert "Core Layer" in diagram
        assert "Utils Layer" in diagram


