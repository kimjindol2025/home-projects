class TestRealWorldScenarios:
    """실제 사용 시나리오"""

    def test_multi_tenant_auth_system(self):
        """멀티 테넌트 인증 시스템"""
        auth = AuthModule("tenant_auth")
        auth.initialize()

        # 여러 테넌트 사용자 등록
        for tenant_id in range(1, 4):
            for user_id in range(1, 3):
                username = f"tenant_{tenant_id}_user_{user_id}"
                auth.register_user(username, f"password_{user_id}")

        users = auth.list_users()
        assert len(users) == 6

    def test_data_processing_pipeline(self):
        """데이터 처리 파이프라인"""
        data_module = DataModule("pipeline")
        data_module.initialize()

        # 여러 배치 처리
        batches = [
            [1, 2, 3, 4, 5],
            [10, 20, 30],
            [100, 200, 300, 400, 500],
        ]

        results = [data_module.process_data(batch) for batch in batches]
        assert len(results) == 3
        assert results[0]["sum"] == 15
        assert results[1]["sum"] == 60
        assert results[2]["sum"] == 1500

    def test_plugin_based_extension_system(self):
        """플러그인 기반 확장 시스템"""
        system = PluginSystem()

        # 여러 플러그인 동적 로딩
        for i in range(3):
            if i % 2 == 0:
                system.register_plugin(f"hello_{i}", HelloPlugin())
            else:
                system.register_plugin(f"calc_{i}", CalculatorPlugin())

        assert len(system.list_plugins()) == 3

    def test_layered_architecture_evolution(self):
        """계층 아키텍처 진화"""
        arch = ProjectArchitecture()

        # 초기 구조
        initial = arch.get_structure()
        assert initial["total_packages"] == 4

        # 의존성 규칙 준수 검증
        validation = arch.validate_imports()
        true_count = sum(1 for v in validation.values() if v)
        false_count = sum(1 for v in validation.values() if not v)

        assert true_count >= 2  # 상위→하위 관계
        assert false_count >= 2  # 역방향 불가


