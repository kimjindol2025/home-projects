class TestIntegration:
    """통합 테스트"""

    def test_single_layer_integration(self):
        """단일 계층 통합 테스트"""
        pkg = SingleLayerPackage()
        pkg.initialize_all()

        # 데이터 처리
        data = pkg.data_module.process_data([1, 2, 3, 4, 5])
        assert data["sum"] == 15

        # 사용자 등록
        pkg.auth_module.register_user("admin", "password")
        assert pkg.auth_module.verify_user("admin", "password")

    def test_multi_layer_integration(self):
        """다중 계층 통합 테스트"""
        pkg = MultiLayerPackage()
        pkg.initialize_all()

        # 각 계층이 초기화됨
        assert pkg.core.data._initialized
        assert pkg.service.auth._initialized

        # 아키텍처 정보 조회
        arch = pkg.api.get_architecture()
        assert "core" in arch
        assert "service" in arch

    def test_plugin_system_integration(self):
        """플러그인 시스템 통합 테스트"""
        system = PluginSystem()

        # 여러 플러그인 등록
        system.register_plugin("hello", HelloPlugin())
        system.register_plugin("calculator", CalculatorPlugin())

        # 실행
        hello_result = system.execute_plugin("hello")
        calc_result = system.execute_plugin("calculator")

        assert hello_result == "Hello from plugin!"
        assert calc_result["1+1"] == 2

    def test_project_architecture_integration(self):
        """프로젝트 아키텍처 통합 테스트"""
        arch = ProjectArchitecture()

        # 구조 확인
        structure = arch.get_structure()
        assert structure["total_modules"] > 0

        # 의존성 확인
        graph = arch.get_dependency_graph()
        assert graph["api"]  # API가 최상위
        assert not graph["core"]  # Core가 최하위

        # 규칙 검증
        validation = arch.validate_imports()
        assert validation["api_imports_services"]


