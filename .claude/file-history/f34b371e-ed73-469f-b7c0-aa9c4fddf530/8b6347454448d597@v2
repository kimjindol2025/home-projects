class TestDataModule:
    """데이터 처리 모듈 테스트"""

    def test_initialization(self):
        """데이터 모듈 초기화"""
        module = DataModule("data")
        assert isinstance(module, ModuleBase)
        assert module.name == "data"

    def test_process_data_before_init(self):
        """초기화 전 처리 실패"""
        module = DataModule("data")
        with pytest.raises(RuntimeError):
            module.process_data([1, 2, 3])

    def test_process_data_after_init(self):
        """초기화 후 데이터 처리"""
        module = DataModule("data")
        module.initialize()
        result = module.process_data([1, 2, 3, 4, 5])

        assert result["count"] == 5
        assert result["sum"] == 15
        assert result["avg"] == 3.0
        assert result["max"] == 5
        assert result["min"] == 1

    def test_process_empty_data(self):
        """빈 데이터 처리"""
        module = DataModule("data")
        module.initialize()
        result = module.process_data([])

        assert result["count"] == 0
        assert result["sum"] == 0
        assert result["avg"] == 0
        assert result["max"] is None
        assert result["min"] is None


