class TestAuthModule:
    """인증 모듈 테스트"""

    def test_initialization(self):
        """인증 모듈 초기화"""
        module = AuthModule("auth")
        assert module.name == "auth"
        assert module.users == {}

    def test_register_user_before_init(self):
        """초기화 전 사용자 등록 실패"""
        module = AuthModule("auth")
        with pytest.raises(RuntimeError):
            module.register_user("admin", "password")

    def test_register_user_after_init(self):
        """초기화 후 사용자 등록"""
        module = AuthModule("auth")
        module.initialize()

        result = module.register_user("admin", "password123")
        assert result is True
        assert "admin" in module.users

    def test_register_duplicate_user(self):
        """중복 사용자 등록 실패"""
        module = AuthModule("auth")
        module.initialize()

        module.register_user("admin", "password123")
        result = module.register_user("admin", "different")
        assert result is False

    def test_verify_user(self):
        """사용자 검증"""
        module = AuthModule("auth")
        module.initialize()
        module.register_user("admin", "password123")

        assert module.verify_user("admin", "password123") is True
        assert module.verify_user("admin", "wrong") is False
        assert module.verify_user("nonexistent", "password") is False

    def test_list_users(self):
        """사용자 목록 조회"""
        module = AuthModule("auth")
        module.initialize()

        module.register_user("user1", "pass1")
        module.register_user("user2", "pass2")
        module.register_user("user3", "pass3")

        users = module.list_users()
        assert len(users) == 3
        assert "user1" in users
        assert "user2" in users
        assert "user3" in users


