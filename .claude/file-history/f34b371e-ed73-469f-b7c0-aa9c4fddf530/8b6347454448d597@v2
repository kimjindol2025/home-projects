class TestPluginSystem:
    """플러그인 시스템 테스트"""

    def test_initialization(self):
        """플러그인 시스템 초기화"""
        system = PluginSystem()
        assert system.plugins == {}

    def test_register_valid_plugin(self):
        """유효한 플러그인 등록"""
        system = PluginSystem()
        plugin = HelloPlugin()

        result = system.register_plugin("hello", plugin)
        assert result is True
        assert "hello" in system.plugins

    def test_register_invalid_plugin(self):
        """유효하지 않은 플러그인 등록 실패"""
        system = PluginSystem()

        # 일반 객체는 플러그인 아님
        result = system.register_plugin("invalid", {})
        assert result is False

    def test_execute_plugin(self):
        """플러그인 실행"""
        system = PluginSystem()
        system.register_plugin("hello", HelloPlugin())

        result = system.execute_plugin("hello")
        assert result == "Hello from plugin!"

    def test_execute_nonexistent_plugin(self):
        """존재하지 않는 플러그인 실행"""
        system = PluginSystem()
        result = system.execute_plugin("nonexistent")
        assert result is None

    def test_list_plugins(self):
        """등록된 플러그인 목록"""
        system = PluginSystem()
        system.register_plugin("hello", HelloPlugin())
        system.register_plugin("calculator", CalculatorPlugin())

        plugins = system.list_plugins()
        assert len(plugins) == 2

    def test_get_plugin_by_name(self):
        """이름으로 플러그인 조회"""
        system = PluginSystem()
        plugin = HelloPlugin()
        system.register_plugin("hello", plugin)

        retrieved = system.get_plugin_by_name("hello")
        assert retrieved is plugin

    def test_unregister_plugin(self):
        """플러그인 제거"""
        system = PluginSystem()
        system.register_plugin("hello", HelloPlugin())

        result = system.unregister_plugin("hello")
        assert result is True
        assert "hello" not in system.plugins

    def test_calculator_plugin(self):
        """계산기 플러그인 테스트"""
        plugin = CalculatorPlugin()
        assert plugin.get_plugin_name() == "Calculator Plugin"
        assert plugin.get_plugin_version() == "2.0.0"

        result = plugin.execute()
        assert result["1+1"] == 2
        assert result["2*3"] == 6


