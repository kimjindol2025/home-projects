"""
v1.4 Sequence Protocol: 시퀀스의 마법

len() → __len__()
obj[i] → __getitem__(i)
obj[i] = val → __setitem__(i, val)
del obj[i] → __delitem__(i)
i in obj → __contains__(i)
iter(obj) → __iter__()
"""

from typing import Any, List, Iterator


class SimpleList:
    """간단한 리스트 클래스"""

    def __init__(self, items: List[Any] = None):
        self._items = items or []

    def __repr__(self) -> str:
        return f"SimpleList({self._items})"

    def __len__(self) -> int:
        """len() 지원"""
        return len(self._items)

    def __getitem__(self, index: int) -> Any:
        """인덱싱 읽기: obj[i]"""
        return self._items[index]

    def __setitem__(self, index: int, value: Any) -> None:
        """인덱싱 쓰기: obj[i] = val"""
        self._items[index] = value

    def __delitem__(self, index: int) -> None:
        """인덱싱 삭제: del obj[i]"""
        del self._items[index]

    def __contains__(self, item: Any) -> bool:
        """멤버십 검사: item in obj"""
        return item in self._items

    def __iter__(self) -> Iterator[Any]:
        """반복 지원: for item in obj"""
        return iter(self._items)

    def append(self, item: Any) -> None:
        """아이템 추가"""
        self._items.append(item)


class CustomRange:
    """커스텀 range 클래스"""

    def __init__(self, start: int, stop: int = None, step: int = 1):
        if stop is None:
            self.start = 0
            self.stop = start
        else:
            self.start = start
            self.stop = stop
        self.step = step

    def __repr__(self) -> str:
        return f"CustomRange({self.start}, {self.stop}, {self.step})"

    def __len__(self) -> int:
        """길이 계산"""
        if self.step > 0:
            return max(0, (self.stop - self.start + self.step - 1) // self.step)
        else:
            return max(0, (self.start - self.stop - self.step - 1) // (-self.step))

    def __getitem__(self, index: int) -> int:
        """인덱싱"""
        if index < 0:
            index += len(self)
        if index < 0 or index >= len(self):
            raise IndexError("Range index out of range")
        return self.start + index * self.step

    def __contains__(self, item: int) -> bool:
        """멤버십 검사"""
        if self.step > 0:
            return self.start <= item < self.stop and (item - self.start) % self.step == 0
        else:
            return self.stop < item <= self.start and (self.start - item) % (-self.step) == 0

    def __iter__(self) -> Iterator[int]:
        """반복"""
        current = self.start
        if self.step > 0:
            while current < self.stop:
                yield current
                current += self.step
        else:
            while current > self.stop:
                yield current
                current += self.step


class Matrix:
    """2D 행렬 클래스"""

    def __init__(self, rows: int, cols: int):
        self.rows = rows
        self.cols = cols
        self.data = [[0 for _ in range(cols)] for _ in range(rows)]

    def __repr__(self) -> str:
        return f"Matrix({self.rows}, {self.cols})"

    def __len__(self) -> int:
        """행 개수"""
        return self.rows

    def __getitem__(self, indices: tuple) -> int:
        """m[i, j] 읽기"""
        row, col = indices
        return self.data[row][col]

    def __setitem__(self, indices: tuple, value: int) -> None:
        """m[i, j] = val"""
        row, col = indices
        self.data[row][col] = value

    def __iter__(self) -> Iterator[List[int]]:
        """행으로 반복"""
        return iter(self.data)


def demonstrate_sequence_protocol():
    """시퀀스 프로토콜 시연"""
    print("\n" + "="*70)
    print("시퀀스 프로토콜: 순차의 마법")
    print("="*70)

    # SimpleList
    print("\n  [SimpleList 시연]")
    sl = SimpleList([1, 2, 3, 4, 5])
    print(f"    sl = {sl}")

    print("\n  [len(sl)]")
    print(f"    len(sl) = {len(sl)}")

    print("\n  [인덱싱 읽기]")
    print(f"    sl[0] = {sl[0]}")
    print(f"    sl[2] = {sl[2]}")

    print("\n  [인덱싱 쓰기]")
    sl[1] = 20
    print(f"    sl[1] = 20")
    print(f"    sl = {sl}")

    print("\n  [멤버십 검사]")
    print(f"    20 in sl: {20 in sl}")
    print(f"    100 in sl: {100 in sl}")

    print("\n  [반복]")
    print(f"    for item in sl: {[x for x in sl]}")

    # CustomRange
    print("\n  [CustomRange 시연]")
    cr = CustomRange(1, 6, 2)
    print(f"    cr = {cr}")
    print(f"    list(cr) = {list(cr)}")
    print(f"    len(cr) = {len(cr)}")
    print(f"    cr[0] = {cr[0]}")
    print(f"    3 in cr: {3 in cr}")

    # Matrix
    print("\n  [Matrix 시연]")
    m = Matrix(3, 3)
    m[0, 0] = 1
    m[1, 1] = 5
    m[2, 2] = 9
    print(f"    m = {m}")
    print(f"    m[0, 0] = {m[0, 0]}")
    print(f"    m[1, 1] = {m[1, 1]}")
    print(f"    len(m) = {len(m)}  (행 개수)")

    print("\n" + "="*70)


