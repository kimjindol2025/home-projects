"""
v1.5 테스트: 조건문
"""

from src.v1_5_smart_decision import smart_decision


def test_smart_decision_returns_dict():
    """반환값이 딕셔너리"""
    result = smart_decision()
    assert isinstance(result, dict)


def test_current_temp():
    """현재 온도는 28도"""
    result = smart_decision()
    assert result["current_temp"] == 28


def test_basket_contents():
    """바구니에 4개 과일"""
    result = smart_decision()
    assert len(result["basket"]) == 4
    assert result["basket"][0] == "포도"
    assert result["basket"][1] == "딸기"
    assert result["basket"][2] == "사과"
    assert result["basket"][3] == "배"


def test_has_apple():
    """바구니에 사과가 있는가?"""
    result = smart_decision()
    assert result["has_apple"] == True


def test_if_condition_greater_than():
    """if 조건: >"""
    temp = 35
    if temp >= 30:
        result = True
    else:
        result = False
    assert result == True


def test_if_condition_less_than():
    """if 조건: <"""
    temp = 15
    if temp >= 20:
        result = False
    else:
        result = True
    assert result == True


def test_elif_condition():
    """elif 조건"""
    temp = 25
    if temp >= 30:
        category = "hot"
    elif temp >= 20:
        category = "comfortable"
    else:
        category = "cold"
    assert category == "comfortable"


def test_equality_operator():
    """== 비교 연산자"""
    fruit = "사과"
    if fruit == "사과":
        result = True
    else:
        result = False
    assert result == True


def test_inequality_operator():
    """!= 비교 연산자"""
    fruit = "포도"
    if fruit != "사과":
        result = True
    else:
        result = False
    assert result == True


def test_if_with_loop():
    """if 문과 for 루프 결합"""
    basket = ["포도", "딸기", "사과", "배"]
    apple_found = False
    for fruit in basket:
        if fruit == "사과":
            apple_found = True
            break
    assert apple_found == True


def test_multiple_conditions():
    """여러 조건 검사"""
    score = 85
    if score >= 90:
        grade = "A"
    elif score >= 80:
        grade = "B"
    elif score >= 70:
        grade = "C"
    else:
        grade = "F"
    assert grade == "B"
