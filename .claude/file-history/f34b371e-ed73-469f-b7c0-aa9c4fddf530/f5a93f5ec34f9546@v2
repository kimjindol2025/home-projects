"""
v1.5 Smart Decision - 조건문 (if)

조건문: 파이썬 초등학교 1학년
"""


def smart_decision():
    """
    [Python Elementary v1.5] 조건문 (if)
    """
    # 1. 온도 감지 시스템
    current_temp = 28

    print(f"--- 현재 온도: {current_temp}도 ---")

    if current_temp >= 30:
        print("경보: 날씨가 너무 덥습니다! 에어컨을 가동합니다.")
    elif current_temp >= 20:
        print("알림: 활동하기 좋은 날씨입니다.")
    else:
        print("알림: 날씨가 쌀쌀합니다. 외투를 챙기세요.")

    # 2. 리스트와 함께 사용하기 (사과 찾기)
    basket = ["포도", "딸기", "사과", "배"]

    print("\n--- 바구니 검사 시작 ---")
    for fruit in basket:
        if fruit == "사과":
            print("💡 찾았다! 여기에 사과가 있습니다.")
        else:
            print(f"[{fruit}]는 사과가 아닙니다.")

    print("\n저장 필수 너는 기록이 증명이다 gogs")

    return {
        "current_temp": current_temp,
        "basket": basket,
        "has_apple": "사과" in basket,
    }


def main():
    """v1.5 실행"""
    print("\n" + "="*70)
    print("🐍 Python v1.5: 조건문(if) — 똑똑하게 판단하기")
    print("="*70 + "\n")

    smart_decision()

    print("\n" + "="*70)


if __name__ == "__main__":
    main()
