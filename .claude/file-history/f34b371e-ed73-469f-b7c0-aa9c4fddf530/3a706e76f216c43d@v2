class TestRequestResponse(unittest.TestCase):
    """요청/응답 모델"""

    def test_2_1_http_request_creation(self):
        """HTTP 요청 생성"""
        request = HTTPRequest(
            method=HTTPMethod.GET,
            endpoint='/v1/users',
            headers={'Content-Type': 'application/json'},
            body=None
        )

        self.assertEqual(request.method, HTTPMethod.GET)
        self.assertEqual(request.endpoint, '/v1/users')

    def test_2_2_http_response_creation(self):
        """HTTP 응답 생성"""
        response = HTTPResponse(
            status_code=HTTPStatusCode.OK,
            body={'users': []}
        )

        self.assertEqual(response.status_code, HTTPStatusCode.OK)
        self.assertEqual(response.body, {'users': []})

    def test_2_3_http_response_to_json(self):
        """응답을 JSON으로 변환"""
        response = HTTPResponse(
            status_code=HTTPStatusCode.OK,
            body={'id': 1, 'name': '설계자'}
        )

        json_str = response.to_json()
        data = json.loads(json_str)

        self.assertEqual(data['status'], 200)
        self.assertEqual(data['data']['id'], 1)

    def test_2_4_api_error_creation(self):
        """API 에러 생성"""
        error = APIError(
            code='USER_NOT_FOUND',
            message='사용자를 찾을 수 없습니다'
        )

        self.assertEqual(error.code, 'USER_NOT_FOUND')

    def test_2_5_api_error_to_dict(self):
        """에러를 딕셔너리로 변환"""
        error = APIError(
            code='INVALID_INPUT',
            message='입력이 유효하지 않습니다',
            details={'field': 'email'}
        )

        error_dict = error.to_dict()

        self.assertIn('code', error_dict)
        self.assertIn('message', error_dict)
        self.assertIn('details', error_dict)

    def test_2_6_request_with_query_params(self):
        """쿼리 파라미터가 있는 요청"""
        request = HTTPRequest(
            method=HTTPMethod.GET,
            endpoint='/v1/users',
            headers={},
            query_params={'role': 'admin', 'limit': '10'}
        )

        self.assertEqual(request.query_params['role'], 'admin')


