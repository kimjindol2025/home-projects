class TestAuthentication(unittest.TestCase):
    """인증"""

    def test_5_1_generate_token(self):
        """토큰 생성"""
        token = AuthToken.generate_token(user_id=1)

        self.assertIsNotNone(token)
        self.assertIn(':', token)

    def test_5_2_token_contains_user_id(self):
        """토큰에 사용자 ID 포함"""
        user_id = 42
        token = AuthToken.generate_token(user_id=user_id)

        # 토큰 형식: HASH:USER_ID
        parts = token.split(':')
        self.assertEqual(int(parts[1]), user_id)

    def test_5_3_verify_valid_token(self):
        """유효한 토큰 검증"""
        user_id = 1
        token = AuthToken.generate_token(user_id=user_id)

        verified_id = AuthToken.verify_token(token)

        self.assertEqual(verified_id, user_id)

    def test_5_4_verify_invalid_token(self):
        """유효하지 않은 토큰"""
        result = AuthToken.verify_token("invalid_token")

        self.assertIsNone(result)

    def test_5_5_token_format(self):
        """토큰 형식"""
        token = AuthToken.generate_token(user_id=1)

        # 형식: HASH:USER_ID
        parts = token.split(':')
        self.assertEqual(len(parts), 2)
        self.assertEqual(len(parts[0]), 32)  # SHA256 해시 일부


class TestAuthorization(unittest.TestCase):
    """인가"""

    def test_5_6_admin_permissions(self):
        """관리자 권한"""
        admin_perms = RoleBasedAccessControl.PERMISSIONS['admin']

        self.assertIn('read', admin_perms)
        self.assertIn('create', admin_perms)
        self.assertIn('update', admin_perms)
        self.assertIn('delete', admin_perms)

    def test_5_7_user_permissions(self):
        """일반 사용자 권한"""
        user_perms = RoleBasedAccessControl.PERMISSIONS['user']

        self.assertIn('read', user_perms)
        self.assertIn('create', user_perms)
        self.assertNotIn('delete', user_perms)

    def test_5_8_guest_permissions(self):
        """게스트 권한"""
        guest_perms = RoleBasedAccessControl.PERMISSIONS['guest']

        self.assertIn('read', guest_perms)
        self.assertNotIn('create', guest_perms)

    def test_5_9_has_permission_admin(self):
        """관리자는 모든 권한"""
        self.assertTrue(RoleBasedAccessControl.has_permission('admin', 'delete'))
        self.assertTrue(RoleBasedAccessControl.has_permission('admin', 'create'))

    def test_5_10_has_permission_user(self):
        """사용자는 제한된 권한"""
        self.assertTrue(RoleBasedAccessControl.has_permission('user', 'create'))
        self.assertFalse(RoleBasedAccessControl.has_permission('user', 'delete'))


