class TestIntegrationScenarios(unittest.TestCase):
    """통합 시나리오"""

    def test_9_1_complete_user_workflow(self):
        """사용자 CRUD 완전 워크플로우"""
        client = APIClient()

        # 1. 사용자 생성
        create_response = client.create_user('설계자', 'designer@gogs.io', 'admin')
        self.assertEqual(create_response.status_code, HTTPStatusCode.CREATED)
        user_id = create_response.body['id']

        # 2. 사용자 조회
        get_response = client.get_user(user_id)
        self.assertEqual(get_response.status_code, HTTPStatusCode.OK)

        # 3. 사용자 수정
        update_response = client.update_user(user_id, name='수정된이름')
        self.assertEqual(update_response.status_code, HTTPStatusCode.OK)

        # 4. 모든 사용자 조회
        all_response = client.get_users()
        self.assertEqual(all_response.status_code, HTTPStatusCode.OK)

        # 5. 사용자 삭제
        delete_response = client.delete_user(user_id)
        self.assertEqual(delete_response.status_code, HTTPStatusCode.OK)

    def test_9_2_complete_experiment_workflow(self):
        """실험 워크플로우 (인증 포함)"""
        client = APIClient()

        # 1. 로그인 (토큰 발급)
        token = client.login(user_id=1)
        self.assertIsNotNone(token)

        # 2. 실험 생성
        create_response = client.create_experiment('테스트', 99.5)
        self.assertEqual(create_response.status_code, HTTPStatusCode.CREATED)
        exp_id = create_response.body['id']

        # 3. 실험 조회
        get_response = client.get_experiment(exp_id)
        self.assertEqual(get_response.status_code, HTTPStatusCode.OK)

        # 4. 모든 실험 조회
        all_response = client.get_experiments()
        self.assertEqual(all_response.status_code, HTTPStatusCode.OK)

    def test_9_3_authentication_flow(self):
        """인증 플로우"""
        client = APIClient()

        # 실험은 인증 필수
        exp_response = client.get_experiments()
        self.assertEqual(exp_response.status_code, HTTPStatusCode.UNAUTHORIZED)

        # 로그인 후
        client.login(user_id=1)
        exp_response = client.get_experiments()
        self.assertEqual(exp_response.status_code, HTTPStatusCode.OK)

    def test_9_4_multiple_users_and_experiments(self):
        """여러 사용자와 실험"""
        client = APIClient()

        # 여러 사용자 생성
        user1 = client.create_user('사용자1', 'user1@gogs.io')
        user2 = client.create_user('사용자2', 'user2@gogs.io')

        # 여러 실험 생성
        client.login(user_id=1)
        for i in range(3):
            client.create_experiment(f'실험{i}', 90 + i)

        # 모든 사용자, 실험 조회
        users_response = client.get_users()
        experiments_response = client.get_experiments()

        self.assertGreater(users_response.body['count'], 1)
        self.assertGreater(experiments_response.body['count'], 0)


