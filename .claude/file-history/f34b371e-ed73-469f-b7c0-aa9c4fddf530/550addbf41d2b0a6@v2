### 3단계: 바이너리 동일성 검증 (Binary Identity Verification)

#### 3.1 SHA-256 해싱

```rust
fn compute_sha256(bytecode: &Bytecode) -> [u8; 32] {
    // 1. instructions 벡터 → 연속 바이트 스트림
    let mut hasher = Sha256::new();

    // 2. OpCode 바이트 시퀀스
    for instr in &bytecode.instructions {
        hasher.update(&[*instr]);
    }

    // 3. 상수 풀
    for constant in &bytecode.constants {
        match constant {
            Value::Int(i) => hasher.update(&i.to_le_bytes()),
            Value::Bool(b) => hasher.update(&[*b as u8]),
            Value::String(s) => {
                hasher.update(s.as_bytes());
                hasher.update(&[s.len() as u8]);
            }
            _ => {}
        }
    }

    // 4. 최종 다이제스트
    let result = hasher.finalize();
    let mut output = [0u8; 32];
    output.copy_from_slice(&result);
    output
}
```

#### 3.2 바이트 단위 비교

```rust
fn compare_bytecode(gen2: &Bytecode, gen3: &Bytecode) -> ComparisonResult {
    // 1. 명령어 길이 비교
    if gen2.instructions.len() != gen3.instructions.len() {
        return ComparisonResult::DifferentLength {
            gen2_len: gen2.instructions.len(),
            gen3_len: gen3.instructions.len(),
        };
    }

    // 2. 명령어 바이트 비교
    for (i, (byte2, byte3)) in gen2.instructions.iter()
        .zip(gen3.instructions.iter())
        .enumerate() {
        if byte2 != byte3 {
            return ComparisonResult::ByteMismatch {
                position: i,
                gen2_byte: *byte2,
                gen3_byte: *byte3,
            };
        }
    }

    // 3. 상수 풀 비교
    if gen2.constants.len() != gen3.constants.len() {
        return ComparisonResult::DifferentConstantCount { /* ... */ };
    }

    for (i, (c2, c3)) in gen2.constants.iter()
        .zip(gen3.constants.iter())
        .enumerate() {
        if !values_equal(c2, c3) {
            return ComparisonResult::ConstantMismatch { /* ... */ };
        }
    }

    ComparisonResult::Identical { hash: hash2 }
}
```

