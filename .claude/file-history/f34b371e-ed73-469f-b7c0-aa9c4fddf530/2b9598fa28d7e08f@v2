    print(f"  - 크기: {info['size_mb']}MB")
    print(f"  - 테이블: {', '.join(info['tables'])}")

    # 10. 데이터 삭제 (선택적)
    print("\n【 Step 9: 데이터 삭제 】")
    logger.delete_experiment(exp5)

    logger.close()

    print("\n" + "=" * 70)
