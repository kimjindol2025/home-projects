"""
v5.2 Hands-On: SQLite 실제 구현 프로젝트
"Gogs 연구 기록 시스템" - 완전한 CRUD 응용

【 학습 목표 】
1. SQLite 데이터베이스 생성 및 연결
2. 테이블 설계 (스키마)
3. CRUD: Create(INSERT), Read(SELECT), Update(UPDATE), Delete(DELETE)
4. 트랜잭션 처리
5. 쿼리 최적화 (인덱싱)
6. 데이터 조회 및 분석

【 프로젝트 흐름 】
초기화 → 데이터 추가 → 조회/분석 → 수정 → 삭제 → 백업
"""

import sqlite3
import json
import time
from datetime import datetime, timedelta
from typing import List, Dict, Optional, Tuple


class GogsResearchLogger:
    """Gogs 연구 기록 시스템 - SQLite 기반"""

    def __init__(self, db_file: str = 'gogs_research.db'):
        """데이터베이스 초기화"""
        self.db_file = db_file
        self.conn = sqlite3.connect(db_file)
        self.cursor = self.conn.cursor()
        self._init_tables()

        print(f"✅ 데이터베이스 연결: {db_file}")

    def _init_tables(self):
        """테이블 생성 (스키마 정의)"""
        # 1. 실험자 테이블
        self.cursor.execute('''
            CREATE TABLE IF NOT EXISTS researchers (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                name TEXT NOT NULL UNIQUE,
                email TEXT NOT NULL UNIQUE,
                created_at DATETIME DEFAULT CURRENT_TIMESTAMP
            )
        ''')

        # 2. 실험 테이블 (정규화)
        self.cursor.execute('''
            CREATE TABLE IF NOT EXISTS experiments (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                researcher_id INTEGER NOT NULL,
                subject TEXT NOT NULL,
                description TEXT,
                result REAL,
                status TEXT DEFAULT 'pending',
                created_at DATETIME DEFAULT CURRENT_TIMESTAMP,
                updated_at DATETIME DEFAULT CURRENT_TIMESTAMP,
                FOREIGN KEY (researcher_id) REFERENCES researchers(id)
            )
        ''')

        # 3. 실험 상세 기록 테이블
        self.cursor.execute('''
            CREATE TABLE IF NOT EXISTS experiment_logs (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                experiment_id INTEGER NOT NULL,
                log_text TEXT,
                log_time DATETIME DEFAULT CURRENT_TIMESTAMP,
                FOREIGN KEY (experiment_id) REFERENCES experiments(id)
            )
        ''')

        # 4. 인덱스 생성 (성능 최적화)
        self.cursor.execute('''
            CREATE INDEX IF NOT EXISTS idx_experiments_researcher
            ON experiments(researcher_id)
        ''')

        self.cursor.execute('''
            CREATE INDEX IF NOT EXISTS idx_experiments_status
            ON experiments(status)
        ''')

        self.cursor.execute('''
            CREATE INDEX IF NOT EXISTS idx_experiment_logs_experiment
            ON experiment_logs(experiment_id)
        ''')

        self.conn.commit()
        print("📊 테이블 생성 완료 (3개 테이블 + 3개 인덱스)")

    # ============================================================================
    # 【 CREATE: 데이터 추가 】
    # ============================================================================

    def add_researcher(self, name: str, email: str) -> int:
        """연구자 추가"""
        try:
            self.cursor.execute(
                'INSERT INTO researchers (name, email) VALUES (?, ?)',
                (name, email)
            )
            self.conn.commit()
            researcher_id = self.cursor.lastrowid
            print(f"✅ 연구자 추가: {name} (ID: {researcher_id})")
            return researcher_id
        except sqlite3.IntegrityError as e:
            print(f"❌ 오류: {e} (중복된 이름/이메일)")
            return -1

    def add_experiment(self, researcher_id: int, subject: str,
                      description: str = "") -> int:
        """실험 추가"""
        self.cursor.execute(
            '''INSERT INTO experiments
               (researcher_id, subject, description, status)
               VALUES (?, ?, ?, 'pending')''',
            (researcher_id, subject, description)
        )
        self.conn.commit()
        exp_id = self.cursor.lastrowid
        print(f"✅ 실험 추가: {subject} (ID: {exp_id})")
        return exp_id

    def log_experiment(self, experiment_id: int, log_text: str):
        """실험 진행 기록"""
        self.cursor.execute(
            'INSERT INTO experiment_logs (experiment_id, log_text) VALUES (?, ?)',
            (experiment_id, log_text)
        )
        self.conn.commit()
        print(f"📝 기록 추가: {log_text}")

    # ============================================================================
    # 【 READ: 데이터 조회 】
    # ============================================================================

    def get_all_researchers(self) -> List[Dict]:
        """모든 연구자 조회"""
        self.cursor.execute('SELECT * FROM researchers')
        rows = self.cursor.fetchall()

        results = []
        for row in rows:
            results.append({
                'id': row[0],
                'name': row[1],
                'email': row[2],
                'created_at': row[3]
            })
        return results

    def get_researcher(self, researcher_id: int) -> Optional[Dict]:
        """특정 연구자 조회"""
        self.cursor.execute(
            'SELECT * FROM researchers WHERE id = ?',
            (researcher_id,)
        )
        row = self.cursor.fetchone()
        if row:
            return {
                'id': row[0],
                'name': row[1],
                'email': row[2],
                'created_at': row[3]
            }
        return None

    def get_researcher_experiments(self, researcher_id: int) -> List[Dict]:
        """연구자의 모든 실험 조회"""
        self.cursor.execute(
            'SELECT * FROM experiments WHERE researcher_id = ? ORDER BY created_at DESC',
            (researcher_id,)
        )
        rows = self.cursor.fetchall()

        results = []
        for row in rows:
            results.append({
                'id': row[0],
                'researcher_id': row[1],
                'subject': row[2],
                'description': row[3],
                'result': row[4],
                'status': row[5],
                'created_at': row[6]
            })
        return results

    def get_experiment(self, experiment_id: int) -> Optional[Dict]:
        """특정 실험 조회"""
        # 실험 정보
        self.cursor.execute(
            'SELECT * FROM experiments WHERE id = ?',
            (experiment_id,)
        )
        exp_row = self.cursor.fetchone()
        if not exp_row:
            return None

        # 실험 로그
        self.cursor.execute(
            'SELECT log_text, log_time FROM experiment_logs WHERE experiment_id = ?',
            (experiment_id,)
        )
        logs = self.cursor.fetchall()

        return {
            'id': exp_row[0],
            'researcher_id': exp_row[1],
            'subject': exp_row[2],
            'description': exp_row[3],
            'result': exp_row[4],
            'status': exp_row[5],
            'created_at': exp_row[6],
            'logs': [{'text': log[0], 'time': log[1]} for log in logs]
        }

    def get_experiments_by_status(self, status: str) -> List[Dict]:
        """상태별 실험 조회 (인덱스 활용)"""
        self.cursor.execute(
            '''SELECT e.id, e.subject, e.result, r.name
               FROM experiments e
               JOIN researchers r ON e.researcher_id = r.id
               WHERE e.status = ?''',
            (status,)
        )
        rows = self.cursor.fetchall()

        results = []
        for row in rows:
            results.append({
                'exp_id': row[0],
                'subject': row[1],
                'result': row[2],
                'researcher': row[3]
            })
        return results

    # ============================================================================
    # 【 UPDATE: 데이터 수정 】
    # ============================================================================

    def update_experiment_result(self, experiment_id: int, result: float):
        """실험 결과 업데이트"""
        self.cursor.execute(
            '''UPDATE experiments
               SET result = ?, status = 'completed', updated_at = CURRENT_TIMESTAMP
               WHERE id = ?''',
            (result, experiment_id)
        )
        self.conn.commit()
        print(f"✅ 실험 결과 업데이트: {result}")

    def update_experiment_status(self, experiment_id: int, status: str):
        """실험 상태 업데이트"""
        valid_statuses = ['pending', 'in_progress', 'completed', 'failed']
        if status not in valid_statuses:
            print(f"❌ 유효하지 않은 상태: {status}")
            return

        self.cursor.execute(
            '''UPDATE experiments
               SET status = ?, updated_at = CURRENT_TIMESTAMP
               WHERE id = ?''',
            (status, experiment_id)
        )
        self.conn.commit()
        print(f"✅ 상태 변경: {status}")

    # ============================================================================
    # 【 DELETE: 데이터 삭제 】
    # ============================================================================

    def delete_experiment(self, experiment_id: int) -> bool:
        """실험 삭제 (CASCADE)"""
        # 1. 로그 먼저 삭제
        self.cursor.execute(
            'DELETE FROM experiment_logs WHERE experiment_id = ?',
            (experiment_id,)
        )

        # 2. 실험 삭제
        self.cursor.execute(
            'DELETE FROM experiments WHERE id = ?',
            (experiment_id,)
        )
        self.conn.commit()
        print(f"✅ 실험 삭제: {experiment_id}")
        return True

    # ============================================================================
    # 【 분석: 데이터 통계 】
    # ============================================================================

    def get_statistics(self) -> Dict:
        """전체 통계"""
        # 연구자 수
        self.cursor.execute('SELECT COUNT(*) FROM researchers')
        researcher_count = self.cursor.fetchone()[0]

        # 실험 수
        self.cursor.execute('SELECT COUNT(*) FROM experiments')
        experiment_count = self.cursor.fetchone()[0]

        # 상태별 실험 수
        self.cursor.execute(
            'SELECT status, COUNT(*) FROM experiments GROUP BY status'
        )
        status_counts = dict(self.cursor.fetchall())

        # 평균 결과
        self.cursor.execute(
            'SELECT AVG(result) FROM experiments WHERE result IS NOT NULL'
        )
        avg_result = self.cursor.fetchone()[0]

        # 최고 점수
        self.cursor.execute(
            'SELECT MAX(result) FROM experiments WHERE result IS NOT NULL'
        )
        max_result = self.cursor.fetchone()[0]

        return {
            'researcher_count': researcher_count,
            'experiment_count': experiment_count,
            'status_distribution': status_counts,
            'average_result': avg_result,
            'max_result': max_result
        }

    def get_top_experiments(self, limit: int = 5) -> List[Dict]:
        """상위 실험 (결과 기준)"""
        self.cursor.execute(
            '''SELECT e.id, e.subject, e.result, r.name
               FROM experiments e
               JOIN researchers r ON e.researcher_id = r.id
               WHERE e.result IS NOT NULL
               ORDER BY e.result DESC
               LIMIT ?''',
            (limit,)
        )
        rows = self.cursor.fetchall()

        results = []
        for row in rows:
            results.append({
                'rank': len(results) + 1,
                'exp_id': row[0],
                'subject': row[1],
                'result': row[2],
                'researcher': row[3]
            })
        return results

    def get_researcher_performance(self, researcher_id: int) -> Dict:
        """연구자의 성과 분석"""
        self.cursor.execute(
            'SELECT COUNT(*) FROM experiments WHERE researcher_id = ?',
            (researcher_id,)
        )
        total = self.cursor.fetchone()[0]

        self.cursor.execute(
            '''SELECT COUNT(*) FROM experiments
               WHERE researcher_id = ? AND status = 'completed' ''',
            (researcher_id,)
        )
        completed = self.cursor.fetchone()[0]

        self.cursor.execute(
            '''SELECT AVG(result) FROM experiments
               WHERE researcher_id = ? AND result IS NOT NULL''',
            (researcher_id,)
        )
        avg_result = self.cursor.fetchone()[0]

        return {
            'total_experiments': total,
            'completed': completed,
            'completion_rate': (completed / total * 100) if total > 0 else 0,
            'average_result': avg_result
        }

    # ============================================================================
    # 【 백업: 데이터 보존 】
    # ============================================================================

    def export_to_json(self, filename: str = 'gogs_research_backup.json'):
        """모든 데이터를 JSON으로 내보내기"""
        # 연구자 데이터
        researchers = self.get_all_researchers()

        # 모든 실험
        self.cursor.execute('SELECT * FROM experiments')
        experiments = []
        for row in self.cursor.fetchall():
            experiments.append({
                'id': row[0],
                'researcher_id': row[1],
                'subject': row[2],
                'description': row[3],
                'result': row[4],
                'status': row[5],
                'created_at': row[6]
            })

        # 모든 로그
        self.cursor.execute('SELECT * FROM experiment_logs')
        logs = []
        for row in self.cursor.fetchall():
            logs.append({
                'id': row[0],
                'experiment_id': row[1],
                'log_text': row[2],
                'log_time': row[3]
            })

        # JSON 저장
        data = {
            'researchers': researchers,
            'experiments': experiments,
            'logs': logs,
            'export_time': datetime.now().isoformat()
        }

        with open(filename, 'w', encoding='utf-8') as f:
            json.dump(data, f, ensure_ascii=False, indent=2)

        print(f"✅ 백업 완료: {filename}")

    def get_database_info(self) -> Dict:
        """데이터베이스 정보"""
        # 테이블 정보
        self.cursor.execute(
            "SELECT name FROM sqlite_master WHERE type='table'"
        )
        tables = [row[0] for row in self.cursor.fetchall()]

        # 데이터 크기
        import os
        size_bytes = os.path.getsize(self.db_file)
        size_mb = size_bytes / (1024 * 1024)

        return {
            'filename': self.db_file,
            'size_bytes': size_bytes,
            'size_mb': round(size_mb, 2),
            'tables': tables
        }

    def close(self):
        """데이터베이스 연결 종료"""
        self.conn.close()
        print("🔌 데이터베이스 연결 종료")


