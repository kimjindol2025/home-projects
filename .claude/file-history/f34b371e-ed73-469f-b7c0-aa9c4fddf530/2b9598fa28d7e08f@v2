def demo():
    """실제 사용 예제"""
    print("=" * 70)
    print("🔬 Gogs 연구 기록 시스템 - SQLite 실전 데모")
    print("=" * 70)

    # 1. 데이터베이스 초기화
    logger = GogsResearchLogger('gogs_research.db')
    print()

    # 2. 연구자 추가
    print("【 Step 1: 연구자 추가 】")
    r1 = logger.add_researcher('설계자', 'designer@gogs.io')
    r2 = logger.add_researcher('개발자', 'dev@gogs.io')
    r3 = logger.add_researcher('분석가', 'analyst@gogs.io')
    print()

    # 3. 실험 추가
    print("【 Step 2: 실험 추가 】")
    exp1 = logger.add_experiment(r1, '비동기 엔진 테스트', '논블로킹 I/O 성능 측정')
    exp2 = logger.add_experiment(r1, '메타클래스 검증', '고급 메타프로그래밍 패턴')
    exp3 = logger.add_experiment(r2, '데이터베이스 최적화', 'SQLite 인덱싱 성능')
    exp4 = logger.add_experiment(r2, 'API 설계', 'REST 엔드포인트 테스트')
    exp5 = logger.add_experiment(r3, '시스템 분석', '마이크로서비스 아키텍처')
    print()

    # 4. 실험 진행 기록
    print("【 Step 3: 실험 진행 기록 】")
    logger.log_experiment(exp1, '테스트 시작')
    logger.log_experiment(exp1, 'async/await 구현 완료')
    logger.log_experiment(exp1, '성능 측정 중...')
    logger.log_experiment(exp1, '테스트 완료')
    print()

    # 5. 실험 결과 업데이트
    print("【 Step 4: 결과 업데이트 및 상태 변경 】")
    logger.update_experiment_result(exp1, 98.5)
    logger.update_experiment_result(exp2, 100.0)
    logger.update_experiment_status(exp3, 'in_progress')
    logger.update_experiment_result(exp4, 95.2)
    logger.update_experiment_status(exp5, 'in_progress')
    print()

    # 6. 데이터 조회
    print("【 Step 5: 데이터 조회 】")
