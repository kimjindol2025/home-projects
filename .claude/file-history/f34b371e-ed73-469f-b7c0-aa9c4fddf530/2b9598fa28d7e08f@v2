    print("\n✅ 완료된 실험:")
    for exp in logger.get_experiments_by_status('completed'):
        print(f"  - {exp['subject']}: {exp['result']}")

    print("\n⏳ 진행 중인 실험:")
    for exp in logger.get_experiments_by_status('in_progress'):
        print(f"  - {exp['subject']}")

    # 7. 통계
    print("\n【 Step 6: 통계 분석 】")
