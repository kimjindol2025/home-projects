def demo_magic_methods():
    """매직 메서드 데모"""
    print("\n" + "="*70)
    print("[4] 매직 메서드: 객체를 더 '똑똑하게' 만들기")
    print("="*70 + "\n")

    storage = SmartStorage("스마트 저장소", capacity=5)

    print("\n--- __str__: print() 출력 ---")
    print(storage)

    print("\n--- __repr__: 개발자용 표현 ---")
    print(repr(storage))

    print("\n--- 데이터 저장 후 ---")
    storage.save("데이터1")
    storage.save("데이터2")
    storage.save("데이터3")
    print(storage)

    print("\n--- __len__: len() 지원 ---")
    print(f"저장소의 길이: {len(storage)}")

    print("\n--- __getitem__: [] 연산자 지원 ---")
    print(f"첫 번째 데이터: {storage[0]}")
    print(f"마지막 데이터: {storage[-1]}")

    print("\n--- __contains__: in 연산자 지원 ---")
    print(f"'데이터1' 포함? {('데이터1' in storage)}")
    print(f"'데이터999' 포함? {('데이터999' in storage)}")

    print("\n--- __iter__: for 루프 지원 ---")
    print("저장된 모든 데이터:")
    for i, data in enumerate(storage, 1):
        print(f"  {i}. {data}")


