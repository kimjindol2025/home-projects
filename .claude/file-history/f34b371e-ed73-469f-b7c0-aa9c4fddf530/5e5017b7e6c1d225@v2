"""
[Python High-School v2.2] 객체 지향 프로그래밍 (OOP) 심화
주제: "데이터와 기능을 하나로 묶는 마법"

클래스의 핵심 3요소:
1. 생성자 (__init__): 객체의 DNA를 부여
2. 속성 (Attributes): 객체가 기억하는 정보
3. 메서드 (Methods): 객체가 수행하는 기능 (항상 self를 첫 인자로)

인스턴스의 의미:
- 클래스: "인간"이라는 개념 (설계도)
- 인스턴스: "철수", "영희"라는 실제 존재 (데이터 독립)
"""

from datetime import datetime
from typing import List, Any, Optional


# ============================================================================
# [1] 스마트 저장소: GogsStorage 기본 클래스
# ============================================================================

class GogsStorage:
    """
    데이터를 안전하게 저장하고 관리하는 스마트 저장소 클래스

    생성자: owner(소유자), capacity(용량)
    속성: owner, capacity, stored_data (리스트)
    메서드: save(), show_all(), clear(), get_size()
    """

    def __init__(self, owner: str, capacity: int = 100):
        """
        생성자: 저장소가 탄생할 때 DNA 부여

        Args:
            owner: 저장소 소유자 이름
            capacity: 최대 저장 가능 데이터 개수
        """
        # 속성 (Attributes): 객체가 기억하는 정보
        self.owner = owner
        self.capacity = capacity
        self.stored_data: List[Any] = []
        self.created_at = datetime.now()
        self.access_count = 0  # 접근 횟수

        print(f"📦 [{self.owner}]님의 전용 저장소가 생성되었습니다.")
        print(f"   용량: {self.capacity} | 생성 시간: {self.created_at.strftime('%Y-%m-%d %H:%M:%S')}")

    def save(self, data: Any) -> bool:
        """
        메서드: 데이터를 저장소에 추가

        Args:
            data: 저장할 데이터

        Returns:
            성공 여부 (bool)
        """
        self.access_count += 1

        if len(self.stored_data) < self.capacity:
            self.stored_data.append(data)
            print(f"✅ 기록 완료: '{data}'")
            print(f"   현재 사용량: {len(self.stored_data)}/{self.capacity}")
            return True
        else:
            print(f"❌ 용량 초과: 더 이상 기록할 수 없습니다!")
            print(f"   현재 사용량: {len(self.stored_data)}/{self.capacity}")
            return False

    def show_all(self) -> None:
        """저장된 모든 데이터 출력"""
        print(f"\n--- [{self.owner}]의 저장 기록 (총 {len(self.stored_data)}개) ---")
        if not self.stored_data:
            print("  (비어있음)")
        else:
            for i, data in enumerate(self.stored_data, 1):
                print(f"  {i}. {data}")
        print("저장 필수 너는 기록이 증명이다 gogs")

    def get_size(self) -> int:
        """현재 저장된 데이터 개수"""
        return len(self.stored_data)

    def is_full(self) -> bool:
        """저장소가 가득 찼는지 확인"""
        return len(self.stored_data) >= self.capacity

    def is_empty(self) -> bool:
        """저장소가 비어있는지 확인"""
        return len(self.stored_data) == 0

    def clear(self) -> None:
        """저장소를 완전히 비우기"""
        self.stored_data.clear()
        print(f"🧹 [{self.owner}]의 저장소가 비워졌습니다.")

    def get_statistics(self) -> dict:
        """저장소 통계"""
        return {
            "owner": self.owner,
            "capacity": self.capacity,
            "current_size": len(self.stored_data),
            "usage_percent": (len(self.stored_data) / self.capacity * 100),
            "created_at": self.created_at.isoformat(),
            "access_count": self.access_count,
        }


# ============================================================================
# [2] 인스턴스의 독립성: 여러 저장소가 각각의 데이터 유지
# ============================================================================

class AdvancedStorage(GogsStorage):
    """
    고급 기능이 추가된 저장소
    - 카테고리별 저장
    - 검색 기능
    - 히스토리 추적
    """

    def __init__(self, owner: str, capacity: int = 100):
        """생성자: 부모 클래스 초기화 + 추가 속성"""
        super().__init__(owner, capacity)
        self.categories: dict = {}  # 카테고리별 분류
        self.history: List[dict] = []  # 모든 작업 기록

    def save_with_category(self, data: Any, category: str) -> bool:
        """카테고리와 함께 저장"""
        if super().save(data):
            # 카테고리 초기화
            if category not in self.categories:
                self.categories[category] = []

            # 카테고리에 추가
            self.categories[category].append(data)

            # 히스토리 기록
            self.history.append({
                "action": "save",
                "data": data,
                "category": category,
                "timestamp": datetime.now().isoformat()
            })
            print(f"   카테고리: [{category}]")
            return True
        return False

    def search(self, keyword: str) -> List[Any]:
        """키워드로 데이터 검색"""
        results = [d for d in self.stored_data if keyword in str(d)]
        print(f"\n🔍 검색어: '{keyword}' → {len(results)}개 발견")
        return results

    def get_category_data(self, category: str) -> List[Any]:
        """카테고리별 데이터 조회"""
        return self.categories.get(category, [])

    def show_history(self) -> None:
        """작업 히스토리 출력"""
        print(f"\n📋 [{self.owner}]의 작업 히스토리 (총 {len(self.history)}개)")
        for i, record in enumerate(self.history, 1):
            print(f"  {i}. [{record['action']}] {record['data']} @ {record['category']}")


