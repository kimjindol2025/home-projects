# [3] 클래스 변수 vs 인스턴스 변수
# ============================================================================

class StorageWithStats:
    """
    클래스 변수 vs 인스턴스 변수의 차이를 보여주는 클래스

    클래스 변수: 모든 인스턴스가 공유
    인스턴스 변수: 각 인스턴스가 독립적으로 유지
    """

    # 클래스 변수: 모든 인스턴스가 공유
    total_instances = 0
    total_data_saved = 0

    def __init__(self, owner: str, capacity: int = 100):
        """생성자"""
        # 클래스 변수 증가
        StorageWithStats.total_instances += 1

        # 인스턴스 변수: 각 인스턴스별 독립
        self.owner = owner
        self.capacity = capacity
        self.stored_data: List[Any] = []
        self.instance_data_count = 0

    def save(self, data: Any) -> bool:
        """데이터 저장"""
        if len(self.stored_data) < self.capacity:
            self.stored_data.append(data)
            self.instance_data_count += 1
            # 클래스 변수 증가
            StorageWithStats.total_data_saved += 1
            return True
        return False

    @classmethod
    def get_total_instances(cls) -> int:
        """클래스 변수: 전체 인스턴스 개수"""
        return cls.total_instances

    @classmethod
    def get_total_saved(cls) -> int:
        """클래스 변수: 전체 저장된 데이터 수"""
        return cls.total_data_saved

    def get_instance_saved(self) -> int:
        """인스턴스 변수: 이 저장소에 저장된 데이터 수"""
        return self.instance_data_count


# ============================================================================
# [4] 매직 메서드 (Magic Methods) - 특별한 행동 정의
# ============================================================================

class SmartStorage:
    """
    매직 메서드를 사용한 '똑똑한' 저장소

    매직 메서드:
    - __str__: print()할 때 출력되는 문자열
    - __repr__: 개발자용 표현
    - __len__: len()으로 길이 조회
    - __getitem__: [] 연산자 지원
    - __contains__: in 연산자 지원
    """

    def __init__(self, owner: str, capacity: int = 100):
        """생성자"""
        self.owner = owner
        self.capacity = capacity
        self.stored_data: List[Any] = []

    def save(self, data: Any) -> bool:
        """데이터 저장"""
        if len(self.stored_data) < self.capacity:
            self.stored_data.append(data)
            return True
        return False

    def __str__(self) -> str:
        """print()할 때 보여주는 문자열"""
        return f"📦 [{self.owner}]의 저장소 ({len(self.stored_data)}/{self.capacity})"

    def __repr__(self) -> str:
        """개발자용 표현 (디버깅)"""
        return f"SmartStorage(owner='{self.owner}', size={len(self.stored_data)}, capacity={self.capacity})"

    def __len__(self) -> int:
        """len() 함수 지원"""
        return len(self.stored_data)

    def __getitem__(self, index: int) -> Any:
        """[] 연산자 지원"""
        return self.stored_data[index]

    def __contains__(self, item: Any) -> bool:
        """in 연산자 지원"""
        return item in self.stored_data

    def __eq__(self, other: 'SmartStorage') -> bool:
        """== 연산자 지원"""
        if not isinstance(other, SmartStorage):
            return False
        return self.stored_data == other.stored_data

    def __iter__(self):
        """for 루프 지원"""
        return iter(self.stored_data)


# ============================================================================
# [5] 캡슐화: 데이터 보호
# ============================================================================

class SecureStorage:
    """
    캡슐화를 통한 데이터 보호
    - private 속성: _속성명 (관례상 외부 접근 금지)
    - protected 속성: __속성명 (완전 히든)
    """

    def __init__(self, owner: str, capacity: int = 100):
        """생성자"""
        self.owner = owner  # public: 외부에서 직접 접근 가능
        self._created_at = datetime.now()  # protected: 접근 권장 안 함
        self.__capacity = capacity  # private: 외부에서 접근 불가
        self.__stored_data: List[Any] = []  # private
        self.__access_log: List[str] = []  # private

    def save(self, data: Any) -> bool:
        """데이터 저장 (유일한 접근 방법)"""
        if len(self.__stored_data) < self.__capacity:
            self.__stored_data.append(data)
            self.__access_log.append(f"SAVE: {data} @ {datetime.now()}")
            return True
        return False

    def get_data(self) -> List[Any]:
        """데이터 조회 (읽기만 가능)"""
        self.__access_log.append(f"READ @ {datetime.now()}")
        return self.__stored_data.copy()  # 복사본 반환 (원본 보호)

    def get_size(self) -> int:
        """저장된 데이터 개수"""
        return len(self.__stored_data)

    def get_capacity(self) -> int:
        """최대 용량"""
        return self.__capacity

    def get_access_log(self) -> List[str]:
        """접근 기록 조회"""
        return self.__access_log.copy()


