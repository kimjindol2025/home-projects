def demonstrate_caching():
    """캐싱 데코레이터 데모"""

    @simple_cache
    def fibonacci(n):
        """피보나치 (캐싱 테스트용)"""
        if n < 2:
            return n
        return fibonacci(n - 1) + fibonacci(n - 2)

    result1 = fibonacci(5)
    result2 = fibonacci(5)  # 캐시에서 반환

    return {"first_call": result1, "cached_call": result2}


def demonstrate_retry():
    """재시도 데코레이터 데모"""

    attempt_count = [0]

    @retry(max_attempts=3, delay=0.1)
    def unreliable_api():
        """불안정한 API"""
        attempt_count[0] += 1
        if attempt_count[0] < 3:
            raise ConnectionError("API 연결 실패")
        return "성공!"

    try:
        result = unreliable_api()
        return {"result": result}
    except Exception as e:
        return {"error": str(e)}


def demonstrate_singleton():
    """싱글톤 패턴 데모"""

    @singleton
    class Database:
        """데이터베이스 싱글톤"""

        def __init__(self):
            self.connection_id = id(self)

    db1 = Database()
    db2 = Database()

    return {"db1_id": db1.connection_id, "db2_id": db2.connection_id, "same": db1 is db2}


