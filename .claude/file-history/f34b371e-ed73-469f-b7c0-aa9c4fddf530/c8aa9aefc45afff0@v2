class DatabaseLogger:
    """데이터베이스 로거 (로깅 관심사)"""

    def __init__(self):
        self.logs = []

    def log(self, message: str):
        timestamp = datetime.now().isoformat()
        log_entry = f"[{timestamp}] {message}"
        self.logs.append(log_entry)


def with_db_logging(logger: DatabaseLogger):
    """데이터베이스 로깅 데코레이터 (AOP)"""

    def decorator(func: Callable) -> Callable:
        @functools.wraps(func)
        def wrapper(*args, **kwargs) -> Any:
            logger.log(f"함수 {func.__name__} 시작 (인자: {args}, {kwargs})")
            try:
                result = func(*args, **kwargs)
                logger.log(f"함수 {func.__name__} 완료 (결과: {result})")
                return result
            except Exception as e:
                logger.log(f"함수 {func.__name__} 에러: {str(e)}")
                raise

        return wrapper

    return decorator


class Authorization:
    """권한 관리 (보안 관심사)"""

    def __init__(self):
        self.permissions = {}

    def grant_permission(self, user: str, permission: str):
        if user not in self.permissions:
            self.permissions[user] = set()
        self.permissions[user].add(permission)

    def check_permission(self, user: str, permission: str) -> bool:
        return permission in self.permissions.get(user, set())


def require_permission(auth: Authorization, required: str):
    """권한 요구 데코레이터"""

    def decorator(func: Callable) -> Callable:
        @functools.wraps(func)
        def wrapper(user: str, *args, **kwargs) -> Any:
            if not auth.check_permission(user, required):
                raise PermissionError(f"사용자 {user}에게 {required} 권한이 없습니다")
            return func(user, *args, **kwargs)

        return wrapper

    return decorator


