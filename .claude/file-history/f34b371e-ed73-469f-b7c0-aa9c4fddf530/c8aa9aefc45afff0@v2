def validate_positive(*arg_names):
    """양수 검증 데코레이터"""

    def decorator(func: Callable) -> Callable:
        @functools.wraps(func)
        def wrapper(*args, **kwargs) -> Any:
            # 위치 인자 검증
            for i, (arg_name, arg_value) in enumerate(zip(arg_names, args)):
                if not isinstance(arg_value, (int, float)) or arg_value <= 0:
                    raise ValueError(
                        f"'{arg_name}'는 양수여야 합니다 (받은 값: {arg_value})"
                    )

            return func(*args, **kwargs)

        return wrapper

    return decorator


