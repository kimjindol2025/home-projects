def gogs_logger(func: Callable) -> Callable:
    """기본 로깅 데코레이터"""

    @functools.wraps(func)
    def wrapper(*args, **kwargs) -> Any:
        print(f"--- [LOG] '{func.__name__}' 함수 시작 ---")
        result = func(*args, **kwargs)
        print(f"--- [LOG] '{func.__name__}' 함수 완료 ---")
        return result

    return wrapper


def timing_decorator(func: Callable) -> Callable:
    """실행 시간 측정 데코레이터"""

    @functools.wraps(func)
    def wrapper(*args, **kwargs) -> Any:
        start_time = time.time()
        result = func(*args, **kwargs)
        end_time = time.time()
        elapsed = end_time - start_time
        print(f"⏱️  [{func.__name__}] 실행 시간: {elapsed:.4f}초")
        return result

    return wrapper


def permission_check(required_permission: str):
    """권한 확인 데코레이터 (파라미터 데코레이터)"""

    def decorator(func: Callable) -> Callable:
        @functools.wraps(func)
        def wrapper(user, *args, **kwargs) -> Any:
            if not hasattr(user, "permissions") or required_permission not in user.permissions:
                raise PermissionError(
                    f"사용자 {user.name}에게 '{required_permission}' 권한이 없습니다"
                )
            print(f"✅ 권한 확인: {user.name} ({required_permission})")
            return func(user, *args, **kwargs)

        return wrapper

    return decorator


