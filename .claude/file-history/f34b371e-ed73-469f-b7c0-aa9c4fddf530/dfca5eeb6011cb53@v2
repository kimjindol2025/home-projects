"""
v6.1 Design Patterns Advanced - Enterprise Architecture Patterns
================================================================

실전 엔터프라이즈 아키텍처 패턴들:
1. Repository Pattern   — DB 접근 로직 추상화
2. Unit of Work Pattern  — 트랜잭션 경계 관리
3. Service Layer Pattern — 비즈니스 로직 계층
4. CQRS Pattern         — 읽기/쓰기 분리
5. Event Sourcing       — 이벤트 기반 상태 추적

철학: "데이터를 어떻게 저장하느냐가 아니라,
       비즈니스 로직이 이를 어떻게 조작하느냐가 중요하다"
"""

from abc import ABC, abstractmethod
from typing import Dict, List, Optional, Any, Callable
from dataclasses import dataclass, field
from datetime import datetime
from enum import Enum


# =============================================================================
# 1. Repository Pattern
# =============================================================================
class Repository(ABC):
    """저장소 인터페이스 — 데이터 접근 로직의 계약"""

    @abstractmethod
    def find_by_id(self, id: int) -> Optional[Dict[str, Any]]:
        """ID로 엔티티 조회"""
        pass

    @abstractmethod
    def find_all(self) -> List[Dict[str, Any]]:
        """모든 엔티티 조회"""
        pass

    @abstractmethod
    def find_by_spec(self, spec) -> List[Dict[str, Any]]:
        """Specification으로 엔티티 조회"""
        pass

    @abstractmethod
    def save(self, entity: Dict[str, Any]) -> Dict[str, Any]:
        """엔티티 저장 (생성/수정)"""
        pass

    @abstractmethod
    def delete(self, id: int) -> bool:
        """엔티티 삭제"""
        pass


class ResearcherRepository(Repository):
    """연구자 저장소 — DB 기반 구현"""

    def __init__(self, db):
        """
        Args:
            db: GogsDatabase 인스턴스
        """
        self.db = db

    def find_by_id(self, id: int) -> Optional[Dict[str, Any]]:
        return self.db.get_researcher(id)

    def find_all(self) -> List[Dict[str, Any]]:
        conn = self.db.get_connection()
        try:
            cursor = conn.cursor()
            cursor.execute("SELECT * FROM researchers ORDER BY id")
            return [dict(row) for row in cursor.fetchall()]
        finally:
            conn.close()

    def find_by_spec(self, spec) -> List[Dict[str, Any]]:
        """Specification으로 필터링"""
        all_researchers = self.find_all()
        return [r for r in all_researchers if spec.is_satisfied_by(r)]

    def save(self, entity: Dict[str, Any]) -> Dict[str, Any]:
        if 'id' in entity and entity['id']:
            # 수정
            return self.db.update_researcher(
                entity['id'],
                entity.get('name'),
                entity.get('email'),
                entity.get('role')
            )
        else:
            # 생성
            return self.db.create_researcher(
                entity['name'],
                entity['email'],
                entity.get('role', 'RESEARCHER')
            )

    def delete(self, id: int) -> bool:
        return self.db.delete_researcher(id)


class InMemoryResearcherRepository(Repository):
    """연구자 저장소 — 테스트용 인메모리 구현"""

    def __init__(self):
        self._data: Dict[int, Dict] = {}
        self._next_id = 1

    def find_by_id(self, id: int) -> Optional[Dict[str, Any]]:
        return self._data.get(id)

    def find_all(self) -> List[Dict[str, Any]]:
        return list(self._data.values())

    def find_by_spec(self, spec) -> List[Dict[str, Any]]:
        return [r for r in self._data.values() if spec.is_satisfied_by(r)]

    def save(self, entity: Dict[str, Any]) -> Dict[str, Any]:
        if 'id' in entity and entity['id']:
            self._data[entity['id']] = entity
            return entity
        else:
            entity['id'] = self._next_id
            self._next_id += 1
            self._data[entity['id']] = entity
            return entity

    def delete(self, id: int) -> bool:
        if id in self._data:
            del self._data[id]
            return True
        return False


# =============================================================================
# 2. Unit of Work Pattern
# =============================================================================
class UnitOfWork:
    """
    트랜잭션 경계를 관리하는 패턴

    다중 Repository 작업을 하나의 트랜잭션으로 조율
    "기록이 증명이다" — 모두 저장되거나 모두 실패하거나
    """

    def __init__(self, db):
        self.db = db
        self.researchers = ResearcherRepository(db)
        self.experiments = None  # ExperimentRepository도 추가 가능
        self._conn = None

    def __enter__(self):
        """Context manager 진입 — 트랜잭션 시작"""
        self._conn = self.db.get_connection()
        return self

    def __exit__(self, exc_type, exc_val, exc_tb):
        """Context manager 종료 — 커밋 또는 롤백"""
        if exc_type is not None:
            # 예외 발생 → 롤백
            self._conn.rollback()
            self._conn.close()
            return False
        else:
            # 성공 → 커밋
            self._conn.commit()
            self._conn.close()
            return True

    def commit(self):
        """명시적 커밋"""
        if self._conn:
            self._conn.commit()

    def rollback(self):
        """명시적 롤백"""
        if self._conn:
            self._conn.rollback()


# =============================================================================
# 3. Service Layer Pattern
# =============================================================================
class ResearcherService:
    """
    비즈니스 로직 계층

    API/Controller와 Repository 사이의 중간 계층
    비즈니스 규칙, 유효성 검사, 이벤트 발생 등을 담당
    """

    def __init__(self, uow: UnitOfWork):
        self.uow = uow
        self._events: List[Dict] = []

    def register_researcher(self, name: str, email: str, role: str) -> Dict:
        """
        연구자 등록 비즈니스 로직
        - 이메일 중복 검사
        - 엔티티 생성
        - 이벤트 발생
        """
        # 중복 검사
        existing = self.uow.researchers.find_all()
        if any(r['email'] == email for r in existing):
            raise ValueError(f"이미 등록된 이메일: {email}")

        # 엔티티 생성
        researcher = {
            'name': name,
            'email': email,
            'role': role
        }

        # 저장
        saved = self.uow.researchers.save(researcher)

        # 이벤트 발생
        self._events.append({
            'type': 'ResearcherRegistered',
            'researcher_id': saved['id'],
            'timestamp': datetime.now().isoformat()
        })

        return saved

    def update_researcher(self, researcher_id: int, name: str, email: str) -> Dict:
        """연구자 정보 수정"""
        researcher = self.uow.researchers.find_by_id(researcher_id)
        if not researcher:
            raise ValueError(f"연구자를 찾을 수 없습니다: {researcher_id}")

        researcher.update({'name': name, 'email': email})
        updated = self.uow.researchers.save(researcher)

        self._events.append({
            'type': 'ResearcherUpdated',
            'researcher_id': researcher_id,
            'timestamp': datetime.now().isoformat()
        })

        return updated

    def get_all_researchers(self) -> List[Dict]:
        """모든 연구자 조회"""
        return self.uow.researchers.find_all()

    def get_events(self) -> List[Dict]:
        """발생한 이벤트 반환 및 초기화"""
        events = self._events
        self._events = []
        return events


