def demonstrate_repository_pattern():
    """Repository 패턴 시연"""
    print("\n" + "="*70)
    print("1️⃣  Repository Pattern 시연")
    print("="*70)

    # 메모리 저장소 생성
    repo = InMemoryResearcherRepository()

    # 데이터 저장
    researcher = repo.save({'name': 'Alice', 'email': 'alice@gogs.io', 'role': 'ADMIN'})
    print(f"✅ 저장됨: {researcher}")

    # 조회
    found = repo.find_by_id(researcher['id'])
    print(f"✅ 조회됨: {found}")

    # 모든 데이터
    all_data = repo.find_all()
    print(f"✅ 전체: {len(all_data)}개 엔티티")

    print("\n💡 핵심: Repository가 없으면 API마다 DB 접근 로직을 반복 작성!")


def demonstrate_service_layer():
    """Service Layer 패턴 시연"""
    print("\n" + "="*70)
    print("2️⃣  Service Layer Pattern 시연")
    print("="*70)

    # 메모리 저장소 + 서비스
    repo = InMemoryResearcherRepository()
    uow = UnitOfWork.__new__(UnitOfWork)
    uow.researchers = repo

    service = ResearcherService(uow)

    # 비즈니스 로직 실행
    researcher = service.register_researcher('Bob', 'bob@gogs.io', 'RESEARCHER')
    print(f"✅ 등록됨: {researcher}")

    # 중복 등록 시도 → 비즈니스 규칙 검사
    try:
        service.register_researcher('Charlie', 'bob@gogs.io', 'RESEARCHER')
    except ValueError as e:
        print(f"❌ 비즈니스 규칙 위반 감지: {e}")

    # 이벤트 확인
    events = service.get_events()
    print(f"✅ 발생한 이벤트: {len(events)}개")
    print(f"   첫 번째 이벤트: {events[0]['type']}")

    print("\n💡 핵심: API Handler가 복잡한 비즈니스 로직으로 오염되지 않음!")


def demonstrate_cqrs():
    """CQRS 패턴 시연"""
    print("\n" + "="*70)
    print("3️⃣  CQRS Pattern 시연")
    print("="*70)

    print("✅ CQRS의 핵심:")
    print("   - 명령(Command): CREATE/UPDATE/DELETE (쓰기)")
    print("   - 쿼리(Query): SELECT (읽기)")
    print("   - 별도 처리기 → 각각 최적화 가능")

    # 명령 생성
    cmd = CreateExperimentCommand(
        researcher_id=1,
        subject="심화 패턴 연구",
        description="Enterprise 패턴 학습"
    )
    print(f"\n📝 명령 객체 생성:")
    print(f"   {cmd}")

    # 쿼리 생성
    query = GetExperimentsQuery(researcher_id=1, status='pending')
    print(f"\n🔍 쿼리 객체 생성:")
    print(f"   {query}")

    print("\n💡 핵심: 읽기와 쓰기를 명시적으로 분리하면 확장성 향상!")


def demonstrate_event_sourcing():
    """Event Sourcing 패턴 시연"""
    print("\n" + "="*70)
    print("4️⃣  Event Sourcing 패턴 시연")
    print("="*70)

    store = ExperimentEventStore()

    # 이벤트 기록
    events = [
        DomainEvent('ExperimentCreated', datetime.now(), 1,
                    {'subject': '패턴 연구', 'description': '심화 학습'}),
        DomainEvent('ExperimentStarted', datetime.now(), 1, {}),
        DomainEvent('LogAdded', datetime.now(), 1, {'message': '첫 시도 완료'}),
        DomainEvent('LogAdded', datetime.now(), 1, {'message': '분석 진행 중'}),
        DomainEvent('ExperimentCompleted', datetime.now(), 1, {'result': 95.5}),
    ]

    for event in events:
        store.append(event)
        print(f"📌 이벤트 기록: {event.event_type}")

    # 상태 재구성
    state = store.replay(1)
    print(f"\n✅ 최종 상태 재구성:")
    print(f"   상태: {state['status']}")
    print(f"   점수: {state['result']}")
    print(f"   히스토리: {len(state['history'])}개 로그")

    print("\n💡 핵심: '무엇이 일어났는가'를 기록하면 '현재 상태'를 언제든 재구성 가능!")


if __name__ == '__main__':
    demonstrate_repository_pattern()
    demonstrate_service_layer()
    demonstrate_cqrs()
    demonstrate_event_sourcing()
    print("\n" + "="*70)
    print("✅ Enterprise Patterns 시연 완료!")
    print("="*70)
