@dataclass
class CreateExperimentCommand:
    """실험 생성 명령"""
    researcher_id: int
    subject: str
    description: str


@dataclass
class UpdateExperimentCommand:
    """실험 수정 명령"""
    experiment_id: int
    status: str
    result: Optional[float] = None


@dataclass
class GetExperimentsQuery:
    """실험 조회 쿼리"""
    researcher_id: Optional[int] = None
    status: Optional[str] = None


class ExperimentCommandHandler:
    """명령 처리기 — 쓰기 작업"""

    def __init__(self, db):
        self.db = db

    def handle_create(self, cmd: CreateExperimentCommand) -> Dict:
        """실험 생성"""
        return self.db.create_experiment(
            cmd.researcher_id,
            cmd.subject,
            cmd.description,
            status='pending'
        )

    def handle_update(self, cmd: UpdateExperimentCommand) -> bool:
        """실험 상태 업데이트"""
        self.db.update_experiment(
            cmd.experiment_id,
            status=cmd.status,
            result=cmd.result
        )
        return True


class ExperimentQueryHandler:
    """쿼리 처리기 — 읽기 작업"""

    def __init__(self, db):
        self.db = db

    def handle_get_all(self, query: GetExperimentsQuery) -> List[Dict]:
        """조건에 맞는 실험 조회"""
        conn = self.db.get_connection()
        try:
            cursor = conn.cursor()
            sql = "SELECT * FROM experiments WHERE 1=1"
            params = []

            if query.researcher_id:
                sql += " AND researcher_id = ?"
                params.append(query.researcher_id)

            if query.status:
                sql += " AND status = ?"
                params.append(query.status)

            cursor.execute(sql, params)
            return [dict(row) for row in cursor.fetchall()]
        finally:
            conn.close()

    def get_statistics(self) -> Dict:
        """통계 조회"""
        conn = self.db.get_connection()
        try:
            cursor = conn.cursor()

            cursor.execute("""
                SELECT
                    COUNT(*) as total_experiments,
                    COUNT(CASE WHEN status = 'completed' THEN 1 END) as completed,
                    AVG(CAST(result AS FLOAT)) as avg_score
                FROM experiments
            """)
            row = cursor.fetchone()
            return dict(row)
        finally:
            conn.close()


