# 5. Event Sourcing
# =============================================================================

@dataclass
class DomainEvent:
    """도메인 이벤트 기본 클래스"""
    event_type: str
    timestamp: datetime
    entity_id: int
    data: Dict = field(default_factory=dict)

    def to_dict(self) -> Dict:
        return {
            'event_type': self.event_type,
            'timestamp': self.timestamp.isoformat(),
            'entity_id': self.entity_id,
            'data': self.data
        }


class ExperimentEventStore:
    """실험 이벤트 저장소"""

    def __init__(self):
        self._events: Dict[int, List[DomainEvent]] = {}

    def append(self, event: DomainEvent) -> None:
        """이벤트 추가"""
        if event.entity_id not in self._events:
            self._events[event.entity_id] = []
        self._events[event.entity_id].append(event)

    def get_events(self, entity_id: int) -> List[DomainEvent]:
        """특정 엔티티의 모든 이벤트"""
        return self._events.get(entity_id, [])

    def replay(self, entity_id: int) -> Dict:
        """이벤트를 재생하여 현재 상태 재구성"""
        events = self.get_events(entity_id)
        state = {
            'id': entity_id,
            'status': 'pending',
            'result': None,
            'history': []
        }

        for event in events:
            if event.event_type == 'ExperimentCreated':
                state.update({
                    'subject': event.data.get('subject'),
                    'description': event.data.get('description'),
                    'created_at': event.timestamp
                })
            elif event.event_type == 'ExperimentStarted':
                state['status'] = 'in_progress'
                state['started_at'] = event.timestamp
            elif event.event_type == 'ExperimentCompleted':
                state['status'] = 'completed'
                state['result'] = event.data.get('result')
                state['completed_at'] = event.timestamp
            elif event.event_type == 'LogAdded':
                state['history'].append(event.data.get('message'))

        return state

    def get_all_events(self) -> Dict[int, List[Dict]]:
        """모든 이벤트 반환"""
        return {
            eid: [e.to_dict() for e in events]
            for eid, events in self._events.items()
        }


