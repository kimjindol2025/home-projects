"""
v1.6 테스트: 함수
"""

from src.v1_6_my_first_function import (
    my_first_function,
    say_hello,
    add_numbers,
    is_even,
)


def test_my_first_function_returns_dict():
    """반환값이 딕셔너리"""
    result = my_first_function()
    assert isinstance(result, dict)


def test_add_numbers_function():
    """더하기 함수"""
    result = add_numbers(10, 20)
    assert result == 30


def test_add_numbers_with_different_values():
    """다양한 값으로 더하기"""
    assert add_numbers(5, 5) == 10
    assert add_numbers(100, 200) == 300
    assert add_numbers(-10, 10) == 0


def test_is_even_with_even_number():
    """짝수 판별: 4는 짝수"""
    assert is_even(4) == True


def test_is_even_with_odd_number():
    """짝수 판별: 7은 홀수"""
    assert is_even(7) == False


def test_is_even_with_zero():
    """짝수 판별: 0은 짝수"""
    assert is_even(0) == True


def test_is_even_with_negative_number():
    """짝수 판별: -2는 짝수"""
    assert is_even(-2) == True


def test_sum_result_in_return():
    """반환값에 sum_result"""
    result = my_first_function()
    assert result["sum_result"] == 30


def test_is_even_result_in_return():
    """반환값에 is_even 결과"""
    result = my_first_function()
    # test_num = 7이므로 is_even(7) == False
    assert result["is_even"] == False


def test_function_call_multiple_times():
    """함수를 여러 번 호출"""
    result1 = add_numbers(1, 2)
    result2 = add_numbers(1, 2)
    assert result1 == result2 == 3


def test_function_with_different_parameter_types():
    """서로 다른 매개변수 타입"""
    # 정수
    assert add_numbers(10, 20) == 30
    # 실수
    assert add_numbers(1.5, 2.5) == 4.0
    # 음수
    assert add_numbers(-5, 3) == -2
