class APIRouter:
    """API 요청 라우팅"""

    def __init__(self):
        self.controller = RESTAPIController()
        self.users = {}  # 인증된 사용자 캐시
        self._setup_demo_users()

    def _setup_demo_users(self):
        """데모용 사용자 설정"""
        admin = User(id=1, name='설계자', email='designer@gogs.io', role='admin')
        user = User(id=2, name='개발자', email='dev@gogs.io', role='user')
        self.controller.users[1] = admin
        self.controller.users[2] = user
        self.controller.next_user_id = 3

    def route(self, request: HTTPRequest, auth_token: Optional[str] = None) -> HTTPResponse:
        """요청 라우팅"""
        # 인증 확인 (일부 엔드포인트는 필수)
        user_id = None
        user_role = None

        if auth_token:
            user_id = AuthToken.verify_token(auth_token)
            if user_id and user_id in self.controller.users:
                user_role = self.controller.users[user_id].role

        # 엔드포인트 파싱
        parts = request.endpoint.split('/')
        # /v1/users -> ['', 'v1', 'users']
        # /v1/users/1 -> ['', 'v1', 'users', '1']

        if len(parts) < 3:
            return HTTPResponse(
                status_code=HTTPStatusCode.BAD_REQUEST,
                body={'error': '잘못된 엔드포인트'}
            )

        version = parts[1]  # v1, v2, ...
        resource = parts[2]  # users, experiments, ...
        resource_id = int(parts[3]) if len(parts) > 3 else None

        # Users 리소스
        if resource == 'users':
            if request.method == HTTPMethod.POST:
                return self.controller.create_user(request)
            elif request.method == HTTPMethod.GET:
                if resource_id:
                    return self.controller.get_user(resource_id)
                else:
                    return self.controller.get_all_users()
            elif request.method == HTTPMethod.PUT:
                if not resource_id:
                    return HTTPResponse(
                        status_code=HTTPStatusCode.BAD_REQUEST,
                        body={'error': 'ID 필요'}
                    )
                return self.controller.update_user(resource_id, request)
            elif request.method == HTTPMethod.DELETE:
                if not resource_id:
                    return HTTPResponse(
                        status_code=HTTPStatusCode.BAD_REQUEST,
                        body={'error': 'ID 필요'}
                    )
                return self.controller.delete_user(resource_id)

        # Experiments 리소스
        elif resource == 'experiments':
            # 인증 필수
            if not user_id:
                return HTTPResponse(
                    status_code=HTTPStatusCode.UNAUTHORIZED,
                    body={'error': '인증 토큰 필요'}
                )

            if request.method == HTTPMethod.POST:
                if not RoleBasedAccessControl.has_permission(user_role, 'create'):
                    return HTTPResponse(
                        status_code=HTTPStatusCode.FORBIDDEN,
                        body={'error': '실험 생성 권한 없음'}
                    )
                return self.controller.create_experiment(request, user_id)
            elif request.method == HTTPMethod.GET:
                if resource_id:
                    return self.controller.get_experiment(resource_id)
                else:
                    return self.controller.get_all_experiments()

        return HTTPResponse(
            status_code=HTTPStatusCode.NOT_FOUND,
            body={'error': '엔드포인트 없음'}
        )


