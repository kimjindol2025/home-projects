"""
v5.3 API 설계와 웹 프레임워크 기초
주제: "웹 서비스의 개방과 상호 운용성"

【 핵심 개념 】
1. REST API: Representational State Transfer
   - 리소스 중심 설계
   - HTTP 메서드를 통한 작업 명시
   - 상태 비보존 (Stateless)

2. HTTP 메서드와 CRUD 매핑
   - GET:    데이터 조회 (Read)
   - POST:   새 데이터 생성 (Create)
   - PUT:    기존 데이터 수정 (Update)
   - DELETE: 데이터 삭제 (Delete)

3. JSON: 웹 표준 데이터 교환 형식
   - JavaScript Object Notation
   - 가독성 + 파싱 효율성
   - 언어 독립적

4. API 버전 관리
   - /v1/users (버전 1)
   - /v2/users (버전 2)
   - 하위 호환성 유지

5. 인증과 인가
   - 인증: 사용자가 누구인가? (Authentication)
   - 인가: 사용자가 무엇을 할 수 있는가? (Authorization)
"""

import json
import time
import hashlib
from typing import Dict, List, Optional, Any, Tuple
from dataclasses import dataclass, asdict, field
from enum import Enum
from datetime import datetime, timedelta


# ============================================================================
# [1] HTTP 메서드와 상태 코드
# ============================================================================

class HTTPMethod(Enum):
    """HTTP 메서드 정의"""
    GET = 'GET'           # 데이터 조회 (조건: 멱등성)
    POST = 'POST'         # 새 리소스 생성 (조건: 비멱등성)
    PUT = 'PUT'           # 기존 리소스 전체 수정 (조건: 멱등성)
    PATCH = 'PATCH'       # 기존 리소스 부분 수정
    DELETE = 'DELETE'     # 리소스 삭제 (조건: 멱등성)


class HTTPStatusCode(Enum):
    """HTTP 상태 코드"""
    # 2xx: 성공
    OK = 200              # 요청 성공
    CREATED = 201         # 리소스 생성 성공
    ACCEPTED = 202        # 요청 수락 (처리 중)
    NO_CONTENT = 204      # 응답 본문 없음

    # 3xx: 리다이렉션
    MOVED_PERMANENTLY = 301
    FOUND = 302

    # 4xx: 클라이언트 오류
    BAD_REQUEST = 400     # 잘못된 요청
    UNAUTHORIZED = 401    # 인증 필요
    FORBIDDEN = 403       # 권한 없음
    NOT_FOUND = 404       # 리소스 없음
    CONFLICT = 409        # 충돌 (중복, 상태 불일치)

    # 5xx: 서버 오류
    INTERNAL_SERVER_ERROR = 500


# ============================================================================
# [2] 요청/응답 데이터 모델
# ============================================================================

@dataclass
class HTTPRequest:
    """HTTP 요청"""
    method: HTTPMethod
    endpoint: str              # /v1/users/{id}
    headers: Dict[str, str]    # {'Authorization': 'Bearer token'}
    body: Optional[Dict[str, Any]] = None
    query_params: Dict[str, str] = field(default_factory=dict)
    timestamp: float = field(default_factory=time.time)


@dataclass
class HTTPResponse:
    """HTTP 응답"""
    status_code: HTTPStatusCode
    body: Dict[str, Any]
    headers: Dict[str, str] = field(default_factory=lambda: {'Content-Type': 'application/json'})
    timestamp: float = field(default_factory=time.time)

    def to_json(self) -> str:
        """JSON으로 변환"""
        response = {
            'status': self.status_code.value,
            'data': self.body,
            'timestamp': self.timestamp
        }
        return json.dumps(response, ensure_ascii=False, indent=2)


