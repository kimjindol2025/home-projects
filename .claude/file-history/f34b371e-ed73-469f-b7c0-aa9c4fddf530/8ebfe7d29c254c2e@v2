class RESTAPIController:
    """REST API 요청 처리"""

    def __init__(self):
        self.users = {}      # {user_id: User}
        self.experiments = {} # {exp_id: Experiment}
        self.next_user_id = 1
        self.next_exp_id = 1

    # --- Users API ---

    def create_user(self, request: HTTPRequest) -> HTTPResponse:
        """POST /v1/users: 사용자 생성"""
        if not request.body or 'name' not in request.body or 'email' not in request.body:
            return HTTPResponse(
                status_code=HTTPStatusCode.BAD_REQUEST,
                body={
                    'error': '필수 필드 누락',
                    'required': ['name', 'email']
                }
            )

        user = User(
            id=self.next_user_id,
            name=request.body['name'],
            email=request.body['email'],
            role=request.body.get('role', 'user')
        )
        self.users[user.id] = user
        self.next_user_id += 1

        return HTTPResponse(
            status_code=HTTPStatusCode.CREATED,
            body={'id': user.id, 'message': '사용자 생성 완료', 'user': user.to_dict()}
        )

    def get_user(self, user_id: int) -> HTTPResponse:
        """GET /v1/users/{id}: 사용자 조회"""
        user = self.users.get(user_id)
        if not user:
            return HTTPResponse(
                status_code=HTTPStatusCode.NOT_FOUND,
                body={'error': f'사용자 {user_id} 없음'}
            )

        return HTTPResponse(
            status_code=HTTPStatusCode.OK,
            body=user.to_dict()
        )

    def get_all_users(self) -> HTTPResponse:
        """GET /v1/users: 모든 사용자 조회"""
        users_list = [user.to_dict() for user in self.users.values()]
        return HTTPResponse(
            status_code=HTTPStatusCode.OK,
            body={'users': users_list, 'count': len(users_list)}
        )

    def update_user(self, user_id: int, request: HTTPRequest) -> HTTPResponse:
        """PUT /v1/users/{id}: 사용자 수정"""
        user = self.users.get(user_id)
        if not user:
            return HTTPResponse(
                status_code=HTTPStatusCode.NOT_FOUND,
                body={'error': f'사용자 {user_id} 없음'}
            )

        # 부분 업데이트
        if 'name' in request.body:
            user.name = request.body['name']
        if 'email' in request.body:
            user.email = request.body['email']
        if 'role' in request.body:
            user.role = request.body['role']

        return HTTPResponse(
            status_code=HTTPStatusCode.OK,
            body={'message': '사용자 수정 완료', 'user': user.to_dict()}
        )

    def delete_user(self, user_id: int) -> HTTPResponse:
        """DELETE /v1/users/{id}: 사용자 삭제"""
        if user_id not in self.users:
            return HTTPResponse(
                status_code=HTTPStatusCode.NOT_FOUND,
                body={'error': f'사용자 {user_id} 없음'}
            )

        deleted_user = self.users.pop(user_id)
        return HTTPResponse(
            status_code=HTTPStatusCode.OK,
            body={'message': '사용자 삭제 완료', 'user': deleted_user.to_dict()}
        )

    # --- Experiments API ---

    def create_experiment(self, request: HTTPRequest, user_id: int) -> HTTPResponse:
        """POST /v1/experiments: 실험 생성"""
        if not request.body or 'subject' not in request.body or 'result' not in request.body:
            return HTTPResponse(
                status_code=HTTPStatusCode.BAD_REQUEST,
                body={'error': '필수 필드 누락', 'required': ['subject', 'result']}
            )

        experiment = Experiment(
            id=self.next_exp_id,
            subject=request.body['subject'],
            result=float(request.body['result']),
            created_by=user_id
        )
        self.experiments[experiment.id] = experiment
        self.next_exp_id += 1

        return HTTPResponse(
            status_code=HTTPStatusCode.CREATED,
            body={'id': experiment.id, 'message': '실험 기록 완료', 'experiment': experiment.to_dict()}
        )

    def get_experiment(self, exp_id: int) -> HTTPResponse:
        """GET /v1/experiments/{id}: 실험 조회"""
        experiment = self.experiments.get(exp_id)
        if not experiment:
            return HTTPResponse(
                status_code=HTTPStatusCode.NOT_FOUND,
                body={'error': f'실험 {exp_id} 없음'}
            )

        return HTTPResponse(
            status_code=HTTPStatusCode.OK,
            body=experiment.to_dict()
        )

    def get_all_experiments(self) -> HTTPResponse:
        """GET /v1/experiments: 모든 실험 조회"""
        experiments_list = [exp.to_dict() for exp in self.experiments.values()]
        return HTTPResponse(
            status_code=HTTPStatusCode.OK,
            body={'experiments': experiments_list, 'count': len(experiments_list)}
        )


