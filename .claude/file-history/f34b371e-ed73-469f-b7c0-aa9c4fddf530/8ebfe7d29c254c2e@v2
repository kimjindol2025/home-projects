class AuthToken:
    """JWT 형식의 토큰 (간소화 버전)"""

    @staticmethod
    def generate_token(user_id: int, secret_key: str = 'gogs_secret') -> str:
        """토큰 생성"""
        payload = {
            'user_id': user_id,
            'issued_at': time.time(),
            'expires_at': time.time() + 3600  # 1시간 유효
        }
        # 간단한 해싱 (실제는 JWT 라이브러리 사용)
        token_string = json.dumps(payload)
        token_hash = hashlib.sha256((token_string + secret_key).encode()).hexdigest()
        return f"{token_hash[:32]}:{user_id}"

    @staticmethod
    def verify_token(token: str, secret_key: str = 'gogs_secret') -> Optional[int]:
        """토큰 검증"""
        try:
            parts = token.split(':')
            if len(parts) != 2:
                return None
            user_id = int(parts[1])
            return user_id
        except:
            return None


class RoleBasedAccessControl:
    """역할 기반 접근 제어 (RBAC)"""

    PERMISSIONS = {
        'admin': ['read', 'create', 'update', 'delete'],
        'user': ['read', 'create'],
        'guest': ['read']
    }

    @staticmethod
    def has_permission(role: str, action: str) -> bool:
        """권한 확인"""
        if role not in RoleBasedAccessControl.PERMISSIONS:
            return False
        return action in RoleBasedAccessControl.PERMISSIONS[role]


