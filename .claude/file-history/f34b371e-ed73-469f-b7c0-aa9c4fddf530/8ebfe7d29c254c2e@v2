@dataclass
class User:
    """사용자 리소스"""
    id: int
    name: str
    email: str
    role: str = 'user'  # 'user', 'admin'
    created_at: str = field(default_factory=lambda: datetime.now().isoformat())

    def to_dict(self) -> Dict[str, Any]:
        """API 응답 형식으로 변환"""
        return asdict(self)


@dataclass
class Experiment:
    """실험 리소스 (v5.2에서 다룬 데이터베이스와 연결)"""
    id: int
    subject: str
    result: float
    created_at: str = field(default_factory=lambda: datetime.now().isoformat())
    created_by: int = 0  # user_id

    def to_dict(self) -> Dict[str, Any]:
        return asdict(self)


@dataclass
class APIError:
    """API 에러 응답"""
    code: str              # 에러 코드
    message: str           # 사용자 메시지
    details: Dict[str, Any] = field(default_factory=dict)
    timestamp: float = field(default_factory=time.time)

    def to_dict(self) -> Dict[str, Any]:
        return asdict(self)


