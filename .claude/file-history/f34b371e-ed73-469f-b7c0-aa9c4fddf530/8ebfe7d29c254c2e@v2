class APIClient:
    """REST API 클라이언트"""

    def __init__(self, base_url: str = 'http://api.gogs.io/v1'):
        self.base_url = base_url
        self.router = APIRouter()
        self.auth_token = None

    def login(self, user_id: int) -> str:
        """로그인 (토큰 발급)"""
        self.auth_token = AuthToken.generate_token(user_id)
        return self.auth_token

    def _make_request(self, method: HTTPMethod, endpoint: str, body: Optional[Dict] = None) -> HTTPResponse:
        """요청 실행 (라우터를 통해 시뮬레이션)"""
        request = HTTPRequest(
            method=method,
            endpoint=endpoint,
            headers={},
            body=body
        )
        return self.router.route(request, self.auth_token)

    # --- Public API ---

    def get_users(self) -> HTTPResponse:
        """GET /users"""
        return self._make_request(HTTPMethod.GET, '/v1/users')

    def get_user(self, user_id: int) -> HTTPResponse:
        """GET /users/{id}"""
        return self._make_request(HTTPMethod.GET, f'/v1/users/{user_id}')

    def create_user(self, name: str, email: str, role: str = 'user') -> HTTPResponse:
        """POST /users"""
        return self._make_request(
            HTTPMethod.POST,
            '/v1/users',
            {'name': name, 'email': email, 'role': role}
        )

    def update_user(self, user_id: int, name: str = None, email: str = None) -> HTTPResponse:
        """PUT /users/{id}"""
        body = {}
        if name:
            body['name'] = name
        if email:
            body['email'] = email
        return self._make_request(HTTPMethod.PUT, f'/v1/users/{user_id}', body)

    def delete_user(self, user_id: int) -> HTTPResponse:
        """DELETE /users/{id}"""
        return self._make_request(HTTPMethod.DELETE, f'/v1/users/{user_id}')

    def create_experiment(self, subject: str, result: float) -> HTTPResponse:
        """POST /experiments"""
        return self._make_request(
            HTTPMethod.POST,
            '/v1/experiments',
            {'subject': subject, 'result': result}
        )

    def get_experiments(self) -> HTTPResponse:
        """GET /experiments"""
        return self._make_request(HTTPMethod.GET, '/v1/experiments')

    def get_experiment(self, exp_id: int) -> HTTPResponse:
        """GET /experiments/{id}"""
        return self._make_request(HTTPMethod.GET, f'/v1/experiments/{exp_id}')


