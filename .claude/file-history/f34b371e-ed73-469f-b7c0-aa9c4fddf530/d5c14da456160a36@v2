def test_complete_workflow():
    """완전한 워크플로우"""
    # 1. 변수 생성
    project = "Gogs-Python"
    version_major = 1
    version_minor = 1

    # 2. 계산
    full_version = version_major + version_minor / 10

    # 3. 문자열 생성
    description = f"{project} v{full_version}"

    # 4. 타입 확인
    assert isinstance(project, str)
    assert isinstance(version_major, int)
    assert isinstance(full_version, float)

    # 5. 결과 검증
    assert "1.1" in description or abs(full_version - 1.1) < 0.01


