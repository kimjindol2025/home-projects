"""
v1.8 테스트: 튜플과 집합
"""

from src.v1_8_fixed_and_unique_data import fixed_and_unique_data


def test_fixed_and_unique_data_returns_dict():
    """반환값이 딕셔너리"""
    result = fixed_and_unique_data()
    assert isinstance(result, dict)


def test_tuple_structure():
    """튜플 구조"""
    result = fixed_and_unique_data()
    location = result["location"]
    assert isinstance(location, tuple)
    assert len(location) == 2
    assert location[0] == 37.5665
    assert location[1] == 126.9780


def test_tuple_immutability():
    """튜플은 변경 불가능"""
    location = (37.5665, 126.9780)
    # 튜플에 할당 시도는 TypeError 발생
    try:
        location[0] = 38.0
        assert False, "튜플은 변경 불가능해야 함"
    except TypeError:
        pass  # 예상된 에러


def test_raw_samples_with_duplicates():
    """원본 샘플 (중복 포함)"""
    result = fixed_and_unique_data()
    raw_samples = result["raw_samples"]
    assert len(raw_samples) == 6
    assert raw_samples.count("철") == 2
    assert raw_samples.count("구리") == 2


def test_set_removes_duplicates():
    """집합은 중복을 제거"""
    result = fixed_and_unique_data()
    unique_samples = result["unique_samples"]
    assert isinstance(unique_samples, set)
    assert len(unique_samples) == 4
    assert "철" in unique_samples
    assert "구리" in unique_samples
    assert "금" in unique_samples
    assert "은" in unique_samples


def test_set_intersection():
    """교집합: 두 집합에 모두 포함된 원소"""
    result = fixed_and_unique_data()
    intersection = result["intersection"]
    assert "B" in intersection
    assert "C" in intersection
    assert len(intersection) == 2


def test_set_union():
    """합집합: 두 집합의 모든 원소"""
    result = fixed_and_unique_data()
    union = result["union"]
    assert len(union) == 4
    assert "A" in union
    assert "B" in union
    assert "C" in union
    assert "D" in union


def test_tuple_access():
    """튜플 인덱싱 접근"""
    location = (37.5665, 126.9780)
    assert location[0] == 37.5665
    assert location[1] == 126.9780


def test_set_operations_manually():
    """집합 연산 수동 테스트"""
    set1 = {1, 2, 3}
    set2 = {2, 3, 4}

    # 교집합
    intersection = set1 & set2
    assert intersection == {2, 3}

    # 합집합
    union = set1 | set2
    assert union == {1, 2, 3, 4}


def test_tuple_from_list():
    """리스트를 튜플로 변환"""
    list_data = [10, 20, 30]
    tuple_data = tuple(list_data)
    assert isinstance(tuple_data, tuple)
    assert tuple_data == (10, 20, 30)


def test_set_from_list():
    """리스트를 집합으로 변환하여 중복 제거"""
    list_with_duplicates = [1, 2, 2, 3, 3, 3]
    set_unique = set(list_with_duplicates)
    assert len(set_unique) == 3
    assert set_unique == {1, 2, 3}
