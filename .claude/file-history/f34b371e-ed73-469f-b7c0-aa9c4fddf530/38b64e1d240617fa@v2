## 📝 실습: 로봇 계층도

```python
# 부모 클래스
class GogsRobot:
    def __init__(self, name):
        self.name = name
        print(f"🤖 기본 로봇 {self.name} 생성")

    def work(self):
        print(f"{self.name}이 지상에서 일합니다")

# 자식 클래스 1: 비행 로봇
class FlyingGogsRobot(GogsRobot):
    def __init__(self, name, altitude):
        super().__init__(name)
        self.altitude = altitude
        print(f"🚀 비행 모듈 장착! 고도: {self.altitude}m")

    def work(self):
        print(f"{self.name}이 {self.altitude}m 상공에서 정찰합니다")

    def fly(self):
        print(f"{self.name}이 날아오릅니다!")

# 자식 클래스 2: 수중 로봇
class SubmarineGogsRobot(GogsRobot):
    def __init__(self, name, depth):
        super().__init__(name)
        self.depth = depth
        print(f"🌊 수중 모듈 장착! 잠수 깊이: {self.depth}m")

    def work(self):
        print(f"{self.name}이 {self.depth}m 수심에서 탐사합니다")

    def dive(self):
        print(f"{self.name}이 잠수합니다!")

# 사용
basic = GogsRobot("지상봇")
flying = FlyingGogsRobot("스카이봇", 500)
submarine = SubmarineGogsRobot("딥봇", 1000)

basic.work()        # 지상 업무
flying.work()       # 상공 업무
flying.fly()        # 비행 기능

submarine.work()    # 수중 탐사
submarine.dive()    # 잠수 기능
```

