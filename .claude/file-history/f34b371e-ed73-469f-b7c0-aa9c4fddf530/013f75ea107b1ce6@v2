"""
v1.4 Callable Objects & Context Managers

__call__() → 함수처럼 호출
__enter__(), __exit__() → with 문 지원
"""

from typing import Any
import time


class Multiplier:
    """호출 가능한 객체: 함수처럼 동작"""

    def __init__(self, n: float):
        self.n = n

    def __call__(self, x: float) -> float:
        """
        인스턴스를 함수처럼 호출

        mul = Multiplier(5)
        mul(3) → mul.__call__(3)
        """
        return x * self.n

    def __repr__(self) -> str:
        return f"Multiplier({self.n})"


class Counter:
    """호출될 때마다 카운트를 증가"""

    def __init__(self):
        self.count = 0

    def __call__(self) -> int:
        self.count += 1
        return self.count

    def reset(self) -> None:
        self.count = 0


class Timer:
    """컨텍스트 매니저: with 문 지원"""

    def __init__(self, name: str = "Operation"):
        self.name = name
        self.start_time = None

    def __enter__(self) -> 'Timer':
        """
        with 블록 진입

        with Timer("task") as t:
            ...
        """
        self.start_time = time.time()
        print(f"[{self.name}] 시작")
        return self

    def __exit__(self, exc_type, exc_val, exc_tb) -> bool:
        """
        with 블록 탈출 (예외 발생 여부 무관)

        예외가 발생하면:
        - exc_type: 예외 타입
        - exc_val: 예외 값
        - exc_tb: 예외 트레이스백
        """
        elapsed = time.time() - self.start_time
        print(f"[{self.name}] 완료. 소요시간: {elapsed:.4f}초")

        if exc_type is not None:
            print(f"[{self.name}] 예외 발생: {exc_type.__name__}")
        return False  # 예외를 전파


class FileManager:
    """파일 관리 컨텍스트 매니저"""

    def __init__(self, filename: str, mode: str = 'r'):
        self.filename = filename
        self.mode = mode
        self.file = None

    def __enter__(self):
        self.file = open(self.filename, self.mode)
        print(f"파일 열기: {self.filename}")
        return self.file

    def __exit__(self, exc_type, exc_val, exc_tb):
        if self.file:
            self.file.close()
            print(f"파일 닫기: {self.filename}")
        return False


class DatabaseConnection:
    """데이터베이스 연결 시뮬레이션"""

    def __init__(self, dbname: str):
        self.dbname = dbname
        self.connected = False

    def __enter__(self):
        print(f"DB 연결: {self.dbname}")
        self.connected = True
        return self

    def __exit__(self, exc_type, exc_val, exc_tb):
        print(f"DB 종료: {self.dbname}")
        self.connected = False
        return False

    def query(self, sql: str) -> str:
        if not self.connected:
            raise RuntimeError("Database not connected")
        return f"Result of: {sql}"


def demonstrate_callable_objects():
    """호출 가능한 객체 시연"""
    print("\n" + "="*70)
    print("호출 가능한 객체 (__call__)")
    print("="*70)

    print("\n  [Multiplier: 함수처럼 동작]")
    mul5 = Multiplier(5)
    print(f"    mul5 = Multiplier(5)")
    print(f"    mul5(3) = {mul5(3)}")
    print(f"    mul5(7) = {mul5(7)}")

    print("\n  [Counter: 호출할 때마다 증가]")
    counter = Counter()
    print(f"    counter = Counter()")
    print(f"    counter() = {counter()}")
    print(f"    counter() = {counter()}")
    print(f"    counter() = {counter()}")

    print("\n" + "="*70)


def demonstrate_context_managers():
    """컨텍스트 매니저 시연"""
    print("\n" + "="*70)
    print("컨텍스트 매니저 (__enter__, __exit__)")
    print("="*70)

    print("\n  [Timer: 시간 측정]")
    print("    with Timer('계산') as t:")
    with Timer('계산'):
        time.sleep(0.1)
        print("    ... 계산 중 ...")

    print("\n  [예외 처리]")
    print("    with Timer('안전한 작업'):")
    try:
        with Timer('안전한 작업'):
            time.sleep(0.05)
            print("    ... 작업 중 ...")
    except Exception as e:
        print(f"    예외: {e}")

    print("\n  [DatabaseConnection 시뮬레이션]")
    print("    with DatabaseConnection('mydb') as db:")
    with DatabaseConnection('mydb') as db:
        print(f"    {db.query('SELECT * FROM users')}")

    print("\n" + "="*70)


