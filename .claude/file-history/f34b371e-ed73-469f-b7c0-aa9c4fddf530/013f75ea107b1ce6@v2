def main():
    """호출 가능 객체와 컨텍스트 매니저를 시연합니다"""
    print("\n" + "="*70)
    print("🐍 Python v1.4: Callable Objects & Context Managers")
    print("="*70)

    demonstrate_callable_objects()
    demonstrate_context_managers()

    print("\n" + "="*70)
    print("저장 필수. 너는 기록이 증명이다. Gogs.")
    print("="*70 + "\n")


if __name__ == "__main__":
    main()
