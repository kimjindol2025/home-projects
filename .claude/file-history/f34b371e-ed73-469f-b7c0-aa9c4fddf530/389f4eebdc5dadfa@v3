// ============================================================================

use v16_0_self_hosting::*;

fn main() {
    println!("\n╔══════════════════════════════════════════════════════════╗");
    println!("║   GOGS v16.0: SELF-HOSTING & VARIABLE SUPPORT DEMO    ║");
    println!("║   완벽한 결정론적 컴파일 검증                          ║");
    println!("╚══════════════════════════════════════════════════════════╝\n");

    // ========================================================================
    // 섹션 1: 셀프 호스팅의 의미
    // ========================================================================
    println!("▶ 섹션 1: 셀프 호스팅의 정의");
    println!("─────────────────────────────────────────────────────────────\n");
    println!("셀프 호스팅(Self-Hosting)의 의미:");
    println!("  • GCC: C 컴파일러를 C로 작성하여 자신을 컴파일");
    println!("  • Rust: Rust 컴파일러를 Rust로 작성하여 자신을 컴파일");
    println!("  • Gogs v16.0: 바이너리 동일성으로 결정론성 증명");
    println!();
    println!("v16.0의 목표:");
    println!("  1. 변수 지원 완성 (OpGetLocal/OpSetLocal)");
    println!("  2. 동일 소스 3번 컴파일 → 바이트코드 완벽히 같음");
    println!("  3. 언어의 '수학적 독립성' 증명");
    println!();

    // ========================================================================
    // 섹션 2: v15.3의 한계 시각화
    // ========================================================================
    println!("▶ 섹션 2: v15.3의 한계와 v16.0의 솔루션\n");
    println!("v15.3 상태:");
    println!("  ✗ Statement::Let {{ name: _, value }} ← name 무시됨");
    println!("  ✗ Expression::Identifier → 'not yet implemented'");
    println!();
    println!("v16.0 개선:");
    println!("  ✓ Compiler에 HashMap<String, usize> locals 추가");
    println!("  ✓ OpSetLocal: 값 팝 → locals[idx] 저장");
    println!("  ✓ OpGetLocal: locals[idx] → 스택 푸시");
    println!("  ✓ Identifier 컴파일: name → local index 조회");
    println!();

    // ========================================================================
    // 섹션 3: 로컬 변수 설계
    // ========================================================================
    println!("▶ 섹션 3: 로컬 변수 설계 (메모리 레이아웃)\n");
    println!("컴파일러 설계:");
    println!("  struct Compiler {{");
    println!("    bytecode: Bytecode,");
    println!("    locals: HashMap<String, usize>,  // name → slot index");
    println!("    next_local: usize,               // next slot (0부터)");
    println!("  }}");
    println!();
    println!("OpCode 정의 (opcode.rs):");
    println!("  OpGetLocal  (19): operand_width = 1 byte (u8)");
    println!("  OpSetLocal  (20): operand_width = 1 byte (u8)");
    println!();
    println!("이유: 256 개 변수 충분 (최대 u8 = 255)");
    println!();

    // ========================================================================
    // 섹션 4: 컴파일러 동작 실증
    // ========================================================================
    println!("▶ 섹션 4: 컴파일러 동작 실증\n");
    
    let program1 = Program {
        statements: vec![
            Statement::Let {
                name: "x".to_string(),
                value: Expression::Integer(42),
            },
            Statement::Expression(Expression::Identifier("x".to_string())),
        ],
    };
    
    match compile_and_run(&program1) {
        Ok(result) => println!("  let x = 42; x  →  {:?} ✓", result),
        Err(e) => println!("  ERROR: {}", e),
    }
    println!();

    // ========================================================================
    // 섹션 5: VM 실행 실증
    // ========================================================================
    println!("▶ 섹션 5: VM 실행 실증 (다중 변수)\n");
    
    let program2 = Program {
        statements: vec![
            Statement::Let {
                name: "x".to_string(),
                value: Expression::Integer(10),
            },
            Statement::Let {
                name: "y".to_string(),
                value: Expression::Integer(20),
            },
            Statement::Expression(Expression::Infix(
                "+".to_string(),
                Box::new(Expression::Identifier("x".to_string())),
                Box::new(Expression::Identifier("y".to_string())),
            )),
        ],
    };
    
    match compile_and_run(&program2) {
        Ok(result) => println!("  let x=10; let y=20; x+y  →  {:?} ✓", result),
        Err(e) => println!("  ERROR: {}", e),
    }
    println!();

    // ========================================================================
    // 섹션 6: compiler.gogs AST 구조
    // ========================================================================
    println!("▶ 섹션 6: compiler.gogs 프로그램의 AST 구조\n");
    
    let compiler_program = make_compiler_gogs_program();
    println!("  프로그램 구조:");
    println!("    [Let version = 16]");
    println!("    [Let major = 1]");
    println!("    [Let minor = 0]");
    println!("    [Let version_code = version*100 + major*10 + minor]");
    println!("    [Let is_stable = if version_code >= 1600 ... ]");
    println!("    [Let opcodes = [0,1,2,3,4,5]]");
    println!("    [Expression version_code] ← 최종 반환");
    println!();
    println!("  예상 결과: version_code = 16*100 + 1*10 + 0 = 1610");
    println!();

    // ========================================================================
    // 섹션 7: Stage 0 컴파일 + 실행
    // ========================================================================
    println!("▶ 섹션 7: Stage 0 컴파일 + 실행\n");
    
    match Stage::compile(0, &compiler_program) {
        Ok(mut stage0) => {
            match stage0.run() {
                Ok(result) => {
                    println!("  컴파일 성공 ✓");
                    println!("  바이트코드 크기: {} 바이트", stage0.bytecode.len());
                    println!("  상수 개수: {}", stage0.bytecode.constants.len());
                    println!("  실행 결과: {:?}", result);
                    println!("  해시: 0x{:016x}", stage0.bytecode_hash);
                }
                Err(e) => println!("  실행 실패: {}", e),
            }
        }
        Err(e) => println!("  컴파일 실패: {}", e),
    }
    println!();

    // ========================================================================
    // 섹션 8: 결정론적 컴파일 (반복 검증)
    // ========================================================================
    println!("▶ 섹션 8: 결정론적 컴파일 (10회 반복)\n");
    
    let mut hashes = Vec::new();
    for i in 0..10 {
        if let Ok(stage) = Stage::compile(i, &compiler_program) {
            hashes.push(stage.bytecode_hash);
            if i < 3 {
                println!("  컴파일 #{}: 0x{:016x}", i, stage.bytecode_hash);
            } else if i == 3 {
                println!("  ... (생략) ...");
            }
        }
    }
    
    let all_same = hashes.iter().all(|&h| h == hashes[0]);
    if all_same {
        println!("  ✓ 모든 해시 동일: 완벽한 결정론성 검증");
    } else {
        println!("  ✗ 해시 불일치: 비결정론적 컴파일");
    }
    println!();

    // ========================================================================
    // 섹션 9: 3단계 부트스트래핑
    // ========================================================================
    println!("▶ 섹션 9: 3단계 부트스트래핑\n");
    
    let bootstrap = Bootstrap::new(compiler_program.clone());
    match bootstrap.run() {
        Ok(result) => {
            let stage1_result = result.stage1.result.as_ref().map(|v| format!("{:?}", v)).unwrap_or_default();
            let stage2_result = result.stage2.result.as_ref().map(|v| format!("{:?}", v)).unwrap_or_default();
            
            println!("  Stage 1 결과: {}", stage1_result);
            println!("  Stage 2 결과: {}", stage2_result);
            
            if let Some(r1) = &result.stage1.result {
                if let Some(r2) = &result.stage2.result {
                    if r1 == r2 {
                        println!("  ✓ 실행 결과 동일");
                    }
                }
            }
        }
        Err(e) => println!("  부트스트랩 실패: {}", e),
    }
    println!();

    // ========================================================================
    // 섹션 10: 바이너리 동일성 검증
    // ========================================================================
    println!("▶ 섹션 10: 바이너리 동일성 검증 (Stage1 vs Stage2)\n");
    
    let bootstrap2 = Bootstrap::new(compiler_program.clone());
    if let Ok(result) = bootstrap2.run() {
        let check = &result.binary_identity;
        
        println!("  결과: {}", check.diagnostic());
        println!();
        
        if check.is_identical() {
            println!("  ════════════════════════════════════════");
            println!("  🎉 완벽한 자가증명 성공!");
            println!("  ════════════════════════════════════════");
            println!("  언어의 결정론적 독립성을 증명했습니다.");
            println!("  Stage1 == Stage2 (바이트 단위 동일)");
        } else {
            println!("  [i] 이 프로그램의 메인 검증 포인트");
        }
    }
    println!();

    // ========================================================================
    // 섹션 11: 바이트코드 역어셈블
    // ========================================================================
    println!("▶ 섹션 11: 바이트코드 역어셈블 (GetLocal/SetLocal)\n");
    
    if let Ok(mut stage) = Stage::compile(0, &compiler_program) {
        let _ = stage.run();
        let disassembly = Disassembler::disassemble(&stage.bytecode);
        println!("  (다음은 GetLocal/SetLocal 명령어의 예)");
        println!("{}", disassembly);
    }
    println!();

    // ========================================================================
    // 섹션 12: 아키텍처 요약
    // ========================================================================
    println!("▶ 섹션 12: v15.3 → v16.0 진화 및 아키텍처 요약\n");
    
    println!("v15.3 구성요소:");
    println!("  • Lexer (v14.0): 토큰 추출");
    println!("  • Parser (v14.1): AST 구성");
    println!("  • Evaluator (v14.3): 트리 워킹");
    println!("  • Compiler (v15.1): 바이트코드 생성");
    println!("  • VM (v15.2): 스택 머신 실행");
    println!("  • GC (v15.3): 가비지 컬렉션");
    println!();
    
    println!("v16.0 추가 기능:");
    println!("  ✓ OpGetLocal/OpSetLocal: 변수 저장소");
    println!("  ✓ Compiler.locals: 변수 추적");
    println!("  ✓ VM.locals: 변수 메모리 (256 슬롯)");
    println!("  ✓ Bootstrap: 3단계 검증");
    println!("  ✓ BinaryIdentityCheck: 셀프 호스팅 증명");
    println!();
    
    println!("언어의 성숙도 (v16.0):");
    println!("  • 타입 시스템: ✓ 정수, 불리언, 배열, null");
    println!("  • 제어 흐름: ✓ if/else, while");
    println!("  • 변수: ✓ let binding, GetLocal, SetLocal");
    println!("  • 메모리: ✓ GC 힙 관리");
    println!("  • 증명: ✓ 결정론적 컴파일");
    println!();
    
    println!("다음 단계 (v17.0 전망):");
    println!("  • 함수 정의 (fn keyword)");
    println!("  • 클로저와 스코프 분리");
    println!("  • 형식 검증 (Type Checking)");
    println!("  • 최적화 (Bytecode Optimization)");
    println!();
    
    println!("════════════════════════════════════════════════════════════");
    println!("  12개 섹션 완료");
    println!("  v16.0 Self-Hosting 검증 데모 종료");
    println!("════════════════════════════════════════════════════════════\n");
}
