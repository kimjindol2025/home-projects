"""
v1.1 테스트: 첫 번째 기록
"""

from src.v1_1_my_first_variable import my_first_variable


def test_my_first_variable_returns_dict():
    """반환값이 딕셔너리"""
    result = my_first_variable()
    assert isinstance(result, dict)


def test_core_version():
    """core_version = 1"""
    result = my_first_variable()
    assert result["core_version"] == 1
    assert isinstance(result["core_version"], int)


def test_sub_version():
    """sub_version = 1"""
    result = my_first_variable()
    assert result["sub_version"] == 1
    assert isinstance(result["sub_version"], int)


def test_full_version_calculation():
    """full_version = 1 + 1/10 = 1.1"""
    result = my_first_variable()
    assert abs(result["full_version"] - 1.1) < 0.0001
    assert isinstance(result["full_version"], float)


def test_language_name():
    """language_name = "파이썬" """
    result = my_first_variable()
    assert result["language_name"] == "파이썬"
    assert isinstance(result["language_name"], str)


def test_status():
    """status = "학습 중" """
    result = my_first_variable()
    assert result["status"] == "학습 중"
    assert isinstance(result["status"], str)


def test_type_of_full_version():
    """type(full_version) == float"""
    result = my_first_variable()
    assert type(result["full_version"]) == float


def test_type_of_language_name():
    """type(language_name) == str"""
    result = my_first_variable()
    assert type(result["language_name"]) == str
