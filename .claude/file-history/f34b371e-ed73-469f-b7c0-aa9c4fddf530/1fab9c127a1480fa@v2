"""
[Python High-School v2.3] 상속과 기능 확장 (심화)
주제: "기존의 유산을 물려받아 새로운 가치 창조하기"

상속의 핵심 메커니즘:
1. Method Overriding (재정의): 부모의 메서드를 자식이 새로 정의
2. super() 활용: 부모의 메서드를 먼저 사용 후 기능 추가
3. 계층 구조: 단계적 기능 확장 (2단계, 3단계 이상)
4. is-a 관계: "보안 저장소는 저장소인가?"라는 질문이 "예"일 때만 상속 사용
"""

from datetime import datetime
from typing import List, Any, Optional


# ============================================================================
# [1] 기본 부모 클래스 (v2.2에서 만든 GogsStorage)
# ============================================================================

class GogsStorage:
    """기본 저장소: 부모 클래스"""

    def __init__(self, owner: str, capacity: int = 100):
        """생성자"""
        self.owner = owner
        self.capacity = capacity
        self.stored_data: List[Any] = []
        self.created_at = datetime.now()
        print(f"📦 [{self.owner}]님의 저장소 생성 (용량: {self.capacity})")

    def save(self, data: Any) -> bool:
        """데이터 저장"""
        if len(self.stored_data) < self.capacity:
            self.stored_data.append(data)
            return True
        return False

    def get_size(self) -> int:
        """저장된 데이터 개수"""
        return len(self.stored_data)

    def is_full(self) -> bool:
        """저장소 가득 찼는지 확인"""
        return len(self.stored_data) >= self.capacity

    def show_all(self) -> None:
        """저장된 모든 데이터 출력"""
        print(f"\n--- [{self.owner}]의 데이터 (총 {len(self.stored_data)}개) ---")
        for i, data in enumerate(self.stored_data, 1):
            print(f"  {i}. {data}")


# ============================================================================
# [2] 1단계 상속: 보안 기능 추가
# ============================================================================

class SecureGogsStorage(GogsStorage):
    """
    보안 기능이 추가된 저장소 (1단계 상속)

    Method Overriding: 부모의 save()를 덮어써서 보안 검사 추가
    super() 활용: 부모의 save() 기능은 그대로 사용
    """

    def __init__(self, owner: str, capacity: int = 100, password: str = "gogs"):
        """생성자: 부모 초기화 + 보안 설정"""
        # 부모의 __init__ 호출
        super().__init__(owner, capacity)
        self.password = password
        self.access_logs: List[str] = []
        print(f"🔐 보안 모듈 활성화 (소유자: {self.owner})")

    def verify_password(self, password: str) -> bool:
        """비밀번호 확인"""
        return password == self.password

    def save(self, data: Any, password: str = "") -> bool:
        """
        Method Overriding: 부모의 save()를 덮어씀
        보안 검사 → 부모의 저장 방식 사용
        """
        # 1. 보안 검사
        if not self.verify_password(password):
            log = f"❌ 저장 실패: 비밀번호 오류 ({datetime.now().strftime('%H:%M:%S')})"
            self.access_logs.append(log)
            print(log)
            return False

        # 2. 부모의 save() 호출 (super() 활용)
        if super().save(data):
            # 3. 로그 기록
            log = f"✅ 저장 성공: {data} ({datetime.now().strftime('%H:%M:%S')})"
            self.access_logs.append(log)
            print(f"🛡️ {log}")
            return True

        # 4. 용량 초과
        log = f"❌ 저장 실패: 용량 초과 ({datetime.now().strftime('%H:%M:%S')})"
        self.access_logs.append(log)
        print(log)
        return False

    def show_logs(self) -> None:
        """보안 로그 출력"""
        print(f"\n--- [{self.owner}]의 보안 로그 ---")
        for log in self.access_logs:
            print(f"  {log}")

    def clear_logs(self) -> None:
        """로그 초기화"""
        self.access_logs.clear()
        print("🧹 로그가 초기화되었습니다.")


# ============================================================================
# [3] 2단계 상속: 백업 기능 추가
# ============================================================================

class BackupSecureGogsStorage(SecureGogsStorage):
    """
    백업 기능이 추가된 보안 저장소 (2단계 상속)

    상속 체계: GogsStorage → SecureGogsStorage → BackupSecureGogsStorage
    Method Overriding: save()를 다시 덮어써서 백업 기능 추가
    """

    def __init__(self, owner: str, capacity: int = 100, password: str = "gogs"):
        """생성자: 부모 초기화 + 백업 설정"""
        super().__init__(owner, capacity, password)
        self.backup_data: List[Any] = []  # 백업용 데이터
        print(f"💾 백업 모듈 활성화 (소유자: {self.owner})")

    def save(self, data: Any, password: str = "") -> bool:
        """
        Method Overriding: 부모의 save()를 다시 덮어씀
        보안 검사 → 저장 → 자동 백업
        """
        # 1. 부모의 save() 호출 (보안 검사 + 저장)
        if super().save(data, password):
            # 2. 자동 백업 (성공했을 때만)
            self.backup_data.append(data)
            print(f"   → 자동 백업 완료 (백업 개수: {len(self.backup_data)})")
            return True

        return False

    def restore_from_backup(self) -> bool:
        """백업에서 복구"""
        if not self.backup_data:
            print("❌ 복구 할 백업이 없습니다.")
            return False

        # 기존 데이터 초기화
        self.stored_data.clear()

        # 백업 데이터 복원
        for data in self.backup_data:
            self.stored_data.append(data)

        print(f"✅ 백업에서 복구 완료 ({len(self.backup_data)}개 항목)")
        return True

    def show_backup(self) -> None:
        """백업 데이터 출력"""
        print(f"\n--- [{self.owner}]의 백업 (총 {len(self.backup_data)}개) ---")
        if not self.backup_data:
            print("  (백업이 없음)")
        else:
            for i, data in enumerate(self.backup_data, 1):
                print(f"  {i}. {data}")


# ============================================================================
# [4] 3단계 상속: 클라우드 동기화 추가
# ============================================================================

class CloudBackupSecureGogsStorage(BackupSecureGogsStorage):
    """
    클라우드 동기화 기능이 추가된 저장소 (3단계 상속)

    상속 체계: GogsStorage → SecureGogsStorage → BackupSecureGogsStorage → CloudBackupSecureGogsStorage
    """

    def __init__(self, owner: str, capacity: int = 100, password: str = "gogs", cloud_id: str = ""):
        """생성자: 부모 초기화 + 클라우드 설정"""
        super().__init__(owner, capacity, password)
        self.cloud_id = cloud_id
        self.cloud_data: List[Any] = []  # 클라우드 동기화 데이터
        print(f"☁️  클라우드 모듈 활성화 (ID: {self.cloud_id})")

    def save(self, data: Any, password: str = "") -> bool:
        """
        Method Overriding: 부모의 save()를 다시 덮어씀
        보안 검사 → 저장 → 백업 → 클라우드 동기화
        """
        # 1. 부모의 save() 호출 (보안 + 저장 + 백업)
        if super().save(data, password):
            # 2. 클라우드 동기화
            self.cloud_data.append(data)
            print(f"   → 클라우드 동기화 완료 (동기화 항목: {len(self.cloud_data)})")
            return True

        return False

    def sync_with_cloud(self) -> bool:
        """클라우드와 동기화"""
        self.cloud_data = self.stored_data.copy()
        print(f"☁️  클라우드 동기화 완료 ({len(self.cloud_data)}개 항목)")
        return True

    def show_cloud(self) -> None:
        """클라우드 데이터 출력"""
        print(f"\n--- [{self.owner}]의 클라우드 데이터 (ID: {self.cloud_id}) ---")
        if not self.cloud_data:
            print("  (클라우드에 데이터가 없음)")
        else:
            for i, data in enumerate(self.cloud_data, 1):
                print(f"  {i}. {data}")


# ============================================================================
# [5] Mixin 패턴: 다양한 기능 조합
# ============================================================================

class LoggingMixin:
    """
    Mixin: 로깅 기능을 여러 클래스에 제공
    상속이 아니라 '기능 조합'의 개념
    """

    def __init__(self):
        self.logs: List[str] = []

    def log(self, message: str) -> None:
        """메시지 로깅"""
        log_entry = f"[{datetime.now().strftime('%H:%M:%S')}] {message}"
        self.logs.append(log_entry)


class CacheMixin:
    """캐시 기능을 제공하는 Mixin"""

    def __init__(self):
        self.cache: dict = {}

    def cache_set(self, key: str, value: Any) -> None:
        """캐시에 저장"""
        self.cache[key] = value

    def cache_get(self, key: str) -> Optional[Any]:
        """캐시에서 조회"""
        return self.cache.get(key)


# ============================================================================
# [6] 다중 상속 (주의해서 사용)
# ============================================================================

class AdvancedStorage(GogsStorage, LoggingMixin, CacheMixin):
    """
    다중 상속 예제: 여러 클래스의 기능을 통합
    (주의: 복잡도가 증가하므로 신중하게 사용)
    """

    def __init__(self, owner: str, capacity: int = 100):
        """생성자: 모든 부모 클래스 초기화"""
        GogsStorage.__init__(self, owner, capacity)
        LoggingMixin.__init__(self)
        CacheMixin.__init__(self)
        print(f"🚀 고급 저장소 생성 (로깅 + 캐시 기능 포함)")

    def save(self, data: Any) -> bool:
        """저장 + 로깅 + 캐시"""
        # 1. 저장
        if super().save(data):
            # 2. 로깅
            self.log(f"데이터 저장: {data}")
            # 3. 캐시
            self.cache_set(f"data_{len(self.stored_data)}", data)
            return True
        return False


# ============================================================================
# [7] isinstance() / issubclass() 검증
# ============================================================================

def check_inheritance_relationships():
    """상속 관계 확인"""
    print("\n" + "="*70)
    print("[상속 관계 검증]")
    print("="*70 + "\n")

    storage = GogsStorage("기본", 5)
    secure_storage = SecureGogsStorage("보안", 5, "gogs")
    backup_storage = BackupSecureGogsStorage("백업", 5, "gogs")
    cloud_storage = CloudBackupSecureGogsStorage("클라우드", 5, "gogs", "cloud123")

    # isinstance() 검증
    print("[isinstance() 검증: 객체가 어느 클래스의 인스턴스인가?]")
    print(f"basic은 GogsStorage? {isinstance(storage, GogsStorage)}")
    print(f"secure는 GogsStorage? {isinstance(secure_storage, GogsStorage)}")
    print(f"secure는 SecureGogsStorage? {isinstance(secure_storage, SecureGogsStorage)}")
    print(f"backup은 GogsStorage? {isinstance(backup_storage, GogsStorage)}")
    print(f"backup은 SecureGogsStorage? {isinstance(backup_storage, SecureGogsStorage)}")
    print(f"cloud는 BackupSecureGogsStorage? {isinstance(cloud_storage, BackupSecureGogsStorage)}")

    # issubclass() 검증
    print("\n[issubclass() 검증: 클래스가 다른 클래스의 하위 클래스인가?]")
    print(f"SecureGogsStorage는 GogsStorage의 하위? {issubclass(SecureGogsStorage, GogsStorage)}")
    print(f"BackupSecureGogsStorage는 SecureGogsStorage의 하위? {issubclass(BackupSecureGogsStorage, SecureGogsStorage)}")
    print(f"CloudBackupSecureGogsStorage는 GogsStorage의 하위? {issubclass(CloudBackupSecureGogsStorage, GogsStorage)}")


