def demonstrate_value_objects():
    """Value Object 시연"""
    print("\n" + "="*70)
    print("1️⃣  Value Object 시연")
    print("="*70)

    # Email Value Object
    email1 = Email("alice@gogs.io")
    email2 = Email("alice@gogs.io")
    print(f"✅ Email 생성: {email1}")
    print(f"✅ Email 동등성 (값 비교): {email1 == email2}")

    # 유효하지 않은 이메일 → 즉시 예외
    try:
        invalid_email = Email("invalid-email")
    except ValueError as e:
        print(f"❌ 유효성 검사: {e}")

    # ExperimentScore
    score1 = ExperimentScore(95.5)
    score2 = ExperimentScore(95.5)
    print(f"\n✅ Score 생성: {score1}")
    print(f"✅ Score 동등성: {score1 == score2}")
    print(f"✅ 합격 여부 (70 이상): {score1.is_passing_score()}")

    # 범위 초과 → 즉시 예외
    try:
        invalid_score = ExperimentScore(150.0)
    except ValueError as e:
        print(f"❌ 유효성 검사: {e}")

    print("\n💡 핵심: Value Object는 생성 시 유효성을 보장!")
    print("   - 유효하지 않은 데이터는 생성 단계에서 차단")
    print("   - 나중에 검증할 필요 없음")


def demonstrate_entities():
    """Entity 시연"""
    print("\n" + "="*70)
    print("2️⃣  Entity 시연")
    print("="*70)

    # 연구자 생성
    email = Email("bob@gogs.io")
    researcher = Researcher(1, "Bob", email, "RESEARCHER")
    print(f"✅ Entity 생성: {researcher}")

    # 정체성 비교 (같은 ID = 같은 사람, 속성이 달라도)
    researcher2 = Researcher(1, "Bob (Modified)", email, "ADMIN")
    print(f"\n✅ 정체성 비교:")
    print(f"   researcher == researcher2: {researcher == researcher2}")
    print(f"   이유: 같은 ID (1) → 같은 사람!")
    print(f"   (값이 다르더라도 상관없음)")

    # 속성 수정
    researcher.update("Bob Updated", "ADMIN")
    print(f"\n✅ 속성 수정 가능: {researcher.name}")

    print("\n💡 핵심: Entity는 정체성(ID)으로 식별!")
    print("   - 같은 ID면 다른 시점의 같은 객체")
    print("   - 속성은 변할 수 있음 (가변)")


def demonstrate_aggregate():
    """Aggregate 패턴 시연"""
    print("\n" + "="*70)
    print("3️⃣  Aggregate Root 시연")
    print("="*70)

    # 집계 생성
    researcher = Researcher(1, "Alice", Email("alice@gogs.io"), "ADMIN")
    experiment = ExperimentAggregate(1, researcher, "패턴 연구")

    print(f"✅ Aggregate 생성: {experiment}")
    print(f"   상태: {experiment.status}")

    # 실험 시작
    experiment.start()
    print(f"\n✅ 실험 시작됨")
    print(f"   상태: {experiment.status}")

    # 로그 추가
    log1 = experiment.add_log("첫 시도 완료")
    print(f"\n✅ 로그 추가: {log1.message}")

    log2 = experiment.add_log("분석 진행 중")
    print(f"✅ 로그 추가: {log2.message}")

    # 불변식 검사: 완료된 실험에는 로그 추가 불가
    score = ExperimentScore(92.5)
    experiment.complete(score)
    print(f"\n✅ 실험 완료: 점수 {experiment.score}")

    try:
        experiment.add_log("나중에 추가된 로그")
    except ValueError as e:
        print(f"❌ 불변식 위반 감지: {e}")

    # 도메인 이벤트 확인
    events = experiment.get_events()
    print(f"\n✅ 발생한 도메인 이벤트: {len(events)}개")
    for event in events:
        print(f"   - {event['type']}")

    print("\n💡 핵심: Aggregate가 불변식(business rules)을 보장!")
    print("   - 완료된 실험 → 로그 추가 불가")
    print("   - 점수 범위 검증")
    print("   - 상태 전이 규칙 강제")


def demonstrate_domain_events():
    """Domain Event 시연"""
    print("\n" + "="*70)
    print("4️⃣  Domain Event 시연")
    print("="*70)

    researcher = Researcher(1, "Charlie", Email("charlie@gogs.io"), "RESEARCHER")
    experiment = ExperimentAggregate(2, researcher, "심화 연구")

    # 여러 상태 전이 발생
    experiment.start()
    experiment.add_log("테스트 1 통과")
    experiment.add_log("테스트 2 통과")
    experiment.complete(ExperimentScore(98.0))

    # 이벤트 수집
    events = experiment.get_events()
    print(f"✅ 발생한 이벤트 흐름:")
    for i, event in enumerate(events, 1):
        print(f"   {i}. {event['type']}")

    print("\n💡 핵심: Event를 통해 비즈니스 프로세스 추적!")
    print("   - 감사(audit trail)")
    print("   - 보상 트랜잭션(saga)")
    print("   - 이벤트 기반 통합")


if __name__ == '__main__':
    demonstrate_value_objects()
    demonstrate_entities()
    demonstrate_aggregate()
    demonstrate_domain_events()
    print("\n" + "="*70)
    print("✅ DDD Patterns 시연 완료!")
    print("="*70)
