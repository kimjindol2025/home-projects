def demonstrate_type_as_metaclass():
    """type()은 메타클래스"""
    print("\n【 type()은 메타클래스 】")

    print("""
모든 클래스의 타입은 type입니다:

    class MyClass:
        pass

    type(MyClass)  # → <class 'type'>
    MyClass.__bases__  # → (<class 'object'>,)

즉, 모든 클래스는 type()의 인스턴스입니다!
    """)

    class MyClass:
        pass

    print("실제 실행:")
    print(f"  type(MyClass) = {type(MyClass)}")
    print(f"  type(type) = {type(type)}")  # type은 자기 자신의 인스턴스


def demonstrate_custom_metaclass():
    """커스텀 메타클래스"""
    print("\n【 커스텀 메타클래스 】")

    print("""
클래스 정의 시 규칙을 강제할 수 있습니다:

    class ValidationMeta(type):
        def __new__(mcs, name, bases, attrs):
            if not name.startswith('Gogs'):
                raise TypeError(f"'{name}'은 'Gogs'로 시작해야 합니다")
            print(f"✅ 클래스 '{name}' 생성 허용됨")
            return super().__new__(mcs, name, bases, attrs)

    class GogsBase(metaclass=ValidationMeta):
        pass

    # 이건 성공:
    class GogsRobot(GogsBase):
        pass

    # 이건 실패:
    try:
        class InvalidClass(GogsBase):
            pass
    except TypeError as e:
        print(f"❌ {e}")
    """)

    class ValidationMeta(type):
        def __new__(mcs, name, bases, attrs):
            if name not in ("GogsBase",):
                if not name.startswith("Gogs"):
                    raise TypeError(
                        f"❌ '{name}'은 'Gogs'로 시작해야 합니다"
                    )
            print(f"✅ 클래스 '{name}' 생성 허용됨")
            return super().__new__(mcs, name, bases, attrs)

    class GogsBase(metaclass=ValidationMeta):
        pass

    print("실제 실행:")

    try:
        class GogsRobot(GogsBase):
            pass

        print("  GogsRobot 생성 성공!")
    except TypeError as e:
        print(f"  에러: {e}")


def demonstrate_singleton_meta():
    """싱글톤 메타클래스"""
    print("\n【 싱글톤 메타클래스 】")

    print("""
메타클래스로 싱글톤 패턴을 강제할 수 있습니다:

    class SingletonMeta(type):
        _instances = {}

        def __call__(cls, *args, **kwargs):
            if cls not in cls._instances:
                cls._instances[cls] = super().__call__(*args, **kwargs)
            return cls._instances[cls]

    class DatabaseConnection(metaclass=SingletonMeta):
        def __init__(self):
            self.connected = True

    db1 = DatabaseConnection()
    db2 = DatabaseConnection()

    db1 is db2  # → True (같은 인스턴스!)
    """)

    class SingletonMeta(type):
        _instances = {}

        def __call__(cls, *args, **kwargs):
            if cls not in cls._instances:
                cls._instances[cls] = super().__call__(*args, **kwargs)
            return cls._instances[cls]

    class DatabaseConnection(metaclass=SingletonMeta):
        def __init__(self):
            self.connected = True

    print("실제 실행:")
    db1 = DatabaseConnection()
    db2 = DatabaseConnection()

    print(f"  db1 is db2: {db1 is db2}")
    print(f"  db1 id: {id(db1)}")
    print(f"  db2 id: {id(db2)}")


def demonstrate_method_injection():
    """메서드 주입"""
    print("\n【 메서드 주입 】")

    print("""
메타클래스로 모든 클래스에 공통 메서드를 추가할 수 있습니다:

    class MethodInjectionMeta(type):
        def __new__(mcs, name, bases, attrs):
            def to_dict(self):
                return {k: v for k, v in self.__dict__.items()
                        if not k.startswith('_')}

            attrs['to_dict'] = to_dict
            return super().__new__(mcs, name, bases, attrs)

    class Person(metaclass=MethodInjectionMeta):
        def __init__(self, name, age):
            self.name = name
            self.age = age

    person = Person("Alice", 30)
    print(person.to_dict())  # → {'name': 'Alice', 'age': 30}
    """)

    class MethodInjectionMeta(type):
        def __new__(mcs, name, bases, attrs):
            def to_dict(self):
                return {
                    k: v
                    for k, v in self.__dict__.items()
                    if not k.startswith("_")
                }

            attrs["to_dict"] = to_dict
            return super().__new__(mcs, name, bases, attrs)

    class Person(metaclass=MethodInjectionMeta):
        def __init__(self, name, age):
            self.name = name
            self.age = age

    print("실제 실행:")
    person = Person("Alice", 30)
    print(f"  person.to_dict() = {person.to_dict()}")


def demonstrate_orm_pattern():
    """ORM 패턴"""
    print("\n【 ORM 패턴 】")

    print("""
메타클래스로 Django 스타일 ORM을 구현할 수 있습니다:

    class Field:
        def __init__(self, field_type):
            self.field_type = field_type

    class ORMMeta(type):
        def __new__(mcs, name, bases, attrs):
            fields = {}
            for attr_name, attr_value in list(attrs.items()):
                if isinstance(attr_value, Field):
                    fields[attr_name] = attr_value

            attrs['__fields__'] = fields
            return super().__new__(mcs, name, bases, attrs)

    class User(metaclass=ORMMeta):
        name = Field(str)
        age = Field(int)

    print(User.__fields__)  # → {'name': <Field>, 'age': <Field>}
    """)

    class Field:
        def __init__(self, field_type):
            self.field_type = field_type

    class ORMMeta(type):
        def __new__(mcs, name, bases, attrs):
            fields = {}
            for attr_name, attr_value in list(attrs.items()):
                if isinstance(attr_value, Field):
                    fields[attr_name] = attr_value

            attrs["__fields__"] = fields
            return super().__new__(mcs, name, bases, attrs)

    class User(metaclass=ORMMeta):
        name = Field(str)
        age = Field(int)

    print("실제 실행:")
    print(f"  User.__fields__ = {User.__fields__}")
    print(f"  필드 이름: {list(User.__fields__.keys())}")


