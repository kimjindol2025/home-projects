"""
v1.2 이터레이터 프로토콜

파이썬의 for 루프는 내부적으로 다음을 호출합니다:
1. iter(obj): 이터레이터 객체 획득
2. next(iterator): 다음 값 획득
3. StopIteration: 종료 신호

이 프로토콜이 모든 반복의 기초입니다.
"""

import sys
from typing import Iterator, Iterable, Any


class IteratorProtocol:
    """이터레이터 프로토콜의 기초"""

    @staticmethod
    def explain_protocol():
        """이터레이터 프로토콜 설명"""
        print("\n" + "="*70)
        print("이터레이터 프로토콜 (Iterator Protocol)")
        print("="*70)

        print("\n  [정의]")
        print("    이터레이터: 두 개의 메서드를 구현한 객체")
        print("    1. __iter__(): 자신을 반환")
        print("    2. __next__(): 다음 값을 반환, 끝이면 StopIteration 발생")

        print("\n  [Iterable vs Iterator]")
        print("    Iterable: iter()를 호출할 수 있는 객체 (리스트, 제너레이터, 등)")
        print("    Iterator: next()를 호출할 수 있는 객체 (이터레이터의 인스턴스)")

        print("\n  [for 루프의 내부 동작]")
        print("    for value in iterable:")
        print("    ↓ 다음과 같이 변환됨:")
        print("    iterator = iter(iterable)      # 이터레이터 획득")
        print("    while True:")
        print("        try:")
        print("            value = next(iterator)  # 다음 값")
        print("        except StopIteration:")
        print("            break                   # 종료")

        print("\n" + "="*70)

    @staticmethod
    def demonstrate_basic():
        """기본 이터레이터 사용"""
        print("\n" + "="*70)
        print("기본 이터레이터 사용법")
        print("="*70)

        print("\n  [리스트의 이터레이터]")
        data = [1, 2, 3]
        print(f"    data = {data}")

        print("\n  [iter() 호출 - 이터레이터 획득]")
        iterator = iter(data)
        print(f"    iterator = iter(data)")
        print(f"    type(iterator): {type(iterator)}")

        print("\n  [next() 호출 - 값 하나씩]")
        print(f"    next(iterator) → {next(iterator)}")
        print(f"    next(iterator) → {next(iterator)}")
        print(f"    next(iterator) → {next(iterator)}")

        print("\n  [StopIteration 발생]")
        try:
            next(iterator)
        except StopIteration:
            print(f"    next(iterator) → StopIteration (끝)")

        print("\n" + "="*70)

    @staticmethod
    def demonstrate_generator_iterator():
        """제너레이터는 자동으로 이터레이터"""
        print("\n" + "="*70)
        print("제너레이터는 Iterator")
        print("="*70)

        def simple_gen():
            yield 1
            yield 2
            yield 3

        print("\n  [제너레이터 함수]")
        print("    def simple_gen():")
        print("        yield 1")
        print("        yield 2")
        print("        yield 3")

        print("\n  [제너레이터 객체]")
        gen = simple_gen()
        print(f"    gen = simple_gen()")
        print(f"    type(gen): {type(gen)}")

        print("\n  [이터레이터 메서드 확인]")
        print(f"    hasattr(gen, '__iter__'): {hasattr(gen, '__iter__')}")
        print(f"    hasattr(gen, '__next__'): {hasattr(gen, '__next__')}")

        print("\n  [직접 호출]")
        print(f"    next(gen) → {next(gen)}")
        print(f"    next(gen) → {next(gen)}")
        print(f"    next(gen) → {next(gen)}")

        print("\n  [결론: 제너레이터는 이미 Iterator]")
        print(f"    iter(gen) is gen: {iter(gen) is gen}")

        print("\n" + "="*70)


class CustomIterator:
    """커스텀 이터레이터 구현"""

    class CountUp:
        """
        0부터 n까지 세는 커스텀 이터레이터

        __iter__와 __next__를 구현해야 함
        """

        def __init__(self, max: int):
            self.max = max
            self.current = 0

        def __iter__(self):
            """이터레이터 프로토콜: 자신을 반환"""
            return self

        def __next__(self):
            """이터레이터 프로토콜: 다음 값 반환"""
            if self.current < self.max:
                value = self.current
                self.current += 1
                return value
            else:
                raise StopIteration

    @staticmethod
    def demonstrate_custom():
        """커스텀 이터레이터 사용"""
        print("\n" + "="*70)
        print("커스텀 이터레이터 구현")
        print("="*70)

        print("\n  [클래스 정의]")
        print("    class CountUp:")
        print("        def __init__(self, max):")
        print("            self.max = max")
        print("            self.current = 0")
        print()
        print("        def __iter__(self):")
        print("            return self")
        print()
        print("        def __next__(self):")
        print("            if self.current < self.max:")
        print("                value = self.current")
        print("                self.current += 1")
        print("                return value")
        print("            else:")
        print("                raise StopIteration")

        print("\n  [사용법]")
        counter = CustomIterator.CountUp(3)
        print(f"    counter = CountUp(3)")

        print("\n  [for 루프 사용]")
        print(f"    for value in counter:")
        for value in CustomIterator.CountUp(3):
            print(f"        {value}")

        print("\n  [직접 호출]")
        counter = CustomIterator.CountUp(3)
        print(f"    next(counter) → {next(counter)}")
        print(f"    next(counter) → {next(counter)}")
        print(f"    next(counter) → {next(counter)}")

        print("\n" + "="*70)

    class RangeIterator:
        """
        내장 range() 함수처럼 동작하는 커스텀 이터레이터
        """

        def __init__(self, start: int, stop: int, step: int = 1):
            self.current = start
            self.stop = stop
            self.step = step

        def __iter__(self):
            return self

        def __next__(self):
            if self.step > 0:
                if self.current >= self.stop:
                    raise StopIteration
            else:
                if self.current <= self.stop:
                    raise StopIteration

            value = self.current
            self.current += self.step
            return value

    @staticmethod
    def demonstrate_range_iterator():
        """RangeIterator 시연"""
        print("\n" + "="*70)
        print("예제: RangeIterator")
        print("="*70)

        print("\n  [내장 range()와 비교]")
        print("    내장 range(2, 8, 2): ", list(range(2, 8, 2)))

        print("\n  [커스텀 RangeIterator]")
        custom_range = CustomIterator.RangeIterator(2, 8, 2)
        print(f"    RangeIterator(2, 8, 2): {list(custom_range)}")

        print("\n" + "="*70)


class IterableVsIterator:
    """Iterable과 Iterator의 관계"""

    @staticmethod
    def demonstrate_difference():
        """차이점 명확히 하기"""
        print("\n" + "="*70)
        print("Iterable vs Iterator")
        print("="*70)

        print("\n  [Iterable (반복 가능한 객체)]")
        print("    - 정의: __iter__() 메서드를 가진 객체")
        print("    - 예: list, str, tuple, dict, set, 제너레이터")
        print("    - 특징: for 루프에 사용할 수 있음")

        print("\n  [Iterator (이터레이터)]")
        print("    - 정의: __iter__()와 __next__() 메서드를 가진 객체")
        print("    - 예: 파일 객체, 제너레이터, 커스텀 이터레이터")
        print("    - 특징: next()를 호출할 수 있음")

        print("\n  [관계]")
        print("    모든 Iterator는 Iterable입니다.")
        print("    (Iterator의 __iter__()는 자신을 반환)")
        print()
        print("    하지만 모든 Iterable이 Iterator는 아닙니다.")
        print("    (리스트는 __iter__()만 있고 __next__()는 없음)")

        print("\n  [검증]")
        print("    list: ", hasattr(list([1,2,3]), '__iter__'), "iter있음, next없음")
        print("    iterator: ", hasattr(iter([1,2,3]), '__iter__'), "iter있음",
              hasattr(iter([1,2,3]), '__next__'), "next있음")

        print("\n" + "="*70)

    @staticmethod
    def demonstrate_iteration_multiple():
        """여러 번 반복 가능성"""
        print("\n" + "="*70)
        print("여러 번 반복 가능성")
        print("="*70)

        print("\n  [Iterable: 여러 번 반복 가능]")
        data = [1, 2, 3]
        print(f"    data = {data}")
        print(f"    1차 반복: {[x for x in data]}")
        print(f"    2차 반복: {[x for x in data]}")
        print(f"    (매번 새로운 iterator를 생성)")

        print("\n  [Iterator: 한 번만 반복 가능]")
        iterator = iter(data)
        print(f"    iterator = iter(data)")
        print(f"    1차 반복: ", end="")
        values1 = []
        for x in iterator:
            values1.append(x)
        print(values1)

        print(f"    2차 반복: ", end="")
        values2 = []
        for x in iterator:
            values2.append(x)
        print(values2 if values2 else "[]  (끝났음)")

        print("\n  [결론]")
        print("    - Iterable: 재사용 가능")
        print("    - Iterator: 소비형 (한 번 사용하면 끝)")

        print("\n" + "="*70)


