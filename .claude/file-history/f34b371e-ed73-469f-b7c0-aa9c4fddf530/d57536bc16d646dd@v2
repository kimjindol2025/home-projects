class ImportStrategy:
    """Import 전략 분석 및 비교"""

    @staticmethod
    def absolute_import_example() -> Dict[str, str]:
        """절대 import 예제: 패키지 루트부터 지정"""
        return {
            "import_style": "from src.v2_4_modules_and_packages.module_organization_patterns import DataModule",
            "pros": "명확하고 재사용 가능, IDE 자동완성 좋음",
            "cons": "패키지 이름 변경 시 모든 import 수정 필요",
            "use_case": "프로덕션, 공개 라이브러리",
        }

    @staticmethod
    def relative_import_example() -> Dict[str, str]:
        """상대 import 예제: 현재 위치에서 상대적으로"""
        return {
            "import_style": "from . import module (패키지 내부용)",
            "pros": "패키지 구조 이동 용이, 패키지 자체 재사용 가능",
            "cons": "스크립트 실행 시 에러 가능, IDE 지원 약할 수 있음",
            "use_case": "패키지 내부 모듈 간 import, 플러그인 시스템",
        }

    @staticmethod
    def circular_import_prevention() -> Dict[str, str]:
        """순환 import 방지 전략"""
        return {
            "strategy_1": "모듈 A ← 모듈 B 단방향 의존만 유지",
            "strategy_2": "함수 내부에서 import (지연 import)",
            "strategy_3": "데이터 클래스로 순환 의존성 분리",
            "strategy_4": "패키지 계층 설계 (상위→하위 방향만)",
        }

    @staticmethod
    def lazy_import_example() -> str:
        """지연 import 예제: 필요할 때만 import"""
        code = """
