class ModuleBase:
    """기본 모듈 클래스: 모듈은 일관된 인터페이스를 가져야 한다"""

    def __init__(self, name: str, version: str = "1.0.0"):
        self.name = name
        self.version = version
        self._initialized = False

    def initialize(self):
        """모듈 초기화"""
        self._initialized = True
        print(f"📦 모듈 [{self.name} v{self.version}] 초기화 완료")

    def get_info(self) -> Dict[str, str]:
        """모듈 정보 조회"""
        return {
            "name": self.name,
            "version": self.version,
            "initialized": self._initialized,
        }

    def __repr__(self):
        return f"<Module {self.name} v{self.version}>"


class DataModule(ModuleBase):
    """데이터 처리 모듈"""

    def process_data(self, data: List[int]) -> Dict[str, Any]:
        """데이터 처리"""
        if not self._initialized:
            raise RuntimeError("모듈이 초기화되지 않았습니다")
        return {
            "count": len(data),
            "sum": sum(data),
            "avg": sum(data) / len(data) if data else 0,
            "max": max(data) if data else None,
            "min": min(data) if data else None,
        }


class FileModule(ModuleBase):
    """파일 I/O 모듈"""

    def __init__(self, name: str, base_path: str = "./data"):
        super().__init__(name)
        self.base_path = Path(base_path)

    def file_info(self, filename: str) -> Dict[str, str]:
        """파일 정보 조회"""
        if not self._initialized:
            raise RuntimeError("모듈이 초기화되지 않았습니다")
        file_path = self.base_path / filename
        return {
            "name": filename,
            "exists": file_path.exists(),
            "path": str(file_path),
        }


class AuthModule(ModuleBase):
    """인증 모듈"""

    def __init__(self, name: str):
        super().__init__(name)
        self.users: Dict[str, str] = {}

    def register_user(self, username: str, password: str) -> bool:
        """사용자 등록"""
        if not self._initialized:
            raise RuntimeError("모듈이 초기화되지 않았습니다")
        if username in self.users:
            return False
        self.users[username] = password
        return True

    def verify_user(self, username: str, password: str) -> bool:
        """사용자 검증"""
        if not self._initialized:
            raise RuntimeError("모듈이 초기화되지 않았습니다")
        return self.users.get(username) == password

    def list_users(self) -> List[str]:
        """사용자 목록"""
        return list(self.users.keys())


