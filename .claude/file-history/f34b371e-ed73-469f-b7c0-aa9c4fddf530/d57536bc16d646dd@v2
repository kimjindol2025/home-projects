class NamespaceManager:
    """네임스페이스 격리 관리자"""

    def __init__(self):
        self._private_state = "_private"  # 언더스코어: 내부용
        self.public_state = "public"  # 공개

    def _private_method(self):
        """언더스코어 메서드: 내부용 (관례)"""
        return "이 메서드는 내부용입니다"

    def public_method(self):
        """공개 메서드: 외부에서 사용해도 됨"""
        return "이 메서드는 공개용입니다"

    def __dunder_method(self):
        """더블 언더스코어: 이름 맹글링 (Name Mangling)"""
        return "이 메서드는 매우 내부용입니다"

    def get_public_api(self) -> List[str]:
        """공개 API 목록"""
        # public_state와 public_method만 노출
        public_members = [m for m in dir(self) if not m.startswith("_")]
        return public_members

    def get_all_attributes(self) -> Dict[str, Any]:
        """모든 속성 조회 (디버깅용)"""
        return {
            "public": self.public_state,
            "private_state": self._private_state,
            "private_pattern": self._private_method(),
            "dunder_pattern": self._NamespaceManager__dunder_method(),
        }


