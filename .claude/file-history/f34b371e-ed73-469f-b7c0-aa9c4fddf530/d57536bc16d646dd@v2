    system.register_plugin("calculator", CalculatorPlugin())

    return {
        "plugins_registered": len(system.plugins),
        "plugin_list": system.list_plugins(),
        "hello_result": system.execute_plugin("hello"),
        "calculator_result": system.execute_plugin("calculator"),
    }


