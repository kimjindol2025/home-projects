# [2] 패키지 구조 설계 (단일 계층 vs 다중 계층)
# ============================================================================

class SingleLayerPackage:
    """단일 계층 패키지: 모든 모듈이 한 수준"""

    def __init__(self):
        self.data_module = DataModule("data")
        self.file_module = FileModule("file")
        self.auth_module = AuthModule("auth")

    def initialize_all(self):
        """모든 모듈 초기화"""
        for module in [self.data_module, self.file_module, self.auth_module]:
            module.initialize()

    def get_all_modules(self) -> Dict[str, ModuleBase]:
        """모든 모듈 조회"""
        return {
            "data": self.data_module,
            "file": self.file_module,
            "auth": self.auth_module,
        }


class MultiLayerPackage:
    """다중 계층 패키지: 기능별 서브패키지"""

    class CoreLayer:
        """핵심 계층"""

        def __init__(self):
            self.data = DataModule("core.data")

        def initialize(self):
            self.data.initialize()

    class ServiceLayer:
        """서비스 계층"""

        def __init__(self):
            self.auth = AuthModule("service.auth")
            self.file = FileModule("service.file")

        def initialize(self):
            self.auth.initialize()
            self.file.initialize()

    class APILayer:
        """API 계층 (상위 수준 인터페이스)"""

        def __init__(self, core: "MultiLayerPackage.CoreLayer", service: "MultiLayerPackage.ServiceLayer"):
            self.core = core
            self.service = service

        def get_architecture(self) -> Dict[str, List[str]]:
            """아키텍처 조회"""
            return {
                "core": ["data"],
                "service": ["auth", "file"],
                "api": ["get_architecture"],
            }

    def __init__(self):
        self.core = self.CoreLayer()
        self.service = self.ServiceLayer()
        self.api = self.APILayer(self.core, self.service)

    def initialize_all(self):
        """모든 계층 초기화"""
        self.core.initialize()
        self.service.initialize()


