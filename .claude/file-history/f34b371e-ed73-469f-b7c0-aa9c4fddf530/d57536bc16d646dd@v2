class PluginInterface:
    """플러그인 인터페이스: 모든 플러그인이 따를 계약"""

    def get_plugin_name(self) -> str:
        """플러그인 이름"""
        raise NotImplementedError

    def get_plugin_version(self) -> str:
        """플러그인 버전"""
        raise NotImplementedError

    def execute(self) -> Any:
        """플러그인 실행"""
        raise NotImplementedError


class HelloPlugin(PluginInterface):
    """Hello 플러그인 예제"""

    def get_plugin_name(self) -> str:
        return "Hello Plugin"

    def get_plugin_version(self) -> str:
        return "1.0.0"

    def execute(self) -> str:
        return "Hello from plugin!"


class CalculatorPlugin(PluginInterface):
    """계산기 플러그인 예제"""

    def get_plugin_name(self) -> str:
        return "Calculator Plugin"

    def get_plugin_version(self) -> str:
        return "2.0.0"

    def execute(self) -> Dict[str, int]:
        return {"1+1": 2, "2*3": 6, "10-5": 5}


class PluginSystem:
    """플러그인 시스템: 동적 모듈 로딩 및 관리"""

    def __init__(self):
        self.plugins: Dict[str, PluginInterface] = {}

    def register_plugin(self, name: str, plugin: PluginInterface) -> bool:
        """플러그인 등록"""
        if not isinstance(plugin, PluginInterface):
            return False
        self.plugins[name] = plugin
        return True

    def execute_plugin(self, name: str) -> Optional[Any]:
        """플러그인 실행"""
        if name not in self.plugins:
            return None
        return self.plugins[name].execute()

    def list_plugins(self) -> List[Dict[str, str]]:
        """등록된 플러그인 목록"""
        return [
            {
                "name": plugin.get_plugin_name(),
                "version": plugin.get_plugin_version(),
            }
            for plugin in self.plugins.values()
        ]

    def get_plugin_by_name(self, name: str) -> Optional[PluginInterface]:
        """플러그인 조회"""
        return self.plugins.get(name)

    def unregister_plugin(self, name: str) -> bool:
        """플러그인 제거"""
        if name in self.plugins:
            del self.plugins[name]
            return True
        return False


