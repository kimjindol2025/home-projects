class ProjectArchitecture:
    """실제 프로젝트 아키텍처 설계"""

    # 프로젝트 구조 정의
    STRUCTURE = {
        "gogs_project/": {
            "__init__.py": "패키지 초기화",
            "core/": {
                "__init__.py": "핵심 모듈 인터페이스",
                "engine.py": "핵심 엔진",
                "model.py": "데이터 모델",
                "config.py": "설정 관리",
            },
            "utils/": {
                "__init__.py": "유틸리티 모듈",
                "logger.py": "로깅",
                "validator.py": "검증",
                "formatter.py": "포매터",
            },
            "services/": {
                "__init__.py": "서비스 모듈",
                "database.py": "데이터베이스 서비스",
                "storage.py": "저장소 서비스",
                "cache.py": "캐시 서비스",
            },
            "api/": {
                "__init__.py": "API 모듈",
                "handlers.py": "핸들러",
                "middleware.py": "미들웨어",
                "routes.py": "라우트",
            },
        }
    }

    class Package:
        """패키지 표현"""

        def __init__(self, name: str, modules: List[str]):
            self.name = name
            self.modules = modules
            self.module_count = len(modules)  # 모듈 개수

        def get_info(self) -> Dict[str, Any]:
            return {
                "package": self.name,
                "modules": self.modules,
                "module_count": self.module_count,
            }

    def __init__(self):
        self.packages = {
            "core": self.Package("core", ["engine", "model", "config"]),
            "utils": self.Package("utils", ["logger", "validator", "formatter"]),
            "services": self.Package("services", ["database", "storage", "cache"]),
            "api": self.Package("api", ["handlers", "middleware", "routes"]),
        }

    def get_structure(self) -> Dict[str, Any]:
        """프로젝트 구조 조회"""
        return {
            "project": "gogs_project",
            "packages": {name: pkg.get_info() for name, pkg in self.packages.items()},
            "total_packages": len(self.packages),
            "total_modules": sum(pkg.module_count for pkg in self.packages.values()),
        }

    def get_dependency_graph(self) -> Dict[str, List[str]]:
        """모듈 의존성 그래프 (계층 구조)"""
        return {
            "api": ["services", "utils", "core"],
            "services": ["core", "utils"],
            "utils": ["core"],
            "core": [],
        }

    def validate_imports(self) -> Dict[str, bool]:
        """import 규칙 검증 (상위 계층이 하위 계층 import 가능, 역은 불가)"""
        return {
            "api_imports_services": True,
            "services_imports_core": True,
            "core_imports_api": False,
            "utils_imports_api": False,
        }

    def get_architecture_diagram(self) -> str:
        """아키텍처 다이어그램"""
        diagram = """
┌─────────────────────────────────────┐
│  API Layer (핸들러, 미들웨어)        │
│  ├─ handlers.py                    │
│  ├─ middleware.py                  │
│  └─ routes.py                      │
└──────────┬──────────────────────────┘
           │ imports
┌──────────▼──────────────────────────┐
│  Services Layer (DB, 저장소, 캐시)   │
│  ├─ database.py                    │
│  ├─ storage.py                     │
│  └─ cache.py                       │
└──────────┬──────────────────────────┘
           │ imports
┌──────────▼──────────────────────────┐
│  Core Layer (엔진, 모델, 설정)       │
│  ├─ engine.py                      │
│  ├─ model.py                       │
│  └─ config.py                      │
└──────────┬──────────────────────────┘
           │ uses
┌──────────▼──────────────────────────┐
│  Utils Layer (로깅, 검증, 포매터)    │
│  ├─ logger.py                      │
│  ├─ validator.py                   │
│  └─ formatter.py                   │
└─────────────────────────────────────┘
        """
        return diagram.strip()


