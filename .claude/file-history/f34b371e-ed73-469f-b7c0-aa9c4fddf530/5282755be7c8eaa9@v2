# ============================================================================
# 6. 상수(Constant) - 절대 바뀌지 않는 값
# ============================================================================

def demonstrate_constants():
    """
    한 번 정하면 절대 바뀌지 않는 값은 대문자로 표기합니다.
    """
    # 상수: 절대 변하지 않는 값
    MAX_STUDENTS = 30  # 최대 학생 수
    PI = 3.14159  # 원주율
    GOGS_VERSION = "1.1"  # Gogs 버전
    BIRTH_YEAR = 2000  # 태어난 해

    # 변수: 바뀔 수 있는 값
    current_students = 25  # 현재 학생 수 (계속 늘어날 수 있음)
    student_name = "Alice"  # 이름 (바뀔 수 있음)

    return {
        "MAX_STUDENTS": MAX_STUDENTS,
        "PI": PI,
        "GOGS_VERSION": GOGS_VERSION,
        "current_students": current_students,
    }


# ============================================================================
# 7. 예약어 (Reserved Words) - 사용할 수 없는 이름들
# ============================================================================

def list_reserved_words():
    """
    파이썬이 이미 쓰고 있는 이름들 (사용 불가)
    """
    reserved_words = [
        "if", "else", "elif",  # 조건문
        "for", "while",  # 반복문
        "def", "return",  # 함수
        "class",  # 클래스
        "import", "from",  # 모듈
        "try", "except",  # 예외 처리
        "with",  # 컨텍스트 매니저
        "and", "or", "not",  # 논리 연산
        "True", "False", "None",  # 특수 값
        "lambda",  # 람다 함수
        "yield",  # 제너레이터
        "pass", "break", "continue",  # 제어 흐름
        "assert",  # 검증
        "del",  # 삭제
        "global", "nonlocal",  # 스코프
        "async", "await",  # 비동기
    ]
    return reserved_words


# ============================================================================
# 8. 정리: 이름 짓기 체크리스트
# ============================================================================

def naming_checklist():
    """
    좋은 변수 이름인지 확인하는 체크리스트
    """
    checklist = {
        "의도가 명확한가?": True,  # 이름만 보고도 뭔지 알 수 있나?
        "영어로 작성했나?": True,  # (한글도 가능하지만 국제 협업을 위해 권장)
        "snake_case를 사용했나?": True,  # 여러 단어는 _로 연결
        "숫자로 시작하지 않았나?": True,
        "특수 문자를 사용하지 않았나?": True,  # @, #, !, 등
        "예약어가 아닌가?": True,  # if, class, def 등
        "너무 길지 않은가?": True,  # 또한 너무 짧지도 않나?
        "대소문자를 일관되게 사용했나?": True,
    }
    return checklist


