"""
v1.1 Variable Naming: 변수의 이름 짓기 규칙

"좋은 이름표는 데이터의 정체를 말한다."
"""


# ============================================================================
# 1. 올바른 이름 (Good Names)
# ============================================================================

def demonstrate_good_names():
    """
    변수의 이름은 그 데이터가 무엇인지 알려줘야 합니다.
    """
    # 의도가 명확한 이름들
    student_name = "Alice"  # 학생의 이름
    age = 25  # 나이
    gpa = 3.8  # 학점
    is_graduated = False  # 졸업했는가? (True/False)

    # 한글 변수명도 가능합니다.
    학생_이름 = "Bob"
    나이 = 30

    return student_name, age, gpa, is_graduated


# ============================================================================
# 2. 나쁜 이름 (Bad Names) - 피해야 할 것들
# ============================================================================

def demonstrate_bad_names():
    """
    의도를 알 수 없는 이름들 - 이렇게 하지 마세요!
    """
    # ❌ 너무 짧은 이름 (의도가 불명확)
    # a = 25  # 이게 뭐지? 나이? 나이?
    # x = "John"  # x가 뭐하는 변수죠?

    # ❌ 오류 기호 사용 불가
    # student@name = "Alice"  # 에러!
    # age! = 25  # 에러!

    # ❌ 파이썬이 이미 쓰는 키워드 (예약어)
    # class = "1학년"  # 에러! 'class'는 파이썬 키워드
    # if = 10  # 에러! 'if'는 파이썬 키워드

    # 올바른 예시
    student_age = 25
    full_name = "John"

    return student_age, full_name


# ============================================================================
# 3. 변수명 규칙 (Naming Conventions)
# ============================================================================

def demonstrate_naming_rules():
    """
    파이썬이 지키도록 요구하는 규칙들
    """
    # ✅ 규칙 1: 문자, 숫자, 밑줄(_)로만 구성
    valid_name_1 = "OK"
    valid_name_2 = "OK"
    valid_name_3_with_underscore = "OK"
    name123 = "OK"

    # ✅ 규칙 2: 숫자로 시작하면 안 됨
    # ❌ 123name = "ERROR"  # 에러!

    # ✅ 규칙 3: 밑줄로 시작할 수 있음 (하지만 특별한 의미가 있습니다)
    _private_variable = "Advanced (나중에 배움)"

    # ✅ 규칙 4: 대소문자를 구분합니다 (Case Sensitive)
    Name = "대문자 N"  # 이것과
    name = "소문자 n"  # 이것은 다른 변수입니다!

    return {
        "valid_name_1": valid_name_1,
        "valid_name_2": valid_name_2,
        "name123": name123,
        "Name": Name,
        "name": name,
    }


# ============================================================================
# 4. 파이썬 스타일: snake_case (밑줄 표기법)
# ============================================================================

def demonstrate_python_style():
    """
    파이썬의 관례: 여러 단어를 연결할 때 밑줄(_)을 사용합니다.
    """
    # ✅ 파이썬 스타일 (권장)
    student_name = "Alice"
    student_age = 25
    is_premium_member = True
    total_score_2026 = 95.5

    # ❌ 다른 언어의 스타일 (피하세요!)
    # studentName = "Bob"  # camelCase (Java, JavaScript 스타일)
    # StudentAge = 30  # PascalCase (클래스명으로 사용)

    return student_name, student_age, is_premium_member, total_score_2026


