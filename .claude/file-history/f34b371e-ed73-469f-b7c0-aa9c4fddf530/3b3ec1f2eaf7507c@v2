"""
v2.2 테스트: 클래스와 객체
"""

from src.v2_2_class_and_object import GogsRobot, class_and_object_demo


def test_class_and_object_demo_returns_dict():
    """반환값이 딕셔너리"""
    result = class_and_object_demo()
    assert isinstance(result, dict)


def test_robot_creation():
    """로봇 객체 생성"""
    robot = GogsRobot("테스트", "v1.0")
    assert robot.name == "테스트"
    assert robot.model_id == "v1.0"
    assert robot.data_count == 0


def test_robot_attributes():
    """로봇의 속성 확인"""
    robot = GogsRobot("알파", "v1.0")
    assert hasattr(robot, "name")
    assert hasattr(robot, "model_id")
    assert hasattr(robot, "data_count")


def test_robot_methods():
    """로봇의 메서드 확인"""
    robot = GogsRobot("알파", "v1.0")
    assert hasattr(robot, "collect_data")
    assert hasattr(robot, "report_status")
    assert callable(robot.collect_data)
    assert callable(robot.report_status)


def test_collect_data_increments():
    """데이터 수집 시 카운트 증가"""
    robot = GogsRobot("알파", "v1.0")
    assert robot.data_count == 0

    robot.collect_data()
    assert robot.data_count == 1

    robot.collect_data()
    assert robot.data_count == 2

    robot.collect_data()
    assert robot.data_count == 3


def test_multiple_robots_independence():
    """여러 로봇의 독립성 확인"""
    robot_a = GogsRobot("알파", "v1.0")
    robot_b = GogsRobot("베타", "v2.0")

    # 로봇 A가 데이터를 수집
    robot_a.collect_data()
    robot_a.collect_data()

    # 로봇 B가 데이터를 수집
    robot_b.collect_data()

    # 각 로봇의 데이터는 독립적
    assert robot_a.data_count == 2
    assert robot_b.data_count == 1


def test_robot_names_and_ids():
    """로봇의 이름과 ID 확인"""
    robot_a = GogsRobot("알파", "v1.0")
    robot_b = GogsRobot("베타", "v2.0")

    assert robot_a.name == "알파"
    assert robot_a.model_id == "v1.0"
    assert robot_b.name == "베타"
    assert robot_b.model_id == "v2.0"


def test_multiple_robots_in_demo():
    """데모에서 생성된 여러 로봇"""
    result = class_and_object_demo()

    robot_a = result["robot_a"]
    robot_b = result["robot_b"]

    assert robot_a.name == "알파"
    assert robot_b.name == "베타"
    assert result["robot_a_data"] == 2
    assert result["robot_b_data"] == 1


def test_robot_class_type():
    """로봇이 GogsRobot 클래스의 인스턴스"""
    robot = GogsRobot("테스트", "v1.0")
    assert isinstance(robot, GogsRobot)
    assert type(robot).__name__ == "GogsRobot"


def test_robot_data_accumulation():
    """로봇의 데이터 누적"""
    robot = GogsRobot("알파", "v1.0")

    for i in range(5):
        robot.collect_data()
        assert robot.data_count == i + 1

    assert robot.data_count == 5


def test_different_robots_different_states():
    """서로 다른 로봇은 서로 다른 상태를 유지"""
    robot1 = GogsRobot("로봇1", "v1.0")
    robot2 = GogsRobot("로봇2", "v2.0")
    robot3 = GogsRobot("로봇3", "v3.0")

    robot1.collect_data()
    robot2.collect_data()
    robot2.collect_data()
    robot3.collect_data()
    robot3.collect_data()
    robot3.collect_data()

    assert robot1.data_count == 1
    assert robot2.data_count == 2
    assert robot3.data_count == 3

    # 로봇들은 서로 다른 인스턴스
    assert robot1 is not robot2
    assert robot2 is not robot3
    assert robot1 is not robot3
