def show_commands():
    """주요 명령어 정리"""
    print("\n" + "="*70)
    print("⚡ 실무 명령어 정리")
    print("="*70)

    commands = {
        "생성": [
            ("python -m venv venv", "가상 환경 생성"),
        ],
        "활성화": [
            ("source venv/bin/activate", "Mac/Linux 활성화"),
            ("call venv\\Scripts\\activate", "Windows 활성화"),
        ],
        "설치": [
            ("pip install package_name", "패키지 설치"),
            ("pip install -r requirements.txt", "requirements.txt로 일괄 설치"),
        ],
        "목록": [
            ("pip list", "설치된 패키지 목록"),
            ("pip show package_name", "특정 패키지 정보"),
        ],
        "기록": [
            ("pip freeze > requirements.txt", "현재 환경 저장"),
        ],
        "제거": [
            ("pip uninstall package_name", "패키지 제거"),
        ],
        "종료": [
            ("deactivate", "가상 환경 나가기"),
        ],
    }

    for category, cmds in commands.items():
        print(f"\n[{category}]")
        for cmd, desc in cmds:
            print(f"  {cmd:<50} # {desc}")


def virtual_environment_demo():
    """전체 데모"""
    print("\n" + "="*70)
    print("📊 현재 파이썬 환경 정보")
    print("="*70)

    print(f"\n파이썬 경로: {sys.executable}")
    print(f"파이썬 버전: {sys.version.split()[0]}")
    print(f"현재 경로: {os.getcwd()}")

    if hasattr(sys, 'real_prefix') or (
        hasattr(sys, 'base_prefix') and sys.base_prefix != sys.prefix
    ):
        print(f"\n✅ 가상 환경 활성화 상태!")
        print(f"   가상 환경 경로: {sys.prefix}")
    else:
        print(f"\n⚠️  기본 파이썬 환경 (가상 환경 미활성화)")
        print(f"   전역 파이썬 경로: {sys.prefix}")

    return {
        "python_path": sys.executable,
        "python_version": sys.version.split()[0],
        "current_directory": os.getcwd(),
        "is_venv_active": hasattr(sys, 'real_prefix') or (
            hasattr(sys, 'base_prefix') and sys.base_prefix != sys.prefix
        ),
    }


