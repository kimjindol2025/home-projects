class DependencyResolver:
    """의존성 해석 및 충돌 해결"""

    # 패키지 간 의존성 정의
    DEPENDENCIES = {
        "pandas": ["numpy"],
        "scikit-learn": ["numpy", "scipy"],
        "django": ["requests"],
        "flask": ["requests"],
        "matplotlib": ["numpy"],
    }

    # 버전 호환성
    VERSION_COMPATIBILITY = {
        ("numpy", "pandas"): {"1.19": ["1.0.0"], "1.20": ["1.1.0", "1.2.0"]},
        ("numpy", "scipy"): {"1.19": ["1.5.0"], "1.24": ["1.9.0"]},
    }

    @staticmethod
    def get_dependencies(package_name: str) -> List[str]:
        """패키지의 의존성 조회"""
        return DependencyResolver.DEPENDENCIES.get(package_name, [])

    @staticmethod
    def check_compatibility(
        package_name: str, version: str, installed: Dict[str, str]
    ) -> Tuple[bool, List[str]]:
        """호환성 검사"""
        deps = DependencyResolver.get_dependencies(package_name)
        missing = []
        compatible = []

        for dep in deps:
            if dep not in installed:
                missing.append(f"❌ {dep}이 설치되지 않았습니다")
            else:
                compatible.append(f"✅ {dep} ({installed[dep]}) 호환 가능")

        return len(missing) == 0, missing + compatible

    @staticmethod
    def resolve_conflicts(installed: Dict[str, str]) -> Tuple[bool, List[str]]:
        """버전 충돌 해결"""
        conflicts = []
        resolved = []

        for (pkg1, pkg2), compat in DependencyResolver.VERSION_COMPATIBILITY.items():
            if pkg1 in installed and pkg2 in installed:
                v1 = installed[pkg1]
                v2 = installed[pkg2]

                if v1 in compat and v2 in compat[v1]:
                    resolved.append(f"✅ {pkg1}({v1}) - {pkg2}({v2}) 호환")
                else:
                    conflicts.append(
                        f"⚠️  {pkg1}({v1}) - {pkg2}({v2}) 호환 불일치"
                    )

        return len(conflicts) == 0, resolved + conflicts


