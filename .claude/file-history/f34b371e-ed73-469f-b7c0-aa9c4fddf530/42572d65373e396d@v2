class ProjectEnvironment:
    """프로젝트 전체 환경 관리"""

    def __init__(self, project_name: str):
        self.project_name = project_name
        self.venv = VirtualEnvironment(f".venv")
        self.package_manager = PackageManager()
        self.requirements = RequirementsHandler()
        self.env_requirements = EnvironmentRequirements()
        self.created_at = datetime.now().isoformat()

    def setup_development(self) -> Dict[str, Any]:
        """개발 환경 설정"""
        # 가상 환경 생성
        self.venv.create()
        self.venv.activate()

        # 개발용 패키지 설치
        env_reqs = self.env_requirements.get_requirements(EnvironmentType.DEVELOPMENT)
        results = []

        for pkg in env_reqs:
            success, msg = self.package_manager.install(pkg.name, pkg.version)
            results.append(msg)

        # requirements.txt 생성
        self.requirements.requirements = env_reqs

        return {
            "project": self.project_name,
            "environment": "development",
            "venv_path": self.venv.path,
            "packages_installed": len(self.package_manager.installed_packages),
            "setup_results": results,
        }

    def setup_production(self) -> Dict[str, Any]:
        """운영 환경 설정"""
        self.venv.create()
        self.venv.activate()

        env_reqs = self.env_requirements.get_requirements(EnvironmentType.PRODUCTION)
        results = []

        for pkg in env_reqs:
            success, msg = self.package_manager.install(pkg.name, pkg.version)
            results.append(msg)

        self.requirements.requirements = env_reqs

        return {
            "project": self.project_name,
            "environment": "production",
            "venv_path": self.venv.path,
            "packages_installed": len(self.package_manager.installed_packages),
            "setup_results": results,
        }

    def generate_requirements_file(self) -> str:
        """requirements.txt 파일 생성"""
        self.requirements.requirements = list(
            self.package_manager.installed_packages.values()
        )
        return self.requirements.generate_content()

    def restore_from_requirements(self, content: str) -> List[str]:
        """requirements.txt에서 복원"""
        self.requirements.load_from_content(content)
        results = []

        for pkg in self.requirements.requirements:
            success, msg = self.package_manager.install(pkg.name, pkg.version)
            results.append(msg)

        return results

    def get_project_info(self) -> Dict[str, Any]:
        """프로젝트 정보"""
        return {
            "project_name": self.project_name,
            "created_at": self.created_at,
            "venv": self.venv.get_info(),
            "packages": self.package_manager.list_installed(),
            "package_count": len(self.package_manager.installed_packages),
            "total_size_mb": self.package_manager.get_total_size(),
        }


