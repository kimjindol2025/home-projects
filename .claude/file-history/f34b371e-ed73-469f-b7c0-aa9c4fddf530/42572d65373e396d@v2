class PackageManager:
    """pip 패키지 관리자 (시뮬레이션)"""

    # PyPI에서 실제로 있는 인기 패키지들
    POPULAR_PACKAGES = {
        "numpy": ["1.19.0", "1.20.0", "1.21.0", "1.24.0"],
        "pandas": ["1.0.0", "1.1.0", "1.2.0", "1.5.0"],
        "requests": ["2.24.0", "2.25.0", "2.26.0", "2.28.0"],
        "flask": ["1.1.0", "2.0.0", "2.1.0", "2.3.0"],
        "django": ["2.2.0", "3.0.0", "3.1.0", "4.0.0"],
        "scipy": ["1.5.0", "1.6.0", "1.7.0", "1.9.0"],
        "matplotlib": ["3.3.0", "3.4.0", "3.5.0", "3.7.0"],
        "scikit-learn": ["0.23.0", "0.24.0", "1.0.0", "1.2.0"],
        "pillow": ["7.2.0", "8.0.0", "9.0.0", "9.4.0"],
        "beautifulsoup4": ["4.9.0", "4.10.0", "4.11.0"],
    }

    def __init__(self):
        self.installed_packages: Dict[str, Package] = {}

    def install(self, package_name: str, version: Optional[str] = None) -> Tuple[bool, str]:
        """패키지 설치"""
        if package_name not in self.POPULAR_PACKAGES:
            return False, f"❌ 패키지 '{package_name}' not found in PyPI"

        # 버전이 지정되지 않으면 최신 버전
        if version is None:
            version = self.POPULAR_PACKAGES[package_name][-1]

        # 버전이 유효한지 확인
        if version not in self.POPULAR_PACKAGES[package_name]:
            return False, f"❌ 버전 '{version}' not available for '{package_name}'"

        # 이미 설치되어 있으면 업그레이드
        if package_name in self.installed_packages:
            old_version = self.installed_packages[package_name].version
            self.installed_packages[package_name] = Package(
                name=package_name,
                version=version,
                size_mb=1.0 + len(package_name) * 0.1,
            )
            msg = f"✅ {package_name}: {old_version} → {version}"
            return True, msg

        # 새로 설치
        package = Package(
            name=package_name,
            version=version,
            size_mb=1.0 + len(package_name) * 0.1,
        )
        self.installed_packages[package_name] = package
        return True, f"✅ {package_name}=={version} 설치 완료"

    def uninstall(self, package_name: str) -> Tuple[bool, str]:
        """패키지 제거"""
        if package_name not in self.installed_packages:
            return False, f"❌ '{package_name}' not installed"

        del self.installed_packages[package_name]
        return True, f"✅ {package_name} 제거 완료"

    def list_installed(self) -> Dict[str, str]:
        """설치된 패키지 목록"""
        return {pkg.name: pkg.version for pkg in self.installed_packages.values()}

    def show_package(self, package_name: str) -> Optional[Dict[str, Any]]:
        """패키지 상세 정보"""
        if package_name not in self.installed_packages:
            return None

        pkg = self.installed_packages[package_name]
        return {
            "name": pkg.name,
            "version": pkg.version,
            "size_mb": pkg.size_mb,
            "installed": True,
        }

    def get_total_size(self) -> float:
        """전체 패키지 용량"""
        return sum(pkg.size_mb for pkg in self.installed_packages.values())

    def get_packages_for_requirements(self) -> List[str]:
        """requirements.txt용 패키지 목록"""
        return sorted([
            f"{pkg.name}=={pkg.version}"
            for pkg in self.installed_packages.values()
        ])


