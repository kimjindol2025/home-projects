# ============================================================================

class RequirementsHandler:
    """requirements.txt 파일 처리"""

    def __init__(self):
        self.requirements: List[Package] = []

    def parse_line(self, line: str) -> Optional[Package]:
        """requirement 라인 파싱"""
        line = line.strip()

        # 주석 및 빈 줄 무시
        if not line or line.startswith("#"):
            return None

        # 형식: package_name==version 또는 package_name>=version
        if "==" in line:
            parts = line.split("==")
            if len(parts) == 2:
                return Package(name=parts[0].strip(), version=parts[1].strip())
        elif ">=" in line:
            parts = line.split(">=")
            if len(parts) == 2:
                return Package(name=parts[0].strip(), version=parts[1].strip() + "+")

        return None

    def load_from_content(self, content: str) -> List[Package]:
        """content에서 requirements 파싱"""
        self.requirements = []
        for line in content.split("\n"):
            pkg = self.parse_line(line)
            if pkg:
                self.requirements.append(pkg)
        return self.requirements

    def generate_content(self) -> str:
        """requirements.txt 내용 생성"""
        lines = [pkg.to_requirement_line() for pkg in self.requirements]
        return "\n".join(lines)

    def add_package(self, package: Package) -> None:
        """패키지 추가"""
        # 기존 패키지가 있으면 제거
        self.requirements = [p for p in self.requirements if p.name != package.name]
        self.requirements.append(package)

    def remove_package(self, package_name: str) -> bool:
        """패키지 제거"""
        original_count = len(self.requirements)
        self.requirements = [p for p in self.requirements if p.name != package_name]
        return len(self.requirements) < original_count

    def get_packages(self) -> List[Package]:
        """패키지 목록"""
        return sorted(self.requirements, key=lambda p: p.name)

    def find_package(self, package_name: str) -> Optional[Package]:
        """패키지 찾기"""
        for pkg in self.requirements:
            if pkg.name == package_name:
                return pkg
        return None


