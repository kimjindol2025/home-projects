        results.append(msg)

    return {
        "type": "package_management",
        "install_results": results,
        "installed": pm.list_installed(),
        "total_size_mb": pm.get_total_size(),
    }


def demonstrate_requirements_handling() -> Dict[str, Any]:
    """requirements.txt 처리"""
    handler = RequirementsHandler()

    content = """numpy==1.24.0
pandas==1.5.0
requests==2.28.0
flask==2.3.0
"""

    packages = handler.load_from_content(content)
    generated = handler.generate_content()

    return {
        "type": "requirements_handling",
        "parsed_packages": len(packages),
        "packages": [p.to_requirement_line() for p in packages],
        "generated_content": generated,
    }


def demonstrate_dependency_resolution() -> Dict[str, Any]:
    """의존성 해석"""
    installed = {"numpy": "1.24.0", "scipy": "1.9.0"}

    # scikit-learn 설치 시도
    compatible, messages = DependencyResolver.check_compatibility(
        "scikit-learn", "1.2.0", installed
    )

    # 버전 충돌 확인
    conflict_check, conflict_msgs = DependencyResolver.resolve_conflicts(installed)

    return {
        "type": "dependency_resolution",
        "installed": installed,
        "package_to_install": "scikit-learn",
        "compatible": compatible,
        "compatibility_check": messages,
        "conflict_free": conflict_check,
        "conflicts": conflict_msgs,
    }


