@dataclass
class Package:
    """패키지 정보"""

    name: str
    version: str
    size_mb: float = 0.0
    description: str = ""

    def __str__(self):
        return f"{self.name}=={self.version}"

    def to_requirement_line(self) -> str:
        """requirement 파일의 한 줄로"""
        return f"{self.name}=={self.version}"


@dataclass
class VirtualEnvironmentInfo:
    """가상 환경 정보"""

    path: str
    python_version: str = "3.10"
    created_at: str = ""
    is_active: bool = False
    packages: List[Package] = None

    def __post_init__(self):
        if self.packages is None:
            self.packages = []
        if not self.created_at:
            self.created_at = datetime.now().isoformat()

    def get_info(self) -> Dict[str, Any]:
        """환경 정보 조회"""
        return {
            "path": self.path,
            "python_version": self.python_version,
            "created_at": self.created_at,
            "is_active": self.is_active,
            "package_count": len(self.packages),
            "packages": [p.to_requirement_line() for p in self.packages],
        }


class VirtualEnvironment:
    """가상 환경 관리자"""

    def __init__(self, path: str = ".venv"):
        self.path = path
        self.info = VirtualEnvironmentInfo(path=path)
        self.is_created = False

    def create(self) -> bool:
        """가상 환경 생성"""
        if self.is_created:
            return False

        self.is_created = True
        self.info.created_at = datetime.now().isoformat()
        print(f"✅ 가상 환경 생성: {self.path}")
        print(f"   파이썬: {self.info.python_version}")
        return True

    def activate(self) -> bool:
        """가상 환경 활성화"""
        if not self.is_created:
            return False

        self.info.is_active = True
        print(f"✅ 가상 환경 활성화: {self.path}")
        return True

    def deactivate(self) -> bool:
        """가상 환경 비활성화"""
        if not self.is_created:
            return False

        self.info.is_active = False
        print(f"✅ 가상 환경 비활성화")
        return True

    def get_status(self) -> Dict[str, Any]:
        """가상 환경 상태"""
        return {
            "created": self.is_created,
            "active": self.info.is_active,
            "path": self.path,
            "python_version": self.info.python_version,
        }

    def get_info(self) -> Dict[str, Any]:
        """상세 정보"""
        return self.info.get_info()


