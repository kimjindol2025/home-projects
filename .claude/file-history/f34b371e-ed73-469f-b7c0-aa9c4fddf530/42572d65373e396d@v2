class EnvironmentValidator:
    """가상 환경 검증"""

    @staticmethod
    def validate_venv_structure(venv_path: str) -> Dict[str, bool]:
        """venv 구조 검증"""
        return {
            "bin_or_scripts": True,  # bin/ (Linux/Mac) 또는 Scripts/ (Windows)
            "pyvenv_cfg": True,  # pyvenv.cfg 파일
            "site_packages": True,  # site-packages 디렉토리
        }

    @staticmethod
    def check_python_version(required: str, actual: str) -> bool:
        """파이썬 버전 호환성 검사"""
        required_parts = required.split(".")
        actual_parts = actual.split(".")

        # Major.Minor 비교
        return (
            required_parts[0] == actual_parts[0]
            and required_parts[1] == actual_parts[1]
        )

    @staticmethod
    def validate_requirements(
        requirements: List[Package], installed: Dict[str, str]
    ) -> Tuple[bool, List[str]]:
        """requirements 파일 검증"""
        issues = []
        validated = []

        for req in requirements:
            if req.name not in installed:
                issues.append(f"❌ {req.name}이 설치되지 않았습니다")
            elif installed[req.name] != req.version:
                issues.append(
                    f"⚠️  {req.name}: {req.version} 필요, {installed[req.name]} 설치됨"
                )
            else:
                validated.append(f"✅ {req.name}=={req.version}")

        return len(issues) == 0, validated + issues

    @staticmethod
    def get_health_check(venv: VirtualEnvironment, pm: PackageManager) -> Dict[str, Any]:
        """환경 상태 체크"""
        return {
            "venv_created": venv.is_created,
            "venv_active": venv.info.is_active,
            "package_count": len(pm.installed_packages),
            "total_size_mb": pm.get_total_size(),
            "python_version": venv.info.python_version,
            "status": "✅ Healthy" if venv.is_created else "❌ Not created",
        }


