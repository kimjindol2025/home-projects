class EnvironmentType:
    """환경 타입 정의"""

    DEVELOPMENT = "development"
    PRODUCTION = "production"
    TESTING = "testing"


class EnvironmentRequirements:
    """환경별 requirements 관리"""

    def __init__(self):
        self.dev_packages: List[Package] = [
            Package("pytest", "7.0.0", description="테스트 프레임워크"),
            Package("black", "22.0.0", description="코드 포매터"),
            Package("pylint", "2.10.0", description="코드 분석"),
        ]
        self.prod_packages: List[Package] = [
            Package("gunicorn", "20.1.0", description="WSGI 서버"),
            Package("psycopg2-binary", "2.9.0", description="PostgreSQL 드라이버"),
        ]
        self.common_packages: List[Package] = [
            Package("numpy", "1.24.0"),
            Package("pandas", "1.5.0"),
            Package("requests", "2.28.0"),
        ]

    def get_requirements(self, env_type: str) -> List[Package]:
        """환경별 requirement 조회"""
        if env_type == EnvironmentType.DEVELOPMENT:
            return self.common_packages + self.dev_packages
        elif env_type == EnvironmentType.PRODUCTION:
            return self.common_packages + self.prod_packages
        elif env_type == EnvironmentType.TESTING:
            return self.common_packages + [
                Package("pytest", "7.0.0"),
                Package("pytest-cov", "3.0.0"),
            ]
        return self.common_packages

    def generate_requirements_txt(self, env_type: str) -> str:
        """requirements 파일 생성"""
        pkgs = self.get_requirements(env_type)
        lines = [f"# {env_type.upper()} requirements"]
        lines.extend([pkg.to_requirement_line() for pkg in pkgs])
        return "\n".join(lines)


