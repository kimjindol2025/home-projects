    # 【 Auth Handlers 】
    def handle_auth_login(self, params: Dict, body: str, token: str = None) -> Tuple[HTTPStatusCode, str]:
        """로그인"""
        try:
            data = self.parse_json_body(body)
            email = data.get('email')
            password = data.get('password')

            if not email or not password:
                return HTTPStatusCode.BAD_REQUEST, self.json_response(
                    HTTPStatusCode.BAD_REQUEST, message='email과 password는 필수'
                )

            token = self.auth.authenticate(email, password)
            if not token:
                return HTTPStatusCode.UNAUTHORIZED, self.json_response(
                    HTTPStatusCode.UNAUTHORIZED, message='이메일 또는 비밀번호가 잘못되었습니다'
                )

            return HTTPStatusCode.OK, self.json_response(HTTPStatusCode.OK, {'token': token})
        except Exception as e:
            return HTTPStatusCode.INTERNAL_SERVER_ERROR, self.json_response(
                HTTPStatusCode.INTERNAL_SERVER_ERROR, message=str(e)
            )

    def handle_auth_logout(self, params: Dict, token: str = None) -> Tuple[HTTPStatusCode, str]:
        """로그아웃"""
        try:
            if not token:
                return HTTPStatusCode.UNAUTHORIZED, self.json_response(
                    HTTPStatusCode.UNAUTHORIZED, message='토큰이 필요합니다'
                )

            self.auth.logout(token)
            return HTTPStatusCode.OK, self.json_response(HTTPStatusCode.OK, message='로그아웃되었습니다')
        except Exception as e:
            return HTTPStatusCode.INTERNAL_SERVER_ERROR, self.json_response(
                HTTPStatusCode.INTERNAL_SERVER_ERROR, message=str(e)
            )

    # 【 Health Check 】
    def handle_health(self, params: Dict, token: str = None) -> Tuple[HTTPStatusCode, str]:
        """헬스 체크"""
        try:
            db_info = self.db.get_database_info()
            return HTTPStatusCode.OK, self.json_response(
                HTTPStatusCode.OK,
                {'status': 'running', 'database': db_info}
            )
        except Exception as e:
            return HTTPStatusCode.INTERNAL_SERVER_ERROR, self.json_response(
                HTTPStatusCode.INTERNAL_SERVER_ERROR, message=str(e)
            )

    def handle_request(self, method: str, path: str, headers: Dict = None,
                      body: str = '') -> Tuple[HTTPStatusCode, str]:
        """HTTP 요청 처리"""
        route_name, params = self.match_route(method, path)

        if not route_name:
            return HTTPStatusCode.NOT_FOUND, self.json_response(
                HTTPStatusCode.NOT_FOUND, message='엔드포인트를 찾을 수 없습니다'
            )

        # 토큰 추출
        auth_header = (headers or {}).get('Authorization', '')
        from .auth import AuthMiddleware
        middleware = AuthMiddleware(self.auth)
        token = middleware.extract_token_from_header(auth_header) if auth_header else None

        # 라우트별 핸들러 호출
        handler_map = {
            'researchers_list': self.handle_researchers_list,
            'researchers_create': self.handle_researchers_create,
            'researchers_get': self.handle_researchers_get,
            'researchers_update': self.handle_researchers_update,
            'researchers_delete': self.handle_researchers_delete,
            'experiments_list': self.handle_experiments_list,
            'experiments_create': self.handle_experiments_create,
            'experiments_get': self.handle_experiments_get,
            'experiments_update': self.handle_experiments_update,
            'experiments_delete': self.handle_experiments_delete,
            'stats': self.handle_statistics,
            'top_experiments': self.handle_top_experiments,
            'auth_login': self.handle_auth_login,
            'auth_logout': self.handle_auth_logout,
            'health': self.handle_health,
        }

        handler = handler_map.get(route_name)
        if not handler:
            return HTTPStatusCode.INTERNAL_SERVER_ERROR, self.json_response(
                HTTPStatusCode.INTERNAL_SERVER_ERROR, message='핸들러를 찾을 수 없습니다'
            )

        # 메서드 시그니처에 따라 호출
        try:
            # body를 받는 핸들러인지 확인
            import inspect
            sig = inspect.signature(handler)
            if 'body' in sig.parameters:
                return handler(params, body, token)
            else:
                return handler(params, token)
        except (TypeError, Exception):
            try:
                return handler(params, body, token)
            except:
                return handler(params, token)
