"""
v1.4 Duck Typing: 파이썬의 철학

"오리처럼 걷고 오리처럼 우는 것은 오리다"

타입을 명시적으로 선언하지 않아도,
필요한 메소드를 구현하면 그 역할을 할 수 있다.
"""

from typing import Any


class Dog:
    """강아지"""

    def sound(self) -> str:
        return "Woof!"

    def move(self) -> str:
        return "Running on four legs"


class Cat:
    """고양이"""

    def sound(self) -> str:
        return "Meow!"

    def move(self) -> str:
        return "Stalking silently"


class Robot:
    """로봇 (개도 고양이도 아니지만, 같은 인터페이스)"""

    def sound(self) -> str:
        return "Beep boop!"

    def move(self) -> str:
        return "Rolling on wheels"


def make_sound(animal: Any) -> None:
    """
    동물이라고 명시하지 않았지만,
    sound() 메소드가 있으면 작동
    """
    print(f"  {animal.sound()}")


def make_move(animal: Any) -> None:
    """
    move() 메소드가 있으면 작동
    """
    print(f"  {animal.move()}")


class Drawable:
    """그리기 가능한 것"""

    def draw(self) -> str:
        return "Base drawing"


class Circle(Drawable):
    def draw(self) -> str:
        return "Drawing a circle: ○"


class Square(Drawable):
    def draw(self) -> str:
        return "Drawing a square: □"


class Triangle(Drawable):
    def draw(self) -> str:
        return "Drawing a triangle: △"


class WeirdShape:
    """Drawable을 상속하지 않았지만, draw() 메소드가 있음"""

    def draw(self) -> str:
        return "Drawing something weird: ◇"


def draw_all(drawables: list) -> None:
    """
    Drawable 타입을 명시하지 않고,
    draw() 메소드가 있으면 모두 그림
    """
    for obj in drawables:
        print(f"  {obj.draw()}")


class Iterable:
    """반복 가능"""

    def __init__(self, max_value: int):
        self.max_value = max_value
        self.current = 0

    def __iter__(self):
        self.current = 0
        return self

    def __next__(self) -> int:
        if self.current < self.max_value:
            self.current += 1
            return self.current
        raise StopIteration


def demonstrate_duck_typing():
    """덕 타이핑 시연"""
    print("\n" + "="*70)
    print("덕 타이핑: 파이썬의 철학")
    print("="*70)

    print("\n  [음성 발생]")
    print("    Dog 객체:")
    make_sound(Dog())

    print("    Cat 객체:")
    make_sound(Cat())

    print("    Robot 객체 (Robot은 동물이 아님!):")
    make_sound(Robot())

    print("\n  [움직임]")
    print("    Dog:")
    make_move(Dog())
    print("    Robot:")
    make_move(Robot())

    print("\n  [그리기]")
    print("    다양한 도형들:")
    shapes = [
        Circle(),
        Square(),
        Triangle(),
        WeirdShape()  # Drawable 상속 안 함!
    ]
    draw_all(shapes)

    print("\n  [반복]")
    print("    Iterable 객체로 반복:")
    it = Iterable(3)
    for val in it:
        print(f"      {val}")

    print("\n" + "="*70)


def demonstrate_protocol():
    """프로토콜 실증"""
    print("\n" + "="*70)
    print("파이썬 프로토콜: 인터페이스의 자유")
    print("="*70)

    print("\n  [매직 메소드 체크리스트]")

    class Realistic:
        def __init__(self, name):
            self.name = name

        def __repr__(self):
            return f"Realistic({self.name})"

        def __str__(self):
            return self.name

        def __len__(self):
            return len(self.name)

        def __getitem__(self, idx):
            return self.name[idx]

        def __contains__(self, char):
            return char in self.name

        def __eq__(self, other):
            if isinstance(other, Realistic):
                return self.name == other.name
            return False

        def __lt__(self, other):
            if isinstance(other, Realistic):
                return self.name < other.name
            return False

    r = Realistic("Gogs")

    print(f"    repr(): {repr(r)}")
    print(f"    str(): {str(r)}")
    print(f"    len(): {len(r)}")
    print(f"    []: {r[0]}, {r[1]}")
    print(f"    in: {'o' in r}")
    print(f"    ==: {r == Realistic('Gogs')}")
    print(f"    <: {r < Realistic('Python')}")

    print("\n" + "="*70)


# ============================================================================
# 메인 실행 함수
# ============================================================================

def main():
    """덕 타이핑을 시연합니다"""
    print("\n" + "="*70)
    print("🐍 Python v1.4: 덕 타이핑 - 파이썬의 철학")
    print("="*70)

    demonstrate_duck_typing()
    demonstrate_protocol()

    print("\n" + "="*70)
    print("저장 필수. 너는 기록이 증명이다. Gogs.")
    print("="*70 + "\n")


if __name__ == "__main__":
    main()
