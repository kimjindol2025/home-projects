## 5. 복잡한 데이터 검증

다양한 데이터를 검증하면서 부분 실패를 처리하는 예:

### 온도/기압 데이터 검증

```python
class ResearchDataValidator:
    """연구 데이터 검증"""

    def validate_temperature(self, temp):
        """온도 데이터 검증"""
        try:
            temp_value = float(temp)

            if temp_value < -273.15:  # 절대영도
                raise DataValidationError("절대영도보다 낮을 수 없습니다")

            return True

        except ValueError:
            logging.error(f"온도는 숫자여야 합니다: {temp}")
            return False

    def validate_pressure(self, pressure):
        """기압 데이터 검증"""
        try:
            pressure_value = float(pressure)

            if pressure_value < 0:
                raise DataValidationError("기압은 음수일 수 없습니다")

            return True

        except ValueError:
            logging.error(f"기압은 숫자여야 합니다: {pressure}")
            return False

    def process_batch(self, data_list):
        """배치 처리: 일부 실패해도 계속 진행"""
        results = {"valid": [], "invalid": []}

        for data in data_list:
            try:
                temp_ok = self.validate_temperature(data['temp'])
                pressure_ok = self.validate_pressure(data['pressure'])

                if temp_ok and pressure_ok:
                    results["valid"].append(data)
                else:
                    results["invalid"].append(data)

            except Exception as e:
                logging.error(f"처리 실패: {e}")
                results["invalid"].append(data)

            finally:
                # 각 데이터마다 정리
                pass

        return results
```

### 사용 예

```python
validator = ResearchDataValidator()

experiments = [
    {"temp": 298.15, "pressure": 101325},   # OK
    {"temp": "25C", "pressure": 101325},    # 온도 형식 에러
    {"temp": -300, "pressure": 101325},     # 절대영도 위반
    {"temp": 373.15, "pressure": -1},       # 기압 음수
]

results = validator.process_batch(experiments)

print(f"성공: {len(results['valid'])}개")
print(f"실패: {len(results['invalid'])}개")
```

