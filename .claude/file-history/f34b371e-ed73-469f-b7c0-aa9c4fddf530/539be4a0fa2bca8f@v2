def demonstrate_message_broker():
    """메시지 브로커 시연"""
    print("\n【 메시지 브로커 사용 예제 】")

    print("""
import queue
import threading

# 중앙 메시지 브로커
broker = queue.Queue()

# Producer: 주문 서비스
def order_service():
    for i in range(3):
        msg = f"Order-{i+1}"
        broker.put(msg)
        print(f"📬 주문 생성: {msg}")

# Consumer: 결제 서비스
def payment_service():
    for _ in range(3):
        msg = broker.get()
        print(f"💳 결제 처리: {msg}")

# 병렬 실행
p1 = threading.Thread(target=order_service)
p2 = threading.Thread(target=payment_service)

p1.start()
p2.start()
p1.join()
p2.join()

출력:
  📬 주문 생성: Order-1
  💳 결제 처리: Order-1
  📬 주문 생성: Order-2
  💳 결제 처리: Order-2
  ...
    """)


