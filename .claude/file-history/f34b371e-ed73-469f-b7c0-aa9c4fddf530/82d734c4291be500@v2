"""
v1.6 My First Function - 나만의 마법 주문 (함수)

함수: 파이썬 초등학교 1학년
"""


# 1. 인사하는 함수 만들기
def say_hello(name):
    """이름을 넣으면 인사해주는 함수"""
    print(f"안녕하세요, {name}님! Gogs 시스템에 접속하셨습니다.")


# 2. 더하기 계산기 함수 만들기
def add_numbers(a, b):
    """두 숫자를 더해서 결과를 돌려주는 함수"""
    result = a + b
    return result


# 3. 응용: 짝수인지 판별하는 함수
def is_even(number):
    """숫자가 짝수인지 판별하는 함수"""
    if number % 2 == 0:
        return True
    else:
        return False


def my_first_function():
    """
    [Python Elementary v1.6] 나만의 마법 주문 (함수)
    """
    # --- 함수 사용하기 (호출) ---
    print("--- 함수 실행 결과 ---")
    say_hello("설계자")
    say_hello("클로드코드")

    sum_result = add_numbers(10, 20)
    print(f"계산 결과: {sum_result}")

    # 짝수 판별
    test_num = 7
    if is_even(test_num):
        print(f"{test_num}은 짝수입니다.")
    else:
        print(f"{test_num}은 홀수입니다.")

    print("\n저장 필수 너는 기록이 증명이다 gogs")

    return {
        "sum_result": sum_result,
        "test_num": test_num,
        "is_even": is_even(test_num),
    }


def main():
    """v1.6 실행"""
    print("\n" + "="*70)
    print("🐍 Python v1.6: 함수(Function) — 반복되는 코드를 마법 주문으로")
    print("="*70 + "\n")

    my_first_function()

    print("\n" + "="*70)


if __name__ == "__main__":
    main()
