def test_list_is_iterable():
    """리스트는 Iterable"""
    data = [1, 2, 3]
    assert hasattr(data, '__iter__')


def test_list_is_not_iterator():
    """리스트는 Iterator가 아님"""
    data = [1, 2, 3]
    assert not hasattr(data, '__next__')


def test_generator_is_both_iterable_and_iterator():
    """제너레이터는 Iterable이자 Iterator"""
    gen = GeneratorBasics.count_up(3)
    assert hasattr(gen, '__iter__')
    assert hasattr(gen, '__next__')


def test_iterator_reuse():
    """Iterable은 재사용 가능, Iterator는 일회용"""
    data = [1, 2, 3]

    # Iterable: 여러 번 반복 가능
    list1 = list(data)
    list2 = list(data)
    assert list1 == list2

    # Iterator: 한 번만 사용 가능
    iterator = iter(data)
    values1 = list(iterator)
    values2 = list(iterator)
    assert values1 == [1, 2, 3]
    assert values2 == []


