def test_lazy_vs_eager_comprehensive():
    """종합 비교"""
    n = 100

    # Eager
    eager = [i for i in range(n)]
    eager_size = sys.getsizeof(eager)

    # Lazy
    lazy = (i for i in range(n))
    lazy_size = sys.getsizeof(lazy)

    # 검증
    assert len(eager) == n
    assert list(lazy) == list(range(n))
    assert eager_size > lazy_size


def test_protocol_compliance():
    """프로토콜 준수"""
    # 리스트
    data = [1, 2, 3]
