def test_list_eager_creation():
    """리스트는 즉시 모든 요소 생성"""
    eager_list = [i for i in range(1000)]
    assert len(eager_list) == 1000
    assert eager_list[500] == 500


def test_generator_lazy_creation():
    """제너레이터는 지연 생성"""
    lazy_gen = (i for i in range(1000))
    # 제너레이터는 길이를 알 수 없음
    assert not hasattr(lazy_gen, '__len__')


def test_memory_difference_small():
    """작은 크기에서 메모리 차이"""
    eager_size, lazy_size = MemoryComparison.compare_sizes(100)
    assert eager_size > lazy_size
    # 리스트가 적어도 2배 이상 크거나 더 클 것
    assert eager_size / lazy_size > 1


def test_memory_difference_large():
    """큰 크기에서 메모리 차이"""
    eager_size, lazy_size = MemoryComparison.compare_sizes(10000)
    assert eager_size > lazy_size
    # 큰 크기에서는 더 큰 차이가 날 것
    assert eager_size / lazy_size > 100


def test_generator_size_constant():
    """제너레이터는 크기가 일정"""
    size1 = sys.getsizeof((i for i in range(100)))
    size2 = sys.getsizeof((i for i in range(1000000)))
    # 동일한 크기 (또는 매우 유사)
    assert abs(size1 - size2) < 100


