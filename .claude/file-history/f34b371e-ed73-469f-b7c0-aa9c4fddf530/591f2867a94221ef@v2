def test_file_like_iteration():
    """파일처럼 순차 읽기"""
    # 제너레이터는 파일 객체처럼 동작
    def line_generator():
        for i in range(3):
            yield f"line {i}"

    lines = []
    for line in line_generator():
        lines.append(line)

    assert lines == ["line 0", "line 1", "line 2"]


def test_pipeline_pattern():
    """파이프라인 패턴"""
    def numbers():
        for i in range(10):
            yield i

    def even_only(gen):
        for x in gen:
            if x % 2 == 0:
                yield x

    def doubled(gen):
        for x in gen:
            yield x * 2

    pipeline = doubled(even_only(numbers()))
    result = list(pipeline)
    assert result == [0, 4, 8, 12, 16]


def test_early_termination():
    """조기 종료"""
    def limited_naturals():
        gen = InfiniteSequences.natural_numbers()
        for _ in range(3):
            yield next(gen)

    values = list(limited_naturals())
    assert values == [0, 1, 2]


