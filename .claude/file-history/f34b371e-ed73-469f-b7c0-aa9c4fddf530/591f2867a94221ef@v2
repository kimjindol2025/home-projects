def test_generator_chaining():
    """제너레이터 연쇄 (Lazy Chaining)"""
    def square_of(gen):
        for value in gen:
            yield value * value

    gen = InfiniteSequences.natural_numbers()
    squared = square_of(gen)

    values = [next(squared) for _ in range(3)]
    assert values == [0, 1, 4]


def test_infinite_chain_memory():
    """무한 연쇄도 메모리 일정"""
    def transform(gen):
        for value in gen:
            yield value * 2

    gen = InfiniteSequences.natural_numbers()
    transformed = transform(gen)

    initial_size = sys.getsizeof(transformed)
    for _ in range(100):
        next(transformed)
    final_size = sys.getsizeof(transformed)

    assert initial_size == final_size


def test_multiple_infinite_sources():
    """여러 무한 소스 동시 사용"""
    nat = InfiniteSequences.natural_numbers()
    even = InfiniteSequences.even_numbers()

    assert next(nat) == 0
    assert next(even) == 0
    assert next(nat) == 1
    assert next(even) == 2


