def demonstrate_echo_server():
    """Echo 서버 시연"""
    print("\n【 Echo 서버 - 메아리 】")

    print("""
import socket

server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
server.bind(('127.0.0.1', 9999))
server.listen(1)

print("서버 시작, 연결 대기 중...")

while True:
    client, addr = server.accept()
    print(f"클라이언트 연결: {addr}")

    # 데이터 수신
    data = client.recv(1024)
    message = data.decode('utf-8')
    print(f"수신: {message}")

    # Echo: 그대로 다시 보냄
    client.send(data)
    print(f"송신: {message}")

    client.close()

동작 원리:
  1. 클라이언트: "Hello" 전송
  2. 서버: "Hello" 수신
  3. 서버: "Hello" 그대로 송신
  4. 클라이언트: "Hello" 수신
    """)


def demonstrate_tcp_client():
    """TCP 클라이언트 시연"""
    print("\n【 TCP 클라이언트 】")

    print("""
import socket

client = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
client.connect(('127.0.0.1', 9999))

print("서버에 연결됨")

# 데이터 전송
message = "Hello, Server!"
client.send(message.encode('utf-8'))

# 응답 수신
data = client.recv(1024)
print(f"응답: {data.decode('utf-8')}")

client.close()
    """)


