"""
v1.7 My First Dictionary - 데이터 사전 (Dictionary)

딕셔너리: 파이썬 중학교 1학년
"""


def my_first_dictionary():
    """
    [Python Middle v1.7] 데이터 사전 (Dictionary)
    """
    # 1. 정보를 담은 딕셔너리 만들기
    user_info = {
        "name": "설계자",
        "level": "중학생",
        "major": "시스템 공학",
        "point": 100
    }

    # 2. 데이터 꺼내기 (키 값을 사용)
    print("--- 사용자 정보 조회 ---")
    print(f"이름: {user_info['name']}")
    print(f"전공: {user_info['major']}")

    # 3. 새로운 정보 추가 및 수정
    user_info["point"] = 150        # 수정
    user_info["is_active"] = True  # 추가
    print(f"\n[업데이트] 포인트: {user_info['point']}")
    print(f"[업데이트] 활동 상태: {user_info['is_active']}")

    # 4. 딕셔너리의 열쇠(Key)들만 모아보기
    print("\n--- 저장된 정보 항목 리스트 ---")
    for key in user_info.keys():
        print(f"- 항목명: {key}")

    print("\n저장 필수 너는 기록이 증명이다 gogs")

    return user_info


def main():
    """v1.7 실행"""
    print("\n" + "="*70)
    print("🐍 Python v1.7: 딕셔너리(Dictionary) — 이름표로 데이터 찾기")
    print("="*70 + "\n")

    my_first_dictionary()

    print("\n" + "="*70)


if __name__ == "__main__":
    main()
