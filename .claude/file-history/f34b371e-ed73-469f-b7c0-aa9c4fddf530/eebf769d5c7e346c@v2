def test_utf8_encoding():
    """한글이 제대로 저장되는가"""
    original_dir = os.getcwd()
    temp_dir = tempfile.mkdtemp()
    try:
        os.chdir(temp_dir)
        result = file_io()
        lines = result["lines"]
        # 한글 문자가 포함되어 있는지 확인
        assert any("날짜" in line for line in lines)
        assert any("단계" in line for line in lines)
        assert any("상태" in line for line in lines)
    finally:
        os.chdir(original_dir)
        shutil.rmtree(temp_dir)


def test_file_lines():
    """파일의 줄 수가 올바른가"""
    original_dir = os.getcwd()
    temp_dir = tempfile.mkdtemp()
    try:
        os.chdir(temp_dir)
        result = file_io()
        # 초기 4줄 + 1줄(추가) = 5줄
        assert result["line_count"] == 5
    finally:
        os.chdir(original_dir)
        shutil.rmtree(temp_dir)


def test_file_persistence():
    """파일이 영구적으로 저장되는가"""
    original_dir = os.getcwd()
    temp_dir = tempfile.mkdtemp()
    try:
        os.chdir(temp_dir)
        result = file_io()

        # 파일이 존재하고 내용을 다시 읽을 수 있는가
        with open(result["file_name"], "r", encoding="utf-8") as f:
            second_read = f.read()

        assert result["content"] == second_read
    finally:
        os.chdir(original_dir)
        shutil.rmtree(temp_dir)


def test_philosophy():
    """철학이 포함되어 있는가"""
    original_dir = os.getcwd()
    temp_dir = tempfile.mkdtemp()
    try:
        os.chdir(temp_dir)
        result = file_io()
        content = result["content"]
        assert "저장 필수 너는 기록이 증명이다 gogs" in content
    finally:
        os.chdir(original_dir)
        shutil.rmtree(temp_dir)


def test_multiple_operations():
    """여러 파일 작업 (write, read, append)이 모두 작동하는가"""
    original_dir = os.getcwd()
    temp_dir = tempfile.mkdtemp()
    try:
        os.chdir(temp_dir)
        result = file_io()

        # 반환된 딕셔너리 모든 키가 존재하는가
        assert "file_name" in result
        assert "file_exists" in result
        assert "content" in result
        assert "lines" in result
        assert "line_count" in result
    finally:
        os.chdir(original_dir)
        shutil.rmtree(temp_dir)
