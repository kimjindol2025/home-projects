"""
v2.0 테스트: 파일 입출력
"""

import os
import tempfile
import shutil
from src.v2_0_file_io import file_io


def test_file_io_returns_dict():
    """반환값이 딕셔너리"""
    # 임시 디렉토리에서 테스트 진행
    original_dir = os.getcwd()
    temp_dir = tempfile.mkdtemp()
    try:
        os.chdir(temp_dir)
        result = file_io()
        assert isinstance(result, dict)
    finally:
        os.chdir(original_dir)
        shutil.rmtree(temp_dir)


def test_file_creation():
    """파일이 생성되는가"""
    original_dir = os.getcwd()
    temp_dir = tempfile.mkdtemp()
    try:
        os.chdir(temp_dir)
        result = file_io()
        assert result["file_exists"] is True
    finally:
        os.chdir(original_dir)
        shutil.rmtree(temp_dir)


def test_file_name():
    """파일명이 올바른가"""
    original_dir = os.getcwd()
    temp_dir = tempfile.mkdtemp()
    try:
        os.chdir(temp_dir)
        result = file_io()
        assert result["file_name"] == "gogs_record.txt"
    finally:
        os.chdir(original_dir)
        shutil.rmtree(temp_dir)


def test_write_mode():
    """쓰기 모드 ('w')로 파일 작성"""
    original_dir = os.getcwd()
    temp_dir = tempfile.mkdtemp()
    try:
        os.chdir(temp_dir)
        result = file_io()
        content = result["content"]
        assert "날짜: 2026-02-24" in content
        assert "단계: 중학교 과정 졸업" in content
        assert "상태: 파이썬 기초 체력 완비" in content
    finally:
        os.chdir(original_dir)
        shutil.rmtree(temp_dir)


def test_append_mode():
    """추가 모드 ('a')로 내용 추가"""
    original_dir = os.getcwd()
