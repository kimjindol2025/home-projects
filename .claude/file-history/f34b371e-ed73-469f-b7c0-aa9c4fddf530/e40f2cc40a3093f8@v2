# [2] 검증 메타클래스: 클래스 이름 검증
# ============================================================================

class GogsValidationMeta(type):
    """클래스 이름이 'Gogs'로 시작하는지 검증"""

    def __new__(mcs, name, bases, attrs):
        # 기본 클래스는 제외
        if name not in ("GogsBase",):
            if not name.startswith("Gogs"):
                raise TypeError(f"❌ 규정 위반: '{name}'은 'Gogs'로 시작해야 합니다")

        print(f"✅ 클래스 '{name}' 생성 허용됨")
        return super().__new__(mcs, name, bases, attrs)


class GogsBase(metaclass=GogsValidationMeta):
    """Gogs로 시작하는 클래스만 허용"""
    pass


# ============================================================================
# [3] 싱글톤 메타클래스
# ============================================================================

class SingletonMeta(type):
    """싱글톤 패턴을 강제하는 메타클래스"""

    _instances = {}

    def __call__(cls, *args, **kwargs):
        if cls not in cls._instances:
            cls._instances[cls] = super().__call__(*args, **kwargs)
        return cls._instances[cls]


# ============================================================================
# [4] 레지스트리 메타클래스: 자동 등록
# ============================================================================

class RegistryMeta(type):
    """클래스가 생성되면 자동으로 레지스트리에 등록"""

    _registry = {}

    def __new__(mcs, name, bases, attrs):
        cls = super().__new__(mcs, name, bases, attrs)

        # 기본 클래스는 등록하지 않음
        if bases and bases[0] != object:
            mcs._registry[name] = cls
            print(f"📝 레지스트리 등록: {name}")

        return cls

    @classmethod
    def get_registry(mcs):
        """등록된 모든 클래스 조회"""
        return mcs._registry

    @classmethod
    def get_class(mcs, name):
        """이름으로 클래스 조회"""
        return mcs._registry.get(name)


# ============================================================================
# [5] 추상 메타클래스
# ============================================================================

class AbstractMeta(type):
    """추상 메서드를 강제하는 메타클래스"""

    def __new__(mcs, name, bases, attrs):
        # 추상 메서드 수집
        abstract_methods = set()
        for attr_name, attr_value in attrs.items():
            if getattr(attr_value, "__isabstractmethod__", False):
                abstract_methods.add(attr_name)

        # 부모 클래스의 추상 메서드도 수집
        for base in bases:
            abstract_methods.update(getattr(base, "__abstractmethods__", set()))

        attrs["__abstractmethods__"] = frozenset(abstract_methods)

        cls = super().__new__(mcs, name, bases, attrs)
        return cls

    def __call__(cls, *args, **kwargs):
        # 추상 메서드를 가진 클래스는 인스턴스화 불가
        if cls.__abstractmethods__:
            raise TypeError(
                f"❌ 추상 메서드 미구현: {', '.join(cls.__abstractmethods__)}"
            )
        return super().__call__(*args, **kwargs)


# ============================================================================
# [6] 메서드 주입 메타클래스
# ============================================================================

class MethodInjectionMeta(type):
    """모든 클래스에 공통 메서드를 자동으로 주입"""

    def __new__(mcs, name, bases, attrs):
        # 공통 메서드 주입
        def to_dict(self):
            """인스턴스를 딕셔너리로 변환"""
            return {
                k: v
                for k, v in self.__dict__.items()
                if not k.startswith("_")
            }

        def to_str(self):
            """인스턴스를 문자열로 변환"""
            return f"{name}({self.to_dict()})"

        attrs["to_dict"] = to_dict
        attrs["__str__"] = to_str

        return super().__new__(mcs, name, bases, attrs)


# ============================================================================
# [7] 속성 검증 메타클래스
# ============================================================================

class PropertyValidationMeta(type):
    """클래스 정의 시 필수 속성을 검증"""

    required_attributes = []

    def __new__(mcs, name, bases, attrs):
        # 기본 클래스 제외
        if name not in ("PropertyValidatedBase",):
            for required in mcs.required_attributes:
                if required not in attrs and not any(
                    hasattr(base, required) for base in bases
                ):
                    raise TypeError(f"❌ 필수 속성 누락: {required}")

        return super().__new__(mcs, name, bases, attrs)


# ============================================================================
# [8] 불변성 메타클래스
# ============================================================================

class ImmutableMeta(type):
    """한 번 생성된 클래스는 수정 불가"""

    def __setattr__(cls, name, value):
        raise TypeError(f"❌ 불변 클래스 '{cls.__name__}'은 수정할 수 없습니다")


# ============================================================================
# [9] 인트로스펙션 메타클래스
# ============================================================================

class IntrospectionMeta(type):
    """클래스의 메타데이터를 수집하는 메타클래스"""

    def __new__(mcs, name, bases, attrs):
        # 메서드 수집
        methods = {}
        properties = {}

        for attr_name, attr_value in attrs.items():
            if callable(attr_value) and not attr_name.startswith("_"):
                methods[attr_name] = inspect.signature(attr_value)
            elif isinstance(attr_value, property):
                properties[attr_name] = attr_value

        attrs["__methods__"] = methods
        attrs["__properties__"] = properties
        attrs["__mro_chain__"] = [base.__name__ for base in bases]

        return super().__new__(mcs, name, bases, attrs)

    @staticmethod
    def get_metadata(cls) -> dict:
        """클래스의 메타데이터 조회"""
        return {
            "name": cls.__name__,
            "methods": getattr(cls, "__methods__", {}),
            "properties": list(getattr(cls, "__properties__", {}).keys()),
            "mro": getattr(cls, "__mro_chain__", []),
            "bases": [b.__name__ for b in cls.__bases__],
        }


# ============================================================================
# [10] ORM 스타일 메타클래스
# ============================================================================

class ORMMeta(type):
    """Django ORM 스타일 메타클래스"""

    def __new__(mcs, name, bases, attrs):
        # 필드 수집
        fields = {}
        for attr_name, attr_value in list(attrs.items()):
            if isinstance(attr_value, Field):
                fields[attr_name] = attr_value

        attrs["__fields__"] = fields
        attrs["_field_names"] = list(fields.keys())

        return super().__new__(mcs, name, bases, attrs)

    def __call__(cls, **kwargs):
        # 검증
        for field_name in cls._field_names:
            if field_name not in kwargs:
                raise TypeError(f"❌ 필수 필드 누락: {field_name}")

        instance = super().__call__()

        # 필드 설정
        for field_name, value in kwargs.items():
            setattr(instance, field_name, value)

        return instance


class Field:
    """ORM 필드"""

    def __init__(self, field_type: Type, default=None):
        self.field_type = field_type
        self.default = default


