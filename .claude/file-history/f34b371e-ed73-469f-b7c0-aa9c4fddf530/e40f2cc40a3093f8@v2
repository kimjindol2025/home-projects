def demonstrate_validation_meta() -> dict:
    """검증 메타클래스 데모"""
    try:
        class GogsRobot(GogsBase):
            pass

        return {"result": "✅ GogsRobot 생성 성공"}
    except TypeError as e:
        return {"error": str(e)}


def demonstrate_singleton_meta() -> dict:
    """싱글톤 메타클래스 데모"""

    class DatabaseConnection(metaclass=SingletonMeta):
        def __init__(self):
            self.connected = True

    db1 = DatabaseConnection()
    db2 = DatabaseConnection()

    return {
        "same_instance": db1 is db2,
        "db1_id": id(db1),
        "db2_id": id(db2),
    }


def demonstrate_registry_meta() -> dict:
    """레지스트리 메타클래스 데모"""

    class Animal(metaclass=RegistryMeta):
        pass

    class Dog(Animal):
        pass

    class Cat(Animal):
        pass

    registry = RegistryMeta.get_registry()
    return {"registered_classes": list(registry.keys())}


def demonstrate_method_injection_meta() -> dict:
    """메서드 주입 메타클래스 데모"""

    class Person(metaclass=MethodInjectionMeta):
        def __init__(self, name, age):
            self.name = name
            self.age = age

    person = Person("Alice", 30)
    return {
        "to_dict": person.to_dict(),
        "str": str(person),
    }


def demonstrate_introspection_meta() -> dict:
    """인트로스펙션 메타클래스 데모"""

    class MyClass(metaclass=IntrospectionMeta):
        def method1(self):
            pass

        def method2(self, arg1, arg2):
            pass

        @property
        def my_property(self):
            return "value"

    metadata = IntrospectionMeta.get_metadata(MyClass)
    return {"metadata": metadata}


