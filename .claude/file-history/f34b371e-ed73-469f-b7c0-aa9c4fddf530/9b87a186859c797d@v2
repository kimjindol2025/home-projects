class TestExceptionIgnorer:
    """예외 무시 테스트"""

    def test_ignore_specified_exception(self):
        """지정된 예외 무시"""
        with ExceptionIgnorer(ValueError):
            raise ValueError("무시됨")

        # 도달함 (예외가 무시됨)
        assert True

    def test_propagate_other_exception(self):
        """다른 예외는 전파"""
        with pytest.raises(RuntimeError):
            with ExceptionIgnorer(ValueError):
                raise RuntimeError("전파됨")

    def test_multiple_exceptions(self):
        """여러 예외 무시"""
        with ExceptionIgnorer(ValueError, TypeError):
            raise ValueError("무시됨")

        with ExceptionIgnorer(ValueError, TypeError):
            raise TypeError("무시됨")

        # 도달함
        assert True


