class TestLockManager:
    """락 매니저 테스트"""

    def test_lock_acquire_and_release(self):
        """락 획득 및 해제"""
        lock = threading.Lock()
        assert not lock.locked()

        with LockManager(lock, "테스트 락"):
            assert lock.locked()

        assert not lock.locked()

    def test_lock_prevents_concurrent_access(self):
        """동시 접근 방지"""
        lock = threading.Lock()
        results = []

        def worker(worker_id):
            with LockManager(lock, f"워커 {worker_id}"):
                results.append(f"시작 {worker_id}")
                time.sleep(0.01)
                results.append(f"종료 {worker_id}")

        threads = [threading.Thread(target=worker, args=(i,)) for i in range(3)]
        for t in threads:
            t.start()
        for t in threads:
            t.join()

        assert len(results) == 6


