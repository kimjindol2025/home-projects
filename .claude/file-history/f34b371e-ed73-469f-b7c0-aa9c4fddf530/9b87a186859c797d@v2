class TestFileManager:
    """파일 처리 매니저 테스트"""

    def test_file_write_read(self):
        """파일 쓰기 및 읽기"""
        with tempfile.NamedTemporaryFile(mode="w", delete=False) as f:
            temp_path = f.name

        try:
            # 쓰기
            with FileManager(temp_path, mode="w") as f:
                f.write("Hello, World!")

            # 읽기
            with FileManager(temp_path, mode="r") as f:
                content = f.read()

            assert content == "Hello, World!"
        finally:
            Path(temp_path).unlink()

    def test_file_closes_on_exit(self):
        """파일이 자동으로 닫힘"""
        with tempfile.NamedTemporaryFile(mode="w", delete=False) as f:
            temp_path = f.name
            f.write("test")

        try:
            file_handle = None
            with FileManager(temp_path, mode="r") as f:
                file_handle = f
                assert not f.closed

            assert file_handle.closed
        finally:
            Path(temp_path).unlink()

    def test_file_closes_on_error(self):
        """에러 발생 시에도 파일이 닫힘"""
        with tempfile.NamedTemporaryFile(mode="w", delete=False) as f:
            temp_path = f.name

        try:
            file_handle = None
            try:
                with FileManager(temp_path, mode="r") as f:
                    file_handle = f
                    raise ValueError("의도적인 에러")
            except ValueError:
                pass

            assert file_handle.closed
        finally:
            Path(temp_path).unlink()


