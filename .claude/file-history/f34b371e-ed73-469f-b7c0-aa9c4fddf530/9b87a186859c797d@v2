class TestSimpleResource:
    """기본 리소스 매니저 테스트"""

    def test_context_enter_exit(self):
        """진입과 퇴출"""
        res = SimpleResource("테스트 리소스")
        assert res.is_open == False

        res.__enter__()
        assert res.is_open == True

        res.__exit__(None, None, None)
        assert res.is_open == False

    def test_with_statement(self):
        """with 문 사용"""
        with SimpleResource("리소스") as res:
            assert res.is_open == True

        assert res.is_open == False

    def test_return_value(self):
        """반환값"""
        with SimpleResource("리소스") as res:
            assert isinstance(res, SimpleResource)
            assert res.name == "리소스"


