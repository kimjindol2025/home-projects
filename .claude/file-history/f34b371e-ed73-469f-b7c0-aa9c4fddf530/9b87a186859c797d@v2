class TestTimer:
    """타이머 테스트"""

    def test_timer_measures_time(self):
        """시간 측정"""
        with Timer("테스트") as timer:
            time.sleep(0.05)

        assert timer.elapsed is not None
        assert timer.elapsed >= 0.04  # 충분한 여유

    def test_timer_with_exception(self):
        """예외 발생 시에도 시간 측정"""
        timer_obj = Timer("에러 테스트")
        try:
            with timer_obj:
                time.sleep(0.02)
                raise ValueError("에러")
        except ValueError:
            pass

        assert timer_obj.elapsed is not None
        assert timer_obj.elapsed >= 0.01

    def test_timer_very_fast(self):
        """매우 빠른 작업"""
        with Timer("빠른 작업") as timer:
            pass

        assert timer.elapsed is not None
        assert timer.elapsed < 0.1


