class TestLabEquipment:
    """연구실 장비 테스트"""

    def test_equipment_normal_operation(self):
        """정상 작동"""
        eq = LabEquipment("입자 가속기")
        assert eq.is_running == False

        with eq:
            assert eq.is_running == True
            data = eq.collect_data()
            assert "완료" in data

        assert eq.is_running == False

    def test_equipment_error_handling(self):
        """에러 처리"""
        eq = LabEquipment("냉각 시스템")

        with pytest.raises(RuntimeError):
            with eq:
                raise RuntimeError("냉각 장치 결함!")

        assert eq.is_running == False

    def test_equipment_collect_data_requires_running(self):
        """가동 중이어야 데이터 수집 가능"""
        eq = LabEquipment("센서")

        with pytest.raises(RuntimeError):
            eq.collect_data()


