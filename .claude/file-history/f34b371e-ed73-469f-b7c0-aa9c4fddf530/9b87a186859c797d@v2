class TestDecoratorBasedContextManagers:
    """데코레이터 기반 컨텍스트 매니저 테스트"""

    def test_temporary_file(self):
        """임시 파일"""
        filepath = None

        with temporary_file(mode="w") as f:
            filepath = f.name
            f.write("test data")
            assert Path(filepath).exists()

        # 파일이 삭제됨
        assert not Path(filepath).exists()

    def test_working_directory(self):
        """작업 디렉토리"""
        original_cwd = str(Path.cwd())
        cwd_changed = False

        with tempfile.TemporaryDirectory() as tmpdir:
            with working_directory(tmpdir):
                current = str(Path.cwd())
                # 디렉토리가 변경되었는지 확인 (정확한 경로는 심볼릭 링크로 다를 수 있음)
                cwd_changed = (current != original_cwd)

            # 복원 확인
            assert str(Path.cwd()) == original_cwd

        assert cwd_changed


