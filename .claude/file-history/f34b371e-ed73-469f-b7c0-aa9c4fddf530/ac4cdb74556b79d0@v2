class TestAggregateRoot:
    """Aggregate Root 테스트"""

    def test_aggregate_creation(self):
        """Aggregate 생성"""
        email = Email("alice@gogs.io")
        researcher = Researcher(1, "Alice", email, "ADMIN")
        experiment = ExperimentAggregate(1, researcher, "패턴 연구")

        assert experiment.id == 1
        assert experiment.status == ExperimentStatus.PENDING

    def test_aggregate_add_log(self):
        """로그 추가"""
        email = Email("alice@gogs.io")
        researcher = Researcher(1, "Alice", email, "ADMIN")
        experiment = ExperimentAggregate(1, researcher, "패턴 연구")

        experiment.start()
        log = experiment.add_log("첫 로그")

        assert len(experiment.logs) == 1

    def test_aggregate_invariant_no_log_after_completion(self):
        """불변식: 완료 후 로그 추가 불가"""
        email = Email("alice@gogs.io")
        researcher = Researcher(1, "Alice", email, "ADMIN")
        experiment = ExperimentAggregate(1, researcher, "패턴 연구")

        experiment.start()
        experiment.complete(ExperimentScore(95.0))

        with pytest.raises(ValueError):
            experiment.add_log("불가능한 로그")

    def test_aggregate_start_transition(self):
        """상태 전이: pending → in_progress"""
        email = Email("alice@gogs.io")
        researcher = Researcher(1, "Alice", email, "ADMIN")
        experiment = ExperimentAggregate(1, researcher, "패턴 연구")

        assert experiment.status == ExperimentStatus.PENDING
        experiment.start()
        assert experiment.status == ExperimentStatus.IN_PROGRESS

    def test_aggregate_completion(self):
        """실험 완료"""
        email = Email("alice@gogs.io")
        researcher = Researcher(1, "Alice", email, "ADMIN")
        experiment = ExperimentAggregate(1, researcher, "패턴 연구")

        experiment.start()
        experiment.complete(ExperimentScore(92.5))

        assert experiment.status == ExperimentStatus.COMPLETED
        assert experiment.score.value == 92.5

    def test_aggregate_generates_events(self):
        """도메인 이벤트 생성"""
        email = Email("alice@gogs.io")
        researcher = Researcher(1, "Alice", email, "ADMIN")
        experiment = ExperimentAggregate(1, researcher, "패턴 연구")

        experiment.start()
        experiment.add_log("로그")
        experiment.complete(ExperimentScore(95.0))

        events = experiment.get_events()
        assert len(events) >= 3


