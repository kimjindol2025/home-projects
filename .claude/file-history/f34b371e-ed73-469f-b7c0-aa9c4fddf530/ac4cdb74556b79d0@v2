class TestPipeline:
    """Pipeline 패턴 테스트"""

    def test_pipeline_single_transformation(self):
        """단일 변환"""
        result = Pipeline(10).pipe(lambda x: x * 2).execute()
        assert result == 20

    def test_pipeline_multiple_transformations(self):
        """다중 변환"""
        result = (
            Pipeline(10)
            .pipe(lambda x: x * 2)
            .pipe(lambda x: x + 5)
            .pipe(lambda x: x / 3)
            .execute()
        )
        assert abs(result - 8.333) < 0.01

    def test_pipeline_with_data_transformation(self):
        """데이터 변환 파이프라인"""
        data = [
            {'id': 1, 'value': 100},
            {'id': 2, 'value': 50},
        ]

        result = (
            Pipeline(data)
            .pipe(lambda items: [item for item in items if item['value'] > 60])
            .pipe(lambda items: sorted(items, key=lambda x: x['value']))
            .execute()
        )

        assert len(result) == 1
        assert result[0]['id'] == 1


class TestSpecification:
    """Specification 패턴 테스트"""

    def test_specification_single_condition(self):
        """단일 조건"""
        spec = HighScoreSpec(80)
        experiment = {'status': 'completed', 'result': 95}

        assert spec.is_satisfied_by(experiment)

    def test_specification_and_combination(self):
        """AND 조합"""
        completed_spec = CompletedExperimentSpec()
        high_score_spec = HighScoreSpec(80)
        combined = completed_spec.and_spec(high_score_spec)

        experiment = {'status': 'completed', 'result': 85}
        assert combined.is_satisfied_by(experiment)

        bad_experiment = {'status': 'pending', 'result': 95}
        assert not combined.is_satisfied_by(bad_experiment)

    def test_specification_or_combination(self):
        """OR 조합"""
        spec1 = CompletedExperimentSpec()
        spec2 = HighScoreSpec(90)
        combined = spec1.or_spec(spec2)

        assert combined.is_satisfied_by({'status': 'completed', 'result': 50})
        assert combined.is_satisfied_by({'status': 'pending', 'result': 95})


class TestResultMonad:
    """Result Monad 테스트"""

    def test_result_ok(self):
        """성공 결과"""
        result = Result.ok(42)
        assert result.is_success()
        assert result.get() == 42

    def test_result_err(self):
        """실패 결과"""
        result = Result.err("에러 발생")
        assert result.is_failure()
        assert result.get_error() == "에러 발생"

    def test_result_map_success(self):
        """성공 시 map 적용"""
        result = Result.ok(5).map(lambda x: x * 2)
        assert result.get() == 10

    def test_result_map_failure(self):
        """실패 시 map은 그대로 전파"""
        result = Result.err("에러").map(lambda x: x * 2)
        assert result.is_failure()

    def test_result_flat_map(self):
        """flat_map으로 Result 반환 함수 연결"""
        def divide(a, b):
            if b == 0:
                return Result.err("0으로 나눌 수 없음")
            return Result.ok(a / b)

        result = Result.ok(10).flat_map(lambda x: divide(x, 2))
        assert result.get() == 5.0

    def test_result_get_or_else(self):
        """값 또는 기본값"""
        assert Result.ok(42).get_or_else(0) == 42
        assert Result.err("에러").get_or_else(0) == 0


