class TestEventSourcing:
    """Event Sourcing 패턴 테스트"""

    def test_event_store_append(self):
        """이벤트 저장"""
        store = ExperimentEventStore()
        event = DomainEvent('TestEvent', datetime.now(), 1, {'data': 'value'})

        store.append(event)
        events = store.get_events(1)

        assert len(events) == 1
        assert events[0].event_type == 'TestEvent'

    def test_event_store_replay(self):
        """이벤트 재생"""
        store = ExperimentEventStore()

        store.append(DomainEvent('ExperimentCreated', datetime.now(), 1,
                                  {'subject': '테스트', 'description': '설명'}))
        store.append(DomainEvent('ExperimentStarted', datetime.now(), 1, {}))
        store.append(DomainEvent('ExperimentCompleted', datetime.now(), 1,
                                  {'result': 95.5}))

        state = store.replay(1)
        assert state['status'] == 'completed'
        assert state['result'] == 95.5

    def test_event_store_get_all_events(self):
        """모든 이벤트 조회"""
        store = ExperimentEventStore()

        store.append(DomainEvent('Event1', datetime.now(), 1, {}))
        store.append(DomainEvent('Event2', datetime.now(), 2, {}))

        all_events = store.get_all_events()
        assert len(all_events) == 2
        assert 1 in all_events
        assert 2 in all_events


