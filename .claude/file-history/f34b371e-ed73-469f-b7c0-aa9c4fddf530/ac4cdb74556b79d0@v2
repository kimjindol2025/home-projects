class TestRepositoryPattern:
    """Repository 패턴 테스트"""

    def test_repository_save_and_retrieve(self):
        """저장 후 조회"""
        repo = InMemoryResearcherRepository()
        researcher = repo.save({'name': 'Alice', 'email': 'alice@gogs.io', 'role': 'ADMIN'})

        retrieved = repo.find_by_id(researcher['id'])
        assert retrieved is not None
        assert retrieved['name'] == 'Alice'

    def test_repository_find_all(self):
        """전체 조회"""
        repo = InMemoryResearcherRepository()
        repo.save({'name': 'Alice', 'email': 'alice@gogs.io'})
        repo.save({'name': 'Bob', 'email': 'bob@gogs.io'})

        all_researchers = repo.find_all()
        assert len(all_researchers) == 2

    def test_repository_delete(self):
        """삭제"""
        repo = InMemoryResearcherRepository()
        researcher = repo.save({'name': 'Alice', 'email': 'alice@gogs.io'})

        repo.delete(researcher['id'])
        assert repo.find_by_id(researcher['id']) is None

    def test_repository_can_be_replaced(self):
        """인터페이스 교체 가능성"""
        # 테스트에서 InMemory 사용
        repo = InMemoryResearcherRepository()
        repo.save({'name': 'Test', 'email': 'test@gogs.io'})

        # 프로덕션에서는 DB 저장소 사용 가능
        # 코드 변경 없음!
        assert len(repo.find_all()) == 1

    def test_repository_find_by_spec(self):
        """Specification으로 조회"""
        repo = InMemoryResearcherRepository()
        repo.save({'name': 'Alice', 'email': 'alice@gogs.io', 'role': 'ADMIN'})
        repo.save({'name': 'Bob', 'email': 'bob@gogs.io', 'role': 'RESEARCHER'})

        # ADMIN만 찾는 spec
        class AdminSpec(Specification):
            def is_satisfied_by(self, candidate):
                return candidate.get('role') == 'ADMIN'

        admins = repo.find_by_spec(AdminSpec())
        assert len(admins) == 1
        assert admins[0]['name'] == 'Alice'


class TestServiceLayer:
    """Service Layer 패턴 테스트"""

