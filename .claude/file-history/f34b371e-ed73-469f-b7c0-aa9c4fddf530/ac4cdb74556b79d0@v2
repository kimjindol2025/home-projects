class TestValueObjects:
    """Value Object 테스트"""

    def test_email_creation(self):
        """이메일 생성"""
        email = Email("alice@gogs.io")
        assert email.value == "alice@gogs.io"

    def test_email_validation(self):
        """이메일 유효성 검사"""
        with pytest.raises(ValueError):
            Email("invalid-email")

    def test_email_equality(self):
        """이메일 동등성 (값으로 비교)"""
        email1 = Email("alice@gogs.io")
        email2 = Email("alice@gogs.io")
        assert email1 == email2

    def test_score_creation(self):
        """점수 생성"""
        score = ExperimentScore(95.5)
        assert score.value == 95.5

    def test_score_range_validation(self):
        """점수 범위 검증"""
        with pytest.raises(ValueError):
            ExperimentScore(150.0)

    def test_score_immutability(self):
        """점수 불변성"""
        score = ExperimentScore(95.0)
        with pytest.raises(AttributeError):
            score.value = 50  # frozen=True로 인해 실패


