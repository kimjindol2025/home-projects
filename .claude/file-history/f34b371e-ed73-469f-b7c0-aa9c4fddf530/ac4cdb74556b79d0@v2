class TestIntegration:
    """통합 테스트"""

    def test_full_workflow(self):
        """전체 워크플로우"""
        # Repository 생성
        repo = InMemoryResearcherRepository()

        # 연구자 저장
        researcher_data = repo.save({'name': 'Alice', 'email': 'alice@gogs.io', 'role': 'ADMIN'})
        researcher = Researcher(
            researcher_data['id'],
            researcher_data['name'],
            Email(researcher_data['email']),
            researcher_data['role']
        )

        # Aggregate 생성
        experiment = ExperimentAggregate(1, researcher, "고급 패턴 연구")

        # 상태 전이
        experiment.start()
        experiment.add_log("분석 1: Repository 패턴")
        experiment.add_log("분석 2: DDD 패턴")
        experiment.complete(ExperimentScore(96.5))

        # 검증
        assert experiment.status == ExperimentStatus.COMPLETED
        assert len(experiment.logs) == 2
        assert experiment.score.is_passing_score()

    def test_repository_service_integration(self):
        """Repository + Service 통합"""
        repo = InMemoryResearcherRepository()
        uow = UnitOfWork.__new__(UnitOfWork)
        uow.researchers = repo
        service = ResearcherService(uow)

        # 서비스를 통한 등록
        researcher = service.register_researcher('Bob', 'bob@gogs.io', 'RESEARCHER')

        # Repository로 직접 조회
        found = repo.find_by_id(researcher['id'])
        assert found['name'] == 'Bob'

    def test_event_sourcing_full_replay(self):
        """Event Sourcing 전체 흐름"""
        store = ExperimentEventStore()

        events = [
            DomainEvent('ExperimentCreated', datetime.now(), 1,
                        {'subject': '연구', 'description': '설명'}),
            DomainEvent('ExperimentStarted', datetime.now(), 1, {}),
            DomainEvent('LogAdded', datetime.now(), 1, {'message': '로그 1'}),
            DomainEvent('LogAdded', datetime.now(), 1, {'message': '로그 2'}),
            DomainEvent('ExperimentCompleted', datetime.now(), 1, {'result': 88.0}),
        ]

        for event in events:
            store.append(event)

        # 재생
        state = store.replay(1)
        assert state['status'] == 'completed'
        assert state['result'] == 88.0
        assert len(state['history']) == 2


