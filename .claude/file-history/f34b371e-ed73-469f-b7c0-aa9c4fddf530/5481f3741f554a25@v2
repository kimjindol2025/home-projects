fn section_4_constant_folding_demo() {
    println!("╔═══════════════════════════════════════════════════════════════════════════════╗");
    println!("║            섹션 4: Constant Folding 실증                                     ║");
    println!("╚═══════════════════════════════════════════════════════════════════════════════╝\n");

    let examples = vec![
        ("2 + 3", IRNode::BinaryOp {
            op: "+".to_string(),
            left: Box::new(IRNode::Constant(2)),
            right: Box::new(IRNode::Constant(3)),
        }),
        ("10 * (5 - 2)", IRNode::BinaryOp {
            op: "*".to_string(),
            left: Box::new(IRNode::Constant(10)),
            right: Box::new(IRNode::BinaryOp {
                op: "-".to_string(),
                left: Box::new(IRNode::Constant(5)),
                right: Box::new(IRNode::Constant(2)),
            }),
        }),
        ("100 / 4", IRNode::BinaryOp {
            op: "/".to_string(),
            left: Box::new(IRNode::Constant(100)),
            right: Box::new(IRNode::Constant(4)),
        }),
    ];

    println!("데모: Constant Folding 실행\n");

    for (desc, mut ir) in examples {
        println!("  원본 표현식: {}", desc);

        let folder = ConstantFolder;
        let stats = folder.run(&mut ir);

        println!("  최적화 결과: {}", ir);
        println!("  Folding 수: {}", stats.constant_folding_count);
        println!("  제거된 노드: {}", stats.nodes_removed);
        println!();
    }

    println!("✅ Constant Folding 완료!\n");
}

fn section_5_dead_code_elimination_concept() {
    println!("╔═══════════════════════════════════════════════════════════════════════════════╗");
    println!("║      섹션 5: Dead Code Elimination — 도달 불가능한 코드 제거                 ║");
    println!("╚═══════════════════════════════════════════════════════════════════════════════╝\n");

    println!("💀 Dead Code란?");
    println!("  절대 실행되지 않을 코드를 의미합니다.");
    println!("  이를 제거하면 바이트코드 크기가 줄고 의도가 명확해집니다.");
    println!("");
    println!("🔍 감지 패턴:");
    println!("");
    println!("  [패턴 1] Constant False 조건");
    println!("    if false {{ ... }}");
    println!("    → 바디 전체 제거");
    println!("");
    println!("  [패턴 2] Constant True 조건");
    println!("    if true {{ A }} else {{ B }}");
    println!("    → A만 남기고 B와 else 제거");
    println!("");
    println!("  [패턴 3] False While");
    println!("    while false {{ ... }}");
    println!("    → 루프 바디 제거");
    println!("");
    println!("  [패턴 4] Unreachable Return");
    println!("    return 42;");
    println!("    ... (이후 코드는 도달 불가능)");
    println!("");
    println!("⚡ 성능 개선:");
    println!("  • 불필요한 분기 제거로 CPU 분기 예측 정확도 향상");
    println!("  • 캐시 오염(cache pollution) 감소");
    println!("  • 프로그램 크기 감소로 I-cache 효율성 증가\n");
}

fn section_6_dead_code_elimination_demo() {
    println!("╔═══════════════════════════════════════════════════════════════════════════════╗");
    println!("║      섹션 6: Dead Code Elimination 실증                                     ║");
    println!("╚═══════════════════════════════════════════════════════════════════════════════╝\n");

    let examples = vec![
        ("if false { 10 }", IRNode::If {
            condition: Box::new(IRNode::Boolean(false)),
            then_branch: Box::new(IRNode::Constant(10)),
            else_branch: None,
        }),
        ("if true { 20 } else { 30 }", IRNode::If {
            condition: Box::new(IRNode::Boolean(true)),
            then_branch: Box::new(IRNode::Constant(20)),
            else_branch: Some(Box::new(IRNode::Constant(30))),
        }),
        ("while false { 100 }", IRNode::While {
            condition: Box::new(IRNode::Boolean(false)),
            body: Box::new(IRNode::Constant(100)),
        }),
    ];

    println!("데모: Dead Code Elimination 실행\n");

    for (desc, mut ir) in examples {
        println!("  원본 코드: {}", desc);

        let eliminator = DeadCodeEliminator;
        let stats = eliminator.run(&mut ir);

        println!("  제거 후: {}", ir);
        println!("  제거된 코드: {}", stats.dead_code_removed);
        println!();
    }

    println!("✅ Dead Code Elimination 완료!\n");
}

fn section_7_optimization_engine() {
    println!("╔═══════════════════════════════════════════════════════════════════════════════╗");
    println!("║         섹션 7: 최적화 엔진 — 다단계 패스 시스템                             ║");
    println!("╚═══════════════════════════════════════════════════════════════════════════════╝\n");

    let mut ir = IRNode::Block(vec![
        IRNode::BinaryOp {
            op: "+".to_string(),
            left: Box::new(IRNode::Constant(2)),
            right: Box::new(IRNode::Constant(3)),
        },
        IRNode::If {
            condition: Box::new(IRNode::Boolean(false)),
            then_branch: Box::new(IRNode::Constant(100)),
            else_branch: None,
        },
    ]);

    println!("최적화 전 IR:");
    println!("  {}\n", ir);

    let engine = OptimizationEngine::new();
    let stats = engine.run_all(&mut ir);

    println!("최적화 후 IR:");
    println!("  {}\n", ir);

    println!("최적화 결과:");
    let report = engine.generate_report(&stats);
    println!("{}\n", report);
}

