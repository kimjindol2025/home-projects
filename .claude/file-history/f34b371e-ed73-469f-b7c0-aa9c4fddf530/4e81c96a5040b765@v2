"""
v1.1 Basic Variables: 변수와 이름표의 기초

파이썬에서 변수는 "값을 담는 상자"가 아니라, 메모리에 떠있는 데이터에 붙이는 '이름표'입니다.
"""


# ============================================================================
# 1. 정수(Integer) - 소수점이 없는 숫자
# ============================================================================

def demonstrate_integers():
    """정수 변수 선언과 사용"""
    # 지금 이 순간, 파이썬은 메모리에 정수 10을 올리고
    # 그것에 'age'라는 이름표를 붙입니다.
    age = 10

    # 또 다른 정수
    year = 2026

    # 계산
    birth_year = year - age

    return age, year, birth_year


# ============================================================================
# 2. 실수(Float) - 소수점이 있는 숫자
# ============================================================================

def demonstrate_floats():
    """실수 변수 선언과 사용"""
    # 정수가 아닌, 소수점이 있는 숫자입니다.
    pi = 3.14
    height = 1.72

    # 정수를 실수로 변환할 수도 있습니다.
    circle_radius = float(5)  # 5.0

    return pi, height, circle_radius


# ============================================================================
# 3. 문자열(String) - 글자
# ============================================================================

def demonstrate_strings():
    """문자열 변수 선언과 사용"""
    # 큰따옴표나 작은따옴표로 감싼 것이 문자열입니다.
    name = "Gogs"
    language = 'Python'
    status = "Learning v1.1"

    # 문자열을 합칠 수 있습니다.
    message = name + " is studying " + language

    return name, language, status, message


# ============================================================================
# 4. 변수 재할당 (이름표 옮기기)
# ============================================================================

def demonstrate_reassignment():
    """이름표를 다른 값에 붙이기"""
    # 처음에는 version에 1이라는 이름표를 붙입니다.
    version = 1

    # 그 다음, 같은 이름표 version을 이제 2에 붙입니다.
    # (이전의 1은 누구의 이름도 없어집니다.)
    version = 2

    # 다시 붙이기
    version = 1.1

    return version


# ============================================================================
# 5. 메모리에서의 생각법
# ============================================================================

def demonstrate_memory_concept():
    """
    [메모리]
    주소         | 값        | 이름표
    -----------|-----------|----------
    0x1000     | 10        | age
    0x1008     | 2026      | year
    0x1010     | 3.14      | pi
    0x1018     | "Gogs"    | name

    = 기호는 '할당'을 의미합니다.
    age = 10은 "메모리의 어딘가에 10을 올리고, 그것에 age라는 이름표를 붙인다"
    """
    age = 10
    year = 2026
    pi = 3.14
    name = "Gogs"

    return age, year, pi, name


# ============================================================================
# 6. 실습: 사용자 정의 변수로 계산하기
# ============================================================================

def calculate_gogs_version():
    """
    [v1.1 실습] Gogs 버전 정보 계산
    """
    # 메인 버전과 서브 버전을 정수로 저장
    major_version = 1
    minor_version = 1

    # 버전을 숫자로 표현 (1.1 → 1.10)
    version_number = major_version + minor_version / 10

    # 프로젝트 이름
    project_name = "Gogs-Python"

    # 언어 이름
    language = "Python"

    # 상태 메시지
    status = "Elementary School Grade 1"

    # 모든 정보를 담은 딕셔너리 (나중에 더 배우게 될 구조)
    info = {
        "name": project_name,
        "version": version_number,
        "language": language,
        "status": status,
        "major": major_version,
        "minor": minor_version,
    }

    return info


# ============================================================================
# 7. 기록 출력
# ============================================================================

def main():
    """
    v1.1 변수와 이름표 - 기본 시연
    """
    print("\n" + "="*70)
    print("🐍 Python v1.1: 변수와 이름표 (초등학교 1학년)")
    print("="*70)

    # 정수
    age, year, birth_year = demonstrate_integers()
    print("\n[1. 정수(Integer)]")
    print(f"  나이: {age}")
    print(f"  연도: {year}")
    print(f"  태어난 해: {birth_year}")

    # 실수
    pi, height, circle_radius = demonstrate_floats()
    print("\n[2. 실수(Float)]")
    print(f"  원주율(π): {pi}")
    print(f"  키: {height}m")
    print(f"  원의 반지름: {circle_radius}")

    # 문자열
    name, language, status, message = demonstrate_strings()
    print("\n[3. 문자열(String)]")
    print(f"  이름: {name}")
    print(f"  언어: {language}")
    print(f"  상태: {status}")
    print(f"  메시지: {message}")

    # 재할당
    version = demonstrate_reassignment()
    print("\n[4. 변수 재할당 (이름표 옮기기)]")
    print(f"  최종 버전: {version}")

    # Gogs 버전 정보
    info = calculate_gogs_version()
    print("\n[5. v1.1 실습 결과]")
    print(f"  프로젝트: {info['name']}")
    print(f"  버전: {info['version']}")
    print(f"  언어: {info['language']}")
    print(f"  상태: {info['status']}")

    print("\n" + "="*70)
    print("저장 필수. 너는 기록이 증명이다. Gogs.")
    print("="*70 + "\n")


if __name__ == "__main__":
    main()
