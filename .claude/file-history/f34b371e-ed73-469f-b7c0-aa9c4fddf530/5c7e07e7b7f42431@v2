class TestDynamicProgramming:
    """동적 계획법 테스트"""

    def test_fibonacci_naive(self):
        """나이브 피보나치"""
        result, calls = DynamicProgramming.fibonacci_naive(5)
        assert result == 5

    def test_fibonacci_dp(self):
        """DP 피보나치"""
        result, calls = DynamicProgramming.fibonacci_dp(5)
