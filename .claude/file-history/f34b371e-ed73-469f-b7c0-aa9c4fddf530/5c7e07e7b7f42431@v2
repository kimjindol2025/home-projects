class TestMinHeap:
    """최소 힙 테스트"""

    def test_heap_push_pop(self):
        """삽입과 추출"""
        heap = MinHeap()
        heap.push(5)
        heap.push(3)
        heap.push(7)

        assert heap.pop() == 3
        assert heap.pop() == 5
        assert heap.pop() == 7

    def test_heap_peek(self):
        """최소값 조회"""
        heap = MinHeap()
        heap.push(5)
        heap.push(3)
        heap.push(7)

        assert heap.peek() == 3

    def test_heap_size(self):
        """크기"""
        heap = MinHeap()
        heap.push(5)
        heap.push(3)
        assert heap.size() == 2

    def test_heap_order(self):
        """힙 순서"""
        heap = MinHeap()
        values = [50, 30, 20, 15, 10, 8, 16]
        for v in values:
            heap.push(v)

        sorted_values = []
        while heap.size() > 0:
            sorted_values.append(heap.pop())

        assert sorted_values == sorted(values)


