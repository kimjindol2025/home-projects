class TestGraph:
    """그래프 테스트"""

    def test_graph_dfs(self):
        """깊이 우선 탐색"""
        g = Graph()
        edges = [(0, 1), (0, 2), (1, 2), (1, 3)]
        for u, v in edges:
            g.add_edge(u, v)

        dfs_result = g.dfs(0)
        assert len(dfs_result) == 4
        assert 0 in dfs_result

    def test_graph_bfs(self):
        """너비 우선 탐색"""
        g = Graph()
        edges = [(0, 1), (0, 2), (1, 2), (1, 3)]
        for u, v in edges:
            g.add_edge(u, v)

        bfs_result = g.bfs(0)
        assert len(bfs_result) == 4
        assert bfs_result[0] == 0

    def test_graph_dijkstra(self):
        """다익스트라 최단경로"""
        g = Graph()
        edges = [(0, 1, 4), (0, 2, 2), (1, 2, 1), (1, 3, 5), (2, 3, 8)]
        for u, v, w in edges:
            g.add_edge(u, v, w)

        distances = g.dijkstra(0)
        assert distances[0] == 0
        assert distances[1] == 3  # 0→2(2) + 2→1(1)
        assert distances[3] == 8  # 0→1(3) + 1→3(5)

    def test_graph_weighted(self):
        """가중치 그래프"""
        g = Graph()
        g.add_edge(1, 2, 10)
        g.add_edge(2, 3, 5)
        distances = g.dijkstra(1)
        assert distances[3] == 15


