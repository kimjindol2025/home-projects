class TestSortingAlgorithms:
    """정렬 알고리즘 테스트"""

    def test_bubble_sort(self):
        """버블 정렬"""
        data = [64, 34, 25, 12, 22, 11, 90]
        sorted_data, comps = SortingAlgorithms.bubble_sort(data)
        assert sorted_data == [11, 12, 22, 25, 34, 64, 90]
        assert comps > 0

    def test_selection_sort(self):
        """선택 정렬"""
        data = [64, 34, 25, 12, 22, 11, 90]
        sorted_data, comps = SortingAlgorithms.selection_sort(data)
        assert sorted_data == [11, 12, 22, 25, 34, 64, 90]

    def test_merge_sort(self):
        """병합 정렬"""
        data = [64, 34, 25, 12, 22, 11, 90]
        sorted_data, comps = SortingAlgorithms.merge_sort(data)
        assert sorted_data == [11, 12, 22, 25, 34, 64, 90]

    def test_quick_sort(self):
        """빠른 정렬"""
        data = [64, 34, 25, 12, 22, 11, 90]
        sorted_data, comps = SortingAlgorithms.quick_sort(data)
        assert sorted_data == [11, 12, 22, 25, 34, 64, 90]

    def test_sorting_on_empty(self):
        """빈 배열 정렬"""
        data = []
        sorted_data, _ = SortingAlgorithms.bubble_sort(data)
        assert sorted_data == []

    def test_sorting_single_element(self):
        """한 요소 정렬"""
        data = [42]
        sorted_data, _ = SortingAlgorithms.merge_sort(data)
        assert sorted_data == [42]

    def test_sorting_already_sorted(self):
        """이미 정렬된 배열"""
        data = [1, 2, 3, 4, 5]
        sorted_data, _ = SortingAlgorithms.quick_sort(data)
        assert sorted_data == [1, 2, 3, 4, 5]

    def test_sorting_reverse_order(self):
        """역순 배열"""
        data = [5, 4, 3, 2, 1]
        sorted_data, _ = SortingAlgorithms.bubble_sort(data)
        assert sorted_data == [1, 2, 3, 4, 5]


