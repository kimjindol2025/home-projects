        values = [3, 4, 5, 6]
        capacity = 5

        result = DynamicProgramming.knapsack_01(weights, values, capacity)
        assert result > 0

    def test_lcs(self):
        """최장 공통 부분수열"""
        result = DynamicProgramming.longest_common_subsequence("ABCDGH", "AEDFHR")
        assert result >= 3


