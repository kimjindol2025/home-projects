class TestSearchAlgorithms:
    """검색 알고리즘 테스트"""

    def test_linear_search_found(self):
        """선형 탐색 - 찾음"""
        data = [64, 34, 25, 12, 22, 11, 90]
        idx, comps = SearchAlgorithms.linear_search(data, 25)
        assert idx == 2

    def test_linear_search_not_found(self):
        """선형 탐색 - 못 찾음"""
        data = [64, 34, 25, 12, 22, 11, 90]
        idx, comps = SearchAlgorithms.linear_search(data, 999)
        assert idx == -1

    def test_binary_search_found(self):
        """이진 탐색 - 찾음"""
        data = sorted([64, 34, 25, 12, 22, 11, 90])
        idx, comps = SearchAlgorithms.binary_search(data, 25)
        assert idx >= 0
        assert data[idx] == 25

    def test_binary_search_not_found(self):
        """이진 탐색 - 못 찾음"""
        data = sorted([64, 34, 25, 12, 22, 11, 90])
        idx, comps = SearchAlgorithms.binary_search(data, 999)
        assert idx == -1

    def test_jump_search(self):
        """점프 탐색"""
        data = sorted(list(range(1, 101)))
        idx, comps = SearchAlgorithms.jump_search(data, 50)
        assert idx >= 0
        assert data[idx] == 50

    def test_search_efficiency(self):
        """검색 효율성"""
        data = sorted(list(range(1, 10001)))
        target = 9999

        _, linear_comps = SearchAlgorithms.linear_search(data, target)
        _, binary_comps = SearchAlgorithms.binary_search(data, target)

        # 이진 탐색이 훨씬 적은 비교
        assert binary_comps < linear_comps


