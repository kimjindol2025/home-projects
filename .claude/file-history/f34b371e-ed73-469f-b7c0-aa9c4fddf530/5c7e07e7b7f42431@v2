class TestBinarySearchTree:
    """이진 탐색 트리 테스트"""

    def test_bst_insert_and_search(self):
        """삽입과 검색"""
        bst = BinarySearchTree()
        bst.insert(25)
        bst.insert(15)
        bst.insert(35)

        assert bst.search(25) == True
        assert bst.search(15) == True
        assert bst.search(999) == False

    def test_bst_inorder(self):
        """중위 순회 (정렬된 순서)"""
        bst = BinarySearchTree()
        values = [25, 15, 35, 10, 20, 30, 40]
        for v in values:
            bst.insert(v)

        inorder = bst.inorder()
        assert inorder == sorted(values)

    def test_bst_height(self):
        """트리 높이"""
        bst = BinarySearchTree()
        bst.insert(25)
        bst.insert(15)
        bst.insert(35)

        height = bst.height()
        assert height == 2

    def test_bst_single_element(self):
        """한 요소"""
        bst = BinarySearchTree()
        bst.insert(42)
        assert bst.height() == 1
        assert bst.search(42) == True


