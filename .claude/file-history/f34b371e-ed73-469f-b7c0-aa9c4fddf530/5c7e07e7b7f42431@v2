class TestHashTable:
    """해시 테이블 테스트"""

    def test_hash_table_put_get(self):
        """해시 테이블 삽입/조회"""
        ht = HashTable()
        ht.put("Alice", 25)
        assert ht.get("Alice") == 25

    def test_hash_table_multiple_items(self):
        """다중 항목"""
        ht = HashTable(size=5)
        ht.put("Alice", 25)
        ht.put("Bob", 30)
        ht.put("Charlie", 35)

        assert ht.get("Alice") == 25
        assert ht.get("Bob") == 30
        assert ht.get("Charlie") == 35

    def test_hash_table_update(self):
        """항목 업데이트"""
        ht = HashTable()
        ht.put("Alice", 25)
        ht.put("Alice", 26)
        assert ht.get("Alice") == 26

    def test_hash_table_remove(self):
        """항목 삭제"""
        ht = HashTable()
        ht.put("Alice", 25)
        ht.remove("Alice")
        assert ht.get("Alice") is None

    def test_hash_table_contains(self):
        """포함 여부"""
        ht = HashTable()
        ht.put("Alice", 25)
        assert ht.contains("Alice") == True
        assert ht.contains("Bob") == False


