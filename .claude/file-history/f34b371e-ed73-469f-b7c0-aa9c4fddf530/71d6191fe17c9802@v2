class TestNoSQLStore:
    """NoSQL 문서 저장소 테스트"""

    def test_insert_document(self):
        """문서 삽입"""
        store = NoSQLStore()
        result = store.insert_document('users', 'user1', {
            'name': '설계자',
            'email': 'designer@gogs.io'
        })
        assert result == True

    def test_find_by_id(self):
        """ID로 검색"""
        store = NoSQLStore()
        store.insert_document('users', 'user1', {
            'name': '설계자',
            'email': 'designer@gogs.io'
        })

        doc = store.find_by_id('user1')
        assert doc is not None
        assert doc.data['name'] == '설계자'

    def test_find_in_collection(self):
        """컬렉션에서 검색"""
        store = NoSQLStore()
        store.insert_document('users', 'user1', {
            'name': '설계자',
            'age': 25
        })
        store.insert_document('users', 'user2', {
            'name': '개발자',
            'age': 28
        })

        result = store.find_in_collection('users', {'age': 25})
        assert len(result) == 1
        assert result[0].data['name'] == '설계자'

    def test_update_document(self):
        """문서 업데이트"""
        store = NoSQLStore()
        store.insert_document('users', 'user1', {
            'name': '설계자',
            'age': 25
        })

        success = store.update_document('user1', {'age': 26})
        assert success == True

        doc = store.find_by_id('user1')
        assert doc.data['age'] == 26

    def test_delete_document(self):
        """문서 삭제"""
        store = NoSQLStore()
        store.insert_document('users', 'user1', {
            'name': '설계자'
        })

        success = store.delete_document('user1')
        assert success == True

        doc = store.find_by_id('user1')
        assert doc is None

    def test_count_collection(self):
        """컬렉션 크기"""
        store = NoSQLStore()
        store.insert_document('users', 'user1', {'name': '설계자'})
        store.insert_document('users', 'user2', {'name': '개발자'})
        store.insert_document('users', 'user3', {'name': '테스터'})

        count = store.count_collection('users')
        assert count == 3

    def test_flexible_schema(self):
        """유연한 스키마"""
        store = NoSQLStore()
        # 다른 구조의 문서
        store.insert_document('users', 'user1', {
            'name': '설계자',
            'email': 'designer@gogs.io'
        })
        store.insert_document('users', 'user2', {
            'name': '개발자',
            'phone': '010-1234-5678'
            # email 없음
        })

        doc1 = store.find_by_id('user1')
        doc2 = store.find_by_id('user2')

        assert 'email' in doc1.data
        assert 'phone' in doc2.data
        assert 'email' not in doc2.data


