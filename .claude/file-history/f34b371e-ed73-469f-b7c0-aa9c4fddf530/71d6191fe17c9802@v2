class TestTransactionManager:
    """ACID 트랜잭션 테스트"""

    def test_transaction_creation(self):
        """트랜잭션 생성"""
        tx = TransactionManager()
        user_id = tx.insert_user('설계자', 'designer@gogs.io')
        assert user_id == 1

    def test_insert_user(self):
        """사용자 삽입"""
        tx = TransactionManager()
        user_id = tx.insert_user('설계자', 'designer@gogs.io')
        user = tx.get_user(user_id)
        assert user is not None
        assert user.name == '설계자'
        assert user.email == 'designer@gogs.io'

    def test_insert_account(self):
        """계좌 삽입"""
        tx = TransactionManager()
        user_id = tx.insert_user('설계자', 'designer@gogs.io')
        account_id = tx.insert_account(user_id, 'savings', 10000)
        balance = tx.get_balance(account_id)
        assert balance == 10000

    def test_multiple_accounts(self):
        """여러 계좌"""
        tx = TransactionManager()
        user_id = tx.insert_user('설계자', 'designer@gogs.io')
        acc1 = tx.insert_account(user_id, 'savings', 10000)
        acc2 = tx.insert_account(user_id, 'checking', 5000)
        assert tx.get_balance(acc1) == 10000
        assert tx.get_balance(acc2) == 5000

    def test_transfer_money_success(self):
        """송금 성공 (ACID 시연)"""
        tx = TransactionManager()
        user_id = tx.insert_user('설계자', 'designer@gogs.io')
        acc1 = tx.insert_account(user_id, 'savings', 10000)
        acc2 = tx.insert_account(user_id, 'checking', 5000)

        # 송금
        success = tx.transfer_money(acc1, acc2, 3000)

        assert success == True
        assert tx.get_balance(acc1) == 7000
        assert tx.get_balance(acc2) == 8000

    def test_transfer_atomicity(self):
        """원자성: 모두 성공하거나 모두 실패"""
        tx = TransactionManager()
        user_id = tx.insert_user('설계자', 'designer@gogs.io')
        acc1 = tx.insert_account(user_id, 'savings', 10000)
        acc2 = tx.insert_account(user_id, 'checking', 5000)

        balance_before_1 = tx.get_balance(acc1)
        balance_before_2 = tx.get_balance(acc2)

        # 송금
        tx.transfer_money(acc1, acc2, 3000)

        # 합계는 변하지 않음
        total_before = balance_before_1 + balance_before_2
        total_after = tx.get_balance(acc1) + tx.get_balance(acc2)

        assert total_before == total_after

    def test_transaction_isolation(self):
        """고립성: 동시 트랜잭션 영향 없음"""
        tx = TransactionManager()
        user_id = tx.insert_user('설계자', 'designer@gogs.io')
        acc1 = tx.insert_account(user_id, 'savings', 10000)

        # 트랜잭션 1 시작
        tx1_id = tx.begin_transaction()
        tx.add_operation(
            'UPDATE accounts SET balance = balance - ? WHERE id = ?',
            (2000, acc1)
        )

        # 잔액 조회 (트랜잭션 1 영향 없음)
        balance = tx.get_balance(acc1)
        assert balance == 10000

        # 트랜잭션 1 커밋
        tx.commit()

        # 이제 변경 적용됨
        balance = tx.get_balance(acc1)
        assert balance == 8000

    def test_begin_and_commit(self):
        """BEGIN과 COMMIT"""
        tx = TransactionManager()
        user_id = tx.insert_user('테스트', 'test@gogs.io')
        assert user_id == 1

        tx_id = tx.begin_transaction()
        tx.add_operation(
            'INSERT INTO accounts (user_id, balance, account_type, created_at) VALUES (?, ?, ?, ?)',
            (user_id, 5000, 'savings', time.time())
        )
        success = tx.commit()
        assert success == True


