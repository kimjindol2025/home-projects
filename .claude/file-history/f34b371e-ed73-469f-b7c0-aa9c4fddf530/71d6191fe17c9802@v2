class TestIndexManager:
    """인덱싱 테스트"""

    def test_index_creation(self):
        """인덱스 생성"""
        index_mgr = IndexManager()
        data = [(1, 'Alice'), (2, 'Bob'), (3, 'Alice')]
        index_mgr.create_index('name', data)
        assert len(index_mgr.indexes) > 0

    def test_search_by_index(self):
        """인덱스로 검색 (빠름)"""
        index_mgr = IndexManager()
        data = [(1, 'Alice'), (2, 'Bob'), (3, 'Alice')]
        index_mgr.create_index('name', data)

        result = index_mgr.search_by_index('name', 'Alice')
        assert result == [1, 3]

    def test_full_scan(self):
        """전체 스캔 (느림)"""
        index_mgr = IndexManager()
        data = [(1, 'Alice'), (2, 'Bob'), (3, 'Alice')]

        result = index_mgr.full_scan('name', 'Alice', data)
        assert result == [1, 3]

    def test_index_hit_ratio(self):
        """인덱스 히트율"""
        index_mgr = IndexManager()
        data = [(i, 'Alice' if i % 2 == 0 else 'Bob') for i in range(100)]
        index_mgr.create_index('name', data)

        # 인덱스 검색 (히트)
        for _ in range(10):
            index_mgr.search_by_index('name', 'Alice')

        stats = index_mgr.get_stats()
        assert stats['hit_count'] == 10
        assert stats['hit_ratio'] > 0.9


