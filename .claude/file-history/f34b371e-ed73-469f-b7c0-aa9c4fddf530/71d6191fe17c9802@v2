class TestBackupManager:
    """백업/복구 테스트"""

    def test_create_backup(self):
        """백업 생성"""
        tx = TransactionManager()
        user_id = tx.insert_user('설계자', 'designer@gogs.io')
        tx.insert_account(user_id, 'savings', 10000)

        backup_mgr = BackupManager(tx)
        success = backup_mgr.create_backup('backup1')
        assert success == True

    def test_backup_info(self):
        """백업 정보"""
        tx = TransactionManager()
        user_id = tx.insert_user('설계자', 'designer@gogs.io')
        tx.insert_account(user_id, 'savings', 10000)

        backup_mgr = BackupManager(tx)
        backup_mgr.create_backup('backup1')

        info = backup_mgr.get_backup_info('backup1')
        assert info['name'] == 'backup1'
        assert info['users_count'] > 0
        assert info['accounts_count'] > 0

    def test_restore_backup(self):
        """백업 복구"""
        tx = TransactionManager()
        user_id = tx.insert_user('설계자', 'designer@gogs.io')
        acc_id = tx.insert_account(user_id, 'savings', 10000)

        backup_mgr = BackupManager(tx)
        backup_mgr.create_backup('backup1')

        # 데이터 변경
        tx.insert_account(user_id, 'checking', 5000)
        assert len(tx.cursor.execute('SELECT * FROM accounts').fetchall()) == 2

        # 백업 복구
        success = backup_mgr.restore_backup('backup1')
        assert success == True

        # 복구됨
        accounts = tx.cursor.execute('SELECT * FROM accounts').fetchall()
        assert len(accounts) == 1


