class TestQueryOptimizer:
    """쿼리 최적화 테스트"""

    def test_query_analysis(self):
        """쿼리 분석"""
        optimizer = QueryOptimizer()
        plan = optimizer.analyze_query('SELECT * FROM users WHERE id = 1')

        assert 'query' in plan
        assert 'type' in plan
        assert plan['type'] == 'SELECT'

    def test_execution_time_estimation(self):
        """실행 시간 추정"""
        optimizer = QueryOptimizer()
        time_simple = optimizer.estimate_execution_time('SELECT * FROM users', 1000)
        time_complex = optimizer.estimate_execution_time(
            'SELECT * FROM users JOIN accounts ON users.id = accounts.user_id',
            1000
        )

        assert time_complex > time_simple

    def test_slow_query_detection(self):
        """느린 쿼리 감지"""
        optimizer = QueryOptimizer()
        optimizer.log_query('SELECT * FROM users', 50.0)
        optimizer.log_query('SELECT * FROM accounts', 150.0)

        slow_queries = optimizer.get_slow_queries(threshold_ms=100.0)
        assert len(slow_queries) == 1
        assert slow_queries[0]['execution_time'] == 150.0


