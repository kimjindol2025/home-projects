class TestDatabasePhilosophy:
    """데이터베이스 철학 테스트"""

    def test_acid_principles(self):
        """ACID 원칙"""
        result = DatabasePhilosophy.acid_principles()
        assert "원자성 (Atomicity)" in result
        assert "일관성 (Consistency)" in result
        assert "고립성 (Isolation)" in result
        assert "지속성 (Durability)" in result

    def test_normalization_levels(self):
        """정규화 레벨"""
        result = DatabasePhilosophy.normalization_levels()
        assert "1NF (First Normal Form)" in result
        assert "2NF (Second Normal Form)" in result
        assert "3NF (Third Normal Form)" in result
        assert "BCNF" in result

    def test_rdbms_vs_nosql(self):
        """RDBMS vs NoSQL"""
        result = DatabasePhilosophy.rdbms_vs_nosql()
        assert "RDBMS" in result
        assert "NoSQL" in result
        assert result["RDBMS"]["특징"] == "구조화된 데이터, 강한 일관성"
        assert result["NoSQL"]["특징"] == "자유로운 구조, 최종 일관성"


