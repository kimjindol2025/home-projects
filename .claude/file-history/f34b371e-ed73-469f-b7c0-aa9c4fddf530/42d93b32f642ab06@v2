# 【 Helper Functions 】
def login_required(f):
    """로그인 필수 데코레이터"""
    def decorated_function(*args, **kwargs):
        if 'token' not in session or 'researcher_id' not in session:
            return redirect(url_for('login_page'))
        return f(*args, **kwargs)
    decorated_function.__name__ = f.__name__
    return decorated_function


def get_current_researcher():
    """현재 사용자 정보"""
    if 'researcher_id' in session:
        return db.get_researcher(session['researcher_id'])
    return None


# 【 Auth Routes 】
@app.route('/')
def index():
    """홈페이지"""
    if 'token' in session:
        researcher = get_current_researcher()
        return redirect(url_for('dashboard', name=researcher['name']))
    return redirect(url_for('login_page'))


@app.route('/login', methods=['GET', 'POST'])
def login_page():
    """로그인 페이지"""
    if request.method == 'POST':
        data = request.get_json()
        email = data.get('email')
        password = data.get('password')

        token = auth.authenticate(email, password)
        if token:
            researcher = db.get_researcher_by_email(email)
            session['token'] = token
            session['researcher_id'] = researcher['id']
            session['email'] = email
            session['name'] = researcher['name']
            session['role'] = researcher.get('role', 'researcher')
            return jsonify({'success': True, 'redirect': url_for('dashboard', name=researcher['name'])})
        else:
            return jsonify({'success': False, 'message': '이메일 또는 비밀번호가 잘못되었습니다'}), 401

    return render_template('login.html')


@app.route('/logout')
def logout():
    """로그아웃"""
    token = session.get('token')
    if token:
        auth.logout(token)
    session.clear()
    return redirect(url_for('login_page'))


