// ============================================================================
// IR: Intermediate Representation - 최적화 전 단계
// ============================================================================

use std::fmt;

/// 중간 표현(IR) 노드
#[derive(Debug, Clone, PartialEq)]
pub enum IRNode {
    /// 정수 상수
    Constant(i64),

    /// 불리언 상수
    Boolean(bool),

    /// null
    Null,

    /// 이진 연산: op left right
    BinaryOp {
        op: String,
        left: Box<IRNode>,
        right: Box<IRNode>,
    },

    /// 전위 연산: op operand
    UnaryOp {
        op: String,
        operand: Box<IRNode>,
    },

    /// 변수 참조
    Variable(String),

    /// 변수 할당
    Assignment {
        name: String,
        value: Box<IRNode>,
    },

    /// if-else 조건문
    If {
        condition: Box<IRNode>,
        then_branch: Box<IRNode>,
        else_branch: Option<Box<IRNode>>,
    },

    /// while 루프
    While {
        condition: Box<IRNode>,
        body: Box<IRNode>,
    },

    /// 블록 (여러 문장)
    Block(Vec<IRNode>),

    /// 배열 리터럴
    Array(Vec<IRNode>),

    /// 인덱싱
    Index {
        array: Box<IRNode>,
        index: Box<IRNode>,
    },
}

impl IRNode {
    /// IR을 복사본으로 깊은 클론
    pub fn deep_clone(&self) -> Self {
        match self {
            IRNode::Constant(n) => IRNode::Constant(*n),
            IRNode::Boolean(b) => IRNode::Boolean(*b),
            IRNode::Null => IRNode::Null,
            IRNode::BinaryOp { op, left, right } => IRNode::BinaryOp {
                op: op.clone(),
                left: Box::new(left.deep_clone()),
                right: Box::new(right.deep_clone()),
            },
            IRNode::UnaryOp { op, operand } => IRNode::UnaryOp {
                op: op.clone(),
                operand: Box::new(operand.deep_clone()),
            },
            IRNode::Variable(name) => IRNode::Variable(name.clone()),
            IRNode::Assignment { name, value } => IRNode::Assignment {
                name: name.clone(),
                value: Box::new(value.deep_clone()),
            },
            IRNode::If { condition, then_branch, else_branch } => IRNode::If {
                condition: Box::new(condition.deep_clone()),
                then_branch: Box::new(then_branch.deep_clone()),
                else_branch: else_branch.as_ref().map(|b| Box::new(b.deep_clone())),
            },
            IRNode::While { condition, body } => IRNode::While {
                condition: Box::new(condition.deep_clone()),
                body: Box::new(body.deep_clone()),
            },
            IRNode::Block(nodes) => {
                IRNode::Block(nodes.iter().map(|n| n.deep_clone()).collect())
            }
            IRNode::Array(elements) => {
                IRNode::Array(elements.iter().map(|e| e.deep_clone()).collect())
            }
            IRNode::Index { array, index } => IRNode::Index {
                array: Box::new(array.deep_clone()),
                index: Box::new(index.deep_clone()),
            },
        }
    }

    /// 노드가 상수인지 확인 (최적화 분석용)
    pub fn is_constant(&self) -> bool {
        matches!(self, IRNode::Constant(_) | IRNode::Boolean(_) | IRNode::Null)
    }

    /// 노드가 순수 함수인지 확인 (부작용 없음)
    pub fn is_pure(&self) -> bool {
        match self {
            IRNode::Constant(_) | IRNode::Boolean(_) | IRNode::Null | IRNode::Variable(_) => true,
            IRNode::BinaryOp { left, right, .. } => left.is_pure() && right.is_pure(),
            IRNode::UnaryOp { operand, .. } => operand.is_pure(),
            IRNode::Array(elements) => elements.iter().all(|e| e.is_pure()),
            IRNode::Index { array, index } => array.is_pure() && index.is_pure(),
            _ => false,
        }
    }
}

impl fmt::Display for IRNode {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        match self {
            IRNode::Constant(n) => write!(f, "{}", n),
            IRNode::Boolean(b) => write!(f, "{}", b),
            IRNode::Null => write!(f, "null"),
            IRNode::BinaryOp { op, left, right } => write!(f, "({} {} {})", left, op, right),
            IRNode::UnaryOp { op, operand } => write!(f, "({}{})", op, operand),
            IRNode::Variable(name) => write!(f, "{}", name),
            IRNode::Assignment { name, value } => write!(f, "({} = {})", name, value),
            IRNode::If { condition, then_branch, else_branch } => {
                write!(f, "if {} {{ {} }}", condition, then_branch)?;
                if let Some(alt) = else_branch {
                    write!(f, " else {{ {} }}", alt)?;
                }
                Ok(())
            }
            IRNode::While { condition, body } => write!(f, "while {} {{ {} }}", condition, body),
            IRNode::Block(nodes) => {
                write!(f, "{{ ")?;
                for (i, node) in nodes.iter().enumerate() {
                    if i > 0 {
                        write!(f, "; ")?;
                    }
                    write!(f, "{}", node)?;
                }
                write!(f, " }}")
            }
            IRNode::Array(elements) => {
                write!(f, "[")?;
                for (i, elem) in elements.iter().enumerate() {
                    if i > 0 {
                        write!(f, ", ")?;
                    }
                    write!(f, "{}", elem)?;
                }
                write!(f, "]")
            }
            IRNode::Index { array, index } => write!(f, "{}[{}]", array, index),
        }
    }
}

/// IR 생성기 통계
#[derive(Debug, Clone, Copy, Default)]
pub struct IRStats {
    pub node_count: usize,
    pub constant_count: usize,
    pub binary_op_count: usize,
    pub variable_count: usize,
}

impl IRStats {
    /// IR 통계 계산
    pub fn from_node(node: &IRNode) -> Self {
        let mut stats = IRStats::default();
        Self::traverse(node, &mut stats);
        stats
    }

    fn traverse(node: &IRNode, stats: &mut IRStats) {
        stats.node_count += 1;

        match node {
            IRNode::Constant(_) => stats.constant_count += 1,
            IRNode::BinaryOp { left, right, .. } => {
                stats.binary_op_count += 1;
                Self::traverse(left, stats);
                Self::traverse(right, stats);
            }
            IRNode::UnaryOp { operand, .. } => Self::traverse(operand, stats),
            IRNode::Variable(_) => stats.variable_count += 1,
            IRNode::Assignment { value, .. } => Self::traverse(value, stats),
            IRNode::If { condition, then_branch, else_branch } => {
                Self::traverse(condition, stats);
                Self::traverse(then_branch, stats);
                if let Some(alt) = else_branch {
                    Self::traverse(alt, stats);
                }
            }
            IRNode::While { condition, body } => {
                Self::traverse(condition, stats);
                Self::traverse(body, stats);
            }
            IRNode::Block(nodes) => {
                for n in nodes {
                    Self::traverse(n, stats);
                }
            }
            IRNode::Array(elements) => {
                for elem in elements {
                    Self::traverse(elem, stats);
                }
            }
            IRNode::Index { array, index } => {
                Self::traverse(array, stats);
                Self::traverse(index, stats);
            }
            _ => {}
        }
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_constant_folding_candidate() {
        let node = IRNode::BinaryOp {
            op: "+".to_string(),
            left: Box::new(IRNode::Constant(2)),
            right: Box::new(IRNode::Constant(3)),
        };

        assert!(node.is_pure());
    }

    #[test]
    fn test_ir_stats() {
        let node = IRNode::BinaryOp {
            op: "+".to_string(),
            left: Box::new(IRNode::Constant(2)),
            right: Box::new(IRNode::Constant(3)),
        };

        let stats = IRStats::from_node(&node);
        assert_eq!(stats.node_count, 3); // BinaryOp + 2 Constants
        assert_eq!(stats.constant_count, 2);
        assert_eq!(stats.binary_op_count, 1);
    }
}
