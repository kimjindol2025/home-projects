def demonstrate_microservices_architecture() -> dict:
    """마이크로서비스 아키텍처 데모"""
    print("\n【 마이크로서비스 아키텍처 시뮬레이션 】")

    broker = MessageBroker()
    order_producer = Producer("OrderService", broker)
    payment_consumer = Consumer("PaymentService", broker)

    # 주문 생성
    order_producer.produce("PaymentService", "Order-001: 주문 처리")
    order_producer.produce("PaymentService", "Order-002: 주문 처리")

    # 결제 처리
    payment_consumer.consume()
    payment_consumer.consume()

    stats = broker.get_stats()
    return {
        "broker_messages": len(stats["history"]),
        "consumed": payment_consumer.processed_count,
    }


def demonstrate_service_registry() -> dict:
    """서비스 레지스트리 데모"""
    print("\n【 서비스 레지스트리 】")

    registry = ServiceRegistry()

    # 서비스 등록
    registry.register("order-service", "192.168.1.100", 8001)
    registry.register("payment-service", "192.168.1.101", 8002)

    # 서비스 발견
    order_service = registry.discover("order-service")
    payment_service = registry.discover("payment-service")

    return {
        "order_service": order_service,
        "payment_service": payment_service,
        "all_services": registry.list_services(),
    }


def demonstrate_circuit_breaker() -> dict:
    """서킷 브레이커 데모"""
    print("\n【 서킷 브레이커 】")

    cb = CircuitBreaker(failure_threshold=2, timeout=5.0)

    def unstable_service():
        if cb.failure_count < 2:
            raise Exception("서비스 장애!")
        return "정상 응답"

    try:
        cb.call(unstable_service)
    except:
        pass

    try:
        cb.call(unstable_service)
    except:
        pass

    # 이제 OPEN 상태
    result = cb.call(unstable_service)

    return {
        "state": cb.state.value,
        "failure_count": cb.failure_count,
    }


