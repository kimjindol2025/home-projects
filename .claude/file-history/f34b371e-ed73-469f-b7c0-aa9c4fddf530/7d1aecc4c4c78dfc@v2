# [4] 서비스 레지스트리 (Service Registry)
# ============================================================================

class ServiceRegistry:
    """분산 시스템의 '전화번호부'"""

    def __init__(self):
        self.services: Dict[str, Dict[str, Any]] = {}
        self.lock = threading.Lock()

    def register(self, service_name: str, host: str, port: int, status: str = "healthy"):
        """서비스 등록"""
        with self.lock:
            if service_name not in self.services:
                self.services[service_name] = []

            self.services[service_name].append({
                "host": host,
                "port": port,
                "status": status,
                "registered_at": datetime.now().isoformat(),
            })
            print(f"📝 서비스 등록: {service_name} ({host}:{port})")

    def discover(self, service_name: str) -> Optional[Dict]:
        """서비스 발견"""
        with self.lock:
            services = self.services.get(service_name, [])
            healthy = [s for s in services if s["status"] == "healthy"]
            return healthy[0] if healthy else None

    def list_services(self) -> Dict:
        """모든 서비스 나열"""
        with self.lock:
            return dict(self.services)

    def deregister(self, service_name: str, host: str):
        """서비스 등록 해제"""
        with self.lock:
            if service_name in self.services:
                self.services[service_name] = [
                    s for s in self.services[service_name]
                    if s["host"] != host
                ]


