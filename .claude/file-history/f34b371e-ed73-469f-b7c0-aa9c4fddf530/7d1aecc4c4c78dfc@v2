# [2] 메시지 브로커 (Message Broker)
# ============================================================================

@dataclass
class Message:
    """메시지 구조"""
    id: str
    sender: str
    receiver: str
    content: str
    timestamp: float = None
    status: str = "pending"  # pending, processing, completed, failed

    def __post_init__(self):
        if self.timestamp is None:
            self.timestamp = time.time()


class MessageBroker:
    """분산 시스템을 위한 메시지 브로커 - 우체국 역할"""

    def __init__(self, max_queue_size: int = 1000):
        self.queue = queue.Queue(maxsize=max_queue_size)
        self.history: List[Message] = []
        self.lock = threading.Lock()

    def publish(self, message: Message) -> bool:
        """메시지 발행"""
        try:
            self.queue.put(message, timeout=1.0)
            with self.lock:
                self.history.append(message)
            print(f"📬 [{message.sender}→{message.receiver}] 메시지 발행: {message.content}")
            return True
        except queue.Full:
            print(f"❌ 큐가 가득 찼습니다")
            return False

    def subscribe(self, timeout: float = None) -> Optional[Message]:
        """메시지 구독"""
        try:
            message = self.queue.get(timeout=timeout)
            message.status = "processing"
            return message
        except queue.Empty:
            return None

    def acknowledge(self, message: Message) -> bool:
        """메시지 수신 확인"""
        with self.lock:
            message.status = "completed"
        print(f"✅ [{message.sender}→{message.receiver}] 처리 완료")
        return True

    def get_stats(self) -> dict:
        """브로커 통계"""
        return {
            "queue_size": self.queue.qsize(),
            "total_messages": len(self.history),
            "history": self.history,
        }


# ============================================================================
# [3] Producer-Consumer 패턴
# ============================================================================

class Producer:
    """데이터를 생성하는 서비스"""

    def __init__(self, name: str, broker: MessageBroker):
        self.name = name
        self.broker = broker
        self.message_count = 0

    def produce(self, receiver: str, content: str) -> bool:
        """메시지 생성"""
        self.message_count += 1
        message = Message(
            id=f"{self.name}-{self.message_count}",
            sender=self.name,
            receiver=receiver,
            content=content,
        )
        return self.broker.publish(message)


class Consumer:
    """데이터를 소비하는 서비스"""

    def __init__(self, name: str, broker: MessageBroker):
        self.name = name
        self.broker = broker
        self.processed_count = 0

    def consume(self, timeout: float = 1.0) -> Optional[Message]:
        """메시지 소비"""
        message = self.broker.subscribe(timeout=timeout)
        if message:
            self.processed_count += 1
            self.broker.acknowledge(message)
            print(f"  🎯 [{self.name}] 처리됨: {message.content}")
            return message
        return None


