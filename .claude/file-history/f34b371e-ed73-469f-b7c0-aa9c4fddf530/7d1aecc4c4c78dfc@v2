# [5] 서킷 브레이커 (Circuit Breaker)
# ============================================================================

class CircuitBreakerState(Enum):
    """서킷 브레이커 상태"""
    CLOSED = "closed"        # 정상 작동
    OPEN = "open"           # 요청 차단
    HALF_OPEN = "half_open" # 회복 시도


class CircuitBreaker:
    """장애 전파를 방지하는 서킷 브레이커"""

    def __init__(self, failure_threshold: int = 5, timeout: float = 60.0):
        self.failure_threshold = failure_threshold
        self.timeout = timeout
        self.failure_count = 0
        self.last_failure_time = None
        self.state = CircuitBreakerState.CLOSED

    def call(self, func: Callable, *args, **kwargs) -> Optional[Any]:
        """함수 호출 (서킷 브레이커 보호)"""
        if self.state == CircuitBreakerState.OPEN:
            # 타임아웃 확인
            if time.time() - self.last_failure_time > self.timeout:
                self.state = CircuitBreakerState.HALF_OPEN
                print("⚡ 서킷 브레이커: HALF_OPEN (회복 시도 중)")
            else:
                print("🚫 서킷 브레이커: OPEN (요청 차단)")
                return None

        try:
            result = func(*args, **kwargs)
            if self.state == CircuitBreakerState.HALF_OPEN:
                self.state = CircuitBreakerState.CLOSED
                self.failure_count = 0
                print("✅ 서킷 브레이커: CLOSED (정상 복구)")
            return result
        except Exception as e:
            self.failure_count += 1
            self.last_failure_time = time.time()

            if self.failure_count >= self.failure_threshold:
                self.state = CircuitBreakerState.OPEN
                print(f"⚠️ 서킷 브레이커: OPEN (장애 감지 - {e})")

            raise


