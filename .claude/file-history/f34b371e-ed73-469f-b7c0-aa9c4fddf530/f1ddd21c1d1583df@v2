"""
v2.4 Modules and Packages - 모듈과 패키지

모듈과 패키지: 파이썬 고등학교 1학년
거인의 어깨 위에 올라타기 (표준 라이브러리 활용)
"""

# 1. 표준 라이브러리 불러오기
import math  # 수학 도구
import os  # 운영체제/파일 시스템 도구
from datetime import datetime  # 날짜/시간 도구
import random  # 랜덤 도구


def modules_and_packages_demo():
    """모듈과 패키지 데모"""

    # 2. 시간 기록 (기록이 증명이다)
    now = datetime.now()
    formatted_time = now.strftime("%Y-%m-%d %H:%M:%S")

    print(f"--- 시스템 현재 시각: {formatted_time} ---")

    # 3. 수학 도구 사용 (복잡한 연산)
    radius = 5
    area = math.pi * (radius ** 2)
    print(f"반지름이 {radius}인 원의 넓이: {area:.2f}")

    # 4. 파일 시스템 정보 확인
    current_path = os.getcwd()
    print(f"현재 작업 경로: {current_path}")

    # 5. 랜덤 도구 (무작위 실험 데이터 생성)
    experiment_id = random.randint(1000, 9999)
    print(f"생성된 실험 고유 ID: {experiment_id}")

    print("\n저장 필수 너는 기록이 증명이다 gogs")

    return {
        "timestamp": formatted_time,
        "time_object": now,
        "radius": radius,
        "area": area,
        "current_path": current_path,
        "experiment_id": experiment_id,
    }


def main():
    """v2.4 실행"""
    print("\n" + "="*70)
    print("🐍 Python v2.4: 모듈과 패키지 — 거인의 어깨 위에 올라타기")
    print("="*70 + "\n")

    modules_and_packages_demo()

    print("\n" + "="*70)


if __name__ == "__main__":
    main()
