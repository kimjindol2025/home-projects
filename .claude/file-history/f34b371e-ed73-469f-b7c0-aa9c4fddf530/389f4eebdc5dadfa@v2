/// Section 8: 결정론적 컴파일
fn section_8_deterministic_compilation() {
    println!("╔═══════════════════════════════════════════════════════════════════════════════╗");
    println!("║                   섹션 8: 결정론적 컴파일 검증                                ║");
    println!("║                                                                               ║");
    println!("║  \"10회 반복 컴파일, 해시 항상 동일\"                                        ║");
    println!("╚═══════════════════════════════════════════════════════════════════════════════╝\n");

    let program = make_compiler_gogs_program();
    let mut hashes = Vec::new();

    for i in 0..10 {
        let mut compiler = Compiler::new();
        compiler.compile(&program).unwrap();
        let bytecode = compiler.bytecode();

        // 간단한 FNV-1a 해시
        let mut hash: u64 = 14695981039346656037;
        for &byte in &bytecode.instructions {
            hash ^= byte as u64;
            hash = hash.wrapping_mul(1099511628211);
        }

        hashes.push(hash);
        println!("  컴파일 #{:2}: 해시 = {:#018x}", i + 1, hash);
    }

    let first_hash = hashes[0];
    let all_equal = hashes.iter().all(|&h| h == first_hash);

    println!("");
    println!("검증 결과:");
    if all_equal {
        println!("  ✅ 결정론적: 모든 컴파일이 동일한 해시 생성!");
    } else {
        println!("  ❌ 비결정론적: 해시가 서로 다름!");
    }
    println!();
}

