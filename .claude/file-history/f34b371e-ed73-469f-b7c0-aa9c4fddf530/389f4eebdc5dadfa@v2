/// Section 10: 바이너리 동일성 검증
fn section_10_binary_identity_verification() {
    println!("╔═══════════════════════════════════════════════════════════════════════════════╗");
    println!("║                   섹션 10: 바이너리 동일성 검증                               ║");
    println!("║                                                                               ║");
    println!("║  \"Stage1 bytecode == Stage2 bytecode (최종 증명)\"                          ║");
    println!("╚═══════════════════════════════════════════════════════════════════════════════╝\n");

    let program = make_compiler_gogs_program();
    let bootstrap = Bootstrap::new(program);

    match bootstrap.run() {
        Ok(result) => {
            let check = &result.binary_identity;
            println!("바이너리 동일성 검사:");
            println!("  • 해시 동일: {} ({:#018x})",
                if check.hashes_equal { "✓" } else { "✗" },
                check.stage1_hash
            );
            println!("  • 명령어 동일: {} ({} bytes)",
                if check.instructions_equal { "✓" } else { "✗" },
                check.instructions_len
            );
            println!("  • 상수 동일: {} ({} constants)",
                if check.constants_equal { "✓" } else { "✗" },
                check.constants_count
            );
            println!("");
            println!("최종 진단:");
            println!("  {}", check.diagnostic());
        }
        Err(e) => println!("❌ 검증 실패: {}", e),
    }
    println!();
}

