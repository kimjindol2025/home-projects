    let mut compiler = Compiler::new();
    compiler.compile(&program).unwrap();
    let bytecode = compiler.bytecode();

    println!("컴파일 결과:");
    println!("  • 로컬 변수 개수: {}", compiler.local_count());
    println!("  • 변수 'x' 인덱스: {:?}", compiler.get_local_index("x"));
    println!("  • 명령어 수: {} bytes", bytecode.instructions.len());
