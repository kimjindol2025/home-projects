    println!("");
    println!("바이트코드 구조:");
    println!("  1. OpConstant 42 (SET 준비)");
    println!("  2. OpSetLocal 0 (로컬[0] = 42)");
    println!("  3. OpGetLocal 0 (스택에 로컬[0] 푸시)");
