def test_parametrized_decorator():
    """파라미터가 있는 데코레이터"""
    def repeat(times):
        def decorator(func):
            @wraps(func)
            def wrapper(*args, **kwargs):
                results = []
                for _ in range(times):
                    results.append(func(*args, **kwargs))
                return results
            return wrapper
        return decorator

    @repeat(3)
    def get_value():
        return "X"

    assert get_value() == ["X", "X", "X"]


def test_decorator_with_args_and_kwargs():
    """파라미터와 옵션이 있는 데코레이터"""
    def repeat(times=1):
        def decorator(func):
            @wraps(func)
            def wrapper(*args, **kwargs):
                return [func(*args, **kwargs) for _ in range(times)]
            return wrapper
        return decorator

    @repeat(times=2)
    def get_value():
        return "Y"

    assert get_value() == ["Y", "Y"]


def test_conditional_decorator():
    """조건부 데코레이터"""
    def maybe_decorate(condition):
        def decorator(func):
            if condition:
                @wraps(func)
                def wrapper(*args, **kwargs):
                    return f"[DECORATED] {func(*args, **kwargs)}"
                return wrapper
            else:
                return func
        return decorator

    @maybe_decorate(True)
    def func1():
        return "result1"

    @maybe_decorate(False)
    def func2():
        return "result2"

    assert func1() == "[DECORATED] result1"
    assert func2() == "result2"


def test_decorator_with_state():
    """상태를 가진 데코레이터"""
    def counting_decorator(func):
        func.call_count = 0

        @wraps(func)
        def wrapper(*args, **kwargs):
            func.call_count += 1
            return func(*args, **kwargs)
        return wrapper

    @counting_decorator
    def greet(name):
        return f"Hello, {name}!"

    greet("Alice")
    greet("Bob")
    assert greet.call_count == 3


