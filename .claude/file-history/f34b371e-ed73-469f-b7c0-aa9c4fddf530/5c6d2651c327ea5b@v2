def test_timing_decorator():
    """실행 시간 측정"""
    def timing(func):
        @wraps(func)
        def wrapper(*args, **kwargs):
            start = time.time()
            result = func(*args, **kwargs)
            elapsed = time.time() - start
            wrapper.elapsed = elapsed
            return result
        return wrapper

    @timing
    def slow_func():
        time.sleep(0.01)
        return "done"

    result = slow_func()
    assert result == "done"
    assert slow_func.elapsed >= 0.01


def test_validation_decorator():
    """입력 검증"""
    def validate_positive(func):
        @wraps(func)
        def wrapper(x):
            if x <= 0:
                raise ValueError(f"Expected positive number, got {x}")
            return func(x)
        return wrapper

    @validate_positive
    def sqrt_approx(x):
        return x ** 0.5

    assert sqrt_approx(4) == 2.0

    with pytest.raises(ValueError):
        sqrt_approx(-1)


def test_caching_decorator():
    """결과 캐싱"""
    def cache(func):
        cache_dict = {}

        @wraps(func)
        def wrapper(*args):
            if args not in cache_dict:
                cache_dict[args] = func(*args)
            return cache_dict[args]
        return wrapper

    call_count = [0]

    @cache
    def expensive_func(x):
        call_count[0] += 1
        return x ** 2

    assert expensive_func(5) == 25
    assert expensive_func(5) == 25  # 캐시됨
    assert call_count[0] == 1  # 한 번만 호출됨


def test_retry_decorator():
    """재시도"""
    def retry(times=3):
        def decorator(func):
            @wraps(func)
            def wrapper(*args, **kwargs):
                for i in range(times):
                    try:
                        return func(*args, **kwargs)
                    except Exception:
                        if i == times - 1:
                            raise
            return wrapper
        return decorator

    attempt_count = [0]

    @retry(times=3)
    def unreliable_func():
        attempt_count[0] += 1
        if attempt_count[0] < 3:
            raise ValueError("Not yet!")
        return "success"

    assert unreliable_func() == "success"
    assert attempt_count[0] == 3


