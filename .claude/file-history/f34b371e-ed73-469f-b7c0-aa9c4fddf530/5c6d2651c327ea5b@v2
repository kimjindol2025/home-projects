def test_function_composition():
    """함수 합성"""
    def compose(f, g):
        return lambda x: f(g(x))

    def double(x):
        return x * 2

    def add_one(x):
        return x + 1

    composed = compose(double, add_one)
    assert composed(5) == 12  # (5+1)*2


def test_pipe():
    """파이프라인"""
    def pipe(x, *funcs):
        result = x
        for func in funcs:
            result = func(result)
        return result

    def add_one(x):
        return x + 1

    def double(x):
        return x * 2

    result = pipe(5, add_one, double)
    assert result == 12


def test_partial_application():
    """부분 적용"""
    from functools import partial

    def multiply(x, y):
        return x * y

    double = partial(multiply, 2)
    triple = partial(multiply, 3)

    assert double(5) == 10
    assert triple(5) == 15


