def test_decorator_with_higher_order():
    """데코레이터 + 고차 함수"""
    def memoize(func):
        cache = {}

        @wraps(func)
        def wrapper(*args):
            if args not in cache:
                cache[args] = func(*args)
            return cache[args]
        return wrapper

    @memoize
    def factorial(n):
        if n <= 1:
            return 1
        return n * factorial(n - 1)

    assert factorial(5) == 120
    assert factorial(10) == 3628800


def test_nested_decorators():
    """중첩 데코레이터"""
    def add_brackets(func):
        @wraps(func)
        def wrapper(*args, **kwargs):
            return f"[{func(*args, **kwargs)}]"
        return wrapper

    def add_parens(func):
        @wraps(func)
        def wrapper(*args, **kwargs):
            return f"({func(*args, **kwargs)})"
        return wrapper

    @add_brackets
    @add_parens
    def greet(name):
        return f"Hello {name}"

    assert greet("Alice") == "[(Hello Alice)]"


def test_first_class_comprehensive():
    """종합 테스트"""
    def apply_operations(x, ops):
        """함수들의 리스트를 순차 적용"""
        result = x
        for op in ops:
            result = op(result)
        return result

    operations = [
        lambda x: x + 10,
        lambda x: x * 2,
        lambda x: x - 5,
    ]

    result = apply_operations(3, operations)
    assert result == 21  # ((3+10)*2)-5
