def test_decorator_application():
    """데코레이터 적용"""
    def simple_decorator(func):
        def wrapper(*args, **kwargs):
            return func(*args, **kwargs)
        return wrapper

    @simple_decorator
    def greet(name):
        return f"Hello, {name}!"

    assert greet("Alice") == "Hello, Alice!"


def test_decorator_wrapping():
    """데코레이터 래핑"""
    call_log = []

    def logger(func):
        def wrapper(*args, **kwargs):
            call_log.append(f"Calling {func.__name__}")
            return func(*args, **kwargs)
        return wrapper

    @logger
    def greet(name):
        return f"Hello, {name}!"

    result = greet("Bob")
    assert result == "Hello, Bob!"
    assert "Calling greet" in call_log


def test_decorator_preserves_metadata():
    """@wraps로 메타데이터 보존"""
    def preserve_metadata(func):
        @wraps(func)
        def wrapper(*args, **kwargs):
            return func(*args, **kwargs)
        return wrapper

    @preserve_metadata
    def documented_func():
        """This is documented"""
        pass

    assert documented_func.__name__ == "documented_func"
    assert documented_func.__doc__ == "This is documented"


def test_decorator_with_return_value():
    """데코레이터가 반환값 처리"""
    def add_suffix(func):
        @wraps(func)
        def wrapper(*args, **kwargs):
            result = func(*args, **kwargs)
            return f"{result}!"
        return wrapper

    @add_suffix
    def greet(name):
        return f"Hello, {name}"

    assert greet("Alice") == "Hello, Alice!"


def test_multiple_decorators():
    """여러 데코레이터"""
    def first(func):
        @wraps(func)
        def wrapper(*args, **kwargs):
            result = func(*args, **kwargs)
            return f"[FIRST:{result}]"
        return wrapper

    def second(func):
        @wraps(func)
        def wrapper(*args, **kwargs):
            result = func(*args, **kwargs)
            return f"[SECOND:{result}]"
        return wrapper

    @first
    @second
    def greet(name):
        return name

    result = greet("Alice")
    assert "FIRST" in result and "SECOND" in result


