def test_return_function():
    """함수를 반환"""
    def make_adder(n):
        def adder(x):
            return x + n
        return adder

    add5 = make_adder(5)
    assert add5(10) == 15
    assert add5(20) == 25


def test_closure_variable():
    """클로저: 변수 기억"""
    def outer(x):
        def inner(y):
            return x + y
        return inner

    add10 = outer(10)
    assert add10(5) == 15
    assert add10(20) == 30


def test_multiple_closures():
    """여러 클로저"""
    def make_multiplier(n):
        def multiplier(x):
            return x * n
        return multiplier

    double = make_multiplier(2)
    triple = make_multiplier(3)

    assert double(5) == 10
    assert triple(5) == 15


def test_closure_independence():
    """클로저 독립성"""
    def make_counter():
        count = 0
        def counter():
            nonlocal count
            count += 1
            return count
        return counter

    c1 = make_counter()
    c2 = make_counter()

    assert c1() == 1
    assert c1() == 2
    assert c2() == 1


def test_return_lambda():
    """람다 반환"""
    def make_multiplier(n):
        return lambda x: x * n

    double = make_multiplier(2)
    assert double(5) == 10


