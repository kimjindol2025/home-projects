def test_function_assignment():
    """함수를 변수에 할당"""
    def greet(name):
        return f"Hello, {name}!"

    greeting = greet
    assert greeting is greet
    assert greeting("Alice") == "Hello, Alice!"


def test_function_in_list():
    """함수를 리스트에 저장"""
    def add(x, y):
        return x + y

    def multiply(x, y):
        return x * y

    ops = [add, multiply]
    assert ops[0](2, 3) == 5
    assert ops[1](2, 3) == 6


def test_function_in_dict():
    """함수를 딕셔너리에 저장"""
    def square(x):
        return x ** 2

    def cube(x):
        return x ** 3

    funcs = {"square": square, "cube": cube}
    assert funcs["square"](3) == 9
    assert funcs["cube"](3) == 27


def test_function_comparison():
    """함수 비교"""
    def func1():
        pass

    func2 = func1
    func3 = lambda: None

    assert func1 is func2
    assert func1 is not func3


def test_function_identity():
    """함수의 정체성"""
    def my_func():
        pass

    assert callable(my_func)
    assert id(my_func) == id(my_func)


