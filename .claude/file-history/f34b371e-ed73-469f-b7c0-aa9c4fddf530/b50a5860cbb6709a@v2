class InfiniteSequenceAnalysis:
    """무한 수열 분석"""

    @staticmethod
    def take(gen: Generator, n: int) -> list:
        """제너레이터에서 처음 n개 값을 취함"""
        return [next(gen) for _ in range(n)]

    @staticmethod
    def demonstrate_sequences():
        """다양한 무한 수열"""
        print("\n" + "="*70)
        print("다양한 무한 수열")
        print("="*70)

        print("\n  [1. 자연수]")
        nat = InfiniteSequences.natural_numbers()
        print(f"    {InfiniteSequenceAnalysis.take(nat, 10)}")

        print("\n  [2. 짝수]")
        even = InfiniteSequences.even_numbers()
        print(f"    {InfiniteSequenceAnalysis.take(even, 10)}")

        print("\n  [3. 2의 거듭제곱]")
        powers = InfiniteSequences.powers_of_two()
        print(f"    {InfiniteSequenceAnalysis.take(powers, 10)}")

        print("\n  [4. 피보나치]")
        fib = InfiniteSequences.fibonacci_infinite()
        print(f"    {InfiniteSequenceAnalysis.take(fib, 10)}")

        print("\n  [5. 소수]")
        primes = InfiniteSequences.primes()
        print(f"    {InfiniteSequenceAnalysis.take(primes, 10)}")

        print("\n  [메모리 점검]")
        for name, gen in [
            ("natural_numbers", InfiniteSequences.natural_numbers()),
            ("even_numbers", InfiniteSequences.even_numbers()),
            ("powers_of_two", InfiniteSequences.powers_of_two()),
            ("fibonacci_infinite", InfiniteSequences.fibonacci_infinite()),
            ("primes", InfiniteSequences.primes()),
        ]:
            size = sys.getsizeof(gen)
            print(f"    {name:20} : {size:,} bytes (고정!)")

        print("\n" + "="*70)

    @staticmethod
    def demonstrate_infinite_chain():
        """무한 수열의 연쇄"""
        print("\n" + "="*70)
        print("무한 수열의 변환 (Lazy Chaining)")
        print("="*70)

        def square_of(gen: Generator) -> Generator:
            """제너레이터의 각 값을 제곱"""
            for value in gen:
                yield value * value

        def filter_even(gen: Generator) -> Generator:
            """짝수만 필터링"""
            for value in gen:
                if value % 2 == 0:
                    yield value

        print("\n  [무한 자연수 → 제곱 → 짝수 필터]")
        nat = InfiniteSequences.natural_numbers()
        squared = square_of(nat)
        evens = filter_even(squared)

        print(f"    natural_numbers() | square() | filter_even()")
        print(f"    처음 10개: {InfiniteSequenceAnalysis.take(evens, 10)}")

        print("\n  [메모리 효율]")
        print(f"    각 변환 단계: {sys.getsizeof(nat):,} bytes (일정)")
        print(f"    총 메모리: 상수 (O(1)) - 값이 얼마나 크든 무관!")

        print("\n" + "="*70)

    @staticmethod
    def demonstrate_practical_use():
        """실제 활용"""
        print("\n" + "="*70)
        print("실제 활용: 로그 스트림 처리")
        print("="*70)

        def read_log_stream() -> Generator[str, None, None]:
            """
            무한 로그 스트림 시뮬레이션
            """
            import random
            counter = 0
            while True:
                status = random.choice(["INFO", "WARNING", "ERROR"])
                message = f"[{status}] Event {counter}"
                yield message
                counter += 1

        def filter_errors(gen: Generator) -> Generator[str, None, None]:
            """에러만 필터링"""
            for line in gen:
                if "ERROR" in line:
                    yield line

        print("\n  [무한 로그 스트림]")
        print("    logs = read_log_stream()  # 영원히 계속되는 스트림")
        print("    errors = filter_errors(logs)  # ERROR만 추출")
        print("    for error in errors:")
        print("        alert(error)  # 실시간 알림")

        print("\n  [메모리 특성]")
        print("    - 로그가 얼마나 많든: 메모리는 일정")
        print("    - 필터링도 즉시: 게으른 처리")
        print("    - 실시간 반응: 값이 필요할 때만 계산")

        print("\n" + "="*70)


