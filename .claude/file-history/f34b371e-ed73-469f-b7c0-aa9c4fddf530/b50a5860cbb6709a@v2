"""
v1.2 증명: 무한 수열

"리스트는 무한할 수 없지만, 제너레이터는 논리적으로 무한한 기록을 담을 수 있다."

메모리는 유한하지만, 제너레이터는 무한한 규칙을 표현합니다.
"""

import sys
from typing import Generator, Tuple
import time


class InfiniteSequences:
    """무한 수열 생성기"""

    @staticmethod
    def natural_numbers() -> Generator[int, None, None]:
        """
        자연수: 1, 2, 3, 4, ...

        Yields:
            무한 자연수 스트림
        """
        n = 0
        while True:
            yield n
            n += 1

    @staticmethod
    def even_numbers() -> Generator[int, None, None]:
        """
        짝수: 0, 2, 4, 6, ...
        """
        n = 0
        while True:
            yield n
            n += 2

    @staticmethod
    def powers_of_two() -> Generator[int, None, None]:
        """
        2의 거듭제곱: 1, 2, 4, 8, 16, ...
        """
        power = 1
        while True:
            yield power
            power *= 2

    @staticmethod
    def fibonacci_infinite() -> Generator[int, None, None]:
        """
        피보나치 수열 (무한)
        """
        a, b = 0, 1
        while True:
            yield a
            a, b = b, a + b

    @staticmethod
    def primes() -> Generator[int, None, None]:
        """
        소수: 2, 3, 5, 7, 11, ...

        Sieve of Eratosthenes를 사용한 무한 소수 생성
        """
        yield 2
        candidates = natural_numbers()
        next(candidates)  # 0, 1 스킵
        next(candidates)  # 2 스킵

        found_primes = []

        for candidate in candidates:
            is_prime = True
            for prime in found_primes:
                if prime * prime > candidate:
                    break
                if candidate % prime == 0:
                    is_prime = False
                    break

            if is_prime:
                found_primes.append(candidate)
                yield candidate

    @staticmethod
    def demonstrate_finite_vs_infinite():
        """유한 vs 무한의 개념적 차이"""
        print("\n" + "="*70)
        print("개념: 유한 vs 무한")
        print("="*70)

        print("\n  [유한 수열 (리스트)]")
        finite_list = [i for i in range(10)]
        print(f"    finite_list = [0, 1, 2, ..., 9]")
        print(f"    Length: {len(finite_list)}")
        print(f"    Memory: {sys.getsizeof(finite_list):,} bytes")

        print("\n  [무한 수열 (제너레이터)]")
        infinite_gen = InfiniteSequences.natural_numbers()
        print(f"    infinite_gen = natural_numbers()")
        print(f"    Length: ∞ (정의할 수 없음)")
        print(f"    Memory: {sys.getsizeof(infinite_gen):,} bytes (고정!)")

        print("\n  [논리적 의미]")
        print("    - 유한: 끝이 있는 데이터")
        print("    - 무한: 끝이 없지만 패턴이 명확한 규칙")
        print("    - 제너레이터: 무한한 규칙을 유한한 메모리에 담음")

        print("\n" + "="*70)

    @staticmethod
    def demonstrate_on_demand():
        """필요할 때마다 생성"""
        print("\n" + "="*70)
        print("필요할 때마다 생성: On-Demand Generation")
        print("="*70)

        print("\n  [1단계: 제너레이터 생성 (규칙만 저장)]")
        gen = InfiniteSequences.natural_numbers()
        print(f"    gen = natural_numbers()")
        print(f"    메모리: {sys.getsizeof(gen):,} bytes (포인터 + 상태)")

        print("\n  [2단계: 필요한 값 요청]")
        print(f"    next(gen) → {next(gen)}")
        print(f"    next(gen) → {next(gen)}")
        print(f"    next(gen) → {next(gen)}")
        print(f"    (계산 비용 발생, 하지만 메모리 추가 할당 없음)")

        print("\n  [특징]")
        print("    - 요청 전: 메모리 거의 0")
        print("    - 요청 시: 계산하여 값 반환")
        print("    - 메모리: 항상 일정 (현재 상태만)")

        print("\n" + "="*70)

