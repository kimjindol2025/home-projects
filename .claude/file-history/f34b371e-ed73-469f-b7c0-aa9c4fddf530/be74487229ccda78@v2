class TestAuthenticationEngine(unittest.TestCase):
    """인증 엔진 테스트"""

    def setUp(self):
        self.auth = AuthenticationEngine()

    def test_register_success(self):
        """회원가입 성공"""
        ok, msg = self.auth.register("alice", "alice@example.com", "SecurePass123")
        self.assertTrue(ok)

    def test_register_weak_password(self):
        """회원가입 약한 비밀번호"""
        ok, msg = self.auth.register("bob", "bob@example.com", "weak")
        self.assertFalse(ok)

    def test_register_duplicate_username(self):
        """회원가입 중복 사용자명"""
        self.auth.register("charlie", "charlie@example.com", "SecurePass123")
        ok, msg = self.auth.register("charlie", "other@example.com", "SecurePass123")
        self.assertFalse(ok)

    def test_login_success(self):
        """로그인 성공"""
        self.auth.register("alice", "alice@example.com", "SecurePass123")
        ok, msg = self.auth.login("alice", "SecurePass123")
        self.assertTrue(ok)

    def test_login_wrong_password(self):
        """로그인 틀린 비밀번호"""
        self.auth.register("alice", "alice@example.com", "SecurePass123")
        ok, msg = self.auth.login("alice", "WrongPassword")
        self.assertFalse(ok)

    def test_login_nonexistent_user(self):
        """로그인 없는 사용자"""
        ok, msg = self.auth.login("nonexistent", "AnyPassword123")
        self.assertFalse(ok)

    def test_account_lockout_after_failures(self):
        """실패 후 계정 잠금"""
        self.auth.register("alice", "alice@example.com", "SecurePass123")

        # 5회 실패
        for i in range(5):
            self.auth.login("alice", "WrongPassword")

        # 6번째 시도 → 계정 잠금
        ok, msg = self.auth.login("alice", "SecurePass123")
        self.assertFalse(ok)
        self.assertIn("locked", msg.lower())

    def test_password_complexity_requirements(self):
        """비밀번호 복잡성 요구사항"""
        tests = [
            ("lowercase", False),  # 소문자만
            ("UPPERCASE", False),  # 대문자만
            ("NoNumbers", False),  # 숫자 없음
            ("Pass1", False),       # 8자 미만
            ("ValidPass1", True),   # 모든 요구사항 충족
        ]

        for password, should_pass in tests:
            ok, _ = self.auth.register(f"user_{password}", "email@test.com", password)
            self.assertEqual(ok, should_pass)

    def test_auth_demo(self):
        """인증 데모"""
        result = self.auth.demo()
        self.assertTrue(result["registration"])
        self.assertTrue(result["login_success"])


