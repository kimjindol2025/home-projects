class TestSecurityPrinciples(unittest.TestCase):
    """보안 원칙 테스트"""

    def test_hashing_irreversible(self):
        """해싱 비가역성"""
        password = "MySecretPassword123"
        hashed, _ = HashingEngine.pbkdf2(password)

        # 해시에서 원본을 복원할 수 없음
        # (하지만 입력과 비교는 가능)
        verified = HashingEngine.verify_pbkdf2(hashed, password)
        self.assertTrue(verified)

    def test_authentication_first_then_authorization(self):
        """인증 먼저, 그 후 인가"""
        # 인증 없이 인가 확인 시도
        # 이는 먼저 사용자를 인증한 후 권한을 확인해야 함

        auth = AuthenticationEngine()
        auth.register("user", "user@test.com", "SecurePass123")
        ok, _ = auth.login("user", "SecurePass123")

        # 인증 성공 후 권한 확인
        self.assertTrue(ok)
        has_read = RBAC.has_permission(Role.USER, Permission.READ)
        self.assertTrue(has_read)

    def test_least_privilege_principle(self):
        """최소 권한 원칙"""
        # 일반 사용자는 최소한의 권한만
        user_perms = RBAC.get_permissions(Role.USER)
        self.assertEqual(len(user_perms), 1)
        self.assertEqual(user_perms[0], Permission.READ)

        # 관리자는 더 많은 권한
        admin_perms = RBAC.get_permissions(Role.ADMIN)
        self.assertGreater(len(admin_perms), len(user_perms))

    def test_defense_in_depth(self):
        """깊이 있는 방어"""
        # 단일 방어가 아닌 여러 계층의 방어
        framework = SecurityFramework("secret")

        # 계층 1: 인증
        framework.auth.register("user", "user@test.com", "SecurePass123")

        # 계층 2: Rate Limiting
        limiter = framework.rate_limiter

        # 계층 3: 감사 로깅
        framework.audit.log("user", "ACTION", "resource", "SUCCESS")

        # 모든 계층이 작동
        self.assertGreater(len(framework.auth.users), 0)
        self.assertGreater(len(framework.audit.logs), 0)


