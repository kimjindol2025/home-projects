        """보안 로그인 요청 제한"""
        self.framework.auth.register("alice", "alice@example.com", "SecurePass123")

        # 100개 이상의 로그인 시도로 rate limit 초과
        for i in range(101):
            self.framework.secure_login("alice", "SecurePass123", "192.168.1.1")

        # 다음 요청 차단
        ok, token = self.framework.secure_login("alice", "SecurePass123", "192.168.1.1")
        self.assertFalse(ok)

    def test_framework_demo(self):
        """프레임워크 데모"""
