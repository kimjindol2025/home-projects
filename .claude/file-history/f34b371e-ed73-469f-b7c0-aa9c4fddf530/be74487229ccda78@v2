class TestTokenEngine(unittest.TestCase):
    """토큰 엔진 테스트"""

    def setUp(self):
        self.engine = TokenEngine("secret_key_123")

    def test_token_generation(self):
        """토큰 생성"""
        token = self.engine.generate_token({"user_id": "user_123"})
        self.assertIsNotNone(token)
        self.assertIn(".", token)

    def test_token_verification_valid(self):
        """토큰 검증 유효"""
        token = self.engine.generate_token({"user_id": "user_123"})
        data = self.engine.verify_token(token)

        self.assertIsNotNone(data)
        self.assertEqual(data["user_id"], "user_123")

    def test_token_verification_invalid(self):
        """토큰 검증 무효"""
        data = self.engine.verify_token("invalid_token")
        self.assertIsNone(data)

    def test_token_tampering_detection(self):
        """토큰 변조 탐지"""
        token = self.engine.generate_token({"user_id": "user_123"})

        # 토큰 변조
        tampered = token[:-10] + "0" * 10
        data = self.engine.verify_token(tampered)

        self.assertIsNone(data)

    def test_token_expiration(self):
        """토큰 만료"""
        # 만료시간 -1 (이미 만료됨)
        token = self.engine.generate_token({"user_id": "user_123"}, expires_in=-1)
        data = self.engine.verify_token(token)

        self.assertIsNone(data)

    def test_token_demo(self):
        """토큰 엔진 데모"""
        result = self.engine.demo()
        self.assertTrue(result["token_created"])
        self.assertTrue(result["token_verified"])
        self.assertTrue(result["invalid_rejected"])


