class TestAuditEngine(unittest.TestCase):
    """감사 엔진 테스트"""

    def setUp(self):
        self.audit = AuditEngine()

    def test_audit_log_creation(self):
        """감사 로그 생성"""
        self.audit.log("user_123", "LOGIN", "auth", "SUCCESS")
        logs = self.audit.get_logs()
        self.assertEqual(len(logs), 1)

    def test_audit_log_details(self):
        """감사 로그 세부사항"""
        self.audit.log("user_123", "DELETE", "file_456", "DENIED", {"reason": "insufficient_permissions"})
        logs = self.audit.get_logs()

        self.assertEqual(logs[0]["user_id"], "user_123")
        self.assertEqual(logs[0]["action"], "DELETE")
        self.assertEqual(logs[0]["resource"], "file_456")
        self.assertEqual(logs[0]["result"], "DENIED")

    def test_audit_filter_by_user(self):
        """감사 로그 사용자 필터"""
        self.audit.log("user_1", "LOGIN", "auth", "SUCCESS")
        self.audit.log("user_2", "LOGIN", "auth", "SUCCESS")
        self.audit.log("user_1", "READ", "file", "SUCCESS")

        user1_logs = self.audit.get_logs("user_1")
        self.assertEqual(len(user1_logs), 2)

    def test_audit_timestamp(self):
        """감사 로그 타임스탬프"""
        self.audit.log("user", "ACTION", "resource", "SUCCESS")
        logs = self.audit.get_logs()

        self.assertIn("timestamp", logs[0])
        self.assertIsNotNone(logs[0]["timestamp"])

    def test_audit_demo(self):
        """감사 엔진 데모"""
        result = AuditEngine().demo()
        self.assertGreater(result["total_logs"], 0)


