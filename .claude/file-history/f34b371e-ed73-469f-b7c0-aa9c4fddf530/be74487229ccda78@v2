class TestRBAC(unittest.TestCase):
    """역할 기반 접근 제어 테스트"""

    def test_user_permissions(self):
        """사용자 역할 권한"""
        self.assertTrue(RBAC.has_permission(Role.USER, Permission.READ))
        self.assertFalse(RBAC.has_permission(Role.USER, Permission.WRITE))
        self.assertFalse(RBAC.has_permission(Role.USER, Permission.DELETE))

    def test_moderator_permissions(self):
        """중재자 역할 권한"""
        self.assertTrue(RBAC.has_permission(Role.MODERATOR, Permission.READ))
        self.assertTrue(RBAC.has_permission(Role.MODERATOR, Permission.WRITE))
        self.assertFalse(RBAC.has_permission(Role.MODERATOR, Permission.DELETE))

    def test_admin_permissions(self):
        """관리자 역할 권한"""
        perms = RBAC.get_permissions(Role.ADMIN)
        self.assertIn(Permission.READ, perms)
        self.assertIn(Permission.WRITE, perms)
        self.assertIn(Permission.DELETE, perms)
        self.assertIn(Permission.ADMIN, perms)

    def test_get_permissions_list(self):
        """권한 리스트"""
        user_perms = RBAC.get_permissions(Role.USER)
        self.assertEqual(len(user_perms), 1)
        self.assertEqual(user_perms[0], Permission.READ)


class TestABAC(unittest.TestCase):
    """속성 기반 접근 제어 테스트"""

    def test_abac_department_match(self):
        """ABAC 부서 일치"""
        result = ABAC.demo()
        self.assertTrue(result["can_access"])

    def test_abac_cross_department(self):
        """ABAC 다른 부서"""
        user = {"id": "user", "department": "sales", "level": 3}
        resource = {"id": "res", "department": "engineering", "level": 2}
        policy = {
            "conditions": [
                {"attribute": "department", "operator": "==", "value": "engineering"}
            ]
        }

        self.assertFalse(ABAC.can_access(user, resource, policy))

    def test_abac_level_requirement(self):
        """ABAC 레벨 요구사항"""
        user = {"level": 2}
        resource = {"level": 3}
        policy = {
            "conditions": [
                {"attribute": "level", "operator": ">=", "value": 3}
            ]
        }

        self.assertFalse(ABAC.can_access(user, resource, policy))


