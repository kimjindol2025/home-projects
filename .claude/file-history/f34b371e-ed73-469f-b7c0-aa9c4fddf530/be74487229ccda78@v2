        self.framework.auth.register("alice", "alice@example.com", "SecurePass123")
        ok, token = self.framework.secure_login("alice", "SecurePass123", "192.168.1.1")

        self.assertTrue(ok)
        self.assertIsNotNone(token)

    def test_secure_login_wrong_password(self):
        """보안 로그인 틀린 비밀번호"""
        self.framework.auth.register("alice", "alice@example.com", "SecurePass123")
        ok, token = self.framework.secure_login("alice", "WrongPassword", "192.168.1.1")

        self.assertFalse(ok)
