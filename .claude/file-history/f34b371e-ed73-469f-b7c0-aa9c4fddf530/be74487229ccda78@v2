class TestHashingEngine(unittest.TestCase):
    """해싱 엔진 테스트"""

    def test_sha256_basic(self):
        """SHA-256 기본 해싱"""
        hash1 = HashingEngine.sha256("password123")
        self.assertIsNotNone(hash1)
        self.assertEqual(len(hash1), 64)  # SHA-256은 64자

    def test_sha256_deterministic(self):
        """SHA-256 결정론성"""
        hash1 = HashingEngine.sha256("password123")
        hash2 = HashingEngine.sha256("password123")
        self.assertEqual(hash1, hash2)

    def test_sha256_different_input(self):
        """SHA-256 다른 입력"""
        hash1 = HashingEngine.sha256("password123")
        hash2 = HashingEngine.sha256("password124")
        self.assertNotEqual(hash1, hash2)

    def test_pbkdf2_salt_generation(self):
        """PBKDF2 솔트 생성"""
        stored1, salt1 = HashingEngine.pbkdf2("password")
        stored2, salt2 = HashingEngine.pbkdf2("password")

        # 같은 비밀번호도 다른 솔트 = 다른 해시
        self.assertNotEqual(stored1, stored2)

    def test_pbkdf2_verification_correct(self):
        """PBKDF2 올바른 비밀번호 검증"""
        stored, _ = HashingEngine.pbkdf2("mypassword")
        verified = HashingEngine.verify_pbkdf2(stored, "mypassword")
        self.assertTrue(verified)

    def test_pbkdf2_verification_wrong(self):
        """PBKDF2 틀린 비밀번호 검증"""
        stored, _ = HashingEngine.pbkdf2("mypassword")
        verified = HashingEngine.verify_pbkdf2(stored, "wrongpassword")
        self.assertFalse(verified)

    def test_pbkdf2_rainbow_table_resistance(self):
        """PBKDF2 레인보우 테이블 저항"""
        # 같은 비밀번호라도 다른 솔트 = 다른 해시
        stored1, _ = HashingEngine.pbkdf2("password")
        stored2, _ = HashingEngine.pbkdf2("password")

        self.assertNotEqual(stored1, stored2)

    def test_hashing_demo(self):
        """해싱 데모"""
        result = HashingEngine.demo()
        self.assertTrue(result["login_correct"])
        self.assertFalse(result["login_wrong"])


