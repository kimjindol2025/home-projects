class TestRateLimiter(unittest.TestCase):
    """요청 제한 테스트"""

    def test_rate_limiter_allows_requests(self):
        """요청 제한 허용"""
        limiter = RateLimiter(max_requests=3, window_seconds=60)

        self.assertTrue(limiter.is_allowed("user1"))
        self.assertTrue(limiter.is_allowed("user1"))
        self.assertTrue(limiter.is_allowed("user1"))

    def test_rate_limiter_rejects_excess(self):
        """요청 제한 거부"""
        limiter = RateLimiter(max_requests=3, window_seconds=60)

        for _ in range(3):
            limiter.is_allowed("user1")

        self.assertFalse(limiter.is_allowed("user1"))

    def test_rate_limiter_separate_users(self):
        """요청 제한 사용자 분리"""
        limiter = RateLimiter(max_requests=2, window_seconds=60)

        limiter.is_allowed("user1")
        limiter.is_allowed("user1")

        # user2는 독립적
        self.assertTrue(limiter.is_allowed("user2"))
        self.assertTrue(limiter.is_allowed("user2"))
        self.assertFalse(limiter.is_allowed("user2"))

    def test_rate_limiter_window_reset(self):
        """요청 제한 윈도우 리셋"""
        limiter = RateLimiter(max_requests=1, window_seconds=1)

        self.assertTrue(limiter.is_allowed("user1"))
        self.assertFalse(limiter.is_allowed("user1"))

        # 1초 대기 후 윈도우 리셋
        time.sleep(1.1)
        self.assertTrue(limiter.is_allowed("user1"))

    def test_rate_limiter_get_remaining(self):
        """요청 제한 남은 요청 수"""
        limiter = RateLimiter(max_requests=5, window_seconds=60)

        limiter.is_allowed("user1")
        limiter.is_allowed("user1")

        remaining = limiter.get_remaining("user1")
        self.assertEqual(remaining, 3)


