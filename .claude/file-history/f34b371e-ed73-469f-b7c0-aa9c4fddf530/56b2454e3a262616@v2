def demonstrate_simple_generator():
    """가장 단순한 제너레이터"""
    print("\n【 가장 단순한 제너레이터 】")

    print("\n1단계: 일반 함수")
    print("""
    def count_up(n):
        i = 0
        while i < n:
            print(i)
            i += 1
    count_up(3)
    # 출력: 0, 1, 2 (즉시 모두 출력)
    """)

    print("\n2단계: 제너레이터로 변환 (return → yield)")
    print("""
    def count_generator(n):
        i = 0
        while i < n:
            yield i
            i += 1
    gen = count_generator(3)
    """)

    print("\n3단계: next() 또는 for로 순회")
    print("""
    for num in gen:
        print(num)
    # 출력: 0, 1, 2 (필요할 때만 생성)
    """)

    # 실제 실행
    def count_generator(n):
        i = 0
        while i < n:
            yield i
            i += 1

    print("\n【 실제 실행 】")
    gen = count_generator(3)
    for num in gen:
        print(f"  {num}")


def demonstrate_memory_efficiency():
    """메모리 효율성 비교"""
    print("\n【 메모리 효율성 비교 】")

    # 리스트 생성 및 메모리 측정
    n = 1000000
    list_data = list(range(n))
    list_size = sys.getsizeof(list_data)

    # 제너레이터 생성 및 메모리 측정
    gen_data = (x for x in range(n))
    gen_size = sys.getsizeof(gen_data)

    print(f"\n100만 개 숫자 저장:")
    print(f"  리스트 크기: {list_size:,} bytes ({list_size / (1024*1024):.2f} MB)")
    print(f"  제너레이터 크기: {gen_size} bytes")
    print(f"  효율성 비: {list_size / gen_size:.0f}배")
    print(f"  메모리 절약: {(list_size - gen_size) / (1024*1024):.2f} MB")


def demonstrate_generator_expressions():
    """제너레이터 표현식"""
    print("\n【 제너레이터 표현식 vs 리스트 컴프리헨션 】")

    print("""
    # 리스트 컴프리헨션 (모든 값을 미리 계산)
    list_comp = [x*2 for x in range(10)]
    # → 메모리: 전체 80 bytes + 리스트 구조

    # 제너레이터 표현식 (필요할 때만 계산)
    gen_expr = (x*2 for x in range(10))
    # → 메모리: 제너레이터 객체만 (약 128 bytes)
    """)

    list_comp = [x * 2 for x in range(10)]
    gen_expr = (x * 2 for x in range(10))

    print(f"\n실제 크기:")
    print(f"  list_comp: {sys.getsizeof(list_comp)} bytes")
    print(f"  gen_expr: {sys.getsizeof(gen_expr)} bytes")


def demonstrate_infinite_sequence():
    """무한 수열"""
    print("\n【 무한 수열 】")

    print("""
    # 무한 카운터 - 끝이 없다!
    def infinite_counter(start=0):
        n = start
        while True:
            yield n
            n += 1

    counter = infinite_counter(10)
    for _ in range(5):
        print(next(counter))  # 10, 11, 12, 13, 14
    """)

    def infinite_counter(start=0):
        n = start
        while True:
            yield n
            n += 1

    print("\n실제 실행 (처음 5개만):")
    counter = infinite_counter(100)
    for _ in range(5):
        print(f"  {next(counter)}")


def demonstrate_practical_example():
    """실제 응용: 대용량 파일 읽기"""
    print("\n【 실제 응용: 대용량 파일 처리 】")

    print("""
    # 대용량 파일을 메모리에 올리지 않고 청크로 읽기
    def read_large_file(filepath, chunk_size=1024):
        with open(filepath, 'r') as f:
            while True:
                chunk = f.read(chunk_size)
                if not chunk:
                    break
                yield chunk

    # 사용: 메모리 사용량이 항상 chunk_size 이하
    for chunk in read_large_file('huge_file.txt'):
        process(chunk)

    이점:
    • 파일 크기와 무관하게 메모리 사용량 일정
    • 1GB 파일도 1KB 메모리로 처리 가능!
    • 프로세스가 중단되어도 그 지점부터 재개 가능
    """)


