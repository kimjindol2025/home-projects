import sys


def explain_generator_concept():
    """제너레이터 개념 설명"""
    print("=" * 70)
    print("🎓 제너레이터의 마법: 게으른 연산(Lazy Evaluation)")
    print("=" * 70)

    print("\n【 기본 원리 】")
    print("""
제너레이터는 함수와 달리 return 대신 yield를 사용합니다.
yield를 만나면 일시 정지했다가, next()를 호출하면 재개합니다.

예: 함수 vs 제너레이터

    # 함수 - 모든 값을 미리 계산
    def make_list():
        result = []
        for i in range(1000000):
            result.append(i)
        return result

    # 제너레이터 - 필요할 때만 계산
    def make_generator():
        for i in range(1000000):
            yield i

메모리 사용:
    list_result = make_list()          # 약 8MB 메모리 필요!
    gen_result = make_generator()      # 약 192 bytes만 필요!
    """)


