@measure_execution_time
async def main():
    """
    Gogs 중앙 데이터 센터 통합 시스템 테스트

    시나리오:
    1. 100개의 데이터를 비동기로 동시 수집 (v4.1)
    2. 수집 중 일부 데이터 손상 (예: data_id % 7 == 0)
    3. 예외 발생 시 시스템은 계속 실행 (v2.1)
    4. 통계 집계 (v2.2)
    5. 정렬된 데이터에서 이진 탐색 (v5.1)
    """

    print("\n" + "="*70)
    print("🛠️  시스템 통합 점검 시작")
    print("="*70)

    analyzer = GogsAnalyzer()

    # 1️⃣ 100개의 데이터를 비동기로 동시 처리 (v4.1)
    # asyncio.gather: 모든 코루틴을 동시에 실행하고 결과를 모음
    print("\n【 Phase 1: 비동기 데이터 수집 】")
    print(f"⏳ 100개 데이터 동시 수집 중...\n")

    tasks = [analyzer.process_data(i) for i in range(100)]
    results = await asyncio.gather(*tasks)

    # 2️⃣ 수집 결과 분석 (v2.1 + v2.2)
    print("\n【 Phase 2: 수집 결과 분석 】")
    stats = analyzer.get_statistics()
    print(f"✅ 성공: {stats['successful']}건")
    print(f"❌ 실패: {stats['failed']}건")
    print(f"📊 성공률: {stats['success_rate']:.1f}%")
    print(f"🚨 손상 노드: {stats['corrupted_nodes']}")

    # 3️⃣ 결과 정렬 (알고리즘 전제 조건)
    print("\n【 Phase 3: 데이터 정렬 】")
    analyzer.registry.sort()
    print(f"✅ {len(analyzer.registry)}개 데이터 정렬 완료")
    print(f"📋 샘플: {analyzer.registry[:10]} ... {analyzer.registry[-10:]}")

    # 4️⃣ 이진 탐색 테스트 (v5.1 알고리즘)
    print("\n【 Phase 4: 최적화된 검색 (이진 탐색) 】")
    search_targets = [5, 25, 50, 75, 99]

    for target in search_targets:
        index = find_record_optimized(analyzer.registry, target)
        if index is not None:
            print(f"🔍 검색 {target}: 인덱스 {index} (값: {analyzer.registry[index]})")
        else:
            print(f"🔍 검색 {target}: 찾지 못함")

    # 5️⃣ 예외 정보 출력
    if analyzer.errors:
        print("\n【 Phase 5: 손상 데이터 상세 기록 】")
        for error in analyzer.errors[:5]:  # 처음 5개만
            print(f"  - {error}")
        if len(analyzer.errors) > 5:
            print(f"  ... 외 {len(analyzer.errors) - 5}개")

    print("\n" + "="*70)
    print("✅ 시스템 통합 점검 완료")
    print("="*70 + "\n")

    return analyzer


