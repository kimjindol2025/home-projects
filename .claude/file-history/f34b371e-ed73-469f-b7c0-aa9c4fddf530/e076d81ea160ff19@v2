# [점검 대상 1] 커스텀 예외 클래스 (v2.1 기반)
# =============================================================================

class DataCorruptionError(Exception):
    """데이터가 손상되었을 때 발생하는 예외"""

    def __init__(self, message: str, node_id: int = None, timestamp: float = None):
        self.message = message
        self.node_id = node_id
        self.timestamp = timestamp or time.time()
        super().__init__(self.message)

    def __str__(self):
        return f"[{self.node_id}] {self.message} @ {self.timestamp:.2f}"


