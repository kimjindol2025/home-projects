def find_record_optimized(records: List[int], target: int) -> Optional[int]:
    """
    이진 탐색으로 정렬된 배열에서 특정 값을 찾음

    시간 복잡도: O(log n) ← O(n)보다 1000배 빠름!
    공간 복잡도: O(1)

    원리:
    1. 배열의 중간값과 target 비교
    2. target이 더 크면 → 오른쪽 절반 탐색
    3. target이 더 작면 → 왼쪽 절반 탐색
    4. 찾거나 범위가 공집합이 될 때까지 반복

    설계 결정:
    - 재귀적 구현 (개념적으로 명확)
    - 인덱스 기반 (배열 슬라이싱 오버헤드 제거)
    """

    def binary_search_recursive(left: int, right: int) -> Optional[int]:
        """
        재귀적 이진 탐색

        불변 조건:
        - left <= right (탐색 범위 유효)
        - records[left:right+1]에서만 탐색
        """
        if left > right:
            # 탐색 범위 공집합: 값을 찾지 못함
            return None

        mid = (left + right) // 2
        mid_value = records[mid]

        if mid_value == target:
            # 찾음!
            return mid
        elif mid_value < target:
            # target이 더 큼 → 오른쪽 절반 탐색
            return binary_search_recursive(mid + 1, right)
        else:
            # target이 더 작음 → 왼쪽 절반 탐색
            return binary_search_recursive(left, mid - 1)

    if not records:
        return None

    return binary_search_recursive(0, len(records) - 1)


def find_record_optimized_iterative(records: List[int], target: int) -> Optional[int]:
    """
    이진 탐색 (반복 버전)

    장점:
    - 스택 오버플로우 위험 없음
    - 약간 더 빠름 (함수 호출 오버헤드 없음)

    단점:
    - 개념적으로 약간 덜 명확
    """
    left, right = 0, len(records) - 1

    while left <= right:
        mid = (left + right) // 2
        mid_value = records[mid]

        if mid_value == target:
            return mid
        elif mid_value < target:
            left = mid + 1
        else:
            right = mid - 1

    return None


