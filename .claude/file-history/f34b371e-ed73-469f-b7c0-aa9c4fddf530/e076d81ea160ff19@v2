# [점검 대상 2-1] 실행 시간을 측정하는 데코레이터 (v3.1 기반 - 구현)
# =============================================================================

def measure_execution_time(func: Callable) -> Callable:
    """
    실행 시간을 측정하고 출력하는 데코레이터

    개념:
    - 함수 실행 전후의 시간차를 측정
    - 비동기 함수도 지원 (asyncio 감지)
    - 성능 프로파일링의 기초

    설계 원칙:
    - 데코레이터는 원본 함수의 메타데이터를 보존해야 함 (@functools.wraps)
    - 함수 서명을 유연하게 처리 (*args, **kwargs)
    """

    @functools.wraps(func)
    async def async_wrapper(*args, **kwargs) -> Any:
        """비동기 함수용 래퍼"""
        start_time = time.time()
        try:
            result = await func(*args, **kwargs)
            return result
        finally:
            elapsed = time.time() - start_time
            print(f"⏱️  {func.__name__} 실행 시간: {elapsed*1000:.2f}ms")

    @functools.wraps(func)
    def sync_wrapper(*args, **kwargs) -> Any:
        """동기 함수용 래퍼"""
        start_time = time.time()
        try:
            result = func(*args, **kwargs)
            return result
        finally:
            elapsed = time.time() - start_time
            print(f"⏱️  {func.__name__} 실행 시간: {elapsed*1000:.2f}ms")

    # 비동기 함수 감지
    if asyncio.iscoroutinefunction(func):
        return async_wrapper
    else:
        return sync_wrapper


