def benchmark_search_algorithms():
    """
    선형 탐색 vs 이진 탐색 성능 비교

    시나리오: 1백만 개의 정렬된 데이터에서 특정 값 탐색
    """
    import random

    print("\n" + "="*70)
    print("🔬 검색 알고리즘 성능 비교")
    print("="*70)

    # 1백만 개의 정렬된 데이터 생성
    size = 1_000_000
    records = list(range(size))
    target = size // 2  # 중간값 탐색

    # 선형 탐색 (O(n))
    start = time.time()
    for i in range(100):  # 100회 반복
        index = next((i for i, x in enumerate(records) if x == target), None)
    linear_time = time.time() - start

    # 이진 탐색 (O(log n))
    start = time.time()
    for i in range(100):  # 100회 반복
        index = find_record_optimized(records, target)
    binary_time = time.time() - start

    improvement = linear_time / binary_time if binary_time > 0 else float('inf')

    print(f"\n📊 데이터 크기: {size:,} 개 (100회 탐색)")
    print(f"📊 대상 값: {target}")
    print(f"\n선형 탐색 (O(n)):  {linear_time*1000:.2f}ms")
    print(f"이진 탐색 (O(log n)): {binary_time*1000:.2f}ms")
    print(f"\n성능 개선: {improvement:.1f}배 향상 ✨")
    print("="*70 + "\n")


