"""
v1.3 First-class Objects: 함수는 데이터다

파이썬에서 함수는 '일급 객체(First-class Object)'입니다.
즉, 함수를 변수에 할당하고, 인자로 전달하고, 반환값으로 돌려받을 수 있습니다.

이것이 데코레이터와 메타 프로그래밍의 기초입니다.
"""

import sys
from typing import Callable, Any


class FirstClassFunctions:
    """일급 객체로서의 함수"""

    @staticmethod
    def demonstrate_assignment():
        """1. 함수를 변수에 할당"""
        print("\n" + "="*70)
        print("1단계: 함수를 변수에 할당")
        print("="*70)

        def greet(name):
            return f"Hello, {name}!"

        print("\n  [함수 정의]")
        print("    def greet(name):")
        print('        return f"Hello, {name}!"')

        print("\n  [변수에 할당]")
        greeting = greet  # 함수를 변수에 할당
        print("    greeting = greet")
        print("    (greeting은 함수 객체를 참조)")

        print("\n  [통해 호출]")
        print(f"    greeting('Alice') → {greeting('Alice')}")
        print(f"    greet('Bob') → {greet('Bob')}")

        print("\n  [증명: 같은 함수]")
        print(f"    greeting is greet: {greeting is greet}")
        print(f"    id(greeting) == id(greet): {id(greeting) == id(greet)}")

        print("\n" + "="*70)

    @staticmethod
    def demonstrate_as_argument():
        """2. 함수를 다른 함수의 인자로 전달"""
        print("\n" + "="*70)
        print("2단계: 함수를 인자로 전달")
        print("="*70)

        def add(a, b):
            return a + b

        def multiply(a, b):
            return a * b

        def apply_operation(x, y, operation):
            """
            operation: 함수 객체를 받음
            """
            return operation(x, y)

        print("\n  [함수들 정의]")
        print("    def add(a, b): return a + b")
        print("    def multiply(a, b): return a * b")
        print()
        print("    def apply_operation(x, y, operation):")
        print("        return operation(x, y)")

        print("\n  [함수를 인자로 전달]")
        print(f"    apply_operation(10, 5, add) → {apply_operation(10, 5, add)}")
        print(f"    apply_operation(10, 5, multiply) → {apply_operation(10, 5, multiply)}")

        print("\n  [해석]")
        print("    - operation은 '함수 객체'")
        print("    - 함수를 데이터처럼 전달")
        print("    - 런타임에 어떤 함수를 쓸지 결정")

        print("\n" + "="*70)

    @staticmethod
    def demonstrate_return_function():
        """3. 함수를 반환값으로 돌려받기"""
        print("\n" + "="*70)
        print("3단계: 함수를 반환값으로 받기")
        print("="*70)

        def make_multiplier(n):
            """
            특정 숫자로 곱하는 함수를 만드는 함수
            """
            def multiplier(x):
                return x * n
            return multiplier  # 함수를 반환

        print("\n  [고차 함수 정의]")
        print("    def make_multiplier(n):")
        print("        def multiplier(x):")
        print("            return x * n")
        print("        return multiplier")

        print("\n  [함수 생성]")
        double = make_multiplier(2)
        triple = make_multiplier(3)
        print("    double = make_multiplier(2)")
        print("    triple = make_multiplier(3)")

        print("\n  [생성된 함수 사용]")
        print(f"    double(5) → {double(5)}")
        print(f"    double(10) → {double(10)}")
        print(f"    triple(5) → {triple(5)}")
        print(f"    triple(10) → {triple(10)}")

        print("\n  [해석]")
        print("    - make_multiplier는 '함수를 반환하는 함수'")
        print("    - 각 multiplier 함수는 고유한 'n' 값을 기억 (클로저)")
        print("    - 런타임에 새로운 함수를 동적으로 생성")

        print("\n" + "="*70)

    @staticmethod
    def demonstrate_closures():
        """클로저(Closure): 함수가 주변 스코프의 변수를 기억"""
        print("\n" + "="*70)
        print("클로저(Closure): 변수를 기억하는 함수")
        print("="*70)

        def outer(x):
            """외부 함수"""
            print(f"\n  [outer 함수 호출, x={x}]")

            def inner(y):
                """내부 함수: 외부 변수 x를 기억"""
                return x + y

            return inner

        print("\n  [함수 정의]")
        print("    def outer(x):")
        print("        def inner(y):")
        print("            return x + y")
        print("        return inner")

        print("\n  [클로저 생성]")
        add5 = outer(5)
        add10 = outer(10)
        print("    add5 = outer(5)")
        print("    add10 = outer(10)")

        print("\n  [클로저 사용]")
        print(f"    add5(3) → {add5(3)}")
        print(f"    add5(7) → {add5(7)}")
        print(f"    add10(3) → {add10(3)}")
        print(f"    add10(7) → {add10(7)}")

        print("\n  [해석]")
        print("    - add5는 outer(5)에서 반환된 inner")
        print("    - add5는 x=5를 기억하는 '클로저'")
        print("    - add10은 독립적으로 x=10을 기억")

        print("\n" + "="*70)


class FunctionAsData:
    """함수를 데이터처럼 다루기"""

    @staticmethod
    def demonstrate_function_properties():
        """함수도 객체: 메타데이터 접근"""
        print("\n" + "="*70)
        print("함수는 객체: 메타데이터 접근")
        print("="*70)

        def calculate(x, y):
            """두 수를 더하는 함수"""
            return x + y

        print("\n  [함수 객체의 메타데이터]")
        print(f"    함수명: {calculate.__name__}")
        print(f"    docstring: {calculate.__doc__}")
        print(f"    모듈: {calculate.__module__}")
        print(f"    코드 객체: {calculate.__code__}")

        print("\n  [코드 객체의 정보]")
        code = calculate.__code__
        print(f"    인자 개수: {code.co_argcount}")
        print(f"    인자명: {code.co_varnames}")
        print(f"    바이트코드 길이: {len(code.co_code)}")

        print("\n  [함수는 호출 가능 객체]")
        print(f"    callable(calculate): {callable(calculate)}")
        print(f"    type(calculate): {type(calculate)}")

        print("\n" + "="*70)

    @staticmethod
    def demonstrate_function_storage():
        """함수를 컨테이너에 저장"""
        print("\n" + "="*70)
        print("함수를 컨테이너에 저장")
        print("="*70)

        def add(x, y):
            return x + y

        def subtract(x, y):
            return x - y

        def multiply(x, y):
            return x * y

        print("\n  [함수 저장소 구성]")
        operations = {
            'add': add,
            'subtract': subtract,
            'multiply': multiply,
        }
        print("    operations = {")
        print("        'add': add,")
        print("        'subtract': subtract,")
        print("        'multiply': multiply,")
        print("    }")

        print("\n  [저장된 함수 사용]")
        print(f"    operations['add'](10, 5) → {operations['add'](10, 5)}")
        print(f"    operations['subtract'](10, 5) → {operations['subtract'](10, 5)}")
        print(f"    operations['multiply'](10, 5) → {operations['multiply'](10, 5)}")

        print("\n  [유연한 계산기]")
        def calculator(op, x, y):
            return operations[op](x, y)

        print(f"    calculator('add', 10, 5) → {calculator('add', 10, 5)}")
        print(f"    calculator('multiply', 10, 5) → {calculator('multiply', 10, 5)}")

        print("\n  [해석]")
        print("    - 함수를 데이터처럼 저장하고 검색")
        print("    - 런타임에 어떤 함수를 쓸지 동적으로 결정")
        print("    - 함수 추가/제거가 코드 변경 없이 가능 (확장성)")

        print("\n" + "="*70)

    @staticmethod
    def demonstrate_function_composition():
        """함수 합성(Function Composition)"""
        print("\n" + "="*70)
        print("함수 합성: 함수들을 조합하기")
        print("="*70)

        def square(x):
            return x ** 2

        def double(x):
            return x * 2

        def add_one(x):
            return x + 1

        def compose(f, g):
            """
            두 함수를 합성하여 새로운 함수 반환
            (f ∘ g)(x) = f(g(x))
            """
            def composed(x):
                return f(g(x))
            return composed

        print("\n  [함수 정의]")
        print("    def square(x): return x ** 2")
        print("    def double(x): return x * 2")
        print("    def add_one(x): return x + 1")
        print()
        print("    def compose(f, g):")
        print("        def composed(x):")
        print("            return f(g(x))")
        print("        return composed")

        print("\n  [함수 합성]")
        square_then_double = compose(double, square)
        print("    square_then_double = compose(double, square)")
        print(f"    square_then_double(3)")
        print(f"      = double(square(3))")
        print(f"      = double(9)")
        print(f"      = {square_then_double(3)}")

        add_then_square = compose(square, add_one)
        print(f"\n    add_then_square = compose(square, add_one)")
        print(f"    add_then_square(5)")
        print(f"      = square(add_one(5))")
        print(f"      = square(6)")
        print(f"      = {add_then_square(5)}")

        print("\n  [해석]")
        print("    - 단순한 함수들을 합성하여 복잡한 함수 만들기")
        print("    - 함수형 프로그래밍의 핵심 개념")

        print("\n" + "="*70)


class HigherOrderFunctions:
    """고차 함수(Higher-order Functions)의 정의"""

    @staticmethod
    def demonstrate_definition():
        """고차 함수의 정의"""
        print("\n" + "="*70)
        print("고차 함수(Higher-order Functions)")
        print("="*70)

        print("\n  [정의]")
        print("    고차 함수: 다음 중 하나를 만족하는 함수")
        print("    1. 함수를 인자로 받음")
        print("    2. 함수를 반환값으로 돌려줌")
        print("    3. 1번과 2번을 모두 함")

        print("\n  [예시 1: 인자로 함수를 받음]")
        print("    def apply(f, x):")
        print("        return f(x)")
        print("    → apply는 고차 함수")

        print("\n  [예시 2: 함수를 반환]")
        print("    def make_adder(n):")
        print("        def adder(x):")
        print("            return x + n")
        print("        return adder")
        print("    → make_adder는 고차 함수")

        print("\n  [예시 3: 둘 다]")
        print("    def apply_twice(f):")
        print("        def applied_twice(x):")
        print("            return f(f(x))")
        print("        return applied_twice")
        print("    → apply_twice는 고차 함수")

        print("\n  [의미]")
        print("    - 함수를 '값'으로 다루는 능력")
        print("    - 이것이 데코레이터의 기초")
        print("    - 이것이 메타 프로그래밍의 핵심")

        print("\n" + "="*70)

    @staticmethod
    def demonstrate_map_filter():
        """내장 고차 함수: map, filter"""
        print("\n" + "="*70)
        print("내장 고차 함수: map, filter")
        print("="*70)

        print("\n  [map: 함수를 각 원소에 적용]")
        def square(x):
            return x ** 2

        numbers = [1, 2, 3, 4, 5]
        squared = list(map(square, numbers))
        print(f"    numbers = {numbers}")
        print(f"    map(square, numbers) → {squared}")

        print("\n  [filter: 함수가 True인 원소만 선택]")
        def is_even(x):
            return x % 2 == 0

        evens = list(filter(is_even, numbers))
        print(f"    filter(is_even, numbers) → {evens}")

        print("\n  [파이썬 스타일: 람다 + 고차 함수]")
        squared2 = list(map(lambda x: x ** 2, numbers))
        evens2 = list(filter(lambda x: x % 2 == 0, numbers))
        print(f"    map(lambda x: x**2, numbers) → {squared2}")
        print(f"    filter(lambda x: x%2==0, numbers) → {evens2}")

        print("\n" + "="*70)


