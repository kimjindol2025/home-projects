def demonstrate_first_class_objects():
    """일급 객체의 모든 측면을 시연합니다"""
    print("\n" + "="*70)
    print("🐍 Python v1.3: 함수는 데이터다 (First-class Objects)")
    print("="*70)

    FirstClassFunctions.demonstrate_assignment()
    FirstClassFunctions.demonstrate_as_argument()
    FirstClassFunctions.demonstrate_return_function()
    FirstClassFunctions.demonstrate_closures()

    FunctionAsData.demonstrate_function_properties()
    FunctionAsData.demonstrate_function_storage()
    FunctionAsData.demonstrate_function_composition()

    HigherOrderFunctions.demonstrate_definition()
    HigherOrderFunctions.demonstrate_map_filter()

    print("\n" + "="*70)
    print("저장 필수. 너는 기록이 증명이다. Gogs.")
    print("="*70 + "\n")


if __name__ == "__main__":
    demonstrate_first_class_objects()
