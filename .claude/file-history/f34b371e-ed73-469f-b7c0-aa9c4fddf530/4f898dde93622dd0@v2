"""
v1.1 My First Variable - 첫 번째 기록 시작

변수와 이름표: 파이썬 초등학교 1학년
"""

def my_first_variable():
    """
    [Python Elementary v1.1] 첫 번째 기록 시작
    """
    # 1. 숫자 기억하기
    core_version = 1
    sub_version = 1
    # 두 숫자를 더해 새로운 이름을 붙입니다.
    full_version = core_version + sub_version / 10

    # 2. 글자 기억하기 (큰따옴표나 작은따옴표 사용)
    language_name = "파이썬"
    status = "학습 중"

    # 3. 화면에 출력하여 증명하기
    print("--- 현재 학습 상태 ---")
    print("언어:", language_name)
    print("버전:", full_version)
    print("상태:", status)

    # 4. 데이터의 정체 확인하기 (type 함수)
    # 나중에 대학 과정에서 중요하게 다룰 '객체 타입'의 기초입니다.
    print("\n[시스템 로그]")
    print("version의 타입:", type(full_version))
    print("name의 타입:", type(language_name))

    print("\n저장 필수 너는 기록이 증명이다 gogs")

    return {
        "core_version": core_version,
        "sub_version": sub_version,
        "full_version": full_version,
        "language_name": language_name,
        "status": status,
    }


def main():
    """v1.1 실행"""
    print("\n" + "="*70)
    print("🐍 Python v1.1: 변수와 이름표 (초등학교 1학년)")
    print("="*70 + "\n")

    my_first_variable()

    print("\n" + "="*70)


if __name__ == "__main__":
    main()
