def handle_client_async(conn, addr):
    data = conn.recv(1024)
    thread = threading.Thread(
        target=process_request,
        args=(conn, data)
    )
    thread.daemon = True
    thread.start()

def process_request(conn, data):
    result = slow_database_query(data)
    conn.sendall(result)
