### 1.1 웹 서버 구현

```python
# 간단한 웹 서버
from v4_3_socket_network import TCPServer, HTTPResponse, HTTPRequest
import threading

class SimpleWebServer(TCPServer):
    def __init__(self, host='localhost', port=8080):
        super().__init__(host, port)
        self.routes = {}

    def register_route(self, path, handler):
        """라우트 등록"""
        self.routes[path] = handler

    def handle_client(self, conn, addr):
        """클라이언트 요청 처리"""
        try:
            # HTTP 요청 수신
            request_data = b""
            while True:
                chunk = conn.recv(1024)
                if not chunk:
                    break
                request_data += chunk
                if b"\r\n\r\n" in request_data:
                    break

            # 파싱
            request = HTTPRequest.from_bytes(request_data)
            if request is None:
                response = HTTPResponse(400, "Bad Request")
            elif request.path in self.routes:
                # 핸들러 실행
                handler = self.routes[request.path]
                response = handler(request)
            else:
                response = HTTPResponse(404, "Not Found")

            # 응답 전송
            conn.sendall(response.to_bytes())
        finally:
            conn.close()

# 사용
server = SimpleWebServer('0.0.0.0', 8080)
server.register_route('/hello', lambda req: HTTPResponse.ok("Hello, World!"))
server.start()

# 클라이언트 연결 수락
while True:
    client = server.accept_client()
    if client:
        conn, addr = client
        thread = threading.Thread(target=server.handle_client, args=(conn, addr))
        thread.start()
```

### 1.2 채팅 서버

```python
from v4_3_socket_network import TCPServer, MessageSerializer
import threading
import time

class ChatServer(TCPServer):
    def __init__(self, host='localhost', port=9999):
        super().__init__(host, port)
        self.clients = {}  # {addr: socket}
        self.messages = []
        self.lock = threading.Lock()

    def broadcast_message(self, sender, message):
        """모든 클라이언트에게 메시지 전송"""
        data = {
            "type": "message",
            "sender": str(sender),
            "text": message,
            "timestamp": time.time()
        }

        serialized = MessageSerializer.serialize(data)

        with self.lock:
            for addr, client_socket in list(self.clients.items()):
                try:
                    client_socket.sendall(serialized)
                except:
                    del self.clients[addr]

    def handle_client(self, conn, addr):
        """클라이언트 처리"""
        self.clients[addr] = conn

        # 참여 알림
        self.broadcast_message("SYSTEM", f"{addr} joined chat")

        try:
            while True:
                data = conn.recv(1024)
                if not data:
                    break

                message = data.decode('utf-8', errors='ignore')
                self.broadcast_message(addr, message)
        finally:
            del self.clients[addr]
            self.broadcast_message("SYSTEM", f"{addr} left chat")
```

