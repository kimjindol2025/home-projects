### 3.3 부분 수신 처리

```python
# 문제: recv()가 모든 데이터를 한 번에 반환하지 않음
# 해결: 루프에서 수신

def recv_all(socket_obj, size):
    """정확히 size 바이트 수신"""
    data = b''
    while len(data) < size:
        chunk = socket_obj.recv(size - len(data))
        if not chunk:
            break
        data += chunk
    return data

def recv_with_length_prefix(socket_obj):
    """길이 접두사 프로토콜"""
    # 4바이트 길이 읽기
    length_bytes = recv_all(socket_obj, 4)
    length = int.from_bytes(length_bytes, 'big')

    # 정확히 length 바이트 읽기
    return recv_all(socket_obj, length)
```

