## 8. 자주하는 실수와 해결책

### 실수 1: 길이 접두사 없이 데이터 송수신

```python
# ❌ 잘못된 코드
def send_data(conn, data):
    """위험: 부분 수신 가능성"""
    conn.sendall(data)

def recv_data(conn):
    """위험: 모든 데이터를 받지 못할 수 있음"""
    return conn.recv(4096)

# ✅ 올바른 코드
def send_data_safe(conn, data):
    """길이 접두사 포함"""
    length = len(data)
    conn.sendall(length.to_bytes(4, 'big'))
    conn.sendall(data)

def recv_data_safe(conn):
    """길이 접두사로 정확한 크기 확인"""
    length_bytes = conn.recv(4)
    if not length_bytes:
        return None
    length = int.from_bytes(length_bytes, 'big')

    data = b''
    while len(data) < length:
        chunk = conn.recv(length - len(data))
        data += chunk
    return data
```

