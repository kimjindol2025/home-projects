# ❌ 잘못된 코드 (Race condition)
class BadServer:
    def __init__(self):
        self.client_count = 0

    def handle_client(self, conn, addr):
        self.client_count += 1  # 경합!

# ✅ 올바른 코드
class GoodServer:
    def __init__(self):
        self.client_count = 0
        self.lock = threading.Lock()

    def handle_client(self, conn, addr):
        with self.lock:
            self.client_count += 1
