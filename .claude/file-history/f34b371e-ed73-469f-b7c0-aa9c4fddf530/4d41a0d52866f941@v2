class ServiceRegistry:
    """서비스 레지스트리"""

    def __init__(self):
        self.services = {}
        self.lock = threading.Lock()

    def register(self, service_name, host, port, metadata=None):
        """서비스 등록"""
        with self.lock:
            self.services[service_name] = {
                'host': host,
                'port': port,
                'metadata': metadata or {},
                'registered_at': time.time()
            }

    def deregister(self, service_name):
        """서비스 등록 해제"""
        with self.lock:
            if service_name in self.services:
                del self.services[service_name]

    def discover(self, service_name):
        """서비스 발견"""
        with self.lock:
            return self.services.get(service_name)

    def list_services(self):
        """모든 서비스 나열"""
        with self.lock:
            return dict(self.services)

# 사용
registry = ServiceRegistry()
registry.register('user_service', 'localhost', 8080, {'version': '1.0'})
registry.register('order_service', 'localhost', 8081, {'version': '1.0'})

user_service = registry.discover('user_service')
print(f"User Service: {user_service['host']}:{user_service['port']}")
