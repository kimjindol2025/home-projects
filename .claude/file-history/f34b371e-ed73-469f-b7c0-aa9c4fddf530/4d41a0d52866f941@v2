class FileTransferProtocol:
    """파일 전송 프로토콜"""

    @staticmethod
    def send_file(socket_obj, filepath):
        """파일 전송"""
        import os

        # 파일 크기 전송
        size = os.path.getsize(filepath)
        socket_obj.sendall(size.to_bytes(8, 'big'))

        # 파일 내용 전송 (청크 단위)
        with open(filepath, 'rb') as f:
            while True:
                chunk = f.read(8192)
                if not chunk:
                    break
                socket_obj.sendall(chunk)

    @staticmethod
    def recv_file(socket_obj, output_path):
        """파일 수신"""
        # 파일 크기 수신
        size_bytes = socket_obj.recv(8)
        size = int.from_bytes(size_bytes, 'big')

        # 파일 내용 수신
        received = 0
        with open(output_path, 'wb') as f:
            while received < size:
                chunk = socket_obj.recv(min(8192, size - received))
                f.write(chunk)
                received += len(chunk)
