### 7.1 실시간 알림 시스템

```python
class NotificationServer(MultiThreadServer):
    """실시간 알림 시스템"""

    def __init__(self):
        super().__init__(port=9999)
        self.subscribers = defaultdict(list)
        self.lock = threading.Lock()

    def subscribe(self, user_id, conn):
        """구독"""
        with self.lock:
            self.subscribers[user_id].append(conn)

    def unsubscribe(self, user_id, conn):
        """구독 취소"""
        with self.lock:
            self.subscribers[user_id].remove(conn)

    def notify(self, user_id, message):
        """알림 전송"""
        data = MessageSerializer.serialize({
            'type': 'notification',
            'message': message,
            'timestamp': time.time()
        })

        with self.lock:
            for conn in self.subscribers.get(user_id, []):
                try:
                    conn.sendall(data)
                except:
                    pass
```

### 7.2 분산 로깅

```python
class DistributedLogger:
    """분산 로깅"""

    def __init__(self, log_server_host, log_server_port):
        self.log_server_host = log_server_host
        self.log_server_port = log_server_port
        self.queue = []
        self.lock = threading.Lock()

    def log(self, level, message, service_name):
        """로그 기록"""
        log_entry = {
            'timestamp': time.time(),
            'level': level,
            'message': message,
            'service': service_name,
            'hostname': socket.gethostname()
        }

        with self.lock:
            self.queue.append(log_entry)

    def flush(self):
        """로그 서버에 전송"""
        with self.lock:
            if not self.queue:
                return

            data = MessageSerializer.serialize({
                'logs': self.queue
            })

            client = TCPClient(self.log_server_host, self.log_server_port)
            if client.connect():
                client.send(data)
                client.close()

            self.queue = []
