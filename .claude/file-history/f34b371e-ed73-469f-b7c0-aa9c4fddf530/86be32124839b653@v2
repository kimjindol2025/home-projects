def test_loopback_address():
    """루프백 주소"""
    loopback = "127.0.0.1"
    # 루프백 주소는 자기 자신을 가리킴
    assert loopback.startswith("127.")


def test_port_range():
    """포트 범위"""
    # 0~1023: 예약 포트
    # 1024~49151: 등록 포트
    # 49152~65535: 동적/개인 포트
    assert 1 <= 9999 <= 65535


def test_socket_address_family():
    """소켓 주소 계열"""
