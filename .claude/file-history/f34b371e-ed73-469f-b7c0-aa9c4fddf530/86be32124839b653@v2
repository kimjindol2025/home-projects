class TestSimpleTCPServer:
    """기본 TCP 서버 테스트"""

    def test_server_creation(self):
        """서버 생성"""
        server = SimpleTCPServer("127.0.0.1", 9999)
        assert server.host == "127.0.0.1"
        assert server.port == 9999
        assert server.running == False

    def test_server_start(self):
        """서버 시작"""
        server = SimpleTCPServer("127.0.0.1", 9999)
        server.start()
        assert server.running == True
        assert server.socket is not None
        server.close()

    def test_server_close(self):
        """서버 종료"""
        server = SimpleTCPServer("127.0.0.1", 9999)
        server.start()
        server.close()
        assert server.socket is not None  # close 후에도 socket 객체는 있음

    def test_server_reuse_address(self):
        """주소 재사용 옵션"""
        server = SimpleTCPServer("127.0.0.1", 9999)
        server.start()
        # SO_REUSEADDR 옵션 확인
        reuseaddr = server.socket.getsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR)
        assert reuseaddr == 1  # SO_REUSEADDR이 활성화됨
        server.close()


