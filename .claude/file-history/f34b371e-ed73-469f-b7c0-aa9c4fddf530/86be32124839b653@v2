class TestEchoServer:
    """Echo 서버 테스트"""

    def test_echo_server_creation(self):
        """Echo 서버 생성"""
        server = EchoServer("127.0.0.1", 9999)
        assert server.host == "127.0.0.1"
        assert server.port == 9999

    def test_echo_server_with_client(self):
        """Echo 서버와 클라이언트 통신"""
        server = EchoServer("127.0.0.1", 9988)
        client = SimpleTCPClient("127.0.0.1", 9988)

        def run_server():
            server.start()
            server.run_once()

        # 서버를 별도 스레드에서 실행
        thread = threading.Thread(target=run_server)
        thread.daemon = True
        thread.start()

        # 클라이언트가 연결할 때까지 잠깐 대기
        time.sleep(0.5)

        if client.connect():
            test_message = "Hello Echo"
            client.send_message(test_message)
            response = client.receive_message()
            client.close()

            assert response == test_message


