    assert hasattr(socket, "AF_INET6")


def test_socket_type():
    """소켓 타입"""
    # SOCK_STREAM: TCP
    assert hasattr(socket, "SOCK_STREAM")
    # SOCK_DGRAM: UDP
    assert hasattr(socket, "SOCK_DGRAM")


def test_protocol_constants():
    """프로토콜 상수"""
    # SOL_SOCKET: 소켓 레벨 옵션
