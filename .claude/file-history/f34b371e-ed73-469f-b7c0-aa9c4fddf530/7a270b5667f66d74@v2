## 📝 실습: 파일 시스템 탐색

```python
import os

# 현재 폴더의 모든 파일 목록
files = os.listdir(".")
print("현재 폴더의 파일:")
for file in files:
    if os.path.isfile(file):
        print(f"  📄 {file}")
    elif os.path.isdir(file):
        print(f"  📁 {file}")

# 파이썬 파일만 찾기
py_files = [f for f in os.listdir(".") if f.endswith(".py")]
print(f"\n파이썬 파일: {py_files}")

# 안전한 경로 결합
full_path = os.path.join(os.getcwd(), "data.txt")
print(f"전체 경로: {full_path}")
```

