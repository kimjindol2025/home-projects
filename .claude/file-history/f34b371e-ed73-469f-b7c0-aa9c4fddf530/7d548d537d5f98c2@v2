## 실제 응용

### 웹 프레임워크의 경로 데코레이터
```python
# Flask의 @app.route() 예
app = Flask(__name__)

@app.route('/api/users')
def get_users():
    return {"users": []}

# 이것이 가능한 이유:
# route()는 함수를 받아 URL 매핑 정보를 추가하는 데코레이터
```

### 권한 확인
```python
def require_role(role):
    def decorator(func):
        @functools.wraps(func)
        def wrapper(user, *args, **kwargs):
            if user.role != role:
                raise PermissionError(f"{role} 권한 필요")
            return func(user, *args, **kwargs)
        return wrapper
    return decorator

@require_role("admin")
def delete_user(user, user_id):
    # admin만 실행 가능
    pass
```

### 입력 검증
```python
def validate_positive(*param_names):
    def decorator(func):
        @functools.wraps(func)
        def wrapper(*args, **kwargs):
            for i, (name, value) in enumerate(zip(param_names, args)):
                if value <= 0:
                    raise ValueError(f"{name}은 양수여야 합니다")
            return func(*args, **kwargs)
        return wrapper
    return decorator

@validate_positive("x", "y")
def divide(x, y):
    return x / y

divide(10, 2)   # ✅ OK
divide(-10, 2)  # ❌ ValueError
```

