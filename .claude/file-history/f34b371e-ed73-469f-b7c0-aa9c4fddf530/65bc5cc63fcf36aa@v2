"""
v1.4 Automatic Loop - 자동 반복문 (for)

반복문: 파이썬 초등학교 1학년
"""


def automatic_loop():
    """
    [Python Elementary v1.4] 자동 반복문 (for)
    """
    # 1. 리스트 준비
    fruits = ["사과", "바나나", "포도", "딸기"]

    print("--- 과일 상자 차례대로 열기 ---")
    # fruits 바구니에서 하나씩 꺼내 'fruit'라는 이름을 붙여서 반복
    for fruit in fruits:
        print(f"상자에서 {fruit}를 꺼냈습니다.")

    # 2. 숫자로 반복하기 (range)
    print("\n--- 1부터 5까지 숫자 세기 ---")
    for i in range(1, 6):  # 1부터 시작해서 6 전(5)까지
        print(f"현재 숫자는 {i}입니다.")

    # 3. 응용: 리스트 안의 숫자 다 더하기
    numbers = [10, 20, 30]
    total = 0

    for num in numbers:
        total = total + num

    print(f"\n[결과] 모든 숫자의 합: {total}")

    print("\n저장 필수 너는 기록이 증명이다 gogs")

    return {
        "fruits": fruits,
        "numbers": numbers,
        "total": total,
    }


def main():
    """v1.4 실행"""
    print("\n" + "="*70)
    print("🐍 Python v1.4: 반복문(for) — 자동화의 첫걸음")
    print("="*70 + "\n")

    automatic_loop()

    print("\n" + "="*70)


if __name__ == "__main__":
    main()
