"""
v1.3 Decorator Basics: 함수를 감싸는 논리의 벽

데코레이터는 원본 함수를 수정하지 않고,
함수 앞뒤에 추가 기능을 붙이는 설계 패턴입니다.

"원본 함수를 건드리지 않고 기능을 확장하기"
"""

import time
from functools import wraps
from typing import Callable, Any


class DecoratorConcept:
    """데코레이터의 개념"""

    @staticmethod
    def manual_wrapping():
        """수동으로 함수 감싸기"""
        print("\n" + "="*70)
        print("수동 함수 래핑 (Manual Function Wrapping)")
        print("="*70)

        def greet(name):
            return f"Hello, {name}!"

        print("\n  [원본 함수]")
        print("    def greet(name):")
        print('        return f"Hello, {name}!"')
        print(f"    greet('Alice') → {greet('Alice')}")

        print("\n  [수동으로 기능 추가 (1단계: 래퍼 함수 만들기)]")
        def logged_greet(name):
            print(f"  [LOG] greet('{name}') 호출됨")
            result = greet(name)
            print(f"  [LOG] 결과: {result}")
            return result

        print("    def logged_greet(name):")
        print("        print(f'  [LOG] greet(\\''{name}\\') 호출됨')")
        print("        result = greet(name)")
        print("        print(f'  [LOG] 결과: {result}')")
        print("        return result")

        print("\n  [사용]")
        print("    logged_greet('Bob'):")
        logged_greet('Bob')

        print("\n  [문제점]")
        print("    - 함수마다 래퍼를 수동으로 만들어야 함")
        print("    - 코드 중복")
        print("    - 유지보수 어려움")

        print("\n" + "="*70)

    @staticmethod
    def decorator_syntax():
        """@decorator 문법"""
        print("\n" + "="*70)
        print("@decorator 문법 (자동 래핑)")
        print("="*70)

        print("\n  [데코레이터 정의]")
        print("    def logger(func):")
        print("        def wrapper(*args, **kwargs):")
        print("            print(f'  [LOG] {func.__name__} 호출됨')")
        print("            result = func(*args, **kwargs)")
        print("            print(f'  [LOG] 완료')")
        print("            return result")
        print("        return wrapper")

        def logger(func):
            def wrapper(*args, **kwargs):
                print(f"  [LOG] {func.__name__} 호출됨")
                result = func(*args, **kwargs)
                print(f"  [LOG] 완료")
                return result
            return wrapper

        print("\n  [@decorator 문법으로 적용]")
        print("    @logger")
        print("    def greet(name):")
        print('        return f"Hello, {name}!"')

        @logger
        def greet(name):
            return f"Hello, {name}!"

        print("\n  [사용]")
        print("    greet('Carol'):")
        result = greet('Carol')
        print(f"    → {result}")

        print("\n  [등가 표현]")
        print("    @logger")
        print("    def greet(name): ...")
        print("    ↓")
        print("    def greet(name): ...")
        print("    greet = logger(greet)")

        print("\n" + "="*70)


class DecoratorWithArguments:
    """데코레이터 작성 패턴"""

    @staticmethod
    def demonstrate_wraps():
        """@wraps로 메타데이터 보존"""
        print("\n" + "="*70)
        print("@wraps: 원본 함수의 메타데이터 보존")
        print("="*70)

        def bad_decorator(func):
            def wrapper(*args, **kwargs):
                return func(*args, **kwargs)
            return wrapper

        def good_decorator(func):
            @wraps(func)
            def wrapper(*args, **kwargs):
                return func(*args, **kwargs)
            return wrapper

        @bad_decorator
        def bad_func():
            """이것은 중요한 함수"""
            pass

        @good_decorator
        def good_func():
            """이것은 중요한 함수"""
            pass

        print("\n  [@wraps가 없는 경우]")
        print(f"    bad_func.__name__: {bad_func.__name__}")
        print(f"    bad_func.__doc__: {bad_func.__doc__}")
        print("    (메타데이터 손실!)")

        print("\n  [@wraps가 있는 경우]")
        print(f"    good_func.__name__: {good_func.__name__}")
        print(f"    good_func.__doc__: {good_func.__doc__}")
        print("    (메타데이터 보존!)")

        print("\n" + "="*70)

    @staticmethod
    def demonstrate_parametrized():
        """파라미터가 있는 데코레이터"""
        print("\n" + "="*70)
        print("파라미터가 있는 데코레이터")
        print("="*70)

        def repeat(times):
            """함수를 여러 번 반복 실행하는 데코레이터"""
            def decorator(func):
                @wraps(func)
                def wrapper(*args, **kwargs):
                    result = None
                    for i in range(times):
                        print(f"  [실행 {i+1}/{times}]")
                        result = func(*args, **kwargs)
                    return result
                return wrapper
            return decorator

        print("\n  [파라미터가 있는 데코레이터 정의]")
        print("    def repeat(times):")
        print("        def decorator(func):")
        print("            @wraps(func)")
        print("            def wrapper(*args, **kwargs):")
        print("                for i in range(times):")
        print("                    result = func(*args, **kwargs)")
        print("                return result")
        print("            return wrapper")
        print("        return decorator")

        print("\n  [사용: @repeat(3)]")
        print("    @repeat(3)")
        print("    def say_hello():")
        print('        return "Hello!"')

        @repeat(3)
        def say_hello():
            return "Hello!"

        print("\n  [실행]")
        say_hello()

        print("\n  [동작 원리]")
        print("    1. repeat(3) 호출 → decorator 함수 반환")
        print("    2. decorator(say_hello) 호출 → wrapper 반환")
        print("    3. say_hello = wrapper")

        print("\n" + "="*70)


class PracticalDecorators:
    """실용적인 데코레이터들"""

    @staticmethod
    def demonstrate_timing():
        """실행 시간 측정 데코레이터"""
        print("\n" + "="*70)
        print("실용 예제 1: 실행 시간 측정")
        print("="*70)

        def timing(func):
            @wraps(func)
            def wrapper(*args, **kwargs):
                start = time.time()
                print(f"  [TIMING] '{func.__name__}' 시작...")
                result = func(*args, **kwargs)
                elapsed = time.time() - start
                print(f"  [TIMING] 소요시간: {elapsed:.6f}초")
                return result
            return wrapper

        print("\n  [데코레이터]")
        print("    def timing(func):")
        print("        @wraps(func)")
        print("        def wrapper(*args, **kwargs):")
        print("            start = time.time()")
        print("            result = func(*args, **kwargs)")
        print("            elapsed = time.time() - start")
        print("            print(f'소요시간: {elapsed:.6f}초')")
        print("            return result")
        print("        return wrapper")

        @timing
        def slow_function():
            """느린 함수"""
            time.sleep(0.1)
            return "완료"

        print("\n  [사용]")
        print("    @timing")
        print("    def slow_function():")
        print("        time.sleep(0.1)")
        print("        return '완료'")
        print()
        result = slow_function()
        print(f"    → {result}")

        print("\n" + "="*70)

    @staticmethod
    def demonstrate_validation():
        """입력 검증 데코레이터"""
        print("\n" + "="*70)
        print("실용 예제 2: 입력 검증")
        print("="*70)

        def validate_positive(*arg_indices):
            """지정된 인자가 양수인지 검증"""
            def decorator(func):
                @wraps(func)
                def wrapper(*args, **kwargs):
                    for idx in arg_indices:
                        if idx < len(args) and args[idx] <= 0:
                            raise ValueError(
                                f"인자 {idx}는 양수여야 합니다: {args[idx]}"
                            )
                    return func(*args, **kwargs)
                return wrapper
            return decorator

        print("\n  [데코레이터]")
        print("    @validate_positive(0, 1)")
        print("    def divide(a, b):")
        print("        return a / b")

        @validate_positive(0, 1)
        def divide(a, b):
            return a / b

        print("\n  [유효한 호출]")
        print(f"    divide(10, 2) → {divide(10, 2)}")

        print("\n  [유효하지 않은 호출]")
        print("    divide(-10, 2)")
        try:
            divide(-10, 2)
        except ValueError as e:
            print(f"    → ValueError: {e}")

        print("\n  [해석]")
        print("    - 함수 내부를 수정하지 않고 검증 로직 추가")
        print("    - 재사용 가능한 검증 데코레이터")

        print("\n" + "="*70)

    @staticmethod
    def demonstrate_caching():
        """결과 캐싱 데코레이터"""
        print("\n" + "="*70)
        print("실용 예제 3: 결과 캐싱 (Memoization)")
        print("="*70)

        def cache(func):
            """함수 결과를 캐싱하는 데코레이터"""
            cached_results = {}

            @wraps(func)
            def wrapper(*args):
                if args in cached_results:
                    print(f"  [CACHE HIT] {args}")
                    return cached_results[args]
                else:
                    print(f"  [CACHE MISS] {args} - 계산 중...")
                    result = func(*args)
                    cached_results[args] = result
                    return result
            return wrapper

        print("\n  [데코레이터]")
        print("    def cache(func):")
        print("        cached_results = {}")
        print("        @wraps(func)")
        print("        def wrapper(*args):")
        print("            if args in cached_results:")
        print("                return cached_results[args]")
        print("            result = func(*args)")
        print("            cached_results[args] = result")
        print("            return result")
        print("        return wrapper")

        @cache
        def fibonacci(n):
            """피보나치 - 계산이 많은 함수"""
            if n <= 1:
                return n
            return fibonacci(n-1) + fibonacci(n-2)

        print("\n  [사용]")
        print("    @cache")
        print("    def fibonacci(n):")
        print("        if n <= 1: return n")
        print("        return fibonacci(n-1) + fibonacci(n-2)")

        print("\n  [첫 번째 호출]")
        print("    fibonacci(5):")
        result1 = fibonacci(5)
        print(f"    → {result1}")

        print("\n  [두 번째 호출 (캐시됨)]")
        print("    fibonacci(5):")
        result2 = fibonacci(5)
        print(f"    → {result2}")

        print("\n" + "="*70)


class DecoratorChaining:
    """여러 데코레이터 조합"""

    @staticmethod
    def demonstrate_chaining():
        """데코레이터 연쇄"""
        print("\n" + "="*70)
        print("데코레이터 연쇄 (Stacking)")
        print("="*70)

        def logger(func):
            @wraps(func)
            def wrapper(*args, **kwargs):
                print(f"  [LOG] {func.__name__} 호출")
                return func(*args, **kwargs)
            return wrapper

        def uppercase(func):
            @wraps(func)
            def wrapper(*args, **kwargs):
                result = func(*args, **kwargs)
                return result.upper()
            return wrapper

        print("\n  [데코레이터 정의]")
        print("    def logger(func): ...")
        print("    def uppercase(func): ...")

        print("\n  [연쇄 적용]")
        print("    @logger")
        print("    @uppercase")
        print("    def greet(name):")
        print('        return f"hello, {name}!"')

        @logger
        @uppercase
        def greet(name):
            return f"hello, {name}!"

        print("\n  [실행]")
        print("    greet('alice'):")
        result = greet('alice')
        print(f"    → {result}")

        print("\n  [순서 해석]")
        print("    @logger")
        print("    @uppercase")
        print("    def greet(name): ...")
        print("    ↓ (아래부터 위로 적용)")
        print("    1. uppercase(greet)")
        print("    2. logger(uppercase(greet))")

        print("\n" + "="*70)


