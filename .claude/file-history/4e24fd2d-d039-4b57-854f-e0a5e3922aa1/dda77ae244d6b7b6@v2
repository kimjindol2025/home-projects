// Logger: 로깅 기능을 제공하는 구조체
type Logger struct {
	prefix string
	level  string // "INFO", "WARN", "ERROR"
}

// Logger의 메서드
func (l Logger) Log(msg string) {
	fmt.Printf("[%s][%s] %s\n", l.prefix, l.level, msg)
}

func (l Logger) LogWithTime(msg string) {
	timestamp := time.Now().Format("15:04:05")
	fmt.Printf("[%s][%s] %s - %s\n", l.prefix, l.level, timestamp, msg)
}

// Server: Logger를 임베딩하는 구조체
// Server는 이제 Logger의 메서드를 자동으로 가지게 됨
type Server struct {
	Logger   // 이름 없이 타입만 선언 = 임베딩!
	Name     string
	Port     int
	IsRunning bool
}

// Server의 고유 메서드
func (s Server) GetInfo() string {
	return fmt.Sprintf("Server: %s (Port: %d)", s.Name, s.Port)
}

func (s *Server) Start() {
	s.IsRunning = true
	// 임베딩된 Logger의 Log() 메서드 직접 호출
	s.Log("서버가 시작되었습니다")
	s.LogWithTime("초기화 완료")
}

func (s *Server) HandleRequest(requestID int) {
	s.Log(fmt.Sprintf("요청 %d를 처리 중입니다", requestID))
	time.Sleep(100 * time.Millisecond)
	s.Log(fmt.Sprintf("요청 %d 처리 완료", requestID))
}

