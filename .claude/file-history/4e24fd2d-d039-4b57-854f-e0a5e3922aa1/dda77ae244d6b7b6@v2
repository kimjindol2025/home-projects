// 심화 과제: 둘을 조합한 실전 시뮬레이션
// ============================================================

// RequestLogger: 요청 로깅 전용 Logger
type RequestLogger struct {
	Logger
}

// RequestHandler: 요청을 처리하는 구조체 (Logger 임베딩)
type RequestHandler struct {
	RequestLogger
	ID       int
	ResponseCh chan string
}

func (rh *RequestHandler) ProcessRequest(delay time.Duration) {
	rh.Log(fmt.Sprintf("요청 %d 처리 시작 (지연: %v)", rh.ID, delay))

	// 지연 시뮬레이션
	time.Sleep(delay)

	result := fmt.Sprintf("요청 %d 완료", rh.ID)
	rh.Log(result)

	// 응답을 채널에 전송
	rh.ResponseCh <- result
}

func demo_integration() {
	fmt.Println("\n" + sep(60))
	fmt.Println("심화과제: Embedding + Concurrency + Channels 조합")
	fmt.Println(sep(60))

	fmt.Println("\n[상황] 3개의 RequestHandler가 동시에 요청 처리")

	responseCh := make(chan string, 3)

	// 3개의 RequestHandler 생성 (각각 Logger 임베딩)
	handlers := []RequestHandler{
		{
			RequestLogger: RequestLogger{
				Logger: Logger{prefix: "HANDLER-1", level: "INFO"},
			},
			ID:         1,
			ResponseCh: responseCh,
		},
		{
			RequestLogger: RequestLogger{
				Logger: Logger{prefix: "HANDLER-2", level: "INFO"},
			},
			ID:         2,
			ResponseCh: responseCh,
		},
		{
			RequestLogger: RequestLogger{
				Logger: Logger{prefix: "HANDLER-3", level: "INFO"},
			},
			ID:         3,
			ResponseCh: responseCh,
		},
	}

	// 3개의 고루틴으로 동시 처리
	fmt.Println("\n[진행] 3개 고루틴 시작:")
	go handlers[0].ProcessRequest(1 * time.Second)
	go handlers[1].ProcessRequest(2 * time.Second)
	go handlers[2].ProcessRequest(3 * time.Second)

	// 응답 수집 (가장 빠른 순서대로)
	fmt.Println("\n[결과] 응답 수집:")
	for i := 0; i < 3; i++ {
		msg := <-responseCh
		fmt.Printf("  %d번째 응답: %s\n", i+1, msg)
	}

	fmt.Println("\n[분석]")
	fmt.Println("  ✓ 각 RequestHandler는 Logger를 임베딩")
	fmt.Println("  ✓ 각 고루틴은 독립적으로 작동")
	fmt.Println("  ✓ 응답은 채널을 통해 안전하게 전달")
	fmt.Println("  ✓ Race condition 없음 (메모리 공유 안 함)")
}

