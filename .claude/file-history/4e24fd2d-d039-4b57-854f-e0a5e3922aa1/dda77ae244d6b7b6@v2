// 고루틴 작업: 지정된 시간 후 채널에 메시지 전송
func sendMessage(ch chan string, duration time.Duration, message string) {
	time.Sleep(duration)
	ch <- message
}

func demo_concurrency() {
	fmt.Println("\n" + sep(60))
	fmt.Println("과제 2: [45, 46, 48] Concurrency - Goroutines + Channels + Select")
	fmt.Println(sep(60))

	fmt.Println("\n[상황] 3개의 고루틴이 각각 1초, 2초, 3초 후에 메시지 전송")

	// 3개의 채널 생성
	ch1 := make(chan string)
	ch2 := make(chan string)
	ch3 := make(chan string)

	fmt.Println("\n[진행] 고루틴 시작:")

	// 고루틴 1: 1초 후 메시지 전송
	go func() {
		fmt.Println("  → 고루틴 1: 1초 대기 중...")
		sendMessage(ch1, 1*time.Second, "고루틴 1: 1초 후 도착")
	}()

	// 고루틴 2: 2초 후 메시지 전송
	go func() {
		fmt.Println("  → 고루틴 2: 2초 대기 중...")
		sendMessage(ch2, 2*time.Second, "고루틴 2: 2초 후 도착")
	}()

	// 고루틴 3: 3초 후 메시지 전송
	go func() {
		fmt.Println("  → 고루틴 3: 3초 대기 중...")
		sendMessage(ch3, 3*time.Second, "고루틴 3: 3초 후 도착")
	}()

	fmt.Println("\n[핵심] select로 가장 빨리 준비된 채널 선택:")

	// select: 여러 채널 중 가장 빨리 준비된 것 처리
	select {
	case msg1 := <-ch1:
		fmt.Printf("\n✅ 선택됨: %s\n", msg1)
		fmt.Println("   (2초, 3초 메시지는 처리되지 않음)")

	case msg2 := <-ch2:
		fmt.Printf("\n✅ 선택됨: %s\n", msg2)

	case msg3 := <-ch3:
		fmt.Printf("\n✅ 선택됨: %s\n", msg3)
	}

	fmt.Println("\n[완료] select가 첫 번째 채널을 처리한 후 즉시 종료")
	fmt.Println("       다른 고루틴들은 백그라운드에서 계속 실행됨")
}

