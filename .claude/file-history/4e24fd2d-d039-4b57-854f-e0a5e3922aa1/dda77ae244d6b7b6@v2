// 추가 실험: select의 타임아웃 패턴
// ============================================================

func demo_timeout_pattern() {
	fmt.Println("\n" + sep(60))
	fmt.Println("추가 실험: select의 타임아웃 패턴")
	fmt.Println(sep(60))

	fmt.Println("\n[상황] 5초 대기하는 고루틴, 하지만 2초 타임아웃 설정")

	slowCh := make(chan string)

	go func() {
		time.Sleep(5 * time.Second)
		slowCh <- "완료! (5초 후)"
	}()

	fmt.Println("\n[진행] select로 타임아웃 처리:")

	select {
	case msg := <-slowCh:
		fmt.Printf("수신: %s\n", msg)

	case <-time.After(2 * time.Second):
		fmt.Println("⏱️  타임아웃! (2초 경과)")
		fmt.Println("   응답 대기를 포기하고 다른 작업 진행")
	}

	fmt.Println("\n[분석] 실무에서 자주 사용하는 패턴:")
	fmt.Println("  • 네트워크 요청 타임아웃")
	fmt.Println("  • 데이터베이스 쿼리 타임아웃")
	fmt.Println("  • 메시지 큐 수신 타임아웃")
}

