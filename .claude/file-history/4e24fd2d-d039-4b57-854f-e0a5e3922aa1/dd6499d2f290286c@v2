// ==========================================
// 섹션 1: 인터페이스의 정의와 구현
// ==========================================
func section1() {
	fmt.Println()
	fmt.Println("📌 [1] 인터페이스의 정의와 구현!")
	fmt.Println("-" * 50)

	// 1-1: 인터페이스 정의
	fmt.Println()
	fmt.Println("1-1. 인터페이스 정의 - 행동의 계약")
	fmt.Println("type Speaker interface {")
	fmt.Println("    SayHello() string")
	fmt.Println("}")

	// 1-2: 구체적 타입의 메서드 구현
	fmt.Println()
	fmt.Println("1-2. 메서드 구현 - 인터페이스 충족")
	h := Human{Name: "Alice"}
	d := Dog{Name: "Max"}
	fmt.Printf("Human.SayHello(): %s\n", h.SayHello())
	fmt.Printf("Dog.SayHello(): %s\n", d.SayHello())

	// 1-3: 인터페이스 변수에 할당
	fmt.Println()
	fmt.Println("1-3. 인터페이스 변수에 할당")
	var speaker Speaker

	speaker = Human{Name: "Bob"}
	fmt.Printf("speaker = Human: %s\n", speaker.SayHello())

	speaker = Dog{Name: "Buddy"}
	fmt.Printf("speaker = Dog: %s\n", speaker.SayHello())
}

// 인터페이스 구현
func (h Human) SayHello() string {
	return "Hello, I am " + h.Name
}

func (d Dog) SayHello() string {
	return "Woof! I am " + d.Name
}

// ==========================================
// 섹션 2: 암묵적 구현 (덕 타이핑)
// ==========================================
func section2() {
	fmt.Println()
	fmt.Println("📌 [2] 암묵적 구현 (덕 타이핑)!")
	fmt.Println("-" * 50)

	// 2-1: implements 키워드 없음
	fmt.Println()
	fmt.Println("2-1. Go는 implements 키워드가 없음!")
	fmt.Println("- 메서드가 있으면 자동으로 인터페이스 구현")
	fmt.Println("- 행동을 하면, 너는 그 타입이다 (덕 타이핑)")

	// 2-2: 덕 타이핑의 예
	fmt.Println()
	fmt.Println("2-2. 어떤 선언도 필요 없음")
	type Person struct {
		Name string
	}

	func() {
		// 이 함수 내에서 Person에 SayHello 메서드 추가
		// Person도 Speaker 인터페이스 구현
	}()

	p := Person{Name: "Charlie"}
	fmt.Printf("Person.SayHello(): %s\n", p.SayHello())
	fmt.Println("(Person은 Speaker 인터페이스를 구현한다고 명시하지 않았음)")

	// 2-3: 다양한 타입이 같은 인터페이스 구현
	fmt.Println()
	fmt.Println("2-3. 다양한 타입이 자동으로 인터페이스 구현")
	speakers := []Speaker{
		Human{Name: "Alice"},
		Dog{Name: "Max"},
		Person{Name: "Bob"},
	}

	for i, s := range speakers {
		fmt.Printf("[%d] %s\n", i, s.SayHello())
	}
}

// Person도 Speaker 구현
func (p Person) SayHello() string {
	return "Hi, I'm " + p.Name
}

// ==========================================
// 섹션 3: 다형성 (Polymorphism)
// ==========================================
func section3() {
	fmt.Println()
	fmt.Println("📌 [3] 다형성 (Polymorphism)!")
	fmt.Println("-" * 50)

	// 3-1: 인터페이스를 매개변수로 받는 함수
	fmt.Println()
	fmt.Println("3-1. 인터페이스를 매개변수로 받기")
	fmt.Println("func Introduce(s Speaker) { ... }")

	// 3-2: 함수 호출
	fmt.Println()
	fmt.Println("3-2. 같은 함수로 다양한 타입 처리")
	Introduce(Human{Name: "Alice"})
	Introduce(Dog{Name: "Max"})
	Introduce(Person{Name: "Bob"})

	// 3-3: 인터페이스 슬라이스
	fmt.Println()
	fmt.Println("3-3. 인터페이스 슬라이스")
	speakers := []Speaker{
		Human{Name: "Diana"},
		Dog{Name: "Buddy"},
		Person{Name: "Eve"},
	}

	for _, speaker := range speakers {
		Introduce(speaker)
	}
}

// 인터페이스를 매개변수로 받는 함수
func Introduce(s Speaker) {
	fmt.Printf("  Introducing: %s\n", s.SayHello())
}

// ==========================================
// 섹션 4: 빈 인터페이스 (interface{} 와 any)
// ==========================================
func section4() {
	fmt.Println()
	fmt.Println("📌 [4] 빈 인터페이스 (interface{} 와 any)!")
	fmt.Println("-" * 50)

	// 4-1: 빈 인터페이스 선언
	fmt.Println()
	fmt.Println("4-1. 빈 인터페이스 - 모든 타입을 수용")
	var emptyInterface interface{}

	emptyInterface = 42
	fmt.Printf("int: %v (%T)\n", emptyInterface, emptyInterface)

	emptyInterface = "Hello"
	fmt.Printf("string: %v (%T)\n", emptyInterface, emptyInterface)

	emptyInterface = 3.14
	fmt.Printf("float64: %v (%T)\n", emptyInterface, emptyInterface)

	emptyInterface = []int{1, 2, 3}
	fmt.Printf("[]int: %v (%T)\n", emptyInterface, emptyInterface)

	// 4-2: any (Go 1.18+)
	fmt.Println()
	fmt.Println("4-2. any 별칭 (Go 1.18+)")
	var anything any = "anything goes!"
	fmt.Printf("anything: %v\n", anything)

	// 4-3: 빈 인터페이스를 받는 함수
	fmt.Println()
	fmt.Println("4-3. PrintAnything - 모든 타입을 출력")
	PrintAnything(42)
	PrintAnything("text")
	PrintAnything([]string{"a", "b", "c"})
	PrintAnything(map[string]int{"x": 10})
}

// 빈 인터페이스를 받는 함수
func PrintAnything(value any) {
	fmt.Printf("  Value: %v (Type: %T)\n", value, value)
}

// ==========================================
// 섹션 5: 타입 어설션 (Type Assertion)
// ==========================================
func section5() {
	fmt.Println()
	fmt.Println("📌 [5] 타입 어설션 (Type Assertion)!")
	fmt.Println("-" * 50)

	// 5-1: 단순 타입 어설션
	fmt.Println()
	fmt.Println("5-1. 단순 타입 어설션 - i.(Type)")
	var i any = "Hello"
	s := i.(string)
	fmt.Printf("s = %s\n", s)

	// 5-2: 안전한 타입 어설션 (comma ok idiom)
	fmt.Println()
	fmt.Println("5-2. 안전한 타입 어설션 - v, ok := i.(Type)")

	i = "World"
	str, ok := i.(string)
	if ok {
		fmt.Printf("String found: %s\n", str)
	}

	num, ok := i.(int)
	if !ok {
		fmt.Printf("Not an int (ok=%v)\n", ok)
	}

	// 5-3: 다양한 타입 어설션
	fmt.Println()
	fmt.Println("5-3. 다양한 타입 어설션")

	values := []any{42, "text", 3.14, true}
	for _, v := range values {
		// 각 타입 확인
		if intVal, ok := v.(int); ok {
			fmt.Printf("  int: %d\n", intVal)
		} else if strVal, ok := v.(string); ok {
			fmt.Printf("  string: %s\n", strVal)
		} else if floatVal, ok := v.(float64); ok {
			fmt.Printf("  float64: %f\n", floatVal)
		} else if boolVal, ok := v.(bool); ok {
			fmt.Printf("  bool: %v\n", boolVal)
		}
	}
}

// ==========================================
// 섹션 6: 타입 스위치
// ==========================================
func section6() {
	fmt.Println()
	fmt.Println("📌 [6] 타입 스위치!")
	fmt.Println("-" * 50)

	// 6-1: 타입 스위치 기본
	fmt.Println()
	fmt.Println("6-1. 타입 스위치 - switch v := value.(type)")
	value := any(42)
	CheckType(value)

	value = "Hello"
	CheckType(value)

	value = 3.14
	CheckType(value)

	// 6-2: 타입 스위치 with 슬라이스
	fmt.Println()
	fmt.Println("6-2. 여러 값에 대한 타입 스위치")
	values := []any{42, "text", 3.14, true, []int{1, 2}}

	for _, v := range values {
		CheckType(v)
	}
}

// 타입 스위치 함수
func CheckType(value any) {
	switch v := value.(type) {
	case int:
		fmt.Printf("  Integer: %d\n", v)
	case string:
		fmt.Printf("  String: %s\n", v)
	case float64:
		fmt.Printf("  Float: %f\n", v)
	case bool:
		fmt.Printf("  Boolean: %v\n", v)
	default:
		fmt.Printf("  Unknown: %T\n", value)
	}
}

// ==========================================
// 섹션 7: 인터페이스 분리 원칙
// ==========================================
func section7() {
	fmt.Println()
	fmt.Println("📌 [7] 인터페이스 분리 원칙!")
	fmt.Println("-" * 50)

	// 7-1: 작은 인터페이스의 개념
	fmt.Println()
	fmt.Println("7-1. 작은 인터페이스들의 조합")
	fmt.Println("type Reader interface { Read() string }")
	fmt.Println("type Writer interface { Write(data string) }")
	fmt.Println("type ReadWriter interface { Reader; Writer }")

	// 7-2: 실제 사용
	fmt.Println()
	fmt.Println("7-2. 작은 인터페이스 사용")

	type Reader interface {
		Read() string
	}

	type Writer interface {
		Write(data string)
	}

	// File은 Reader와 Writer 모두 구현
	type File struct {
		Name    string
		Content string
	}

	func() {
		var r Reader
		var w Writer

		f := File{Name: "data.txt", Content: "hello"}
		r = f
		w = f

		fmt.Printf("Read: %s\n", r.Read())
		w.Write("world")
	}()
}

