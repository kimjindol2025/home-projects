func section8() {
	fmt.Println()
	fmt.Println("📌 [8] Assignment 1-8 - 결제 시스템!")
	fmt.Println("-" * 50)

	// Assignment 1: 결제 시스템
	fmt.Println()
	fmt.Println("[Assignment 1] 결제 시스템 설계")

	// 신용카드 결제
	fmt.Println()
	fmt.Println("1. 신용카드 결제")
	card := &CreditCard{CardNumber: "1234-5678", Balance: 1000}
	fmt.Printf("  Initial: %s (%.2f)\n", card.CardNumber, card.GetBalance())

	if err := card.Pay(200); err != nil {
		fmt.Printf("  Error: %v\n", err)
	} else {
		fmt.Printf("  After Pay(200): %.2f\n", card.GetBalance())
	}

	// PayPal 결제
	fmt.Println()
	fmt.Println("2. PayPal 결제")
	paypal := &PayPal{Email: "user@example.com", Balance: 500}
	fmt.Printf("  Initial: %s (%.2f)\n", paypal.Email, paypal.GetBalance())

	if err := paypal.Pay(100); err != nil {
		fmt.Printf("  Error: %v\n", err)
	} else {
		fmt.Printf("  After Pay(100): %.2f\n", paypal.GetBalance())
	}

	// 결제 실패 (잔액 부족)
	fmt.Println()
	fmt.Println("3. 결제 실패 - 잔액 부족")
	if err := card.Pay(2000); err != nil {
		fmt.Printf("  Error: %v (잔액: %.2f)\n", err, card.GetBalance())
	}

	// ProcessPayment 함수 (다형성)
	fmt.Println()
	fmt.Println("4. ProcessPayment - 인터페이스 매개변수")
	fmt.Println("  모든 Payer 타입을 처리")

	var payers []Payer = []Payer{card, paypal}
	for i, payer := range payers {
		fmt.Printf("  [%d] Processing payment of 50\n", i)
		if err := ProcessPayment(payer, 50); err != nil {
			fmt.Printf("      Error: %v\n", err)
		} else {
			fmt.Printf("      Balance after: %.2f\n", payer.GetBalance())
		}
	}

	// Assignment 2: 타입 단언
	fmt.Println()
	fmt.Println("[Assignment 2] 타입 단언")
	fmt.Println()

	// 다양한 타입을 any에 담기
	var data any = 42
	fmt.Printf("data = %v (%T)\n", data, data)

	// 타입 단언으로 타입 확인
	if i, ok := data.(int); ok {
		fmt.Printf("  It's an int: %d\n", i)
	}

	if _, ok := data.(string); !ok {
		fmt.Printf("  It's not a string\n")
	}
}

// Payer 인터페이스 구현
func (cc *CreditCard) Pay(amount float64) error {
	if amount > cc.Balance {
		return fmt.Errorf("insufficient balance: have %.2f, need %.2f", cc.Balance, amount)
	}
	cc.Balance -= amount
	return nil
}

func (cc *CreditCard) Refund(amount float64) error {
	cc.Balance += amount
	return nil
}

func (cc *CreditCard) GetBalance() float64 {
	return cc.Balance
}

func (pp *PayPal) Pay(amount float64) error {
	if amount > pp.Balance {
		return fmt.Errorf("insufficient balance: have %.2f, need %.2f", pp.Balance, amount)
	}
	pp.Balance -= amount
	return nil
}

func (pp *PayPal) Refund(amount float64) error {
	pp.Balance += amount
	return nil
}

func (pp *PayPal) GetBalance() float64 {
	return pp.Balance
}

// ProcessPayment 함수 (다형성)
func ProcessPayment(payer Payer, amount float64) error {
	return payer.Pay(amount)
}
