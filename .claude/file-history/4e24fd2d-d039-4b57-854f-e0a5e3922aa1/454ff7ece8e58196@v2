// Package models defines data structures for calculator operations

package models

// Operation represents a calculation operation
type Operation struct {
	Operator string  // "+", "-", "*", "/"
	A        float64 // First operand
	B        float64 // Second operand
}

// Result represents the result of a calculation
type Result struct {
	Operation string  // Description of operation
	Value     float64 // Calculated result
	Error     string  // Error message if any
}
