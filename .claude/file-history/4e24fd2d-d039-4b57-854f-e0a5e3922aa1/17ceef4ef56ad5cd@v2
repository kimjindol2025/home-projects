    Name string
}

func (api *ProductAPI) ServeHTTP(w http.ResponseWriter, r *http.Request) {
    switch r.URL.Path {
    case "/products":
        api.handleProducts(w, r)
    case "/products/create":
        api.handleCreate(w, r)
    default:
        http.NotFound(w, r)
    }
}

