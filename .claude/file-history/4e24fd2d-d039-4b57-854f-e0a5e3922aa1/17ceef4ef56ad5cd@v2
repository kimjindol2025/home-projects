## 5️⃣ JSON API 설계

### 📋 구조체를 JSON으로 변환

```go
package main

import (
    "encoding/json"
    "fmt"
    "net/http"
)

// API 응답 구조체
type User struct {
    ID    int    `json:"id"`
    Name  string `json:"name"`
    Email string `json:"email"`
}

type Response struct {
    Success bool   `json:"success"`
    Data    User   `json:"data"`
    Message string `json:"message"`
}

func getUserHandler(w http.ResponseWriter, r *http.Request) {
    // 1. 데이터 준비
    user := User{
        ID:    1,
        Name:  "Alice",
        Email: "alice@example.com",
    }

    response := Response{
        Success: true,
        Data:    user,
        Message: "User retrieved successfully",
    }

    // 2. 응답 헤더 설정
    w.Header().Set("Content-Type", "application/json")

    // 3. 구조체를 JSON으로 인코딩
    json.NewEncoder(w).Encode(response)
}

func main() {
    http.HandleFunc("/api/user", getUserHandler)
    http.ListenAndServe(":8080", nil)
}
```

### 📤 JSON 출력 예시

```json
{
  "success": true,
  "data": {
    "id": 1,
    "name": "Alice",
    "email": "alice@example.com"
  },
  "message": "User retrieved successfully"
}
```

### 🔑 struct tags의 역할

```go
type User struct {
    ID    int    `json:"id"`          // JSON에서 "id"로 표현
    Name  string `json:"name"`        // JSON에서 "name"로 표현
    Email string `json:"email"`       // JSON에서 "email"로 표현
    // 태그가 없으면 필드명 그대로 사용
}

// 특수 옵션
type Advanced struct {
    Hidden string `json:"-"`                    // JSON 제외
    Value  string `json:"value,omitempty"`      // nil이면 생략
    Custom string `json:"custom_name"`          // 이름 변경
}
```

