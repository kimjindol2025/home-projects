// ============================================================================

func calculateSliceGrowth(capacity int) int {
	if capacity == 0 {
		return 1
	}
	if capacity < 256 {
		return capacity * 2  // 2배 증가
	}
	// 256 이상: 1.25배 증가
	newcap := capacity
	for newcap < capacity {
		newcap += newcap / 4
	}
	return newcap
}

func section4Demo() {
	fmt.Printf("[%s%s]\n", separator, section4)

	fmt.Println("\n🎯 슬라이스의 동적 확장")
	fmt.Println("   append() 호출 시 용량 부족 → growslice() 함수 호출")

	fmt.Println("\n📊 용량 증가 전략")
	fmt.Println("   < 256:  2배 증가 (빠른 성장)")
	fmt.Println("   ≥ 256:  1.25배 증가 (메모리 효율)")

	fmt.Println("\n💻 슬라이스 확장 시뮬레이션")

	capacities := []int{0, 1, 2, 4, 8, 16, 128, 256, 512, 1024}

	fmt.Println("\n   용량 증가 패턴:")
	fmt.Println("   초기 용량 → 새 용량")
	fmt.Println("   ────────────────────")

	for _, cap := range capacities {
		newcap := calculateSliceGrowth(cap)
		ratio := float64(newcap) / float64(cap)
		if cap == 0 {
			fmt.Printf("   %d → %d (초기)\n", cap, newcap)
		} else {
			fmt.Printf("   %d → %d (%.2f배)\n", cap, newcap, ratio)
		}
	}

	fmt.Println("\n⚡ 성능 임플리케이션")
	fmt.Println("   ❌ 나쁜 예:")
	fmt.Println("      s := []int{}")
	fmt.Println("      for i := 0; i < 1000; i++ {")
	fmt.Println("          s = append(s, i)  // 메모리 재할당 + 복사 반복")
	fmt.Println("      }")
	fmt.Println("      비용: O(n²) - 매우 느림")
	fmt.Println()
	fmt.Println("   ✅ 좋은 예:")
	fmt.Println("      s := make([]int, 0, 1000)  // 미리 용량 할당")
	fmt.Println("      for i := 0; i < 1000; i++ {")
	fmt.Println("          s = append(s, i)  // 메모리 재할당 없음")
	fmt.Println("      }")
	fmt.Println("      비용: O(n) - 매우 빠름")

	fmt.Println()
}

