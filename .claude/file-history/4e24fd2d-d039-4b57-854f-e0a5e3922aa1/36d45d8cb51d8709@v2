// 채널 시뮬레이션
type simulatedChan struct {
	buf     []interface{}
	sendx   int
	recvx   int
	qcount  int
	mu      sync.Mutex
	sendq   []string // 송신 대기 고루틴
	recvq   []string // 수신 대기 고루틴
	closed  bool
}

func (c *simulatedChan) Send(goroutineID string, value interface{}) error {
	c.mu.Lock()
	defer c.mu.Unlock()

	if c.closed {
		return fmt.Errorf("send on closed channel")
	}

	// 수신 대기 고루틴이 있는가?
	if len(c.recvq) > 0 {
		waiting := c.recvq[0]
		c.recvq = c.recvq[1:]
		fmt.Printf("   [채널] G(%s) → G(%s) 직접 전송\n", goroutineID, waiting)
		return nil
	}

	// 버퍼가 가득 찼나?
	if c.qcount >= len(c.buf) {
		c.sendq = append(c.sendq, goroutineID)
		fmt.Printf("   [채널] G(%s) 송신 대기 (버퍼 가득 참)\n", goroutineID)
		return nil
	}

	// 버퍼에 저장
	c.buf[c.sendx] = value
	c.sendx = (c.sendx + 1) % len(c.buf)
	c.qcount++
	fmt.Printf("   [채널] G(%s) → 버퍼에 저장 (크기: %d/%d)\n", goroutineID, c.qcount, len(c.buf))
	return nil
}

