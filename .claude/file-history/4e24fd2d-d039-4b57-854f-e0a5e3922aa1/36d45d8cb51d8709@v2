// 고루틴 시뮬레이션
type simulatedG struct {
	id       int
	status   string    // runnable, running, waiting
	created  time.Time
	duration time.Duration
}

type simulatedScheduler struct {
	goroutines []*simulatedG
	mu         sync.Mutex
}

func (s *simulatedScheduler) newproc(id int) {
	s.mu.Lock()
	defer s.mu.Unlock()

	g := &simulatedG{
		id:      id,
		status:  "runnable",
		created: time.Now(),
	}
	s.goroutines = append(s.goroutines, g)
}

func (s *simulatedScheduler) schedule() []*simulatedG {
	s.mu.Lock()
	defer s.mu.Unlock()

	var running []*simulatedG
	for _, g := range s.goroutines {
		if g.status == "runnable" {
			g.status = "running"
			running = append(running, g)
			if len(running) >= 2 { // 최대 2개 동시 실행
				break
			}
		}
	}
	return running
}

