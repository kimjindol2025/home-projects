	fmt.Println("  ┌─ ORM (gorm) (고수준) ───────────────────────────────────┐")
	fmt.Println("  │ var users []User                                        │")
	fmt.Println("  │ db.Find(&users)  // 끝!                                 │")
	fmt.Println("  └──────────────────────────────────────────────────────────┘")

	fmt.Println("\n✓ ORM의 장점:")
	fmt.Println("  • 코드 간결함 (Scan 반복 없음)")
	fmt.Println("  • 자동 마이그레이션 (테이블 자동 생성)")
