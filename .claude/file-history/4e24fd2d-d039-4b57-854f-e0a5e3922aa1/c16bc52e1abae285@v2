func section7_Transaction() {
	fmt.Println("\n[섹션 7] 트랜잭션 (Transaction)")
	fmt.Println("============================================================")

	fmt.Println("\n✓ 트랜잭션의 ACID 속성:")
	fmt.Println("")
	fmt.Println("  Atomicity (원자성)")
	fmt.Println("    → 모두 성공하거나 모두 실패")
	fmt.Println("    → 중간 상태는 없음")
	fmt.Println("")
	fmt.Println("  Consistency (일관성)")
	fmt.Println("    → 데이터 무결성 유지")
	fmt.Println("    → 제약조건 위반 불가")
	fmt.Println("")
	fmt.Println("  Isolation (격리성)")
	fmt.Println("    → 동시 실행 시 간섭 없음")
	fmt.Println("    → 독립적으로 실행")
	fmt.Println("")
	fmt.Println("  Durability (지속성)")
	fmt.Println("    → 저장되면 영구 유지")
	fmt.Println("    → 시스템 장애에도 안전")

	fmt.Println("\n✓ 실제 사례: 송금 거래")
	fmt.Println("")
	fmt.Println("  ❌ 트랜잭션 없음:")
	fmt.Println("    1. Alice 계좌에서 $100 차감   ← 성공")
	fmt.Println("    2. 네트워크 끊김!")
	fmt.Println("    3. Bob 계좌에 $100 입금      ← 실패")
	fmt.Println("    → $100이 사라짐! (데이터 무결성 깨짐)")
	fmt.Println("")
	fmt.Println("  ✅ 트랜잭션 사용:")
	fmt.Println("    BEGIN TRANSACTION")
	fmt.Println("    1. Alice 계좌에서 $100 차감   ← 성공")
	fmt.Println("    2. 네트워크 끊김!")
	fmt.Println("    3. Bob 계좌에 $100 입금      ← 실패")
	fmt.Println("    ROLLBACK (모두 취소)")
	fmt.Println("    → 원래 상태로 복원")

	fmt.Println("\n✓ 코드 패턴:")
	fmt.Println("")
	fmt.Println("  tx, err := db.Begin()          // 트랜잭션 시작")
	fmt.Println("  if err != nil {")
	fmt.Println("      return err")
	fmt.Println("  }")
	fmt.Println("")
	fmt.Println("  // 여러 쿼리 실행")
	fmt.Println("  _, err = tx.Exec(\"UPDATE accounts SET balance = balance - 100 WHERE id = 1\")")
	fmt.Println("  if err != nil {")
	fmt.Println("      tx.Rollback()  // 실패 시 롤백")
	fmt.Println("      return err")
	fmt.Println("  }")
	fmt.Println("")
	fmt.Println("  _, err = tx.Exec(\"UPDATE accounts SET balance = balance + 100 WHERE id = 2\")")
	fmt.Println("  if err != nil {")
	fmt.Println("      tx.Rollback()")
	fmt.Println("      return err")
	fmt.Println("  }")
	fmt.Println("")
	fmt.Println("  tx.Commit()  // 모두 성공하면 커밋")
}

