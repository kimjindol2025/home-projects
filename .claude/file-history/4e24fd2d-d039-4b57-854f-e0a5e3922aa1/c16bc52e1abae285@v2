func section6_ORMConcept() {
	fmt.Println("\n[섹션 6] ORM (Object-Relational Mapping) 개념")
	fmt.Println("============================================================")

	fmt.Println("\n✓ ORM의 철학:")
	fmt.Println("  테이블 → 구조체")
	fmt.Println("  행 → 구조체 인스턴스")
	fmt.Println("  컬럼 → 필드")
	fmt.Println("")
	fmt.Println("  결과: SQL을 거의 쓰지 않음!")

	fmt.Println("\n✓ database/sql vs ORM 비교:")
	fmt.Println("")
	fmt.Println("  ┌─ database/sql (저수준) ─────────────────────────────────┐")
	fmt.Println("  │ rows, err := db.Query(\"SELECT id, name FROM users\")     │")
	fmt.Println("  │ defer rows.Close()                                       │")
	fmt.Println("  │ for rows.Next() {                                        │")
	fmt.Println("  │     var id int                                           │")
	fmt.Println("  │     var name string                                      │")
	fmt.Println("  │     rows.Scan(&id, &name)                               │")
