func section5_ErrorHandling() {
	fmt.Println("\n[섹션 5] 에러 처리")
	fmt.Println("============================================================")

	fmt.Println("\n✓ 일반적인 에러 시나리오:")
	fmt.Println("  1. 연결 실패")
	fmt.Println("     err := db.Ping()")
	fmt.Println("     if err != nil {")
	fmt.Println("         log.Fatal(\"Database unreachable\")")
	fmt.Println("     }")
	fmt.Println("")
	fmt.Println("  2. 행 없음")
	fmt.Println("     err := db.QueryRow(\"SELECT name FROM users WHERE id = ?\", 999).Scan(&name)")
	fmt.Println("     if err == sql.ErrNoRows {")
	fmt.Println("         fmt.Println(\"User not found\")")
	fmt.Println("     }")
	fmt.Println("")
	fmt.Println("  3. 데이터 타입 불일치")
	fmt.Println("     // 테이블: age INTEGER")
	fmt.Println("     // Go: var age string")
	fmt.Println("     // → Scan 에러 발생!")
	fmt.Println("")
	fmt.Println("  4. SQL 에러")
	fmt.Println("     rows, err := db.Query(\"SELECT * FROM nonexistent_table\")")
	fmt.Println("     if err != nil {")
	fmt.Println("         fmt.Println(\"Query error:\", err)")
	fmt.Println("     }")

	fmt.Println("\n✓ SQL 인젝션 방지 (매개변수 바인딩):")
	fmt.Println("  ❌ 위험한 코드:")
	fmt.Println("     userInput := \"1; DROP TABLE users;\"")
	fmt.Println("     query := fmt.Sprintf(\"SELECT * FROM users WHERE id = %s\", userInput)")
	fmt.Println("     → 데이터베이스 파괴!")
	fmt.Println("")
	fmt.Println("  ✅ 안전한 코드:")
	fmt.Println("     query := \"SELECT * FROM users WHERE id = ?\"")
	fmt.Println("     rows, err := db.Query(query, userInput)")
	fmt.Println("     → 드라이버가 자동으로 이스케이프")

	// 시뮬레이션: 에러 처리
	store := NewUserStore()

	fmt.Println("\n✓ 실제 에러 처리 (시뮬레이션):")

	// 에러 case: 사용자 없음
	_, err := store.GetByID(999)
	if err != nil {
		fmt.Printf("  ✓ 에러 처리됨: %v\n", err)
	}

	// 에러 case: 필수 필드 누락
	_, err = store.Create("", "invalid@email.com", 25)
	if err != nil {
		fmt.Printf("  ✓ 에러 처리됨: %v\n", err)
	}
}

