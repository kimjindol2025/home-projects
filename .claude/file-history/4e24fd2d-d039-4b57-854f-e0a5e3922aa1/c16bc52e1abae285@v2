// User 구조체: 데이터베이스의 사용자 테이블과 매핑
type User struct {
	ID    int
	Name  string
	Email string
	Age   int
}

func (u User) String() string {
	return fmt.Sprintf("User{ID:%d, Name:%s, Email:%s, Age:%d}", u.ID, u.Name, u.Email, u.Age)
}

