// UserStore: 메모리 기반 데이터 저장소 (데이터베이스 시뮬레이션)
type UserStore struct {
	users map[int]User
	nextID int
}

func NewUserStore() *UserStore {
	return &UserStore{
		users: make(map[int]User),
		nextID: 1,
	}
}

// CREATE: 새 사용자 추가
func (store *UserStore) Create(name, email string, age int) (int, error) {
	if name == "" || email == "" {
		return 0, fmt.Errorf("name and email are required")
	}

	user := User{
		ID: store.nextID,
		Name: name,
		Email: email,
		Age: age,
	}

	store.users[store.nextID] = user
	id := store.nextID
	store.nextID++

	return id, nil
}

// READ: 사용자 조회
func (store *UserStore) GetByID(id int) (*User, error) {
	user, exists := store.users[id]
	if !exists {
		return nil, fmt.Errorf("user not found")
	}
	return &user, nil
}

// READ: 모든 사용자 조회
func (store *UserStore) GetAll() []User {
	users := make([]User, 0)
	for _, user := range store.users {
		users = append(users, user)
	}
	return users
}

// UPDATE: 사용자 수정
func (store *UserStore) Update(id int, name, email string, age int) error {
	if _, exists := store.users[id]; !exists {
		return fmt.Errorf("user not found")
	}

	store.users[id] = User{
		ID: id,
		Name: name,
		Email: email,
		Age: age,
	}

	return nil
}

// DELETE: 사용자 삭제
func (store *UserStore) Delete(id int) error {
	if _, exists := store.users[id]; !exists {
		return fmt.Errorf("user not found")
	}

	delete(store.users, id)
	return nil
}

func section4_CRUDOperations() {
	fmt.Println("\n[섹션 4] CRUD 연산 (Create, Read, Update, Delete)")
	fmt.Println("============================================================")

	store := NewUserStore()

	// CREATE
	fmt.Println("\n✓ CREATE (삽입):")
	id1, err := store.Create("Alice", "alice@example.com", 25)
	if err == nil {
		fmt.Printf("  → User created with ID: %d\n", id1)
	}

	id2, _ := store.Create("Bob", "bob@example.com", 30)
	fmt.Printf("  → User created with ID: %d\n", id2)

	id3, _ := store.Create("Charlie", "charlie@example.com", 35)
	fmt.Printf("  → User created with ID: %d\n", id3)

	// READ (단일)
	fmt.Println("\n✓ READ (단일 조회):")
	user, _ := store.GetByID(id1)
	fmt.Printf("  → Retrieved: %s\n", user)

	// READ (전체)
	fmt.Println("\n✓ READ (전체 조회):")
	allUsers := store.GetAll()
	for i, u := range allUsers {
		fmt.Printf("  %d. %s\n", i+1, u)
	}

	// UPDATE
	fmt.Println("\n✓ UPDATE (수정):")
	err = store.Update(id1, "Alice Smith", "alice.smith@example.com", 26)
	if err == nil {
		fmt.Printf("  → User %d updated\n", id1)
		user, _ := store.GetByID(id1)
		fmt.Printf("     New data: %s\n", user)
	}

	// DELETE
	fmt.Println("\n✓ DELETE (삭제):")
	err = store.Delete(id2)
	if err == nil {
		fmt.Printf("  → User %d deleted\n", id2)
	}

	fmt.Println("\n✓ 최종 상태:")
	fmt.Printf("  → 남은 사용자: %d명\n", len(store.GetAll()))
}

