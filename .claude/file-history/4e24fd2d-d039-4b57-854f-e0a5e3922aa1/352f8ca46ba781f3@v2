// TestOffHeapBuffer: 오프힙 메모리 할당
func TestOffHeapBuffer(t *testing.T) {
	size := 1024
	ob, err := AllocOffHeap(size)
	if err != nil {
		t.Fatalf("AllocOffHeap failed: %v", err)
	}
	defer ob.Release()

	if ob.size != size {
		t.Errorf("Expected size %d, got %d", size, ob.size)
	}

	if len(ob.Value()) != size {
		t.Errorf("Expected buffer length %d, got %d", size, len(ob.Value()))
	}

	t.Logf("✓ Off-Heap allocation successful: %d bytes", size)
}

// TestOffHeapBufferRefCounting: 참조 카운팅
func TestOffHeapBufferRefCounting(t *testing.T) {
	ob, _ := AllocOffHeap(512)

	if ob.refCount != 1 {
		t.Errorf("Expected initial refCount 1, got %d", ob.refCount)
	}

	ob.Retain()
	if ob.refCount != 2 {
		t.Errorf("Expected refCount 2 after Retain, got %d", ob.refCount)
	}

	ob.Retain()
	if ob.refCount != 3 {
		t.Errorf("Expected refCount 3, got %d", ob.refCount)
	}

	ob.Release()
	if ob.refCount != 2 {
		t.Errorf("Expected refCount 2 after Release, got %d", ob.refCount)
	}

	ob.Release()
	ob.Release()

	t.Log("✓ Reference counting works correctly")
}

// TestWorkStealingWorker: 작업 도난 워커
func TestWorkStealingWorker(t *testing.T) {
