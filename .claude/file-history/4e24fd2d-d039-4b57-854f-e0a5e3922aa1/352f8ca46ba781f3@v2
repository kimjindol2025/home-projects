// TestLongRunningWorkStealing: 장시간 작업 도난
func TestLongRunningWorkStealing(t *testing.T) {
	workers := make([]*WorkStealingWorker, 4)
	for i := 0; i < 4; i++ {
		workers[i] = NewWorkStealingWorker(i, 100)
	}

	// 작업 생성
	for i := 0; i < 100; i++ {
		workers[0].EnqueueLocal(&WorkerTask{ID: i, Value: i})
	}

	// 도난 시도
	stolen := 0
	for i := 1; i < 4; i++ {
		for j := 0; j < 50; j++ {
			if task := workers[i].TryStealFrom(workers[0]); task != nil {
				stolen++
			}
		}
	}

	if stolen == 0 {
		t.Log("⚠ No tasks stolen (expected in some cases)")
	} else {
		t.Logf("✓ Tasks stolen: %d", stolen)
	}
}

