// TestQueueConcurrency: 큐 동시성
func TestQueueConcurrency(t *testing.T) {
	q := NewSimpleLockFreeQueue()

	done := make(chan struct{}, 10)

	// 생산자
	for i := 0; i < 5; i++ {
		go func(id int) {
			for j := 0; j < 20; j++ {
				q.Enqueue(id*1000 + j)
			}
			done <- struct{}{}
		}(i)
	}

	// 소비자
	for i := 0; i < 5; i++ {
		go func() {
			count := 0
			for count < 20 {
				if _, ok := q.Dequeue(); ok {
					count++
				}
			}
			done <- struct{}{}
		}()
	}

	for i := 0; i < 10; i++ {
		<-done
	}

	t.Log("✓ Queue concurrency test passed")
}

