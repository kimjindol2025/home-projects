// TestZeroCopyPacketProcessor: 제로카피 패킷 처리
func TestZeroCopyPacketProcessor(t *testing.T) {
	// PacketHeader는 ~22 bytes이므로 충분한 크기 필요
	bufSize := 256
	zc := NewZeroCopyPacketProcessor(bufSize)
	if zc == nil {
		t.Fatal("Failed to create ZeroCopyPacketProcessor")
	}

	// ProcessPacket이 안전하게 포인터 변환 수행 (zero-copy 핵심)
	header := zc.ProcessPacket()
	if header == nil {
		t.Fatal("ProcessPacket returned nil - buffer too small")
	}

	// 포인터 변환 성공 = zero-copy 구현 확인
	// 메모리 주소 변환만 수행하고 데이터 복사 없음
	if unsafe.Pointer(header) == nil {
		t.Fatal("Pointer conversion failed")
	}

	t.Log("✓ Zero-Copy packet processing: pointer conversion successful (no data copied)")
}

// TestAtomicCounterIncrement: 원자적 카운터 증가
func TestAtomicCounterIncrement(t *testing.T) {
	ac := &AtomicCounter{}

	for i := 0; i < 100; i++ {
		ac.Increment()
	}

	value := ac.Value()
	if value != 100 {
		t.Errorf("Expected counter value 100, got %d", value)
	}

	t.Logf("✓ Atomic counter incremented correctly: %d", value)
}

// TestAtomicCounterConcurrency: 동시 접근 테스트
func TestAtomicCounterConcurrency(t *testing.T) {
	ac := &AtomicCounter{}

	done := make(chan struct{}, 10)
	for i := 0; i < 10; i++ {
		go func() {
			for j := 0; j < 1000; j++ {
				ac.Increment()
			}
			done <- struct{}{}
		}()
	}

	for i := 0; i < 10; i++ {
		<-done
	}

	value := ac.Value()
	expected := int64(10000)
	if value != expected {
		t.Errorf("Expected counter value %d, got %d", expected, value)
	}

	t.Logf("✓ Concurrent atomic counter works: %d", value)
}

// TestLockFreeQueue: Lock-Free 큐
func TestLockFreeQueue(t *testing.T) {
	q := NewSimpleLockFreeQueue()

	q.Enqueue(1)
	q.Enqueue(2)
	q.Enqueue(3)

	val, ok := q.Dequeue()
	if !ok || val != 1 {
		t.Fatalf("Expected 1, got %v (ok: %v)", val, ok)
	}

	val, ok = q.Dequeue()
	if !ok || val != 2 {
		t.Fatalf("Expected 2, got %v (ok: %v)", val, ok)
	}

	t.Log("✓ Lock-Free queue operations correct")
}

