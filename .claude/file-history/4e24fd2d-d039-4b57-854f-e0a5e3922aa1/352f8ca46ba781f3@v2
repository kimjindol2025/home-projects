// TestWorkStealingFromOther: 다른 워커에서 작업 도난
func TestWorkStealingFromOther(t *testing.T) {
	w1 := NewWorkStealingWorker(1, 10)
	w2 := NewWorkStealingWorker(2, 10)

	// w1에 작업 추가
	for i := 0; i < 3; i++ {
		w1.EnqueueLocal(&WorkerTask{ID: i, Value: i * 10})
	}

	// w2가 w1에서 작업 도난
	task := w2.TryStealFrom(w1)
	if task == nil {
		t.Fatal("Failed to steal task")
	}

	if w2.StealCount() != 1 {
		t.Errorf("Expected steal count 1, got %d", w2.StealCount())
	}

	t.Logf("✓ Work stolen successfully: Task ID=%d", task.ID)
}

