func section6_PreemptiveScheduling() {
	fmt.Println("\n[섹션 6] 선점형 스케줄링 (Go 1.14+)")
	fmt.Println("============================================================")

	fmt.Println("\n✓ 문제 (Go 1.13 이전):")
	fmt.Println("")
	fmt.Println("  무한 루프 고루틴이 시스템을 멈추게 함:")
	fmt.Println("")
	fmt.Println("    go func() {")
	fmt.Println("        for { }  // 무한 루프")
	fmt.Println("    }()")
	fmt.Println("    fmt.Println(\"이 줄은 절대 실행되지 않음\")")
	fmt.Println("")
	fmt.Println("  → 고루틴이 제어권을 양보하지 않으므로")
	fmt.Println("     메인 고루틴은 실행 기회를 얻을 수 없음 (데드락)")

	fmt.Println("\n✓ 해결책 (Go 1.14+): 선점형 스케줄링")
	fmt.Println("")
	fmt.Println("  Go 런타임이 주기적으로 체크 (10ms):")
	fmt.Println("    1. 현재 G가 10ms 이상 실행했나?")
	fmt.Println("    2. 예 → 강제로 컨텍스트 스위칭")
	fmt.Println("    3. 다른 G에게 기회 제공")

	fmt.Println("\n✓ 효과:")
	fmt.Println("")
	fmt.Println("  • 공정성 (Fairness)")
	fmt.Println("    모든 고루틴이 실행 기회를 얻음")
	fmt.Println("")
	fmt.Println("  • 응답성 (Responsiveness)")
	fmt.Println("    UI 반응성 향상")
	fmt.Println("")
	fmt.Println("  • 안정성 (Stability)")
	fmt.Println("    무한 루프 하나가 시스템 멈추지 않음")

	fmt.Println("\n✓ 실제 확인 (Go 1.14 필수):")

	// 선점형 스케줄링 테스트
	fmt.Println("")
	runtime.GOMAXPROCS(1)  // 1개 코어로 제한

	done := make(chan bool)

	// 고강도 계산 고루틴
	go func() {
		fmt.Println("  • 고강도 계산 시작")
		for i := 0; i < 100000000; i++ {
			_ = i * i
		}
		fmt.Println("  • 고강도 계산 완료")
		done <- true
	}()

	// 메인 고루틴도 실행 가능한가?
	time.Sleep(100 * time.Millisecond)
	fmt.Println("  ✓ 메인 고루틴이 실행됨 (선점 성공!)")

	<-done
}

