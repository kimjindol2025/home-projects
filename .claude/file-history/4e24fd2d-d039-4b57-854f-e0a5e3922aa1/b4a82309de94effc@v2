func section5_WorkStealing() {
	fmt.Println("\n[섹션 5] 워크 스틸링 (Work Stealing)")
	fmt.Println("============================================================")

	fmt.Println("\n✓ 문제 상황:")
	fmt.Println("")
	fmt.Println("  일반적인 작업 분배:")
	fmt.Println("  ┌─────────────┐  ┌─────────────┐")
	fmt.Println("  │ P0          │  │ P1          │")
	fmt.Println("  │ [G1,G2,G3] │  │ []          │ ← 유휴!")
	fmt.Println("  └─────────────┘  └─────────────┘")
	fmt.Println("")
	fmt.Println("  결과: P1의 M은 아무것도 할 수 없음 (CPU 낭비)")

	fmt.Println("\n✓ 해결책: 워크 스틸링")
	fmt.Println("")
	fmt.Println("  P1이 P0의 대기열에서 G를 '훔친다':")
	fmt.Println("  ┌─────────────┐  ┌─────────────┐")
	fmt.Println("  │ P0          │  │ P1          │")
	fmt.Println("  │ [G1,G2]    │  │ [G3]        │ ← 훔친 것!")
	fmt.Println("  └─────────────┘  └─────────────┘")
	fmt.Println("")
	fmt.Println("  결과: 모든 P가 활용됨 (CPU 효율 100%)")

	fmt.Println("\n✓ 워크 스틸링 알고리즘 (의사 코드):")
	fmt.Println("")
	fmt.Println("  P_i의 M이 G를 완료했을 때:")
	fmt.Println("    1. P_i의 로컬 대기열 확인")
	fmt.Println("    2. 없으면 → 전역 대기열 확인")
	fmt.Println("    3. 없으면 → 다른 P의 대기열에서 훔치기")
	fmt.Println("    4. 절반을 훔침 (50% 규칙)")

	fmt.Println("\n✓ 실제 시뮬레이션:")

	// 워크 스틸링 효과 시뮬레이션
	tasks := 100
	workers := 4

	start := time.Now()
	var wg sync.WaitGroup

	// GOMAXPROCS 설정
	runtime.GOMAXPROCS(workers)

	for i := 0; i < tasks; i++ {
		wg.Add(1)
		go func() {
			defer wg.Done()
			// 간단한 작업
			sum := 0
			for j := 0; j < 1000000; j++ {
				sum += j
			}
		}()
	}

	wg.Wait()
	elapsed := time.Since(start)

	fmt.Printf("  작업: %d개\n", tasks)
	fmt.Printf("  워커(P): %d개\n", workers)
	fmt.Printf("  소요 시간: %v\n", elapsed)
	fmt.Printf("  추정 처리량: %.0f 작업/초\n", float64(tasks)/elapsed.Seconds())
}

