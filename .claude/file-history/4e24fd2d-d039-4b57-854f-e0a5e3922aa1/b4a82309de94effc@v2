func section7_RuntimePackage() {
	fmt.Println("\n[섹션 7] runtime 패키지: 스케줄러 제어")
	fmt.Println("============================================================")

	fmt.Println("\n✓ 핵심 함수:")
	fmt.Println("")
	fmt.Println("  1. runtime.GOMAXPROCS(n)")
	fmt.Println("     • P의 개수 설정")
	fmt.Println("     • GOMAXPROCS(-1): 현재값 반환")
	fmt.Println("")
	fmt.Println("  2. runtime.NumGoroutine()")
	fmt.Println("     • 현재 활성 고루틴 개수")
	fmt.Println("")
	fmt.Println("  3. runtime.Gosched()")
	fmt.Println("     • 현재 고루틴에서 제어권 양보")
	fmt.Println("     • 다른 고루틴이 실행할 기회 제공")
	fmt.Println("")
	fmt.Println("  4. runtime.NumCPU()")
	fmt.Println("     • CPU 코어 개수 반환")
	fmt.Println("")
	fmt.Println("  5. runtime.Stack()")
	fmt.Println("     • 현재 스택 정보 출력")

	fmt.Println("\n✓ GOMAXPROCS 실습:")
	fmt.Println("")

	// 기본 P 개수
	defaultP := runtime.GOMAXPROCS(-1)
	fmt.Printf("  기본 P: %d\n", defaultP)

	// P 변경
	oldP := runtime.GOMAXPROCS(2)
	fmt.Printf("  P를 2로 변경: %d → 2\n", oldP)
	fmt.Printf("  이제 최대 2개 고루틴이 동시 실행\n")

	// P 복원
	runtime.GOMAXPROCS(defaultP)
	fmt.Printf("  P 복원: %d\n", defaultP)

	fmt.Println("\n✓ NumGoroutine 실습:")
	fmt.Println("")

	fmt.Printf("  메인 시작: %d\n", runtime.NumGoroutine())

	var wg sync.WaitGroup
	for i := 0; i < 5; i++ {
		wg.Add(1)
		go func() {
			defer wg.Done()
			time.Sleep(50 * time.Millisecond)
		}()
	}

	fmt.Printf("  생성 직후: %d\n", runtime.NumGoroutine())

	wg.Wait()
	fmt.Printf("  완료 후: %d\n", runtime.NumGoroutine())

	fmt.Println("\n✓ Gosched 실습:")
	fmt.Println("")

	go func() {
		fmt.Println("  • G1 시작")
		runtime.Gosched()  // 다른 G에게 양보
		fmt.Println("  • G1 재개")
	}()

	go func() {
		fmt.Println("  • G2 시작 (G1이 양보했으므로 실행 기회 획득)")
		fmt.Println("  • G2 종료")
	}()

	time.Sleep(100 * time.Millisecond)
}

