func section2_GoroutineAnalysis() {
	fmt.Println("\n[섹션 2] G (Goroutine): 경량 작업 단위")
	fmt.Println("============================================================")

	fmt.Println("\n✓ Goroutine vs OS Thread 비교:")
	fmt.Println("")
	fmt.Println("  메모리:")
	fmt.Println("    • OS Thread: 1개당 2MB")
	fmt.Println("    • Goroutine: 1개당 4KB")
	fmt.Println("    • 비율: 2MB ÷ 4KB = 500배 효율!")
	fmt.Println("")
	fmt.Println("  동시성:")
	fmt.Println("    • OS Thread: 최대 수백 개")
	fmt.Println("    • Goroutine: 수백만 개")
	fmt.Println("")
	fmt.Println("  생성 비용:")
	fmt.Println("    • OS Thread: 매우 비쌈 (커널 호출)")
	fmt.Println("    • Goroutine: 매우 싼 비용")

	fmt.Println("\n✓ Goroutine 상태 머신:")
	fmt.Println("")
	fmt.Println("  생성 → Runnable (실행 대기)")
	fmt.Println("         ↓")
	fmt.Println("       Running (CPU에서 실행 중)")
	fmt.Println("         ├→ Waiting (채널/뮤텍스 대기)")
	fmt.Println("         ├→ Blocked (시스템 호출)")
	fmt.Println("         └→ Runnable (다시 실행 가능)")
	fmt.Println("         ↓")
	fmt.Println("       완료")

	fmt.Println("\n✓ 실제 구현 예시:")

	// 고루틴 생성 및 추적
	start := time.Now()
	initialG := runtime.NumGoroutine()
	fmt.Printf("  초기 고루틴: %d\n", initialG)

	var wg sync.WaitGroup
	for i := 0; i < 10; i++ {
		wg.Add(1)
		go func(id int) {
			defer wg.Done()
			time.Sleep(100 * time.Millisecond)
			fmt.Printf("    • G%d 완료\n", id)
		}(i)
	}

	fmt.Printf("  생성 직후: %d개 고루틴\n", runtime.NumGoroutine())

	wg.Wait()
	fmt.Printf("  완료 후: %d개 고루틴\n", runtime.NumGoroutine())
	fmt.Printf("  소요 시간: %v\n", time.Since(start))
}

