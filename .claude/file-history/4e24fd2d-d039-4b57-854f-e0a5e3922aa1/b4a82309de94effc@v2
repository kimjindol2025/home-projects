		runtime.GOMAXPROCS(p)

		start := time.Now()
		var wg sync.WaitGroup

		for i := 0; i < tasks; i++ {
			wg.Add(1)
			go func() {
				defer wg.Done()
				// 작은 작업
				for j := 0; j < 10000; j++ {
					_ = j
				}
			}()
		}

		wg.Wait()
		elapsed := time.Since(start)
		results[p] = elapsed

		fmt.Printf("  P=%d: %v\n", p, elapsed)
	}

	// 개선율 계산
	fmt.Println("")
	baseline := results[1]
	for p := 2; p <= 4; p++ {
		improvement := float64(baseline) / float64(results[p])
		fmt.Printf("  P=%d → P=1 대비 %.2fx 빠름\n", p, improvement)
	}

	fmt.Println("\n✓ 과제 2: 데드락 탐지 (의도적 시뮬레이션)")
	fmt.Println("")
	fmt.Println("  데드락 코드 패턴:")
	fmt.Println("    ch := make(chan int)  // 버퍼 없음")
	fmt.Println("    go func() {")
	fmt.Println("        data := <-ch  // 영원히 대기")
	fmt.Println("    }()")
	fmt.Println("    // 모든 고루틴이 블록됨 → panic!")

	fmt.Println("\n  Go 런타임의 감지:")
	fmt.Println("    panic: all goroutines are asleep - deadlock!")
	fmt.Println("    [이 상황은 실제로 발생시키면 프로그램이 멈추므로")
	fmt.Println("     시뮬레이션으로 설명]")

	fmt.Println("\n✓ 과제 3: 워크 스틸링 시뮬레이션")
	fmt.Println("")
	fmt.Println("  불균형한 작업 분배:")
	fmt.Println("    P0에 100개 작업, P1에 0개 작업")
	fmt.Println("    → P1의 M이 P0의 작업을 '훔쳐서' 처리")
	fmt.Println("    → 모든 코어 활용 (CPU 효율 상승)")
}

