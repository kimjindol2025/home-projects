// Package configs provides configuration management for the calculator

package configs

// Config holds application configuration
type Config struct {
	AppName string
	Version string
	Debug   bool
}

// LoadConfig returns the default configuration
func LoadConfig() *Config {
	return &Config{
		AppName: "Calculator",
		Version: "1.0",
		Debug:   true,
	}
}
