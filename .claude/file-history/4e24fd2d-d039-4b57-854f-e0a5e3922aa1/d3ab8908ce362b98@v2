## 8️⃣ 실전 예제: 마이크로서비스 클러스터

### 📋 시스템 설계

```
Service Registry: 중앙 전화번호부
  ├─ Service A: [10.0.1.1:3000, 10.0.1.2:3000]
  ├─ Service B: [10.0.2.1:4000, 10.0.2.2:4000]
  └─ Service C: [10.0.3.1:5000]

Client들:
  ├─ API Gateway (로드밸런서)
  ├─ Mobile App (직접 호출)
  └─ Web App (직접 호출)

Health Check:
  ├─ 매 10초마다 GET /health
  ├─ 응답 없으면 제거
  └─ 복구되면 다시 추가
```

### 🔧 코드 구조

```go
// 1. 서비스 등록/해제
type ServiceRegistry struct {
    services map[string][]ServiceInstance
    mu       sync.RWMutex
}

func (sr *ServiceRegistry) Register(service ServiceInstance) {
    sr.mu.Lock()
    sr.services[service.Name] = append(sr.services[service.Name], service)
    sr.mu.Unlock()
}

// 2. 서비스 발견
func (sr *ServiceRegistry) GetInstances(name string) []ServiceInstance {
    sr.mu.RLock()
    defer sr.mu.RUnlock()
    return sr.services[name]
}

// 3. 부하분산 선택
type LoadBalancer struct {
    policy string  // "round-robin", "least-connection", etc
    index  int
}

func (lb *LoadBalancer) Select(instances []ServiceInstance) ServiceInstance {
    switch lb.policy {
    case "round-robin":
        selected := instances[lb.index % len(instances)]
        lb.index++
        return selected
    case "least-connection":
        // min connection 찾기
    }
}

// 4. Health Check
func HealthChecker(registry *ServiceRegistry, interval time.Duration) {
    ticker := time.NewTicker(interval)
    for range ticker.C {
        for serviceName, instances := range registry.services {
            for _, instance := range instances {
                if !isHealthy(instance) {
                    registry.Deregister(serviceName, instance.ID)
                }
            }
        }
    }
}
```

