## 4️⃣ 실전 패턴: 타임아웃 서버

### 📋 HTTP 핸들러 with Context

```go
import "net/http"

func heavyWorkHandler(w http.ResponseWriter, r *http.Request) {
    ctx, cancel := context.WithTimeout(r.Context(), 3*time.Second)
    defer cancel()

    result := make(chan string, 1)
    go func() {
        // 무거운 작업 (5초 걸림)
        time.Sleep(5 * time.Second)
        result <- "완료"
    }()

    select {
    case res := <-result:
        w.WriteHeader(http.StatusOK)
        fmt.Fprintf(w, "결과: %s\n", res)
    case <-ctx.Done():
        w.WriteHeader(http.StatusGatewayTimeout)
        fmt.Fprintf(w, "타임아웃\n")
    }
}

http.HandleFunc("/work", heavyWorkHandler)
http.ListenAndServe(":8080", nil)
```

### 🔗 Context 전파

```go
func parentTask(ctx context.Context) error {
    ctx, cancel := context.WithTimeout(ctx, 2*time.Second)
    defer cancel()

    // 여러 자식 작업 동시 실행
    var wg sync.WaitGroup
    var mu sync.Mutex
    var result []string

    for i := 0; i < 5; i++ {
        wg.Add(1)
        go func(id int) {
            defer wg.Done()
            if err := childTask(ctx, id); err == nil {
                mu.Lock()
                result = append(result, fmt.Sprintf("child-%d OK", id))
                mu.Unlock()
            }
        }(i)
    }

    wg.Wait()
    fmt.Printf("결과: %v\n", result)
    return nil
}

func childTask(ctx context.Context, id int) error {
    select {
    case <-time.After(1 * time.Second):
        fmt.Printf("Child %d: 완료\n", id)
        return nil
    case <-ctx.Done():
        fmt.Printf("Child %d: 취소됨\n", id)
        return ctx.Err()
    }
}
```

