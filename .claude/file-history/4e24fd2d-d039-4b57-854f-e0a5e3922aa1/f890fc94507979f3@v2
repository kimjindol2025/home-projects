func main() {
    ctx := context.Background()
    ctx = context.WithValue(ctx, requestIDKey, "req-001")
    ctx = context.WithValue(ctx, userIDKey, 42)

    logWithContext(ctx, "작업 시작")
    // 출력: [req-001] [User:42] 작업 시작
}
