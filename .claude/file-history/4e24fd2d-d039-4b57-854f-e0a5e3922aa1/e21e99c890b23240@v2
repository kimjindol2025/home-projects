// 섹션 7️⃣: Raft 분산 합의 시뮬레이션
// ============================================================================

// RaftNode: Raft 노드 상태
type RaftNode struct {
	ID       string
	State    string // "FOLLOWER", "CANDIDATE", "LEADER"
	Term     int
	VotedFor string
	Logs     []string
}

// RaftCluster: Raft 클러스터
type RaftCluster struct {
	nodes map[string]*RaftNode
	mu    sync.Mutex
}

// NewRaftCluster 생성
func NewRaftCluster() *RaftCluster {
	return &RaftCluster{
		nodes: make(map[string]*RaftNode),
	}
}

// AddNode: 노드 추가
func (rc *RaftCluster) AddNode(id string) {
	rc.mu.Lock()
	defer rc.mu.Unlock()

	rc.nodes[id] = &RaftNode{
		ID:    id,
		State: "FOLLOWER",
		Term:  0,
		Logs:  make([]string, 0),
	}
	fmt.Printf("[Raft] ✓ 노드 추가: %s (FOLLOWER)\n", id)
}

// ElectLeader: 리더 선출
func (rc *RaftCluster) ElectLeader() {
	rc.mu.Lock()
	defer rc.mu.Unlock()

	// 모든 노드의 term 증가
	for _, node := range rc.nodes {
		node.Term++
		node.State = "CANDIDATE"
		fmt.Printf("[Raft] 🗳️ %s: term=%d, CANDIDATE로 변신\n", node.ID, node.Term)
	}

	// 첫 번째 노드를 리더로 선출
	for _, node := range rc.nodes {
		node.State = "FOLLOWER"
	}

	firstNode := rc.nodes["node-1"]
	if firstNode != nil {
		firstNode.State = "LEADER"
		fmt.Printf("[Raft] 👑 리더 선출: %s\n", firstNode.ID)
	}

	// 다른 노드들은 FOLLOWER
	for _, node := range rc.nodes {
		if node.State != "LEADER" {
			node.State = "FOLLOWER"
		}
	}
}

// ReplicateLog: 로그 복제
func (rc *RaftCluster) ReplicateLog(entry string) {
	rc.mu.Lock()
	defer rc.mu.Unlock()

	var leader *RaftNode
	for _, node := range rc.nodes {
		if node.State == "LEADER" {
			leader = node
			break
		}
	}

	if leader == nil {
		fmt.Println("[Raft] ❌ 리더 없음, 로그 복제 불가")
		return
	}

	// 리더에서 로그 추가
	leader.Logs = append(leader.Logs, entry)
	fmt.Printf("[Raft] 📝 리더 %s에 로그 추가: %s\n", leader.ID, entry)

	// 모든 Follower에 복제
	for _, node := range rc.nodes {
		if node.State == "FOLLOWER" {
			node.Logs = append(node.Logs, entry)
			fmt.Printf("[Raft]   → %s에 복제\n", node.ID)
		}
	}

	fmt.Println("[Raft] ✓ 로그 복제 완료 (quorum 수락)")
}

// RaftDemo: Raft 시뮬레이션
func RaftDemo() {
	fmt.Println("\n[Raft] 분산 합의 시뮬레이션")
	fmt.Println(repeatStr("-", 68))

	cluster := NewRaftCluster()

	fmt.Println("\n1️⃣ 클러스터 구성 (3개 노드)")
	for i := 1; i <= 3; i++ {
		cluster.AddNode(fmt.Sprintf("node-%d", i))
	}

	fmt.Println("\n2️⃣ 리더 선출")
	cluster.ElectLeader()

	fmt.Println("\n3️⃣ 로그 복제 (상태 변화)")
	cluster.ReplicateLog("ServiceA registered")
	cluster.ReplicateLog("ServiceB registered")
	cluster.ReplicateLog("ServiceC registered")
}

