// ============================================================================
// 섹션 1️⃣: Service Registry - 중앙 전화번호부
// ============================================================================

// ServiceInstance: 서비스 인스턴스
type ServiceInstance struct {
	ID       string
	Name     string
	Address  string
	Port     int
	Status   string // "UP", "DOWN"
	LastHeat time.Time
}

// ServiceRegistry: 중앙 서비스 저장소
type ServiceRegistry struct {
	services map[string][]ServiceInstance
	mu       sync.RWMutex
}

// NewServiceRegistry 생성
func NewServiceRegistry() *ServiceRegistry {
	return &ServiceRegistry{
		services: make(map[string][]ServiceInstance),
	}
}

// ============================================================================
// 섹션 2️⃣: 등록/조회/해제 (Register/Discover/Deregister)
// ============================================================================

// Register: 서비스 등록
func (sr *ServiceRegistry) Register(instance ServiceInstance) {
	sr.mu.Lock()
	defer sr.mu.Unlock()

	instance.Status = "UP"
	instance.LastHeat = time.Now()

	sr.services[instance.Name] = append(sr.services[instance.Name], instance)
	fmt.Printf("[Registry] ✓ 등록: %s (%s:%d) - ID: %s\n",
		instance.Name, instance.Address, instance.Port, instance.ID)
}

// Discover: 서비스 발견
func (sr *ServiceRegistry) Discover(serviceName string) []ServiceInstance {
	sr.mu.RLock()
	defer sr.mu.RUnlock()

	var result []ServiceInstance
	for _, instance := range sr.services[serviceName] {
		if instance.Status == "UP" {
			result = append(result, instance)
		}
	}

	fmt.Printf("[Registry] 🔍 발견: %s - %d개 인스턴스\n", serviceName, len(result))
	return result
}

// Deregister: 서비스 해제
func (sr *ServiceRegistry) Deregister(serviceName, instanceID string) {
	sr.mu.Lock()
	defer sr.mu.Unlock()

	instances := sr.services[serviceName]
	for i, instance := range instances {
		if instance.ID == instanceID {
			sr.services[serviceName] = append(instances[:i], instances[i+1:]...)
			fmt.Printf("[Registry] ✗ 해제: %s - ID: %s\n", serviceName, instanceID)
			return
		}
	}
}

// ListAllServices: 모든 서비스 조회
func (sr *ServiceRegistry) ListAllServices() {
	sr.mu.RLock()
	defer sr.mu.RUnlock()

	fmt.Println("\n[Registry] 📊 전체 서비스 목록:")
	for serviceName, instances := range sr.services {
		fmt.Printf("  %s:\n", serviceName)
		for _, instance := range instances {
			fmt.Printf("    - ID:%s, 주소:%s:%d, 상태:%s\n",
				instance.ID, instance.Address, instance.Port, instance.Status)
		}
	}
}

// ============================================================================
// 섹션 3️⃣: Health Check - 서비스 생존 확인
// ============================================================================

// HealthChecker: 주기적 상태 확인
type HealthChecker struct {
	registry *ServiceRegistry
	interval time.Duration
}

// NewHealthChecker 생성
func NewHealthChecker(registry *ServiceRegistry, interval time.Duration) *HealthChecker {
	return &HealthChecker{
		registry: registry,
		interval: interval,
	}
}

// CheckHealth: 상태 확인 및 제거
func (hc *HealthChecker) CheckHealth() {
	ticker := time.NewTicker(hc.interval)
	defer ticker.Stop()

	fmt.Println("\n[HealthChecker] 💓 상태 확인 시작")

	for i := 0; i < 3; i++ {
		<-ticker.C

		// 먼저 상태 확인 대상 수집 (락 짧게)
		hc.registry.mu.RLock()
		var toCheck []struct {
			serviceName string
			instance    ServiceInstance
		}

		for serviceName, instances := range hc.registry.services {
			for _, instance := range instances {
				toCheck = append(toCheck, struct {
					serviceName string
					instance    ServiceInstance
				}{serviceName, instance})
			}
		}
		hc.registry.mu.RUnlock()

		// 상태 확인 (락 없이)
		for _, item := range toCheck {
			if rand.Float32() > 0.5 {
				fmt.Printf("[HealthChecker] ✓ %s (%s) 정상\n", item.serviceName, item.instance.ID)
			} else {
				fmt.Printf("[HealthChecker] ⚠️ %s (%s) 다운 감지 - 제거\n", item.serviceName, item.instance.ID)
				hc.registry.Deregister(item.serviceName, item.instance.ID)
			}
		}
	}
}

// ============================================================================
// 섹션 4️⃣: Client-side Discovery - 클라이언트가 직접 선택
// ============================================================================

// ClientSideDiscovery: 클라이언트 구현
type ClientSideDiscovery struct {
	registry      *ServiceRegistry
	loadBalancer  LoadBalancer
}

// NewClientSideDiscovery 생성
func NewClientSideDiscovery(registry *ServiceRegistry, lb LoadBalancer) *ClientSideDiscovery {
	return &ClientSideDiscovery{
		registry:     registry,
		loadBalancer: lb,
	}
}

// CallService: 서비스 호출
func (csd *ClientSideDiscovery) CallService(serviceName string) {
	// 1. 서비스 발견
	instances := csd.registry.Discover(serviceName)

	if len(instances) == 0 {
		fmt.Printf("[Client] ❌ %s 인스턴스 없음\n", serviceName)
		return
	}

	// 2. 부하분산으로 선택
	selected := csd.loadBalancer.Select(instances)

	// 3. 직접 호출
	fmt.Printf("[Client] 📤 %s에 요청 → %s:%d\n",
		serviceName, selected.Address, selected.Port)
}

// ============================================================================
// 섹션 5️⃣: Server-side Discovery - 로드밸런서가 중개
// ============================================================================

// LoadBalancer: 로드밸런서 인터페이스
type LoadBalancer interface {
	Select(instances []ServiceInstance) ServiceInstance
}

// RoundRobinLB: Round Robin 로드밸런서
type RoundRobinLB struct {
	index int
	mu    sync.Mutex
}

// Select: Round Robin 선택
func (rrb *RoundRobinLB) Select(instances []ServiceInstance) ServiceInstance {
	rrb.mu.Lock()
	defer rrb.mu.Unlock()

	if len(instances) == 0 {
		return ServiceInstance{}
	}

	selected := instances[rrb.index%len(instances)]
	rrb.index++
	return selected
}

// LeastConnectionLB: Least Connection 로드밸런서
type LeastConnectionLB struct {
	connections map[string]int
	mu          sync.Mutex
}

// NewLeastConnectionLB 생성
func NewLeastConnectionLB() *LeastConnectionLB {
	return &LeastConnectionLB{
		connections: make(map[string]int),
	}
}

// Select: 연결이 적은 서버 선택
func (lcb *LeastConnectionLB) Select(instances []ServiceInstance) ServiceInstance {
	lcb.mu.Lock()
	defer lcb.mu.Unlock()

	minConns := int(^uint(0) >> 1) // 최대값
	var selected ServiceInstance

	for _, instance := range instances {
		conns := lcb.connections[instance.ID]
		if conns < minConns {
			minConns = conns
			selected = instance
		}
	}

	// 연결 증가
	lcb.connections[selected.ID]++
	fmt.Printf("[LB] Least Connection: %s 선택 (활성 연결: %d)\n",
		selected.ID, lcb.connections[selected.ID])

	return selected
}

// ReleaseConnection: 연결 해제
func (lcb *LeastConnectionLB) ReleaseConnection(instanceID string) {
	lcb.mu.Lock()
	defer lcb.mu.Unlock()

	if lcb.connections[instanceID] > 0 {
		lcb.connections[instanceID]--
	}
}

// ServerSideProxy: 로드밸런서 프록시
type ServerSideProxy struct {
	registry     *ServiceRegistry
	loadBalancer LoadBalancer
}

// NewServerSideProxy 생성
func NewServerSideProxy(registry *ServiceRegistry, lb LoadBalancer) *ServerSideProxy {
	return &ServerSideProxy{
		registry:     registry,
		loadBalancer: lb,
	}
}

// Forward: 요청 중개
func (ssp *ServerSideProxy) Forward(serviceName string) {
	instances := ssp.registry.Discover(serviceName)

	if len(instances) == 0 {
		fmt.Printf("[Proxy] ❌ %s 인스턴스 없음\n", serviceName)
		return
	}

	selected := ssp.loadBalancer.Select(instances)
	fmt.Printf("[Proxy] 🔄 %s → %s:%d로 forward\n",
		serviceName, selected.Address, selected.Port)
}

