// LoadBalancingComparison: 알고리즘 비교
func LoadBalancingComparison() {
	fmt.Println("\n[부하분산] 알고리즘 비교 시연")
	fmt.Println(repeatStr("-", 68))

	registry := NewServiceRegistry()

	// 서비스 등록
	for i := 1; i <= 3; i++ {
		registry.Register(ServiceInstance{
			ID:      fmt.Sprintf("service-a-%d", i),
			Name:    "service-a",
			Address: fmt.Sprintf("10.0.1.%d", i),
			Port:    3000,
		})
	}

	fmt.Println("\n1️⃣ Round Robin (순환)")
	fmt.Println(repeatStr("-", 68))
	rrLB := &RoundRobinLB{}
	for i := 1; i <= 5; i++ {
		instances := registry.Discover("service-a")
		selected := rrLB.Select(instances)
		fmt.Printf("  요청 %d → %s\n", i, selected.ID)
	}

	fmt.Println("\n2️⃣ Least Connection (연결 적은 곳)")
	fmt.Println(repeatStr("-", 68))
	lcLB := NewLeastConnectionLB()
	for i := 1; i <= 3; i++ {
		instances := registry.Discover("service-a")
		selected := lcLB.Select(instances)
		fmt.Printf("  요청 %d → %s\n", i, selected.ID)
	}

	fmt.Println("\n  (연결 해제)")
	lcLB.ReleaseConnection("service-a-1")
	lcLB.ReleaseConnection("service-a-1")

	fmt.Println("\n  (추가 요청들)")
	for i := 4; i <= 6; i++ {
		instances := registry.Discover("service-a")
		selected := lcLB.Select(instances)
		fmt.Printf("  요청 %d → %s\n", i, selected.ID)
	}
}

