// APIGateway: API Gateway 구현
type APIGateway struct {
	router         *http.ServeMux
	services       map[string]string // path → serviceURL
	jwt            *SimpleJWT
	rateLimiter    *UserRateLimiter
}

// NewAPIGateway 생성
func NewAPIGateway(secretKey string) *APIGateway {
	return &APIGateway{
		router:         http.NewServeMux(),
		services:       make(map[string]string),
		jwt:            NewSimpleJWT(secretKey),
		rateLimiter:    NewUserRateLimiter(),
	}
}

// RegisterService: 서비스 등록
func (gw *APIGateway) RegisterService(path, serviceURL string) {
	gw.services[path] = serviceURL
	fmt.Printf("[Gateway] ✓ 서비스 등록: %s → %s\n", path, serviceURL)
}

// ProxyHandler: ReverseProxy 핸들러
func (gw *APIGateway) ProxyHandler(serviceURL string) http.HandlerFunc {
	return func(w http.ResponseWriter, r *http.Request) {
		target, _ := url.Parse(serviceURL)
		proxy := httputil.NewSingleHostReverseProxy(target)

		// 사용자 정보를 헤더에 추가 (내부 서비스로 전파)
		userID, _ := r.Context().Value("user_id").(string)
		if userID != "" {
			r.Header.Set("X-User-ID", userID)
			r.Header.Set("X-User-Role", r.Context().Value("role").(string))
			r.Header.Set("X-Internal-Call", "true")
		}

		fmt.Printf("[Gateway] 🔄 %s → %s\n", r.URL.Path, serviceURL)

		proxy.ServeHTTP(w, r)
	}
}

// SetupRoutes: 라우팅 설정
func (gw *APIGateway) SetupRoutes() {
	// 공개 엔드포인트
	gw.router.Handle("/auth/login", CORSMiddleware(http.HandlerFunc(gw.LoginHandler())))
	gw.router.Handle("/auth/refresh", CORSMiddleware(RefreshHandler(gw.jwt)))

	// 보호된 엔드포인트 - /api/user/*
	userHandler := CORSMiddleware(
		SanitizeHeadersMiddleware(
			AuthMiddleware(gw.jwt)(
				PropagateAuthMiddleware(
					http.HandlerFunc(gw.ProxyHandler("http://localhost:3001")),
				),
			),
		),
	)
	gw.router.Handle("/api/user/", userHandler)

	// 속도 제한이 있는 엔드포인트 - /api/calc/*
	calcHandler := CORSMiddleware(
		SanitizeHeadersMiddleware(
			AuthMiddleware(gw.jwt)(
				RateLimitMiddleware(gw.rateLimiter)(
					PropagateAuthMiddleware(
						http.HandlerFunc(gw.ProxyHandler("http://localhost:5000")),
					),
				),
			),
		),
	)
	gw.router.Handle("/api/calc/", calcHandler)
}

// LoginHandler: 로그인 엔드포인트
func (gw *APIGateway) LoginHandler() http.HandlerFunc {
	return func(w http.ResponseWriter, r *http.Request) {
		if r.Method != http.MethodPost {
			http.Error(w, "Method not allowed", http.StatusMethodNotAllowed)
			return
		}

		var loginReq struct {
			UserID   string `json:"user_id"`
			Password string `json:"password"`
		}
		json.NewDecoder(r.Body).Decode(&loginReq)

		// 간단한 검증 (실제로는 DB 조회)
		if loginReq.UserID == "" || loginReq.Password == "" {
			http.Error(w, "Invalid credentials", http.StatusBadRequest)
			return
		}

		// 권한 결정 (간단한 로직)
		role := "user"
		if loginReq.UserID == "admin" {
			role = "admin"
		}

		// Access Token (1시간) + Refresh Token (7일)
		accessToken, _ := gw.jwt.GenerateToken(loginReq.UserID, loginReq.UserID, role, 1*time.Hour)
		refreshToken, _ := gw.jwt.GenerateToken(loginReq.UserID, loginReq.UserID, role, 7*24*time.Hour)

		fmt.Printf("[Login] ✓ 로그인 성공: %s (Role: %s)\n", loginReq.UserID, role)

		w.Header().Set("Content-Type", "application/json")
		json.NewEncoder(w).Encode(map[string]string{
			"access_token":  accessToken,
			"refresh_token": refreshToken,
			"token_type":    "Bearer",
		})
	}
}

