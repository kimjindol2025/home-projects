// Helper 함수들
// ============================================================================

func repeatStr(s string, count int) string {
	result := ""
	for i := 0; i < count; i++ {
		result += s
	}
	return result
}

// 간단한 Base64 인코딩/디코딩
func encodeBase64(data []byte) string {
	const alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-_"
	result := ""
	for i := 0; i < len(data); i += 3 {
		b1 := data[i]
		b2 := byte(0)
		b3 := byte(0)

		if i+1 < len(data) {
			b2 = data[i+1]
		}
		if i+2 < len(data) {
			b3 = data[i+2]
		}

		result += string(alphabet[(b1 >> 2) & 0x3F])
		result += string(alphabet[((b1 & 0x03) << 4) | ((b2 >> 4) & 0x0F)])
		if i+1 < len(data) {
			result += string(alphabet[((b2 & 0x0F) << 2) | ((b3 >> 6) & 0x03)])
		}
		if i+2 < len(data) {
			result += string(alphabet[b3 & 0x3F])
		}
	}
	return result
}

// 간단한 Base64 디코딩
func decodeBase64(s string) ([]byte, error) {
	const alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-_"
	result := []byte{}

	for i := 0; i < len(s); i += 4 {
		b1 := strings.Index(alphabet, string(s[i]))
		b2 := 0
		b3 := 0
		b4 := 0

		if i+1 < len(s) {
			b2 = strings.Index(alphabet, string(s[i+1]))
		}
		if i+2 < len(s) {
			b3 = strings.Index(alphabet, string(s[i+2]))
		}
		if i+3 < len(s) {
			b4 = strings.Index(alphabet, string(s[i+3]))
		}

		result = append(result, byte((b1<<2)|(b2>>4)))
		if i+2 < len(s) {
			result = append(result, byte(((b2&0x0f)<<4)|(b3>>2)))
		}
		if i+3 < len(s) {
			result = append(result, byte(((b3&0x03)<<6)|b4))
		}
	}

	return result, nil
}

// 간단한 HMAC-SHA256 (XOR 기반 간단 버전)
func simpleHMAC(message, key string) string {
	hash := 0
	for _, c := range message {
		hash = (hash*31 + int(c)) % 1000000
	}
	for _, c := range key {
		hash = (hash*31 + int(c)) % 1000000
	}
	return fmt.Sprintf("%06d", hash)
}

