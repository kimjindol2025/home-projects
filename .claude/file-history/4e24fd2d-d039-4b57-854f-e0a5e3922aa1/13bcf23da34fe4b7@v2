// 섹션 2️⃣: 인증 미들웨어
// ============================================================================

// AuthMiddleware: JWT 인증 미들웨어
func AuthMiddleware(jwt *SimpleJWT) func(http.Handler) http.Handler {
	return func(next http.Handler) http.Handler {
		return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
			// Authorization 헤더 추출
			authHeader := r.Header.Get("Authorization")
			if authHeader == "" {
				fmt.Println("[Auth] ❌ Authorization 헤더 없음")
				http.Error(w, "Missing authorization header", http.StatusUnauthorized)
				return
			}

			// "Bearer " 접두사 제거
			tokenString := strings.TrimPrefix(authHeader, "Bearer ")
			if tokenString == authHeader {
				fmt.Println("[Auth] ❌ Bearer 토큰 형식 오류")
				http.Error(w, "Invalid authorization format", http.StatusUnauthorized)
				return
			}

			// JWT 검증
			claims, err := jwt.ValidateToken(tokenString)
			if err != nil {
				http.Error(w, fmt.Sprintf("Invalid token: %v", err), http.StatusUnauthorized)
				return
			}

			// Context에 사용자 정보 저장
			ctx := context.WithValue(r.Context(), "user_id", claims.UserID)
			ctx = context.WithValue(ctx, "role", claims.Role)
			ctx = context.WithValue(ctx, "name", claims.Name)

			next.ServeHTTP(w, r.WithContext(ctx))
		})
	}
}

// ============================================================================
// 섹션 3️⃣: 권한 전파 (Authorization Propagation)
// ============================================================================

// PropagateAuthMiddleware: 내부 서비스에 사용자 정보 전파
func PropagateAuthMiddleware(next http.Handler) http.Handler {
	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		userID, ok := r.Context().Value("user_id").(string)
		if !ok {
			fmt.Println("[Propagate] ❌ 사용자 정보 없음")
			http.Error(w, "User info not found", http.StatusInternalServerError)
			return
		}

		role, _ := r.Context().Value("role").(string)

		// 내부 서비스로 전달할 헤더 추가 (Context에 저장)
		fmt.Printf("[Propagate] ✓ 사용자 정보 전파: %s (Role: %s)\n", userID, role)

		// 다음 미들웨어/핸들러에 전달
		next.ServeHTTP(w, r)
	})
}

// SanitizeHeadersMiddleware: 외부 요청의 X-* 헤더 제거
func SanitizeHeadersMiddleware(next http.Handler) http.Handler {
	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		// 외부 요청에서 보안 헤더 제거 (스푸핑 방지)
		r.Header.Del("X-User-ID")
		r.Header.Del("X-User-Role")
		r.Header.Del("X-User-Name")
		r.Header.Del("X-Internal-Call")

		fmt.Println("[Sanitize] ✓ 외부 헤더 제거")

		next.ServeHTTP(w, r)
	})
}

// ============================================================================
// 섹션 4️⃣: Rate Limiting (Token Bucket)
// ============================================================================

// UserRateLimiter: 사용자별 속도 제한
type UserRateLimiter struct {
	limiters map[string]*rate.Limiter
	mu       sync.Mutex
}

// NewUserRateLimiter 생성
func NewUserRateLimiter() *UserRateLimiter {
	return &UserRateLimiter{
		limiters: make(map[string]*rate.Limiter),
	}
}

// Allow: 요청 허용 여부
func (url *UserRateLimiter) Allow(userID string) bool {
	url.mu.Lock()
	limiter, exists := url.limiters[userID]
	if !exists {
		// 사용자별: 초당 5개 요청, burst 10
		limiter = rate.NewLimiter(rate.Limit(5), 10)
		url.limiters[userID] = limiter
	}
	url.mu.Unlock()

	allowed := limiter.Allow()
	if !allowed {
		fmt.Printf("[RateLimit] ⛔ 사용자 %s 속도 제한 초과\n", userID)
	}

	return allowed
}

// RateLimitMiddleware: 속도 제한 미들웨어
func RateLimitMiddleware(rl *UserRateLimiter) func(http.Handler) http.Handler {
	return func(next http.Handler) http.Handler {
		return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
			userID, ok := r.Context().Value("user_id").(string)
			if !ok {
				// 인증되지 않은 사용자: 전역 제한 (초당 1개)
				userID = "anonymous"
			}

			if !rl.Allow(userID) {
				http.Error(w, "Rate limit exceeded", http.StatusTooManyRequests)
				return
			}

			fmt.Printf("[RateLimit] ✓ %s 요청 허용\n", userID)
			next.ServeHTTP(w, r)
		})
	}
}

// ============================================================================
// 섹션 5️⃣: Token Refresh - 토큰 갱신
// ============================================================================

// RefreshHandler: 토큰 갱신 엔드포인트
func RefreshHandler(jwt *SimpleJWT) http.HandlerFunc {
	return func(w http.ResponseWriter, r *http.Request) {
		if r.Method != http.MethodPost {
			http.Error(w, "Method not allowed", http.StatusMethodNotAllowed)
			return
		}

		var req struct {
			RefreshToken string `json:"refresh_token"`
		}
		json.NewDecoder(r.Body).Decode(&req)

		// Refresh Token 검증
		claims, err := jwt.ValidateToken(req.RefreshToken)
		if err != nil {
			fmt.Println("[Refresh] ❌ Refresh 토큰 검증 실패")
			http.Error(w, "Invalid refresh token", http.StatusUnauthorized)
			return
		}

		// 새 Access Token 생성 (1시간)
		newAccessToken, _ := jwt.GenerateToken(claims.UserID, claims.Name, claims.Role, 1*time.Hour)

		fmt.Printf("[Refresh] ✓ 토큰 갱신: %s\n", claims.UserID)

		w.Header().Set("Content-Type", "application/json")
		json.NewEncoder(w).Encode(map[string]string{
			"access_token": newAccessToken,
		})
	}
}

// ============================================================================
// 섹션 6️⃣: CORS (Cross-Origin Resource Sharing)
// ============================================================================

// CORSMiddleware: CORS 처리
func CORSMiddleware(next http.Handler) http.Handler {
	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		w.Header().Set("Access-Control-Allow-Origin", "*")
		w.Header().Set("Access-Control-Allow-Methods", "GET, POST, PUT, DELETE, OPTIONS")
		w.Header().Set("Access-Control-Allow-Headers", "Content-Type, Authorization")

		// Preflight 요청 처리
		if r.Method == http.MethodOptions {
			fmt.Println("[CORS] ✓ Preflight 요청 허용")
			w.WriteHeader(http.StatusOK)
			return
		}

		next.ServeHTTP(w, r)
	})
}

