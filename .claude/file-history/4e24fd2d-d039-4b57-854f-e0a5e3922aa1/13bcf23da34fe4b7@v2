// Claims: JWT 클레임
type Claims struct {
	UserID string `json:"user_id"`
	Name   string `json:"name"`
	Role   string `json:"role"`
	ExpAt  int64  `json:"exp"`
	IssuedAt int64 `json:"iat"`
}

// SimpleJWT: JWT 구현 (간단한 버전)
type SimpleJWT struct {
	secretKey string
}

// NewSimpleJWT 생성
func NewSimpleJWT(secretKey string) *SimpleJWT {
	return &SimpleJWT{
		secretKey: secretKey,
	}
}

// GenerateToken: JWT 토큰 생성
func (j *SimpleJWT) GenerateToken(userID, name, role string, duration time.Duration) (string, error) {
	claims := Claims{
		UserID:   userID,
		Name:     name,
		Role:     role,
		IssuedAt: time.Now().Unix(),
		ExpAt:    time.Now().Add(duration).Unix(),
	}

	// Payload 인코딩
	payload, _ := json.Marshal(claims)
	payloadB64 := encodeBase64(payload)

	// Header 인코딩
	header := map[string]string{
		"alg": "HS256",
		"typ": "JWT",
	}
	headerBytes, _ := json.Marshal(header)
	headerB64 := encodeBase64(headerBytes)

	// Signature 생성
	message := headerB64 + "." + payloadB64
	signature := simpleHMAC(message, j.secretKey)

	token := headerB64 + "." + payloadB64 + "." + signature
	fmt.Printf("[JWT] ✓ 토큰 발급: %s (유효기간: %v)\n", userID, duration)

	return token, nil
}

// ValidateToken: JWT 토큰 검증
func (j *SimpleJWT) ValidateToken(token string) (*Claims, error) {
	parts := strings.Split(token, ".")
	if len(parts) != 3 {
		return nil, fmt.Errorf("invalid token format")
	}

	headerB64, payloadB64, signatureB64 := parts[0], parts[1], parts[2]

	// Signature 검증
	message := headerB64 + "." + payloadB64
	expectedSignature := simpleHMAC(message, j.secretKey)

	if signatureB64 != expectedSignature {
		fmt.Println("[JWT] ❌ 서명 검증 실패")
		return nil, fmt.Errorf("invalid signature")
	}

	// Payload 디코딩
	payloadBytes, _ := decodeBase64(payloadB64)
	var claims Claims
	json.Unmarshal(payloadBytes, &claims)

	// 만료 확인
	if time.Now().Unix() > claims.ExpAt {
		fmt.Printf("[JWT] ❌ 토큰 만료: %s\n", claims.UserID)
		return nil, fmt.Errorf("token expired")
	}

	fmt.Printf("[JWT] ✓ 토큰 검증 성공: %s (Role: %s)\n", claims.UserID, claims.Role)
	return &claims, nil
}

