// ============================================================================
// Section 5: Work Stealing Scheduler Concept
// ============================================================================

// WorkerTask: 작업 항목
type WorkerTask struct {
	ID    int
	Value int
}

// WorkStealingWorker: 작업 도난 기능이 있는 워커
type WorkStealingWorker struct {
	id        int
	localTasks chan *WorkerTask
	stealCount int64
}

// NewWorkStealingWorker: 워커 생성
func NewWorkStealingWorker(id int, queueSize int) *WorkStealingWorker {
	return &WorkStealingWorker{
		id:        id,
		localTasks: make(chan *WorkerTask, queueSize),
		stealCount: 0,
	}
}

// EnqueueLocal: 로컬 작업 큐에 추가
func (w *WorkStealingWorker) EnqueueLocal(task *WorkerTask) bool {
	select {
	case w.localTasks <- task:
		return true
	default:
		return false
	}
}

// TryStealFrom: 다른 워커에서 작업 도난 시도
func (w *WorkStealingWorker) TryStealFrom(victim *WorkStealingWorker) *WorkerTask {
	select {
	case task := <-victim.localTasks:
		atomic.AddInt64(&w.stealCount, 1)
		return task
	default:
		return nil
	}
}

// StealCount: 도난당한 작업 수 조회
func (w *WorkStealingWorker) StealCount() int64 {
	return atomic.LoadInt64(&w.stealCount)
}

