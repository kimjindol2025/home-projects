// BenchmarkComparison: 성능 비교
type BenchmarkComparison struct {
	NormalCopyTime    time.Duration
	ZeroCopyTime      time.Duration
	MutexTime         time.Duration
	LockFreeTime      time.Duration
	OnHeapGCTime      time.Duration
	OffHeapAllocTime  time.Duration
}

// RunBenchmarks: 모든 벤치마크 실행
func RunBenchmarks() *BenchmarkComparison {
	bc := &BenchmarkComparison{}

	// 1. Zero-Copy vs Normal Copy
	fmt.Println("📊 Zero-Copy Performance Test")
	zc := NewZeroCopyPacketProcessor(1024)
	start := time.Now()
	for i := 0; i < 10000; i++ {
		_ = zc.ProcessPacket()
	}
	bc.ZeroCopyTime = time.Since(start)
	fmt.Printf("  Zero-Copy: %v\n", bc.ZeroCopyTime)

	// 2. Lock-Free Counter
	fmt.Println("📊 Lock-Free Counter Test")
	counter := &AtomicCounter{}
	start = time.Now()
	for i := 0; i < 1000000; i++ {
		counter.Increment()
	}
	bc.LockFreeTime = time.Since(start)
	fmt.Printf("  Lock-Free: %v\n", bc.LockFreeTime)

	// 3. Off-Heap Allocation
	fmt.Println("📊 Off-Heap Allocation Test")
	start = time.Now()
	ob, _ := AllocOffHeap(1024 * 1024)
	bc.OffHeapAllocTime = time.Since(start)
	ob.Release()
	fmt.Printf("  Off-Heap Alloc: %v\n", bc.OffHeapAllocTime)

	return bc
}

