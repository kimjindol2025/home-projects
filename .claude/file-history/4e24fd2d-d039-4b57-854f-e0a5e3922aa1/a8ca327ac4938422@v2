// MemoryHierarchy: 메모리 계층 구조 시뮬레이션
type MemoryHierarchy struct {
	l1Cache  map[int64]interface{} // 64KB (시뮬레이션)
	l2Cache  map[int64]interface{} // 256KB (시뮬레이션)
	l3Cache  map[int64]interface{} // 8MB (시뮬레이션)
	mainMem  map[int64]interface{} // 무제한
	l1Hits   int64
	l1Misses int64
	mu       sync.RWMutex          // 동시성 보호
}

// NewMemoryHierarchy: 메모리 계층 초기화
func NewMemoryHierarchy() *MemoryHierarchy {
	return &MemoryHierarchy{
		l1Cache: make(map[int64]interface{}),
		l2Cache: make(map[int64]interface{}),
		l3Cache: make(map[int64]interface{}),
		mainMem: make(map[int64]interface{}),
	}
}

// Access: 메모리 접근 (캐시 계층 시뮬레이션)
func (mh *MemoryHierarchy) Access(address int64) (interface{}, int) {
	mh.mu.RLock()
	defer mh.mu.RUnlock()

	// L1 캐시 확인
	if val, ok := mh.l1Cache[address]; ok {
		atomic.AddInt64(&mh.l1Hits, 1)
		return val, 1 // L1 (1 사이클)
	}
	atomic.AddInt64(&mh.l1Misses, 1)

	// L2 캐시 확인
	if val, ok := mh.l2Cache[address]; ok {
		return val, 4 // L2 (4 사이클)
	}

	// L3 캐시 확인
	if val, ok := mh.l3Cache[address]; ok {
		return val, 10 // L3 (10 사이클)
	}

	// 메인 메모리 접근
	if val, ok := mh.mainMem[address]; ok {
		return val, 100 // 메인 메모리 (100 사이클)
	}

	return nil, 0
}

// Store: 값 저장
func (mh *MemoryHierarchy) Store(address int64, value interface{}) {
	mh.mu.Lock()
	defer mh.mu.Unlock()

	mh.l1Cache[address] = value
}

