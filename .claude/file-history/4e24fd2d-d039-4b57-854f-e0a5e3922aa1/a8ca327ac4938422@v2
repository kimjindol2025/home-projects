// OffHeapBuffer: mmap을 사용한 오프힙 버퍼
type OffHeapBuffer struct {
	data     []byte
	refCount int64
	file     *os.File
	size     int
}

// AllocOffHeap: 오프힙 메모리 할당 (mmap 사용)
func AllocOffHeap(size int) (*OffHeapBuffer, error) {
	// 1. 임시 파일 생성
	file, err := os.CreateTemp("", "offheap_")
	if err != nil {
		return nil, err
	}

	// 2. 파일 크기 설정
	if err := file.Truncate(int64(size)); err != nil {
		file.Close()
		return nil, err
	}

	// 3. mmap (실제로는 더 복잡함)
	// 여기서는 시뮬레이션: 일반 메모리 할당
	data := make([]byte, size)

	return &OffHeapBuffer{
		data:     data,
		refCount: 1,
		file:     file,
		size:     size,
	}, nil
}

// Retain: 참조 카운트 증가
func (ob *OffHeapBuffer) Retain() {
	atomic.AddInt64(&ob.refCount, 1)
}

// Release: 참조 카운트 감소 및 메모리 해제
func (ob *OffHeapBuffer) Release() error {
	if atomic.AddInt64(&ob.refCount, -1) == 0 {
		ob.file.Close()
		return os.Remove(ob.file.Name())
	}
	return nil
}

// Value: 오프힙 메모리 접근
func (ob *OffHeapBuffer) Value() []byte {
	return ob.data
}

