// Section 7: GC vs Off-Heap Memory Impact
// ============================================================================

// GCImpactAnalyzer: GC 영향 분석
type GCImpactAnalyzer struct {
	beforeMemory uint64
	afterMemory  uint64
	gcPause      time.Duration
}

// SimulateGC: GC 시뮬레이션
func (gia *GCImpactAnalyzer) SimulateGC() {
	var m runtime.MemStats
	runtime.ReadMemStats(&m)
	gia.beforeMemory = m.HeapAlloc

	start := time.Now()
	runtime.GC()
	gia.gcPause = time.Since(start)

	runtime.ReadMemStats(&m)
	gia.afterMemory = m.HeapAlloc
}

// GetReport: GC 보고서
func (gia *GCImpactAnalyzer) GetReport() string {
	return fmt.Sprintf("GC Pause: %v, Memory Freed: %d bytes",
		gia.gcPause, gia.beforeMemory-gia.afterMemory)
}

