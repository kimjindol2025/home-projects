// PacketHeader: 네트워크 패킷 헤더 구조
type PacketHeader struct {
	Version      byte
	HeaderLength byte
	TotalLength  uint16
	Identification uint16
	Flags        byte
	FragmentOffset uint16
	TTL          byte
	Protocol     byte
	Checksum     uint16
	SrcIP        [4]byte
	DstIP        [4]byte
}

// ZeroCopyPacketProcessor: 데이터 복사 없이 직접 처리
type ZeroCopyPacketProcessor struct {
	buffer []byte
	size   int
}

// NewZeroCopyPacketProcessor: 패킷 버퍼 생성 (실제 mmap 시뮬레이션)
func NewZeroCopyPacketProcessor(size int) *ZeroCopyPacketProcessor {
	return &ZeroCopyPacketProcessor{
		buffer: make([]byte, size),
		size:   size,
	}
}

// ProcessPacket: unsafe.Pointer를 사용한 0-복사 처리
func (zc *ZeroCopyPacketProcessor) ProcessPacket() *PacketHeader {
	// 1. 버퍼의 시작 주소를 PacketHeader 포인터로 변환
	// 2. 실제로는 패킷이 NIC DMA 버퍼에 있음 (커널 메모리)
	// 3. Go 프로그램이 mmap으로 접근하므로 데이터 복사 없음

	// PacketHeader는 최소 22 바이트
	if len(zc.buffer) < 22 {
		return nil
	}

	// unsafe 포인터 변환 (데이터 복사 없음!)
	header := (*PacketHeader)(unsafe.Pointer(&zc.buffer[0]))
	return header
}

