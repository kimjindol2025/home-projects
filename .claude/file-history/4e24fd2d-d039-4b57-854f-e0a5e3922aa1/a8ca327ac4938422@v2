// ComputationRequest: Julia 계산 요청
type ComputationRequest struct {
	ID      string
	OpType  string // "matmul", "svd", "solve"
	DataA   []float64
	DataB   []float64
	Rows    int
	Cols    int
	TraceID string // OpenTelemetry 추적 ID
}

// ComputationResponse: Julia 계산 응답
type ComputationResponse struct {
	ID       string
	Result   []float64
	Error    string
	Duration time.Duration
	TraceID  string
}

// HybridKernelControlPlane: 제어 평면 (Go)
type HybridKernelControlPlane struct {
	workers       []*WorkStealingWorker
	requestQueue  chan *ComputationRequest
	responseQueue chan *ComputationResponse
	mu            sync.RWMutex
}

// NewHybridKernelControlPlane: 제어 평면 생성
func NewHybridKernelControlPlane(numWorkers int) *HybridKernelControlPlane {
	workers := make([]*WorkStealingWorker, numWorkers)
	for i := 0; i < numWorkers; i++ {
		workers[i] = NewWorkStealingWorker(i, 100)
	}

	return &HybridKernelControlPlane{
		workers:       workers,
		requestQueue:  make(chan *ComputationRequest, 1000),
		responseQueue: make(chan *ComputationResponse, 1000),
	}
}

// DispatchRequest: 계산 요청 분배
func (cp *HybridKernelControlPlane) DispatchRequest(req *ComputationRequest) {
	// 라운드 로빈으로 워커에 작업 할당
	workerID := len(req.ID) % len(cp.workers)
	worker := cp.workers[workerID]

	task := &WorkerTask{
		ID:    len(req.ID),
		Value: len(req.DataA),
	}

	if !worker.EnqueueLocal(task) {
		// 큐가 가득 찼으면 다른 워커에서 도난
		for _, other := range cp.workers {
			if other.id != worker.id {
				task := &WorkerTask{
					ID:    len(req.ID),
					Value: len(req.DataA),
				}
				if other.EnqueueLocal(task) {
					break
				}
			}
		}
	}
}

// GetWorkerStats: 워커 통계
func (cp *HybridKernelControlPlane) GetWorkerStats() map[int]int64 {
	stats := make(map[int]int64)
	for i, w := range cp.workers {
		stats[i] = w.StealCount()
	}
	return stats
}

