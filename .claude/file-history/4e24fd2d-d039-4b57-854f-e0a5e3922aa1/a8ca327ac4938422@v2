// AtomicCounter: 캐시 라인 padding을 포함한 원자적 카운터
type AtomicCounter struct {
	count int64
	_     [56]byte // 패딩: 64바이트 캐시 라인 (false sharing 방지)
}

// Increment: 원자적 증가
func (ac *AtomicCounter) Increment() {
	atomic.AddInt64(&ac.count, 1)
}

// Value: 현재 값 읽음
func (ac *AtomicCounter) Value() int64 {
	return atomic.LoadInt64(&ac.count)
}

// LockFreeNode: lock-free 큐의 노드
type LockFreeNode struct {
	value interface{}
	next  *LockFreeNode
}

// SimpleLockFreeQueue: CAS 기반의 간단한 lock-free 큐
type SimpleLockFreeQueue struct {
	head *LockFreeNode
	tail *LockFreeNode
	mu   sync.Mutex // 실제 lock-free 아님 (교육용)
}

// NewSimpleLockFreeQueue: 큐 초기화 (sentinel 노드 포함)
func NewSimpleLockFreeQueue() *SimpleLockFreeQueue {
	sentinel := &LockFreeNode{}
	return &SimpleLockFreeQueue{
		head: sentinel,
		tail: sentinel,
	}
}

// Enqueue: 요소 추가
func (q *SimpleLockFreeQueue) Enqueue(value interface{}) {
	q.mu.Lock()
	defer q.mu.Unlock()

	newNode := &LockFreeNode{value: value}
	q.tail.next = newNode
	q.tail = newNode
}

// Dequeue: 요소 제거
func (q *SimpleLockFreeQueue) Dequeue() (interface{}, bool) {
	q.mu.Lock()
	defer q.mu.Unlock()

	if q.head.next == nil {
		return nil, false
	}

	node := q.head.next
	q.head = node
	return node.value, true
}

