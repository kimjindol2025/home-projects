### 📋 슬라이스 필터링

```go
// 조건에 맞는 요소 추출
func filterOdd(nums []int) []int {
    result := make([]int, 0)
    for _, num := range nums {
        if num%2 != 0 {
            result = append(result, num)
        }
    }
    return result
}

nums := []int{1, 2, 3, 4, 5, 6}
odds := filterOdd(nums)  // [1, 3, 5]
```

---

### 📋 슬라이스 변환

```go
// 모든 요소에 함수 적용
func transform(nums []int, f func(int) int) []int {
    result := make([]int, len(nums))
    for i, num := range nums {
        result[i] = f(num)
    }
    return result
}

nums := []int{1, 2, 3, 4}
doubled := transform(nums, func(x int) int { return x * 2 })
// [2, 4, 6, 8]
```

