func section8_assignment2_2() {
	fmt.Println("\n============================================================")
	fmt.Println("섹션 8: Assignment 2-2 - 실전 벤치마킹")
	fmt.Println("============================================================")

	// Assignment 1: 데이터 필터링 파이프라인
	fmt.Println("\n[8-1] Assignment 2-2-1: 데이터 필터링 파이프라인")
	fmt.Println("요구사항: 1-100 생성 → 짝수 필터 → 제곱 변환 → 결과 수집")

	// 파이프라인 구성
	gen := make(chan int, 10)
	go func() {
		for i := 1; i <= 100; i++ {
			gen <- i
		}
		close(gen)
	}()

	even := make(chan int, 10)
	go func() {
		for i := range gen {
			if i%2 == 0 {
				even <- i
			}
		}
		close(even)
	}()

	squared := make(chan int, 10)
	go func() {
		for i := range even {
			squared <- i * i
		}
		close(squared)
	}()

	count := 0
	sumSquares := 0
	for s := range squared {
		count++
		sumSquares += s
	}

	fmt.Printf("결과: %d개 짝수의 제곱, 합계: %d\n", count, sumSquares)
	fmt.Println("예상: 50개 짝수의 제곱")

	// Assignment 2: Select 우선순위 처리
	fmt.Println("\n[8-2] Assignment 2-2-2: Select 우선순위 처리")
	fmt.Println("요구사항: important 채널 우선 처리, 그 후 normal 채널")

	important := make(chan string, 100)
	normal := make(chan string, 100)

	// important 데이터 배포
	go func() {
		for i := 0; i < 50; i++ {
			important <- fmt.Sprintf("IMP-%d", i)
		}
		close(important)
	}()

	// normal 데이터 배포
	go func() {
		for i := 0; i < 50; i++ {
			normal <- fmt.Sprintf("NOR-%d", i)
		}
		close(normal)
	}()

	importantCount := 0
	normalCount := 0

	for importantCount < 50 || normalCount < 50 {
		// 우선순위 처리: important 먼저
		if important != nil {
			select {
			case _, ok := <-important:
				if ok {
					importantCount++
				} else {
					important = nil
				}
			default:
				if normal != nil {
					select {
					case _, ok := <-normal:
						if ok {
							normalCount++
						} else {
							normal = nil
						}
					default:
					}
				}
			}
		} else if normal != nil {
			select {
			case _, ok := <-normal:
				if ok {
					normalCount++
				} else {
					normal = nil
				}
			default:
			}
		}
	}

	fmt.Printf("처리 결과: important=%d, normal=%d\n", importantCount, normalCount)

	// Assignment 3: 성능 벤치마크 (순차 vs 병렬)
	fmt.Println("\n[8-3] Assignment 2-2-3: 성능 벤치마크")
	fmt.Println("요구사항: 1워커 vs 8워커 처리량 비교")

	benchmarkWorkerCount := func(numWorkers int, totalJobs int) time.Duration {
		jobs := make(chan int, 50)
		done := make(chan bool, numWorkers)

		start := time.Now()

		// 워커 시작
		for w := 0; w < numWorkers; w++ {
			go func() {
				for range jobs {
					time.Sleep(1 * time.Millisecond)
				}
				done <- true
			}()
		}

		// 작업 배포
		go func() {
			for j := 0; j < totalJobs; j++ {
				jobs <- j
			}
			close(jobs)
		}()

		// 워커 대기
		for i := 0; i < numWorkers; i++ {
			<-done
		}

		return time.Since(start)
	}

	const totalJobs = 200

	fmt.Printf("\n벤치마크 시작: %d개 작업 (각 1ms)\n", totalJobs)

	duration1 := benchmarkWorkerCount(1, totalJobs)
	fmt.Printf("워커 1개: %v (처리량: %.0f ops/s)\n", duration1, float64(totalJobs)/duration1.Seconds())

	duration8 := benchmarkWorkerCount(8, totalJobs)
	fmt.Printf("워커 8개: %v (처리량: %.0f ops/s)\n", duration8, float64(totalJobs)/duration8.Seconds())

	improvement := float64(duration1.Nanoseconds()) / float64(duration8.Nanoseconds())
	fmt.Printf("\n성능 개선 (1→8): %.2fx\n", improvement)
	fmt.Printf("예상 개선도: ~8배, 실제: %.2fx\n", improvement)

	// Summary
	fmt.Println("\n[Assignment 2-2 완료]")
	fmt.Println("✓ 데이터 필터링 파이프라인: 1-100 → 짝수 → 제곱")
	fmt.Println("✓ Select 우선순위 처리: important 먼저 소진")
	fmt.Println("✓ 성능 벤치마크: 병렬 처리 성능 검증")
}

