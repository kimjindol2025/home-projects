// 섹션 6: Select 우선순위 처리
// ============================================================

func section6_selectPriority() {
	fmt.Println("\n============================================================")
	fmt.Println("섹션 6: Select 우선순위 처리")
	fmt.Println("============================================================")

	// [6-1] 기본 select
	fmt.Println("\n[6-1] 기본 Select (순서 무관)")

	important := make(chan string, 5)
	normal := make(chan string, 5)

	go func() {
		for i := 0; i < 3; i++ {
			important <- fmt.Sprintf("중요-%d", i)
			time.Sleep(30 * time.Millisecond)
		}
		close(important)
	}()

	go func() {
		for i := 0; i < 3; i++ {
			normal <- fmt.Sprintf("일반-%d", i)
			time.Sleep(25 * time.Millisecond)
		}
		close(normal)
	}()

	count := 0
	totalExpected := 6

	for count < totalExpected {
		select {
		case msg, ok := <-important:
			if ok {
				fmt.Printf("[우선] %s\n", msg)
			} else {
				important = nil // 채널 비활성화
			}
			count++
		case msg, ok := <-normal:
			if ok {
				fmt.Printf("[일반] %s\n", msg)
			} else {
				normal = nil
			}
			count++
		}
	}

	// [6-2] 우선순위 처리 (for-select 루프 내 중첩)
	fmt.Println("\n[6-2] 우선순위 처리 (important 먼저 소진)")

	time.Sleep(200 * time.Millisecond) // [6-1] 완료 대기

	important2 := make(chan string, 5)
	normal2 := make(chan string, 5)

	go func() {
		for i := 0; i < 5; i++ {
			important2 <- fmt.Sprintf("important-%d", i)
		}
		close(important2)
	}()

	go func() {
		for i := 0; i < 5; i++ {
			normal2 <- fmt.Sprintf("normal-%d", i)
		}
		close(normal2)
	}()

	// 우선순위 처리: important가 있으면 먼저 처리
	time.Sleep(50 * time.Millisecond)
	count = 0
	processed := 0

	for count < 10 {
		// 먼저 important2 채널 확인
		if important2 != nil {
			select {
			case msg, ok := <-important2:
				if ok {
					fmt.Printf("[우선] %s\n", msg)
					processed++
				} else {
					important2 = nil
				}
				count++
				continue
			default: // important2가 준비되지 않았으면 normal2 시도
			}
		}

		// important2가 없으면 normal2 처리
		if normal2 != nil {
			select {
			case msg, ok := <-normal2:
				if ok {
					fmt.Printf("[일반] %s\n", msg)
					processed++
				} else {
					normal2 = nil
				}
				count++
			default:
				if important2 == nil && normal2 == nil {
					break
				}
				time.Sleep(10 * time.Millisecond)
			}
		} else {
			break
		}
	}

	fmt.Printf("처리 완료: %d개\n", processed)
}

// ============================================================
// 섹션 7: 파이프라인 아키텍처 (Generator → Filter → Square)
// ============================================================

func section7_pipeline() {
	fmt.Println("\n============================================================")
	fmt.Println("섹션 7: 파이프라인 아키텍처")
	fmt.Println("============================================================")

	fmt.Println("\n[7-1] 3단계 파이프라인: 생성 → 필터 → 변환")

	// Stage 1: Generator (1-10 생성)
	generator := func() <-chan int {
		ch := make(chan int, 5)
		go func() {
			for i := 1; i <= 10; i++ {
				fmt.Printf("[생성기] %d\n", i)
				ch <- i
			}
			close(ch)
		}()
		return ch
	}

	// Stage 2: Filter (짝수만 필터)
	filter := func(in <-chan int) <-chan int {
		ch := make(chan int, 5)
		go func() {
			for val := range in {
				if val%2 == 0 {
					fmt.Printf("[필터] %d 통과\n", val)
					ch <- val
				} else {
					fmt.Printf("[필터] %d 제외\n", val)
				}
			}
			close(ch)
		}()
		return ch
	}

	// Stage 3: Square (제곱 계산)
	square := func(in <-chan int) <-chan int {
		ch := make(chan int, 5)
		go func() {
			for val := range in {
				result := val * val
				fmt.Printf("[변환] %d^2 = %d\n", val, result)
				ch <- result
			}
			close(ch)
		}()
		return ch
	}

	// 파이프라인 구성
	fmt.Println("파이프라인 시작: 1-10 → 짝수만 → 제곱")
	results := square(filter(generator()))

	fmt.Println("\n최종 결과:")
	for result := range results {
		fmt.Printf("결과: %d\n", result)
	}

	// [7-2] 멀티 스테이지 파이프라인 벤치마크
	fmt.Println("\n[7-2] 파이프라인 성능 벤치마크")

	// 직렬 처리
	start := time.Now()
	for i := 1; i <= 1000; i++ {
		if i%2 == 0 {
			_ = i * i
		}
	}
	directTime := time.Since(start)
	fmt.Printf("직렬 처리: %v\n", directTime)

	// 파이프라인 처리
	start = time.Now()
	genCh := make(chan int, 100)
	go func() {
		for i := 1; i <= 1000; i++ {
			genCh <- i
		}
		close(genCh)
	}()

	filterCh := make(chan int, 100)
	go func() {
		for i := range genCh {
			if i%2 == 0 {
				filterCh <- i
			}
		}
		close(filterCh)
	}()

	count := 0
	for range filterCh {
		count++
	}
	pipelineTime := time.Since(start)
	fmt.Printf("파이프라인 처리: %v\n", pipelineTime)
	fmt.Printf("처리량: %d개\n", count)
}

