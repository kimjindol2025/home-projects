// ============================================================
// 섹션 1: Buffered vs Unbuffered 채널 비교
// ============================================================

func section1_bufferedVsUnbuffered() {
	fmt.Println("\n============================================================")
	fmt.Println("섹션 1: Buffered vs Unbuffered 채널 비교")
	fmt.Println("============================================================")

	// 1-1: Unbuffered 채널 (동기 방식)
	fmt.Println("\n[1-1] Unbuffered 채널 (동기 방식)")
	start := time.Now()
	unbufferedCh := make(chan int)

	go func() {
		for i := 1; i <= 5; i++ {
			fmt.Printf("송신: %d\n", i)
			unbufferedCh <- i // 수신자를 기다림
		}
		close(unbufferedCh)
	}()

	count := 0
	for val := range unbufferedCh {
		fmt.Printf("수신: %d\n", val)
		time.Sleep(100 * time.Millisecond) // 느린 수신자
		count++
	}
	fmt.Printf("시간: %.3fs, 처리: %d개\n", time.Since(start).Seconds(), count)

	// 1-2: Buffered 채널 (비동기 방식)
	fmt.Println("\n[1-2] Buffered 채널 (버퍼 크기 5, 비동기 방식)")
	start = time.Now()
	bufferedCh := make(chan int, 5)

	go func() {
		for i := 1; i <= 5; i++ {
			fmt.Printf("송신: %d (버퍼 담김)\n", i)
			bufferedCh <- i // 버퍼에 넣고 계속 진행
		}
		close(bufferedCh)
	}()

	count = 0
	for val := range bufferedCh {
		fmt.Printf("수신: %d\n", val)
		time.Sleep(100 * time.Millisecond) // 느린 수신자
		count++
	}
	fmt.Printf("시간: %.3fs, 처리: %d개\n", time.Since(start).Seconds(), count)

	// 1-3: 처리량 벤치마크
	fmt.Println("\n[1-3] 처리량(Throughput) 벤치마크")

	// Unbuffered 벤치마크
	fmt.Println("Unbuffered 채널: 1000개 전송")
	start = time.Now()
	ch := make(chan int)
	go func() {
		for i := 0; i < 1000; i++ {
			ch <- i
		}
		close(ch)
	}()
	for range ch {
	}
	unbufferedTime := time.Since(start)
	fmt.Printf("소요시간: %v\n", unbufferedTime)

	// Buffered 벤치마크
	fmt.Println("Buffered 채널: 1000개 전송 (버퍼 크기 100)")
	start = time.Now()
	ch = make(chan int, 100)
	go func() {
		for i := 0; i < 1000; i++ {
			ch <- i
		}
		close(ch)
	}()
	for range ch {
	}
	bufferedTime := time.Since(start)
	fmt.Printf("소요시간: %v\n", bufferedTime)
	fmt.Printf("개선 효과: %.2fx\n", float64(unbufferedTime.Nanoseconds())/float64(bufferedTime.Nanoseconds()))
}

// ============================================================
// 섹션 2: Fan-out 패턴 (1:N 데이터 분산)
// ============================================================

func section2_fanOut() {
	fmt.Println("\n============================================================")
	fmt.Println("섹션 2: Fan-out 패턴 (1:N 데이터 분산)")
	fmt.Println("============================================================")

	fmt.Println("\n[2-1] 기본 Fan-out: 생산자 → 여러 워커")

	// 생산자: 작업 생성
	jobs := make(chan int, 10)

	// 워커 3개 시작
	numWorkers := 3
	done := make(chan bool, numWorkers)

	for w := 0; w < numWorkers; w++ {
		go func(workerID int) {
			fmt.Printf("워커 %d: 시작\n", workerID)
			for job := range jobs {
				fmt.Printf("워커 %d: 작업 %d 처리 중\n", workerID, job)
				time.Sleep(100 * time.Millisecond)
				fmt.Printf("워커 %d: 작업 %d 완료\n", workerID, job)
			}
			fmt.Printf("워커 %d: 종료\n", workerID)
			done <- true
		}(w)
	}

	// 작업 배포 (fan-out)
	fmt.Println("생산자: 작업 5개 배포")
	for j := 1; j <= 5; j++ {
		jobs <- j
		fmt.Printf("생산자: 작업 %d 배포\n", j)
	}
	close(jobs) // 작업 배포 완료 신호

	// 모든 워커 대기
	for i := 0; i < numWorkers; i++ {
		<-done
	}
	fmt.Println("모든 작업 완료!")

	// [2-2] 동시 처리 비율 측정
	fmt.Println("\n[2-2] 동시 처리 능력 비교")

	testFanOut := func(numWorkers int, totalJobs int) time.Duration {
		jobs := make(chan int, 10)
		done := make(chan bool, numWorkers)
		start := time.Now()

		for w := 0; w < numWorkers; w++ {
			go func() {
				for range jobs {
					time.Sleep(10 * time.Millisecond)
				}
				done <- true
			}()
		}

		go func() {
			for j := 0; j < totalJobs; j++ {
				jobs <- j
			}
			close(jobs)
		}()

		for i := 0; i < numWorkers; i++ {
			<-done
		}
		return time.Since(start)
	}

	time1 := testFanOut(1, 20)
	fmt.Printf("워커 1개: %v\n", time1)

	time3 := testFanOut(3, 20)
	fmt.Printf("워커 3개: %v\n", time3)

	time6 := testFanOut(6, 20)
	fmt.Printf("워커 6개: %v\n", time6)

	fmt.Printf("성능 개선 (1→6): %.2fx\n", float64(time1.Nanoseconds())/float64(time6.Nanoseconds()))
}

// ============================================================
// 섹션 3: Fan-in 패턴 (N:1 결과 수집)
// ============================================================

func section3_fanIn() {
	fmt.Println("\n============================================================")
	fmt.Println("섹션 3: Fan-in 패턴 (N:1 결과 수집)")
	fmt.Println("============================================================")

	fmt.Println("\n[3-1] 기본 Fan-in: 여러 워커 → 결과 수집")

	// 결과 채널
	results := make(chan string, 10)

	// 워커 4개 시작
	for w := 1; w <= 4; w++ {
		go func(workerID int) {
			for i := 1; i <= 3; i++ {
				result := fmt.Sprintf("워커%d-결과%d", workerID, i)
				results <- result
				fmt.Printf("워커 %d: %s 전송\n", workerID, result)
				time.Sleep(50 * time.Millisecond)
			}
		}(w)
	}

	// 결과 수집 (fan-in)
	fmt.Println("소비자: 결과 수집 중...")
	totalResults := 4 * 3 // 4개 워커 × 3개 결과
	for i := 0; i < totalResults; i++ {
		result := <-results
		fmt.Printf("소비자 수신: %s\n", result)
	}
	fmt.Println("모든 결과 수집 완료!")

	// [3-2] Select를 이용한 다중 채널 Fan-in
	fmt.Println("\n[3-2] Select를 이용한 다중 채널 Fan-in")

	result1 := make(chan string, 5)
	result2 := make(chan string, 5)
	result3 := make(chan string, 5)

	go func() {
		for i := 0; i < 3; i++ {
			result1 <- fmt.Sprintf("source1-%d", i)
			time.Sleep(30 * time.Millisecond)
		}
		close(result1)
	}()

	go func() {
		for i := 0; i < 3; i++ {
			result2 <- fmt.Sprintf("source2-%d", i)
			time.Sleep(25 * time.Millisecond)
		}
		close(result2)
	}()

	go func() {
		for i := 0; i < 3; i++ {
			result3 <- fmt.Sprintf("source3-%d", i)
			time.Sleep(35 * time.Millisecond)
		}
		close(result3)
	}()

	// 3개 소스의 결과를 하나의 채널에서 수집
	count := 0
	totalExpected := 9

	for count < totalExpected {
		select {
		case r, ok := <-result1:
			if ok {
				fmt.Printf("[source1] %s\n", r)
				count++
			}
		case r, ok := <-result2:
			if ok {
				fmt.Printf("[source2] %s\n", r)
				count++
			}
		case r, ok := <-result3:
			if ok {
				fmt.Printf("[source3] %s\n", r)
				count++
			}
		}
	}
	fmt.Printf("모든 소스 수집 완료 (%d개)\n", count)
}

// ============================================================
// 섹션 4: Worker Pool 완전 구현
// ============================================================

type WorkerPool struct {
	jobs    chan int
	results chan string
	workers int
}

func section4_workerPool() {
	fmt.Println("\n============================================================")
	fmt.Println("섹션 4: Worker Pool 완전 구현")
	fmt.Println("============================================================")

	fmt.Println("\n[4-1] 워커 풀 생성 및 작업 배포")

	pool := &WorkerPool{
		jobs:    make(chan int, 20),
		results: make(chan string, 20),
		workers: 4,
	}

	// 워커 풀 시작
	var wg sync.WaitGroup
	wg.Add(pool.workers)

	for w := 0; w < pool.workers; w++ {
		go func(workerID int) {
			defer wg.Done()
			for job := range pool.jobs {
				fmt.Printf("워커 %d: 작업 %d 처리\n", workerID, job)
				time.Sleep(50 * time.Millisecond)
				result := fmt.Sprintf("결과[%d] = %d^2 = %d", job, job, job*job)
				pool.results <- result
			}
			fmt.Printf("워커 %d: 종료\n", workerID)
		}(w)
	}

	// 작업 배포 (goroutine에서 동시 실행)
	go func() {
		fmt.Println("작업 배포 시작: 10개")
		for j := 1; j <= 10; j++ {
			pool.jobs <- j
		}
		close(pool.jobs)
	}()

	// 결과 수집 (별도 goroutine)
	resultsDone := make(chan bool)
	go func() {
		for i := 0; i < 10; i++ {
			result := <-pool.results
			fmt.Printf("결과: %s\n", result)
		}
		resultsDone <- true
	}()

	// 대기
	wg.Wait()
	<-resultsDone
	fmt.Println("워커 풀 작업 완료!")

	// [4-2] 워커 풀 벤치마크
	fmt.Println("\n[4-2] 워커 풀 크기에 따른 성능")

	benchmarkWorkerPool := func(numWorkers int, numJobs int) time.Duration {
		jobs := make(chan int, numWorkers)
		done := make(chan bool, numWorkers)
		start := time.Now()

		// 워커 시작
		for w := 0; w < numWorkers; w++ {
			go func() {
				for range jobs {
					time.Sleep(10 * time.Millisecond)
				}
				done <- true
			}()
		}

		// 작업 배포
		go func() {
			for j := 0; j < numJobs; j++ {
				jobs <- j
			}
			close(jobs)
		}()

		// 워커 대기
		for i := 0; i < numWorkers; i++ {
			<-done
		}

		return time.Since(start)
	}

	elapsed1 := benchmarkWorkerPool(1, 50)
	fmt.Printf("워커 1개: %v\n", elapsed1)

	elapsed4 := benchmarkWorkerPool(4, 50)
	fmt.Printf("워커 4개: %v\n", elapsed4)

	elapsed8 := benchmarkWorkerPool(8, 50)
	fmt.Printf("워커 8개: %v\n", elapsed8)

	fmt.Printf("성능 개선 (1→8): %.2fx\n", float64(elapsed1.Nanoseconds())/float64(elapsed8.Nanoseconds()))
}

// ============================================================
// 섹션 5: 채널 Close 패턴 및 상태 관리
// ============================================================

func section5_channelClose() {
	fmt.Println("\n============================================================")
	fmt.Println("섹션 5: 채널 Close 패턴 및 상태 관리")
	fmt.Println("============================================================")

	// [5-1] 채널 종료 신호
	fmt.Println("\n[5-1] 채널 종료 신호 처리")

	jobs := make(chan int, 5)
	done := make(chan bool)

	go func() {
		count := 0
		for job := range jobs {
			fmt.Printf("작업 %d 처리\n", job)
			count++
		}
		fmt.Printf("채널 종료 감지! 총 %d개 작업 처리\n", count)
		done <- true
	}()

	// 작업 전송
	for i := 1; i <= 5; i++ {
		jobs <- i
	}
	close(jobs) // 송신 완료 신호
	fmt.Println("채널 종료 신호 전송")

	<-done
	fmt.Println("워커 종료 완료")

	// [5-2] ok 값을 이용한 채널 상태 확인
	fmt.Println("\n[5-2] ok 값을 이용한 채널 상태 확인")

	ch := make(chan string, 3)
	ch <- "첫번째"
	ch <- "두번째"
	close(ch)

	// 채널에서 값 읽기
	val, ok := <-ch
	fmt.Printf("값: %s, ok: %v\n", val, ok)

	val, ok = <-ch
	fmt.Printf("값: %s, ok: %v\n", val, ok)

	val, ok = <-ch
	fmt.Printf("값: %s, ok: %v (채널 닫혀있음)\n", val, ok)

	val, ok = <-ch
	fmt.Printf("값: %s, ok: %v (빈 채널에서 읽음)\n", val, ok)

	// [5-3] WaitGroup을 이용한 안전한 종료
	fmt.Println("\n[5-3] WaitGroup을 이용한 안전한 종료")

	var wg sync.WaitGroup
	jobs = make(chan int, 10)
	numWorkers := 3

	// 워커 시작
	for w := 0; w < numWorkers; w++ {
		wg.Add(1)
		go func(id int) {
			defer wg.Done()
			for job := range jobs {
				fmt.Printf("워커 %d: 작업 %d\n", id, job)
				time.Sleep(20 * time.Millisecond)
			}
		}(w)
	}

	// 작업 배포
	for j := 1; j <= 9; j++ {
		jobs <- j
	}
	close(jobs)

	wg.Wait()
	fmt.Println("모든 워커 종료!")
}

