// ==========================================
// 섹션 1: If-Else 조건문
// ==========================================
func section1() {
	fmt.Println()
	fmt.Println("📌 [1] IF-ELSE 조건문 - 소괄호() 없음!")
	fmt.Println("-" * 50)

	// 1-1: 기본 if (괄호 없음)
	fmt.Println()
	fmt.Println("1-1. 기본 if 문 (소괄호 제거)")
	score := 85
	if score >= 90 {
		fmt.Println("A학점")
	} else if score >= 80 {
		fmt.Println("B학점")
	} else {
		fmt.Println("C학점 이하")
	}
	// 출력: B학점

	// 1-2: If 초기화 구문 (대학원 수준의 에러 처리)
	fmt.Println()
	fmt.Println("1-2. If 초기화 구문 - 짧은 선언")
	// 패턴: if 변수 := 계산(); 조건 {
	if status := getStudentStatus(score); status == "PASS" {
		fmt.Println("학생 상태:", status)
		fmt.Println("학점이 충분합니다")
	} else {
		fmt.Println("학생 상태:", status)
		fmt.Println("학점이 부족합니다")
	}
	// 주의: status는 if-else 블록 밖에서 사용 불가 (스코프 제한)

	// 1-3: Scope 연구 (대학 과제)
	fmt.Println()
	fmt.Println("1-3. Scope 연구 - 변수의 생명주기")
	if val := 100; val > 90 {
		fmt.Printf("If 블록: val = %d (유효)\n", val)
	} else {
		fmt.Printf("Else 블록: val = %d (유효)\n", val)
	}
	// fmt.Println(val)  // 컴파일 에러: val is undefined
	fmt.Println("블록 밖: val은 존재하지 않음 (스코프 제한)")

	// 1-4: 명시적 에러 처리 (Go의 철학)
	fmt.Println()
	fmt.Println("1-4. 명시적 에러 처리 - If err != nil")
	result, err := divideNumbers(10, 2)
	if err != nil {
		fmt.Println("에러:", err)
	} else {
		fmt.Printf("나눗셈 결과: %v\n", result)
	}

	// 0으로 나누기 시도
	result, err = divideNumbers(10, 0)
	if err != nil {
		fmt.Println("에러:", err)
	}
}

// 학생 상태 판정
func getStudentStatus(score int) string {
	if score >= 60 {
		return "PASS"
	}
	return "FAIL"
}

// 나눗셈 (에러 처리)
func divideNumbers(a, b int) (int, error) {
	if b == 0 {
		return 0, fmt.Errorf("division by zero not allowed")
	}
	return a / b, nil
}

// ==========================================
// 섹션 2: For 루프 - 3가지 형태
// ==========================================
func section2() {
	fmt.Println()
	fmt.Println("📌 [2] FOR 루프 - Go의 유일한 반복 구조!")
	fmt.Println("-" * 50)

	// 2-1: C 스타일 For (초기화; 조건; 증감)
	fmt.Println()
	fmt.Println("2-1. C 스타일 For - 초기화; 조건; 증감")
	for i := 0; i < 5; i++ {
		fmt.Printf("%d ", i)
	}
	fmt.Println("← 0부터 4까지 증가")

	// 2-2: While 형태 (조건만)
	fmt.Println()
	fmt.Println("2-2. While 형태 - 조건만 있음 (Python/Java의 while)")
	j := 0
	for j < 3 {
		fmt.Printf("%d ", j)
		j++
	}
	fmt.Println("← While 루프처럼 동작")

	// 2-3: 무한 루프
	fmt.Println()
	fmt.Println("2-3. 무한 루프 - for { ... }")
	count := 0
	for {
		count++
		if count > 2 {
			break // 명시적 탈출
		}
		fmt.Printf("%d ", count)
	}
	fmt.Println("← 명시적 break로 탈출")

	// 2-4: Range 기반 For (컬렉션 순회)
	fmt.Println()
	fmt.Println("2-4. Range For - 배열/슬라이스/맵 순회")
	numbers := []int{10, 20, 30}
	for i, val := range numbers {
		fmt.Printf("[%d]=%d ", i, val)
	}
	fmt.Println("← 인덱스와 값 동시")

	// 2-5: Range에서 값만 필요
	fmt.Println()
	fmt.Println("2-5. Range For - 값만 필요 (블랭크 식별자 _)")
	for _, val := range numbers {
		fmt.Printf("%d ", val)
	}
	fmt.Println("← 인덱스는 무시")

	// 2-6: Range에서 인덱스만 필요
	fmt.Println()
	fmt.Println("2-6. Range For - 인덱스만 필요")
	for i := range numbers {
		fmt.Printf("%d ", i)
	}
	fmt.Println("← 값은 무시")

	// 2-7: 맵 순회
	fmt.Println()
	fmt.Println("2-7. Range For - 맵(Map) 순회")
	grades := map[string]int{
		"Alice": 95,
		"Bob":   87,
		"Carol": 92,
	}
	for name, grade := range grades {
		fmt.Printf("%s:%d ", name, grade)
	}
	fmt.Println("← 맵의 순서는 무작위 (해시테이블)")

	// 2-8: 문자열 순회 (Rune 단위)
	fmt.Println()
	fmt.Println("2-8. Range For - 문자열 순회 (Rune 단위)")
	str := "Go"
	for i, ch := range str {
		fmt.Printf("[%d]='%c' ", i, ch)
	}
	fmt.Println("← 각 글자를 독립적으로 처리")

	// 2-9: Break와 Continue
	fmt.Println()
	fmt.Println("2-9. Break와 Continue - 루프 제어")
	for i := 0; i < 5; i++ {
		if i == 1 {
			fmt.Print("(skip) ")
			continue // 1은 스킵
		}
		if i == 4 {
			fmt.Print("(break)")
			break // 4에서 탈출
		}
		fmt.Printf("%d ", i)
	}
	fmt.Println()
}

// ==========================================
// 섹션 3: Switch-Case 문
// ==========================================
func section3() {
	fmt.Println()
	fmt.Println("📌 [3] SWITCH-CASE 문 - 자동 Break!")
	fmt.Println("-" * 50)

	// 3-1: 기본 switch
	fmt.Println()
	fmt.Println("3-1. 기본 Switch")
	day := 3
	switch day {
	case 1:
		fmt.Println("Monday")
	case 2:
		fmt.Println("Tuesday")
	case 3:
		fmt.Println("Wednesday")
	default:
		fmt.Println("Other day")
	}

	// 3-2: 여러 case 한번에
	fmt.Println()
	fmt.Println("3-2. 여러 Case 한번에")
	switch day {
	case 1, 7:
		fmt.Println("Weekend prep or Actual weekend")
	case 2, 3, 4, 5, 6:
		fmt.Println("Weekday")
	}

	// 3-3: Fallthrough (드물게 사용)
	fmt.Println()
	fmt.Println("3-3. Fallthrough - 명시적으로만 다음 case 실행")
	switch day {
	case 1:
		fmt.Println("Monday - Start of week")
		fallthrough
	case 2:
		fmt.Println("Early week")
	default:
		fmt.Println("Other")
	}

	// 3-4: 조건식 Switch (변수 없음) - Go의 독특한 기능!
	fmt.Println()
	fmt.Println("3-4. 조건식 Switch - 변수 없이 조건만")
	score := 85
	switch {
	case score >= 90:
		fmt.Println("A학점")
	case score >= 80:
		fmt.Println("B학점")
	case score >= 70:
		fmt.Println("C학점")
	default:
		fmt.Println("F학점")
	}

	// 3-5: Switch 초기화 (If처럼)
	fmt.Println()
	fmt.Println("3-5. Switch 초기화 구문")
	switch status := getGrade(score); status {
	case "HIGH":
		fmt.Println("High achievement!")
	case "MID":
		fmt.Println("Good work")
	default:
		fmt.Println("Keep trying")
	}
}

func getGrade(score int) string {
	if score >= 85 {
		return "HIGH"
	}
	return "MID"
}

// ==========================================
// 섹션 4: Defer 문 - 자원 정리
// ==========================================
func section4() {
	fmt.Println()
	fmt.Println("📌 [4] DEFER 문 - 자동 정리 (LIFO)")
	fmt.Println("-" * 50)

	// 4-1: 기본 Defer
	fmt.Println()
	fmt.Println("4-1. 기본 Defer - 함수 종료 직전 실행")
	fmt.Println("시작")
	defer fmt.Println("← Defer 실행 (함수 끝에서)")
	fmt.Println("중간")
	// 출력 순서: 시작 → 중간 → Defer 실행

	// 4-2: 여러 Defer (LIFO - Stack)
	fmt.Println()
	fmt.Println("4-2. 여러 Defer - 역순 실행 (LIFO)")
	defer fmt.Println("첫 번째 Defer (마지막 실행)")
	defer fmt.Println("두 번째 Defer (중간 실행)")
	defer fmt.Println("세 번째 Defer (처음 실행)")
	// 출력 순서: 3 → 2 → 1

	// 4-3: 파일/자원 정리 패턴
	fmt.Println()
	fmt.Println("4-3. 파일 정리 패턴 (Try-Finally 같은 효과)")
	readFileExample()

	// 4-4: Lock 해제 패턴
	fmt.Println()
	fmt.Println("4-4. Lock 해제 패턴 (Mutex)")
	lockExample()
}

// 파일 정리 패턴
func readFileExample() {
	fmt.Println("파일 열기 시뮬레이션")
	file := "config.json"
	fmt.Printf("  → 파일 '%s' 오픈\n", file)
	defer fmt.Printf("  → 파일 '%s' 자동 닫기 (defer 실행)\n", file)
	fmt.Println("  → 파일 읽기 작업 중...")
	// 함수 종료 시 자동으로 파일 닫기 실행
}

// Lock 해제 패턴
func lockExample() {
	fmt.Println("Lock 획득")
	fmt.Println("  → Mutex 잠금")
	defer fmt.Println("  → Mutex 자동 해제 (defer 실행)")
	fmt.Println("  → 임계 영역 실행 중...")
	// 함수 종료 시 자동으로 Unlock 실행
}

// ==========================================
// 섹션 5: 실무 패턴 - FizzBuzz
// ==========================================
func section5() {
	fmt.Println()
	fmt.Println("📌 [5] 실무 패턴 - FizzBuzz (For + Switch)")
	fmt.Println("-" * 50)

	// FizzBuzz 요구사항:
	// 1~100까지 출력하되
	// - 3의 배수: "Fizz"
	// - 5의 배수: "Buzz"
	// - 15의 배수: "FizzBuzz"
	// - 그 외: 숫자

	fmt.Println()
	fmt.Println("FizzBuzz 1~30 (For + Switch 조합)")
	fizzBuzz(30)

	fmt.Println()
	fmt.Println()
	fmt.Println("FizzBuzz - 대학원 수준 분석")
	fmt.Println("코드 구조:")
	fmt.Println("  for i := 1; i <= n; i++ {")
	fmt.Println("      switch {")
	fmt.Println("      case i%15 == 0: FizzBuzz")
	fmt.Println("      case i%3 == 0:  Fizz")
	fmt.Println("      case i%5 == 0:  Buzz")
	fmt.Println("      default:        숫자")
	fmt.Println("      }")
	fmt.Println("  }")
	fmt.Println()
	fmt.Println("왜 15를 먼저 검사할까?")
	fmt.Println("  → 조건의 순서가 중요! (조건식 switch에서)")
}

func fizzBuzz(n int) {
	for i := 1; i <= n; i++ {
		switch {
		case i%15 == 0: // 15의 배수 (3과 5의 공배수)
			fmt.Print("FizzBuzz ")
		case i%3 == 0: // 3의 배수
			fmt.Print("Fizz ")
		case i%5 == 0: // 5의 배수
			fmt.Print("Buzz ")
		default: // 그 외
			fmt.Printf("%d ", i)
		}
	}
	fmt.Println()
}
