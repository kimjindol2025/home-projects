## 3️⃣ 구조체와 데이터 매핑

### 📋 Row → Struct 변환

```go
// 데이터베이스 테이블
// CREATE TABLE users (
//     id INTEGER PRIMARY KEY,
//     name TEXT,
//     email TEXT,
//     age INTEGER
// );

// Go 구조체
type User struct {
    ID    int
    Name  string
    Email string
    Age   int
}

// 데이터 조회 및 매핑
func GetUserStruct(db *sql.DB, userID int) (*User, error) {
    user := &User{}
    err := db.QueryRow(
        "SELECT id, name, email, age FROM users WHERE id = ?",
        userID,
    ).Scan(&user.ID, &user.Name, &user.Email, &user.Age)

    if err == sql.ErrNoRows {
        return nil, fmt.Errorf("user not found")
    }
    if err != nil {
        return nil, err
    }

    return user, nil
}

// 여러 사용자 조회
func GetAllUsersStruct(db *sql.DB) ([]User, error) {
    rows, err := db.Query("SELECT id, name, email, age FROM users")
    if err != nil {
        return nil, err
    }
    defer rows.Close()

    var users []User
    for rows.Next() {
        var user User
        if err := rows.Scan(&user.ID, &user.Name, &user.Email, &user.Age); err != nil {
            return nil, err
        }
        users = append(users, user)
    }

    return users, rows.Err()
}
```

### 🔍 NULL 값 처리

```go
// 문제: NULL 값을 int나 string에 직접 Scan할 수 없음
type User struct {
    ID    int
    Name  string
    Email string  // NULL일 수 있음
    Age   int     // NULL일 수 있음
}

// 해결: sql.NullString, sql.NullInt64 사용
type User struct {
    ID    int
    Name  string
    Email sql.NullString  // NULL 가능
    Age   sql.NullInt64   // NULL 가능
}

// Scan 후 NULL 확인
user := User{}
db.QueryRow("SELECT id, name, email, age FROM users WHERE id = ?", 1).
    Scan(&user.ID, &user.Name, &user.Email, &user.Age)

if user.Email.Valid {
    fmt.Println("Email:", user.Email.String)
} else {
    fmt.Println("Email is NULL")
}
```

