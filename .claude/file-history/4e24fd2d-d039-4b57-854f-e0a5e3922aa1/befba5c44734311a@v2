## 2️⃣ CRUD 연산: 기본 데이터 조작

### 📋 CREATE (삽입)

```go
// 1. INSERT 쿼리 작성
result, err := db.Exec(
    "INSERT INTO users (name, email, age) VALUES (?, ?, ?)",
    "Alice",
    "alice@example.com",
    25,
)
if err != nil {
    log.Fatal(err)
}

// 2. 삽입된 행의 ID 확인
id, err := result.LastInsertId()
rowsAffected, err := result.RowsAffected()

fmt.Printf("Inserted ID: %d, Rows affected: %d\n", id, rowsAffected)
```

### 📋 READ (조회)

```go
// 단일 사용자 조회
func GetUser(db *sql.DB, userID int) (string, error) {
    var name string
    err := db.QueryRow("SELECT name FROM users WHERE id = ?", userID).Scan(&name)
    if err == sql.ErrNoRows {
        return "", fmt.Errorf("user not found")
    }
    if err != nil {
        return "", err
    }
    return name, nil
}

// 모든 사용자 조회
func GetAllUsers(db *sql.DB) ([]map[string]interface{}, error) {
    rows, err := db.Query("SELECT id, name, email FROM users")
    if err != nil {
        return nil, err
    }
    defer rows.Close()

    var users []map[string]interface{}
    for rows.Next() {
        var id int
        var name, email string
        if err := rows.Scan(&id, &name, &email); err != nil {
            return nil, err
        }

        user := map[string]interface{}{
            "id":    id,
            "name":  name,
            "email": email,
        }
        users = append(users, user)
    }

    return users, rows.Err()
}
```

### 📋 UPDATE (수정)

```go
result, err := db.Exec(
    "UPDATE users SET name = ?, email = ? WHERE id = ?",
    "Alice Smith",
    "alice.smith@example.com",
