## 8️⃣ 실전: 사용자 관리 시스템

### 📋 전체 구조

```go
package main

import (
    "database/sql"
    "log"

    _ "github.com/lib/pq"
)

type User struct {
    ID    int
    Name  string
    Email string
    Age   int
}

type UserDB struct {
    db *sql.DB
}

func (u *UserDB) CreateUser(name, email string, age int) (int, error) {
    var id int
    err := u.db.QueryRow(
        "INSERT INTO users (name, email, age) VALUES ($1, $2, $3) RETURNING id",
        name, email, age,
    ).Scan(&id)
    return id, err
}

func (u *UserDB) GetUser(id int) (*User, error) {
    user := &User{}
    err := u.db.QueryRow(
        "SELECT id, name, email, age FROM users WHERE id = $1",
        id,
    ).Scan(&user.ID, &user.Name, &user.Email, &user.Age)
    return user, err
}

func (u *UserDB) UpdateUser(id int, name, email string, age int) error {
    _, err := u.db.Exec(
        "UPDATE users SET name = $1, email = $2, age = $3 WHERE id = $4",
        name, email, age, id,
    )
    return err
}

func (u *UserDB) DeleteUser(id int) error {
    _, err := u.db.Exec("DELETE FROM users WHERE id = $1", id)
    return err
}

func (u *UserDB) ListUsers() ([]User, error) {
    rows, err := u.db.Query("SELECT id, name, email, age FROM users ORDER BY id")
    if err != nil {
        return nil, err
    }
    defer rows.Close()

    var users []User
    for rows.Next() {
        var user User
        if err := rows.Scan(&user.ID, &user.Name, &user.Email, &user.Age); err != nil {
            return nil, err
        }
        users = append(users, user)
    }
    return users, rows.Err()
}

func main() {
    db, err := sql.Open("postgres", "user=admin password=secret dbname=myapp")
    if err != nil {
        log.Fatal(err)
    }
    defer db.Close()

    if err := db.Ping(); err != nil {
        log.Fatal(err)
    }

    userDB := &UserDB{db: db}

    // CREATE
    id, _ := userDB.CreateUser("Alice", "alice@example.com", 25)
    log.Printf("Created user with ID: %d\n", id)

    // READ
    user, _ := userDB.GetUser(id)
    log.Printf("User: %v\n", user)

    // UPDATE
    userDB.UpdateUser(id, "Alice Smith", "alice.smith@example.com", 26)

    // LIST
    users, _ := userDB.ListUsers()
    for _, u := range users {
        log.Printf("User: %+v\n", u)
    }

    // DELETE
    userDB.DeleteUser(id)
}
```

