// Package calculator provides arithmetic operations
// This package is internal and not publicly accessible
// from outside the module (enforced by Go 1.4+ internal/ rule)

package calculator

import "errors"

// Add adds two floating point numbers
func Add(a, b float64) float64 {
	return a + b
}

// Subtract subtracts two floating point numbers
func Subtract(a, b float64) float64 {
	return a - b
}

// Multiply multiplies two floating point numbers
func Multiply(a, b float64) float64 {
	return a * b
}

// Divide divides two floating point numbers
// Returns error if divisor is zero
func Divide(a, b float64) (float64, error) {
	if b == 0 {
		return 0, errors.New("division by zero")
	}
	return a / b, nil
}
