// Package logger provides simple logging utilities
// This package is public and can be imported from outside the module

package logger

import "fmt"

// Log outputs an info-level log message
func Log(msg string) {
	fmt.Printf("[LOG] %s\n", msg)
}

// Error outputs an error-level log message
func Error(msg string) {
	fmt.Printf("[ERROR] %s\n", msg)
}

// Success outputs a success-level log message
func Success(msg string) {
	fmt.Printf("[SUCCESS] %s\n", msg)
}

// Info outputs a formatted info message
func Info(format string, args ...interface{}) {
	fmt.Printf("[INFO] "+format+"\n", args...)
}
