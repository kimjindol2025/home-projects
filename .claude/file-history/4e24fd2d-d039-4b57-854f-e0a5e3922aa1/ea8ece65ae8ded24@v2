package main

import "fmt"

// Hello, Gopher! - v1.1 Go 학습의 첫 번째 프로그램
//
// 이 프로그램은 Go의 기본 구조를 보여줍니다:
// 1. package main   : 실행 가능한 프로그램
// 2. import "fmt"   : 표준 라이브러리 사용
// 3. func main()    : 프로그램의 시작점
//
// Go의 철학:
// - 단순함 (Simplicity): 최소한의 키워드와 문법
// - 명확함: 코드를 읽기 쉽게 작성
// - 효율성: 빠른 컴파일과 실행

func main() {
	fmt.Println("===================================")
	fmt.Println("대학 과정 Go 학습을 시작합니다.")
	fmt.Println("===================================")
	fmt.Println()

	// Go의 특징 설명
	fmt.Println("✨ Go의 3가지 핵심 철학:")
	fmt.Println("1️⃣  Simplicity (단순성)")
	fmt.Println("    → 키워드 25개, 배우기 쉬움")
	fmt.Println()
	fmt.Println("2️⃣  Concurrency (병행성)")
	fmt.Println("    → Goroutine으로 수백만 개 작업 동시 처리")
	fmt.Println()
	fmt.Println("3️⃣  Efficiency (효율성)")
	fmt.Println("    → 컴파일 언어로 빠른 실행 속도")
	fmt.Println()
	fmt.Println("===================================")
	fmt.Println("기록이 증명이다. (Your record is your proof.)")
	fmt.Println("===================================")
}
