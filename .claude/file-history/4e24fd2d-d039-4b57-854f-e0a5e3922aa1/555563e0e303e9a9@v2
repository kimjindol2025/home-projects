## 6️⃣ 에러 처리 패턴

### 📋 패턴 1: 조기 반환 (Early Return)

```go
func validateAndProcess(input string) error {
    if input == "" {
        return errors.New("input is empty")
    }

    if len(input) < 3 {
        return errors.New("input too short")
    }

    if !isValidFormat(input) {
        return fmt.Errorf("invalid format: %s", input)
    }

    // 모든 검증 통과 후 실제 처리
    process(input)
    return nil
}

// Go의 가장 일반적인 패턴: 작은 에러부터 순서대로 확인하고 반환
```

### 🔍 패턴 2: 에러 래핑과 체이닝

```go
func deepOperation() error {
    if err := layer1(); err != nil {
        return fmt.Errorf("layer1 failed: %w", err)
    }
    if err := layer2(); err != nil {
        return fmt.Errorf("layer2 failed: %w", err)
    }
    return nil
}
```

### 🎯 패턴 3: 맞춤형 에러 정보

```go
type Operation struct {
    Name  string
    Error error
}

func (o Operation) String() string {
    if o.Error == nil {
        return fmt.Sprintf("%s: OK", o.Name)
    }
    return fmt.Sprintf("%s: FAILED - %v", o.Name, o.Error)
}

// 사용
ops := []Operation{
    {Name: "Fetch", Error: fetchData()},
    {Name: "Parse", Error: parseJSON()},
    {Name: "Store", Error: storeDB()},
}

for _, op := range ops {
    fmt.Println(op)  // 각 작업의 상태 출력
}
```

### ⚡ 패턴 4: 에러와 로깅

```go
import "log"

func readConfig(path string) (Config, error) {
    data, err := os.ReadFile(path)
    if err != nil {
        // 로그에 기록하되, 에러는 호출자가 처리하도록 반환
        log.Printf("failed to read config at %s: %v", path, err)
        return Config{}, fmt.Errorf("reading config: %w", err)
    }

    var config Config
    if err := json.Unmarshal(data, &config); err != nil {
        log.Printf("failed to parse config: %v", err)
        return Config{}, fmt.Errorf("parsing config: %w", err)
    }

    return config, nil
}
```

