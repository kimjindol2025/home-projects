// 섹션 8: Assignment 2-4 - 종합 벤치마킹
// ============================================================

func section8_assignment2_4() {
	fmt.Println("\n============================================================")
	fmt.Println("섹션 8: Assignment 2-4 - 종합 벤치마킹")
	fmt.Println("============================================================")

	// Assignment 1: 타임아웃 서버
	fmt.Println("\n[8-1] Assignment 2-4-1: 타임아웃 서버")
	fmt.Println("요구사항: 3초 타임아웃, 무거운 작업 강제 중단")

	testTimeoutServer := func(taskDuration time.Duration, timeout time.Duration) {
		ctx, cancel := context.WithTimeout(context.Background(), timeout)
		defer cancel()

		done := make(chan error, 1)

		go func() {
			fmt.Printf("  작업 시작 (%v 소요)...\n", taskDuration)
			time.Sleep(taskDuration)
			done <- nil
		}()

		select {
		case <-done:
			fmt.Println("  ✓ 작업 완료")
		case <-ctx.Done():
			fmt.Printf("  ✗ Timeout (%v 초과)\n", timeout)
		}
	}

	fmt.Println("시나리오 1: 1초 작업, 3초 타임아웃 → 완료")
	testTimeoutServer(1*time.Second, 3*time.Second)

	fmt.Println("시나리오 2: 5초 작업, 3초 타임아웃 → 타임아웃")
	testTimeoutServer(5*time.Second, 3*time.Second)

	// Assignment 2: WaitGroup 벤치마크
	fmt.Println("\n[8-2] Assignment 2-4-2: WaitGroup 안전성 검증")
	fmt.Println("요구사항: 고루틴 1,000개, 각 1,000회 작업")

	var wg sync.WaitGroup
	count := 0
	var mu sync.Mutex

	fmt.Println("올바른 패턴: Add() 고루틴 생성 전에")

	start := time.Now()

	for i := 0; i < 1000; i++ {
		wg.Add(1)  // 올바른 위치
		go func() {
			defer wg.Done()
			for j := 0; j < 1000; j++ {
				mu.Lock()
				count++
				mu.Unlock()
			}
		}()
	}

	wg.Wait()
	elapsed := time.Since(start)

	fmt.Printf("결과:\n")
	fmt.Printf("예상값: 1,000,000\n")
	fmt.Printf("실제값: %d\n", count)
	fmt.Printf("정확성: %.1f%%\n", float64(count)/10000*100)
	fmt.Printf("시간: %v\n", elapsed)

	if count == 1000000 {
		fmt.Println("✓ WaitGroup 패턴 검증 통과")
	}

	// Assignment 3: Context + WaitGroup 통합
	fmt.Println("\n[8-3] Assignment 2-4-3: Context + WaitGroup 통합")
	fmt.Println("요구사항: 타임아웃 내 병렬 작업 수행")

	ctx, cancel := context.WithTimeout(context.Background(), 2*time.Second)
	defer cancel()

	var wg2 sync.WaitGroup
	successCount := 0
	timeoutCount := 0
	var mu2 sync.Mutex

	numTasks := 10

	for i := 0; i < numTasks; i++ {
		wg2.Add(1)
		go func(id int) {
			defer wg2.Done()

			// 각 작업 시간: 100-500ms
			taskDuration := time.Duration((id%5+1)*100) * time.Millisecond

			select {
			case <-time.After(taskDuration):
				fmt.Printf("  작업 %d: 완료 (%v)\n", id, taskDuration)
				mu2.Lock()
				successCount++
				mu2.Unlock()
			case <-ctx.Done():
				fmt.Printf("  작업 %d: 취소됨\n", id)
				mu2.Lock()
				timeoutCount++
				mu2.Unlock()
			}
		}(i)
	}

	wg2.Wait()

	fmt.Printf("\n결과:\n")
	fmt.Printf("성공: %d개\n", successCount)
	fmt.Printf("취소: %d개\n", timeoutCount)
	fmt.Printf("타임아웃: 2초 / 모든 고루틴 안전 종료\n")
	fmt.Println("✓ Context + WaitGroup 통합 검증 완료")
}

