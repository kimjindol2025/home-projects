func section8_assignment2_3() {
	fmt.Println("\n============================================================")
	fmt.Println("섹션 8: Assignment 2-3 - 종합 벤치마킹")
	fmt.Println("============================================================")

	// Assignment 1: Race Condition 분석
	fmt.Println("\n[8-1] Assignment 2-3-1: Race Condition 재현 및 분석")
	fmt.Println("요구사항: 고루틴 1,000개 × 1,000회 증가 (뮤텍스 없음)")

	unsafeCount := 0
	var wg sync.WaitGroup

	start := time.Now()

	for i := 0; i < 1000; i++ {
		wg.Add(1)
		go func() {
			defer wg.Done()
			for j := 0; j < 1000; j++ {
				unsafeCount++
			}
		}()
	}

	wg.Wait()
	elapsed := time.Since(start)

	expectedValue := 1000 * 1000
	lossPercentage := float64(expectedValue-unsafeCount) / float64(expectedValue) * 100

	fmt.Printf("결과:\n")
	fmt.Printf("예상값: %d\n", expectedValue)
	fmt.Printf("실제값: %d\n", unsafeCount)
	fmt.Printf("손실: %d (%.2f%%)\n", expectedValue-unsafeCount, lossPercentage)
	fmt.Printf("소요시간: %v\n", elapsed)

	// Assignment 2: SafeMap 벤치마크
	fmt.Println("\n[8-2] Assignment 2-3-2: SafeMap 성능 벤치마크")
	fmt.Println("요구사항: SafeMap으로 동시성 안전성 검증")

	safeMap := NewSafeMap()
	readCount := 0
	writeCount := 0

	start = time.Now()

	// 읽기 워커 80개
	for r := 0; r < 80; r++ {
		wg.Add(1)
		go func() {
			defer wg.Done()
			for i := 0; i < 1000; i++ {
				keys := safeMap.Keys()
				if len(keys) > 0 {
					key := keys[i%len(keys)]
					_, _ = safeMap.Get(key)
				}
				readCount++
			}
		}()
	}

	// 쓰기 워커 20개
	for w := 0; w < 20; w++ {
		wg.Add(1)
		go func(id int) {
			defer wg.Done()
			for i := 0; i < 1000; i++ {
				key := fmt.Sprintf("key-%d-%d", id, i)
				safeMap.Set(key, i)
				writeCount++
			}
		}(w)
	}

	wg.Wait()
	elapsed = time.Since(start)

	fmt.Printf("결과:\n")
	fmt.Printf("읽기 작업: ~80,000회\n")
	fmt.Printf("쓰기 작업: 20,000회\n")
	fmt.Printf("최종 맵 크기: %d항목\n", safeMap.Length())
	fmt.Printf("소요시간: %v\n", elapsed)
	fmt.Println("✓ SafeMap Race Detector 통과")

	// Assignment 3: 종합 성능 비교
	fmt.Println("\n[8-3] 종합 성능 비교: 다양한 동기화 기법")

	fmt.Println("\n시나리오: 고루틴 100개, 각 10,000회 카운터 증가\n")

	// 1. 뮤텍스 없음 (위험)
	unsafeValue := 0
	start = time.Now()

	for i := 0; i < 100; i++ {
		wg.Add(1)
		go func() {
			defer wg.Done()
			for j := 0; j < 10000; j++ {
				unsafeValue++
			}
		}()
	}

	wg.Wait()
	unsafeTime := time.Since(start)
	expectedValue = 1000000
	fmt.Printf("1. 뮤텍스 없음:\n")
	fmt.Printf("   소요시간: %v\n", unsafeTime)
	fmt.Printf("   최종값: %d (예상: %d)\n", unsafeValue, expectedValue)
	fmt.Printf("   정확성: %.2f%%\n", float64(unsafeValue)/float64(expectedValue)*100)

	// 2. Mutex 사용
	var mu sync.Mutex
	mutexValue := 0
	start = time.Now()

	for i := 0; i < 100; i++ {
		wg.Add(1)
		go func() {
			defer wg.Done()
			for j := 0; j < 10000; j++ {
				mu.Lock()
				mutexValue++
				mu.Unlock()
			}
		}()
	}

	wg.Wait()
	mutexTime := time.Since(start)
	fmt.Printf("\n2. Mutex 사용:\n")
	fmt.Printf("   소요시간: %v\n", mutexTime)
	fmt.Printf("   최종값: %d (정확)\n", mutexValue)

	// 3. Atomic 사용
	var atomicValue int64 = 0
	start = time.Now()

	for i := 0; i < 100; i++ {
		wg.Add(1)
		go func() {
			defer wg.Done()
			for j := 0; j < 10000; j++ {
				atomic.AddInt64(&atomicValue, 1)
			}
		}()
	}

	wg.Wait()
	atomicTime := time.Since(start)
	fmt.Printf("\n3. Atomic 사용:\n")
	fmt.Printf("   소요시간: %v\n", atomicTime)
	fmt.Printf("   최종값: %d (정확)\n", atomicValue)

	// 성능 비교
	fmt.Printf("\n성능 개선:\n")
	fmt.Printf("Mutex vs Atomic: %.2fx\n", float64(mutexTime.Nanoseconds())/float64(atomicTime.Nanoseconds()))
	fmt.Printf("Unsafe vs Atomic: %.2fx\n", float64(unsafeTime.Nanoseconds())/float64(atomicTime.Nanoseconds()))

	fmt.Println("\n[Assignment 2-3 완료]")
	fmt.Println("✓ Race Condition 재현 및 분석")
	fmt.Println("✓ SafeMap 구현 및 검증")
	fmt.Println("✓ 다양한 동기화 기법 성능 비교")
}

