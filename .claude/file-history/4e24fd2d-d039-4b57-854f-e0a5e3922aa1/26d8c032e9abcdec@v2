type Singleton struct {
	value int
}

var (
	instance *Singleton
	once     sync.Once
)

func GetSingleton() *Singleton {
	once.Do(func() {
		fmt.Println("Singleton 초기화 중...")
		instance = &Singleton{value: 42}
		time.Sleep(100 * time.Millisecond)
	})
	return instance
}

