func section4_atomic() {
	fmt.Println("\n============================================================")
	fmt.Println("섹션 4: Atomic 연산 (CPU 수준 최적화)")
	fmt.Println("============================================================")

	fmt.Println("\n[4-1] 기본 Atomic 연산")

	var count int64 = 0
	var wg sync.WaitGroup

	fmt.Println("고루틴 100개가 각 1000회 Atomic 증가")

	start := time.Now()

	for i := 0; i < 100; i++ {
		wg.Add(1)
		go func() {
			defer wg.Done()
			for j := 0; j < 1000; j++ {
				atomic.AddInt64(&count, 1)
			}
		}()
	}

	wg.Wait()
	elapsed := time.Since(start)

	fmt.Printf("최종값: %d (예상: 100000)\n", count)
	fmt.Printf("소요시간: %v\n", elapsed)

	// [4-2] 다양한 Atomic 연산
	fmt.Println("\n[4-2] 다양한 Atomic 연산")

	var counter int64 = 100

	fmt.Printf("초기값: %d\n", counter)

	// Add
	atomic.AddInt64(&counter, 50)
	fmt.Printf("AddInt64(counter, 50): %d\n", atomic.LoadInt64(&counter))

	// Store/Load
	atomic.StoreInt64(&counter, 1000)
	fmt.Printf("StoreInt64(counter, 1000): %d\n", atomic.LoadInt64(&counter))

	// CompareAndSwap
	swapped := atomic.CompareAndSwapInt64(&counter, 1000, 2000)
	fmt.Printf("CompareAndSwap(1000 -> 2000): %v, 현재값: %d\n", swapped, atomic.LoadInt64(&counter))

	swapped = atomic.CompareAndSwapInt64(&counter, 1000, 3000)  // 실패 (현재값이 1000이 아님)
	fmt.Printf("CompareAndSwap(1000 -> 3000): %v, 현재값: %d\n", swapped, atomic.LoadInt64(&counter))

	// [4-3] Mutex vs Atomic 성능 비교
	fmt.Println("\n[4-3] 성능 비교: Mutex vs Atomic")

	benchmarkMutexCounter := func() time.Duration {
		var mu sync.Mutex
		count := int64(0)

		start := time.Now()

		var wg sync.WaitGroup
		for i := 0; i < 100; i++ {
			wg.Add(1)
			go func() {
				defer wg.Done()
				for j := 0; j < 10000; j++ {
					mu.Lock()
					count++
					mu.Unlock()
				}
			}()
		}

		wg.Wait()
		return time.Since(start)
	}

	benchmarkAtomicCounter := func() time.Duration {
		var count int64 = 0

		start := time.Now()

		var wg sync.WaitGroup
		for i := 0; i < 100; i++ {
			wg.Add(1)
			go func() {
				defer wg.Done()
				for j := 0; j < 10000; j++ {
					atomic.AddInt64(&count, 1)
				}
			}()
		}

		wg.Wait()
		return time.Since(start)
	}

	fmt.Println("시나리오: 고루틴 100개 × 10,000회 증가")

	mutexTime := benchmarkMutexCounter()
	fmt.Printf("Mutex 사용: %v\n", mutexTime)

	atomicTime := benchmarkAtomicCounter()
	fmt.Printf("Atomic 사용: %v\n", atomicTime)

	fmt.Printf("성능 개선: %.2fx\n", float64(mutexTime.Nanoseconds())/float64(atomicTime.Nanoseconds()))
}

