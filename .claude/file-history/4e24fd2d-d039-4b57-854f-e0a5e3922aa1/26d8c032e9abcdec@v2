// ============================================================
// 섹션 1: Mutex 기본 (뮤텍스를 이용한 안전한 카운터)
// ============================================================

type Counter struct {
	mu    sync.Mutex
	value int
}

func (c *Counter) Increment() {
	c.mu.Lock()
	defer c.mu.Unlock()
	c.value++
}

func (c *Counter) Value() int {
	c.mu.Lock()
	defer c.mu.Unlock()
	return c.value
}

func section1_mutexBasics() {
	fmt.Println("\n============================================================")
	fmt.Println("섹션 1: Mutex 기본 (뮤텍스를 이용한 안전한 카운터)")
	fmt.Println("============================================================")

	fmt.Println("\n[1-1] 기본 뮤텍스 사용")

	counter := &Counter{}

	// 고루틴 10개가 각각 100번씩 증가
	numGoroutines := 10
	incrementPerGoroutine := 100

	fmt.Printf("고루틴 %d개, 각 %d회 증가\n", numGoroutines, incrementPerGoroutine)

	var wg sync.WaitGroup
	start := time.Now()

	for i := 0; i < numGoroutines; i++ {
		wg.Add(1)
		go func(id int) {
			defer wg.Done()
			for j := 0; j < incrementPerGoroutine; j++ {
				counter.Increment()
			}
			fmt.Printf("고루틴 %d: 완료\n", id)
		}(i)
	}

	wg.Wait()
	elapsed := time.Since(start)

	expectedValue := numGoroutines * incrementPerGoroutine
	actualValue := counter.Value()

	fmt.Printf("\n결과:\n")
	fmt.Printf("예상값: %d\n", expectedValue)
	fmt.Printf("실제값: %d\n", actualValue)
	fmt.Printf("시간: %v\n", elapsed)

	if expectedValue == actualValue {
		fmt.Println("✓ 데이터 무결성 유지!")
	} else {
		fmt.Printf("✗ 데이터 손상 (%d 손실)\n", expectedValue-actualValue)
	}

	// [1-2] defer와 패닉
	fmt.Println("\n[1-2] defer를 이용한 안전한 Unlock (패닉 처리)")

	type SafeCounter struct {
		mu    sync.Mutex
		value int
	}

	sc := &SafeCounter{}

	defer func() {
		if r := recover(); r != nil {
			fmt.Printf("패닉 발생했지만 안전함: %v\n", r)
		}
	}()

	func() {
		sc.mu.Lock()
		defer sc.mu.Unlock()

		sc.value = 100
		fmt.Printf("뮤텍스 잠금: value = %d\n", sc.value)

		// 패닉 발생 → defer가 실행 → Unlock 호출됨
		panic("의도적 패닉!")
	}()
}

