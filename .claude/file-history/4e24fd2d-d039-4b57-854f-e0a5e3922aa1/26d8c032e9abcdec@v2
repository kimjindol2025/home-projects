// 섹션 2: Race Condition 재현 (뮤텍스 없는 위험)
// ============================================================

func section2_raceCondition() {
	fmt.Println("\n============================================================")
	fmt.Println("섹션 2: Race Condition 재현 (뮤텍스 없는 위험)")
	fmt.Println("============================================================")

	fmt.Println("\n[2-1] 뮤텍스 없이 고루틴 1,000개가 카운터 증가")

	unsafeCount := 0  // 뮤텍스 없음!
	numGoroutines := 1000
	incrementsPerGoroutine := 100

	fmt.Printf("고루틴 %d개, 각 %d회 증가 (뮤텍스 없음)\n", numGoroutines, incrementsPerGoroutine)

	var wg sync.WaitGroup
	start := time.Now()

	for i := 0; i < numGoroutines; i++ {
		wg.Add(1)
		go func() {
			defer wg.Done()
			for j := 0; j < incrementsPerGoroutine; j++ {
				unsafeCount++  // 경쟁 상태 발생!
			}
		}()
	}

	wg.Wait()
	elapsed := time.Since(start)

	expectedValue := numGoroutines * incrementsPerGoroutine
	fmt.Printf("\n결과:\n")
	fmt.Printf("예상값: %d\n", expectedValue)
	fmt.Printf("실제값: %d\n", unsafeCount)
	fmt.Printf("손실: %d (%.1f%%)\n", expectedValue-unsafeCount,
		float64(expectedValue-unsafeCount)/float64(expectedValue)*100)
	fmt.Printf("시간: %v\n", elapsed)

	fmt.Println("\n💡 Race Condition 설명:")
	fmt.Println("count++ 연산은 실제로 3단계:")
	fmt.Println("  1. 메모리에서 값 읽기 (Load)")
	fmt.Println("  2. 값 증가 (Increment)")
	fmt.Println("  3. 메모리에 값 쓰기 (Store)")
	fmt.Println("")
	fmt.Println("여러 고루틴이 동시에 이 3단계를 실행하면,")
	fmt.Println("중간 결과가 덮어씌워져 데이터가 손상됨")

	// [2-2] 뮤텍스로 해결
	fmt.Println("\n[2-2] 뮤텍스로 Race Condition 해결")

	safeCount := 0
	var mu sync.Mutex

	fmt.Printf("동일한 시나리오 (뮤텍스 사용)\n")

	start = time.Now()

	for i := 0; i < numGoroutines; i++ {
		wg.Add(1)
		go func() {
			defer wg.Done()
			for j := 0; j < incrementsPerGoroutine; j++ {
				mu.Lock()
				safeCount++
				mu.Unlock()
			}
		}()
	}

	wg.Wait()
	elapsed = time.Since(start)

	fmt.Printf("\n결과:\n")
	fmt.Printf("예상값: %d\n", expectedValue)
	fmt.Printf("실제값: %d\n", safeCount)
	fmt.Printf("시간: %v\n", elapsed)

	if expectedValue == safeCount {
		fmt.Println("✓ 데이터 무결성 유지!")
	}
}

