// 섹션 3: RWMutex (읽기/쓰기 분리)
// ============================================================

type DataStore struct {
	mu    sync.RWMutex
	data  map[string]int
}

func (ds *DataStore) Get(key string) int {
	ds.mu.RLock()
	defer ds.mu.RUnlock()
	return ds.data[key]
}

func (ds *DataStore) Set(key string, value int) {
	ds.mu.Lock()
	defer ds.mu.Unlock()
	ds.data[key] = value
}

func section3_rwmutex() {
	fmt.Println("\n============================================================")
	fmt.Println("섹션 3: RWMutex (읽기/쓰기 분리)")
	fmt.Println("============================================================")

	fmt.Println("\n[3-1] RWMutex 기본 사용 (읽기는 병렬, 쓰기는 배타적)")

	ds := &DataStore{
		data: make(map[string]int),
	}

	// 초기 데이터 설정
	ds.Set("counter", 0)

	var wg sync.WaitGroup
	start := time.Now()

	// 읽기 워커 8개
	for i := 0; i < 8; i++ {
		wg.Add(1)
		go func(id int) {
			defer wg.Done()
			for j := 0; j < 1000; j++ {
				val := ds.Get("counter")
				_ = val  // 사용
			}
			fmt.Printf("읽기 워커 %d: 1000회 읽음\n", id)
		}(i)
	}

	// 쓰기 워커 2개
	for i := 0; i < 2; i++ {
		wg.Add(1)
		go func(id int) {
			defer wg.Done()
			for j := 0; j < 100; j++ {
				ds.Set("counter", j)
			}
			fmt.Printf("쓰기 워커 %d: 100회 씀\n", id)
		}(i)
	}

	wg.Wait()
	elapsed := time.Since(start)

	fmt.Printf("\n결과:\n")
	fmt.Printf("총 작업: 읽기 8000회 + 쓰기 200회\n")
	fmt.Printf("소요시간: %v\n", elapsed)

	// [3-2] Mutex vs RWMutex 성능 비교
	fmt.Println("\n[3-2] 성능 비교: Mutex vs RWMutex")

	benchmarkMutex := func(readRatio float64) time.Duration {
		var mu sync.Mutex
		data := 0
		readOps := int(10000 * readRatio)
		writeOps := 10000 - readOps

		start := time.Now()

		var wg sync.WaitGroup

		// 읽기 작업
		for i := 0; i < readOps; i++ {
			wg.Add(1)
			go func() {
				defer wg.Done()
				mu.Lock()
				_ = data
				mu.Unlock()
			}()
		}

		// 쓰기 작업
		for i := 0; i < writeOps; i++ {
			wg.Add(1)
			go func() {
				defer wg.Done()
				mu.Lock()
				data++
				mu.Unlock()
			}()
		}

		wg.Wait()
		return time.Since(start)
	}

	benchmarkRWMutex := func(readRatio float64) time.Duration {
		var mu sync.RWMutex
		data := 0
		readOps := int(10000 * readRatio)
		writeOps := 10000 - readOps

		start := time.Now()

		var wg sync.WaitGroup

		// 읽기 작업
		for i := 0; i < readOps; i++ {
			wg.Add(1)
			go func() {
				defer wg.Done()
				mu.RLock()
				_ = data
				mu.RUnlock()
			}()
		}

		// 쓰기 작업
		for i := 0; i < writeOps; i++ {
			wg.Add(1)
			go func() {
				defer wg.Done()
				mu.Lock()
				data++
				mu.Unlock()
			}()
		}

		wg.Wait()
		return time.Since(start)
	}

	fmt.Println("시나리오: 읽기 90% + 쓰기 10%")

	mutexTime := benchmarkMutex(0.9)
	fmt.Printf("Mutex 사용: %v\n", mutexTime)

	rwmutexTime := benchmarkRWMutex(0.9)
	fmt.Printf("RWMutex 사용: %v\n", rwmutexTime)

	fmt.Printf("성능 개선: %.2fx\n", float64(mutexTime.Nanoseconds())/float64(rwmutexTime.Nanoseconds()))
}

