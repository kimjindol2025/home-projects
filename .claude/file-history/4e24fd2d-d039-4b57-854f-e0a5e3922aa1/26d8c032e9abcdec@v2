// ============================================================
// 섹션 7: 고급 패턴 (Cond - 조건 변수)
// ============================================================

type WaitQueue struct {
	mu   sync.Mutex
	cond *sync.Cond
	data []int
}

func NewWaitQueue() *WaitQueue {
	q := &WaitQueue{
		data: make([]int, 0),
	}
	q.cond = sync.NewCond(&q.mu)
	return q
}

func (q *WaitQueue) Enqueue(item int) {
	q.mu.Lock()
	defer q.mu.Unlock()

	q.data = append(q.data, item)
	q.cond.Signal()  // 대기 중인 goroutine 깨우기
}

func (q *WaitQueue) Dequeue() int {
	q.mu.Lock()
	defer q.mu.Unlock()

	for len(q.data) == 0 {
		q.cond.Wait()  // 데이터가 들어올 때까지 대기
	}

	item := q.data[0]
	q.data = q.data[1:]
	return item
}

func section7_advancedPatterns() {
	fmt.Println("\n============================================================")
	fmt.Println("섹션 7: 고급 패턴 (조건 변수 Cond)")
	fmt.Println("============================================================")

	fmt.Println("\n[7-1] 조건 변수를 이용한 대기 큐")

	queue := NewWaitQueue()
	var wg sync.WaitGroup

	// 소비자 2개 (대기)
	for i := 0; i < 2; i++ {
		wg.Add(1)
		go func(id int) {
			defer wg.Done()
			for j := 0; j < 3; j++ {
				item := queue.Dequeue()
				fmt.Printf("소비자 %d: 아이템 %d 수신\n", id, item)
				time.Sleep(100 * time.Millisecond)
			}
		}(i)
	}

	// 생산자 1개 (공급)
	time.Sleep(100 * time.Millisecond)

	for i := 1; i <= 6; i++ {
		fmt.Printf("생산자: 아이템 %d 전송\n", i)
		queue.Enqueue(i)
		time.Sleep(50 * time.Millisecond)
	}

	wg.Wait()
	fmt.Println("✓ 모든 항목 처리 완료")
}

