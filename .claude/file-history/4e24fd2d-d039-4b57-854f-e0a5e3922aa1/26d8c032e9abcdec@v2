type SafeMap struct {
	mu    sync.RWMutex
	items map[string]interface{}
}

func NewSafeMap() *SafeMap {
	return &SafeMap{
		items: make(map[string]interface{}),
	}
}

func (sm *SafeMap) Get(key string) (interface{}, bool) {
	sm.mu.RLock()
	defer sm.mu.RUnlock()
	val, ok := sm.items[key]
	return val, ok
}

func (sm *SafeMap) Set(key string, value interface{}) {
	sm.mu.Lock()
	defer sm.mu.Unlock()
	sm.items[key] = value
}

func (sm *SafeMap) Delete(key string) {
	sm.mu.Lock()
	defer sm.mu.Unlock()
	delete(sm.items, key)
}

func (sm *SafeMap) Length() int {
	sm.mu.RLock()
	defer sm.mu.RUnlock()
	return len(sm.items)
}

func (sm *SafeMap) Keys() []string {
	sm.mu.RLock()
	defer sm.mu.RUnlock()

	keys := make([]string, 0, len(sm.items))
	for k := range sm.items {
		keys = append(keys, k)
	}
	return keys
}

func section5_safeMap() {
	fmt.Println("\n============================================================")
	fmt.Println("섹션 5: SafeMap 구현 (동시성 안전 맵)")
	fmt.Println("============================================================")

	fmt.Println("\n[5-1] SafeMap 기본 사용")

	safeMap := NewSafeMap()

	fmt.Println("초기 상태:")
	fmt.Printf("길이: %d\n", safeMap.Length())

	// Set 작업
	safeMap.Set("name", "Go")
	safeMap.Set("version", 1.21)
	safeMap.Set("author", "Robert Griesemer")

	fmt.Println("\n3개 항목 추가 후:")
	fmt.Printf("길이: %d\n", safeMap.Length())
	fmt.Printf("Keys: %v\n", safeMap.Keys())

	// Get 작업
	if val, ok := safeMap.Get("name"); ok {
		fmt.Printf("name: %v\n", val)
	}

	// Delete 작업
	safeMap.Delete("version")
	fmt.Printf("\nversion 삭제 후 길이: %d\n", safeMap.Length())

	// [5-2] 동시성 테스트
	fmt.Println("\n[5-2] 동시성 테스트 (고루틴 100개 동시 접근)")

	safeMap = NewSafeMap()
	var wg sync.WaitGroup

	start := time.Now()

	// 쓰기 워커 20개
	for w := 0; w < 20; w++ {
		wg.Add(1)
		go func(workerID int) {
			defer wg.Done()
			for i := 0; i < 100; i++ {
				key := fmt.Sprintf("key-%d-%d", workerID, i)
				safeMap.Set(key, i*100)
			}
			fmt.Printf("쓰기 워커 %d: 100개 저장\n", workerID)
		}(w)
	}

	// 읽기 워커 80개
	for r := 0; r < 80; r++ {
		wg.Add(1)
		go func(readerID int) {
			defer wg.Done()
			for i := 0; i < 100; i++ {
				// 무작위로 읽기
				keys := safeMap.Keys()
				if len(keys) > 0 {
					key := keys[i%len(keys)]
					_, _ = safeMap.Get(key)
				}
			}
			fmt.Printf("읽기 워커 %d: 100회 읽음\n", readerID)
		}(r)
	}

	wg.Wait()
	elapsed := time.Since(start)

	finalLength := safeMap.Length()
	fmt.Printf("\n결과:\n")
	fmt.Printf("최종 맵 크기: %d 항목\n", finalLength)
	fmt.Printf("소요시간: %v\n", elapsed)
	fmt.Println("✓ Race Detector 통과 (동시성 안전)")
}

