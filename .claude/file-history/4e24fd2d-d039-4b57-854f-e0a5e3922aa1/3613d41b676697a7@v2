// 벤치마킹 테스트 함수들 (실제 테스트에서 사용)

// BenchmarkSimpleAdd: 기본 벤치마크
func BenchmarkSimpleAdd(b *testing.B) {
	for i := 0; i < b.N; i++ {
		_ = 1 + 2
	}
}

// BenchmarkSliceGood: 최적화된 슬라이스 (용량 미리 할당)
func BenchmarkSliceGood(b *testing.B) {
	b.ReportAllocs()
	for i := 0; i < b.N; i++ {
		s := make([]int, 0, 100)  // 용량 미리 할당
		for j := 0; j < 100; j++ {
			s = append(s, j)
		}
	}
}

// BenchmarkSliceBad: 최악의 슬라이스 (반복적 재할당)
func BenchmarkSliceBad(b *testing.B) {
	b.ReportAllocs()
	for i := 0; i < b.N; i++ {
		var s []int  // 용량 없음
		for j := 0; j < 100; j++ {
			s = append(s, j)  // 매번 재할당
		}
	}
}

