func section6Demo() {
	fmt.Printf("[%s%s]\n", separator, section6)

	fmt.Println("\n🎯 GOMEMLIMIT (Go 1.19+)")
	fmt.Println("   최대 메모리 제한을 통한 GC 자동 조절")

	fmt.Println("\n📊 메모리 관리 방식 비교:")
	fmt.Println("   과거 (GOGC만):")
	fmt.Println("   - GOGC=100 → 힙 2배 증가했을 때 GC")
	fmt.Println("   - 메모리 사용량 예측 불가능")
	fmt.Println()
	fmt.Println("   현대 (GOMEMLIMIT 추가):")
	fmt.Println("   - GOMEMLIMIT=512MiB → 512MB 초과 금지")
	fmt.Println("   - GC가 자동으로 빈도 조절")
	fmt.Println("   - K8s OOM Kill 방지")

	fmt.Println("\n💻 GOMEMLIMIT 사용:")
	fmt.Println("   # 환경 변수")
	fmt.Println("   $ export GOMEMLIMIT=512MiB")
	fmt.Println("   $ go run main.go")
	fmt.Println()
	fmt.Println("   # 프로그래밍 방식")
	fmt.Println("   import \"runtime/debug\"")
	fmt.Println("   debug.SetMemoryLimit(512 * 1024 * 1024)  // 512MB")

	fmt.Println("\n⚡ GOMEMLIMIT의 효과:")
	fmt.Println("   ✓ 메모리 사용량 예측 가능")
	fmt.Println("   ✓ 컨테이너 환경에서 안정성 향상")
	fmt.Println("   ✓ GC 빈도 자동 조절 (성능 vs 메모리 균형)")
	fmt.Println("   ✓ OOM Kill 방지")

	fmt.Println("\n📈 현재 메모리 상태:")
	var m runtime.MemStats
	runtime.ReadMemStats(&m)
	fmt.Printf("   Alloc:      %v MB\n", m.Alloc/1024/1024)
	fmt.Printf("   TotalAlloc: %v MB\n", m.TotalAlloc/1024/1024)
	fmt.Printf("   Sys:        %v MB\n", m.Sys/1024/1024)
	fmt.Printf("   NumGC:      %v\n", m.NumGC)

	// 현재 메모리 제한 확인
	limit := debug.SetMemoryLimit(-1)  // -1: 읽기만
	debug.SetMemoryLimit(limit)
	fmt.Printf("   MemoryLimit: %v MB\n", limit/1024/1024)

	fmt.Println()
}

