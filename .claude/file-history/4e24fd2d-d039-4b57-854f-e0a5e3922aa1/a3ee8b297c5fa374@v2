## 5️⃣ 실무 패턴: 도서관 관리 시스템

### 📋 데이터 모델

```go
// Book 구조체
type Book struct {
    ID     int     // 책 ID
    Title  string  // 제목
    Author string  // 저자
    Year   int     // 출판년도
    ISBN   string  // ISBN
    Available bool  // 대여 가능 여부
}

// Library 구조체
type Library struct {
    Name  string       // 도서관 이름
    Books []Book       // 도서 목록 (슬라이스)
    Index map[string]*Book  // ISBN으로 책을 빠르게 찾기 (맵)
}

// 책 추가
func (lib *Library) AddBook(book Book) {
    lib.Books = append(lib.Books, book)
    lib.Index[book.ISBN] = &book  // 인덱스 업데이트
}

// ISBN으로 책 찾기
func (lib *Library) FindByISBN(isbn string) *Book {
    return lib.Index[isbn]
}

// 책 대여
func (lib *Library) BorrowBook(isbn string) error {
    book := lib.FindByISBN(isbn)
    if book == nil {
        return fmt.Errorf("book not found")
    }
    if !book.Available {
        return fmt.Errorf("book not available")
    }
    book.Available = false
    return nil
}
```

