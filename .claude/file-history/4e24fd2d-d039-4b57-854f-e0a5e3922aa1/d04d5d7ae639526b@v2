	fmt.Println("\n💡 구조체 필드 순서의 중요성:")
	fmt.Printf("BadOrder 크기:  %d bytes (패딩 많음)\n", unsafe.Sizeof(BadOrder{}))
	fmt.Printf("GoodOrder 크기: %d bytes (패딩 최소)\n", unsafe.Sizeof(GoodOrder{}))
