// 섹션 7️⃣: Zero Allocation 코드
// ============================================================================

// ❌ 나쁜 예: 매 호출마다 Heap 할당
func badConcat(strs []string) string {
	var result string
	for _, s := range strs {
		result += s // 매번 새 문자열 객체 생성 & 힙 할당
	}
	return result
}

// ✅ 좋은 예: 버퍼 재사용 (Zero Allocation)
func goodConcat(strs []string, buf *bytes.Buffer) string {
	buf.Reset() // 버퍼 초기화 (힙 할당 X)
	for _, s := range strs {
		buf.WriteString(s)
	}
	return buf.String()
}

// Zero Allocation 패턴: sync.Pool
type Buffer struct {
	data []byte
}

var bufferPool = sync.Pool{
	New: func() interface{} {
		return &Buffer{data: make([]byte, 1024)}
	},
}

func processWithPool(data string) {
	buf := bufferPool.Get().(*Buffer)
	defer bufferPool.Put(buf)

	copy(buf.data, data)
}

func section6Demo() {
	fmt.Printf("[%s%s]\n", separator, section6)

	fmt.Println("\n🎯 Zero Allocation 전략")
	fmt.Println("   1. 객체 재사용: sync.Pool")
	fmt.Println("   2. 스택 배열: [N]T 대신 []T")
	fmt.Println("   3. 버퍼 풀: bytes.Buffer 재사용")
	fmt.Println("   4. 구조체 값: 포인터 아닌 값 전달")

	fmt.Println("\n❌ 나쁜 예: String Concatenation (매 호출마다 힙 할당)")
	strs := []string{"Hello", " ", "World", "!"}
	result1 := badConcat(strs)
	fmt.Printf("결과: %s (힙 할당 3회)\n", result1)

	fmt.Println("\n✅ 좋은 예: Buffer 재사용 (Zero Allocation)")
	var buf bytes.Buffer
	result2 := goodConcat(strs, &buf)
	fmt.Printf("결과: %s (힙 할당 0회)\n", result2)

	fmt.Println("\n💾 sync.Pool로 객체 재사용:")
	for i := 0; i < 3; i++ {
		processWithPool(fmt.Sprintf("Data %d", i))
	}
	fmt.Println("   3개의 요청 처리, 동일 버퍼 재사용 (Zero Allocation)")

	fmt.Println()
}

