func demonstrateGCTuning() {
	fmt.Println("🎛️ GOGC 환경 변수")
	fmt.Printf("   현재 GOGC: %s (기본값: 100)\n", os.Getenv("GOGC"))
	fmt.Println("   GOGC=100: NextGC = Heap * 2 (기본값)")
	fmt.Println("   GOGC=50:  NextGC = Heap * 1.5 (공격적 GC)")
	fmt.Println("   GOGC=200: NextGC = Heap * 3 (느슨한 GC)")

	fmt.Println("\n🔧 debug.SetGCPercent() 사용 예")
	fmt.Println("   debug.SetGCPercent(50)   // GOGC=50과 동일")
	fmt.Println("   debug.SetGCPercent(100)  // GOGC=100 (기본값)")
	fmt.Println("   debug.SetGCPercent(-1)   // GC 비활성화 (권장 X)")

	var m runtime.MemStats
	runtime.ReadMemStats(&m)

	fmt.Println("\n📊 메모리 통계")
	fmt.Printf("   Alloc:       %v MB (현재 할당)\n", m.Alloc/1024/1024)
	fmt.Printf("   TotalAlloc:  %v MB (총 할당)\n", m.TotalAlloc/1024/1024)
	fmt.Printf("   Sys:         %v MB (시스템 할당)\n", m.Sys/1024/1024)
	fmt.Printf("   NumGC:       %v (GC 실행 횟수)\n", m.NumGC)
	fmt.Printf("   GC 비율:     %.1f%%\n", float64(m.NumGC)/float64(m.Mallocs)*100)
}

