type Employee struct {
	ID     uint32  // 오프셋 0,  크기 4
	Age    uint8   // 오프셋 4,  크기 1 (+ 3 bytes padding)
	Salary float64 // 오프셋 8,  크기 8
	Name   string  // 오프셋 16, 크기 16 (포인터 + 길이)
}

func analyzeMemoryLayout() {
	emp := Employee{
		ID:     12345,
		Age:    30,
		Salary: 75000.0,
		Name:   "Alice",
	}

	fmt.Printf("Employee 크기: %d bytes\n", unsafe.Sizeof(emp))
	fmt.Printf("\n필드 오프셋:\n")
	fmt.Printf("   ID     offset: %d\n", unsafe.Offsetof(emp.ID))
	fmt.Printf("   Age    offset: %d\n", unsafe.Offsetof(emp.Age))
	fmt.Printf("   Salary offset: %d\n", unsafe.Offsetof(emp.Salary))
	fmt.Printf("   Name   offset: %d\n", unsafe.Offsetof(emp.Name))

	fmt.Printf("\n필드 정렬 크기:\n")
	fmt.Printf("   ID     align: %d\n", unsafe.Alignof(emp.ID))
	fmt.Printf("   Age    align: %d\n", unsafe.Alignof(emp.Age))
	fmt.Printf("   Salary align: %d\n", unsafe.Alignof(emp.Salary))
	fmt.Printf("   Name   align: %d\n", unsafe.Alignof(emp.Name))

	fmt.Printf("\n메모리 주소:\n")
	fmt.Printf("   Employee: %p\n", &emp)
	fmt.Printf("   ID:       %p\n", &emp.ID)
	fmt.Printf("   Age:      %p\n", &emp.Age)
	fmt.Printf("   Salary:   %p\n", &emp.Salary)
	fmt.Printf("   Name:     %p\n", &emp.Name)
}

type BadOrder struct {
	A bool    // 1 byte (+ 7 padding)
	B int64   // 8 bytes
	C bool    // 1 byte (+ 7 padding)
	D int64   // 8 bytes
	E bool    // 1 byte (+ 7 padding)
}

type GoodOrder struct {
	B int64   // 8 bytes
	D int64   // 8 bytes
	A bool    // 1 byte
	C bool    // 1 byte
	E bool    // 1 byte
	// 5 bytes padding
}

func section5Demo() {
	fmt.Printf("[%s%s]\n", separator, section5)

	fmt.Println("\n📐 메모리 레이아웃 분석:")
