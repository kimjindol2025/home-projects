func demonstrateGC() {
	// GC 통계 수집
	var m1 runtime.MemStats
	runtime.ReadMemStats(&m1)

	fmt.Printf("GC 실행 전:\n")
	fmt.Printf("   할당된 메모리: %v MB\n", m1.Alloc/1024/1024)
	fmt.Printf("   총 할당: %v MB\n", m1.TotalAlloc/1024/1024)
	fmt.Printf("   GC 횟수: %v\n", m1.NumGC)

	// 대량 메모리 할당해서 GC 트리거
	var slices [][]int
	for i := 0; i < 1000; i++ {
		slices = append(slices, make([]int, 10000))
	}

	// 명시적 GC 실행
	runtime.GC()

	var m2 runtime.MemStats
	runtime.ReadMemStats(&m2)

	fmt.Printf("\nGC 실행 후:\n")
	fmt.Printf("   할당된 메모리: %v MB\n", m2.Alloc/1024/1024)
	fmt.Printf("   총 할당: %v MB\n", m2.TotalAlloc/1024/1024)
	fmt.Printf("   GC 횟수: %v\n", m2.NumGC)
	fmt.Printf("   GC 시간 (STW): %v ms\n", m2.PauseNs[(m2.NumGC-1)%256]/1e6)
}

