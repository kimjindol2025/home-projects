type Person struct {
	ID    uint32 // 오프셋 0
	Age   uint8  // 오프셋 4
	Alive bool   // 오프셋 5
}

func pointerArithmeticMission() {
	fmt.Printf("[%s%s]\n", separator, section8)

	fmt.Println("\n📝 Assignment 4-1: 메모리 해킹")

	fmt.Println("\n【 과제 1: Escape 분석 】")
	fmt.Println("   실행: go build -gcflags=\"-m\" 401_memory_layout_escape_analysis.go")
	fmt.Println("   분석:")
	fmt.Println("   ✓ escapeToHeap: x escapes to heap")
	fmt.Println("   ✓ escapeCase2: x escapes to heap")
	fmt.Println("   ✓ escapeCase3: x does not escape")
	fmt.Println("   ✓ escapeCase4: x escapes to heap")

	fmt.Println("\n【 과제 2: 포인터 산술 미션 】")

	p := Person{ID: 1, Age: 25, Alive: true}

	fmt.Printf("\n초기 상태:\n")
	fmt.Printf("   Person: ID=%d, Age=%d, Alive=%v\n", p.ID, p.Age, p.Alive)

	personPtr := unsafe.Pointer(&p)

	// Age 필드 주소 계산 및 변경
	fmt.Printf("\n1️⃣ Age 필드 변경 (포인터 산술):")
	ageOffset := unsafe.Offsetof(p.Age)
	fmt.Printf("   Age 오프셋: %d\n", ageOffset)
	agePtr := (*uint8)(unsafe.Pointer(uintptr(personPtr) + ageOffset))
	fmt.Printf("   원래 값: %d\n", *agePtr)
	*agePtr = 99
	fmt.Printf("   변경된 값: %d\n", *agePtr)
	fmt.Printf("   검증: p.Age = %d ✓\n", p.Age)

	// Alive 필드 주소 계산 및 변경
	fmt.Printf("\n2️⃣ Alive 필드 변경 (포인터 산술):")
	aliveOffset := unsafe.Offsetof(p.Alive)
	fmt.Printf("   Alive 오프셋: %d\n", aliveOffset)
	alivePtr := (*bool)(unsafe.Pointer(uintptr(personPtr) + aliveOffset))
	fmt.Printf("   원래 값: %v\n", *alivePtr)
	*alivePtr = false
	fmt.Printf("   변경된 값: %v\n", *alivePtr)
	fmt.Printf("   검증: p.Alive = %v ✓\n", p.Alive)

	fmt.Printf("\n최종 상태:\n")
	fmt.Printf("   Person: ID=%d, Age=%d, Alive=%v\n", p.ID, p.Age, p.Alive)

	fmt.Println("\n✅ 포인터 산술 성공!")
	fmt.Println("   메모리에 직접 접근하여 값 수정 완료")
	fmt.Println("   (매우 위험한 수준이지만, 당신은 이 양날의 검을 다룰 자격이 있습니다)")

	fmt.Println()
}

