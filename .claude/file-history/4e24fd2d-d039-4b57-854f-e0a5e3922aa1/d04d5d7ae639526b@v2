// ❌ 나쁜 예: 힙으로 탈출하는 포인터 반환
func escapeToHeap() *int {
	x := 10
	return &x // x는 함수 끝나도 살아있어야 하므로 Heap으로 이동
}

// ✅ 좋은 예: 값 전달 (Stack 내에서 완료)
func noEscapeStackArray() [10]int {
	arr := [10]int{1, 2, 3, 4, 5}
	return arr // 스택 배열은 그대로 반환 (복사)
}

// ✅ 좋은 예: 포인터 사용만 함 (Escape 없음)
func usePointerNoEscape(p *int) int {
	return *p + 10 // p가 어디서 왔는지 상관없음
}

