type Point struct {
	X int32  // 오프셋 0, 크기 4
	Y int32  // 오프셋 4, 크기 4
	Z int32  // 오프셋 8, 크기 4
}

func demonstratePointerArithmetic() {
	p := Point{X: 10, Y: 20, Z: 30}

	fmt.Printf("초기 Point: X=%d, Y=%d, Z=%d\n", p.X, p.Y, p.Z)
	fmt.Printf("Point 크기: %d bytes\n", unsafe.Sizeof(p))

	// 방법 1: 정상적인 접근
	fmt.Printf("정상 접근: p.Y = %d\n", p.Y)

	// 방법 2: 포인터 산술로 직접 접근
	ptr := unsafe.Pointer(&p)

	// Y 필드 주소 = p 주소 + 4 bytes
	yPtr := (*int32)(unsafe.Pointer(uintptr(ptr) + 4))
	fmt.Printf("포인터 산술: *yPtr = %d\n", *yPtr)

	// Y 필드를 999로 변경
	*yPtr = 999
	fmt.Printf("변경 후 p.Y = %d (메모리에 직접 쓰임!)\n", p.Y)
}

func stringToBytes(s string) []byte {
	// String 내부 구조체
	type StringHeader struct {
		Data uintptr
		Len  int
	}

	// []byte 내부 구조체
	type SliceHeader struct {
		Data uintptr
		Len  int
		Cap  int
	}

	sh := (*StringHeader)(unsafe.Pointer(&s))

	bh := SliceHeader{
		Data: sh.Data,
		Len:  sh.Len,
		Cap:  sh.Len,
	}

	return *(*[]byte)(unsafe.Pointer(&bh))
}

