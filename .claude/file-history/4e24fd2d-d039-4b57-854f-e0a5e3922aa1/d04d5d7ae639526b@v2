// Escape 케이스들
func escapeCase1() *int {
	x := 10
	return &x // ❌ x escapes to heap
}

func escapeCase2(x int) interface{} {
	return x // ❌ x escapes to heap (interface{} 때문)
}

func escapeCase3(x int) int {
	return x + 10 // ✅ x does not escape
}

func escapeCase4() {
	x := 10
	go func() {
		_ = x // ❌ x escapes to heap (클로저 참조)
	}()
}

