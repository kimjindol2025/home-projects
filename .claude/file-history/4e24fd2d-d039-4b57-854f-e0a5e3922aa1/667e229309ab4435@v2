// Entry point for the calculator application
// Demonstrates proper project structure with:
// - internal/calculator (비공개 패키지)
// - internal/models (데이터 구조)
// - pkg/logger (공개 로깅 유틸)
// - configs (설정 관리)

package main

import (
	"fmt"

	"github.com/golang_study/calculator_project/configs"
	"github.com/golang_study/calculator_project/internal/calculator"
	"github.com/golang_study/calculator_project/internal/models"
	"github.com/golang_study/calculator_project/pkg/logger"
)

func main() {
	fmt.Println("============================================================")
	fmt.Println("🎓 Calculator Project - Assignment 1-13")
	fmt.Println("============================================================")

	// Load configuration
	cfg := configs.LoadConfig()
	logger.Log(fmt.Sprintf("Application: %s v%s", cfg.AppName, cfg.Version))

	fmt.Println("\n[섹션 1] 기본 사칙연산")
	fmt.Println("============================================================")

	// Test Addition
	result1 := calculator.Add(10, 5)
	logger.Success(fmt.Sprintf("10 + 5 = %f", result1))

	// Test Subtraction
	result2 := calculator.Subtract(10, 5)
	logger.Success(fmt.Sprintf("10 - 5 = %f", result2))

	// Test Multiplication
	result3 := calculator.Multiply(10, 5)
	logger.Success(fmt.Sprintf("10 * 5 = %f", result3))

	// Test Division (success case)
	result4, err := calculator.Divide(10, 5)
	if err != nil {
		logger.Error(err.Error())
	} else {
		logger.Success(fmt.Sprintf("10 / 5 = %f", result4))
	}

	fmt.Println("\n[섹션 2] 에러 처리: Division by Zero")
	fmt.Println("============================================================")

	// Test Division by Zero (error case)
	_, err = calculator.Divide(10, 0)
	if err != nil {
		logger.Error(fmt.Sprintf("Division error: %v", err))
	}

	fmt.Println("\n[섹션 3] 구조체를 활용한 연산")
	fmt.Println("============================================================")

	// Create operations using the models package
	operations := []models.Operation{
		{Operator: "+", A: 100, B: 50},
		{Operator: "-", A: 100, B: 50},
		{Operator: "*", A: 100, B: 50},
		{Operator: "/", A: 100, B: 50},
	}

	results := make([]models.Result, len(operations))

	for i, op := range operations {
		results[i] = performOperation(op)
		if results[i].Error != "" {
			logger.Error(results[i].Error)
		} else {
			logger.Success(results[i].Operation)
		}
	}

	fmt.Println("\n[섹션 4] 패키지 가시성 규칙")
	fmt.Println("============================================================")
	logger.Log("공개 함수 (capitalized):")
	logger.Log("  ✓ calculator.Add()       - internal/calculator에서 공개")
	logger.Log("  ✓ calculator.Divide()    - 에러 처리")
	logger.Log("  ✓ logger.Log()           - pkg/logger에서 공개")
	logger.Log("  ✓ logger.Success()       - pkg/logger에서 공개")
	logger.Log("\n비공개 함수 (unexported):")
	logger.Log("  • performOperation()     - 파일 범위 내에서만 사용")

	fmt.Println("\n[섹션 5] 모듈 구조 확인")
	fmt.Println("============================================================")
	logger.Log("현재 모듈: github.com/golang_study/calculator_project")
	logger.Log("Go 버전: 1.26")
	logger.Log("구조:")
	logger.Log("  ├── cmd/main/main.go          (진입점)")
	logger.Log("  ├── internal/calculator/      (비공개 패키지)")
	logger.Log("  ├── internal/models/          (데이터 구조)")
	logger.Log("  ├── pkg/logger/               (공개 유틸)")
	logger.Log("  ├── configs/                  (설정 관리)")
	logger.Log("  ├── go.mod                    (모듈 선언)")
	logger.Log("  └── go.sum                    (의존성 체크섬)")

	fmt.Println("\n" + "============================================================")
	fmt.Println("✅ 프로젝트 아키텍처 데모 완료!")
	fmt.Println("============================================================\n")
}

// performOperation is a private function (unexported)
// It demonstrates that private functions are local to the file/package
func performOperation(op models.Operation) models.Result {
	switch op.Operator {
	case "+":
		return models.Result{
			Operation: fmt.Sprintf("%.0f + %.0f = %.0f", op.A, op.B, calculator.Add(op.A, op.B)),
			Value:     calculator.Add(op.A, op.B),
			Error:     "",
		}
	case "-":
		return models.Result{
			Operation: fmt.Sprintf("%.0f - %.0f = %.0f", op.A, op.B, calculator.Subtract(op.A, op.B)),
			Value:     calculator.Subtract(op.A, op.B),
			Error:     "",
		}
	case "*":
		return models.Result{
			Operation: fmt.Sprintf("%.0f * %.0f = %.0f", op.A, op.B, calculator.Multiply(op.A, op.B)),
			Value:     calculator.Multiply(op.A, op.B),
			Error:     "",
		}
	case "/":
		result, err := calculator.Divide(op.A, op.B)
		errMsg := ""
		if err != nil {
			errMsg = err.Error()
		}
		return models.Result{
			Operation: fmt.Sprintf("%.0f / %.0f = %.2f", op.A, op.B, result),
			Value:     result,
			Error:     errMsg,
		}
	default:
		return models.Result{
			Operation: "",
			Value:     0,
			Error:     "unknown operator",
		}
	}
}
