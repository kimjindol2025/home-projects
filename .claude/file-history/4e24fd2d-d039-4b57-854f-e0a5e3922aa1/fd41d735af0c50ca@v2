// 섹션 6️⃣: Circuit Breaker - 분산 시스템 장애 격리
// ============================================================================

// CircuitBreakerState 상태
type CircuitBreakerState string

const (
	CLOSED     CircuitBreakerState = "CLOSED"
	OPEN       CircuitBreakerState = "OPEN"
	HALF_OPEN  CircuitBreakerState = "HALF_OPEN"
)

// CircuitBreaker 구현
type CircuitBreaker struct {
	state           CircuitBreakerState
	failureCount    int
	successCount    int
	lastFailureTime time.Time
	failureThreshold int
	timeout         time.Duration
	mu              sync.Mutex
}

// NewCircuitBreaker 생성
func NewCircuitBreaker(failureThreshold int, timeout time.Duration) *CircuitBreaker {
	return &CircuitBreaker{
		state:            CLOSED,
		failureThreshold: failureThreshold,
		timeout:          timeout,
	}
}

// Execute: Circuit Breaker로 보호된 실행
func (cb *CircuitBreaker) Execute(fn func() error) error {
	cb.mu.Lock()
	state := cb.state
	cb.mu.Unlock()

	switch state {
	case CLOSED:
		err := fn()

		cb.mu.Lock()
		if err != nil {
			cb.failureCount++
			cb.lastFailureTime = time.Now()

			fmt.Printf("[CB] ❌ 실패 #%d\n", cb.failureCount)

			if cb.failureCount >= cb.failureThreshold {
				cb.state = OPEN
				fmt.Println("[CB] 🛑 Circuit Breaker OPEN (차단됨)")
			}
			cb.mu.Unlock()
			return err
		}

		cb.failureCount = 0
		cb.mu.Unlock()
		return nil

	case OPEN:
		cb.mu.Lock()
		if time.Since(cb.lastFailureTime) > cb.timeout {
			cb.state = HALF_OPEN
			cb.successCount = 0
			cb.mu.Unlock()
			fmt.Println("[CB] 🔄 Circuit Breaker HALF_OPEN (복구 시도)")
			// 재귀 호출 대신 직접 실행
			return cb.Execute(fn)
		}
		cb.mu.Unlock()

		fmt.Println("[CB] ⛔ 요청 차단 (Circuit OPEN)")
		return fmt.Errorf("circuit breaker is OPEN")

	case HALF_OPEN:
		err := fn()

		cb.mu.Lock()
		if err != nil {
			cb.state = OPEN
			fmt.Println("[CB] ❌ 복구 실패 → OPEN")
			cb.mu.Unlock()
			return err
		}

		cb.successCount++
		if cb.successCount >= 2 {
			cb.state = CLOSED
			cb.failureCount = 0
			fmt.Println("[CB] ✓ Circuit Breaker CLOSED (정상 복구)")
		}
		cb.mu.Unlock()
		return nil
	}

	return fmt.Errorf("unknown state")
}

// CircuitBreakerDemo: 장애 격리 시연
func CircuitBreakerDemo() {
	fmt.Println("\n[Circuit Breaker] 분산 시스템 장애 격리")

	cb := NewCircuitBreaker(2, 1*time.Second)

	// 정상 요청
	fmt.Println("\n1️⃣ 정상 요청들")
	cb.Execute(func() error {
		fmt.Println("[Service] ✓ 요청 성공")
		return nil
	})

	// 실패 요청 시작
	fmt.Println("\n2️⃣ 실패 요청들 (실패 임계값 = 2)")
	for i := 0; i < 3; i++ {
		cb.Execute(func() error {
			return fmt.Errorf("service error")
		})
	}

	// Circuit이 차단됨
	fmt.Println("\n3️⃣ Circuit이 차단됨")
	for i := 0; i < 2; i++ {
		cb.Execute(func() error {
			fmt.Println("[Service] 실제 요청은 하지 않음")
			return nil
		})
	}

	// 시간 경과 후 복구 시도
	fmt.Println("\n4️⃣ 타임아웃 후 복구 시도 (HALF_OPEN)")
	time.Sleep(1100 * time.Millisecond)

	cb.Execute(func() error {
		fmt.Println("[Service] 💪 테스트 요청 - 성공!")
		return nil
	})

	// 정상 복구
	fmt.Println("\n5️⃣ 서비스 정상 복구 (CLOSED)")
	for i := 0; i < 2; i++ {
		cb.Execute(func() error {
			fmt.Println("[Service] ✓ 정상 작동")
			return nil
		})
	}
}

