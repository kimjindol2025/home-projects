// Order 타입
type Order struct {
	ID     string
	UserID string
	Items  []string
	Total  float64
	Status string
}

// Publisher: 주문 생성
func OrderPublisher(broker *SimpleMessageBroker) {
	fmt.Println("\n[Publisher] 주문 생성 시작")

	for i := 1; i <= 3; i++ {
		order := Order{
			ID:     fmt.Sprintf("order-%d", i),
			UserID: fmt.Sprintf("user-%d", i),
			Items:  []string{"item-1", "item-2"},
			Total:  99.99,
			Status: "PENDING",
		}

		broker.Publish("order-created", order)
		time.Sleep(200 * time.Millisecond)
	}
}

// Subscriber 1: 이메일 서비스
func EmailServiceSubscriber(broker *SimpleMessageBroker, done <-chan struct{}) {
	messages := broker.Subscribe("order-created")

	go func() {
		for {
			select {
			case msg := <-messages:
				order := msg.Payload.(Order)
				fmt.Printf("  [EmailService] 📧 확인 이메일 발송: %s → %s\n", order.ID, order.UserID)
				time.Sleep(100 * time.Millisecond)
				broker.Acknowledge(msg)

			case <-done:
				fmt.Println("  [EmailService] ✓ 종료")
				return
			}
		}
	}()
}

// Subscriber 2: 결제 서비스
func PaymentServiceSubscriber(broker *SimpleMessageBroker, done <-chan struct{}) {
	messages := broker.Subscribe("order-created")

	go func() {
		for {
			select {
			case msg := <-messages:
				order := msg.Payload.(Order)
				fmt.Printf("  [PaymentService] 💳 결제 처리: %s ($%.2f)\n", order.ID, order.Total)
				time.Sleep(150 * time.Millisecond)
				broker.Acknowledge(msg)

			case <-done:
				fmt.Println("  [PaymentService] ✓ 종료")
				return
			}
		}
	}()
}

// Subscriber 3: 재고 서비스
func InventoryServiceSubscriber(broker *SimpleMessageBroker, done <-chan struct{}) {
	messages := broker.Subscribe("order-created")

	go func() {
		for {
			select {
			case msg := <-messages:
				order := msg.Payload.(Order)
				fmt.Printf("  [InventoryService] 📦 재고 감소: %s\n", order.ID)
				time.Sleep(80 * time.Millisecond)
				broker.Acknowledge(msg)

			case <-done:
				fmt.Println("  [InventoryService] ✓ 종료")
				return
			}
		}
	}()
}

