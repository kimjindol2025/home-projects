// 섹션 1️⃣: Message Broker - 기본 구조
// ============================================================================

// Message 타입 정의
type Message struct {
	ID        string
	Topic     string
	Payload   interface{}
	Timestamp time.Time
	RetryCount int
}

// MessageBroker 인터페이스
type MessageBroker interface {
	Publish(topic string, message interface{}) error
	Subscribe(topic string) <-chan *Message
	Acknowledge(msg *Message) error
}

// SimpleMessageBroker 구현
type SimpleMessageBroker struct {
	topics    map[string][]chan *Message
	messages  map[string][]*Message
	mu        sync.RWMutex
	msgID     int
}

// NewMessageBroker 생성
func NewMessageBroker() *SimpleMessageBroker {
	return &SimpleMessageBroker{
		topics:   make(map[string][]chan *Message),
		messages: make(map[string][]*Message),
	}
}

// Publish: 메시지 발행
func (mb *SimpleMessageBroker) Publish(topic string, payload interface{}) error {
	mb.mu.Lock()
	defer mb.mu.Unlock()

	mb.msgID++
	msg := &Message{
		ID:        fmt.Sprintf("msg-%d", mb.msgID),
		Topic:     topic,
		Payload:   payload,
		Timestamp: time.Now(),
	}

	// 메시지 저장 (At-Least-Once)
	mb.messages[topic] = append(mb.messages[topic], msg)

	fmt.Printf("[Broker] ✓ 메시지 발행: %s (Topic: %s)\n", msg.ID, topic)

	// 모든 구독자에게 전송
	if consumers, exists := mb.topics[topic]; exists {
		for _, ch := range consumers {
			select {
			case ch <- msg:
			default:
				fmt.Printf("[Broker] ⚠️ Consumer 채널 가득참: %s\n", topic)
			}
		}
	}

	return nil
}

// Subscribe: 메시지 구독
func (mb *SimpleMessageBroker) Subscribe(topic string) <-chan *Message {
	mb.mu.Lock()
	defer mb.mu.Unlock()

	ch := make(chan *Message, 10)
	mb.topics[topic] = append(mb.topics[topic], ch)

	fmt.Printf("[Broker] ✓ 구독자 등록: Topic=%s\n", topic)
	return ch
}

// Acknowledge: 메시지 처리 완료
func (mb *SimpleMessageBroker) Acknowledge(msg *Message) error {
	fmt.Printf("[Broker] ✓ ACK 수신: %s\n", msg.ID)
	return nil
}

