// 섹션 7️⃣: Dead Letter Queue (DLQ) - 실패한 메시지 처리
// ============================================================================

// DLQ 타입
type DeadLetterQueue struct {
	failedMessages []*Message
	mu             sync.RWMutex
}

// NewDLQ 생성
func NewDLQ() *DeadLetterQueue {
	return &DeadLetterQueue{
		failedMessages: make([]*Message, 0),
	}
}

// Put: 실패한 메시지 저장
func (dlq *DeadLetterQueue) Put(msg *Message, reason string) {
	dlq.mu.Lock()
	defer dlq.mu.Unlock()

	fmt.Printf("[DLQ] ⚠️ 실패한 메시지 저장: %s (이유: %s)\n", msg.ID, reason)
	dlq.failedMessages = append(dlq.failedMessages, msg)
}

// GetAll: 모든 실패 메시지 조회
func (dlq *DeadLetterQueue) GetAll() []*Message {
	dlq.mu.RLock()
	defer dlq.mu.RUnlock()

	result := make([]*Message, len(dlq.failedMessages))
	copy(result, dlq.failedMessages)
	return result
}

// DLQDemo: Dead Letter Queue 시연
func DLQDemo() {
	fmt.Println("\n[Dead Letter Queue] 실패한 메시지 처리")

	dlq := NewDLQ()
	maxRetries := 3

	// 메시지 처리 시뮬레이션
	messages := []*Message{
		{ID: "msg-1", Topic: "orders", Payload: Order{ID: "order-1"}},
		{ID: "msg-2", Topic: "orders", Payload: "invalid-data"}, // 처리 실패
		{ID: "msg-3", Topic: "orders", Payload: Order{ID: "order-3"}},
	}

	fmt.Println("\n[처리] 메시지들을 순차 처리")

	for _, msg := range messages {
		msg.RetryCount = 0

		for msg.RetryCount < maxRetries {
			_, ok := msg.Payload.(Order)

			if !ok && msg.RetryCount == 0 {
				msg.RetryCount++
				fmt.Printf("[처리] ⚠️ 오류 발생: %s (재시도 %d/%d)\n", msg.ID, msg.RetryCount, maxRetries)
				continue
			}

			if !ok && msg.RetryCount >= maxRetries {
				dlq.Put(msg, "Invalid data format")
				break
			}

			fmt.Printf("[처리] ✓ 성공: %s\n", msg.ID)
			break
		}
	}

	// DLQ 모니터링
	fmt.Println("\n[모니터링] DLQ에 저장된 메시지들")
	failed := dlq.GetAll()
	fmt.Printf("총 %d개의 실패한 메시지\n", len(failed))

	for _, msg := range failed {
		fmt.Printf("  - ID: %s, Topic: %s\n", msg.ID, msg.Topic)
	}
}

