// Event 타입
type Event struct {
	ID        string
	Type      string      // "WithdrawRequested", "DepositReceived", ...
	UserID    string
	Amount    float64
	Timestamp time.Time
}

// EventStore: 모든 이벤트 기록
type EventStore struct {
	events []*Event
	mu     sync.RWMutex
}

// NewEventStore 생성
func NewEventStore() *EventStore {
	return &EventStore{
		events: make([]*Event, 0),
	}
}

// Append: 이벤트 추가
func (es *EventStore) Append(event *Event) {
	es.mu.Lock()
	defer es.mu.Unlock()

	es.events = append(es.events, event)
	fmt.Printf("[Event Sourcing] 📝 이벤트 기록: %s (%s)\n", event.Type, event.ID)
}

// GetHistory: 이벤트 히스토리 조회
func (es *EventStore) GetHistory(userID string) []*Event {
	es.mu.RLock()
	defer es.mu.RUnlock()

	var result []*Event
	for _, e := range es.events {
		if e.UserID == userID {
			result = append(result, e)
		}
	}
	return result
}

// ComputeBalance: 현재 잔액 계산 (이벤트 재생)
func (es *EventStore) ComputeBalance(userID string) float64 {
	es.mu.RLock()
	defer es.mu.RUnlock()

	balance := 1000.0 // 초기값

	for _, e := range es.events {
		if e.UserID == userID {
			switch e.Type {
			case "Withdraw":
				balance -= e.Amount
			case "Deposit":
				balance += e.Amount
			}
		}
	}

	return balance
}

// EventSourcingDemo: Event Sourcing 시연
func EventSourcingDemo() {
	fmt.Println("\n[Event Sourcing] 모든 상태 변화를 이벤트로 기록")

	store := NewEventStore()

	// 사건 1: 출금
	store.Append(&Event{
		ID:        "evt-1",
		Type:      "Withdraw",
		UserID:    "user-1",
		Amount:    100,
		Timestamp: time.Now(),
	})

	// 사건 2: 입금
	store.Append(&Event{
		ID:        "evt-2",
		Type:      "Deposit",
		UserID:    "user-1",
		Amount:    500,
		Timestamp: time.Now(),
	})

	// 사건 3: 출금
	store.Append(&Event{
		ID:        "evt-3",
		Type:      "Withdraw",
		UserID:    "user-1",
		Amount:    200,
		Timestamp: time.Now(),
	})

	// 현재 잔액 계산
	balance := store.ComputeBalance("user-1")
	fmt.Printf("\n[Event Sourcing] 💰 현재 잔액: $%.2f\n", balance)
	fmt.Printf("   계산식: $1000 - $100 + $500 - $200 = $%.2f\n", balance)

	// 감시 추적 (Audit Trail)
	fmt.Println("\n[Event Sourcing] 📊 감시 추적 (Audit Trail)")
	history := store.GetHistory("user-1")
	for i, event := range history {
		fmt.Printf("  %d. %s: $%.2f\n", i+1, event.Type, event.Amount)
	}
}

