// 섹션 4️⃣: Idempotency - 중복 메시지 안전 처리
// ============================================================================

// ProcessedPayments: 처리된 결제 기록 (Idempotency 키)
var ProcessedPayments = make(map[string]bool)
var paymentMutex sync.Mutex

// PaymentWithIdempotency: Idempotent 결제 처리
func PaymentWithIdempotency(paymentID string, amount float64) error {
	paymentMutex.Lock()
	defer paymentMutex.Unlock()

	// 이미 처리했는지 확인
	if ProcessedPayments[paymentID] {
		fmt.Printf("[Idempotency] ✓ 이미 처리된 결제: %s (재시도 무시)\n", paymentID)
		return nil
	}

	// 결제 처리
	fmt.Printf("[Idempotency] 💳 결제 처리: %s ($%.2f)\n", paymentID, amount)
	time.Sleep(100 * time.Millisecond)

	// 상태 기록
	ProcessedPayments[paymentID] = true

	return nil
}

// IdempotencyDemo: 중복 처리 시나리오
func IdempotencyDemo() {
	fmt.Println("\n[Idempotency] 중복 메시지 처리 시연")

	// 시나리오: 결제 요청이 2번 들어옴 (Network Retry)
	paymentID := "payment-123"

	fmt.Println("\n시도 1: 첫 번째 결제 요청")
	PaymentWithIdempotency(paymentID, 99.99)

	fmt.Println("\nNetwork 재시도로 인한 중복 요청...")
	PaymentWithIdempotency(paymentID, 99.99)

	fmt.Println("\n또 다른 중복 요청...")
	PaymentWithIdempotency(paymentID, 99.99)

	fmt.Println("\n✓ 결과: $99.99만 1회 청구됨 (중복 없음)")
}

