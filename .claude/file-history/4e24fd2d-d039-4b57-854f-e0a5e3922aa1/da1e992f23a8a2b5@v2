// 간단한 산술 함수들
func add(a, b int) int {
	return a + b
}

func multiply(a, b int) int {
	return a * b
}

func subtract(a, b int) int {
	return a - b
}

func fastSum(s []int) int {
	_ = s[3]  // Bounds Check Elimination: 미리 범위 체크
	return s[0] + s[1] + s[2] + s[3]
}

