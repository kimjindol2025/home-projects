// 섹션 5️⃣: SSA와 컴파일러 최적화
// ============================================================================

func sampleSSA(x int) int {
	a := 5 + 3    // 상수 폴딩: 8
	b := a * 2    // 상수 폴딩: 16
	c := b + x    // 변수 포함: 16 + x
	d := c + 0    // 죽은 코드: c + 0 = c
	return d
}

