func generateAndAnalyzeAssembly() {
	fmt.Println("\n【 추가: 실제 어셈블리 분석 】")

	// 임시 파일 생성
	tempCode := `package main

func add(a, b int) int {
    return a + b
}

func multiply(a, b int) int {
    return a * b
}

func main() {}
`

	filename := "/tmp/test_asm.go"
	if err := os.WriteFile(filename, []byte(tempCode), 0644); err != nil {
		fmt.Printf("파일 생성 실패: %v\n", err)
		return
	}

	fmt.Printf("\n생성된 임시 파일: %s\n", filename)

	// go tool compile 실행
	cmd := exec.Command("go", "tool", "compile", "-S", filename)
	output, err := cmd.CombinedOutput()
	if err != nil {
		fmt.Printf("어셈블리 생성 실패: %v\n", err)
		return
	}

	// 관련 부분만 추출
	lines := strings.Split(string(output), "\n")
	inFunction := false
	count := 0

	fmt.Println("\n📊 생성된 어셈블리 (add 함수):")
	fmt.Println("───────────────────────────────────")

	for _, line := range lines {
		if strings.Contains(line, "main.add") || inFunction {
			inFunction = true
			if line == "" {
				inFunction = false
				continue
			}
			if count < 10 {
				fmt.Println(line)
				count++
			}
			if count >= 10 {
				break
			}
		}
	}

	fmt.Println("───────────────────────────────────")

	// 파일 정리
	os.Remove(filename)
}

