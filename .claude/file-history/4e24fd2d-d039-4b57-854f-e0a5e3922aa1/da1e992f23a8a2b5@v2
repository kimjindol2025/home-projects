// ❌ Bounds Check가 있는 코드
func sumUnsafe(s []int) int {
	return s[0] + s[1] + s[2] + s[3]
}

// ✅ Bounds Check Elimination 적용
func sumOptimized(s []int) int {
	_ = s[3]  // 미리 범위 체크 (패닉 가능 확인)
	return s[0] + s[1] + s[2] + s[3]
}

