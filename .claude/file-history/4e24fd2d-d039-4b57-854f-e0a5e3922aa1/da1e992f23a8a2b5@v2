// ✅ 인라이닝 가능: 매우 작음
func min(a, b int) int {
	if a < b {
		return a
	}
	return b
}

// ✅ 인라이닝 가능: 한 줄
func max(a, b int) int {
	if a > b {
		return a
	}
	return b
}

// ❌ 인라이닝 불가: 함수가 큼
func complexLogic(x int) int {
	result := 0
	for i := 0; i < 100; i++ {
		result += i * x
	}
	return result
}

