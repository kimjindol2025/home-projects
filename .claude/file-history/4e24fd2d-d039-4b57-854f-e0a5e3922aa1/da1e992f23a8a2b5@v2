	fmt.Println("\n🎯 Bounds Check Elimination (BCE)")
	fmt.Println("   배열 범위 검사를 최소화하는 최적화")

	fmt.Println("\n🔴 문제: 범위 검사 오버헤드")
	fmt.Println("   각 배열 접근마다 범위 검사 수행")
	fmt.Println("   s[0] + s[1] + s[2] + s[3]")
	fmt.Println("   → 4개의 범위 검사 + 4개의 덧셈 = 성능 저하!")

	fmt.Println("\n🟢 해결: Bounds Check Elimination")
	fmt.Println("   미리 상한을 체크하면 이후 체크 생략")
	fmt.Println("   _ = s[3]  // 미리 범위 체크")
	fmt.Println("   → 1개의 범위 검사 + 4개의 덧셈 = 4배 빠름!")

	fmt.Println("\n📊 성능 개선")
	fmt.Println("   범위 검사 없음: 4 사이클")
	fmt.Println("   범위 검사 있음: 20+ 사이클 (5배 느림)")
	fmt.Println("   BCE 적용:      8 사이클 (2배 빠름)")

	arr := []int{10, 20, 30, 40, 50}
	fmt.Printf("\n💡 실행 결과:")
	fmt.Printf("\n   범위 검사 있음: sumUnsafe = %d\n", sumUnsafe(arr))
	fmt.Printf("   범위 검사 없음: sumOptimized = %d\n", sumOptimized(arr))

	fmt.Println("\n🔍 BCE 분석 명령어")
	fmt.Println("   $ go build -gcflags=\"-m -m\" your_file.go 2>&1 | grep \"bounds\"")

	fmt.Println()
}

