## 8️⃣ 실전 예제: E-Commerce 주문 처리 시스템

### 📋 아키텍처

```
Customer가 주문 생성
    ↓
Order Service (order-created 발행)
    ├─→ Payment Service (결제 처리)
    ├─→ Inventory Service (재고 감소)
    ├─→ Email Service (확인 이메일)
    ├─→ Notification Service (알림)
    └─→ Analytics Service (분석)

각 서비스는 독립적으로 작동
→ 1개 실패해도 다른 서비스는 계속 작동
```

### 🔧 코드 예제

```go
// 1. Order 생성 (Publisher)
type Order struct {
    ID       string
    UserID   string
    Items    []OrderItem
    Total    float64
    Status   string
}

func CreateOrder(broker MessageBroker, userID string, items []OrderItem) (string, error) {
    order := Order{
        ID:     generateID(),
        UserID: userID,
        Items:  items,
        Total:  calculateTotal(items),
        Status: "PENDING",
    }

    // 메시지 발행
    event := map[string]interface{}{
        "type":  "OrderCreated",
        "order": order,
        "time":  time.Now(),
    }

    err := broker.Publish("order-events", event)
    return order.ID, err
}

// 2. Payment Service (Subscriber)
func PaymentServiceListener(broker MessageBroker) {
    events := broker.Subscribe("order-events")

    for event := range events {
        if event.Type == "OrderCreated" {
            order := event.Order

            // 결제 처리 (Idempotent)
            err := processPayment(order.ID, order.Total)
            if err == nil {
                broker.Publish("payment-events", map[string]interface{}{
                    "type":     "PaymentProcessed",
                    "order_id": order.ID,
                    "status":   "SUCCESS",
                })
            } else {
                broker.Publish("payment-events", map[string]interface{}{
                    "type":     "PaymentFailed",
                    "order_id": order.ID,
                    "error":    err.Error(),
                })
            }
        }
    }
}

// 3. Inventory Service (Subscriber)
func InventoryServiceListener(broker MessageBroker) {
    events := broker.Subscribe("order-events")

    for event := range events {
        if event.Type == "OrderCreated" {
            order := event.Order

            // 재고 감소 (트랜잭션 기반)
            err := updateInventory(order.Items)
            if err == nil {
                broker.Publish("inventory-events", map[string]interface{}{
                    "type":     "InventoryUpdated",
                    "order_id": order.ID,
                })
            }
        }
    }
}

// 4. Email Service (Subscriber)
func EmailServiceListener(broker MessageBroker) {
    events := broker.Subscribe("order-events")

    for event := range events {
        if event.Type == "OrderCreated" {
            order := event.Order

            // 이메일 발송 (실패해도 주문은 계속 진행)
            sendConfirmationEmail(order.UserID, order.ID)
        }
    }
}
```

