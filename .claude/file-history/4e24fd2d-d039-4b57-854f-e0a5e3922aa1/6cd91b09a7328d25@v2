## 3️⃣ 빈 인터페이스 (interface{} 와 any)

### 📋 모든 타입을 수용하는 만능 상자

```go
// 빈 인터페이스: 메서드가 없으므로 모든 타입이 구현함
var emptyInterface interface{}

emptyInterface = 42
emptyInterface = "Hello"
emptyInterface = 3.14
emptyInterface = []int{1, 2, 3}
emptyInterface = struct{ Name string }{Name: "Alice"}

fmt.Println(emptyInterface)  // 마지막 값

// Go 1.18+ : any는 interface{}의 별칭
var anything any = "anything goes!"
fmt.Println(anything)

// 함수에서 사용
func PrintAnything(value any) {
    fmt.Println(value)
}

PrintAnything(42)
PrintAnything("text")
PrintAnything([]int{1, 2, 3})
```

---

### 📋 타입 어설션 (Type Assertion)

```go
// 빈 인터페이스에 담긴 데이터의 실제 타입 확인
var i any = "Hello"

// 1. 단순 타입 어설션 (panic 가능)
s := i.(string)  // i가 string이면 s에 할당
fmt.Println(s)    // Hello

// 2. 안전한 타입 어설션 (comma ok idiom)
str, ok := i.(string)
if ok {
    fmt.Println("String:", str)
}

num, ok := i.(int)
if !ok {
    fmt.Println("Not an int")  // 이 경로 실행
}

// 3. 타입 스위치
value := any(42)

switch v := value.(type) {
case int:
    fmt.Println("Integer:", v)
case string:
    fmt.Println("String:", v)
case float64:
    fmt.Println("Float:", v)
default:
    fmt.Println("Unknown type")
}
```

