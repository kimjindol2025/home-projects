## 5️⃣ 실무 패턴

### 📋 결제 시스템 설계

```go
// 인터페이스 정의
type Payer interface {
    Pay(amount float64) error
    Refund(amount float64) error
}

// 구체적 구현: 신용카드
type CreditCard struct {
    CardNumber string
    Balance    float64
}

func (cc *CreditCard) Pay(amount float64) error {
    if amount > cc.Balance {
        return fmt.Errorf("insufficient balance")
    }
    cc.Balance -= amount
    return nil
}

func (cc *CreditCard) Refund(amount float64) error {
    cc.Balance += amount
    return nil
}

// 구체적 구현: PayPal
type PayPal struct {
    Email   string
    Balance float64
}

func (pp *PayPal) Pay(amount float64) error {
    if amount > pp.Balance {
        return fmt.Errorf("insufficient balance")
    }
    pp.Balance -= amount
    return nil
}

func (pp *PayPal) Refund(amount float64) error {
    pp.Balance += amount
    return nil
}

// 결제 처리 (Payer 인터페이스만 사용)
func ProcessPayment(payer Payer, amount float64) error {
    return payer.Pay(amount)
}

// 사용
card := &CreditCard{CardNumber: "1234", Balance: 1000}
paypal := &PayPal{Email: "user@example.com", Balance: 500}

ProcessPayment(card, 100)    // OK
ProcessPayment(paypal, 50)   // OK
```

