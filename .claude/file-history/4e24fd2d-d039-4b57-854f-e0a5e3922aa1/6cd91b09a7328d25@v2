## 4️⃣ 인터페이스 분리 원칙 (Interface Segregation Principle)

### 📝 작은 인터페이스의 위력

```go
// ❌ 큰 인터페이스 (나쁜 예)
type Animal interface {
    Eat()
    Sleep()
    Run()
    Swim()
    Fly()
    Climb()
}

// ✅ 작은 인터페이스들 (좋은 예)
type Eater interface {
    Eat()
}

type Sleeper interface {
    Sleep()
}

type Runner interface {
    Run()
}

type Swimmer interface {
    Swim()
}

// 큰 인터페이스를 정의하려면 작은 것들의 조합으로
type Animal interface {
    Eater
    Sleeper
    Runner
}

// Dog는 일부 메서드만 구현하면 됨
type Dog struct{}

func (d Dog) Eat() { fmt.Println("Dog eats") }
func (d Dog) Sleep() { fmt.Println("Dog sleeps") }
func (d Dog) Run() { fmt.Println("Dog runs") }
// Dog는 Animal 인터페이스 구현
```

