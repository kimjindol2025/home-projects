// ============================================================

// APIServer: 상태를 가진 서버 구조체
type APIServer struct {
	Name        string
	Version     string
	StartTime   time.Time
	RequestCount int
}

// ServeHTTP: http.Handler 인터페이스 구현 (Duck Typing)
func (s *APIServer) ServeHTTP(w http.ResponseWriter, r *http.Request) {
	s.RequestCount++

	switch r.URL.Path {
	case "/info":
		s.handleInfo(w, r)
	case "/status":
		s.handleStatus(w, r)
	default:
		http.NotFound(w, r)
	}
}

func (s *APIServer) handleInfo(w http.ResponseWriter, r *http.Request) {
	info := fmt.Sprintf(
		"Server: %s\nVersion: %s\nUptime: %v\nRequests: %d\n",
		s.Name,
		s.Version,
		time.Since(s.StartTime).String(),
		s.RequestCount,
	)
	fmt.Fprint(w, info)
}

func (s *APIServer) handleStatus(w http.ResponseWriter, r *http.Request) {
	status := fmt.Sprintf("Status: OK (Total Requests: %d)\n", s.RequestCount)
	fmt.Fprint(w, status)
}

