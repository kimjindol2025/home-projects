func helloHandler(w http.ResponseWriter, r *http.Request) {
	// URL 쿼리 파라미터 추출
	name := r.URL.Query().Get("name")

	// 기본값 설정
	if name == "" {
		name = "World"
	}

	// 응답 작성
	greeting := fmt.Sprintf("Hello %s!\n", name)
	fmt.Fprint(w, greeting)
}

