// Product: 상품 정보 구조체
type Product struct {
	ID    int     `json:"id"`
	Name  string  `json:"name"`
	Price float64 `json:"price"`
	Stock int     `json:"stock"`
}

// APIResponse: API 응답 구조체
type APIResponse struct {
	Success bool        `json:"success"`
	Data    interface{} `json:"data"`
	Message string      `json:"message"`
	Error   string      `json:"error,omitempty"`
}

// 샘플 제품 데이터
var products = map[int]Product{
	1: {ID: 1, Name: "Gopher Plush", Price: 29.99, Stock: 50},
	2: {ID: 2, Name: "Go Mug", Price: 14.99, Stock: 100},
	3: {ID: 3, Name: "Go T-Shirt", Price: 24.99, Stock: 30},
}

func productHandler(w http.ResponseWriter, r *http.Request) {
	// Content-Type 설정
	w.Header().Set("Content-Type", "application/json")

	// 쿼리 파라미터에서 ID 추출
	idStr := r.URL.Query().Get("id")

	if idStr == "" {
		// ID가 없으면 모든 제품 반환
		response := APIResponse{
			Success: true,
			Data:    products,
			Message: "All products retrieved",
		}
		json.NewEncoder(w).Encode(response)
		return
	}

	// ID를 정수로 변환
	var id int
	_, err := fmt.Sscanf(idStr, "%d", &id)
	if err != nil {
		response := APIResponse{
			Success: false,
			Message: "Invalid ID format",
			Error:   err.Error(),
		}
		w.WriteHeader(http.StatusBadRequest)
		json.NewEncoder(w).Encode(response)
		return
	}

	// ID로 제품 검색
	product, exists := products[id]
	if !exists {
		response := APIResponse{
			Success: false,
			Message: "Product not found",
			Error:   fmt.Sprintf("Product ID %d does not exist", id),
		}
		w.WriteHeader(http.StatusNotFound)
		json.NewEncoder(w).Encode(response)
		return
	}

	// 제품 반환
	response := APIResponse{
		Success: true,
		Data:    product,
		Message: fmt.Sprintf("Product ID %d retrieved", id),
	}
	w.WriteHeader(http.StatusOK)
	json.NewEncoder(w).Encode(response)
}

func section4_jsonAPI() {
	fmt.Println("\n[섹션 4] JSON API (Assignment 2)")
	fmt.Println("================================================")

	http.HandleFunc("/api/product", productHandler)

	fmt.Println("✓ 엔드포인트: /api/product")
	fmt.Println("✓ 예시: /api/product?id=1 → JSON 응답")
	fmt.Println("✓ 예시: /api/product → 모든 제품 반환")
	fmt.Println("✓ 구조체 태그: json:\"field\" 사용")
}

