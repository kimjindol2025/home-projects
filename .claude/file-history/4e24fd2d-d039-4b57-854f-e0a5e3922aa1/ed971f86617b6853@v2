// 섹션 6: HTTP 메서드 구분
// ============================================================

func methodHandler(w http.ResponseWriter, r *http.Request) {
	w.Header().Set("Content-Type", "application/json")

	var message string
	var statusCode int

	switch r.Method {
	case http.MethodGet:
		message = "GET 요청: 데이터 조회"
		statusCode = http.StatusOK

	case http.MethodPost:
		message = "POST 요청: 데이터 생성"
		statusCode = http.StatusCreated

	case http.MethodPut:
		message = "PUT 요청: 데이터 수정"
		statusCode = http.StatusOK

	case http.MethodDelete:
		message = "DELETE 요청: 데이터 삭제"
		statusCode = http.StatusOK

	default:
		message = "지원하지 않는 메서드"
		statusCode = http.StatusMethodNotAllowed
	}

	response := APIResponse{
		Success: statusCode < 400,
		Message: message,
	}

	w.WriteHeader(statusCode)
	json.NewEncoder(w).Encode(response)
}

func section6_httpMethods() {
	fmt.Println("\n[섹션 6] HTTP 메서드 구분")
	fmt.Println("================================================")

	http.HandleFunc("/api/resource", methodHandler)

	fmt.Println("✓ GET /api/resource → 조회")
	fmt.Println("✓ POST /api/resource → 생성")
	fmt.Println("✓ PUT /api/resource → 수정")
	fmt.Println("✓ DELETE /api/resource → 삭제")
}

// ============================================================
// 섹션 7: 에러 처리
// ============================================================

func errorHandler(w http.ResponseWriter, r *http.Request) {
	w.Header().Set("Content-Type", "application/json")

	status := r.URL.Query().Get("status")

	switch status {
	case "404":
		w.WriteHeader(http.StatusNotFound)
		response := APIResponse{
			Success: false,
			Message: "Not Found",
			Error:   "Requested resource does not exist",
		}
		json.NewEncoder(w).Encode(response)

	case "400":
		w.WriteHeader(http.StatusBadRequest)
		response := APIResponse{
			Success: false,
			Message: "Bad Request",
			Error:   "Invalid request parameters",
		}
		json.NewEncoder(w).Encode(response)

	case "500":
		w.WriteHeader(http.StatusInternalServerError)
		response := APIResponse{
			Success: false,
			Message: "Internal Server Error",
			Error:   "An unexpected error occurred",
		}
		json.NewEncoder(w).Encode(response)

	default:
		w.WriteHeader(http.StatusOK)
		response := APIResponse{
			Success: true,
			Message: "OK",
		}
		json.NewEncoder(w).Encode(response)
	}
}

func section7_errorHandling() {
	fmt.Println("\n[섹션 7] 에러 처리")
	fmt.Println("================================================")

	http.HandleFunc("/api/error", errorHandler)

	fmt.Println("✓ /api/error?status=404 → Not Found (404)")
	fmt.Println("✓ /api/error?status=400 → Bad Request (400)")
	fmt.Println("✓ /api/error?status=500 → Server Error (500)")
	fmt.Println("✓ /api/error → OK (200)")
}

