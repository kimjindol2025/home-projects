	fmt.Println("\n[섹션 3] 동적 경로 처리 (Assignment 1)")
	fmt.Println("================================================")

	http.HandleFunc("/hello", helloHandler)

	fmt.Println("✓ 엔드포인트: /hello?name=<이름>")
	fmt.Println("✓ 예시: /hello?name=Gopher → 'Hello Gopher!'")
	fmt.Println("✓ 기본값: /hello → 'Hello World!'")
}

