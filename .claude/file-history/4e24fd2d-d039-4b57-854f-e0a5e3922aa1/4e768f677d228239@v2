### 📊 GC 통계 수집

```go
import (
    "fmt"
    "runtime"
)

func printGCStats() {
    var m runtime.MemStats
    runtime.ReadMemStats(&m)

    fmt.Printf("Alloc: %v MB\n", m.Alloc/1024/1024)        // 현재 할당된 메모리
    fmt.Printf("TotalAlloc: %v MB\n", m.TotalAlloc/1024/1024) // 총 할당된 메모리
    fmt.Printf("Sys: %v MB\n", m.Sys/1024/1024)            // 시스템이 할당한 메모리
    fmt.Printf("NumGC: %v\n", m.NumGC)                      // GC 실행 횟수
    fmt.Printf("PauseNs: %v ms\n", m.PauseNs[(m.NumGC+255)%256]/1e6) // 마지막 STW 시간
}
```

