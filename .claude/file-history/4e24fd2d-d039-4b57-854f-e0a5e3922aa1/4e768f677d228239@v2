### 📝 과제 1: Escape 분석 리포트

```bash
# 당신의 코드에서 어떤 변수가 Heap으로 Escape하는가?

# Step 1: 코드 작성
cat > test_escape.go << 'EOF'
package main

func escapeCase1() *int {
    x := 10
    return &x
}

func escapeCase2(name string) interface{} {
    return name
}

func escapeCase3(x int) int {
    return x + 10
}

func main() {}
EOF

# Step 2: 분석 실행
go build -gcflags="-m -m" test_escape.go

# Step 3: 결과 해석
# test_escape.go:3:6: can inline escapeCase1
# test_escape.go:4:5: x escapes to heap  ← Escape 발생!
#
# test_escape.go:8:6: can inline escapeCase2
# test_escape.go:9:9: name escapes to heap ← interface{} 때문에 Escape
#
# test_escape.go:13:6: can inline escapeCase3
# test_escape.go:14:9: x does not escape ← 탈출 없음 (✓ 좋음)
```

### 📝 과제 2: 포인터 산술 미션

```go
// 미션: 구조체의 두 번째 필드를 직접 접근하여 값 수정

package main

import (
    "fmt"
    "unsafe"
)

type Person struct {
    ID   uint32  // 오프셋 0
    Age  uint8   // 오프셋 4
    Alive bool   // 오프셋 5
}

func pointerArithmeticMission() {
    p := Person{ID: 1, Age: 25, Alive: true}

    fmt.Printf("초기 상태: ID=%d, Age=%d, Alive=%v\n", p.ID, p.Age, p.Alive)

    // 포인터 산술을 사용하여 Age 필드 주소 계산
    personPtr := unsafe.Pointer(&p)
    agePtr := (*uint8)(unsafe.Pointer(uintptr(personPtr) + unsafe.Offsetof(p.Age)))

    // Age를 99로 변경
    *agePtr = 99

    fmt.Printf("수정 후: ID=%d, Age=%d, Alive=%v\n", p.ID, p.Age, p.Alive)

    // Alive 필드도 변경해보기
    alivePtr := (*bool)(unsafe.Pointer(uintptr(personPtr) + unsafe.Offsetof(p.Alive)))
    *alivePtr = false

    fmt.Printf("최종 상태: ID=%d, Age=%d, Alive=%v\n", p.ID, p.Age, p.Alive)
}
```

