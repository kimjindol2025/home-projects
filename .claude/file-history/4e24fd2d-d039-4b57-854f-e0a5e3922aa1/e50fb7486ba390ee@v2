// MultipleStreamsSimulation: HTTP/2 멀티플렉싱 시연
// 1개 TCP 연결 위에 여러 스트림이 동시에 진행
func MultipleStreamsSimulation() {
	fmt.Println("\n[HTTP/2 Multiplexing] 시뮬레이션 시작")
	fmt.Println("1개 TCP 연결 상에서 여러 스트림 동시 진행:")

	var wg sync.WaitGroup

	// 스트림 1: CreateOrder
	wg.Add(1)
	go func() {
		defer wg.Done()
		fmt.Println("  [Stream 1] CreateOrder 시작 (0ms)")
		time.Sleep(800 * time.Millisecond)
		fmt.Println("  [Stream 1] CreateOrder 완료 (800ms) ✓")
	}()

	// 스트림 2: GetPriceStream
	wg.Add(1)
	go func() {
		defer wg.Done()
		fmt.Println("  [Stream 2] GetPriceStream 시작 (50ms)")
		time.Sleep(1000 * time.Millisecond)
		fmt.Println("  [Stream 2] GetPriceStream 완료 (1050ms) ✓")
	}()

	// 스트림 3: UploadFile
	wg.Add(1)
	go func() {
		defer wg.Done()
		fmt.Println("  [Stream 3] UploadFile 시작 (100ms)")
		time.Sleep(600 * time.Millisecond)
		fmt.Println("  [Stream 3] UploadFile 완료 (700ms) ✓")
	}()

	wg.Wait()
	fmt.Println("✓ HTTP/2 멀티플렉싱 완료 (총 1050ms - 순차 처리와 비교하면 2400ms 단축)")
}

