// Order 메시지 (OrderService에서 사용)
type Order struct {
	OrderID    string
	UserID     string
	Items      []string
	TotalPrice float64
	Status     string // PENDING, SHIPPED, DELIVERED
}

// CreateOrderRequest
type CreateOrderRequest struct {
	UserID string
	Items  []string
}

// CreateOrderResponse
type CreateOrderResponse struct {
	OrderID    string
	TotalPrice float64
	Error      string
}

// GetPriceRequest
type GetPriceRequest struct {
	Symbol string // AAPL, GOOGL 등
}

// GetPriceResponse (스트리밍)
type GetPriceResponse struct {
	Price     float64
	Timestamp int64
}

// FileChunk (클라이언트 스트리밍)
type FileChunk struct {
	Filename string
	Data     []byte
}

// FileUploadResponse
type FileUploadResponse struct {
	FileID     string
	TotalBytes int64
}

// ChatMessage (양방향 스트리밍)
type ChatMessage struct {
	UserID    string
	Content   string
	Timestamp int64
}

// ============================================================================
// 섹션 2️⃣: Unary RPC - 일반적인 1:1 요청/응답
// ============================================================================

// OrderService 인터페이스
type OrderService interface {
	CreateOrder(ctx context.Context, req *CreateOrderRequest) (*CreateOrderResponse, error)
}

// OrderServiceServer 구현
type OrderServiceServer struct {
	orders map[string]*Order
	mu     sync.Mutex
}

// NewOrderServiceServer 생성
func NewOrderServiceServer() *OrderServiceServer {
	return &OrderServiceServer{
		orders: make(map[string]*Order),
	}
}

// CreateOrder: Unary RPC 구현
func (s *OrderServiceServer) CreateOrder(ctx context.Context, req *CreateOrderRequest) (*CreateOrderResponse, error) {
	fmt.Println("[Unary] CreateOrder 요청:", req.UserID, req.Items)

	if req.UserID == "" {
		return nil, status.Error(codes.InvalidArgument, "user_id 필수")
	}

	s.mu.Lock()
	defer s.mu.Unlock()

	orderID := fmt.Sprintf("order-%d", time.Now().Unix())
	totalPrice := float64(len(req.Items)) * 29.99

	order := &Order{
		OrderID:    orderID,
		UserID:     req.UserID,
		Items:      req.Items,
		TotalPrice: totalPrice,
		Status:     "PENDING",
	}

	s.orders[orderID] = order

	fmt.Printf("✓ 주문 생성: %s (%.2f원)\n", orderID, totalPrice)

	return &CreateOrderResponse{
		OrderID:    orderID,
		TotalPrice: totalPrice,
	}, nil
}

// ============================================================================
// 섹션 3️⃣: Server Streaming - 서버가 지속적으로 데이터 전송
// ============================================================================

// PriceService 인터페이스
type PriceService interface {
	GetPriceStream(req *GetPriceRequest, stream grpc.ServerStream) error
}

// PriceServiceServer 구현
type PriceServiceServer struct{}

// NewPriceServiceServer 생성
func NewPriceServiceServer() *PriceServiceServer {
	return &PriceServiceServer{}
}

// GetPriceStream: Server Streaming RPC
func (s *PriceServiceServer) GetPriceStream(req *GetPriceRequest, stream grpc.ServerStream) error {
	fmt.Println("[Server Streaming] 가격 실시간 스트림:", req.Symbol)

	symbol := req.Symbol
	for i := 0; i < 5; i++ {
		// 가격 시뮬레이션
		basePrice := 150.0
		randomDelta := (rand.Float64() - 0.5) * 10
		price := basePrice + randomDelta

		response := &GetPriceResponse{
			Price:     price,
			Timestamp: time.Now().Unix(),
		}

		// Send는 실제로는 stream.SendMsg(response)
		fmt.Printf("  → %s: %.2f (타임스탬프: %d)\n", symbol, price, response.Timestamp)

		time.Sleep(500 * time.Millisecond)
	}

	fmt.Println("✓ 가격 스트림 종료")
	return nil
}

// ============================================================================
// 섹션 4️⃣: Client Streaming - 클라이언트가 대량 데이터 전송
// ============================================================================

// FileUploadService 인터페이스
type FileUploadService interface {
	UploadFile(stream grpc.ServerStream) error
}

// FileUploadServiceServer 구현
type FileUploadServiceServer struct{}

// NewFileUploadServiceServer 생성
func NewFileUploadServiceServer() *FileUploadServiceServer {
	return &FileUploadServiceServer{}
}

// UploadFile: Client Streaming RPC (시뮬레이션)
func (s *FileUploadServiceServer) UploadFile(ctx context.Context) (*FileUploadResponse, error) {
	fmt.Println("[Client Streaming] 파일 업로드 시작")

	var totalBytes int64 = 0
	chunkCount := 0

	// 클라이언트가 보내는 64KB 청크 10개 시뮬레이션
	for i := 0; i < 10; i++ {
		chunkSize := int64(64 * 1024) // 64KB
		totalBytes += chunkSize
		chunkCount++

		fmt.Printf("  ↓ 청크 %d: %d bytes (누적: %d MB)\n", i+1, chunkSize, totalBytes/(1024*1024))
		time.Sleep(100 * time.Millisecond)
	}

	fileID := fmt.Sprintf("file-%d", time.Now().Unix())
	fmt.Printf("✓ 파일 업로드 완료: %s (%d MB)\n", fileID, totalBytes/(1024*1024))

	return &FileUploadResponse{
		FileID:     fileID,
		TotalBytes: totalBytes,
	}, nil
}

// ============================================================================
// 섹션 5️⃣: Bi-directional Streaming - 양방향 실시간 대화
// ============================================================================

// ChatService 인터페이스
type ChatService interface {
	Chat(stream grpc.ServerStream) error
}

// ChatServiceServer 구현
type ChatServiceServer struct {
	clients map[string]chan *ChatMessage
	mu      sync.Mutex
}

// NewChatServiceServer 생성
func NewChatServiceServer() *ChatServiceServer {
	return &ChatServiceServer{
		clients: make(map[string]chan *ChatMessage),
	}
}

// Chat: Bi-directional Streaming RPC (시뮬레이션)
func (s *ChatServiceServer) Chat(ctx context.Context, userID string) error {
	fmt.Printf("[Bi-directional] 채팅 시작: %s\n", userID)

	s.mu.Lock()
	msgChan := make(chan *ChatMessage, 10)
	s.clients[userID] = msgChan
	s.mu.Unlock()

	defer func() {
		s.mu.Lock()
		delete(s.clients, userID)
		s.mu.Unlock()
		close(msgChan)
	}()

	// 송신 고루틴 시뮬레이션
	go func() {
		for i := 0; i < 3; i++ {
			msg := &ChatMessage{
				UserID:    userID,
				Content:   fmt.Sprintf("메시지 %d", i+1),
				Timestamp: time.Now().Unix(),
			}
			s.broadcastMessage(msg)
			time.Sleep(200 * time.Millisecond)
		}
	}()

	// 수신 대기 시뮬레이션
	timeout := time.After(1500 * time.Millisecond)
	for {
		select {
		case msg := <-msgChan:
			fmt.Printf("  ↔ [%s]: %s\n", msg.UserID, msg.Content)
		case <-timeout:
			fmt.Println("✓ 채팅 종료")
			return nil
		}
	}
}

// broadcastMessage: 모든 클라이언트에 메시지 브로드캐스트
func (s *ChatServiceServer) broadcastMessage(msg *ChatMessage) {
	s.mu.Lock()
	defer s.mu.Unlock()

	for _, ch := range s.clients {
		select {
		case ch <- msg:
		default:
			// 채널이 가득 찼으면 스킵
		}
	}
}

// ============================================================================
// 섹션 6️⃣: Interceptor - 미들웨어 패턴 (인증, 로깅)
// ============================================================================

// LoggingInterceptor: 로깅 인터셉터
func LoggingInterceptor(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {
	start := time.Now()

	fmt.Printf("[Interceptor] 요청 시작: %s\n", info.FullMethod)

	resp, err := handler(ctx, req)

	duration := time.Since(start)
	if err != nil {
		fmt.Printf("[Interceptor] 완료 (%v) - 에러: %v\n", duration, err)
	} else {
		fmt.Printf("[Interceptor] 완료 (%v) - OK\n", duration)
	}

	return resp, err
}

// AuthInterceptor: 인증 인터셉터 (토큰 검증)
func AuthInterceptor(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {
	md, ok := metadata.FromIncomingContext(ctx)
	if !ok {
		return nil, status.Error(codes.Unauthenticated, "메타데이터 없음")
	}

	authTokens := md.Get("authorization")
	if len(authTokens) == 0 {
		return nil, status.Error(codes.Unauthenticated, "토큰 없음")
	}

	token := authTokens[0]
	fmt.Printf("[Auth Interceptor] 토큰 검증: %s\n", token)

	if token != "valid-token-123" {
		return nil, status.Error(codes.Unauthenticated, "토큰 유효하지 않음")
	}

	fmt.Println("[Auth Interceptor] ✓ 토큰 검증 성공")
	return handler(ctx, req)
}

