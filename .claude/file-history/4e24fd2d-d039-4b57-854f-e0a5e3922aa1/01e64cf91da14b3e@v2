// ==================== 섹션 1: 변수 선언의 3가지 방식 ====================

func section1VariableDeclarations() {
	fmt.Println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
	fmt.Println("📌 섹션 1: 변수 선언의 3가지 방식")
	fmt.Println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")

	// 방식 1: 표준 선언 (var 키워드)
	fmt.Println("\n[방식 1] 표준 선언 (var 키워드)")
	var age int = 25
	var name string
	var isStudent bool = true

	fmt.Printf("  age (var age int = 25): %v (타입: %T)\n", age, age)
	fmt.Printf("  name (var name string): %q (타입: %T, 제로 값)\n", name, name)
	fmt.Printf("  isStudent (var isStudent bool = true): %v (타입: %T)\n", isStudent, isStudent)

	// 여러 변수 한 번에 선언
	fmt.Println("\n  여러 변수 한 번에 선언:")
	var (
		height   float64 = 180.5
		weight   float64 = 75.0
		graduated bool    = false
	)
	fmt.Printf("    height: %v, weight: %v, graduated: %v\n", height, weight, graduated)

	// 방식 2: 타입 추론
	fmt.Println("\n[방식 2] 타입 추론 (var x = value)")
	var university = "Graduate School of Go"  // string으로 추론
	var score = 98                            // int로 추론
	var gpa = 3.95                            // float64로 추론

	fmt.Printf("  university: %q (타입: %T)\n", university, university)
	fmt.Printf("  score: %v (타입: %T)\n", score, score)
	fmt.Printf("  gpa: %v (타입: %T)\n", gpa, gpa)

	// 방식 3: 단축 선언 (함수 내부에서만 사용 가능)
	fmt.Println("\n[방식 3] 단축 선언 (:= 연산자, 함수 내부만 가능)")
	language := "Go"                           // string
	year := 2009                               // int
	isFunctional := true                       // bool
	version := 1.21                            // float64

	fmt.Printf("  language := \"Go\": %q (타입: %T)\n", language, language)
	fmt.Printf("  year := 2009: %v (타입: %T)\n", year, year)
	fmt.Printf("  isFunctional := true: %v (타입: %T)\n", isFunctional, isFunctional)
	fmt.Printf("  version := 1.21: %v (타입: %T)\n", version, version)

	fmt.Println("\n  💡 팁: 함수 내부에서는 := 사용이 권장 (간결하고 읽기 쉬움)")
	fmt.Println("  💡 팁: 함수 외부는 var 사용 (명시성)")
}

// ==================== 섹션 2: Go의 엄격한 타입 규칙 ====================

func section2StrictTyping() {
	fmt.Println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
	fmt.Println("📌 섹션 2: Go의 엄격한 타입 규칙 (Strict Type System)")
	fmt.Println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")

	fmt.Println("\n⚠️  원칙: Go는 암묵적 형변환을 절대 허용하지 않습니다!")

	// 예제 1: int와 float64 더하기
	fmt.Println("\n[예제 1] int와 float64 더하기")
	var a int = 10
	var b float64 = 20.5

	fmt.Printf("  a (int): %v\n", a)
	fmt.Printf("  b (float64): %v\n", b)

	// 다음은 컴파일 에러 발생:
	// fmt.Println(a + b)  // ❌ error: invalid operation: a + b (mismatched types int and float64)

	fmt.Println("  ❌ a + b (직접 계산) → 컴파일 에러!")
	fmt.Println("  ✅ float64(a) + b (명시적 변환) → 실행 가능")
	fmt.Printf("  결과: %.1f\n", float64(a)+b)

	// 예제 2: 명시적 형변환
	fmt.Println("\n[예제 2] 명시적 형변환 (Type Conversion)")
	var num int32 = 100
	var bigNum int64 = 1000

	fmt.Printf("  num (int32): %v\n", num)
	fmt.Printf("  bigNum (int64): %v\n", bigNum)

	// 명시적 변환 필요
	fmt.Printf("  int64(num) + bigNum = %v\n", int64(num)+bigNum)

	// 예제 3: 문자열로 변환
	fmt.Println("\n[예제 3] 숫자를 문자열로 변환")
	var code rune = 65  // ASCII 코드
	var value int = 42

	fmt.Printf("  string(65): %q (ASCII 65번 = 'A')\n", string(code))
	fmt.Printf("  strconv.Itoa(42): %q (정수 → 문자열)\n", strconv.Itoa(value))

	// 예제 4: 안전한 타입 변환
	fmt.Println("\n[예제 4] 안전한 타입 변환 (String → Int)")
	strValue := "123"
	intValue, err := strconv.Atoi(strValue)

	if err != nil {
		fmt.Printf("  변환 실패: %v\n", err)
	} else {
		fmt.Printf("  \"%s\" → %d (타입: %T)\n", strValue, intValue, intValue)
	}

	// 예제 5: 실패하는 경우
	fmt.Println("\n[예제 5] 실패하는 변환")
	invalidStr := "abc"
	_, err2 := strconv.Atoi(invalidStr)

	if err2 != nil {
		fmt.Printf("  \"%s\" → 변환 실패: %v (not a number)\n", invalidStr, err2)
	}

	fmt.Println("\n💡 Go의 철학: \"개발자가 명시적으로 의도를 밝혀라.\"")
	fmt.Println("   → 버그 방지, 성능 최적화, 대규모 시스템에서 안정성 확보")
}

// ==================== 섹션 3: 상수와 iota ====================

func section3ConstantsAndIota() {
	fmt.Println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
	fmt.Println("📌 섹션 3: 상수와 iota (Constants & Enumeration)")
	fmt.Println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")

	// 예제 1: 학년 Enumeration
	fmt.Println("\n[예제 1] 학년 상태 (학교 시스템)")
	fmt.Printf("  Freshman: %d\n", Freshman)
	fmt.Printf("  Sophomore: %d\n", Sophomore)
	fmt.Printf("  Junior: %d\n", Junior)
	fmt.Printf("  Senior: %d\n", Senior)

	// 예제 2: 분산 시스템 노드 상태
	fmt.Println("\n[예제 2] 분산 시스템 노드 상태")
	fmt.Printf("  NodeOffline: %d\n", NodeOffline)
	fmt.Printf("  NodeOnline: %d\n", NodeOnline)
	fmt.Printf("  NodeHealthy: %d\n", NodeHealthy)
	fmt.Printf("  NodeDegraded: %d\n", NodeDegraded)
	fmt.Printf("  NodeFailed: %d\n", NodeFailed)

	// 예제 3: 비트 플래그 (권한 시스템)
	fmt.Println("\n[예제 3] 비트 플래그로 권한 시스템 (2진 표현)")
	fmt.Printf("  Read:    %d (0b%04b)\n", Read, Read)
	fmt.Printf("  Write:   %d (0b%04b)\n", Write, Write)
	fmt.Printf("  Execute: %d (0b%04b)\n", Execute, Execute)
	fmt.Printf("  Delete:  %d (0b%04b)\n", Delete, Delete)

	// 권한 조합 (OR 연산)
	userPermissions := Read | Write  // 읽기 + 쓰기
	fmt.Printf("\n  사용자 권한 (Read|Write): %d (0b%04b)\n", userPermissions, userPermissions)

	// 권한 확인 (AND 연산)
	fmt.Printf("  사용자가 Read 권한 가짐? %v\n", userPermissions&Read != 0)
	fmt.Printf("  사용자가 Delete 권한 가짐? %v\n", userPermissions&Delete != 0)

	// 예제 4: 기본 상수
	fmt.Println("\n[예제 4] 기본 상수 (Constants)")
	fmt.Printf("  PI = %.5f\n", PI)
	fmt.Printf("  사용 예: 반지름 5인 원의 넓이 = %.2f\n", PI*5*5)

	fmt.Println("\n💡 iota의 강점:")
	fmt.Println("   - 값을 자동으로 관리 (오류 방지)")
	fmt.Println("   - 새로운 항목 추가 시 번호 자동 증가")
	fmt.Println("   - 코드 의도가 명확 (상태 관리, 권한 등)")
}

// ==================== 섹션 4: 제로 값 (Zero Values) ====================

func section4ZeroValues() {
	fmt.Println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
	fmt.Println("📌 섹션 4: 제로 값 (Zero Values) - Go의 메모리 안전성")
	fmt.Println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")

	fmt.Println("\n✨ Go의 특징: 모든 변수는 선언 시 자동으로 기본값(제로 값)이 할당됨")

	// 각 타입별 제로 값
	fmt.Println("\n[각 타입의 제로 값]")

	var i int
	fmt.Printf("  int: %d\n", i)

	var f float64
	fmt.Printf("  float64: %f\n", f)

	var b bool
	fmt.Printf("  bool: %v\n", b)

	var s string
	fmt.Printf("  string: %q (빈 문자열)\n", s)

	var sl []int
	fmt.Printf("  []int: %v (슬라이스)\n", sl)

	var m map[string]int
	fmt.Printf("  map: %v (맵)\n", m)

	var p *int
	fmt.Printf("  *int: %v (포인터)\n", p)

	// 구조체 예제
	fmt.Println("\n[구조체의 제로 값]")

	type User struct {
		Name  string
		Age   int
		Email string
	}

	var user User
	fmt.Printf("  user.Name: %q (제로 값)\n", user.Name)
	fmt.Printf("  user.Age: %d (제로 값)\n", user.Age)
	fmt.Printf("  user.Email: %q (제로 값)\n", user.Email)

	// 안전성 예제
	fmt.Println("\n[메모리 안전성]")
	type Score struct {
		Math    int
		English int
		Science int
	}

	var scores Score  // 자동으로 모든 필드가 0
	fmt.Printf("  초기화 없이도: Math=%d, English=%d, Science=%d\n",
		scores.Math, scores.English, scores.Science)

	fmt.Println("\n💡 제로 값의 중요성:")
	fmt.Println("   1. 메모리 안전성: 초기화 불필요")
	fmt.Println("   2. 버그 방지: 예측 불가능한 값 없음")
	fmt.Println("   3. 대규모 시스템: 신뢰할 수 있는 기본 상태")
}

// ==================== 섹션 5: 기본 타입 시스템 ====================

func section5TypeSystem() {
	fmt.Println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
	fmt.Println("📌 섹션 5: Go의 기본 타입 시스템")
	fmt.Println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")

	fmt.Println("\n[정수 타입 (Integer Types)]")
	var i8 int8 = 127
	var i16 int16 = 32767
	var i32 int32 = 2147483647
	var i64 int64 = 9223372036854775807

	fmt.Printf("  int8:  %v (범위: -128 ~ 127)\n", i8)
	fmt.Printf("  int16: %v (범위: -32,768 ~ 32,767)\n", i16)
	fmt.Printf("  int32: %v\n", i32)
	fmt.Printf("  int64: %v\n", i64)

	fmt.Printf("  int:   %v (플랫폼 의존)\n", i64)

	fmt.Println("\n[부호 없는 정수 (Unsigned Integer)]")
	var ui8 uint8 = 255
	var ui16 uint16 = 65535
	var byte_val byte = 200  // byte = uint8

	fmt.Printf("  uint8: %v (범위: 0 ~ 255)\n", ui8)
	fmt.Printf("  uint16: %v (범위: 0 ~ 65,535)\n", ui16)
	fmt.Printf("  byte: %v (uint8의 alias)\n", byte_val)

	fmt.Println("\n[부동소수점 (Float)]")
	var f32 float32 = 3.14
	var f64 float64 = 3.141592653589793

	fmt.Printf("  float32: %v (4바이트)\n", f32)
	fmt.Printf("  float64: %v (8바이트, 기본값)\n", f64)

	fmt.Println("\n[복소수 (Complex)]")
	var c64 complex64 = complex(3, 4)
	var c128 complex128 = complex(5, 12)

	fmt.Printf("  complex64: %v\n", c64)
	fmt.Printf("  complex128: %v\n", c128)
	fmt.Printf("  real(5+12i) = %v, imag(5+12i) = %v\n", real(c128), imag(c128))

	fmt.Println("\n[문자열과 문자]")
	var str string = "Hello, Gopher!"
	var ch rune = 'G'        // int32, Unicode 문자
	var b uint8 = 'A'        // byte

	fmt.Printf("  string: %q\n", str)
	fmt.Printf("  rune 'G': %v (int32, Unicode)\n", ch)
	fmt.Printf("  byte 'A': %v (uint8, ASCII)\n", b)

	fmt.Println("\n[부울]")
	var t bool = true
	var f bool = false

	fmt.Printf("  true: %v\n", t)
	fmt.Printf("  false: %v\n", f)

	fmt.Println("\n💡 타입 선택의 중요성:")
	fmt.Println("   - 정확한 타입 선택 = 메모리 효율 + 성능")
	fmt.Println("   - 대규모 시스템: 수십억 개 데이터 저장 시 차이 극대화")
	fmt.Println("   - 0~100 범위: int8 (1바이트) vs int64 (8바이트) = 8배 메모리 절감")
}
