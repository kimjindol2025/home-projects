package main

import (
	"errors"
	"fmt"
	"os"
)

// v1.1 Lesson 1-9: Error Handling & Panic/Recover (에러 처리)
// 주제: 예외가 아닌 값으로 다루는 에러의 철학
//
// Go의 에러 처리 철학:
// 1. error 인터페이스: 모든 에러의 기반
// 2. 커스텀 에러: 타입별로 의미있는 에러 정의
// 3. 에러 래핑: 컨텍스트를 보존하면서 원인 추적
// 4. panic: 복구 불가능한 상황
// 5. recover: defer 내에서 panic 처리
// 6. defer: 리소스 정리 보장
// 7. 에러 패턴: 실전 에러 처리 기법
// 8. 복합 에러 처리: 다중 에러 타입 처리

// ===== 커스텀 에러 타입 정의 =====

// ValidationError: 입력 검증 실패 에러
type ValidationError struct {
	Field   string
	Message string
}

func (ve ValidationError) Error() string {
	return fmt.Sprintf("validation error in field '%s': %s", ve.Field, ve.Message)
}

// NotFoundError: 리소스를 찾을 수 없는 에러
type NotFoundError struct {
	Resource string
	ID       string
}

func (nfe NotFoundError) Error() string {
	return fmt.Sprintf("%s with ID '%s' not found", nfe.Resource, nfe.ID)
}

// UnauthorizedError: 인증/인가 실패 에러
type UnauthorizedError struct {
	Reason string
}

func (ue UnauthorizedError) Error() string {
	return fmt.Sprintf("unauthorized: %s", ue.Reason)
}

// DatabaseError: 데이터베이스 작업 실패 에러
type DatabaseError struct {
	Operation string
	Details   string
}

func (de DatabaseError) Error() string {
	return fmt.Sprintf("database error during %s: %s", de.Operation, de.Details)
}

// User 구조체: 사용자 데이터
type User struct {
	ID    string
	Name  string
	Email string
}

// 시뮬레이션된 사용자 저장소
var users = map[string]User{
	"u001": {ID: "u001", Name: "Alice", Email: "alice@example.com"},
	"u002": {ID: "u002", Name: "Bob", Email: "bob@example.com"},
}

// ===== 함수들 =====

// section1: 기본 에러 처리 (error 인터페이스)
func section1() {
	fmt.Println("\n[섹션 1] 기본 에러 처리 (error 인터페이스)")
	fmt.Println("============================================================")

	// errors.New()로 간단한 에러 생성
	simpleErr := errors.New("something went wrong")
	fmt.Printf("Simple error: %v\n", simpleErr)
	fmt.Printf("Error type: %T\n", simpleErr)

	// fmt.Errorf()로 포맷팅된 에러 생성
	username := "alice"
	formattedErr := fmt.Errorf("user '%s' not found in system", username)
	fmt.Printf("Formatted error: %v\n", formattedErr)

	// 에러 확인 패턴 (Go의 가장 기본적인 패턴)
	err := validateEmail("invalid-email")
	if err != nil {
		fmt.Printf("Validation failed: %v\n", err)
	} else {
		fmt.Println("Validation passed")
	}

	// 성공 케이스
	err = validateEmail("valid@example.com")
	if err != nil {
		fmt.Printf("Validation failed: %v\n", err)
	} else {
		fmt.Println("Validation passed")
	}
}

// section2: 커스텀 에러 타입
func section2() {
	fmt.Println("\n[섹션 2] 커스텀 에러 타입")
	fmt.Println("============================================================")

	// ValidationError 예시
	err := ValidationError{Field: "email", Message: "invalid format"}
	fmt.Printf("Custom error: %v\n", err)
	fmt.Printf("Error type: %T\n", err)

	// 호출자가 에러를 타입 단언으로 처리
	if ve, ok := err.(ValidationError); ok {
		fmt.Printf("Caught ValidationError - Field: %s, Message: %s\n", ve.Field, ve.Message)
	}

	// NotFoundError 예시
	err = NotFoundError{Resource: "User", ID: "u999"}
	fmt.Printf("NotFoundError: %v\n", err)

	// UnauthorizedError 예시
	err = UnauthorizedError{Reason: "expired token"}
	fmt.Printf("UnauthorizedError: %v\n", err)

	// DatabaseError 예시
	err = DatabaseError{Operation: "insert", Details: "constraint violation"}
	fmt.Printf("DatabaseError: %v\n", err)
}

// section3: 에러 래핑 (fmt.Errorf with %w)
func section3() {
	fmt.Println("\n[섹션 3] 에러 래핑과 컨텍스트")
	fmt.Println("============================================================")

	// 에러를 래핑하면서 컨텍스트 추가
	err := readUserData("u999")
	fmt.Printf("Wrapped error: %v\n", err)

	// 원본 에러 확인 (errors.Is 사용)
	if errors.Is(err, os.ErrNotExist) {
		fmt.Println("Root cause: file not found")
	} else {
		fmt.Println("Other error")
	}

	// 원본 에러 추출 (errors.As 사용)
	var nfe NotFoundError
	if errors.As(err, &nfe) {
		fmt.Printf("Extracted NotFoundError: %v\n", nfe)
	}

	// 성공 케이스
	err = readUserData("u001")
	if err != nil {
		fmt.Printf("Error: %v\n", err)
	} else {
		fmt.Println("User data read successfully")
	}
}

// section4: 타입 어설션으로 에러 처리
func section4() {
	fmt.Println("\n[섹션 4] 타입 어설션으로 에러 처리")
	fmt.Println("============================================================")

	// 여러 종류의 에러 처리
	errors := []error{
		ValidationError{Field: "password", Message: "too weak"},
		NotFoundError{Resource: "Document", ID: "d123"},
		UnauthorizedError{Reason: "invalid credentials"},
		DatabaseError{Operation: "update", Details: "deadlock"},
	}

	for i, err := range errors {
		fmt.Printf("\nError %d: %v\n", i+1, err)

		// 타입 스위치로 각 에러별 처리
		switch e := err.(type) {
		case ValidationError:
			fmt.Printf("  [ACTION] Re-validate field '%s'\n", e.Field)
		case NotFoundError:
			fmt.Printf("  [ACTION] Create new %s\n", e.Resource)
		case UnauthorizedError:
			fmt.Printf("  [ACTION] Refresh authentication token\n")
		case DatabaseError:
			fmt.Printf("  [ACTION] Retry operation '%s'\n", e.Operation)
		default:
			fmt.Printf("  [ACTION] Unknown error, log and escalate\n")
		}
	}
}

// section5: Panic 메커니즘
func section5() {
	fmt.Println("\n[섹션 5] Panic 메커니즘")
	fmt.Println("============================================================")

	// Panic은 일반적으로 사용하면 안 되지만, 교육 목적으로 작은 예시
	fmt.Println("Demonstrating panic scenarios (recovered safely):")

	// 1. 배열 범위 초과 (classic panic)
	func() {
		defer func() {
			if r := recover(); r != nil {
				fmt.Printf("  Caught panic: array index out of range\n")
			}
		}()

		arr := []int{1, 2, 3}
		_ = arr[10] // panic!
	}()

	// 2. nil 포인터 역참조
	func() {
		defer func() {
			if r := recover(); r != nil {
				fmt.Printf("  Caught panic: nil pointer dereference\n")
			}
		}()

		var ptr *User
		_ = ptr.ID // panic!
	}()

	// 3. 명시적 panic
	func() {
		defer func() {
			if r := recover(); r != nil {
				fmt.Printf("  Caught panic: %v\n", r)
			}
		}()

		panic("critical failure: system resource unavailable")
	}()

	fmt.Println("All panics recovered safely!")
}

// section6: Recover 메커니즘
func section6() {
	fmt.Println("\n[섹션 6] Recover로 안전한 작업")
	fmt.Println("============================================================")

	// safeOperation은 recover를 사용하여 안전하게 panic을 처리
	result, err := safeOperation()
	if err != nil {
		fmt.Printf("Operation error (recovered): %v\n", err)
	} else {
		fmt.Printf("Operation successful: %s\n", result)
	}

	// 정상 작업
	result, err = safeOperationNormal()
	if err != nil {
		fmt.Printf("Operation error: %v\n", err)
	} else {
		fmt.Printf("Operation successful: %s\n", result)
	}
}

// section7: Defer로 리소스 정리 보장
func section7() {
	fmt.Println("\n[섹션 7] Defer로 리소스 정리 보장")
	fmt.Println("============================================================")

	// Defer 실행 순서 (LIFO)
	fmt.Println("Demonstrating defer execution order (LIFO):")
	demonstrateDefer()

	// Defer와 에러 처리 조합
	fmt.Println("\nDefer with error handling:")
	err := operationWithDefer()
	if err != nil {
		fmt.Printf("Error: %v\n", err)
	}
}

// section8: 실전 예시 - 파일 처리
func section8() {
	fmt.Println("\n[섹션 8] 실전: 파일 처리와 에러 처리")
	fmt.Println("============================================================")

	// 임시 파일 생성 및 처리
	filePath := "/tmp/test_error_handling.txt"

	// 파일 쓰기
	err := writeFile(filePath, "Hello, Error Handling!")
	if err != nil {
		fmt.Printf("Write failed: %v\n", err)
	} else {
		fmt.Println("File written successfully")
	}

	// 파일 읽기
	content, err := readFile(filePath)
	if err != nil {
		fmt.Printf("Read failed: %v\n", err)
	} else {
		fmt.Printf("File content: %s\n", content)
	}

	// 파일 삭제
	err = deleteFile(filePath)
	if err != nil {
		fmt.Printf("Delete failed: %v\n", err)
	} else {
		fmt.Println("File deleted successfully")
	}

	// 존재하지 않는 파일 읽기 시도
	_, err = readFile("/tmp/nonexistent.txt")
	if err != nil {
		fmt.Printf("Expected error for nonexistent file: %v\n", err)
	}
}

// ===== 헬퍼 함수들 =====

// validateEmail: 이메일 검증 (에러 반환)
func validateEmail(email string) error {
	if email == "" {
		return ValidationError{Field: "email", Message: "cannot be empty"}
	}
	if len(email) < 5 || !containsChar(email, '@') {
		return ValidationError{Field: "email", Message: "invalid format"}
	}
	return nil
}

// containsChar: 문자열에 특정 문자가 포함되었는지 확인
func containsChar(s string, c byte) bool {
	for i := 0; i < len(s); i++ {
		if s[i] == c {
			return true
		}
	}
	return false
}

// readUserData: 사용자 데이터 읽기 (에러 래핑 예시)
func readUserData(userID string) error {
	if _, ok := users[userID]; !ok {
		// 원본 에러: NotFoundError 생성
		err := NotFoundError{Resource: "User", ID: userID}
		// 컨텍스트 추가하면서 에러 래핑
		return fmt.Errorf("failed to load user data: %w", err)
	}
	return nil
}

// safeOperation: panic을 recover로 처리하는 안전한 작업
func safeOperation() (string, error) {
	var err error

	defer func() {
		if r := recover(); r != nil {
			err = fmt.Errorf("operation panicked: %v", r)
		}
	}()

	// 위험한 작업 (panic 발생)
	data := []int{1, 2, 3}
	_ = data[10] // panic!

	return "success", nil
}

// safeOperationNormal: 정상적으로 작동하는 작업
func safeOperationNormal() (string, error) {
	defer func() {
		if r := recover(); r != nil {
			// recover 코드는 있지만 panic이 발생하지 않으므로 실행 안 됨
		}
	}()

	data := []int{1, 2, 3}
	_ = data[0] // 안전함

	return "normal operation complete", nil
}

// demonstrateDefer: defer의 LIFO 실행 순서
func demonstrateDefer() {
	defer fmt.Println("  3. Third defer")
	defer fmt.Println("  2. Second defer")
	defer fmt.Println("  1. First defer")
	fmt.Println("  0. Main function body")
}

// operationWithDefer: defer와 에러 처리 조합
func operationWithDefer() error {
	var err error

	// 가상의 리소스 할당
	resource := "Database Connection"
	fmt.Printf("  Allocated: %s\n", resource)

	// defer로 정리 보장
	defer func() {
		fmt.Printf("  Cleaned up: %s\n", resource)
	}()

	// 작업 중 에러 발생
	if true { // 에러 조건
		err = errors.New("database operation failed")
		return err // defer는 여전히 실행됨!
	}

	return nil
}

// writeFile: 파일 쓰기 (defer 사용)
func writeFile(path, content string) error {
	file, err := os.Create(path)
	if err != nil {
		return fmt.Errorf("creating file '%s': %w", path, err)
	}
	defer file.Close() // 어떻게 종료되든 파일이 닫힘

	_, err = file.WriteString(content)
	if err != nil {
		return fmt.Errorf("writing to file '%s': %w", path, err)
	}

	return nil
}

// readFile: 파일 읽기 (defer 사용)
func readFile(path string) (string, error) {
	file, err := os.Open(path)
	if err != nil {
		return "", fmt.Errorf("opening file '%s': %w", path, err)
	}
	defer file.Close() // 어떻게 종료되든 파일이 닫힘

	// 파일 크기 확인
	stat, err := file.Stat()
	if err != nil {
		return "", fmt.Errorf("stat file '%s': %w", path, err)
	}

	// 파일 읽기
	buffer := make([]byte, stat.Size())
	_, err = file.Read(buffer)
	if err != nil {
		return "", fmt.Errorf("reading file '%s': %w", path, err)
	}

	return string(buffer), nil
}

// deleteFile: 파일 삭제 (에러 처리)
func deleteFile(path string) error {
	if err := os.Remove(path); err != nil {
		return fmt.Errorf("deleting file '%s': %w", path, err)
	}
	return nil
}

