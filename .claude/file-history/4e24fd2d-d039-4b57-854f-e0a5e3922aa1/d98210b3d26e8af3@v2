// 45. Goroutines
func worker(id int) {
	for i := 0; i < 3; i++ {
		fmt.Printf("Worker %d: %d\n", id, i)
		time.Sleep(100 * time.Millisecond)
	}
}

func demo45_goroutines() {
	fmt.Println("\n[45] Goroutines")
	go worker(1)
	go worker(2)
	time.Sleep(500 * time.Millisecond)
}

// 46. Channels
