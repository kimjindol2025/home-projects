// 27. Multiple Returns
func divide(a, b float64) (float64, error) {
	if b == 0 {
		return 0, errors.New("division by zero")
	}
	return a / b, nil
}

func demo27_multipleReturns() {
	fmt.Println("\n[27] Multiple Returns")
	result, err := divide(10, 2)
	if err != nil {
		fmt.Printf("Error: %v\n", err)
	} else {
		fmt.Printf("10 / 2 = %v\n", result)
	}
}

// 28. Named Return Values
func swapNamed(a, b int) (x int, y int) {
	x = b
	y = a
	return  // x, y 자동 반환
}

func demo28_namedReturns() {
	fmt.Println("\n[28] Named Return Values")
	x, y := swapNamed(10, 20)
	fmt.Printf("swapNamed(10, 20): x=%d, y=%d\n", x, y)
}

// 29. Variadic Functions
func sum(nums ...int) int {
	total := 0
	for _, n := range nums {
		total += n
	}
	return total
}

func demo29_variadic() {
	fmt.Println("\n[29] Variadic Functions")
	fmt.Printf("sum(1, 2, 3): %d\n", sum(1, 2, 3))
	fmt.Printf("sum(1, 2, 3, 4, 5): %d\n", sum(1, 2, 3, 4, 5))

	slice := []int{10, 20, 30}
	fmt.Printf("sum(10, 20, 30...): %d\n", sum(slice...))
}

