// 33. Value Receiver
type Counter struct {
	value int
}

func (c Counter) IncrementValue() int {
	c.value++
	return c.value
}

func demo33_valueReceiver() {
	fmt.Println("\n[33] Value Receiver")
	counter := Counter{value: 0}
	fmt.Printf("Before: %d\n", counter.value)
	fmt.Printf("IncrementValue(): %d\n", counter.IncrementValue())
	fmt.Printf("After: %d (unchanged)\n", counter.value)
}

// 34. Pointer Receiver
func (c *Counter) IncrementPointer() int {
	c.value++
	return c.value
}

func demo34_pointerReceiver() {
	fmt.Println("\n[34] Pointer Receiver")
	counter := Counter{value: 0}
	fmt.Printf("Before: %d\n", counter.value)
	fmt.Printf("IncrementPointer(): %d\n", counter.IncrementPointer())
	fmt.Printf("After: %d (changed)\n", counter.value)
}

