// 38. Type Assertion
func demo38_typeAssertion() {
	fmt.Println("\n[38] Type Assertion")
	var anything interface{} = 42

	// 단순 어설션 (실패 시 panic)
	// num := anything.(int)

	// 안전한 어설션 (실패 시 ok=false)
	num, ok := anything.(int)
	if ok {
		fmt.Printf("It's an int: %d\n", num)
	}

