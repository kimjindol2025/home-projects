	} else {
		fmt.Printf("It's not a string\n")
	}
}

// 39. Type Switch
func describe(x interface{}) {
	switch v := x.(type) {
	case int:
		fmt.Printf("Integer: %d\n", v)
	case string:
		fmt.Printf("String: %s\n", v)
	case []int:
		fmt.Printf("Slice: %v\n", v)
	default:
		fmt.Printf("Unknown type\n")
	}
}

func demo39_typeSwitch() {
	fmt.Println("\n[39] Type Switch")
	describe(42)
	describe("hello")
	describe([]int{1, 2, 3})
	describe(3.14)
}

