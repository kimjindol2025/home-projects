// 43. panic
func riskyOperation(safe bool) {
	if !safe {
		panic("unsafe operation!")
	}
	fmt.Println("Operation completed safely")
}

// 44. recover
func demo44_recover() {
	fmt.Println("\n[44] recover")
	defer func() {
		if r := recover(); r != nil {
			fmt.Printf("Recovered from panic: %v\n", r)
		}
	}()

	riskyOperation(false)
	fmt.Println("This won't be printed")
}

