### 🎯 반환값 네이밍 (Named Return Values)

```go
// 반환값에 이름을 붙일 수 있음
func swap(x, y int) (y int, x int) {
    // 이름이 붙으면 자동으로 변수 선언됨
    // y와 x가 이미 선언되어 있음
    return  // naked return (반환값이름만 있으면 됨)
}

// 더 나은 예: 명확한 반환값 이름
func divide(a, b float64) (result float64, err error) {
    if b == 0 {
        err = fmt.Errorf("division by zero")
        return  // result=0, err=error 자동 반환
    }
    result = a / b
    return  // result=계산값, err=nil 자동 반환
}
```

