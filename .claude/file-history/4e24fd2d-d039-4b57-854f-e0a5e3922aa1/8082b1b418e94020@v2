### 📋 Pipeline 패턴

```go
// 함수를 연결하는 패턴
func pipe(value int, funcs ...func(int) int) int {
    for _, f := range funcs {
        value = f(value)
    }
    return value
}

// 사용
result := pipe(5,
    func(x int) int { return x * 2 },     // 5 * 2 = 10
    func(x int) int { return x + 3 },     // 10 + 3 = 13
    func(x int) int { return x * x },     // 13 * 13 = 169
)
fmt.Println(result)  // 169
```

