## 📝 실무 패턴: 에러 핸들링

### 📋 divide 함수의 올바른 사용

```go
// divide 함수
func divide(a, b float64) (float64, error) {
    if b == 0 {
        return 0, fmt.Errorf("cannot divide by zero")
    }
    return a / b, nil
}

// ✅ 올바른 패턴 1: 에러 체크
result, err := divide(10, 2)
if err != nil {
    fmt.Println("Error:", err)
    return
}
fmt.Println("Result:", result)

// ✅ 올바른 패턴 2: 블랭크 식별자 사용
result, _ := divide(10, 2)  // 에러 무시 (의도적)
fmt.Println("Result:", result)

// ✅ 올바른 패턴 3: defer와 함께
func safeCalculate() {
    defer func() {
        if r := recover(); r != nil {
            fmt.Println("Recovered from panic:", r)
        }
    }()

    result, err := divide(10, 0)
    if err != nil {
        panic(err)
    }
    fmt.Println(result)
}
```

