### 📝 클로저의 위험성

```go
// ⚠️ 일반적인 실수
functions := make([]func(), 0)
for i := 0; i < 3; i++ {
    functions = append(functions, func() {
        fmt.Println(i)  // i는 참조!
    })
}

for _, f := range functions {
    f()
}
// 출력: 3 3 3 (모두 같은 i를 참조)

// ✅ 해결: 매개변수로 값 전달
functions = make([]func(), 0)
for i := 0; i < 3; i++ {
    func(num int) {  // 매개변수로 받음
        functions = append(functions, func() {
            fmt.Println(num)  // 값 복사
        })
    }(i)
}

for _, f := range functions {
    f()
}
// 출력: 0 1 2 (올바름)
```

