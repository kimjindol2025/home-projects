## 2️⃣ 다중 반환값 - Go의 가장 강력한 특징

### 📋 Multiple Return Values

```go
// 기본: 두 개의 반환값
func divide(a, b float64) (float64, error) {
    if b == 0 {
        return 0, fmt.Errorf("division by zero not allowed")
    }
    return a / b, nil
}

// 사용 패턴: 에러 체크
result, err := divide(10, 2)
if err != nil {
    log.Fatal(err)  // 에러 처리
}
fmt.Println("Result:", result)

// 세 개 이상의 반환값도 가능
func getPersonInfo() (string, int, error) {
    name := "Alice"
    age := 25
    return name, age, nil
}

name, age, err := getPersonInfo()
if err != nil {
    // 처리
}
```

