// 섹션 7: Assignment 1-4 실습
// ==========================================
func section7() {
	fmt.Println()
	fmt.Println("📌 [7] Assignment 1-4 - 함수형 프로그래밍!")
	fmt.Println("-" * 50)

	// Assignment 1: 에러 핸들링 패턴
	fmt.Println()
	fmt.Println("[Assignment 1] 에러 핸들링 패턴")
	fmt.Println()

	// 테스트 1: 정상 나눗셈
	fmt.Println("Case 1: 10 / 2")
	result, err := divide(10, 2)
	if err != nil {
		fmt.Printf("Error: %v\n", err)
	} else {
		fmt.Printf("Result: %.2f\n", result)
	}

	// 테스트 2: 0으로 나누기
	fmt.Println()
	fmt.Println("Case 2: 10 / 0")
	result, err = divide(10, 0)
	if err != nil {
		fmt.Printf("Error: %v\n", err)
	} else {
		fmt.Printf("Result: %.2f\n", result)
	}

	// Assignment 2: 함수형 프로그래밍
	fmt.Println()
	fmt.Println("[Assignment 2] 함수형 프로그래밍 - Operator 타입")
	fmt.Println()

	// Operator 함수 타입 정의
	type Operator func(int, int) int

	// 연산 함수들 정의
	operators := map[string]Operator{
		"+": func(a, b int) int { return a + b },
		"-": func(a, b int) int { return a - b },
		"*": func(a, b int) int { return a * b },
	}

	a, b := 5, 3

	// calculate 함수를 사용한 계산
	for op, opFunc := range operators {
		result := calculate(a, b, opFunc)
		fmt.Printf("%d %s %d = %d\n", a, op, b, result)
	}

	// 추가: Pipeline 패턴
	fmt.Println()
	fmt.Println("[Bonus] Pipeline 패턴 - 함수 연결")
	value := 5
	result2 := pipe(value,
		func(x int) int { return x * 2 },     // 5 * 2 = 10
		func(x int) int { return x + 3 },     // 10 + 3 = 13
		func(x int) int { return x * x },     // 13 * 13 = 169
	)
	fmt.Printf("pipe(5, *2, +3, ^2) = %d\n", result2)
}

// Pipeline 함수
func pipe(value int, funcs ...func(int) int) int {
	for _, f := range funcs {
		value = f(value)
	}
	return value
}
