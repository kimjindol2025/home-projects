// 섹션 6: 클로저 (Closures)
// ==========================================
func section6() {
	fmt.Println()
	fmt.Println("📌 [6] 클로저 - 외부 변수를 포획하는 함수!")
	fmt.Println("-" * 50)

	// 6-1: 기본 클로저 - 카운터
	fmt.Println()
	fmt.Println("6-1. 기본 클로저 - makeCounter()")
	counter := makeCounter()
	fmt.Printf("counter1: %d, %d, %d\n", counter(), counter(), counter())

	// 6-2: 독립적인 클로저
	fmt.Println()
	fmt.Println("6-2. 독립적인 클로저 - 각각 별도의 상태")
	counter1 := makeCounter()
	counter2 := makeCounter()
	fmt.Printf("counter1: %d\n", counter1())
	fmt.Printf("counter2: %d\n", counter2())
	fmt.Printf("counter1: %d\n", counter1())
	fmt.Printf("counter2: %d\n", counter2())

	// 6-3: 곱셈기 (Multiplier) 클로저
	fmt.Println()
	fmt.Println("6-3. 곱셈기 클로저 - createMultiplier()")
	double := createMultiplier(2)
	triple := createMultiplier(3)
	fmt.Printf("double(5) = %d\n", double(5))
	fmt.Printf("triple(5) = %d\n", triple(5))

	// 6-4: 계산기 클로저
	fmt.Println()
	fmt.Println("6-4. 계산기 클로저 - createBankAccount()")
	account := createBankAccount(1000)
	fmt.Printf("Initial balance: %.2f\n", account(0))     // 조회
	fmt.Printf("After deposit 100: %.2f\n", account(100)) // 입금
	fmt.Printf("After withdraw 50: %.2f\n", account(-50)) // 출금
	fmt.Printf("Current balance: %.2f\n", account(0))     // 조회

	// 6-5: 검증기 클로저
	fmt.Println()
	fmt.Println("6-5. 검증기 클로저 - createValidator()")
	validateUsername := createValidator(3)
	fmt.Printf("validateUsername(\"alice\") = %v\n", validateUsername("alice"))
	fmt.Printf("validateUsername(\"ab\") = %v\n", validateUsername("ab"))
}

// 클로저 함수들
func makeCounter() func() int {
	count := 0
	return func() int {
		count++
		return count
	}
}

func createMultiplier(factor int) func(int) int {
	return func(x int) int {
		return x * factor
	}
}

func createBankAccount(initialBalance float64) func(float64) float64 {
	balance := initialBalance
	return func(amount float64) float64 {
		balance += amount
		return balance
	}
}

func createValidator(minLength int) func(string) bool {
	return func(s string) bool {
		return len(s) >= minLength
	}
}

