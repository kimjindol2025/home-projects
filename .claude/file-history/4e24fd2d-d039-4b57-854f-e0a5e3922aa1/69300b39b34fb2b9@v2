// 섹션 1: 기본 함수 구조
// ==========================================
func section1() {
	fmt.Println()
	fmt.Println("📌 [1] 기본 함수 구조 - 타입을 이름 뒤에!")
	fmt.Println("-" * 50)

	// 1-1: 단순 함수
	fmt.Println()
	fmt.Println("1-1. 단순 함수 - 두 정수의 합")
	result := add(3, 5)
	fmt.Printf("add(3, 5) = %d\n", result)

	// 1-2: 같은 타입은 생략 가능
	fmt.Println()
	fmt.Println("1-2. 타입 생략 - multiply(4, 7)")
	result = multiply(4, 7)
	fmt.Printf("multiply(4, 7) = %d\n", result)

	// 1-3: 매개변수 없는 함수
	fmt.Println()
	fmt.Println("1-3. 매개변수 없는 함수 - greet()")
	message := greet()
	fmt.Println("Message:", message)

	// 1-4: 반환값 없는 함수
	fmt.Println()
	fmt.Println("1-4. 반환값 없는 함수 - printMessage()")
	printMessage("Hello from Go!")
}

// 기본 함수들
func add(a, b int) int {
	return a + b
}

func multiply(a, b int) int {
	return a * b
}

func greet() string {
	return "Hello, Gopher!"
}

func printMessage(msg string) {
	fmt.Println("Message:", msg)
}

// ==========================================
// 섹션 2: 다중 반환값 (Multiple Return Values)
// ==========================================
func section2() {
	fmt.Println()
	fmt.Println("📌 [2] 다중 반환값 - 결과 + 에러!")
	fmt.Println("-" * 50)

	// 2-1: 에러 처리 기본 패턴
	fmt.Println()
	fmt.Println("2-1. 에러 처리 - divide(10, 2)")
	result, err := divide(10, 2)
	if err != nil {
		fmt.Println("Error:", err)
	} else {
		fmt.Printf("10 / 2 = %.2f\n", result)
	}

	// 2-2: 0으로 나누기 (에러 발생)
	fmt.Println()
	fmt.Println("2-2. 에러 처리 - divide(10, 0) - 에러 발생!")
	result, err = divide(10, 0)
	if err != nil {
		fmt.Printf("Error: %v\n", err)
		fmt.Printf("반환값은 안전한 기본값: %.2f\n", result)
	}

	// 2-3: 3개 반환값
	fmt.Println()
	fmt.Println("2-3. 3개 반환값 - getPersonInfo()")
	name, age, err := getPersonInfo()
	if err != nil {
		fmt.Println("Error:", err)
	} else {
		fmt.Printf("%s is %d years old\n", name, age)
	}

	// 2-4: 명명된 반환값 (Named Return Values)
	fmt.Println()
	fmt.Println("2-4. 명명된 반환값 - swap(5, 3)")
	a, b := swap(5, 3)
	fmt.Printf("After swap: a=%d, b=%d\n", a, b)
}

// 다중 반환값 함수들
func divide(a, b float64) (float64, error) {
	if b == 0 {
		return 0, fmt.Errorf("cannot divide by zero")
	}
	return a / b, nil
}

func getPersonInfo() (string, int, error) {
	name := "Alice"
	age := 25
	return name, age, nil
}

// 명명된 반환값
func swap(x, y int) (y int, x int) {
	return y, x // 네이밍이 반환값 순서를 명확히 함
}

// ==========================================
// 섹션 3: 가변 인자 함수 (Variadic Functions)
// ==========================================
func section3() {
	fmt.Println()
	fmt.Println("📌 [3] 가변 인자 함수 - 개수가 정해지지 않음!")
	fmt.Println("-" * 50)

	// 3-1: 기본 가변 인자
	fmt.Println()
	fmt.Println("3-1. 가변 인자 - sumAll(1, 2, 3)")
	result := sumAll(1, 2, 3)
	fmt.Printf("sumAll(1, 2, 3) = %d\n", result)

	// 3-2: 다양한 개수
	fmt.Println()
	fmt.Println("3-2. 다양한 개수 - sumAll(1, 2, 3, 4, 5)")
	result = sumAll(1, 2, 3, 4, 5)
	fmt.Printf("sumAll(1, 2, 3, 4, 5) = %d\n", result)

	// 3-3: 인자 없음
	fmt.Println()
	fmt.Println("3-3. 인자 없음 - sumAll()")
	result = sumAll()
	fmt.Printf("sumAll() = %d\n", result)

	// 3-4: 슬라이스 언팩
	fmt.Println()
	fmt.Println("3-4. 슬라이스 언팩 - sumAll([]int{10, 20, 30}...)")
	nums := []int{10, 20, 30}
	result = sumAll(nums...)
	fmt.Printf("sumAll(nums...) = %d\n", result)

	// 3-5: interface{} 가변 인자
	fmt.Println()
	fmt.Println("3-5. 다양한 타입 - printAll(1, \"hello\", 3.14)")
	printAll(1, "hello", 3.14, true)
}

// 가변 인자 함수들
func sumAll(nums ...int) int {
	total := 0
	for _, num := range nums {
		total += num
	}
	return total
}

func printAll(values ...interface{}) {
	fmt.Print("Values: ")
	for i, v := range values {
		if i > 0 {
			fmt.Print(", ")
		}
		fmt.Printf("%v", v)
	}
	fmt.Println()
}

// ==========================================
// 섹션 4: 일급 함수 (First-class Functions)
// ==========================================
func section4() {
	fmt.Println()
	fmt.Println("📌 [4] 일급 함수 - 함수를 변수처럼 취급!")
	fmt.Println("-" * 50)

	// 함수 타입 정의
	type Operation func(int, int) int

	// 4-1: 함수를 변수에 할당
	fmt.Println()
	fmt.Println("4-1. 함수를 변수에 할당")
	var op Operation
	op = func(a, b int) int {
		return a + b
	}
	fmt.Printf("op(5, 3) = %d (덧셈)\n", op(5, 3))

	// 4-2: 함수를 반환하는 함수
	fmt.Println()
	fmt.Println("4-2. 함수를 반환하는 함수 - getOperation()")
	addOp := getOperation("+")
	subOp := getOperation("-")
	mulOp := getOperation("*")

	fmt.Printf("add: %d\n", addOp(10, 5))
	fmt.Printf("subtract: %d\n", subOp(10, 5))
	fmt.Printf("multiply: %d\n", mulOp(10, 5))

	// 4-3: 함수를 매개변수로 받기 (고차 함수)
	fmt.Println()
	fmt.Println("4-3. 함수를 매개변수로 받기 - calculate()")
	result1 := calculate(5, 3, func(a, b int) int { return a + b })
	result2 := calculate(5, 3, func(a, b int) int { return a - b })
	result3 := calculate(5, 3, func(a, b int) int { return a * b })

	fmt.Printf("calculate(5, 3, add) = %d\n", result1)
	fmt.Printf("calculate(5, 3, subtract) = %d\n", result2)
	fmt.Printf("calculate(5, 3, multiply) = %d\n", result3)

	// 4-4: 함수 배열
	fmt.Println()
	fmt.Println("4-4. 함수 배열 - []Operation")
	ops := []Operation{
		func(a, b int) int { return a + b },
		func(a, b int) int { return a - b },
		func(a, b int) int { return a * b },
	}

	names := []string{"Add", "Sub", "Mul"}
	for i, op := range ops {
		fmt.Printf("%s(10, 5) = %d\n", names[i], op(10, 5))
	}
}

func getOperation(op string) func(int, int) int {
	switch op {
	case "+":
		return func(a, b int) int { return a + b }
	case "-":
		return func(a, b int) int { return a - b }
	case "*":
		return func(a, b int) int { return a * b }
	default:
		return func(a, b int) int { return 0 }
	}
}

func calculate(a, b int, op func(int, int) int) int {
	return op(a, b)
}

// ==========================================
// 섹션 5: 익명 함수 (Anonymous Functions)
// ==========================================
func section5() {
	fmt.Println()
	fmt.Println("📌 [5] 익명 함수 - 이름 없이 정의!")
	fmt.Println("-" * 50)

	// 5-1: 익명 함수 즉시 실행
	fmt.Println()
	fmt.Println("5-1. 익명 함수 즉시 실행")
	func() {
		fmt.Println("Anonymous function executed immediately!")
	}()

	// 5-2: 매개변수가 있는 익명 함수
	fmt.Println()
	fmt.Println("5-2. 매개변수가 있는 익명 함수")
	func(a, b int) {
		fmt.Printf("Anonymous: %d + %d = %d\n", a, b, a+b)
	}(5, 3)

	// 5-3: 반환값이 있는 익명 함수
	fmt.Println()
	fmt.Println("5-3. 반환값이 있는 익명 함수")
	result := func(x, y int) int {
		return x * y
	}(4, 5)
	fmt.Printf("Anonymous function result: %d\n", result)

	// 5-4: 익명 함수를 변수에 할당
	fmt.Println()
	fmt.Println("5-4. 익명 함수를 변수에 할당")
	square := func(x int) int {
		return x * x
	}
	fmt.Printf("square(5) = %d\n", square(5))
	fmt.Printf("square(10) = %d\n", square(10))

	// 5-5: for 루프에서 익명 함수
	fmt.Println()
	fmt.Println("5-5. for 루프에서 익명 함수")
	for i := 0; i < 3; i++ {
		func(num int) {
			fmt.Printf("Iteration %d\n", num)
		}(i)
	}
}

