// ==========================================
// 섹션 1: 맵 (Map) 기초
// ==========================================
func section1() {
	fmt.Println()
	fmt.Println("📌 [1] 맵 (Map) - 키-값 기반의 고속 검색!")
	fmt.Println("-" * 50)

	// 1-1: 맵 선언 및 초기화
	fmt.Println()
	fmt.Println("1-1. 맵 선언 - make 사용 (권장)")
	grades := make(map[string]int)
	grades["Alice"] = 95
	grades["Bob"] = 88
	grades["Carol"] = 92
	fmt.Printf("grades: %v\n", grades)

	// 1-2: 맵 리터럴
	fmt.Println()
	fmt.Println("1-2. 맵 리터럴 - 한 번에 초기화")
	person := map[string]string{
		"name": "Gopher",
		"city": "Seoul",
		"job":  "Engineer",
	}
	fmt.Printf("person: %v\n", person)

	// 1-3: 다양한 타입
	fmt.Println()
	fmt.Println("1-3. 다양한 키-값 타입")
	settings := make(map[string]bool)
	settings["dark_mode"] = true
	settings["notifications"] = false
	fmt.Printf("settings: %v\n", settings)

	// 1-4: 중첩 맵
	fmt.Println()
	fmt.Println("1-4. 중첩 맵 - map[string][]int")
	scores := make(map[string][]int)
	scores["Alice"] = []int{95, 88, 92}
	scores["Bob"] = []int{85, 90, 88}
	fmt.Printf("scores: %v\n", scores)

	// 1-5: Nil 맵의 위험성
	fmt.Println()
	fmt.Println("1-5. Nil 맵 - 읽기는 OK, 쓰기는 panic!")
	var nilMap map[string]int
	fmt.Printf("nilMap[\"key\"]: %d (읽기: 기본값 반환)\n", nilMap["key"])
	// nilMap["key"] = 100  // panic: assignment to entry in nil map
	fmt.Println("(쓰기 시도 주석 처리됨 - panic 발생)")
}

// ==========================================
// 섹션 2: 맵 조작 및 Comma ok Idiom
// ==========================================
func section2() {
	fmt.Println()
	fmt.Println("📌 [2] 맵 조작 - Comma ok Idiom!")
	fmt.Println("-" * 50)

	// 2-1: 기본 조작
	fmt.Println()
	fmt.Println("2-1. 맵 값 읽기 및 쓰기")
	student := make(map[string]string)
	student["name"] = "Alice"
	student["major"] = "CS"
	fmt.Printf("student: %v\n", student)
	fmt.Printf("student[\"name\"]: %s\n", student["name"])

	// 2-2: Comma ok idiom (값 존재 여부 확인)
	fmt.Println()
	fmt.Println("2-2. Comma ok Idiom - 값 존재 여부 확인")
	grades := map[string]int{
		"Alice": 95,
		"Bob":   88,
	}

	// 존재하는 키
	score, ok := grades["Alice"]
	if ok {
		fmt.Printf("Alice: %d (존재함)\n", score)
	}

	// 존재하지 않는 키
	score, ok = grades["Charlie"]
	if !ok {
		fmt.Printf("Charlie: 데이터 없음 (score=%d는 기본값)\n", score)
	}

	// 2-3: 값 삭제
	fmt.Println()
	fmt.Println("2-3. 값 삭제 - delete 함수")
	person := map[string]string{
		"name": "Gopher",
		"city": "Seoul",
		"job":  "Engineer",
	}
	fmt.Printf("Before: %v (len=%d)\n", person, len(person))
	delete(person, "job")
	fmt.Printf("After delete(\"job\"): %v (len=%d)\n", person, len(person))

	// 2-4: 맵 크기
	fmt.Println()
	fmt.Println("2-4. 맵 크기 - len 함수")
	settings := map[string]bool{
		"dark_mode": true,
		"sound": true,
		"vibration": false,
	}
	fmt.Printf("len(settings): %d\n", len(settings))
}

// ==========================================
// 섹션 3: 맵 순회 (순서 무작위화)
// ==========================================
func section3() {
	fmt.Println()
	fmt.Println("📌 [3] 맵 순회 - 순서는 무작위!")
	fmt.Println("-" * 50)

	// 3-1: 키-값 순회
	fmt.Println()
	fmt.Println("3-1. 키-값 순회 - for key, value := range map")
	person := map[string]string{
		"name": "Alice",
		"city": "Seoul",
		"job":  "Engineer",
	}
	fmt.Println("Iteration 1:")
	for key, value := range person {
		fmt.Printf("  %s: %s\n", key, value)
	}

	// 3-2: 순서 무작위화 확인
	fmt.Println()
	fmt.Println("3-2. 순서 무작위화 - 여러 번 순회하면 순서가 다름")
	fmt.Println("Iteration 2 (순서가 다를 수 있음):")
	for key := range person {
		fmt.Printf("  %s\n", key)
	}

	// 3-3: 키만 순회
	fmt.Println()
	fmt.Println("3-3. 키만 순회")
	grades := map[string]int{
		"Alice": 95,
		"Bob": 88,
		"Carol": 92,
	}
	for name := range grades {
		fmt.Printf("  %s\n", name)
	}

	// 3-4: 값만 순회
	fmt.Println()
	fmt.Println("3-4. 값만 순회")
	for _, score := range grades {
		fmt.Printf("  %d\n", score)
	}

	// 3-5: 의도적 무작위화의 이유
	fmt.Println()
	fmt.Println("3-5. 순서 무작위화의 이유")
	fmt.Println("Go는 개발자가 맵 순서에 의존하는 버그를 만들지 않도록")
	fmt.Println("의도적으로 순회 순서를 무작위화합니다.")
}

// ==========================================
// 섹션 4: 구조체 기초
// ==========================================
func section4() {
	fmt.Println()
	fmt.Println("📌 [4] 구조체 (Struct) - 데이터의 집합체!")
	fmt.Println("-" * 50)

	// 4-1: 구조체 선언 및 초기화
	fmt.Println()
	fmt.Println("4-1. 구조체 선언 및 초기화")
	s1 := Student{
		Person: Person{
			Name: "Gopher",
			Age:  20,
		},
		ID:    20260101,
		Major: "Computer Science",
		GPA:   4.5,
	}
	fmt.Printf("Student: %+v\n", s1)

	// 4-2: 필드 접근 및 수정
	fmt.Println()
	fmt.Println("4-2. 필드 접근 및 수정")
	fmt.Printf("Name: %s, Age: %d\n", s1.Name, s1.Age)
	s1.GPA = 4.0
	fmt.Printf("After s1.GPA = 4.0: %f\n", s1.GPA)

	// 4-3: 부분 초기화
	fmt.Println()
	fmt.Println("4-3. 부분 초기화 - 명시된 필드만")
	s2 := Student{
		Person: Person{Name: "Alice"},
		ID:     20260102,
	}
	fmt.Printf("s2: Name=%s, Age=%d (기본값), Major=%s\n", s2.Name, s2.Age, s2.Major)

	// 4-4: 구조체 비교
	fmt.Println()
	fmt.Println("4-4. 구조체 비교 - 모든 필드가 같으면 equal")
	a := Book{ID: 1, Title: "Go", Author: "Google", Year: 2009, ISBN: "001"}
	b := Book{ID: 1, Title: "Go", Author: "Google", Year: 2009, ISBN: "001"}
	c := Book{ID: 2, Title: "Go", Author: "Google", Year: 2009, ISBN: "001"}
	fmt.Printf("a == b: %v (모든 필드 동일)\n", a == b)
	fmt.Printf("a == c: %v (ID 다름)\n", a == c)

	// 4-5: 익명 구조체
	fmt.Println()
	fmt.Println("4-5. 익명 구조체 - 일회성")
	point := struct {
		x, y int
	}{
		x: 10,
		y: 20,
	}
	fmt.Printf("point: {x=%d, y=%d}\n", point.x, point.y)
}

// ==========================================
// 섹션 5: 구조체 임베딩 (Composition)
// ==========================================
func section5() {
	fmt.Println()
	fmt.Println("📌 [5] 구조체 임베딩 - 상속 대신 합성!")
	fmt.Println("-" * 50)

	// 5-1: 임베딩 기본
	fmt.Println()
	fmt.Println("5-1. 임베딩 기본 - Person을 Student에 임베딩")
	s := Student{
		Person: Person{Name: "Gopher", Age: 20},
		ID:     20260101,
		Major:  "CS",
		GPA:    4.5,
	}
	fmt.Printf("s: %+v\n", s)

	// 5-2: 임베딩된 필드 접근
	fmt.Println()
	fmt.Println("5-2. 임베딩된 필드 직접 접근 (타입 승격)")
	fmt.Printf("s.Name: %s (Person.Name과 동일)\n", s.Name)
	fmt.Printf("s.Person.Name: %s (명시적 접근도 가능)\n", s.Person.Name)

	// 5-3: 임베딩된 필드 수정
	fmt.Println()
	fmt.Println("5-3. 임베딩된 필드 수정")
	fmt.Printf("Before: Age = %d\n", s.Age)
	s.Age = 21
	fmt.Printf("After s.Age = 21: %d\n", s.Age)

	// 5-4: 합성의 강력함
	fmt.Println()
	fmt.Println("5-4. 임베딩으로 타입 확장 (상속 없이)")
	fmt.Println("Go는 상속이 없지만, 임베딩으로 기능 확장")
	fmt.Println("이것이 'Composition over Inheritance' 철학")
}

// ==========================================
// 섹션 6: 메모리 정렬 (Memory Alignment)
// ==========================================
func section6() {
	fmt.Println()
	fmt.Println("📌 [6] 메모리 정렬 - 시스템 프로그래밍의 묘미!")
	fmt.Println("-" * 50)

	// 6-1: 패딩의 개념
	fmt.Println()
	fmt.Println("6-1. 패딩 (Padding) - 메모리 정렬을 위한 빈 공간")

	type BadAlignment struct {
		a byte    // 1 바이트
		b int64   // 8 바이트
		c byte    // 1 바이트
	}

	type GoodAlignment struct {
		b int64   // 8 바이트
		a byte    // 1 바이트
		c byte    // 1 바이트
	}

	fmt.Printf("BadAlignment: %d 바이트\n", unsafe.Sizeof(BadAlignment{}))
	fmt.Printf("GoodAlignment: %d 바이트\n", unsafe.Sizeof(GoodAlignment{}))
	fmt.Println("규칙: 큰 타입을 앞에 배치하면 패딩 감소!")

	// 6-2: Person 구조체의 메모리 레이아웃
	fmt.Println()
	fmt.Println("6-2. Person 구조체 메모리 레이아웃")
	p := Person{Name: "Alice", Age: 25}
	fmt.Printf("Person 크기: %d 바이트\n", unsafe.Sizeof(p))
	fmt.Printf("Name 오프셋: %d\n", unsafe.Offsetof(p.Name))
	fmt.Printf("Age 오프셋: %d\n", unsafe.Offsetof(p.Age))

	// 6-3: Book 구조체의 메모리 레이아웃
	fmt.Println()
	fmt.Println("6-3. Book 구조체 메모리 레이아웃 - 메모리 효율 분석")
	book := Book{Title: "Go"}
	fmt.Printf("Book 크기: %d 바이트\n", unsafe.Sizeof(book))
	fmt.Printf("ID 오프셋: %d\n", unsafe.Offsetof(book.ID))
	fmt.Printf("Title 오프셋: %d\n", unsafe.Offsetof(book.Title))
	fmt.Printf("Author 오프셋: %d\n", unsafe.Offsetof(book.Author))
	fmt.Printf("Year 오프셋: %d\n", unsafe.Offsetof(book.Year))
	fmt.Printf("ISBN 오프셋: %d\n", unsafe.Offsetof(book.ISBN))
	fmt.Printf("Available 오프셋: %d\n", unsafe.Offsetof(book.Available))
}

// ==========================================
// 섹션 7: 실무 패턴 - 도서관 관리 시스템
// ==========================================
func section7() {
	fmt.Println()
	fmt.Println("📌 [7] 실무 패턴 - 도서관 관리 시스템!")
	fmt.Println("-" * 50)

	// 7-1: Library 생성
	fmt.Println()
	fmt.Println("7-1. 도서관 생성 및 책 추가")
	lib := Library{
		Name:  "Seoul Public Library",
		Books: make([]Book, 0),
		Index: make(map[string]*Book),
	}

	// 책 추가
	book1 := Book{
		ID: 1, Title: "The Go Programming Language",
		Author: "Donovan & Kernighan", Year: 2015,
		ISBN: "978-0134190440", Available: true,
	}
	book2 := Book{
		ID: 2, Title: "Go in Action",
		Author: "Kennedy et al.", Year: 2015,
		ISBN: "978-1617291784", Available: true,
	}

	lib.Books = append(lib.Books, book1, book2)
	lib.Index[book1.ISBN] = &lib.Books[0]
	lib.Index[book2.ISBN] = &lib.Books[1]

	fmt.Printf("도서관: %s\n", lib.Name)
	fmt.Printf("보유 도서: %d권\n", len(lib.Books))

	// 7-2: ISBN으로 책 검색
	fmt.Println()
	fmt.Println("7-2. ISBN으로 책 검색")
	found := lib.Index[book1.ISBN]
	if found != nil {
		fmt.Printf("찾음: %s (저자: %s)\n", found.Title, found.Author)
	}

	// 7-3: 모든 책 출력
	fmt.Println()
	fmt.Println("7-3. 도서관의 모든 책")
	for _, book := range lib.Books {
		status := "대여 가능"
		if !book.Available {
			status = "대여 불가"
		}
		fmt.Printf("- %s (%s) [%s]\n", book.Title, book.Author, status)
	}
}

// ==========================================
// 섹션 8: Assignment 1-6 실습
// ==========================================
func section8() {
	fmt.Println()
	fmt.Println("📌 [8] Assignment 1-6 - 설계 과제!")
	fmt.Println("-" * 50)

	// Assignment 1: 맵 순회 및 순서 무작위화
	fmt.Println()
	fmt.Println("[Assignment 1] 맵 순회 순서 분석")
	grades := map[string]int{
		"Alice": 95,
		"Bob":   88,
		"Carol": 92,
		"Diana": 85,
	}

	fmt.Println()
	fmt.Println("같은 맵을 여러 번 순회 - 순서를 관찰하세요")
	fmt.Println()

	// 첫 번째 순회
	fmt.Println("1차 순회:")
	order1 := make([]string, 0)
	for key := range grades {
		fmt.Printf("  %s\n", key)
		order1 = append(order1, key)
	}

	fmt.Println()
	fmt.Println("2차 순회 (순서가 다를 수 있음):")
	order2 := make([]string, 0)
	for key := range grades {
		fmt.Printf("  %s\n", key)
		order2 = append(order2, key)
	}

	fmt.Println()
	fmt.Println("분석:")
	fmt.Println("- 맵의 순회 순서는 매번 다를 수 있음 (무작위)")
	fmt.Println("- 이는 Go의 의도적 설계: 개발자의 순서 의존 버그 방지")

	// Assignment 2: 도서관 관리 시스템 설계
	fmt.Println()
	fmt.Println("[Assignment 2] 도서관 관리 시스템 설계")
	fmt.Println()

	// Library 생성
	myLib := Library{
		Name:  "My Personal Library",
		Books: make([]Book, 0),
		Index: make(map[string]*Book),
	}

	// 책 추가
	books := []Book{
		{
			ID: 1, Title: "Clean Code",
			Author: "Robert C. Martin", Year: 2008,
			ISBN: "0132350882", Available: true,
		},
		{
			ID: 2, Title: "Design Patterns",
			Author: "Gang of Four", Year: 1994,
			ISBN: "0201633612", Available: true,
		},
	}

	for _, b := range books {
		myLib.Books = append(myLib.Books, b)
		myLib.Index[b.ISBN] = &myLib.Books[len(myLib.Books)-1]
	}

	// 도서관 정보 출력
	fmt.Printf("도서관 이름: %s\n", myLib.Name)
	fmt.Printf("총 도서 수: %d권\n", len(myLib.Books))

	fmt.Println()
	fmt.Println("도서 목록:")
	for _, book := range myLib.Books {
		fmt.Printf("- [%s] %s (저자: %s, %d)\n",
			book.ISBN, book.Title, book.Author, book.Year)
	}

	// 특정 ISBN으로 검색
	fmt.Println()
	fmt.Println("ISBN 검색 테스트:")
	searchISBN := "0132350882"
	if found, ok := myLib.Index[searchISBN]; ok {
		fmt.Printf("찾음: %s by %s\n", found.Title, found.Author)
	} else {
		fmt.Printf("찾지 못함: %s\n", searchISBN)
	}
}
