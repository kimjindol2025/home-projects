// 섹션 6: 포인터 리시버의 필요성 (비교)
// ==========================================
func section6() {
	fmt.Println()
	fmt.Println("📌 [6] 포인터 리시버의 필요성!")
	fmt.Println("-" * 50)

	// 6-1: 값 리시버로 수정 시도
	fmt.Println()
	fmt.Println("6-1. 값 리시버로 수정 - 실패")
	a := Account{Name: "Bob", Balance: 500}
	fmt.Printf("Before DepositValue(100): %s = %.2f\n", a.Name, a.Balance)
	a.DepositValue(100)  // 값 리시버 (복사본만 수정)
	fmt.Printf("After DepositValue(100): %s = %.2f (변화 없음!)\n", a.Name, a.Balance)

	// 6-2: 포인터 리시버로 수정
	fmt.Println()
	fmt.Println("6-2. 포인터 리시버로 수정 - 성공")
	b := Account{Name: "Carol", Balance: 500}
	fmt.Printf("Before Deposit(100): %s = %.2f\n", b.Name, b.Balance)
	b.Deposit(100)  // 포인터 리시버 (원본 수정)
	fmt.Printf("After Deposit(100): %s = %.2f (변함!)\n", b.Name, b.Balance)

	// 6-3: 메모리 비교
	fmt.Println()
	fmt.Println("6-3. 메모리 영향 - 왜 포인터 리시버를 사용할까?")
	fmt.Println("값 리시버: 구조체 전체 복사 → 메모리 낭비")
	fmt.Println("포인터 리시버: 포인터만 전달 → 효율적")
}

// 값 리시버로 수정 시도 (실패)
func (a Account) DepositValue(amount float64) {
	a.Balance += amount  // 복사본만 수정
}

// ==========================================
// 섹션 7: 메서드 체이닝
// ==========================================
func section7() {
	fmt.Println()
	fmt.Println("📌 [7] 메서드 체이닝!")
	fmt.Println("-" * 50)

	// 7-1: Builder 패턴
	fmt.Println()
	fmt.Println("7-1. Builder 패턴 - 메서드 체이닝")
	result := (&AccountBuilder{}).
		SetName("Alice").
		SetBalance(1000).
		Deposit(500).
		Build()
	fmt.Printf("결과: %s\n", result)

	// 7-2: 복잡한 체이닝
	fmt.Println()
	fmt.Println("7-2. 복잡한 체이닝")
	result2 := (&AccountBuilder{}).
		SetName("Bob").
		SetBalance(2000).
		Deposit(500).
		Withdraw(300).
		Deposit(200).
		Build()
	fmt.Printf("결과: %s\n", result2)
}

// Builder 패턴용 구조체
type AccountBuilder struct {
	Name    string
	Balance float64
}

func (ab *AccountBuilder) SetName(name string) *AccountBuilder {
	ab.Name = name
	return ab
}

func (ab *AccountBuilder) SetBalance(balance float64) *AccountBuilder {
	ab.Balance = balance
	return ab
}

func (ab *AccountBuilder) Deposit(amount float64) *AccountBuilder {
	ab.Balance += amount
	return ab
}

func (ab *AccountBuilder) Withdraw(amount float64) *AccountBuilder {
	if amount <= ab.Balance {
		ab.Balance -= amount
	}
	return ab
}

func (ab *AccountBuilder) Build() string {
	return fmt.Sprintf("%s (Balance: %.2f)", ab.Name, ab.Balance)
}

