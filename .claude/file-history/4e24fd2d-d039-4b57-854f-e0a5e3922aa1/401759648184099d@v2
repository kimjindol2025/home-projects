// 섹션 8: Assignment 1-7 실습
// ==========================================
func section8() {
	fmt.Println()
	fmt.Println("📌 [8] Assignment 1-7 - 메모리 구조 추적!")
	fmt.Println("-" * 50)

	// Assignment 1: 값 전달의 한계
	fmt.Println()
	fmt.Println("[Assignment 1] 값 전달의 한계 - Swap 함수")
	fmt.Println()

	fmt.Println("1. 값 전달 (실패):")
	x1, y1 := 10, 20
	fmt.Printf("  Before: x = %d, y = %d\n", x1, y1)
	swapValues(x1, y1)  // 함수 내에서 출력됨
	fmt.Printf("  After: x = %d, y = %d (변화 없음)\n", x1, y1)

	fmt.Println()
	fmt.Println("2. 포인터 전달 (성공):")
	x2, y2 := 10, 20
	fmt.Printf("  Before: x = %d, y = %d\n", x2, y2)
	swapPointers(&x2, &y2)
	fmt.Printf("  After: x = %d, y = %d (변함!)\n", x2, y2)

	fmt.Println()
	fmt.Println("설명:")
	fmt.Println("- 값 전달: 함수에 복사본을 전달 → 원본 영향 없음")
	fmt.Println("- 포인터 전달: 함수에 주소를 전달 → 원본 수정 가능")

	// Assignment 2: 메서드 설계
	fmt.Println()
	fmt.Println("[Assignment 2] 계좌 관리 시스템 - 메서드 설계")
	fmt.Println()

	account := Account{Name: "Charlie", Balance: 1000}
	fmt.Printf("계좌 초기화: %s, 잔액 = %.2f\n\n", account.Name, account.Balance)

	// 입금
	fmt.Println("1. 입금 (Deposit) - 포인터 리시버")
	fmt.Printf("  Before: %.2f\n", account.Balance)
	account.Deposit(500)
	fmt.Printf("  After Deposit(500): %.2f\n", account.Balance)

	// 출금
	fmt.Println()
	fmt.Println("2. 출금 (Withdraw) - 포인터 리시버")
	fmt.Printf("  Before: %.2f\n", account.Balance)
	ok := account.Withdraw(300)
	fmt.Printf("  After Withdraw(300): %.2f (success: %v)\n", account.Balance, ok)

	// 출금 실패
	fmt.Println()
	fmt.Println("3. 출금 실패 - 잔액 부족")
	fmt.Printf("  Before: %.2f\n", account.Balance)
	ok = account.Withdraw(3000)
	fmt.Printf("  After Withdraw(3000): %.2f (success: %v - 실패)\n", account.Balance, ok)

	// 조회
	fmt.Println()
	fmt.Println("4. 조회 (GetBalance) - 값 리시버")
	fmt.Printf("  GetBalance(): %.2f\n", account.GetBalance())

	fmt.Println()
	fmt.Println("핵심:")
	fmt.Println("- Deposit/Withdraw는 포인터 리시버: 잔액 수정 필요")
	fmt.Println("- GetBalance는 값 리시버: 읽기만 필요")
	fmt.Println("- 포인터 리시버만 사용: 일관성 (Go의 관례)")
}
