// 섹션 4: 메서드 기초
// ==========================================
func section4() {
	fmt.Println()
	fmt.Println("📌 [4] 메서드 (Methods) 기초!")
	fmt.Println("-" * 50)

	// 4-1: 메서드 선언 및 호출
	fmt.Println()
	fmt.Println("4-1. 메서드 선언 - (r Rectangle) 리시버")
	rect := Rectangle{width: 5, height: 3}
	fmt.Printf("Rectangle: width = %f, height = %f\n", rect.width, rect.height)
	fmt.Printf("rect.Area() = %f\n", rect.Area())

	// 4-2: 여러 메서드
	fmt.Println()
	fmt.Println("4-2. 여러 메서드")
	fmt.Printf("rect.Perimeter() = %f\n", rect.Perimeter())
	fmt.Printf("rect.String() = %s\n", rect.String())

	// 4-3: 메서드 vs 함수
	fmt.Println()
	fmt.Println("4-3. 메서드 vs 함수 비교")
	// 함수로 호출할 수도 있음 (다른 방식)
	area := Rectangle.Area(rect)
	fmt.Printf("Rectangle.Area(rect) = %f\n", area)
}

// Rectangle 메서드들 (값 리시버)
func (r Rectangle) Area() float64 {
	return r.width * r.height
}

func (r Rectangle) Perimeter() float64 {
	return 2 * (r.width + r.height)
}

func (r Rectangle) String() string {
	return fmt.Sprintf("Rectangle{width=%f, height=%f}", r.width, r.height)
}

// ==========================================
// 섹션 5: 값 리시버 vs 포인터 리시버
// ==========================================
func section5() {
	fmt.Println()
	fmt.Println("📌 [5] 값 리시버 vs 포인터 리시버!")
	fmt.Println("-" * 50)

	// 5-1: 값 리시버 (읽기 전용)
	fmt.Println()
	fmt.Println("5-1. 값 리시버 - 읽기 전용 (복사본)")
	acc := Account{Name: "Alice", Balance: 1000}
	fmt.Printf("Account: %s, Balance: %.2f\n", acc.Name, acc.Balance)
	fmt.Printf("acc.GetBalance() = %.2f\n", acc.GetBalance())

	// 5-2: 포인터 리시버 (수정 가능)
	fmt.Println()
	fmt.Println("5-2. 포인터 리시버 - 수정 가능 (원본)")
	fmt.Printf("Before Deposit(500): Balance = %.2f\n", acc.Balance)
	acc.Deposit(500)  // 포인터 리시버
	fmt.Printf("After Deposit(500): Balance = %.2f\n", acc.Balance)

	// 5-3: 출금
	fmt.Println()
	fmt.Println("5-3. 출금 - 포인터 리시버")
	ok := acc.Withdraw(200)
	fmt.Printf("Withdraw(200): success = %v, Balance = %.2f\n", ok, acc.Balance)

	// 5-4: 출금 실패
	fmt.Println()
	fmt.Println("5-4. 출금 실패 - 잔액 부족")
	ok = acc.Withdraw(2000)
	fmt.Printf("Withdraw(2000): success = %v, Balance = %.2f\n", ok, acc.Balance)
}

// Account 메서드들
func (a Account) GetBalance() float64 {
	return a.Balance  // 값 리시버 (읽기)
}

func (a *Account) Deposit(amount float64) {
	a.Balance += amount  // 포인터 리시버 (수정)
}

func (a *Account) Withdraw(amount float64) bool {
	if amount > a.Balance {
		return false
	}
	a.Balance -= amount
	return true
}

