// ==========================================
// 섹션 1: 포인터 기초
// ==========================================
func section1() {
	fmt.Println()
	fmt.Println("📌 [1] 포인터 (Pointer) 기초!")
	fmt.Println("-" * 50)

	// 1-1: 포인터 선언 및 초기화
	fmt.Println()
	fmt.Println("1-1. 포인터 선언 및 초기화")
	var a int = 10
	var p *int = &a  // p는 a의 주소를 가짐

	fmt.Printf("a의 값: %d\n", a)
	fmt.Printf("p의 값 (주소): %p\n", p)
	fmt.Printf("p가 가리키는 값: %d\n", *p)

	// 1-2: 포인터의 타입
	fmt.Println()
	fmt.Println("1-2. 포인터의 타입")
	fmt.Printf("a의 타입: %T\n", a)      // int
	fmt.Printf("p의 타입: %T\n", p)      // *int
	fmt.Printf("&a의 타입: %T\n", &a)    // *int

	// 1-3: 여러 포인터
	fmt.Println()
	fmt.Println("1-3. 같은 변수를 가리키는 여러 포인터")
	var q *int = &a  // q도 a를 가리킴
	fmt.Printf("p과 q가 같은 주소를 가리키는가? %v\n", p == q)

	// 1-4: Nil 포인터
	fmt.Println()
	fmt.Println("1-4. Nil 포인터")
	var nilPtr *int
	fmt.Printf("nilPtr == nil: %v\n", nilPtr == nil)
	// fmt.Println(*nilPtr)  // panic: nil pointer dereference
	fmt.Println("(역참조 시도 주석 처리됨 - panic 발생)")
}

// ==========================================
// 섹션 2: & 와 * 연산자
// ==========================================
func section2() {
	fmt.Println()
	fmt.Println("📌 [2] & 와 * 연산자!")
	fmt.Println("-" * 50)

	// 2-1: & 연산자 (주소 추출)
	fmt.Println()
	fmt.Println("2-1. & 연산자 - 주소 추출")
	x := 42
	px := &x
	fmt.Printf("x = %d\n", x)
	fmt.Printf("&x = %p\n", &x)
	fmt.Printf("px = %p\n", px)
	fmt.Printf("&x == px: %v\n", &x == px)

	// 2-2: * 연산자 (역참조)
	fmt.Println()
	fmt.Println("2-2. * 연산자 - 역참조 (주소의 값 접근)")
	fmt.Printf("*px = %d\n", *px)
	fmt.Printf("x = %d\n", x)
	fmt.Printf("*px == x: %v\n", *px == x)

	// 2-3: 포인터를 통한 값 수정
	fmt.Println()
	fmt.Println("2-3. 포인터를 통한 값 수정")
	fmt.Printf("Before: x = %d\n", x)
	*px = 100
	fmt.Printf("After *px = 100: x = %d\n", x)
	fmt.Printf("원본도 변함! (같은 메모리 참조)\n")

	// 2-4: 포인터의 포인터
	fmt.Println()
	fmt.Println("2-4. 포인터의 포인터")
	ppx := &px  // px의 주소
	fmt.Printf("ppx의 타입: %T\n", ppx)
	fmt.Printf("**ppx = %d\n", **ppx)

	// 2-5: 포인터 연산은 불가능
	fmt.Println()
	fmt.Println("2-5. 포인터 연산 금지 (Go의 안전성)")
	// px++  // 컴파일 에러! 포인터 연산 불가
	// px += 4  // 컴파일 에러!
	fmt.Println("Go는 포인터 연산을 금지합니다")
	fmt.Println("(메모리 오염 및 버퍼 오버플로우 방지)")
}

// ==========================================
// 섹션 3: 포인터와 함수
// ==========================================
func section3() {
	fmt.Println()
	fmt.Println("📌 [3] 포인터와 함수!")
	fmt.Println("-" * 50)

	// 3-1: 값 전달 (포인터 없음)
	fmt.Println()
	fmt.Println("3-1. 값 전달 - 함수 내 변경은 원본에 영향 없음")
	n1 := 10
	fmt.Printf("Before increment(n1): n1 = %d\n", n1)
	increment(n1)  // 값 복사
	fmt.Printf("After increment(n1): n1 = %d (변화 없음)\n", n1)

	// 3-2: 포인터 전달
	fmt.Println()
	fmt.Println("3-2. 포인터 전달 - 함수 내 변경이 원본에 영향")
	n2 := 10
	fmt.Printf("Before incrementPtr(&n2): n2 = %d\n", n2)
	incrementPtr(&n2)  // 주소 전달
	fmt.Printf("After incrementPtr(&n2): n2 = %d (변함!)\n", n2)

	// 3-3: 두 값 교환 (값 전달 - 실패)
	fmt.Println()
	fmt.Println("3-3. Swap 함수 - 값 전달 (실패)")
	a, b := 5, 10
	fmt.Printf("Before swap(a, b): a = %d, b = %d\n", a, b)
	swapValues(a, b)
	fmt.Printf("After swap(a, b): a = %d, b = %d (변화 없음)\n", a, b)

	// 3-4: 두 값 교환 (포인터 전달 - 성공)
	fmt.Println()
	fmt.Println("3-4. Swap 함수 - 포인터 전달 (성공!)")
	a, b = 5, 10
	fmt.Printf("Before swapPointers(&a, &b): a = %d, b = %d\n", a, b)
	swapPointers(&a, &b)
	fmt.Printf("After swapPointers(&a, &b): a = %d, b = %d (변함!)\n", a, b)

	// 3-5: 포인터 반환
	fmt.Println()
	fmt.Println("3-5. 포인터 반환 (이스케이프 분석)")
	p := createInt(42)
	fmt.Printf("*p = %d\n", *p)
	fmt.Println("(컴파일러가 이 변수를 힙에 할당)")
}

// 값 전달 함수들
func increment(n int) {
	n = n + 1
	fmt.Printf("  (함수 내: n = %d)\n", n)
}

func incrementPtr(p *int) {
	*p = *p + 1
	fmt.Printf("  (함수 내: *p = %d)\n", *p)
}

func swapValues(a, b int) {
	a, b = b, a
	fmt.Printf("  (함수 내: a = %d, b = %d)\n", a, b)
}

func swapPointers(pa, pb *int) {
	*pa, *pb = *pb, *pa
	fmt.Printf("  (함수 내: *pa = %d, *pb = %d)\n", *pa, *pb)
}

func createInt(value int) *int {
	x := value
	return &x  // 이스케이프: x는 힙에 할당됨
}

