	fmt.Println()
	fmt.Println("1-1. 배열 선언 - 고정 크기")
	grades := [3]int{90, 85, 95}
	fmt.Printf("grades: %v\n", grades)
	fmt.Printf("len(grades): %d\n", len(grades))

	// 1-2: 크기 추론
	fmt.Println()
	fmt.Println("1-2. 크기 추론 - [...]int")
	scores := [...]int{10, 20, 30, 40}
	fmt.Printf("scores: %v\n", scores)
	fmt.Printf("len(scores): %d\n", len(scores))

	// 1-3: 인덱스로 초기화
	fmt.Println()
	fmt.Println("1-3. 인덱스로 초기화")
	arr := [5]int{0: 10, 2: 30, 4: 50}
	fmt.Printf("arr: %v\n", arr)

	// 1-4: 배열의 순회
	fmt.Println()
	fmt.Println("1-4. 배열 순회 - Range")
	for i, score := range grades {
		fmt.Printf("[%d] = %d\n", i, score)
	}

	// 1-5: 배열의 문제점 (전체 복사)
	fmt.Println()
	fmt.Println("1-5. 배열의 타입 - [3]int와 [5]int는 다른 타입")
	// var arr1 [3]int
