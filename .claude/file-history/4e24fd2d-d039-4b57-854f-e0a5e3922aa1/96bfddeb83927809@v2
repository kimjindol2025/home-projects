	// arr1 = arr2  // 컴파일 에러! 다른 타입이므로 할당 불가
	fmt.Println("배열의 크기는 타입의 일부!")

	// 1-6: 2차원 배열
	fmt.Println()
	fmt.Println("1-6. 2차원 배열")
	matrix := [2][3]int{
		{1, 2, 3},
		{4, 5, 6},
	}
	fmt.Printf("matrix: %v\n", matrix)
}

// ==========================================
// 섹션 2: 슬라이스 기초 (Slice Basics)
// ==========================================
func section2() {
	fmt.Println()
	fmt.Println("📌 [2] 슬라이스 (Slice) - 동적 크기의 유연성!")
	fmt.Println("-" * 50)

	// 2-1: 슬라이스 리터럴
	fmt.Println()
	fmt.Println("2-1. 슬라이스 리터럴 - 크기 지정 안 함")
	languages := []string{"Go", "Python", "C++"}
	fmt.Printf("languages: %v\n", languages)
	fmt.Printf("len(languages): %d\n", len(languages))
	fmt.Printf("cap(languages): %d\n", cap(languages))

	// 2-2: make로 슬라이스 생성
	fmt.Println()
	fmt.Println("2-2. make - len=5, cap=5")
	slice1 := make([]int, 5)
	fmt.Printf("slice1: %v\n", slice1)
	fmt.Printf("len(slice1): %d, cap(slice1): %d\n", len(slice1), cap(slice1))

	// 2-3: make로 길이와 용량 지정
	fmt.Println()
	fmt.Println("2-3. make - len=5, cap=10")
	slice2 := make([]int, 5, 10)
	fmt.Printf("len(slice2): %d, cap(slice2): %d\n", len(slice2), cap(slice2))

	// 2-4: 빈 슬라이스
	fmt.Println()
	fmt.Println("2-4. 빈 슬라이스 - make([]int, 0)")
	slice3 := make([]int, 0)
	fmt.Printf("len(slice3): %d, cap(slice3): %d\n", len(slice3), cap(slice3))

	// 2-5: 빈 슬라이스 + 용량
	fmt.Println()
	fmt.Println("2-5. 빈 슬라이스 + 용량 - make([]int, 0, 10)")
	slice4 := make([]int, 0, 10)
	fmt.Printf("len(slice4): %d, cap(slice4): %d\n", len(slice4), cap(slice4))

	// 2-6: nil 슬라이스
	fmt.Println()
	fmt.Println("2-6. nil 슬라이스 - 선언만 하고 초기화 안 함")
	var slice5 []int
	fmt.Printf("slice5: %v (nil)\n", slice5)
	fmt.Printf("len(slice5): %d, cap(slice5): %d\n", len(slice5), cap(slice5))
}

// ==========================================
// 섹션 3: 슬라이스의 내부 구조 (Slice Header)
// ==========================================
func section3() {
	fmt.Println()
	fmt.Println("📌 [3] 슬라이스의 내부 구조 - Pointer, Len, Cap!")
	fmt.Println("-" * 50)

	// 3-1: 기본 개념
	fmt.Println()
	fmt.Println("3-1. 슬라이스 헤더 구조")
	fmt.Println("슬라이스 = { Pointer, Length, Capacity }")
	slice := make([]int, 5, 10)
	fmt.Printf("slice: %v\n", slice)
	fmt.Printf("  Pointer: 배열의 시작 주소\n")
	fmt.Printf("  Length (len):  %d (현재 요소 개수)\n", len(slice))
	fmt.Printf("  Capacity (cap): %d (최대 용량)\n", cap(slice))

	// 3-2: 용량의 의미
	fmt.Println()
	fmt.Println("3-2. 용량의 의미")
	nums := make([]int, 3, 8)
	for i := 0; i < len(nums); i++ {
		nums[i] = (i + 1) * 10
	}
	fmt.Printf("nums: %v\n", nums)
	fmt.Printf("len(nums): %d, cap(nums): %d\n", len(nums), cap(nums))

	// 용량 안에서 append
	nums = append(nums, 40, 50, 60, 70, 80)
	fmt.Printf("After append (40,50,60,70,80):\n")
	fmt.Printf("nums: %v\n", nums)
	fmt.Printf("len(nums): %d, cap(nums): %d (용량 내, 재할당 없음)\n", len(nums), cap(nums))

	// 용량 초과
	fmt.Println()
	fmt.Println("3-3. 용량 초과 - 자동 확장")
	nums = append(nums, 90)  // 9번째 요소 (용량 초과!)
	fmt.Printf("After append (90) - 용량 초과:\n")
	fmt.Printf("nums: %v\n", nums)
	fmt.Printf("len(nums): %d, cap(nums): %d (새 배열 할당!)\n", len(nums), cap(nums))
}

// ==========================================
// 섹션 4: 슬라이싱 (Slicing)
// ==========================================
func section4() {
	fmt.Println()
	fmt.Println("📌 [4] 슬라이싱 (Slicing) - 부분 추출!")
	fmt.Println("-" * 50)

	// 4-1: 기본 슬라이싱
	fmt.Println()
	fmt.Println("4-1. 기본 슬라이싱 - nums[low:high]")
	original := []int{10, 20, 30, 40, 50}
	fmt.Printf("original: %v\n", original)

	sub1 := original[1:3]
	fmt.Printf("original[1:3]: %v\n", sub1)

	sub2 := original[:2]
	fmt.Printf("original[:2]: %v\n", sub2)

	sub3 := original[2:]
	fmt.Printf("original[2:]: %v\n", sub3)

	sub4 := original[:]
	fmt.Printf("original[:]: %v\n", sub4)

	// 4-2: 슬라이싱과 용량
	fmt.Println()
	fmt.Println("4-2. 슬라이싱과 용량 - cap(sub)")
	nums := []int{1, 2, 3, 4, 5, 6, 7, 8}
	part := nums[2:5]
	fmt.Printf("nums: %v\n", nums)
	fmt.Printf("part = nums[2:5]: %v\n", part)
	fmt.Printf("len(part): %d, cap(part): %d\n", len(part), cap(part))

	// 4-3: 슬라이싱으로 인한 데이터 공유
	fmt.Println()
	fmt.Println("4-3. 데이터 공유 - 같은 배열 참조!")
	original = []int{1, 2, 3, 4, 5}
	slice := original[1:4]
	fmt.Printf("original: %v\n", original)
	fmt.Printf("slice = original[1:4]: %v\n", slice)

	// 슬라이스 수정
	slice[0] = 999
	fmt.Printf("After slice[0] = 999:\n")
	fmt.Printf("original: %v ← 원본도 변함!\n", original)
	fmt.Printf("slice: %v\n", slice)

	// 4-4: 3-인덱스 슬라이싱 (용량 제한)
	fmt.Println()
	fmt.Println("4-4. 3-인덱스 슬라이싱 - nums[low:high:max]")
	nums = []int{10, 20, 30, 40, 50, 60}
	fmt.Printf("nums: %v\n", nums)

	limitedSlice := nums[1:4:4]
	fmt.Printf("nums[1:4:4]: %v\n", limitedSlice)
	fmt.Printf("len: %d, cap: %d (max-low = 4-1 = 3)\n", len(limitedSlice), cap(limitedSlice))
	fmt.Println("이제 limitedSlice[3]에 접근하면 panic!")
}

// ==========================================
// 섹션 5: 메모리 효율성 (Memory Efficiency)
// ==========================================
func section5() {
	fmt.Println()
	fmt.Println("📌 [5] 메모리 효율성 - Pass by Value!")
	fmt.Println("-" * 50)

	// 5-1: 배열의 비효율성
	fmt.Println()
	fmt.Println("5-1. 배열의 비효율성 - 전체 복사")
	fmt.Println("함수에 배열을 넘기면 배열 전체가 복사됨")
	fmt.Println("예: [1000]int → 8000바이트 복사!")

	smallArr := [3]int{1, 2, 3}
	fmt.Printf("Before: %v\n", smallArr)
	modifyArray(smallArr)  // 배열 전체 복사
	fmt.Printf("After modifyArray: %v (변화 없음)\n", smallArr)

	// 5-2: 슬라이스의 효율성
	fmt.Println()
	fmt.Println("5-2. 슬라이스의 효율성 - 헤더만 복사")
	fmt.Println("함수에 슬라이스를 넘기면 헤더만 복사됨")
	fmt.Println("헤더: 포인터(8) + 길이(8) + 용량(8) = 24바이트")
	fmt.Println("실제 데이터는 공유! (같은 배열 참조)")

	smallSlice := []int{1, 2, 3}
	fmt.Printf("Before: %v\n", smallSlice)
	modifySlice(smallSlice)  // 헤더만 복사
	fmt.Printf("After modifySlice: %v (변함!)\n", smallSlice)

	// 5-3: 슬라이스의 값 타입 특성
	fmt.Println()
	fmt.Println("5-3. 슬라이스는 값 타입 - 재할당은 함수에 영향 없음")
	slice := []int{1, 2, 3}
	fmt.Printf("Before: %v (len=%d)\n", slice, len(slice))
	tryReassign(slice)
	fmt.Printf("After tryReassign: %v (len=%d) - 변화 없음!\n", slice, len(slice))
}

// 배열 수정 (전체 복사되므로 영향 없음)
func modifyArray(arr [3]int) {
	arr[0] = 999
	fmt.Println("  → 함수 내: arr[0] = 999")
}

// 슬라이스 수정 (같은 배열 참조하므로 영향 있음)
func modifySlice(s []int) {
	s[0] = 999
	fmt.Println("  → 함수 내: s[0] = 999")
}

// 슬라이스 재할당 (함수 내 로컬만 변함)
func tryReassign(s []int) {
	s = append(s, 4)
	fmt.Printf("  → 함수 내: append 후 len=%d\n", len(s))
}

// ==========================================
// 섹션 6: 슬라이스 조작 함수
// ==========================================
func section6() {
	fmt.Println()
	fmt.Println("📌 [6] 슬라이스 조작 함수 - Append, Copy!")
	fmt.Println("-" * 50)

	// 6-1: Append
	fmt.Println()
	fmt.Println("6-1. Append - 요소 추가")
	slice := []int{1, 2, 3}
	fmt.Printf("원본: %v (len=%d, cap=%d)\n", slice, len(slice), cap(slice))

	slice = append(slice, 4)
	fmt.Printf("append(4): %v (len=%d, cap=%d)\n", slice, len(slice), cap(slice))

	slice = append(slice, 5, 6, 7)
	fmt.Printf("append(5,6,7): %v (len=%d, cap=%d)\n", slice, len(slice), cap(slice))

	// 6-2: 슬라이스 병합
	fmt.Println()
	fmt.Println("6-2. 슬라이스 병합 - append(s1, s2...)")
	s1 := []int{1, 2}
	s2 := []int{3, 4, 5}
	result := append(s1, s2...)
	fmt.Printf("s1: %v\n", s1)
	fmt.Printf("s2: %v\n", s2)
	fmt.Printf("append(s1, s2...): %v\n", result)

	// 6-3: Copy
	fmt.Println()
	fmt.Println("6-3. Copy - 슬라이스 복사")
	source := []int{10, 20, 30, 40, 50}
	dest := make([]int, 3)
	count := copy(dest, source)
	fmt.Printf("source: %v\n", source)
	fmt.Printf("dest (3개 용량): %v\n", dest)
	fmt.Printf("복사된 개수: %d\n", count)

	// 복사 후 독립적
	dest[0] = 999
	fmt.Printf("After dest[0] = 999:\n")
	fmt.Printf("source: %v (변화 없음)\n", source)
	fmt.Printf("dest: %v\n", dest)

	// 6-4: 부분 복사
	fmt.Println()
	fmt.Println("6-4. 부분 복사")
	source = []int{10, 20, 30, 40, 50}
	dest = make([]int, 5)
	copy(dest, source[1:4])
	fmt.Printf("source: %v\n", source)
	fmt.Printf("copy(dest, source[1:4]): %v\n", dest)
}

// ==========================================
// 섹션 7: Assignment 1-5 실습
// ==========================================
func section7() {
	fmt.Println()
	fmt.Println("📌 [7] Assignment 1-5 - Make와 Capacity!")
	fmt.Println("-" * 50)

	// Assignment 1: Make와 Capacity
	fmt.Println()
	fmt.Println("[Assignment 1] make([]int, 5, 10) 분석")
	slice := make([]int, 5, 10)
	fmt.Printf("초기 상태:\n")
	fmt.Printf("  len(slice) = %d\n", len(slice))
	fmt.Printf("  cap(slice) = %d\n", cap(slice))
	fmt.Printf("  slice = %v\n", slice)

	fmt.Println()
	fmt.Println("용량 내 append - 10개까지 추가 가능 (재할당 없음)")
	for i := 0; i < 5; i++ {
		slice = append(slice, 100+i)
	}
	fmt.Printf("After append(5 items):\n")
	fmt.Printf("  len(slice) = %d\n", len(slice))
	fmt.Printf("  cap(slice) = %d (변화 없음)\n", cap(slice))

	fmt.Println()
	fmt.Println("용량 초과 - 11번째 append")
	fmt.Printf("Before 11th append: len=%d, cap=%d\n", len(slice), cap(slice))
	slice = append(slice, 200)
	fmt.Printf("After 11th append: len=%d, cap=%d (새 배열 할당!)\n", len(slice), cap(slice))
	fmt.Println("Go의 용량 확장 정책: 보통 2배")

	// Assignment 2: 슬라이싱과 용량
	fmt.Println()
	fmt.Println("[Assignment 2] 슬라이싱과 용량 분석")
	nums := []int{1, 2, 3, 4, 5}
	fmt.Printf("nums = %v\n", nums)

	sub := nums[1:3]
	fmt.Printf("sub = nums[1:3] = %v\n", sub)
	fmt.Printf("  len(sub) = %d\n", len(sub))
	fmt.Printf("  cap(sub) = %d (원본의 3~끝 = 4개)\n", cap(sub))

	fmt.Println()
	fmt.Println("sub[3] = 100을 시도")
	sub[3] = 100  // 가능! (cap=4이므로)
	fmt.Printf("After sub[3] = 100:\n")
	fmt.Printf("  sub = %v\n", sub)
	fmt.Printf("  nums = %v ← 원본도 변함! (5번째 요소)\n", nums)

	fmt.Println()
	fmt.Println("이것이 슬라이스의 위험성! 데이터 공유로 인한 예상치 못한 수정")

	// 추가: 안전한 방법 (Copy 사용)
	fmt.Println()
	fmt.Println("[Bonus] 안전한 방법 - Copy로 독립적 복사")
	nums = []int{1, 2, 3, 4, 5}
	safeSub := make([]int, 3)
	copy(safeSub, nums[1:4])
	fmt.Printf("nums = %v\n", nums)
	fmt.Printf("safeSub = %v (독립적 복사)\n", safeSub)

	safeSub[0] = 999
	fmt.Printf("After safeSub[0] = 999:\n")
	fmt.Printf("  safeSub = %v\n", safeSub)
	fmt.Printf("  nums = %v ← 변화 없음 (독립적)\n", nums)
}
