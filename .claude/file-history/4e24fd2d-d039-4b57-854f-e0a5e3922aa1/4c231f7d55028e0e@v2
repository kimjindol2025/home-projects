## 8️⃣ 종합 실전 예제: 안전한 웹 서버

```go
import (
    "sync"
    "sync/atomic"
)

type WebServer struct {
    // 동적 설정 (RWMutex)
    mu          sync.RWMutex
    settings    map[string]string

    // 통계 (Atomic)
    requestsServed int64
    bytesServed    int64

    // 싱글톤 (Once)
    once     sync.Once
    logger   *Logger
}

func (ws *WebServer) GetLogger() *Logger {
    ws.once.Do(func() {
        ws.logger = NewLogger()
    })
    return ws.logger
}

func (ws *WebServer) HandleRequest() {
    // 통계 업데이트 (Atomic)
    atomic.AddInt64(&ws.requestsServed, 1)

    // 설정 읽기 (RWMutex)
    ws.mu.RLock()
    timeout := ws.settings["timeout"]
    ws.mu.RUnlock()

    // ... 처리 ...

    atomic.AddInt64(&ws.bytesServed, 1024)
}

func (ws *WebServer) UpdateSettings(key, value string) {
    ws.mu.Lock()
    defer ws.mu.Unlock()
    ws.settings[key] = value
}
