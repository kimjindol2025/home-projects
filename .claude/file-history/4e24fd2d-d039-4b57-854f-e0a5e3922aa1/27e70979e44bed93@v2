package main

import (
	"errors"
	"fmt"
)

// 간단한 문법 검증용 테스트 파일

type ValidationError struct {
	Field   string
	Message string
}

func (ve ValidationError) Error() string {
	return fmt.Sprintf("validation error in field '%s': %s", ve.Field, ve.Message)
}

type NotFoundError struct {
	Resource string
	ID       string
}

func (nfe NotFoundError) Error() string {
	return fmt.Sprintf("%s with ID '%s' not found", nfe.Resource, nfe.ID)
}

func testBasicError() {
	err := errors.New("simple error")
	if err != nil {
		fmt.Println("Error:", err)
	}
}

func testCustomError() {
	err := ValidationError{Field: "email", Message: "invalid"}
	fmt.Println("Custom error:", err)

	if ve, ok := err.(ValidationError); ok {
		fmt.Printf("Field: %s\n", ve.Field)
	}
}

func testErrorWrapping() {
	err := NotFoundError{Resource: "User", ID: "123"}
	wrappedErr := fmt.Errorf("operation failed: %w", err)
	fmt.Println("Wrapped:", wrappedErr)
}

func testDefer() {
	defer fmt.Println("1. Defer")
	defer fmt.Println("2. Defer")
	fmt.Println("Main code")
}

func safeOp() (string, error) {
	defer func() {
		if r := recover(); r != nil {
			fmt.Println("Recovered:", r)
		}
	}()

	arr := []int{1, 2, 3}
	_ = arr[10] // panic!

	return "ok", nil
}

func main() {
	fmt.Println("=== Syntax Test ===")

	testBasicError()
	testCustomError()
	testErrorWrapping()
	testDefer()

	result, err := safeOp()
	if err != nil {
		fmt.Println("Error:", err)
	} else {
		fmt.Println("Result:", result)
	}

	fmt.Println("=== All tests passed ===")
}
