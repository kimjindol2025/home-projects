## 7️⃣ Pipeline Architecture: 다단계 데이터 처리

### 📋 개념

```
┌─────────────┐      ┌─────────────┐      ┌─────────────┐
│ Generator   │ ───→ │  Filter     │ ───→ │ Transformer │
│ (1~100)     │ CH1  │ (짝수만)     │ CH2  │ (제곱)       │
└─────────────┘      └─────────────┘      └─────────────┘
                           ↓                      ↓
                     여러 worker         최종 결과 수집
```

### 🔑 구현

```go
// 1단계: Generator (데이터 생성)
func generate(n int) <-chan int {
    out := make(chan int)
    go func() {
        for i := 1; i <= n; i++ {
            out <- i
        }
        close(out)
    }()
    return out
}

// 2단계: Filter (짝수만)
func filter(in <-chan int) <-chan int {
    out := make(chan int)
    go func() {
        for i := range in {
            if i%2 == 0 {
                out <- i
            }
        }
        close(out)
    }()
    return out
}

// 3단계: Square (제곱)
func square(in <-chan int) <-chan int {
    out := make(chan int)
    go func() {
        for i := range in {
            out <- i * i
        }
        close(out)
    }()
    return out
}

// 사용법
func main() {
    nums := generate(100)
    filtered := filter(nums)
    squared := square(filtered)

    for result := range squared {
        fmt.Println(result)
    }
}
```

