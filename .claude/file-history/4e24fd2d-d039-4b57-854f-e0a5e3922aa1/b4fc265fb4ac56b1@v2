## 1️⃣ 포인터 (Pointer) - 메모리 주소의 이해

### 📋 포인터 기본 개념

```go
// 포인터 선언
var p *int  // int를 가리키는 포인터

// 포인터에 주소 할당
a := 10
p = &a  // & : a의 메모리 주소를 추출

// 포인터 값 확인
fmt.Println(p)   // 주소 출력 (예: 0xc0000120b0)
fmt.Println(&a)  // 같은 주소

// 역참조 (Dereferencing)
fmt.Println(*p)  // 주소가 가리키는 값 출력 (10)

// 포인터를 통해 값 수정
*p = 20
fmt.Println(a)   // 20 (원본도 변함!)
```

---

### 🔍 포인터의 세부 사항

```go
// 포인터의 타입
var a int = 10
var p *int = &a

fmt.Printf("a의 타입: %T\n", a)      // int
fmt.Printf("p의 타입: %T\n", p)      // *int
fmt.Printf("&a의 타입: %T\n", &a)    // *int

// 포인터도 변수
var q *int
q = p  // q도 a를 가리킴
fmt.Println(*q)  // 20 (같은 주소)

// Nil 포인터
var nilPtr *int
fmt.Println(nilPtr == nil)  // true
// fmt.Println(*nilPtr)  // panic: nil pointer dereference
```

---

### 📋 포인터와 함수

```go
// 값 전달 (포인터 없음)
func addOne(n int) {
    n = n + 1  // 복사본 수정
}

a := 10
addOne(a)
fmt.Println(a)  // 10 (변화 없음)

// 포인터 전달 (포인터 있음)
func addOnePtr(p *int) {
    *p = *p + 1  // 원본 수정
}

a = 10
addOnePtr(&a)
fmt.Println(a)  // 11 (변함!)

// 슬라이스와 포인터
func appendNumber(s []int) {
    s = append(s, 100)  // 로컬 슬라이스만 변함
}

nums := []int{1, 2, 3}
appendNumber(nums)
fmt.Println(nums)  // [1, 2, 3] (변화 없음 - 슬라이스 헤더 복사)

func appendNumberPtr(p *[]int) {
    *p = append(*p, 100)  // 원본 슬라이스 수정
}

appendNumberPtr(&nums)
fmt.Println(nums)  // [1, 2, 3, 100]
```

