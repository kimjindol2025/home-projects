## 5️⃣ 메서드 체이닝과 고급 패턴

### 📋 메서드 체이닝

```go
type Builder struct {
    name string
    age  int
}

func (b *Builder) SetName(name string) *Builder {
    b.name = name
    return b  // 자신을 반환
}

func (b *Builder) SetAge(age int) *Builder {
    b.age = age
    return b  // 자신을 반환
}

func (b *Builder) Build() string {
    return fmt.Sprintf("%s (%d)", b.name, b.age)
}

// 체이닝 사용
result := (&Builder{}).
    SetName("Alice").
    SetAge(25).
    Build()
fmt.Println(result)  // Alice (25)
```

