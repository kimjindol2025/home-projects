#!/usr/bin/env node

/**
 * Trend Analyzer - 추세 분석
 * Phase 9.4: 예측 분석
 *
 * 기능:
 * - 추세 추출 및 분석
 * - 변화점 감지
 * - 계절성 분석
 * - 성장 곡선 분석
 */

/**
 * 추세 분석 결과
 */
class TrendAnalysis {
  constructor(direction, strength, slope, changePoints) {
    this.direction = direction;      // upward, downward, stable
    this.strength = strength;        // 0-100
    this.slope = slope;              // 기울기
    this.changePoints = changePoints; // 변화점 인덱스
  }
}

/**
 * 선형 회귀 분석
 */
class LinearRegression {
  /**
   * 최소제곱법으로 회귀선 계산
   */
  static fit(data) {
    const n = data.length;
    if (n < 2) return null;

    let sumX = 0, sumY = 0, sumXY = 0, sumX2 = 0;

    for (let i = 0; i < n; i++) {
      sumX += i;
      sumY += data[i];
      sumXY += i * data[i];
      sumX2 += i * i;
    }

    const slope = (n * sumXY - sumX * sumY) / (n * sumX2 - sumX * sumX);
    const intercept = (sumY - slope * sumX) / n;

    return {
      slope,
      intercept,
      r2: LinearRegression.calculateR2(data, slope, intercept)
    };
  }

  /**
   * R² (결정계수) 계산
   */
  static calculateR2(data, slope, intercept) {
    const mean = data.reduce((a, b) => a + b) / data.length;
    let ssTotal = 0, ssRes = 0;

    for (let i = 0; i < data.length; i++) {
      const predicted = slope * i + intercept;
      const actual = data[i];

      ssTotal += (actual - mean) ** 2;
      ssRes += (actual - predicted) ** 2;
    }

    return ssTotal === 0 ? 0 : 1 - (ssRes / ssTotal);
  }

  /**
   * 예측값 계산
   */
  static predict(x, slope, intercept) {
    return slope * x + intercept;
  }
}

/**
 * 변화점 감지 (Change Point Detection)
 */
class ChangePointDetector {
  /**
   * PELT 알고리즘 기반 변화점 감지
   */
  static detectChanges(data, penalty = 10) {
    if (data.length < 3) return [];

    const changePoints = [];
    let segmentStart = 0;

    for (let i = 1; i < data.length - 1; i++) {
      // 현재 점의 편차 계산
      const before = data.slice(0, i + 1);
      const after = data.slice(i + 1);

      const beforeVariance = ChangePointDetector.calculateVariance(before);
      const afterVariance = ChangePointDetector.calculateVariance(after);
      const combinedVariance = ChangePointDetector.calculateVariance(data);

      // 변화도 계산 (BIC 스타일)
      const cost = beforeVariance + afterVariance - combinedVariance;

      if (cost > penalty) {
        changePoints.push({
          index: i,
          score: Math.min(1, cost / (penalty * 2))
        });
      }
    }

    return changePoints;
  }

  /**
   * 분산 계산
   */
  static calculateVariance(data) {
    if (data.length === 0) return 0;

    const mean = data.reduce((a, b) => a + b) / data.length;
    return data.reduce((sum, x) => sum + (x - mean) ** 2, 0) / data.length;
  }

  /**
   * 급격한 변화 감지
   */
  static detectSuddenChanges(data, threshold = 0.5) {
    const changes = [];

    for (let i = 1; i < data.length; i++) {
      const change = (data[i] - data[i - 1]) / (Math.abs(data[i - 1]) || 1);

      if (Math.abs(change) > threshold) {
        changes.push({
          index: i,
          change: change * 100,
          magnitude: Math.abs(change)
        });
      }
    }

    return changes;
  }
}

/**
 * 계절성 분석
 */
class SeasonalityAnalyzer {
  /**
   * 자기상관함수 (ACF) 분석
   */
  static analyzeACF(data, maxLag = 24) {
    const mean = data.reduce((a, b) => a + b) / data.length;
    const acf = [];

    const c0 = data.reduce((sum, x) => sum + (x - mean) ** 2, 0) / data.length;

    for (let lag = 0; lag <= maxLag; lag++) {
      if (lag === 0) {
        acf.push(1);
      } else {
        const c = data.slice(0, data.length - lag)
          .reduce((sum, x, i) => sum + (x - mean) * (data[i + lag] - mean), 0) / data.length;
        acf.push(c / c0);
      }
    }

    return acf;
  }

  /**
   * 계절성 주기 감지
   */
  static detectSeasonalPeriod(data) {
    const acf = SeasonalityAnalyzer.analyzeACF(data, Math.min(30, data.length - 1));

    let maxACF = 0;
    let seasonalPeriod = 0;

    // 첫 lag를 제외하고 최대 ACF 찾기
    for (let i = 2; i < acf.length; i++) {
      if (acf[i] > maxACF && acf[i] > 0.3) {
        maxACF = acf[i];
        seasonalPeriod = i;
      }
    }

    return {
      hasSeasonal: maxACF > 0.4,
      period: seasonalPeriod,
      strength: maxACF,
      acf: acf.slice(0, 13)
    };
  }

  /**
   * 계절성 성분 추출
   */
  static extractSeasonal(data, period) {
    const seasonal = Array(data.length).fill(0);

    for (let p = 0; p < period; p++) {
      const indices = [];
      for (let i = p; i < data.length; i += period) {
        indices.push(data[i]);
      }

      const avgSeasonal = indices.reduce((a, b) => a + b) / indices.length;

      for (let i = p; i < data.length; i += period) {
        seasonal[i] = avgSeasonal;
      }
    }

    return seasonal;
  }
}

/**
 * 성장 곡선 분석
 */
class GrowthCurveAnalyzer {
  /**
   * 성장률 계산
   */
  static calculateGrowthRate(data, windowSize = 3) {
    const growthRates = [];

    for (let i = windowSize; i < data.length; i++) {
      const before = data[i - windowSize];
      const after = data[i];

      if (before !== 0) {
        const rate = Math.pow(after / before, 1 / windowSize) - 1;
        growthRates.push({
          index: i,
          rate: rate * 100,
          cagr: rate * 100  // Compound Annual Growth Rate
        });
      }
    }

    return growthRates;
  }

  /**
   * S곡선 (Logistic Curve) 피팅
   */
  static fitLogisticCurve(data) {
    const n = data.length;
    const maxValue = Math.max(...data);
    const minValue = Math.min(...data);
    const midpoint = (maxValue + minValue) / 2;

    // L: 최대값, k: 성장률, x0: 중점
    let L = maxValue;
    let k = 0.5;
    let x0 = n / 2;

    // 간단한 근사: 데이터 중점 찾기
    for (let i = 0; i < n; i++) {
      if (data[i] >= midpoint) {
        x0 = i;
        break;
      }
    }

    return {
      L,     // 최대 용량
      k,     // 성장률
      x0,    // 중점
      type: 'logistic',
      fitted: Array.from({ length: n }, (_, i) =>
        L / (1 + Math.exp(-k * (i - x0)))
      )
    };
  }

  /**
   * 지수 성장 피팅
   */
  static fitExponentialGrowth(data) {
    if (data.length < 2) return null;

    // log 변환으로 선형화
    const logData = data.map(d => Math.log(d || 0.001));
    const regression = LinearRegression.fit(logData);

    return {
      baseValue: Math.exp(regression.intercept),
      growthRate: regression.slope,
      type: 'exponential',
      fitted: Array.from({ length: data.length }, (_, i) =>
        Math.exp(regression.intercept) * Math.exp(regression.slope * i)
      )
    };
  }

  /**
   * 성장 단계 판정
   */
  static classifyGrowthStage(data) {
    const recentGrowth = GrowthCurveAnalyzer.calculateGrowthRate(
      data.slice(-10),
      3
    );

    if (recentGrowth.length === 0) {
      return 'insufficient_data';
    }

    const avgRecentGrowth = recentGrowth.reduce((sum, g) => sum + g.rate, 0) / recentGrowth.length;

    if (avgRecentGrowth > 20) {
      return 'rapid_growth';
    } else if (avgRecentGrowth > 5) {
      return 'healthy_growth';
    } else if (avgRecentGrowth > 0) {
      return 'slow_growth';
    } else if (avgRecentGrowth > -5) {
      return 'stable';
    } else {
      return 'decline';
    }
  }
}

/**
 * 통합 추세 분석기
 */
class TrendAnalyzer {
  constructor(config = {}) {
    this.config = {
      windowSize: config.windowSize || 5,
      changePointPenalty: config.changePointPenalty || 10,
      ...config
    };

    this.data = [];
    this.trend = null;
    this.changePoints = [];
    this.seasonality = null;
    this.growthCurve = null;
  }

  /**
   * 데이터 로드
   */
  loadData(values) {
    this.data = values;
    return this;
  }

  /**
   * 전체 추세 분석
   */
  analyze() {
    if (this.data.length < 3) return null;

    // 1. 선형 회귀 분석
    const regression = LinearRegression.fit(this.data);

    // 2. 추세 방향 결정
    const recentData = this.data.slice(-Math.floor(this.data.length / 3));
    const recentRegression = LinearRegression.fit(recentData);
    const slope = recentRegression?.slope || 0;

    const direction = slope > 0.1 ? 'upward' :
                     slope < -0.1 ? 'downward' : 'stable';

    // 3. 추세 강도
    const strength = Math.min(100, Math.abs(slope) * 10 * (recentRegression?.r2 || 0));

    // 4. 변화점 감지
    this.changePoints = ChangePointDetector.detectChanges(
      this.data,
      this.config.changePointPenalty
    );

    // 5. 계절성 분석
    this.seasonality = SeasonalityAnalyzer.detectSeasonalPeriod(this.data);

    // 6. 성장 곡선 분석
    if (Math.min(...this.data) > 0) {
      this.growthCurve = GrowthCurveAnalyzer.fitLogisticCurve(this.data);
    }

    this.trend = new TrendAnalysis(
      direction,
      strength,
      slope,
      this.changePoints
    );

    return this.trend;
  }

  /**
   * 구간별 추세
   */
  analyzeBySegment(segmentSize = null) {
    if (!segmentSize) {
      segmentSize = Math.floor(this.data.length / 5);
    }

    const segments = [];

    for (let i = 0; i < this.data.length; i += segmentSize) {
      const segment = this.data.slice(i, i + segmentSize);
      if (segment.length >= 2) {
        const regression = LinearRegression.fit(segment);
        segments.push({
          startIndex: i,
          endIndex: i + segment.length - 1,
          slope: regression.slope,
          r2: regression.r2,
          direction: regression.slope > 0 ? 'up' : 'down'
        });
      }
    }

    return segments;
  }

  /**
   * 미래 추세 예측
   */
  forecastTrend(steps = 5) {
    if (!this.trend) {
      this.analyze();
    }

    const regression = LinearRegression.fit(this.data);
    const forecasts = [];

    for (let i = 0; i < steps; i++) {
      const forecastIdx = this.data.length + i;
      const value = LinearRegression.predict(forecastIdx, regression.slope, regression.intercept);
      forecasts.push({
        step: i + 1,
        forecast: Math.max(0, value),
        trend: this.trend.direction
      });
    }

    return forecasts;
  }

  /**
   * 주요 통계
   */
  getStatistics() {
    const mean = this.data.reduce((a, b) => a + b) / this.data.length;
    const variance = this.data.reduce((sum, x) => sum + (x - mean) ** 2, 0) / this.data.length;
    const stdDev = Math.sqrt(variance);

    return {
      mean,
      stdDev,
      min: Math.min(...this.data),
      max: Math.max(...this.data),
      cv: (stdDev / Math.abs(mean || 1)) * 100  // 변이계수
    };
  }

  /**
   * JSON 내보내기
   */
  toJSON() {
    if (!this.trend) {
      this.analyze();
    }

    return {
      trend: {
        direction: this.trend.direction,
        strength: this.trend.strength.toFixed(2),
        slope: this.trend.slope.toFixed(4)
      },
      changePoints: this.changePoints.length,
      seasonality: this.seasonality,
      growthStage: GrowthCurveAnalyzer.classifyGrowthStage(this.data),
      statistics: this.getStatistics()
    };
  }
}

