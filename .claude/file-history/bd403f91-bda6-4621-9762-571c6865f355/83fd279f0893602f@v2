#!/usr/bin/env node

/**
 * Auto Scaler - 자동 스케일링
 * Phase 10.4: Enterprise Deployment
 *
 * 기능:
 * - 수평 확장 (HPA)
 * - 수직 확장 (VPA)
 * - 메트릭 기반 스케일링
 * - 스케일 예측
 */

/**
 * 메트릭 수집기
 */
class MetricsCollector {
  constructor() {
    this.metrics = [];
    this.history = [];
  }

  /**
   * 메트릭 수집
   */
  collectMetric(deploymentName, cpu, memory, requestCount) {
    const metric = {
      timestamp: Date.now(),
      deployment: deploymentName,
      cpu: cpu,  // CPU 사용률 (%)
      memory: memory,  // 메모리 사용률 (%)
      requestCount: requestCount,  // 초당 요청 수
      latency: Math.floor(Math.random() * 200) + 50  // ms
    };

    this.metrics.push(metric);
    this.history.push(metric);

    // 최근 100개만 유지
    if (this.metrics.length > 100) {
      this.metrics.shift();
    }

    return metric;
  }

  /**
   * 평균 메트릭 계산
   */
  getAverageMetrics(deploymentName, window = 10) {
    const recentMetrics = this.metrics
      .filter(m => m.deployment === deploymentName)
      .slice(-window);

    if (recentMetrics.length === 0) {
      return null;
    }

    const avgCpu = recentMetrics.reduce((sum, m) => sum + m.cpu, 0) / recentMetrics.length;
    const avgMemory = recentMetrics.reduce((sum, m) => sum + m.memory, 0) / recentMetrics.length;
    const avgRequests = recentMetrics.reduce((sum, m) => sum + m.requestCount, 0) / recentMetrics.length;

    return {
      deployment: deploymentName,
      avgCpu: avgCpu.toFixed(2),
      avgMemory: avgMemory.toFixed(2),
      avgRequests: Math.round(avgRequests),
      sampleCount: recentMetrics.length
    };
  }

  /**
   * 메트릭 정보
   */
  getMetricsInfo() {
    return {
      totalMetrics: this.history.length,
      recentMetrics: this.metrics.length
    };
  }
}

/**
 * 수평 확장 정책 (HPA)
 */
class HorizontalPodAutoscaler {
  constructor() {
    this.policies = [];
    this.scaleHistory = [];
  }

  /**
   * HPA 정책 추가
   */
  addPolicy(deploymentName, spec) {
    const policy = {
      deploymentName,
      minReplicas: spec.minReplicas || 1,
      maxReplicas: spec.maxReplicas || 10,
      targetCpu: spec.targetCpu || 80,  // CPU 임계값 (%)
      targetMemory: spec.targetMemory || 85,  // 메모리 임계값 (%)
      scaleUpThreshold: spec.scaleUpThreshold || 80,
      scaleDownThreshold: spec.scaleDownThreshold || 30,
      cooldownPeriod: spec.cooldownPeriod || 300000,  // 5분
      createdAt: Date.now()
    };

    this.policies.push(policy);

    return {
      success: true,
      policy: deploymentName,
      minReplicas: policy.minReplicas,
      maxReplicas: policy.maxReplicas
    };
  }

  /**
   * 스케일링 결정
   */
  calculateScale(deploymentName, metrics, currentReplicas) {
    const policy = this.policies.find(p => p.deploymentName === deploymentName);

    if (!policy) {
      return { success: false, reason: 'Policy not found' };
    }

    let targetReplicas = currentReplicas;
    let reason = 'no-action';

    // CPU 기반 스케일링
    if (metrics.cpu > policy.scaleUpThreshold) {
      const cpuRatio = metrics.cpu / policy.targetCpu;
      targetReplicas = Math.ceil(currentReplicas * cpuRatio);
      reason = 'high-cpu';
    }

    // 메모리 기반 스케일링
    if (metrics.memory > policy.scaleUpThreshold) {
      const memRatio = metrics.memory / policy.targetMemory;
      targetReplicas = Math.max(targetReplicas, Math.ceil(currentReplicas * memRatio));
      reason = 'high-memory';
    }

    // Scale down
    if (metrics.cpu < policy.scaleDownThreshold && metrics.memory < policy.scaleDownThreshold) {
      targetReplicas = Math.max(policy.minReplicas, Math.ceil(currentReplicas * 0.5));
      reason = 'low-utilization';
    }

    // 범위 체크
    targetReplicas = Math.max(policy.minReplicas, Math.min(targetReplicas, policy.maxReplicas));

    return {
      success: true,
      deployment: deploymentName,
      currentReplicas,
      targetReplicas,
      reason,
      changed: targetReplicas !== currentReplicas
    };
  }

  /**
   * HPA 정보
   */
  getPolicyInfo() {
    return {
      totalPolicies: this.policies.length,
      policies: this.policies.map(p => ({
        deployment: p.deploymentName,
        minReplicas: p.minReplicas,
        maxReplicas: p.maxReplicas,
        targetCpu: p.targetCpu + '%'
      }))
    };
  }
}

/**
 * 수직 확장 정책 (VPA)
 */
class VerticalPodAutoscaler {
  constructor() {
    this.recommendations = [];
  }

  /**
   * 리소스 권장사항 계산
   */
  calculateRecommendations(deploymentName, historicalMetrics) {
    const avgCpu = historicalMetrics.reduce((sum, m) => sum + m.cpu, 0) / historicalMetrics.length;
    const avgMemory = historicalMetrics.reduce((sum, m) => sum + m.memory, 0) / historicalMetrics.length;
    const maxCpu = Math.max(...historicalMetrics.map(m => m.cpu));
    const maxMemory = Math.max(...historicalMetrics.map(m => m.memory));

    // P95 추정 (소수의 높은 값 제외)
    const cpuP95 = Math.percentile ? historicalMetrics.map(m => m.cpu).sort((a, b) => a - b)[Math.floor(historicalMetrics.length * 0.95)] : avgCpu * 1.3;
    const memoryP95 = Math.percentile ? historicalMetrics.map(m => m.memory).sort((a, b) => a - b)[Math.floor(historicalMetrics.length * 0.95)] : avgMemory * 1.3;

    const recommendation = {
      deployment: deploymentName,
      timestamp: Date.now(),
      current: {
        cpu: '1000m',
        memory: '512Mi'
      },
      recommended: {
        cpu: Math.ceil(cpuP95 * 10) + '00m',  // P95 × 1.1 safety margin
        memory: Math.ceil(memoryP95 * 2) + 'Mi'
      },
      confidence: (Math.min(100, historicalMetrics.length * 5) / 100).toFixed(2)
    };

    this.recommendations.push(recommendation);

    return recommendation;
  }

  /**
   * VPA 정보
   */
  getRecommendationInfo() {
    return {
      totalRecommendations: this.recommendations.length,
      recommendations: this.recommendations.slice(-5).map(r => ({
        deployment: r.deployment,
        recommended: r.recommended,
        confidence: r.confidence
      }))
    };
  }
}

/**
 * 스케일 매니저
 */
class ScaleManager {
  constructor() {
    this.metricsCollector = new MetricsCollector();
    this.hpa = new HorizontalPodAutoscaler();
    this.vpa = new VerticalPodAutoscaler();
    this.deployments = new Map();
  }

  /**
   * 배포 등록
   */
  registerDeployment(name, initialReplicas = 3) {
    this.deployments.set(name, {
      name,
      replicas: initialReplicas,
      lastScaleTime: Date.now()
    });

    // HPA 정책 추가
    this.hpa.addPolicy(name, {
      minReplicas: 1,
      maxReplicas: 10,
      targetCpu: 70,
      targetMemory: 80
    });

    return { success: true, deployment: name, replicas: initialReplicas };
  }

  /**
   * 자동 스케일링 실행
   */
  runAutoScaling(deploymentName, cpuUsage, memoryUsage, requestCount) {
    const deployment = this.deployments.get(deploymentName);

    if (!deployment) {
      return { success: false, reason: 'Deployment not found' };
    }

    // 메트릭 수집
    this.metricsCollector.collectMetric(deploymentName, cpuUsage, memoryUsage, requestCount);

    // 평균 메트릭 계산
    const avgMetrics = this.metricsCollector.getAverageMetrics(deploymentName);

    if (!avgMetrics) {
      return { success: false, reason: 'Insufficient metrics' };
    }

    // HPA 계산
    const hpaResult = this.hpa.calculateScale(
      deploymentName,
      { cpu: parseFloat(avgMetrics.avgCpu), memory: parseFloat(avgMetrics.avgMemory) },
      deployment.replicas
    );

    if (!hpaResult.success) {
      return hpaResult;
    }

    // 스케일링 실행
    if (hpaResult.changed) {
      deployment.replicas = hpaResult.targetReplicas;
      deployment.lastScaleTime = Date.now();

      return {
        success: true,
        deployment: deploymentName,
        previousReplicas: hpaResult.currentReplicas,
        newReplicas: hpaResult.targetReplicas,
        reason: hpaResult.reason,
        scaled: true
      };
    }

    return {
      success: true,
      deployment: deploymentName,
      replicas: deployment.replicas,
      scaled: false,
      reason: 'Within acceptable range'
    };
  }

  /**
   * 스케일 예측
   */
  predictScale(deploymentName, projectedLoad) {
    const deployment = this.deployments.get(deploymentName);

    if (!deployment) {
      return { success: false, reason: 'Deployment not found' };
    }

    // 선형 예측
    const projectedCpu = projectedLoad.cpuPercentage || 60;
    const projectedMemory = projectedLoad.memoryPercentage || 70;

    const hpaPolicy = this.hpa.policies.find(p => p.deploymentName === deploymentName);

    if (!hpaPolicy) {
      return { success: false, reason: 'HPA policy not found' };
    }

    let predictedReplicas = deployment.replicas;

    if (projectedCpu > hpaPolicy.targetCpu) {
      predictedReplicas = Math.ceil(deployment.replicas * (projectedCpu / hpaPolicy.targetCpu));
    }

    predictedReplicas = Math.max(hpaPolicy.minReplicas, Math.min(predictedReplicas, hpaPolicy.maxReplicas));

    return {
      success: true,
      deployment: deploymentName,
      currentReplicas: deployment.replicas,
      projectedLoad,
      predictedReplicas,
      confidence: '0.85'
    };
  }

  /**
   * 매니저 상태
   */
  getStatus() {
    const deploymentStatus = [];

    for (const [name, deployment] of this.deployments) {
      const avgMetrics = this.metricsCollector.getAverageMetrics(name);
      deploymentStatus.push({
        deployment: name,
        replicas: deployment.replicas,
        metrics: avgMetrics,
        lastScaleTime: new Date(deployment.lastScaleTime).toISOString()
      });
    }

    return {
      deployments: deploymentStatus,
      hpa: this.hpa.getPolicyInfo(),
      vpa: this.vpa.getRecommendationInfo(),
      metrics: this.metricsCollector.getMetricsInfo()
    };
  }
}

