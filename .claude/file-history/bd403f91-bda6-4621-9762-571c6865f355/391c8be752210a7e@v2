#!/usr/bin/env node

/**
 * AI Documentation Generator - 자동 문서 생성
 * Phase 9.0: AI 강화
 *
 * 기능:
 * - 자동 README 생성
 * - API 문서 자동화
 * - 아키텍처 다이어그램 자동 생성
 * - 변경사항 자동 요약
 */

class DocumentationGenerator {
  constructor(projectName = 'Project') {
    this.projectName = projectName;
    this.apis = [];
    this.functions = [];
    this.modules = [];
    this.changelog = [];
  }

  /**
   * 함수 시그니처 추출
   */
  extractFunctionSignatures(code) {
    const functions = [];
    const functionRegex = /function\s+(\w+)\s*\((.*?)\)|const\s+(\w+)\s*=\s*(?:async\s*)?\((.*?)\)\s*=>/gm;

    let match;
    while ((match = functionRegex.exec(code)) !== null) {
      const name = match[1] || match[3];
      const params = (match[2] || match[4] || '').split(',').map(p => p.trim()).filter(p => p);

      functions.push({
        name,
        params,
        description: this.extractJSDocComment(code, match.index)
      });
    }

    this.functions = functions;
    return functions;
  }

  /**
   * JSDoc 주석 추출
   */
  extractJSDocComment(code, position) {
    const beforeCode = code.substring(Math.max(0, position - 500), position);
    const jsdocMatch = beforeCode.match(/\/\*\*([\s\S]*?)\*\//);

    if (jsdocMatch) {
      return jsdocMatch[1]
        .split('\n')
        .map(line => line.replace(/^\s*\*\s?/, '').trim())
        .filter(line => line)
        .join('\n');
    }

    return 'No description available';
  }

  /**
   * 클래스 추출
   */
  extractClasses(code) {
    const classes = [];
    const classRegex = /class\s+(\w+)(?:\s+extends\s+(\w+))?\s*\{([\s\S]*?)\n\}/gm;

    let match;
    while ((match = classRegex.exec(code)) !== null) {
      const className = match[1];
      const extends_class = match[2];
      const body = match[3];

      const methods = [];
      const methodRegex = /(?:async\s+)?(\w+)\s*\((.*?)\)\s*\{/gm;
      let methodMatch;

      while ((methodMatch = methodRegex.exec(body)) !== null) {
        const methodName = methodMatch[1];
        const params = (methodMatch[2] || '').split(',').map(p => p.trim()).filter(p => p);

        methods.push({
          name: methodName,
          params,
          isAsync: body.substring(Math.max(0, methodMatch.index - 10), methodMatch.index).includes('async')
        });
      }

      classes.push({
        name: className,
        extendsClass: extends_class,
        methods,
        description: this.extractJSDocComment(code, match.index)
      });
    }

    this.modules = classes;
    return classes;
  }

  /**
   * API 엔드포인트 추출 (Express 기반)
   */
  extractAPIs(code) {
    const apis = [];
    const apiRegex = /app\.(get|post|put|delete|patch)\s*\(\s*['"`]([^'"`]+)['"`]\s*,/gm;

    let match;
    while ((match = apiRegex.exec(code)) !== null) {
      const method = match[1].toUpperCase();
      const path = match[2];

      apis.push({
        method,
        path,
        description: this.extractJSDocComment(code, match.index)
      });
    }

    this.apis = apis;
    return apis;
  }

  /**
   * 자동 README 생성
   */
  generateReadme(code, projectInfo = {}) {
    this.extractFunctionSignatures(code);
    this.extractClasses(code);
    this.extractAPIs(code);

    let readme = '';

    // 제목
    readme += `# ${this.projectName}\n\n`;

    // 설명
    readme += `${projectInfo.description || 'A new project.'}\n\n`;

    // 설치
    readme += '## Installation\n\n';
    readme += '```bash\n';
    readme += 'npm install\n';
    readme += '```\n\n';

    // 사용법
    if (this.functions.length > 0 || this.modules.length > 0) {
      readme += '## Usage\n\n';

      if (this.modules.length > 0) {
        readme += '### Classes\n\n';
        for (const cls of this.modules) {
          readme += `#### ${cls.name}\n`;
          if (cls.extendsClass) {
            readme += `Extends: \`${cls.extendsClass}\`\n\n`;
          }
          readme += `${cls.description}\n\n`;

          if (cls.methods.length > 0) {
            readme += 'Methods:\n';
            for (const method of cls.methods) {
              readme += `- \`${method.name}(${method.params.join(', ')})\`${method.isAsync ? ' (async)' : ''}\n`;
            }
            readme += '\n';
          }
        }
      }

      if (this.functions.length > 0) {
        readme += '### Functions\n\n';
        for (const func of this.functions) {
          readme += `#### \`${func.name}(${func.params.join(', ')})\`\n`;
          readme += `${func.description}\n\n`;
        }
      }
    }

    // API 엔드포인트
    if (this.apis.length > 0) {
      readme += '## API Endpoints\n\n';
      readme += '| Method | Path | Description |\n';
      readme += '|--------|------|-------------|\n';

      for (const api of this.apis) {
        const desc = api.description.split('\n')[0] || 'No description';
        readme += `| ${api.method} | \`${api.path}\` | ${desc} |\n`;
      }

      readme += '\n';
    }

    // 기여
    readme += '## Contributing\n\n';
    readme += 'Contributions are welcome!\n\n';

    // 라이선스
    readme += '## License\n\n';
    readme += 'MIT\n';

    return readme;
  }

  /**
   * API 문서 생성 (OpenAPI 형식)
   */
  generateOpenAPISpec(version = '1.0.0', host = 'api.example.com') {
    const spec = {
      openapi: '3.0.0',
      info: {
        title: this.projectName,
        version,
        description: 'Auto-generated API documentation'
      },
      servers: [
        {
          url: `https://${host}`,
          description: 'Production server'
        }
      ],
      paths: {}
    };

    // 엔드포인트 추가
    for (const api of this.apis) {
      if (!spec.paths[api.path]) {
        spec.paths[api.path] = {};
      }

      const method = api.method.toLowerCase();
      spec.paths[api.path][method] = {
        summary: api.description.split('\n')[0],
        description: api.description,
        responses: {
          '200': {
            description: 'Successful response',
            content: {
              'application/json': {
                schema: {
                  type: 'object',
                  properties: {
                    success: { type: 'boolean' },
                    data: { type: 'object' }
                  }
                }
              }
            }
          },
          '400': {
            description: 'Bad request'
          },
          '500': {
            description: 'Server error'
          }
        }
      };
    }

    return spec;
  }

  /**
   * 아키텍처 다이어그램 생성
   */
  generateArchitectureDiagram() {
    let diagram = '';
    diagram += '# Architecture\n\n';
    diagram += '```\n';

    if (this.modules.length > 0) {
      diagram += '┌─────────────────────────────────────┐\n';
      diagram += '│           Application               │\n';
      diagram += '└─────────────────────────────────────┘\n';
      diagram += '              ↓\n';

      diagram += '┌─────────────────────────────────────┐\n';
      diagram += '│          Business Logic             │\n';

      for (const cls of this.modules) {
        diagram += `│  • ${cls.name}\n`;
      }

      diagram += '└─────────────────────────────────────┘\n';
      diagram += '              ↓\n';

      diagram += '┌─────────────────────────────────────┐\n';
      diagram += '│            Data Layer               │\n';
      diagram += '│  • Database                         │\n';
      diagram += '│  • Cache                            │\n';
      diagram += '│  • External APIs                    │\n';
      diagram += '└─────────────────────────────────────┘\n';
    }

    diagram += '```\n\n';

    if (this.apis.length > 0) {
      diagram += '## API Flow\n\n';
      diagram += '```\n';
      diagram += 'Client Request → Router → Controller → Service → Database\n';
      diagram += '                                           ↓\n';
      diagram += '                      Response ← Formatter ← Model\n';
      diagram += '```\n';
    }

    return diagram;
  }

  /**
   * 변경사항 요약 생성
   */
  generateChangelog(changes = []) {
    let changelog = '# Changelog\n\n';
    changelog += '## [Unreleased]\n\n';

    if (changes.length === 0) {
      changelog += '### Added\n';
      changelog += `- Initial ${this.projectName} implementation\n`;
      changelog += `- ${this.functions.length} functions\n`;
      changelog += `- ${this.modules.length} classes/modules\n`;
      changelog += `- ${this.apis.length} API endpoints\n\n`;

      changelog += '### Changed\n';
      changelog += '- None\n\n';

      changelog += '### Fixed\n';
      changelog += '- None\n\n';

      changelog += '### Deprecated\n';
      changelog += '- None\n\n';

      changelog += '### Removed\n';
      changelog += '- None\n\n';

      changelog += '### Security\n';
      changelog += '- None\n\n';
    } else {
      for (const change of changes) {
        changelog += `### ${change.type}\n`;
        changelog += `${change.description}\n\n`;
      }
    }

    changelog += '---\n';
    changelog += `Generated at: ${new Date().toISOString()}\n`;

    return changelog;
  }

  /**
   * 종합 문서 생성
   */
  generateCompleteDocs(code, projectInfo = {}) {
    const docs = {
      readme: this.generateReadme(code, projectInfo),
      openapi: this.generateOpenAPISpec(),
      architecture: this.generateArchitectureDiagram(),
      changelog: this.generateChangelog(),
      functions: this.functions,
      classes: this.modules,
      apis: this.apis,
      summary: {
        totalFunctions: this.functions.length,
        totalClasses: this.modules.length,
        totalEndpoints: this.apis.length,
        generatedAt: new Date().toISOString()
      }
    };

    return docs;
  }

  /**
   * 문서를 파일로 저장 (시뮬레이션)
   */
  saveDocs(docs, outputDir = './docs') {
    const files = {
      'README.md': docs.readme,
      'openapi.json': JSON.stringify(docs.openapi, null, 2),
      'ARCHITECTURE.md': docs.architecture,
      'CHANGELOG.md': docs.changelog
    };

    return files;
  }
}

