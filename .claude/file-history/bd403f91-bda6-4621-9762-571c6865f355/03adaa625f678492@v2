  ];

  const recognizer = new PatternRecognizer({
    windowSize: 3,
    minFrequency: 2
  });

  console.log('✅ Test 1: Data Loading');
  recognizer.loadData(testData);
  console.log(`  Data Points: ${recognizer.data.length}\n`);

  console.log('✅ Test 2: Pattern Recognition');
  const patterns = recognizer.recognize();
  console.log(`  Patterns Found: ${patterns.length}`);
  patterns.slice(0, 3).forEach((p, i) => {
    console.log(`    ${i + 1}. Type: ${p.type}, Freq: ${p.frequency || p.strength?.toFixed(2)}`);
  });
  console.log();

  console.log('✅ Test 3: Distance Metrics');
  const a = [1, 2, 3];
  const b = [1, 2, 3];
  const c = [4, 5, 6];
  console.log(`  Euclidean (identical): ${DistanceMetrics.euclidean(a, b).toFixed(3)}`);
  console.log(`  Cosine (identical): ${DistanceMetrics.cosine(a, b).toFixed(3)}`);
  console.log(`  Cosine (different): ${DistanceMetrics.cosine(a, c).toFixed(3)}\n`);

  console.log('✅ Test 4: Clustering');
  const clusters = recognizer.clustering(2);
  console.log(`  Clusters Created: ${clusters.length}`);
  clusters.forEach((c, i) => {
