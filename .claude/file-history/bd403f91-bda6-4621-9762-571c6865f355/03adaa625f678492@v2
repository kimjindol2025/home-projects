#!/usr/bin/env node

/**
 * Pattern Recognizer - 패턴 인식
 * Phase 9.4: 예측 분석
 *
 * 기능:
 * - 패턴 매칭
 * - 유사도 분석
 * - 클러스터링
 * - 반복 패턴 감지
 */

/**
 * 패턴
 */
class Pattern {
  constructor(id, sequence, frequency, type) {
    this.id = id;
    this.sequence = sequence;      // 패턴 시퀀스
    this.frequency = frequency;    // 발생 횟수
    this.type = type;              // recurring, cyclic, trend
    this.confidence = 0;           // 신뢰도
  }
}

/**
 * 거리 계산 (유사도)
 */
class DistanceMetrics {
  /**
   * 유클리드 거리
   */
  static euclidean(a, b) {
    let sum = 0;
    for (let i = 0; i < Math.min(a.length, b.length); i++) {
      sum += (a[i] - b[i]) ** 2;
    }
    return Math.sqrt(sum);
  }

  /**
   * 맨해튼 거리
   */
  static manhattan(a, b) {
    let sum = 0;
    for (let i = 0; i < Math.min(a.length, b.length); i++) {
      sum += Math.abs(a[i] - b[i]);
    }
    return sum;
  }

  /**
   * 코사인 유사도
   */
  static cosine(a, b) {
    let dotProduct = 0;
    let magnitudeA = 0;
    let magnitudeB = 0;

    for (let i = 0; i < Math.min(a.length, b.length); i++) {
      dotProduct += a[i] * b[i];
      magnitudeA += a[i] * a[i];
      magnitudeB += b[i] * b[i];
    }

    magnitudeA = Math.sqrt(magnitudeA);
    magnitudeB = Math.sqrt(magnitudeB);

    if (magnitudeA === 0 || magnitudeB === 0) return 0;

    return dotProduct / (magnitudeA * magnitudeB);
  }

  /**
   * 동적 시간 워핑 (DTW)
   */
  static dtw(a, b) {
    const m = a.length;
    const n = b.length;

    const cost = Array(m + 1).fill(0).map(() => Array(n + 1).fill(Infinity));
    cost[0][0] = 0;

    for (let i = 1; i <= m; i++) {
      for (let j = 1; j <= n; j++) {
        const distance = Math.abs(a[i - 1] - b[j - 1]);
        cost[i][j] = distance + Math.min(
          cost[i - 1][j],
          cost[i][j - 1],
          cost[i - 1][j - 1]
        );
      }
    }

    return cost[m][n];
  }
}

/**
 * 패턴 매칭
 */
class PatternMatcher {
  /**
   * 서브시퀀스 매칭
   */
  static findMatches(data, pattern, threshold = 0.9) {
    const matches = [];
    const patternLen = pattern.length;

    for (let i = 0; i <= data.length - patternLen; i++) {
      const window = data.slice(i, i + patternLen);
      const similarity = DistanceMetrics.cosine(pattern, window);

      if (similarity > threshold) {
        matches.push({
          startIndex: i,
          endIndex: i + patternLen - 1,
          similarity
        });
      }
    }

    return matches;
  }

  /**
   * 슬라이딩 윈도우로 패턴 추출
   */
  static extractPatterns(data, windowSize, minFrequency = 2) {
    const patterns = new Map();

    for (let i = 0; i <= data.length - windowSize; i++) {
      const window = data.slice(i, i + windowSize);
      const key = window.map(v => v.toFixed(2)).join(',');

      if (!patterns.has(key)) {
        patterns.set(key, {
          sequence: window,
          positions: [],
          frequency: 0
        });
      }

      patterns.get(key).positions.push(i);
      patterns.get(key).frequency++;
    }

    // minFrequency 이상의 패턴만 반환
    const result = [];
    for (const [key, value] of patterns.entries()) {
      if (value.frequency >= minFrequency) {
        result.push({
          sequence: value.sequence,
          frequency: value.frequency,
          positions: value.positions,
          confidence: Math.min(1, value.frequency / (data.length - windowSize))
        });
      }
    }

    return result.sort((a, b) => b.frequency - a.frequency);
  }
}

/**
 * K-means 클러스터링
 */
class KMeansClustering {
  /**
   * 클러스터링 수행
   */
  static cluster(data, k = 3, maxIterations = 100) {
    if (data.length < k) return null;

    // 1. 초기 중심점 선택 (랜덤)
    const centers = [];
    const indices = new Set();

    while (centers.length < k) {
      const idx = Math.floor(Math.random() * data.length);
      if (!indices.has(idx)) {
        centers.push([...data[idx]]);
        indices.add(idx);
      }
    }

    let assignments = Array(data.length).fill(0);
    let converged = false;

    // 2. K-means 반복
    for (let iter = 0; iter < maxIterations && !converged; iter++) {
      // 2-1. 각 데이터포인트를 가장 가까운 중심점에 할당
      let newAssignments = Array(data.length).fill(0);
      for (let i = 0; i < data.length; i++) {
        let minDistance = Infinity;
        let closestCenter = 0;

        for (let j = 0; j < k; j++) {
          const distance = DistanceMetrics.euclidean(data[i], centers[j]);
          if (distance < minDistance) {
            minDistance = distance;
            closestCenter = j;
          }
        }

        newAssignments[i] = closestCenter;
      }

      // 2-2. 중심점 업데이트
      const newCenters = Array(k).fill(0).map(() => []);
      const counts = Array(k).fill(0);

      for (let i = 0; i < data.length; i++) {
        const cluster = newAssignments[i];
        for (let j = 0; j < data[i].length; j++) {
          newCenters[cluster][j] = (newCenters[cluster][j] || 0) + data[i][j];
        }
        counts[cluster]++;
      }

      // 평균 계산
      for (let j = 0; j < k; j++) {
        if (counts[j] > 0) {
          newCenters[j] = newCenters[j].map(v => v / counts[j]);
        }
      }

      // 수렴 확인
      converged = assignments.every((v, i) => v === newAssignments[i]);
      assignments = newAssignments;
      for (let j = 0; j < k; j++) {
        centers[j] = newCenters[j];
      }
    }

    // 3. 결과 생성
    const clusters = Array(k).fill(0).map((_, i) => ({
      centroid: centers[i],
      members: [],
      size: 0
    }));

    for (let i = 0; i < data.length; i++) {
      clusters[assignments[i]].members.push(i);
      clusters[assignments[i]].size++;
    }

    return clusters;
  }
}

/**
 * 반복 패턴 감지
 */
class RecurringPatternDetector {
  /**
   * 주기적 패턴 감지
   */
  static detectPeriodic(data) {
    const patterns = [];

    // 가능한 주기 테스트 (2부터 data.length/2까지)
    for (let period = 2; period <= data.length / 2; period++) {
      let correlation = 0;
      let count = 0;

      for (let i = 0; i + period < data.length; i++) {
        const current = data[i];
        const next = data[i + period];

        correlation += current === next ? 1 : 0;
        count++;
      }

      const strength = correlation / count;

      if (strength > 0.6) {
        patterns.push({
          period,
          strength,
          type: 'periodic'
        });
      }
    }

    return patterns.sort((a, b) => b.strength - a.strength);
  }

  /**
   * 반복되는 서브시퀀스 감지
   */
  static detectRepeatSequences(data, minLength = 3, minRepeat = 2) {
    const sequences = new Map();

    for (let len = minLength; len <= data.length / minRepeat; len++) {
      for (let i = 0; i <= data.length - len; i++) {
        const seq = data.slice(i, i + len);
        const key = seq.map(v => v.toFixed(2)).join(',');

        if (!sequences.has(key)) {
          sequences.set(key, {
            sequence: seq,
            positions: []
          });
        }

        sequences.get(key).positions.push(i);
      }
    }

    const result = [];
    for (const [key, value] of sequences.entries()) {
      if (value.positions.length >= minRepeat) {
        // 중복 위치 확인 (겹치지 않는)
        let nonOverlapping = 0;
        let lastEnd = -1;

        for (const pos of value.positions.sort((a, b) => a - b)) {
          if (pos > lastEnd) {
            nonOverlapping++;
            lastEnd = pos + value.sequence.length - 1;
          }
        }

        if (nonOverlapping >= minRepeat) {
          result.push({
            sequence: value.sequence,
            frequency: nonOverlapping,
            positions: value.positions,
            type: 'repeating'
          });
        }
      }
    }

    return result.sort((a, b) => b.frequency - a.frequency);
  }
}

/**
 * 통합 패턴 인식기
 */
class PatternRecognizer {
  constructor(config = {}) {
    this.config = {
      windowSize: config.windowSize || 5,
      minFrequency: config.minFrequency || 2,
      similarityThreshold: config.similarityThreshold || 0.85,
      ...config
    };

    this.data = [];
    this.patterns = [];
    this.clusters = [];
  }

  /**
   * 데이터 로드
   */
  loadData(values) {
    this.data = values;
    return this;
  }

  /**
   * 패턴 인식
   */
  recognize() {
    if (this.data.length < this.config.windowSize) return [];

    // 1. 반복 패턴 감지
    const recurringPatterns = RecurringPatternDetector.detectRepeatSequences(
      this.data,
      this.config.windowSize,
      this.config.minFrequency
    );

    // 2. 슬라이딩 윈도우 패턴 추출
    const windowPatterns = PatternMatcher.extractPatterns(
      this.data,
      this.config.windowSize,
      this.config.minFrequency
    );

    // 3. 주기적 패턴 감지
    const periodicPatterns = RecurringPatternDetector.detectPeriodic(this.data);

    // 4. 모든 패턴 병합
    this.patterns = [
      ...recurringPatterns.map(p => ({
        ...p,
        type: 'repeating',
        id: `repeat-${this.patterns.length}`
      })),
      ...windowPatterns.map(p => ({
        ...p,
        type: 'window',
        id: `window-${this.patterns.length}`
      })),
      ...periodicPatterns.map(p => ({
        ...p,
        type: 'periodic',
        id: `periodic-${this.patterns.length}`
      }))
    ];

    return this.patterns.sort((a, b) => (b.frequency || b.strength) - (a.frequency || a.strength));
  }

  /**
   * 데이터 클러스터링
   */
  clustering(k = 3) {
    if (this.data.length === 0) return [];

    // 슬라이딩 윈도우로 벡터 변환
    const vectors = [];
    for (let i = 0; i <= this.data.length - this.config.windowSize; i++) {
      vectors.push(this.data.slice(i, i + this.config.windowSize));
    }

    if (vectors.length < k) {
      k = Math.max(1, vectors.length - 1);
    }

    this.clusters = KMeansClustering.cluster(vectors, k);

    return this.clusters;
  }

  /**
   * 유사 패턴 찾기
   */
  findSimilarPatterns(pattern) {
    if (this.patterns.length === 0) {
      this.recognize();
    }

    const similar = [];

    for (const p of this.patterns) {
      if (p.sequence) {
        const similarity = DistanceMetrics.cosine(pattern, p.sequence);
        if (similarity > this.config.similarityThreshold) {
          similar.push({
            pattern: p,
            similarity
          });
        }
      }
    }

    return similar.sort((a, b) => b.similarity - a.similarity);
  }

  /**
   * JSON 내보내기
   */
  toJSON() {
    return {
      totalDataPoints: this.data.length,
      patternsFound: this.patterns.length,
      patterns: this.patterns.slice(0, 5),  // 상위 5개
      clusters: this.clusters.length,
      config: {
        windowSize: this.config.windowSize,
        minFrequency: this.config.minFrequency
      }
    };
  }
}

// 테스트 코드
function runTests() {
