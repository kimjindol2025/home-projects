/**
 * 장애 주입기
 */
class FaultInjector {
  constructor() {
    this.faults = [];
    this.activeInjections = [];
  }

  /**
   * 네트워크 지연 주입
   */
  injectLatency(component, delayMs, duration) {
    const injection = {
      id: `latency-${Date.now()}`,
      type: 'latency',
      component,
      delayMs,
      duration,
      startTime: Date.now(),
      active: true
    };

    this.activeInjections.push(injection);
    this.faults.push(injection);

    return {
      success: true,
      injectionId: injection.id,
      type: 'latency',
      delayMs,
      duration
    };
  }

  /**
   * 에러율 주입
   */
  injectErrors(component, errorRate, duration) {
    const injection = {
      id: `error-${Date.now()}`,
      type: 'error',
      component,
      errorRate,  // %
      duration,
      startTime: Date.now(),
      active: true,
      triggeredCount: 0
    };

    this.activeInjections.push(injection);
    this.faults.push(injection);

    return {
      success: true,
      injectionId: injection.id,
      type: 'error',
      errorRate: errorRate + '%',
      duration
    };
  }

  /**
   * 리소스 제약 주입
   */
  injectResourceConstraint(component, limitType, limitValue, duration) {
    const injection = {
      id: `resource-${Date.now()}`,
      type: 'resource-constraint',
      component,
      limitType,  // 'cpu', 'memory', 'disk'
      limitValue,
      duration,
      startTime: Date.now(),
      active: true
    };

    this.activeInjections.push(injection);
    this.faults.push(injection);

    return {
      success: true,
      injectionId: injection.id,
      type: 'resource-constraint',
      limitType,
      limitValue,
      duration
    };
  }

  /**
   * 네트워크 분할 주입
   */
  injectNetworkPartition(component1, component2, duration) {
    const injection = {
      id: `partition-${Date.now()}`,
      type: 'network-partition',
      components: [component1, component2],
      duration,
      startTime: Date.now(),
      active: true
    };

    this.activeInjections.push(injection);
    this.faults.push(injection);

    return {
      success: true,
      injectionId: injection.id,
      type: 'network-partition',
      components: [component1, component2],
      duration
    };
  }

  /**
   * 복구 확인
   */
  checkRecovery(injectionId) {
    const injection = this.activeInjections.find(i => i.id === injectionId);

    if (!injection) {
      return { recovered: false, reason: 'Injection not found' };
    }

    const elapsed = Date.now() - injection.startTime;

    if (elapsed >= injection.duration) {
      injection.active = false;
      return {
        recovered: true,
        injectionId,
        recoveryTime: Math.round(elapsed) + 'ms',
        type: injection.type
      };
    }

    return {
      recovered: false,
      remaining: Math.round(injection.duration - elapsed) + 'ms'
    };
  }

  /**
   * 장애 정보
   */
  getInfo() {
    const activeFaults = this.activeInjections.filter(f => f.active).length;

    return {
      totalFaults: this.faults.length,
      activeFaults,
      faultTypes: {
        latency: this.faults.filter(f => f.type === 'latency').length,
        error: this.faults.filter(f => f.type === 'error').length,
        resourceConstraint: this.faults.filter(f => f.type === 'resource-constraint').length,
        networkPartition: this.faults.filter(f => f.type === 'network-partition').length
      }
    };
  }
}

/**
 * 복원력 검증기
 */
class ResilienceValidator {
  constructor() {
    this.tests = [];
    this.results = [];
  }

  /**
   * 복원력 테스트 추가
   */
  addTest(name, testFn, expectedRecoveryTime) {
    this.tests.push({
      name,
      testFn,
      expectedRecoveryTime
    });
  }

  /**
   * 테스트 실행
   */
  runTests() {
    const results = [];

    for (const test of this.tests) {
      const startTime = Date.now();

      try {
        test.testFn();
        const elapsed = Date.now() - startTime;

        const passed = elapsed <= test.expectedRecoveryTime;

        const result = {
          name: test.name,
          passed,
          actualRecoveryTime: elapsed + 'ms',
          expectedRecoveryTime: test.expectedRecoveryTime + 'ms',
          status: passed ? 'PASSED' : 'FAILED'
        };

        results.push(result);
        this.results.push(result);
      } catch (error) {
        results.push({
          name: test.name,
          passed: false,
          error: error.message,
          status: 'ERROR'
        });
      }
    }

    return results;
  }

  /**
   * 복원력 정보
   */
  getInfo() {
    const passed = this.results.filter(r => r.passed).length;
    const failed = this.results.filter(r => !r.passed).length;

    return {
      totalTests: this.results.length,
      passed,
      failed,
      passRate: this.results.length > 0 ? (passed / this.results.length * 100).toFixed(2) + '%' : 'N/A',
      results: this.results
    };
  }
}

/**
 * 자동 복구 검증기
 */
class AutoRecoveryValidator {
  constructor() {
    this.recoveryActions = [];
    this.metrics = [];
  }

  /**
   * 복구 액션 등록
   */
  registerRecoveryAction(condition, action) {
    this.recoveryActions.push({
      condition,
      action,
      triggered: false,
      triggerCount: 0
    });
  }

  /**
   * 메트릭 확인 및 복구 실행
   */
  checkAndRecover(metric) {
    const recoveredActions = [];

    for (const recoveryAction of this.recoveryActions) {
      if (recoveryAction.condition(metric)) {
        recoveryAction.action();
        recoveryAction.triggered = true;
        recoveryAction.triggerCount++;

        recoveredActions.push({
          condition: recoveryAction.condition.toString(),
          executed: true,
          timestamp: Date.now()
        });
      }
    }

    this.metrics.push({
      timestamp: Date.now(),
      metric,
      recoveredActions
    });

    return {
      success: true,
      recoveredCount: recoveredActions.length,
      actions: recoveredActions
    };
  }

  /**
   * 복구 정보
   */
  getInfo() {
    const triggered = this.recoveryActions.filter(a => a.triggered).length;

    return {
      registeredActions: this.recoveryActions.length,
      triggeredActions: triggered,
      totalTriggers: this.recoveryActions.reduce((sum, a) => sum + a.triggerCount, 0),
      metricsChecked: this.metrics.length
    };
  }
}

/**
 * 카오스 테스트 러너
 */
class ChaosTestRunner {
  constructor() {
    this.faultInjector = new FaultInjector();
    this.resilienceValidator = new ResilienceValidator();
    this.recoveryValidator = new AutoRecoveryValidator();
    this.scenarios = [];
  }

  /**
   * 카오스 시나리오 추가
   */
  addScenario(name, faultType, component, duration) {
    this.scenarios.push({
      name,
      faultType,
      component,
      duration,
      executed: false
    });
  }

  /**
   * 모든 시나리오 실행
   */
  runAllScenarios() {
    const results = [];

    for (const scenario of this.scenarios) {
      try {
        let injectionResult;

        if (scenario.faultType === 'latency') {
          injectionResult = this.faultInjector.injectLatency(scenario.component, 500, scenario.duration);
        } else if (scenario.faultType === 'error') {
          injectionResult = this.faultInjector.injectErrors(scenario.component, 10, scenario.duration);
        } else if (scenario.faultType === 'resource') {
          injectionResult = this.faultInjector.injectResourceConstraint(scenario.component, 'memory', 50, scenario.duration);
        } else if (scenario.faultType === 'partition') {
          injectionResult = this.faultInjector.injectNetworkPartition(scenario.component, 'peer-service', scenario.duration);
        }

        scenario.executed = true;

        results.push({
          scenario: scenario.name,
          type: scenario.faultType,
          injected: injectionResult.success,
          injectionId: injectionResult.injectionId
        });
      } catch (error) {
        results.push({
          scenario: scenario.name,
          type: scenario.faultType,
          injected: false,
          error: error.message
        });
      }
    }

    return results;
  }

  /**
   * 종합 보고서
   */
  generateReport() {
    return {
      timestamp: new Date().toISOString(),
      faults: this.faultInjector.getInfo(),
      resilience: this.resilienceValidator.getInfo(),
      recovery: this.recoveryValidator.getInfo(),
      scenarios: this.scenarios.length,
      executedScenarios: this.scenarios.filter(s => s.executed).length,
      overallStatus: this.resilienceValidator.getInfo().passRate !== 'N/A' ? 'COMPLETED' : 'PENDING'
    };
  }
}

