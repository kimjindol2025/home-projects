#!/usr/bin/env node

/**
 * Optimization Suggester - 최적화 제안
 * Phase 9.4: 예측 분석
 *
 * 기능:
 * - 최적화 기회 식별
 * - 우선순위 계산
 * - 영향도 평가
 * - 비용-이득 분석
 */

/**
 * 최적화 제안
 */
class OptimizationSuggestion {
  constructor(id, title, description, category) {
    this.id = id;
    this.title = title;
    this.description = description;
    this.category = category;        // performance, resource, cost, reliability
    this.priority = 'medium';        // low, medium, high, critical
    this.estimatedImpact = 0;        // 0-100
    this.estimatedEffort = 0;        // 0-100
    this.roi = 0;                    // return on investment
    this.confidence = 0;             // 신뢰도
  }
}

/**
 * 성능 분석기
 */
class PerformanceAnalyzer {
  /**
   * 성능 병목 식별
   */
  static identifyBottlenecks(metrics) {
    const bottlenecks = [];

    // CPU 사용률
    if (metrics.cpuUsage > 80) {
      bottlenecks.push({
        type: 'cpu',
        severity: metrics.cpuUsage > 95 ? 'critical' : 'high',
        value: metrics.cpuUsage,
        recommendation: 'CPU 최적화, 멀티스레딩, 병렬 처리'
      });
    }

    // 메모리 사용률
    if (metrics.memoryUsage > 85) {
      bottlenecks.push({
        type: 'memory',
        severity: metrics.memoryUsage > 95 ? 'critical' : 'high',
        value: metrics.memoryUsage,
        recommendation: '메모리 누수 제거, 캐시 최적화, 가비지 컬렉션'
      });
    }

    // I/O 지연
    if (metrics.ioLatency > 100) {
      bottlenecks.push({
        type: 'io',
        severity: metrics.ioLatency > 500 ? 'critical' : 'high',
        value: metrics.ioLatency,
        recommendation: 'I/O 캐싱, 비동기 처리, 데이터베이스 인덱싱'
      });
    }

    // 네트워크 대역폭
    if (metrics.networkUsage > 80) {
      bottlenecks.push({
        type: 'network',
        severity: metrics.networkUsage > 95 ? 'critical' : 'medium',
        value: metrics.networkUsage,
        recommendation: '데이터 압축, CDN 사용, API 배치 처리'
      });
    }

    return bottlenecks;
  }

  /**
   * 처리량 개선 기회
   */
  static analyzeThroughput(throughput, capacity) {
    const utilizationRate = throughput / capacity;
    const headroom = 1 - utilizationRate;

    return {
      utilizationRate: utilizationRate * 100,
      headroom: headroom * 100,
      recommendation: headroom < 0.2 ? 'critical' : headroom < 0.5 ? 'high' : 'normal',
      potentialIncrease: capacity * 0.2
    };
  }
}

/**
 * 자원 최적화 분석기
 */
class ResourceOptimizer {
  /**
   * 비용 절감 기회
   */
  static analyzeCostSavings(resources) {
    const opportunities = [];

    // 미사용 리소스
    if (resources.unusedInstances > 0) {
      opportunities.push({
        type: 'unused-resources',
        quantity: resources.unusedInstances,
        monthlySavings: resources.costPerInstance * resources.unusedInstances,
        priority: 'high'
      });
    }

    // 과도한 리소스 할당
    if (resources.overAllocatedPercentage > 20) {
      opportunities.push({
        type: 'over-allocation',
        percentage: resources.overAllocatedPercentage,
        monthlySavings: resources.totalMonthlySpend * (resources.overAllocatedPercentage / 100),
        priority: 'medium'
      });
    }

    // 이전 버전 사용
    if (resources.legacyComponentPercentage > 10) {
      opportunities.push({
        type: 'legacy-upgrade',
        percentage: resources.legacyComponentPercentage,
        monthlySavings: resources.totalMonthlySpend * 0.15,
        priority: 'medium'
      });
    }

    return opportunities.sort((a, b) => b.monthlySavings - a.monthlySavings);
  }

  /**
   * 확장성 개선
   */
  static analyzeScalability(currentLoad, peakLoad, capacity) {
    const scaleUpFactor = peakLoad / currentLoad;
    const headroom = (capacity - peakLoad) / capacity;

    return {
      scaleUpFactor,
      isScalable: scaleUpFactor <= 2,
      headroom: headroom * 100,
      recommendation: scaleUpFactor > 3 ? 'critical' : scaleUpFactor > 2 ? 'high' : 'normal',
      requiredCapacity: peakLoad * 1.2
    };
  }
}

/**
 * 신뢰성 분석기
 */
class ReliabilityAnalyzer {
  /**
   * 장애점 식별
   */
  static identifyFailurePoints(components) {
    const failures = [];

    for (const comp of components) {
      if (comp.mtbf < 100) {  // 평균 무장애 시간 (시간)
        failures.push({
          component: comp.name,
          mtbf: comp.mtbf,
          availability: comp.availability,
          riskLevel: comp.mtbf < 50 ? 'critical' : 'high',
          recommendation: '중복성 추가, 모니터링 강화, 예방 유지보수'
        });
      }
    }

    return failures.sort((a, b) => a.mtbf - b.mtbf);
  }

  /**
   * SLA 준수 분석
   */
  static analyzeSLACompliance(targets, actuals) {
    const analysis = [];

    for (const key in targets) {
      const target = targets[key];
      const actual = actuals[key] || 0;
      const compliance = (actual / target) * 100;

      analysis.push({
        metric: key,
        target,
        actual,
        compliance,
        status: compliance >= 95 ? 'pass' : compliance >= 85 ? 'warning' : 'fail'
      });
    }

    return analysis;
  }
}

/**
 * ROI 계산기
 */
class ROICalculator {
  /**
   * ROI 계산
   */
  static calculateROI(investment, benefit, timeframe) {
    const roi = ((benefit - investment) / investment) * 100;
    const paybackPeriod = investment / (benefit / timeframe);

    return {
      roi: roi.toFixed(2),
      paybackPeriod: paybackPeriod.toFixed(2),
      netBenefit: (benefit - investment).toFixed(2),
      roiPerYear: (roi / timeframe).toFixed(2)
    };
  }

  /**
   * 우선순위 점수 계산
   */
  static calculatePriorityScore(impact, effort, urgency = 1) {
    // 영향 / 노력 × 긴급성
    const score = (impact / (effort || 1)) * urgency;
    return Math.min(100, score * 10);
  }

  /**
   * 실행 순서 최적화
   */
  static optimizeExecutionOrder(suggestions) {
    return suggestions.sort((a, b) => {
      const scoreA = this.calculatePriorityScore(a.estimatedImpact, a.estimatedEffort);
      const scoreB = this.calculatePriorityScore(b.estimatedImpact, b.estimatedEffort);
      return scoreB - scoreA;
    });
  }
}

/**
 * 통합 최적화 제안기
 */
class OptimizationSuggester {
  constructor(config = {}) {
    this.config = {
      performanceWeight: config.performanceWeight || 0.3,
      costWeight: config.costWeight || 0.3,
      reliabilityWeight: config.reliabilityWeight || 0.2,
      scalabilityWeight: config.scalabilityWeight || 0.2,
      ...config
    };

    this.suggestions = [];
    this.metrics = null;
  }

  /**
   * 메트릭 로드
   */
  loadMetrics(metrics) {
    this.metrics = metrics;
    return this;
  }

  /**
   * 최적화 제안 생성
   */
  generate() {
    if (!this.metrics) return [];

    const suggestions = [];

    // 1. 성능 병목 분석
    const bottlenecks = PerformanceAnalyzer.identifyBottlenecks(this.metrics);
    for (const bn of bottlenecks) {
      const suggestion = new OptimizationSuggestion(
        `perf-${bn.type}`,
        `${bn.type.toUpperCase()} 병목 해결`,
        bn.recommendation,
        'performance'
      );
      suggestion.priority = bn.severity;
      suggestion.estimatedImpact = 100 - bn.value;
      suggestion.estimatedEffort = bn.severity === 'critical' ? 80 : 60;
      suggestion.confidence = 0.95;
      suggestions.push(suggestion);
    }

    // 2. 처리량 분석
    if (this.metrics.throughput && this.metrics.capacity) {
      const tp = PerformanceAnalyzer.analyzeThroughput(
        this.metrics.throughput,
        this.metrics.capacity
      );

      if (tp.headroom < 20) {
        const suggestion = new OptimizationSuggestion(
          'throughput-increase',
          '처리량 증대 필요',
          '용량 확장 또는 로드 밸런싱',
          'performance'
        );
        suggestion.priority = tp.recommendation === 'critical' ? 'critical' : 'high';
        suggestion.estimatedImpact = 40;
        suggestion.estimatedEffort = 70;
        suggestion.confidence = 0.9;
        suggestions.push(suggestion);
      }
    }

    // 3. 비용 절감 기회
    if (this.metrics.resources) {
      const opportunities = ResourceOptimizer.analyzeCostSavings(this.metrics.resources);
      for (const opp of opportunities.slice(0, 2)) {
        const suggestion = new OptimizationSuggestion(
          `cost-${opp.type}`,
          `${opp.type} 제거`,
          `월별 ${Math.round(opp.monthlySavings)}원 절감 가능`,
          'cost'
        );
        suggestion.priority = opp.priority;
        suggestion.estimatedImpact = 50;
        suggestion.estimatedEffort = 30;
        suggestion.confidence = 0.85;
        suggestion.roi = opp.monthlySavings * 12;
        suggestions.push(suggestion);
      }
    }

    // 4. 신뢰성 개선
    if (this.metrics.components) {
      const failures = ReliabilityAnalyzer.identifyFailurePoints(this.metrics.components);
      for (const fail of failures.slice(0, 2)) {
        const suggestion = new OptimizationSuggestion(
          `reliability-${fail.component}`,
          `${fail.component} 신뢰성 개선`,
          fail.recommendation,
          'reliability'
        );
        suggestion.priority = fail.riskLevel;
        suggestion.estimatedImpact = 60;
        suggestion.estimatedEffort = 50;
        suggestion.confidence = 0.8;
        suggestions.push(suggestion);
      }
    }

    // 5. ROI 계산 및 우선순위 정렬
    for (const suggestion of suggestions) {
      if (suggestion.roi === 0 && suggestion.estimatedImpact > 0) {
        const roi = ROICalculator.calculateROI(
          suggestion.estimatedEffort * 10000,
          suggestion.estimatedImpact * 5000,
          1
        );
        suggestion.roi = parseFloat(roi.roi);
      }

      suggestion.priority = this.determinePriority(suggestion);
    }

    this.suggestions = ROICalculator.optimizeExecutionOrder(suggestions);
    return this.suggestions;
  }

  /**
   * 우선순위 결정
   */
  determinePriority(suggestion) {
    const score = ROICalculator.calculatePriorityScore(
      suggestion.estimatedImpact,
      suggestion.estimatedEffort
    );

    if (suggestion.priority === 'critical') {
      return 'critical';
    } else if (score > 70 || suggestion.priority === 'high') {
      return 'high';
    } else if (score > 40) {
      return 'medium';
    } else {
      return 'low';
    }
  }

  /**
   * 실행 계획 생성
   */
  generateExecutionPlan(maxSuggestions = 5) {
    const plan = [];

    for (let i = 0; i < Math.min(maxSuggestions, this.suggestions.length); i++) {
      const suggestion = this.suggestions[i];
      plan.push({
        phase: i + 1,
        title: suggestion.title,
        description: suggestion.description,
        estimatedEffort: suggestion.estimatedEffort,
        expectedImpact: suggestion.estimatedImpact,
        priority: suggestion.priority,
        roi: suggestion.roi,
        effort: `${suggestion.estimatedEffort} points`
      });
    }

    return plan;
  }

  /**
   * JSON 내보내기
   */
  toJSON() {
    return {
      totalSuggestions: this.suggestions.length,
      byCriticality: {
        critical: this.suggestions.filter(s => s.priority === 'critical').length,
        high: this.suggestions.filter(s => s.priority === 'high').length,
        medium: this.suggestions.filter(s => s.priority === 'medium').length,
        low: this.suggestions.filter(s => s.priority === 'low').length
      },
      byCategory: {
        performance: this.suggestions.filter(s => s.category === 'performance').length,
        cost: this.suggestions.filter(s => s.category === 'cost').length,
        reliability: this.suggestions.filter(s => s.category === 'reliability').length,
        scalability: this.suggestions.filter(s => s.category === 'scalability').length
      },
      topSuggestions: this.suggestions.slice(0, 3)
    };
  }
}

