#!/usr/bin/env node

/**
 * Log Aggregator - 로그 집계
 * Phase 10.4: Enterprise Deployment
 *
 * 기능:
 * - 다중 소스 로그 수집
 * - 로그 필터링 및 검색
 * - 로그 저장소 관리
 * - 이상 탐지
 */

/**
 * 로그 수집기
 */
class LogCollector {
  constructor() {
    this.logs = [];
    this.sources = new Set();
  }

  /**
   * 로그 기록
   */
  recordLog(source, level, message, metadata = {}) {
    const log = {
      timestamp: Date.now(),
      source,
      level,  // DEBUG, INFO, WARN, ERROR, FATAL
      message,
      metadata,
      id: `log-${Date.now()}-${Math.random().toString(36).slice(2)}`
    };

    this.logs.push(log);
    this.sources.add(source);

    // 최근 10000개만 유지
    if (this.logs.length > 10000) {
      this.logs.shift();
    }

    return log;
  }

  /**
   * 로그 필터링
   */
  filterLogs(filters) {
    let filtered = this.logs;

    if (filters.source) {
      filtered = filtered.filter(l => l.source === filters.source);
    }

    if (filters.level) {
      const levels = ['DEBUG', 'INFO', 'WARN', 'ERROR', 'FATAL'];
      const minLevel = levels.indexOf(filters.level);
      filtered = filtered.filter(l => levels.indexOf(l.level) >= minLevel);
    }

    if (filters.startTime) {
      filtered = filtered.filter(l => l.timestamp >= filters.startTime);
    }

    if (filters.endTime) {
      filtered = filtered.filter(l => l.timestamp <= filters.endTime);
    }

    if (filters.keyword) {
      filtered = filtered.filter(l => l.message.includes(filters.keyword));
    }

    return filtered;
  }

  /**
   * 로그 통계
   */
  getStatistics() {
    const levelCounts = {};
    const sourceCounts = {};

    for (const log of this.logs) {
      levelCounts[log.level] = (levelCounts[log.level] || 0) + 1;
      sourceCounts[log.source] = (sourceCounts[log.source] || 0) + 1;
    }

    return {
      totalLogs: this.logs.length,
      levelCounts,
      sourceCounts,
      sources: Array.from(this.sources)
    };
  }

  /**
   * 로그 정보
   */
  getInfo() {
    return {
      totalLogs: this.logs.length,
      sources: this.sources.size,
      statistics: this.getStatistics()
    };
  }
}

/**
 * 로그 저장소
 */
class LogRepository {
  constructor() {
    this.buckets = new Map();  // 날짜별 로그 그룹
  }

  /**
   * 로그 저장
   */
  storeLogs(logs) {
    for (const log of logs) {
      const date = new Date(log.timestamp).toISOString().split('T')[0];

      if (!this.buckets.has(date)) {
        this.buckets.set(date, []);
      }

      this.buckets.get(date).push(log);
    }

    return {
      success: true,
      logsStored: logs.length,
      bucketCount: this.buckets.size
    };
  }

  /**
   * 날짜별 로그 조회
   */
  getLogsByDate(date) {
    return this.buckets.get(date) || [];
  }

  /**
   * 저장소 정보
   */
  getInfo() {
    let totalLogs = 0;
    for (const bucket of this.buckets.values()) {
      totalLogs += bucket.length;
    }

    return {
      totalLogsByDate: this.buckets.size,
      totalLogs,
      dates: Array.from(this.buckets.keys()).sort()
    };
  }
}

/**
 * 이상 탐지기
 */
class AnomalyDetector {
  constructor() {
    this.errorThreshold = 10;  // 시간당 에러 수 임계값
    this.anomalies = [];
  }

  /**
   * 이상 탐지
   */
  detectAnomalies(logs) {
    const errors = logs.filter(l => l.level === 'ERROR' || l.level === 'FATAL');

    if (errors.length === 0) {
      return { anomalies: [], detected: false };
    }

    // 시간 그룹화
    const hourlyErrors = {};

    for (const error of errors) {
      const hour = new Date(error.timestamp).getHours();
      hourlyErrors[hour] = (hourlyErrors[hour] || 0) + 1;
    }

    // 임계값 초과 확인
    const detectedAnomalies = [];

    for (const [hour, count] of Object.entries(hourlyErrors)) {
      if (count > this.errorThreshold) {
        const anomaly = {
          timestamp: Date.now(),
          type: 'high-error-rate',
          hour,
          errorCount: count,
          threshold: this.errorThreshold,
          severity: count > this.errorThreshold * 3 ? 'CRITICAL' : 'HIGH'
        };

        detectedAnomalies.push(anomaly);
        this.anomalies.push(anomaly);
      }
    }

    return {
      anomalies: detectedAnomalies,
      detected: detectedAnomalies.length > 0
    };
  }

  /**
   * 이상 정보
   */
  getInfo() {
    return {
      totalAnomalies: this.anomalies.length,
      recentAnomalies: this.anomalies.slice(-10)
    };
  }
}

/**
 * 로그 수집 시스템
 */
class LogAggregationSystem {
  constructor() {
    this.collector = new LogCollector();
    this.repository = new LogRepository();
    this.anomalyDetector = new AnomalyDetector();
  }

  /**
   * 로그 수집 및 저장
   */
  ingestLogs(sourceLogs) {
    // 로그 수집
    const collectedLogs = [];

    for (const log of sourceLogs) {
      const collected = this.collector.recordLog(
        log.source,
        log.level,
        log.message,
        log.metadata || {}
      );
      collectedLogs.push(collected);
    }

    // 저장소에 저장
    this.repository.storeLogs(collectedLogs);

    // 이상 탐지
    const anomalyResult = this.anomalyDetector.detectAnomalies(collectedLogs);

    return {
      success: true,
      logsIngested: collectedLogs.length,
      anomaliesDetected: anomalyResult.detected,
      anomalies: anomalyResult.anomalies
    };
  }

  /**
   * 로그 검색
   */
  searchLogs(filters) {
    const filtered = this.collector.filterLogs(filters);

    return {
      success: true,
      matchCount: filtered.length,
      logs: filtered.slice(-100)  // 최근 100개
    };
  }

  /**
   * 분석 리포트
   */
  generateAnalysisReport(startTime, endTime) {
    const logsInRange = this.collector.filterLogs({
      startTime,
      endTime
    });

    const errorLogs = logsInRange.filter(l => l.level === 'ERROR' || l.level === 'FATAL');
    const warnLogs = logsInRange.filter(l => l.level === 'WARN');

    const topSources = {};

    for (const log of logsInRange) {
      topSources[log.source] = (topSources[log.source] || 0) + 1;
    }

    const sortedSources = Object.entries(topSources)
      .sort((a, b) => b[1] - a[1])
      .slice(0, 5);

    return {
      timeRange: {
        start: new Date(startTime).toISOString(),
        end: new Date(endTime).toISOString()
      },
      totalLogs: logsInRange.length,
      errorCount: errorLogs.length,
      warningCount: warnLogs.length,
      errorRate: logsInRange.length > 0 ? (errorLogs.length / logsInRange.length * 100).toFixed(2) + '%' : '0%',
      topSources: Object.fromEntries(sortedSources),
      anomalies: this.anomalyDetector.anomalies.filter(
        a => a.timestamp >= startTime && a.timestamp <= endTime
      )
    };
  }

  /**
   * 시스템 상태
   */
  getStatus() {
    return {
      collector: this.collector.getInfo(),
      repository: this.repository.getInfo(),
      anomalies: this.anomalyDetector.getInfo(),
      systemHealth: this.anomalyDetector.anomalies.length === 0 ? 'HEALTHY' : 'DEGRADED'
    };
  }
}

