#!/usr/bin/env node

/**
 * AI Security Analyzer - 보안 취약점 탐지
 * Phase 9.0: AI 강화
 *
 * 기능:
 * - 보안 취약점 탐지 (OWASP Top 10)
 * - 의존성 보안 분석
 * - 권한 관리 검증
 * - 암호화 강도 평가
 */

class SecurityAnalyzer {
  constructor() {
    this.vulnerabilities = [];
    this.riskScore = 0;
    this.recommendations = [];
  }

  /**
   * OWASP Top 10 취약점 탐지
   */
  detectOWASPVulnerabilities(code) {
    const vulnerabilities = [];

    // 1. Injection (SQL, OS, LDAP, XPath)
    if (this.detectInjectionVulnerabilities(code)) {
      vulnerabilities.push({
        owasp: 'A1:2021 - Injection',
        severity: 'CRITICAL',
        type: 'INJECTION',
        description: 'SQL 인젝션, OS 명령어 인젝션 위험',
        locations: this.findInjectionPatterns(code),
        remediation: '파라미터화된 쿼리, 입력 검증 사용'
      });
      this.riskScore += 25;
    }

    // 2. Broken Authentication
    if (this.detectAuthenticationIssues(code)) {
      vulnerabilities.push({
        owasp: 'A2:2021 - Broken Authentication',
        severity: 'CRITICAL',
        type: 'AUTH_ISSUE',
        description: '약한 인증, 세션 관리 부재',
        locations: this.findAuthenticationIssues(code),
        remediation: '강력한 인증, 세션 타임아웃 설정'
      });
      this.riskScore += 20;
    }

    // 3. Broken Access Control
    if (this.detectAccessControlIssues(code)) {
      vulnerabilities.push({
        owasp: 'A3:2021 - Broken Access Control',
        severity: 'CRITICAL',
        type: 'ACCESS_CONTROL',
        description: '권한 검증 부재, 수평적 특권 상승',
        locations: this.findAccessControlIssues(code),
        remediation: '모든 요청에 권한 검증 추가'
      });
      this.riskScore += 15;
    }

    // 4. SQL Injection
    const sqlInjections = this.findSQLInjections(code);
    if (sqlInjections.length > 0) {
      vulnerabilities.push({
        owasp: 'A3:2021 - SQL Injection',
        severity: 'CRITICAL',
        type: 'SQL_INJECTION',
        description: '동적 SQL 쿼리 생성',
        locations: sqlInjections,
        remediation: 'Prepared Statements 또는 ORM 사용'
      });
      this.riskScore += 25;
    }

    // 5. XSS (Cross-Site Scripting)
    const xssIssues = this.findXSSVulnerabilities(code);
    if (xssIssues.length > 0) {
      vulnerabilities.push({
        owasp: 'A7:2021 - Cross-Site Scripting',
        severity: 'HIGH',
        type: 'XSS',
        description: 'DOM, Stored, Reflected XSS 위험',
        locations: xssIssues,
        remediation: 'Output Encoding, CSP 헤더 설정'
      });
      this.riskScore += 15;
    }

    // 6. CSRF (Cross-Site Request Forgery)
    if (this.detectCSRFVulnerability(code)) {
      vulnerabilities.push({
        owasp: 'A1:2021 - CSRF Token Absence',
        severity: 'HIGH',
        type: 'CSRF',
        description: 'CSRF 토큰 부재',
        locations: [],
        remediation: 'CSRF 토큰 구현 및 검증'
      });
      this.riskScore += 10;
    }

    // 7. Security Misconfiguration
    if (this.detectSecurityMisconfig(code)) {
      vulnerabilities.push({
        owasp: 'A5:2021 - Security Misconfiguration',
        severity: 'MEDIUM',
        type: 'MISCONFIG',
        description: '디버그 모드 활성화, 보안 헤더 부재',
        locations: [],
        remediation: '보안 헤더 설정, 디버그 비활성화'
      });
      this.riskScore += 10;
    }

    // 8. Using Components with Known Vulnerabilities
    if (this.detectOutdatedDependencies(code)) {
      vulnerabilities.push({
        owasp: 'A6:2021 - Vulnerable Dependencies',
        severity: 'HIGH',
        type: 'OLD_DEPS',
        description: '취약한 버전의 라이브러리 사용',
        locations: [],
        remediation: '의존성 업데이트, 보안 패치 적용'
      });
      this.riskScore += 15;
    }

    // 9. Insufficient Logging & Monitoring
    if (this.detectLoggingIssues(code)) {
      vulnerabilities.push({
        owasp: 'A9:2021 - Security Logging & Monitoring',
        severity: 'MEDIUM',
        type: 'NO_LOGGING',
        description: '보안 이벤트 로깅 부재',
        locations: [],
        remediation: '감사 로깅 및 모니터링 구현'
      });
      this.riskScore += 8;
    }

    this.vulnerabilities = vulnerabilities;
    return vulnerabilities;
  }

  /**
   * 인젝션 취약점 탐지
   */
  detectInjectionVulnerabilities(code) {
    return /\+|concat|format|template/.test(code) && /query|execute|eval|system/i.test(code);
  }

  /**
   * 인젝션 패턴 찾기
   */
  findInjectionPatterns(code) {
    const patterns = [];
    const lines = code.split('\n');

    lines.forEach((line, i) => {
      if (/SELECT|UPDATE|DELETE|INSERT/.test(line) && /\+|concat|`\$/.test(line)) {
        patterns.push({
          line: i + 1,
          code: line.trim().substring(0, 70)
        });
      }
    });

    return patterns;
  }

  /**
   * 인증 문제 탐지
   */
  detectAuthenticationIssues(code) {
    return !/password|token|session|auth/i.test(code) || /password.*===|hardcoded.*password/i.test(code);
  }

  /**
   * 인증 문제 찾기
   */
  findAuthenticationIssues(code) {
    const issues = [];

    if (/password\s*[:=]\s*['"][^'"]{3,}['"]/i.test(code)) {
      issues.push({
        type: 'HARDCODED_PASSWORD',
        message: '하드코딩된 비밀번호'
      });
    }

    if (/token.*=.*['"][^'"]{3,}['"]/i.test(code)) {
      issues.push({
        type: 'HARDCODED_TOKEN',
        message: '하드코딩된 토큰'
      });
    }

    return issues;
  }

  /**
   * 접근 제어 문제 탐지
   */
  detectAccessControlIssues(code) {
    return !/permission|authorize|role|privilege|admin|user\.id/.test(code);
  }

  /**
   * 접근 제어 문제 찾기
   */
  findAccessControlIssues(code) {
    return [];
  }

  /**
   * SQL 인젝션 찾기
   */
  findSQLInjections(code) {
    const injections = [];
    const sqlPatterns = [
      /SELECT.*\+.*\$/,
      /UPDATE.*WHERE.*\+/,
      /DELETE.*FROM.*\+/,
      /INSERT.*VALUES.*\+/
    ];

    const lines = code.split('\n');
    lines.forEach((line, i) => {
      sqlPatterns.forEach(pattern => {
        if (pattern.test(line)) {
          injections.push({
            line: i + 1,
            code: line.trim(),
            suggestion: 'Prepared Statement 또는 ORM 사용'
          });
        }
      });
    });

    return injections;
  }

  /**
   * XSS 취약점 찾기
   */
  findXSSVulnerabilities(code) {
    const xsses = [];
    const lines = code.split('\n');

    lines.forEach((line, i) => {
      if (/innerHTML\s*=.*\$|innerHTML\s*=.*\+|innerHTML\s*=.*template/.test(line)) {
        xsses.push({
          line: i + 1,
          type: 'DOM_XSS',
          code: line.trim(),
          suggestion: 'textContent 또는 sanitization 라이브러리 사용'
        });
      }

      if (/document\.write|eval\(/gi.test(line)) {
        xsses.push({
          line: i + 1,
          type: 'DANGEROUS_API',
          code: line.trim(),
          suggestion: 'document.write/eval 피하고 안전한 DOM API 사용'
        });
      }
    });

    return xsses;
  }

  /**
   * CSRF 취약점 탐지
   */
  detectCSRFVulnerability(code) {
    return !/csrf|token|nonce/.test(code) && /POST|PUT|DELETE/.test(code);
  }

  /**
   * 보안 설정 오류 탐지
   */
  detectSecurityMisconfig(code) {
    return /debug.*true|console\.log|debugger|process\.env\.DEBUG/i.test(code);
  }

  /**
   * 오래된 의존성 탐지
   */
  detectOutdatedDependencies(code) {
    return /require\(|import\s+/i.test(code);
  }

  /**
   * 로깅 문제 탐지
   */
  detectLoggingIssues(code) {
    return !/log|audit|trace|monitor|event/.test(code);
  }

  /**
   * 암호화 강도 평가
   */
  evaluateEncryptionStrength(code) {
    const evaluation = {
      status: 'UNKNOWN',
      score: 0,
      issues: []
    };

    // MD5 사용 (약함)
    if (/md5/i.test(code)) {
      evaluation.issues.push({
        severity: 'CRITICAL',
        message: 'MD5 해시 사용 (약함, 충돌 가능)',
        remediation: 'SHA-256 또는 bcrypt 사용'
      });
      evaluation.score += 20;
    }

    // SHA-1 사용 (약함)
    if (/sha1|sha-1/i.test(code)) {
      evaluation.issues.push({
        severity: 'HIGH',
        message: 'SHA-1 사용 (약함)',
        remediation: 'SHA-256 또는 SHA-512 사용'
      });
      evaluation.score += 15;
    }

    // 강력한 해시 사용
    if (/bcrypt|scrypt|argon2|sha256|sha512/i.test(code)) {
      evaluation.score += 10;
    }

    // TLS/SSL 사용
    if (/https|tls|ssl|crypto|cipher/i.test(code)) {
      evaluation.score += 15;
    }

    // 암호화 없음
    if (!/encrypt|cipher|crypto|tls|https/.test(code) && /password|token|secret|key/i.test(code)) {
      evaluation.issues.push({
        severity: 'CRITICAL',
        message: '암호화 부재: 민감한 데이터 평문 저장',
        remediation: '적절한 암호화 알고리즘 구현'
      });
      evaluation.score += 30;
    }

    evaluation.status = evaluation.score < 25 ? 'STRONG' : evaluation.score < 50 ? 'FAIR' : 'WEAK';

    return evaluation;
  }

  /**
   * 의존성 보안 검증
   */
  validateDependencySecurity(packageJson) {
    const report = {
      totalDependencies: 0,
      vulnerableDependencies: [],
      outdatedDependencies: [],
      riskyDependencies: []
    };

    // 예시: 알려진 취약한 패키지
    const riskyPackages = {
      'lodash': { version: '<4.17.21', severity: 'MEDIUM', cve: 'CVE-2021-23337' },
      'moment': { version: '<2.29.1', severity: 'LOW', cve: 'CVE-2022-31129' },
      'serialize-javascript': { version: '<3.1.0', severity: 'HIGH', cve: 'CVE-2020-7660' }
    };

    if (packageJson && packageJson.dependencies) {
      report.totalDependencies = Object.keys(packageJson.dependencies).length;

      // 각 의존성 검증
      for (const [pkg, version] of Object.entries(packageJson.dependencies)) {
        if (riskyPackages[pkg]) {
          report.vulnerableDependencies.push({
            package: pkg,
            version,
            severity: riskyPackages[pkg].severity,
            cve: riskyPackages[pkg].cve,
            remediation: `Update to ${riskyPackages[pkg].version}`
          });
        }
      }
    }

    return report;
  }

  /**
   * 종합 보안 보고서
   */
  generateSecurityReport(code, packageJson = null) {
    const owasp = this.detectOWASPVulnerabilities(code);
    const encryption = this.evaluateEncryptionStrength(code);
    const dependencies = this.validateDependencySecurity(packageJson);

    const report = {
      vulnerabilities: owasp,
      encryption: encryption,
      dependencies: dependencies,
      riskScore: this.riskScore,
      riskLevel: this.getRiskLevel(),
      summary: {
        critical: owasp.filter(v => v.severity === 'CRITICAL').length,
        high: owasp.filter(v => v.severity === 'HIGH').length,
        medium: owasp.filter(v => v.severity === 'MEDIUM').length,
        low: owasp.filter(v => v.severity === 'LOW').length
      },
      recommendations: this.generateRecommendations(owasp, encryption)
    };

    return report;
  }

  /**
   * 위험도 계산
   */
  getRiskLevel() {
    if (this.riskScore > 80) return 'CRITICAL';
    if (this.riskScore > 60) return 'HIGH';
    if (this.riskScore > 40) return 'MEDIUM';
    if (this.riskScore > 20) return 'LOW';
    return 'MINIMAL';
  }

  /**
   * 권장사항 생성
   */
  generateRecommendations(vulnerabilities, encryption) {
    const recommendations = [];

    // 즉시 조치 필요
    const critical = vulnerabilities.filter(v => v.severity === 'CRITICAL');
    if (critical.length > 0) {
      recommendations.push({
        priority: 'CRITICAL',
        action: `즉시 ${critical.length}개의 중대 취약점 해결 필요`,
        items: critical.map(v => v.type)
      });
    }

    // 암호화 개선
    if (encryption.status === 'WEAK') {
      recommendations.push({
        priority: 'HIGH',
        action: '암호화 강도 개선',
        suggestions: [
          'MD5/SHA-1 대신 SHA-256 또는 bcrypt 사용',
          'TLS/SSL로 전송 중 데이터 보호',
          '저장된 민감 데이터 암호화'
        ]
      });
    }

    // 모니터링 추가
    recommendations.push({
      priority: 'MEDIUM',
      action: '보안 모니터링 및 로깅 구현',
      suggestions: [
        '감사 로그 활성화',
        '보안 이벤트 모니터링',
        '침입 탐지 시스템 설정'
      ]
    });

    return recommendations;
  }

  /**
   * 보고서 포맷팅
   */
  formatReport(report) {
    let output = '';
    output += '═'.repeat(70) + '\n';
    output += '🔒 SECURITY ANALYSIS REPORT\n';
    output += '═'.repeat(70) + '\n\n';

    output += `📊 Risk Score: ${report.riskScore}/100\n`;
    output += `Risk Level: ${report.riskLevel}\n\n`;

    output += `⚠️  Vulnerabilities:\n`;
    output += `  • Critical: ${report.summary.critical}\n`;
    output += `  • High: ${report.summary.high}\n`;
    output += `  • Medium: ${report.summary.medium}\n`;
    output += `  • Low: ${report.summary.low}\n\n`;

    if (report.recommendations.length > 0) {
      output += `💡 Recommendations:\n`;
      for (const rec of report.recommendations) {
        output += `  [${rec.priority}] ${rec.action}\n`;
      }
    }

    return output;
  }
}

