// 🐀 Hash Chain Verifier - 기록이 위조되지 않았는가?
// 목표: SHA256 체인으로 기록 무결성 검증 (100% integrity 필수)

import * as crypto from 'crypto';

export interface TestResult {
  timestamp: number;
  commit: string;
  testName: string;
  output: string;
  exitCode: number;
  hash?: string;
  previousHash?: string;
}

export interface ChainVerificationResult {
  isValid: boolean;
  brokenAt?: number;
  reason?: string;
  totalLinks: number;
  verifiedLinks: number;
}

export class HashChainVerifier {
  private chain: TestResult[] = [];

  // ============ SHA256 해시 계산 ============
  private calculateHash(
    timestamp: number,
    commit: string,
    testName: string,
    output: string,
    previousHash?: string
  ): string {
    // 해시 입력: previousHash (있으면) + timestamp + commit + testName + output
    let input = '';

    if (previousHash) {
      input += previousHash;
    }

    input += `${timestamp}|${commit}|${testName}|${output}`;

    return crypto.createHash('sha256').update(input).digest('hex');
  }

  // ============ 테스트 결과 기록 ============
  recordTestResult(
    timestamp: number,
    commit: string,
    testName: string,
    output: string,
    exitCode: number
  ): TestResult {
    // 이전 결과의 해시 구하기
    const previousHash =
      this.chain.length > 0 ? this.chain[this.chain.length - 1].hash : undefined;

    // 현재 해시 계산
    const hash = this.calculateHash(
      timestamp,
      commit,
      testName,
      output,
      previousHash
    );

    const result: TestResult = {
      timestamp,
      commit,
      testName,
      output,
      exitCode,
      hash,
      previousHash,
    };

    this.chain.push(result);
    return result;
  }

  // ============ 체인 검증 ============
  verifyChain(): ChainVerificationResult {
    console.log('🐀 [HASH CHAIN VERIFIER] Verifying hash chain...\n');

    if (this.chain.length === 0) {
      return {
        isValid: true,
        totalLinks: 0,
        verifiedLinks: 0,
      };
    }

    let verifiedLinks = 0;
    let brokenAt = -1;

    for (let i = 0; i < this.chain.length; i++) {
      const result = this.chain[i];

      // i번째 결과의 해시 재계산
      const recalculatedHash = this.calculateHash(
        result.timestamp,
        result.commit,
        result.testName,
        result.output,
        result.previousHash
      );

      // 저장된 해시와 비교
      if (recalculatedHash !== result.hash) {
        console.log(
          `❌ [BROKEN] Chain broken at link ${i}:`
        );
        console.log(
          `   Expected: ${result.hash?.substring(0, 16)}...`
        );
        console.log(
          `   Calculated: ${recalculatedHash.substring(0, 16)}...`
        );
        console.log(`   Test: ${result.testName}`);

        brokenAt = i;
        return {
          isValid: false,
          brokenAt,
          reason: `Hash mismatch at link ${i} (${result.testName})`,
          totalLinks: this.chain.length,
          verifiedLinks,
        };
      }

      verifiedLinks++;

      // 이전 링크와의 연결 검증 (i > 0일 때)
      if (i > 0) {
        const prevResult = this.chain[i - 1];

        // 현재 결과의 previousHash가 이전 결과의 hash와 일치하는가?
        if (result.previousHash !== prevResult.hash) {
          console.log(
            `❌ [BROKEN] Chain link mismatch at position ${i}:`
          );
          console.log(
            `   Expected previous: ${prevResult.hash?.substring(0, 16)}...`
          );
          console.log(
            `   Actual previous: ${result.previousHash?.substring(0, 16)}...`
          );

          brokenAt = i;
          return {
            isValid: false,
            brokenAt,
            reason: `Chain link broken at ${i} (${result.testName})`,
            totalLinks: this.chain.length,
            verifiedLinks,
          };
        }
      }
    }

    console.log(
      `✅ Hash chain integrity verified: ${verifiedLinks}/${this.chain.length} links`
    );

    return {
      isValid: true,
      totalLinks: this.chain.length,
      verifiedLinks,
    };
  }

  // ============ 특정 위치의 해시 검증 ============
  verifyAtIndex(index: number): boolean {
    if (index < 0 || index >= this.chain.length) {
      return false;
    }

    const result = this.chain[index];
    const recalculatedHash = this.calculateHash(
      result.timestamp,
      result.commit,
      result.testName,
      result.output,
      result.previousHash
    );

    return recalculatedHash === result.hash;
  }

  // ============ 체인 길이 ============
  getChainLength(): number {
    return this.chain.length;
  }

  // ============ 체인 내용 ============
  getChain(): TestResult[] {
    return this.chain;
  }

  // ============ 특정 테스트 결과 찾기 ============
  findResult(testName: string): TestResult[] {
    return this.chain.filter((r) => r.testName === testName);
  }

  // ============ 통계 ============
  getStatistics() {
    const stats = {
      totalLinks: this.chain.length,
      byTest: {} as Record<string, number>,
      byCommit: {} as Record<string, number>,
    };

    for (const result of this.chain) {
      stats.byTest[result.testName] = (stats.byTest[result.testName] || 0) + 1;
      stats.byCommit[result.commit] = (stats.byCommit[result.commit] || 0) + 1;
    }

    return stats;
  }

  // ============ 해시 체인 시각화 ============
  visualizeChain(): string {
    let visualization = '';

    for (let i = 0; i < this.chain.length; i++) {
      const result = this.chain[i];
      const hashDisplay = result.hash?.substring(0, 8) || 'NULL';

      visualization += `Link ${i}: ${result.testName}@${result.commit}\n`;
      visualization += `  Hash: ${hashDisplay}...\n`;

      if (i < this.chain.length - 1) {
        visualization += '  ↓\n';
      }
    }

    return visualization;
  }

  // ============ 체인 데이터 저장/로드 ============
  serializeChain(): string {
    return JSON.stringify(this.chain, null, 2);
  }

  deserializeChain(jsonStr: string): void {
    this.chain = JSON.parse(jsonStr);
  }
}
