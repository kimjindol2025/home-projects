// 🐀 Differential Executor - 다양한 환경에서 일관성 검증
// 목표: 다양한 환경에서 실행해도 결과가 같은가? (100% consistency 필수)

export interface Environment {
  name: string;
  os: string;
  arch: string;
  version: string;
}

export interface ExecutionResult {
  environment: Environment;
  output: string;
  exitCode: number;
  executionTime: number;
  memoryUsed: number;
}

export interface DifferentialReport {
  isConsistent: boolean;
  outputMatch: boolean;
  exitCodeMatch: boolean;
  performanceVariance: number; // %
  memoryVariance: number; // %
  environments: number;
  results: ExecutionResult[];
  issues: string[];
}

export class DifferentialExecutor {
  private results: ExecutionResult[] = [];

  // ============ 환경 정보 수집 ============
  detectEnvironment(): Environment {
    return {
      name: this.getEnvironmentName(),
      os: process.platform,
      arch: process.arch,
      version: process.version,
    };
  }

  private getEnvironmentName(): string {
    const platform = process.platform;
    const arch = process.arch;

    // platform과 arch 조합으로 이름 만들기
    if (platform === 'linux') {
      if (arch === 'x64') return 'Linux x86-64';
      if (arch === 'arm64') return 'Linux ARM64';
    } else if (platform === 'darwin') {
      if (arch === 'x64') return 'macOS x86-64';
      if (arch === 'arm64') return 'macOS ARM64 (M1)';
    } else if (platform === 'win32') {
      if (arch === 'x64') return 'Windows x86-64';
    }

    return `${platform}-${arch}`;
  }

  // ============ 테스트 실행 시뮬레이션 ============
  recordExecution(
    output: string,
    exitCode: number,
    executionTime: number,
    memoryUsed: number
  ): ExecutionResult {
    const environment = this.detectEnvironment();

    const result: ExecutionResult = {
      environment,
      output,
      exitCode,
      executionTime,
      memoryUsed,
    };

    this.results.push(result);
    return result;
  }

  // ============ 출력 일관성 검증 ============
  private checkOutputConsistency(results: ExecutionResult[]): boolean {
    if (results.length === 0) return true;

    const firstOutput = results[0].output;

    for (let i = 1; i < results.length; i++) {
      if (results[i].output !== firstOutput) {
        return false;
      }
    }

    return true;
  }

  // ============ Exit Code 일관성 검증 ============
  private checkExitCodeConsistency(results: ExecutionResult[]): boolean {
    if (results.length === 0) return true;

    const firstCode = results[0].exitCode;

    for (let i = 1; i < results.length; i++) {
      if (results[i].exitCode !== firstCode) {
        return false;
      }
    }

    return true;
  }

  // ============ 성능 분산 계산 (%) ============
  private calculatePerformanceVariance(
    results: ExecutionResult[]
  ): number {
    if (results.length < 2) return 0;

    const times = results.map((r) => r.executionTime);
    const avg = times.reduce((a, b) => a + b, 0) / times.length;
    const variance = Math.max(...times) - Math.min(...times);

    return (variance / avg) * 100;
  }

  // ============ 메모리 분산 계산 (%) ============
  private calculateMemoryVariance(results: ExecutionResult[]): number {
    if (results.length < 2) return 0;

    const memory = results.map((r) => r.memoryUsed);
    const avg = memory.reduce((a, b) => a + b, 0) / memory.length;
    const variance = Math.max(...memory) - Math.min(...memory);

    return (variance / avg) * 100;
  }

  // ============ 전체 차등 분석 ============
  generateDifferentialReport(): DifferentialReport {
    console.log('🐀 [DIFFERENTIAL EXECUTOR] Analyzing results...\n');

    const issues: string[] = [];

    // 1. 출력 일관성
    const outputMatch = this.checkOutputConsistency(this.results);
    if (!outputMatch) {
      issues.push('Output differs across environments');
    }

    // 2. Exit Code 일관성
    const exitCodeMatch = this.checkExitCodeConsistency(this.results);
    if (!exitCodeMatch) {
      issues.push('Exit code differs across environments');
    }

    // 3. 성능 분산
    const performanceVariance = this.calculatePerformanceVariance(
      this.results
    );
    if (performanceVariance > 5) {
      issues.push(
        `Performance variance too high: ${performanceVariance.toFixed(2)}% (threshold: 5%)`
      );
    }

    // 4. 메모리 분산
    const memoryVariance = this.calculateMemoryVariance(this.results);
    if (memoryVariance > 10) {
      issues.push(
        `Memory variance too high: ${memoryVariance.toFixed(2)}% (threshold: 10%)`
      );
    }

    // 5. 환경 수
    const environmentCount = new Set(
      this.results.map((r) => r.environment.name)
    ).size;

    const isConsistent =
      outputMatch &&
      exitCodeMatch &&
      performanceVariance <= 5 &&
      memoryVariance <= 10;

    const report: DifferentialReport = {
      isConsistent,
      outputMatch,
      exitCodeMatch,
      performanceVariance,
      memoryVariance,
      environments: environmentCount,
      results: this.results,
      issues,
    };

    this.printReport(report);
    return report;
  }

  // ============ 보고서 출력 ============
  private printReport(report: DifferentialReport): void {
    console.log('📊 DIFFERENTIAL EXECUTION REPORT:\n');

    for (const result of report.results) {
      console.log(`Environment: ${result.environment.name}`);
      console.log(`  Output: ${result.output.substring(0, 50)}...`);
      console.log(`  Exit Code: ${result.exitCode}`);
      console.log(
        `  Time: ${result.executionTime}ms, Memory: ${result.memoryUsed}MB\n`
      );
    }

    console.log('Consistency Checks:');
    console.log(`  Output Match: ${report.outputMatch ? '✅' : '❌'}`);
    console.log(`  Exit Code Match: ${report.exitCodeMatch ? '✅' : '❌'}`);
    console.log(
      `  Performance Variance: ${report.performanceVariance.toFixed(2)}% (threshold: 5%) ${report.performanceVariance <= 5 ? '✅' : '❌'}`
    );
    console.log(
      `  Memory Variance: ${report.memoryVariance.toFixed(2)}% (threshold: 10%) ${report.memoryVariance <= 10 ? '✅' : '❌'}`
    );
    console.log(`  Environments Tested: ${report.environments}`);

    if (report.issues.length > 0) {
      console.log('\n⚠️  Issues:');
      for (const issue of report.issues) {
        console.log(`  - ${issue}`);
      }
    } else {
      console.log('\n✅ All checks passed!');
    }
  }

  // ============ 환경 정보 표시 ============
  printEnvironmentInfo(): void {
    const env = this.detectEnvironment();
    console.log('Current Environment:');
    console.log(`  Name: ${env.name}`);
    console.log(`  OS: ${env.os}`);
    console.log(`  Architecture: ${env.arch}`);
    console.log(`  Version: ${env.version}`);
  }

  // ============ 통계 ============
  getStatistics() {
    const stats = {
      totalRuns: this.results.length,
      avgExecutionTime:
        this.results.reduce((a, b) => a + b.executionTime, 0) /
        this.results.length,
      avgMemory:
        this.results.reduce((a, b) => a + b.memoryUsed, 0) / this.results.length,
      environments: new Set(this.results.map((r) => r.environment.name)).size,
    };

    return stats;
  }

  // ============ 결과 조회 ============
  getResults(): ExecutionResult[] {
    return this.results;
  }
}
