#!/usr/bin/env node

/**
 * Circuit Transpiler - 회로 변환기
 * Phase 10.1: Real Quantum Hardware Integration
 *
 * 기능:
 * - 임의 회로 → 네이티브 게이트 변환
 * - 게이트 분해
 * - 결합선 제약 최적화
 * - 회로 최적화
 */

/**
 * 게이트 분해기
 */
class GateDecomposer {
  constructor() {
    this.decompositions = new Map();
    this.initializeDecompositions();
  }

  /**
   * 분해 규칙 초기화
   */
  initializeDecompositions() {
    // U3 게이트 분해: U3(θ, φ, λ) = RZ(φ) RX(π/2) RZ(θ) RX(π/2) RZ(λ)
    this.decompositions.set('U3', [
      { gate: 'RZ', params: ['phi'] },
      { gate: 'RX', params: [Math.PI / 2] },
      { gate: 'RZ', params: ['theta'] },
      { gate: 'RX', params: [Math.PI / 2] },
      { gate: 'RZ', params: ['lambda'] }
    ]);

    // Toffoli 분해: Toffoli = CNOT + T + ...
    this.decompositions.set('Toffoli', [
      { gate: 'CNOT', qubits: [1, 2] },
      { gate: 'T_dagger', qubits: [2] },
      { gate: 'CNOT', qubits: [0, 2] },
      { gate: 'T', qubits: [2] },
      { gate: 'CNOT', qubits: [1, 2] },
      { gate: 'T_dagger', qubits: [2] },
      { gate: 'CNOT', qubits: [0, 2] },
      { gate: 'T', qubits: [2] }
    ]);

    // SWAP 분해: SWAP = CNOT(0→1) + CNOT(1→0) + CNOT(0→1)
    this.decompositions.set('SWAP', [
      { gate: 'CNOT', qubits: [0, 1] },
      { gate: 'CNOT', qubits: [1, 0] },
      { gate: 'CNOT', qubits: [0, 1] }
    ]);

    // iSWAP 분해: S + CNOT + iSWAP_like
    this.decompositions.set('iSWAP', [
      { gate: 'H', qubits: [0] },
      { gate: 'CNOT', qubits: [0, 1] },
      { gate: 'X', qubits: [0] },
      { gate: 'H', qubits: [1] }
    ]);
  }

  /**
   * 게이트 분해
   */
  decompose(gate, params = [], qubits = []) {
    if (!this.decompositions.has(gate)) {
      return [{ gate, params, qubits }];  // 기본 게이트
    }

    const decomposition = this.decompositions.get(gate);
    const decomposed = [];

    for (const step of decomposition) {
      let stepGate = { ...step };

      // 파라미터 대체
      if (params.length > 0 && step.params) {
        stepGate.params = step.params.map(p => {
          if (typeof p === 'string') {
            const paramIndex = ['theta', 'phi', 'lambda'].indexOf(p);
            return params[paramIndex] || p;
          }
          return p;
        });
      }

      // 큐빗 재매핑
      if (step.qubits && qubits.length > 0) {
        stepGate.qubits = step.qubits.map(q => qubits[q]);
      }

      decomposed.push(stepGate);
    }

    return decomposed;
  }

  /**
   * 회로 분해
   */
  decomposeCircuit(circuit, targetGates = ['H', 'X', 'RX', 'RY', 'RZ', 'CNOT']) {
    const decomposedCircuit = {
      gates: [],
      originalGates: circuit.gates.length,
      decomposedGates: 0
    };

    for (const gate of circuit.gates) {
      if (targetGates.includes(gate.gate)) {
        decomposedCircuit.gates.push(gate);
      } else {
        const decomposed = this.decompose(gate.gate, gate.params, gate.qubits);
        decomposedCircuit.gates.push(...decomposed);
      }
    }

    decomposedCircuit.decomposedGates = decomposedCircuit.gates.length;
    return decomposedCircuit;
  }
}

/**
 * 결합선 최적화기
 */
class CouplingOptimizer {
  constructor(couplingMap) {
    this.couplingMap = couplingMap || this.getDefaultCouplingMap();
    this.routed = false;
  }

  /**
   * 기본 결합선 맵
   */
  getDefaultCouplingMap() {
    // IBM 6-qubit: 선형 결합선
    return [
      [0, 1], [1, 0],
      [1, 2], [2, 1],
      [2, 3], [3, 2],
      [3, 4], [4, 3],
      [4, 5], [5, 4]
    ];
  }

  /**
   * CNOT 라우팅
   */
  routeCNOT(control, target) {
    const edge = [control, target];
    const reversedEdge = [target, control];

    // 직접 결합선 존재
    for (const [from, to] of this.couplingMap) {
      if (from === control && to === target) {
        return {
          routing: 'direct',
          gates: [{ gate: 'CNOT', qubits: [control, target] }]
        };
      }
    }

    // 역방향 결합선
    for (const [from, to] of this.couplingMap) {
      if (from === target && to === control) {
        return {
          routing: 'reversed',
          gates: [
            { gate: 'H', qubits: [control] },
            { gate: 'H', qubits: [target] },
            { gate: 'CNOT', qubits: [target, control] },
            { gate: 'H', qubits: [control] },
            { gate: 'H', qubits: [target] }
          ]
        };
      }
    }

    // 중간 큐빗 경유 (3-CNOT 분해)
    return {
      routing: 'decomposed',
      gates: [
        { gate: 'CNOT', qubits: [control, 1] },
        { gate: 'CNOT', qubits: [1, target] },
        { gate: 'CNOT', qubits: [control, 1] }
      ]
    };
  }

  /**
   * 회로 라우팅
   */
  routeCircuit(circuit) {
    const routedCircuit = {
      gates: [],
      originalTwoQubitGates: 0,
      routedTwoQubitGates: 0
    };

    for (const gate of circuit.gates) {
      if (gate.gate === 'CNOT') {
        routedCircuit.originalTwoQubitGates++;
        const routing = this.routeCNOT(gate.qubits[0], gate.qubits[1]);
        routedCircuit.gates.push(...routing.gates);
        routedCircuit.routedTwoQubitGates += routing.gates.length;
      } else {
        routedCircuit.gates.push(gate);
      }
    }

    this.routed = true;
    return routedCircuit;
  }

  /**
   * 결합선 정보 조회
   */
  getCouplingInfo() {
    return {
      edgeCount: this.couplingMap.length,
      maxQubits: Math.max(...this.couplingMap.flat()) + 1,
      routed: this.routed,
      couplingMap: this.couplingMap
    };
  }
}

/**
 * 회로 최적화기
 */
class CircuitOptimizer {
  constructor() {
    this.optimizations = [];
  }

  /**
   * 연속 단일 큐빗 게이트 합치기
   */
  mergeSingleQubits(circuit) {
    const merged = {
      gates: [],
      originalGates: circuit.gates.length,
      mergedGates: 0
    };

    let i = 0;
    while (i < circuit.gates.length) {
      const current = circuit.gates[i];

      // 연속 RZ/RY/RX 게이트 찾기
      if (['RZ', 'RY', 'RX'].includes(current.gate)) {
        let j = i + 1;
        let totalAngle = current.params[0] || 0;

        while (j < circuit.gates.length &&
               circuit.gates[j].gate === current.gate &&
               circuit.gates[j].qubits[0] === current.qubits[0]) {
          totalAngle += circuit.gates[j].params[0] || 0;
          j++;
        }

        if (j > i + 1) {
          // 게이트 합침
          merged.gates.push({
            gate: current.gate,
            params: [totalAngle],
            qubits: current.qubits,
            merged: true
          });
          i = j;
          this.optimizations.push('merge_single_qubit');
        } else {
          merged.gates.push(current);
          i++;
        }
      } else {
        merged.gates.push(current);
        i++;
      }
    }

    merged.mergedGates = merged.gates.length;
    return merged;
  }

  /**
   * 불필요한 게이트 제거
   */
  removeIdentities(circuit) {
    const cleaned = {
      gates: [],
      originalGates: circuit.gates.length,
      removedIdentities: 0
    };

    for (const gate of circuit.gates) {
      // X X = I, H H = I, 등
      if ((gate.gate === 'X' || gate.gate === 'H') && gate.params &&
          Math.abs(gate.params[0]) < 0.001) {
        cleaned.removedIdentities++;
        this.optimizations.push('remove_identity');
      } else if (gate.gate === 'RZ' && gate.params &&
                 Math.abs(gate.params[0]) < 0.001) {
        cleaned.removedIdentities++;
      } else {
        cleaned.gates.push(gate);
      }
    }

    cleaned.removedIdentities = circuit.gates.length - cleaned.gates.length;
    return cleaned;
  }

  /**
   * 전체 최적화
   */
  optimize(circuit) {
    const optimized = this.mergeSingleQubits(circuit);
    const cleaned = this.removeIdentities(optimized);

    return {
      circuit: cleaned,
      originalGates: circuit.gates.length,
      optimizedGates: cleaned.gates.length,
      gateSavings: circuit.gates.length - cleaned.gates.length,
      savingsPercent: ((circuit.gates.length - cleaned.gates.length) / circuit.gates.length * 100).toFixed(1),
      optimizations: this.optimizations
    };
  }
}

/**
 * 회로 변환기 (메인)
 */
class CircuitTranspiler {
  constructor(targetBackend = 'ibm', targetGates = null) {
    this.targetBackend = targetBackend;
    this.targetGates = targetGates || this.getDefaultTargetGates(targetBackend);
    this.decomposer = new GateDecomposer();
    this.optimizer = new CouplingOptimizer();
    this.optimizationEngine = new CircuitOptimizer();
    this.transpilationSteps = [];
  }

  /**
   * 기본 대상 게이트
   */
  getDefaultTargetGates(backend) {
    const gateMap = {
      'ibm': ['U3', 'CX'],
      'google': ['PhasedXPowGate', 'ISwapPowGate'],
      'aws': ['U', 'CX']
    };
    return gateMap[backend] || ['H', 'X', 'CNOT'];
  }

  /**
   * 회로 변환
   */
  transpile(circuit) {
    let current = JSON.parse(JSON.stringify(circuit));

    // 1단계: 게이트 분해
    current = this.decomposer.decomposeCircuit(current, this.targetGates);
    this.transpilationSteps.push({
      step: 'decomposition',
      gateCount: current.gates.length
    });

    // 2단계: 최적화
    const optimized = this.optimizationEngine.optimize(current);
    current = optimized.circuit;
    this.transpilationSteps.push({
      step: 'optimization',
      gateCount: current.gates.length,
      savings: optimized.gateSavings
    });

    // 3단계: 라우팅
    current = this.optimizer.routeCircuit(current);
    this.transpilationSteps.push({
      step: 'routing',
      gateCount: current.gates.length
    });

    return {
      circuit: current,
      backend: this.targetBackend,
      steps: this.transpilationSteps,
      totalGates: current.gates.length,
      depth: this.calculateDepth(current)
    };
  }

  /**
   * 회로 깊이 계산
   */
  calculateDepth(circuit) {
    const qubits = new Map();

    for (const gate of circuit.gates) {
      const q = gate.qubits[0];
      qubits.set(q, (qubits.get(q) || 0) + 1);
    }

    return Math.max(...qubits.values(), 0);
  }
}

