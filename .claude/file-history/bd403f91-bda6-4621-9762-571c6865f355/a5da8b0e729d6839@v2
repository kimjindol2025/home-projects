/**
 * 양자 네트워크 노드
 */
class QuantumNetworkNode {
  constructor(nodeId, location, qubitCapacity = 50) {
    this.nodeId = nodeId;
    this.location = location;  // { lat, lon }
    this.qubitCapacity = qubitCapacity;
    this.allocatedQubits = 0;
    this.neighbors = [];
    this.quantumMemory = [];
    this.dataRate = 1000;  // Mbps
  }

  /**
   * 이웃 노드 추가
   */
  addNeighbor(node, latency = 10) {
    this.neighbors.push({
      node: node.nodeId,
      latency,  // ms
      connected: true
    });
  }

  /**
   * 양자 상태 저장
   */
  storeQuantumState(state) {
    if (this.allocatedQubits >= this.qubitCapacity) {
      return { success: false, reason: 'Capacity exceeded' };
    }

    this.quantumMemory.push({
      stateId: `state-${Date.now()}`,
      state,
      storedAt: Date.now(),
      coherenceTime: 1000  // ms
    });

    this.allocatedQubits += state.qubits || 1;

    return {
      success: true,
      stateId: this.quantumMemory[this.quantumMemory.length - 1].stateId,
      allocatedQubits: this.allocatedQubits
    };
  }

  /**
   * 양자 상태 전송 준비
   */
  prepareForTransmission(stateId) {
    const state = this.quantumMemory.find(s => s.stateId === stateId);

    if (!state) {
      return { success: false, reason: 'State not found' };
    }

    // 양자 상태 직렬화 (시뮬레이션)
    const serialized = {
      stateId,
      data: JSON.stringify(state.state),
      size: JSON.stringify(state.state).length,
      timestamp: Date.now()
    };

    return {
      success: true,
      serialized,
      estimatedTransmissionTime: (serialized.size / this.dataRate) * 1000  // ms
    };
  }

  /**
   * 노드 상태
   */
  getStatus() {
    return {
      nodeId: this.nodeId,
      location: this.location,
      qubitCapacity: this.qubitCapacity,
      allocatedQubits: this.allocatedQubits,
      utilizationRate: (this.allocatedQubits / this.qubitCapacity * 100).toFixed(1) + '%',
      storedStates: this.quantumMemory.length,
      neighbors: this.neighbors.length,
      dataRate: this.dataRate + ' Mbps'
    };
  }
}

/**
 * 양자 네트워크 토폴로지
 */
class QuantumNetworkTopology {
  constructor() {
    this.nodes = new Map();
    this.links = [];
    this.networkType = 'mesh';  // mesh, star, tree
  }

  /**
   * 노드 추가
   */
  addNode(node) {
    this.nodes.set(node.nodeId, node);
  }

  /**
   * 링크 추가
   */
  addLink(nodeId1, nodeId2, latency = 10, bandwidth = 1000) {
    this.links.push({
      from: nodeId1,
      to: nodeId2,
      latency,
      bandwidth,
      active: true
    });
  }

  /**
   * 최단 경로 찾기 (BFS)
   */
  findShortestPath(sourceId, targetId) {
    const queue = [[sourceId, [sourceId]]];
    const visited = new Set([sourceId]);

    while (queue.length > 0) {
      const [current, path] = queue.shift();

      if (current === targetId) {
        return {
          found: true,
          path,
          hopCount: path.length - 1,
          estimatedLatency: (path.length - 1) * 10  // ms
        };
      }

      const node = this.nodes.get(current);
      for (const neighbor of node.neighbors) {
        if (!visited.has(neighbor.node)) {
          visited.add(neighbor.node);
          queue.push([neighbor.node, [...path, neighbor.node]]);
        }
      }
    }

    return { found: false, reason: 'No path found' };
  }

  /**
   * 네트워크 토폴로지 정보
   */
  getTopologyInfo() {
    return {
      nodes: this.nodes.size,
      links: this.links.length,
      networkType: this.networkType,
      activeLinks: this.links.filter(l => l.active).length,
      averageLatency: (this.links.reduce((sum, l) => sum + l.latency, 0) / this.links.length).toFixed(1) + ' ms',
      totalBandwidth: this.links.reduce((sum, l) => sum + l.bandwidth, 0) + ' Mbps'
    };
  }
}

/**
 * 양자 상태 라우터
 */
class QuantumStateRouter {
  constructor(topology) {
    this.topology = topology;
    this.routingTable = new Map();
    this.transmissions = [];
  }

  /**
   * 라우팅 경로 계산
   */
  calculateRoute(sourceId, targetId, stateSize) {
    const pathInfo = this.topology.findShortestPath(sourceId, targetId);

    if (!pathInfo.found) {
      return { success: false, reason: 'No route available' };
    }

    // 각 링크의 전송 시간 계산
    let totalTime = 0;
    for (let i = 0; i < pathInfo.path.length - 1; i++) {
      const fromId = pathInfo.path[i];
      const toId = pathInfo.path[i + 1];
      const link = this.topology.links.find(l => l.from === fromId && l.to === toId);

      if (link) {
        const transmissionTime = (stateSize / link.bandwidth) * 1000;  // ms
        totalTime += transmissionTime + link.latency;
      }
    }

    return {
      success: true,
      path: pathInfo.path,
      hopCount: pathInfo.hopCount,
      estimatedTime: Math.round(totalTime),
      reliability: 0.95 + (Math.random() * 0.05)  // 95-100%
    };
  }

  /**
   * 양자 상태 전송
   */
  transmitQuantumState(sourceId, targetId, stateId, stateSize) {
    const route = this.calculateRoute(sourceId, targetId, stateSize);

    if (!route.success) {
      return { success: false, reason: route.reason };
    }

    const transmission = {
      transmissionId: `tx-${Date.now()}`,
      source: sourceId,
      target: targetId,
      stateId,
      route: route.path,
      estimatedTime: route.estimatedTime,
      startTime: Date.now(),
      status: 'in-transit',
      reliability: route.reliability
    };

    this.transmissions.push(transmission);

    return {
      success: true,
      transmissionId: transmission.transmissionId,
      estimatedArrival: Date.now() + route.estimatedTime,
      reliability: (route.reliability * 100).toFixed(1) + '%'
    };
  }

  /**
   * 라우터 상태
   */
  getStatus() {
    const activeTransmissions = this.transmissions.filter(t => t.status === 'in-transit').length;
    const completedTransmissions = this.transmissions.filter(t => t.status === 'completed').length;

    return {
      totalTransmissions: this.transmissions.length,
      activeTransmissions,
      completedTransmissions,
      failedTransmissions: this.transmissions.filter(t => t.status === 'failed').length,
      averageReliability: (this.transmissions.reduce((sum, t) => sum + t.reliability, 0) / Math.max(this.transmissions.length, 1) * 100).toFixed(1) + '%'
    };
  }
}

/**
 * 펀딩 고속화 (Funding Speedup)
 */
class QuantumFundingAccelerator {
  constructor(networkTopology) {
    this.topology = networkTopology;
    this.cache = new Map();
    this.cacheHits = 0;
    this.cacheMisses = 0;
  }

  /**
   * 상태 캐싱
   */
  cacheQuantumState(stateId, state) {
    this.cache.set(stateId, {
      state,
      cachedAt: Date.now(),
      accessCount: 0
    });
  }

  /**
   * 캐시에서 상태 조회
   */
  getFromCache(stateId) {
    const cached = this.cache.get(stateId);

    if (cached) {
      cached.accessCount++;
      this.cacheHits++;
      return {
        found: true,
        state: cached.state,
        accessCount: cached.accessCount
      };
    }

    this.cacheMisses++;
    return { found: false };
  }

  /**
   * 지역 캐싱 (Local Caching)
   */
  enableLocalCaching(nodeId, states) {
    const node = this.topology.nodes.get(nodeId);

    if (!node) {
      return { success: false, reason: 'Node not found' };
    }

    let cached = 0;
    for (const state of states) {
      const storeResult = node.storeQuantumState(state);
      if (storeResult.success) {
        cached++;
      }
    }

    return {
      success: true,
      nodeId,
      cachedStates: cached,
      totalStates: states.length,
      cacheHitRate: (this.cacheHits / (this.cacheHits + this.cacheMisses) * 100).toFixed(1) + '%'
    };
  }

  /**
   * 가속기 상태
   */
  getStatus() {
    return {
      cachedStates: this.cache.size,
      cacheHits,
      cacheMisses,
      hitRate: (this.cacheHits / (this.cacheHits + this.cacheMisses) * 100).toFixed(1) + '%'
    };
  }
}

