// 🐀 Anti-Lie Test Mouse v1.2 - Jest Tests

import { AntiLieMouse } from '../src/anti_lie_mouse';
import { MutationGenerator } from '../src/mutation_generator';
import { HashChainVerifier } from '../src/hash_chain_verifier';
import { DifferentialExecutor } from '../src/differential_executor';

describe('🐀 Anti-Lie Test Mouse v1.2', () => {
  // ============ Mutation Testing Tests ============
  describe('Stage 1: Mutation Testing', () => {
    it('should generate 50+ mutations', () => {
      const generator = new MutationGenerator();
      const mutations = generator.generateAllMutations('sample code');

      expect(mutations.length).toBeGreaterThanOrEqual(50);
      console.log(`✅ Generated ${mutations.length} mutations`);
    });

    it('should have different mutation types', () => {
      const generator = new MutationGenerator();
      const mutations = generator.generateAllMutations('sample code');

      const types = new Set(mutations.map((m) => m.type));

      expect(types.size).toBeGreaterThan(1);
      expect(types.has('CONSTANT_MUTATION')).toBe(true);
      expect(types.has('OPERATOR_MUTATION')).toBe(true);
      expect(types.has('RETURN_MUTATION')).toBe(true);

      console.log(
        `✅ Found ${types.size} different mutation types: ${Array.from(types).join(', ')}`
      );
    });

    it('should calculate mutation statistics', () => {
      const generator = new MutationGenerator();
      generator.generateAllMutations('sample code');

      const stats = generator.getStatistics();

      expect(stats.total).toBeGreaterThanOrEqual(50);
      expect(stats.byType['CONSTANT_MUTATION']).toBeGreaterThan(0);
      expect(stats.byType['OPERATOR_MUTATION']).toBeGreaterThan(0);

      console.log(`✅ Mutation statistics:`, stats);
    });
  });

  // ============ Hash Chain Tests ============
  describe('Stage 2: Hash Chain Verification', () => {
    it('should record test results with hashes', () => {
      const verifier = new HashChainVerifier();

      const result = verifier.recordTestResult(
        Date.now(),
        'commit123',
        'test-1',
        '✅ PASSED',
        0
      );

      expect(result.hash).toBeDefined();
      expect(result.hash?.length).toBe(64); // SHA256 = 64 hex chars

      console.log(`✅ Hash recorded: ${result.hash?.substring(0, 16)}...`);
    });

    it('should verify hash chain integrity', () => {
      const verifier = new HashChainVerifier();

      // 3개 테스트 결과 기록
      verifier.recordTestResult(Date.now(), 'abc', 'test-1', '✅ PASSED', 0);
      verifier.recordTestResult(
        Date.now() + 1000,
        'abc',
        'test-2',
        '✅ PASSED',
        0
      );
      verifier.recordTestResult(
        Date.now() + 2000,
        'abc',
        'test-3',
        '✅ PASSED',
        0
      );

      const verification = verifier.verifyChain();

      expect(verification.isValid).toBe(true);
      expect(verification.totalLinks).toBe(3);
      expect(verification.verifiedLinks).toBe(3);

      console.log(
        `✅ Chain verified: ${verification.verifiedLinks}/${verification.totalLinks} links`
      );
    });

    it('should detect chain tampering', () => {
      const verifier = new HashChainVerifier();

      // 2개 결과 기록
      verifier.recordTestResult(Date.now(), 'abc', 'test-1', '✅ PASSED', 0);
      verifier.recordTestResult(
        Date.now() + 1000,
        'abc',
        'test-2',
        '✅ PASSED',
        0
      );

      // 체인 직렬화
      const serialized = verifier.serializeChain();

      // 변조 시뮬레이션: 첫 번째 결과의 output 변경
      const tampered = serialized.replace('PASSED', 'FAILED');

      // 새 verifier에 변조된 데이터 로드
      const verifier2 = new HashChainVerifier();
      verifier2.deserializeChain(tampered);

      const verification = verifier2.verifyChain();

      // 변조가 감지되어야 함
      expect(verification.isValid).toBe(false);
      expect(verification.brokenAt).toBeGreaterThanOrEqual(0);

      console.log(
        `✅ Tampering detected at link ${verification.brokenAt}`
      );
    });

    it('should find specific test results', () => {
      const verifier = new HashChainVerifier();

      verifier.recordTestResult(Date.now(), 'abc', 'Stack-Integrity', '✅', 0);
      verifier.recordTestResult(Date.now(), 'abc', 'JIT-Poisoning', '✅', 0);
      verifier.recordTestResult(Date.now(), 'abc', 'Stack-Integrity', '✅', 0);

      const stackResults = verifier.findResult('Stack-Integrity');

      expect(stackResults.length).toBe(2);

      console.log(
        `✅ Found ${stackResults.length} results for Stack-Integrity`
      );
    });
  });

  // ============ Differential Execution Tests ============
  describe('Stage 3: Differential Execution', () => {
    it('should detect current environment', () => {
      const executor = new DifferentialExecutor();
      const env = executor.detectEnvironment();

      expect(env.name).toBeDefined();
      expect(env.os).toBeDefined();
      expect(env.arch).toBeDefined();

      console.log(`✅ Detected environment: ${env.name}`);
    });

    it('should record execution results', () => {
      const executor = new DifferentialExecutor();

      const result = executor.recordExecution('✅ PASSED', 0, 150, 45);

      expect(result.output).toBe('✅ PASSED');
      expect(result.exitCode).toBe(0);
      expect(result.executionTime).toBe(150);
      expect(result.memoryUsed).toBe(45);

      console.log(
        `✅ Recorded: ${result.executionTime}ms, ${result.memoryUsed}MB`
      );
    });

    it('should verify cross-environment consistency', () => {
      const executor = new DifferentialExecutor();

      // 3개 환경에서 동일한 결과
      executor.recordExecution('✅ ALIVE', 0, 1200, 145);
      executor.recordExecution('✅ ALIVE', 0, 1220, 142);
      executor.recordExecution('✅ ALIVE', 0, 1150, 150);

      const report = executor.generateDifferentialReport();

      expect(report.outputMatch).toBe(true);
      expect(report.exitCodeMatch).toBe(true);
      expect(report.performanceVariance).toBeLessThan(5);
      expect(report.memoryVariance).toBeLessThan(10);
      expect(report.isConsistent).toBe(true);

      console.log(`✅ All environments consistent`);
    });

    it('should calculate performance variance', () => {
      const executor = new DifferentialExecutor();

      // 성능 차이 있음 (1200, 1220, 1150)
      executor.recordExecution('✅ ALIVE', 0, 1200, 145);
      executor.recordExecution('✅ ALIVE', 0, 1220, 142);
      executor.recordExecution('✅ ALIVE', 0, 1150, 150);

      const report = executor.generateDifferentialReport();

      // 분산이 5% 이하여야 함
      expect(report.performanceVariance).toBeLessThanOrEqual(5);

      console.log(
        `✅ Performance variance: ${report.performanceVariance.toFixed(2)}%`
      );
    });
  });

  // ============ Full Integration Tests ============
  describe('Full Anti-Lie Verification', () => {
    it('should run complete verification with mutation testing', () => {
      const mouse = new AntiLieMouse();

      // Stage 1만 실행 (Mutation Testing)
      const killRate = mouse.runMutationTesting(
        'if (rsp_drift != 0) { DEAD }'
      );

      // Kill Rate 확인 (80% 이상)
      expect(killRate).toBeGreaterThanOrEqual(80);

      console.log(`✅ Mutation Kill Rate: ${killRate.toFixed(2)}%`);
    });

    it('should run complete verification with hash chain', () => {
      const mouse = new AntiLieMouse();

      // Stage 2만 실행 (Hash Chain)
      const verification = mouse.runHashChainVerification();

      expect(verification.isValid).toBe(true);
      expect(verification.totalLinks).toBeGreaterThan(0);

      console.log(
        `✅ Hash Chain: ${verification.totalLinks} links verified`
      );
    });

    it('should run complete verification with differential execution', () => {
      const mouse = new AntiLieMouse();

      // Stage 3만 실행 (Differential)
      const report = mouse.runDifferentialExecution();

      expect(report.outputMatch).toBe(true);
      expect(report.isConsistent).toBe(true);

      console.log(`✅ Differential: ${report.environments} environments`);
    });

    it('should run full Anti-Lie verification', () => {
      const mouse = new AntiLieMouse();

      // 전체 검증 실행
      const result = mouse.runFullVerification();

      // 최소 요구사항
      // - Mutation Kill Rate >= 80%
      // - Hash Chain Valid
      // - Differential Consistent
      expect(result.details.mutationKillRate).toBeGreaterThanOrEqual(80);
      expect(result.hashChainValid).toBe(true);
      expect(result.differentialConsistent).toBe(true);

      console.log(`✅ Full verification complete:`);
      console.log(
        `   Mutation Kill Rate: ${result.details.mutationKillRate.toFixed(2)}%`
      );
      console.log(`   Hash Chain Valid: ${result.hashChainValid}`);
      console.log(`   Differential Consistent: ${result.differentialConsistent}`);
      console.log(`   Overall: ${result.overall ? 'VERIFIED' : 'INVALID'}`);
    });
  });

  // ============ Stress Tests ============
  describe('Stress Tests', () => {
    it('should handle 1000+ mutations', () => {
      const generator = new MutationGenerator();

      // 한 번에 많은 돌연변이 생성
      for (let i = 0; i < 10; i++) {
        generator.generateAllMutations('code');
      }

      const stats = generator.getStatistics();
      expect(stats.total).toBeGreaterThanOrEqual(1000);

      console.log(`✅ Handled ${stats.total} mutations without error`);
    });

    it('should verify large hash chains', () => {
      const verifier = new HashChainVerifier();

      // 1000개 결과 기록
      for (let i = 0; i < 1000; i++) {
        verifier.recordTestResult(
          Date.now() + i * 100,
          'commit',
          `test-${i}`,
          `Output ${i}`,
          0
        );
      }

      const verification = verifier.verifyChain();

      expect(verification.isValid).toBe(true);
      expect(verification.totalLinks).toBe(1000);

      console.log(
        `✅ Verified 1000-link chain without errors`
      );
    });
  });
});
