  const optimal = sdm.decideOptimal();
  console.log(`  Expected value: ${optimal.expectedValue.toFixed(2)}`);
  console.log(`  Confidence: ${optimal.confidence.toFixed(2)}\n`);

  console.log('✅ Test 3: Interference Pattern');
  const sdm2 = new SuperpositionDecisionMaker(decisions);
  sdm2.applyPreferences(d => 1 - d.score);
  sdm.interference(sdm2);
  const afterInterference = sdm.decideOptimal();
  console.log(`  After interference - Expected: ${afterInterference.expectedValue.toFixed(2)}\n`);

  console.log('✅ Test 4: Entangled Decision Making');
  const agents = [
    { decision: 0.8, confidence: 0.9 },
    { decision: 0.75, confidence: 0.85 },
    { decision: 0.85, confidence: 0.95 }
  ];
  const edm = new EntangledDecisionMaker(agents);
