#!/usr/bin/env node

/**
 * Probabilistic Decision Maker - 확률론적 의사결정
 * Phase 10: Quantum-Ready Intelligence
 *
 * 기능:
 * - 양자 확률 기반 의사결정
 * - 슈퍼포지션 기반 탐색
 * - 얽힘 활용
 * - 양자 상태 중첩
 */

/**
 * 양자 확률 분포
 */
class QuantumProbabilityDistribution {
  constructor(outcomes = []) {
    this.outcomes = outcomes;              // 가능한 결과
    this.amplitudes = [];                  // 복소 진폭
    this.probabilities = [];               // 고전 확률
    this.superposition = true;
  }

  /**
   * 진폭 설정
   */
  setAmplitudes(amplitudes) {
    this.amplitudes = amplitudes;
    this.updateProbabilities();
    return this;
  }

  /**
   * 확률 업데이트
   */
  updateProbabilities() {
    let normalization = 0;

    for (const amp of this.amplitudes) {
      const prob = Math.abs(amp) ** 2;
      normalization += prob;
    }

    this.probabilities = this.amplitudes.map(amp => {
      return Math.abs(amp) ** 2 / (normalization || 1);
    });

    return this;
  }

  /**
   * 기댓값
   */
  expectation(valueFunction) {
    let expected = 0;

    for (let i = 0; i < this.outcomes.length; i++) {
      const outcome = this.outcomes[i];
      const probability = this.probabilities[i];
      const value = valueFunction(outcome);
      expected += value * probability;
    }

    return expected;
  }

  /**
   * 분산
   */
  variance(valueFunction) {
    const exp = this.expectation(valueFunction);
    const exp2 = this.expectation(outcome => valueFunction(outcome) ** 2);
    return exp2 - exp ** 2;
  }

  /**
   * 측정 (붕괴)
   */
  measure() {
    let rand = Math.random();
    let cumulative = 0;

    for (let i = 0; i < this.outcomes.length; i++) {
      cumulative += this.probabilities[i];
      if (rand < cumulative) {
        return {
          outcome: this.outcomes[i],
          index: i,
          probability: this.probabilities[i]
        };
      }
    }

    return { outcome: this.outcomes[0], index: 0 };
  }
}

/**
 * 슈퍼포지션 기반 의사결정
 */
class SuperpositionDecisionMaker {
  constructor(decisions) {
    this.decisions = decisions;            // 가능한 의사결정
    this.distribution = new QuantumProbabilityDistribution(decisions);

    // 균등 중첩으로 초기화
    const amplitude = 1 / Math.sqrt(decisions.length);
    this.distribution.setAmplitudes(
      Array(decisions.length).fill(amplitude)
    );
  }

  /**
   * 의사결정 선호도 적용
   */
  applyPreferences(preferenceFunction) {
    const amplitudes = this.decisions.map(decision => {
      const preference = preferenceFunction(decision);  // 0-1
      return Math.sqrt(preference);
    });

    // 정규화
    let norm = 0;
    for (const amp of amplitudes) {
      norm += amp ** 2;
    }
    norm = Math.sqrt(norm);

    this.distribution.setAmplitudes(
      amplitudes.map(amp => amp / norm)
    );

    return this;
  }

  /**
   * 간섭 패턴 (파괴적/보강적)
   */
  interference(otherMaker) {
    const newAmplitudes = [];

    for (let i = 0; i < this.decisions.length; i++) {
      const amp1 = this.distribution.amplitudes[i] || 0;
      const amp2 = otherMaker.distribution.amplitudes[i] || 0;

      // 간섭: 복소 덧셈
      newAmplitudes.push(amp1 + amp2);
    }

    this.distribution.setAmplitudes(newAmplitudes);
    return this;
  }

  /**
   * 최적 의사결정
   */
  decideOptimal() {
    const valueFunction = (decision) => decision.score || 0.5;
    const expected = this.distribution.expectation(valueFunction);
    const variance = this.distribution.variance(valueFunction);

    return {
      expectedValue: expected,
      variance,
      confidence: Math.sqrt(1 / (variance + 1)),
      bestDecision: this.decisions[
        this.distribution.probabilities.indexOf(
          Math.max(...this.distribution.probabilities)
        )
      ]
    };
  }

  /**
   * 양자 측정
   */
  measure() {
    return this.distribution.measure();
  }
}

/**
 * 얽힘 기반 협력 의사결정
 */
class EntangledDecisionMaker {
  constructor(agents = []) {
    this.agents = agents;
    this.entanglement = 0.9;              // 얽힘 정도
    this.correlationMatrix = [];
  }

  /**
   * 상관관계 계산
   */
  calculateCorrelations() {
    const n = this.agents.length;
    this.correlationMatrix = Array(n).fill(0).map(() => Array(n).fill(0));

    for (let i = 0; i < n; i++) {
      for (let j = 0; j < n; j++) {
        if (i === j) {
          this.correlationMatrix[i][j] = 1;
        } else {
          // 얽힘을 통한 상관관계
          const correlation = Math.cos(
            (this.agents[i].decision - this.agents[j].decision) *
            this.entanglement
          );
          this.correlationMatrix[i][j] = correlation;
        }
      }
    }

    return this.correlationMatrix;
  }

  /**
   * 합의 측정 (Bell test)
   */
  measureConcurrence() {
    let concurrence = 0;

    for (let i = 0; i < this.agents.length; i++) {
      for (let j = i + 1; j < this.agents.length; j++) {
        const corr = this.correlationMatrix[i][j];
        concurrence += corr;
      }
    }

    // 정규화
    const pairs = this.agents.length * (this.agents.length - 1) / 2;
    return concurrence / pairs;
  }

  /**
   * 집단 의사결정
   */
  collectiveDecision() {
    this.calculateCorrelations();
    const concurrence = this.measureConcurrence();

    // 가중 투표: 얽힘이 강할수록 더 강한 영향
    const weights = this.agents.map((agent, i) => {
      let weight = agent.confidence || 0.5;

      // 다른 에이전트와의 얽힘 고려
      for (let j = 0; j < this.agents.length; j++) {
        if (i !== j) {
          weight += this.correlationMatrix[i][j] * 0.1;
        }
      }

      return weight;
    });

    // 정규화
    const totalWeight = weights.reduce((a, b) => a + b, 0);
    const normalizedWeights = weights.map(w => w / totalWeight);

    // 가중 평균
    let decision = 0;
    for (let i = 0; i < this.agents.length; i++) {
      decision += (this.agents[i].decision || 0) * normalizedWeights[i];
    }

    return {
      decision,
      concurrence,
      weights: normalizedWeights,
      consensus: concurrence > 0.7  // 높은 얽힘 = 높은 합의
    };
  }
}

/**
 * 양자 기반 다중 의사결정
 */
class QuantumMultiDecisionMaker {
  constructor(numDecisions = 3) {
    this.numDecisions = numDecisions;
    this.decisions = Array(numDecisions).fill(0).map(() => ({}));
    this.superpositionMakers = [];
    this.entangledMakers = [];
  }

  /**
   * 의사결정 추가
   */
  addDecision(decision, confidence = 0.5) {
    const superpositionMaker = new SuperpositionDecisionMaker([decision]);
    superpositionMaker.applyPreferences(() => confidence);
    this.superpositionMakers.push(superpositionMaker);
    return this;
  }

  /**
   * 에이전트 추가
   */
  addAgent(agent) {
    this.superpositionMakers.forEach(maker => {
      maker.applyPreferences(d => agent.evaluateDecision(d));
    });
    return this;
  }

  /**
   * 최종 의사결정
   */
  finalizeDecision() {
    // 모든 슈퍼포지션의 간섭
    let interferedMaker = this.superpositionMakers[0];

    for (let i = 1; i < this.superpositionMakers.length; i++) {
      interferedMaker.interference(this.superpositionMakers[i]);
    }

    const optimal = interferedMaker.decideOptimal();
    const measured = interferedMaker.measure();

    return {
      optimal,
      measured,
      confidence: optimal.confidence,
      chosenDecision: measured.outcome
    };
  }
}

