// 🐀 Mutation Generator - 코드에 의도적 버그를 주입
// 목표: 테스트가 이 버그들을 모두 감지하는가? (100% kill rate 필수)

export interface Mutation {
  id: number;
  type: string;
  originalCode: string;
  mutatedCode: string;
  description: string;
}

export class MutationGenerator {
  private mutationId = 0;
  private mutations: Mutation[] = [];

  // ============ 1단계: Constant Mutation (상수 변경) ============
  generateConstantMutations(code: string): Mutation[] {
    const constantMutations: Mutation[] = [];

    // 0 → 1, 1 → 0 변경
    constantMutations.push({
      id: this.mutationId++,
      type: 'CONSTANT_MUTATION',
      originalCode: 'if (count === 0) { ... }',
      mutatedCode: 'if (count === 1) { ... }',
      description: '경계값: 0 → 1로 변경',
    });

    // 비교 연산자 경계값 변경
    constantMutations.push({
      id: this.mutationId++,
      type: 'CONSTANT_MUTATION',
      originalCode: 'if (latency < 100) { ... }',
      mutatedCode: 'if (latency < 99) { ... }',
      description: '경계값: 100 → 99로 변경',
    });

    constantMutations.push({
      id: this.mutationId++,
      type: 'CONSTANT_MUTATION',
      originalCode: 'if (rate > 1000) { ... }',
      mutatedCode: 'if (rate > 999) { ... }',
      description: '경계값: 1000 → 999로 변경',
    });

    constantMutations.push({
      id: this.mutationId++,
      type: 'CONSTANT_MUTATION',
      originalCode: 'if (memory === 0) { ... }',
      mutatedCode: 'if (memory === -1) { ... }',
      description: '경계값: 0 → -1로 변경',
    });

    constantMutations.push({
      id: this.mutationId++,
      type: 'CONSTANT_MUTATION',
      originalCode: 'const MAX_DEPTH = 100;',
      mutatedCode: 'const MAX_DEPTH = 101;',
      description: '상수: 100 → 101로 변경',
    });

    this.mutations.push(...constantMutations);
    return constantMutations;
  }

  // ============ 2단계: Operator Mutation (연산자 변경) ============
  generateOperatorMutations(code: string): Mutation[] {
    const operatorMutations: Mutation[] = [];

    // < → >
    operatorMutations.push({
      id: this.mutationId++,
      type: 'OPERATOR_MUTATION',
      originalCode: 'if (x < 100) { ... }',
      mutatedCode: 'if (x > 100) { ... }',
      description: '연산자: < → >로 변경',
    });

    // > → <
    operatorMutations.push({
      id: this.mutationId++,
      type: 'OPERATOR_MUTATION',
      originalCode: 'if (y > 50) { ... }',
      mutatedCode: 'if (y < 50) { ... }',
      description: '연산자: > → <로 변경',
    });

    // == → !=
    operatorMutations.push({
      id: this.mutationId++,
      type: 'OPERATOR_MUTATION',
      originalCode: 'if (count == 0) { ... }',
      mutatedCode: 'if (count != 0) { ... }',
      description: '연산자: == → !=로 변경',
    });

    // != → ==
    operatorMutations.push({
      id: this.mutationId++,
      type: 'OPERATOR_MUTATION',
      originalCode: 'if (error != null) { ... }',
      mutatedCode: 'if (error == null) { ... }',
      description: '연산자: != → ==로 변경',
    });

    // <= → <
    operatorMutations.push({
      id: this.mutationId++,
      type: 'OPERATOR_MUTATION',
      originalCode: 'if (value <= 100) { ... }',
      mutatedCode: 'if (value < 100) { ... }',
      description: '연산자: <= → <로 변경',
    });

    // >= → >
    operatorMutations.push({
      id: this.mutationId++,
      type: 'OPERATOR_MUTATION',
      originalCode: 'if (value >= 50) { ... }',
      mutatedCode: 'if (value > 50) { ... }',
      description: '연산자: >= → >로 변경',
    });

    // + → -
    operatorMutations.push({
      id: this.mutationId++,
      type: 'OPERATOR_MUTATION',
      originalCode: 'result = a + b;',
      mutatedCode: 'result = a - b;',
      description: '산술: + → -로 변경',
    });

    // - → +
    operatorMutations.push({
      id: this.mutationId++,
      type: 'OPERATOR_MUTATION',
      originalCode: 'total = sum - value;',
      mutatedCode: 'total = sum + value;',
      description: '산술: - → +로 변경',
    });

    // * → /
    operatorMutations.push({
      id: this.mutationId++,
      type: 'OPERATOR_MUTATION',
      originalCode: 'product = x * y;',
      mutatedCode: 'product = x / y;',
      description: '산술: * → /로 변경',
    });

    this.mutations.push(...operatorMutations);
    return operatorMutations;
  }

  // ============ 3단계: Return Value Mutation (반환값 변경) ============
  generateReturnMutations(code: string): Mutation[] {
    const returnMutations: Mutation[] = [];

    // true → false
    returnMutations.push({
      id: this.mutationId++,
      type: 'RETURN_MUTATION',
      originalCode: 'return true;',
      mutatedCode: 'return false;',
      description: '반환값: true → false로 변경',
    });

    // false → true
    returnMutations.push({
      id: this.mutationId++,
      type: 'RETURN_MUTATION',
      originalCode: 'return false;',
      mutatedCode: 'return true;',
      description: '반환값: false → true로 변경',
    });

    // 0 → 1
    returnMutations.push({
      id: this.mutationId++,
      type: 'RETURN_MUTATION',
      originalCode: 'return 0;',
      mutatedCode: 'return 1;',
      description: '반환값: 0 → 1로 변경',
    });

    // 1 → 0
    returnMutations.push({
      id: this.mutationId++,
      type: 'RETURN_MUTATION',
      originalCode: 'return 1;',
      mutatedCode: 'return 0;',
      description: '반환값: 1 → 0으로 변경',
    });

    // null → undefined
    returnMutations.push({
      id: this.mutationId++,
      type: 'RETURN_MUTATION',
      originalCode: 'return null;',
      mutatedCode: 'return undefined;',
      description: '반환값: null → undefined로 변경',
    });

    // undefined → null
    returnMutations.push({
      id: this.mutationId++,
      type: 'RETURN_MUTATION',
      originalCode: 'return undefined;',
      mutatedCode: 'return null;',
      description: '반환값: undefined → null로 변경',
    });

    // "" → "X"
    returnMutations.push({
      id: this.mutationId++,
      type: 'RETURN_MUTATION',
      originalCode: 'return "";',
      mutatedCode: 'return "X";',
      description: '반환값: "" → "X"로 변경',
    });

    this.mutations.push(...returnMutations);
    return returnMutations;
  }

  // ============ 4단계: Logic Mutation (논리 변경) ============
  generateLogicMutations(code: string): Mutation[] {
    const logicMutations: Mutation[] = [];

    // && → ||
    logicMutations.push({
      id: this.mutationId++,
      type: 'LOGIC_MUTATION',
      originalCode: 'if (a && b) { ... }',
      mutatedCode: 'if (a || b) { ... }',
      description: '논리: && → ||로 변경',
    });

    // || → &&
    logicMutations.push({
      id: this.mutationId++,
      type: 'LOGIC_MUTATION',
      originalCode: 'if (x || y) { ... }',
      mutatedCode: 'if (x && y) { ... }',
      description: '논리: || → &&로 변경',
    });

    // ! 추가
    logicMutations.push({
      id: this.mutationId++,
      type: 'LOGIC_MUTATION',
      originalCode: 'if (condition) { ... }',
      mutatedCode: 'if (!condition) { ... }',
      description: '논리: ! (NOT) 추가',
    });

    // ! 제거
    logicMutations.push({
      id: this.mutationId++,
      type: 'LOGIC_MUTATION',
      originalCode: 'if (!error) { ... }',
      mutatedCode: 'if (error) { ... }',
      description: '논리: ! (NOT) 제거',
    });

    // if → if not
    logicMutations.push({
      id: this.mutationId++,
      type: 'LOGIC_MUTATION',
      originalCode: 'if (isValid) { return true; }',
      mutatedCode: 'if (!isValid) { return true; }',
      description: '조건문 반전',
    });

    this.mutations.push(...logicMutations);
    return logicMutations;
  }

  // ============ 5단계: Boundary Mutation (경계값 변경) ============
  generateBoundaryMutations(code: string): Mutation[] {
    const boundaryMutations: Mutation[] = [];

    // Loop bound 변경 (n → n-1)
    boundaryMutations.push({
      id: this.mutationId++,
      type: 'BOUNDARY_MUTATION',
      originalCode: 'for (let i = 0; i < 100; i++) { ... }',
      mutatedCode: 'for (let i = 0; i < 99; i++) { ... }',
      description: '루프 경계: 100 → 99로 변경',
    });

    // Loop bound 변경 (n → n+1)
    boundaryMutations.push({
      id: this.mutationId++,
      type: 'BOUNDARY_MUTATION',
      originalCode: 'for (let i = 1; i <= 100; i++) { ... }',
      mutatedCode: 'for (let i = 1; i <= 101; i++) { ... }',
      description: '루프 경계: 100 → 101로 변경',
    });

    // Array index bound 변경
    boundaryMutations.push({
      id: this.mutationId++,
      type: 'BOUNDARY_MUTATION',
      originalCode: 'if (index < array.length) { ... }',
      mutatedCode: 'if (index <= array.length) { ... }',
      description: '배열 경계: < → <=로 변경',
    });

    // Range check 변경
    boundaryMutations.push({
      id: this.mutationId++,
      type: 'BOUNDARY_MUTATION',
      originalCode: 'if (value >= 0 && value < 100) { ... }',
      mutatedCode: 'if (value >= 1 && value < 100) { ... }',
      description: '범위 확인: 0 → 1로 변경',
    });

    this.mutations.push(...boundaryMutations);
    return boundaryMutations;
  }

  // ============ 전체 돌연변이 생성 ============
  generateAllMutations(code: string): Mutation[] {
    console.log('🐀 [MUTATION GENERATOR] Generating all mutations...\n');

    const constants = this.generateConstantMutations(code);
    console.log(`✅ Generated ${constants.length} constant mutations`);

    const operators = this.generateOperatorMutations(code);
    console.log(`✅ Generated ${operators.length} operator mutations`);

    const returns = this.generateReturnMutations(code);
    console.log(`✅ Generated ${returns.length} return mutations`);

    const logics = this.generateLogicMutations(code);
    console.log(`✅ Generated ${logics.length} logic mutations`);

    const boundaries = this.generateBoundaryMutations(code);
    console.log(`✅ Generated ${boundaries.length} boundary mutations`);

    const total = this.mutations.length;
    console.log(`\n📊 Total mutations: ${total}`);

    return this.mutations;
  }

  // ============ 돌연변이 적용 시뮬레이션 ============
  injectMutation(code: string, mutation: Mutation): string {
    // 실제로는 AST를 파싱하여 정확히 주입하지만,
    // 여기서는 간단히 시뮬레이션
    return code.replace(mutation.originalCode, mutation.mutatedCode);
  }

  // ============ 통계 ============
  getStatistics() {
    const stats = {
      total: this.mutations.length,
      byType: {} as Record<string, number>,
    };

    for (const mutation of this.mutations) {
      stats.byType[mutation.type] = (stats.byType[mutation.type] || 0) + 1;
    }

    return stats;
  }

  getMutations(): Mutation[] {
    return this.mutations;
  }
}
