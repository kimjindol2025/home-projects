 *
 * 기능:
 * - 사용자 피드백 수집
 * - 협력 세션 관리
 * - 상호작용 분석
 * - 동의 형성
 */

/**
 * 사용자 피드백
 */
class UserFeedback {
  constructor(userId, feedbackType, content, rating = 0) {
    this.userId = userId;
    this.feedbackType = feedbackType;    // suggestion, correction, validation, concern
    this.content = content;
    this.rating = rating;                 // -1(bad), 0(neutral), 1(good)
    this.timestamp = Date.now();
    this.actionable = false;
    this.priority = 'medium';
  }
}

/**
 * 협력 세션
 */
class CollaborationSession {
  constructor(id, topic, aiAgent, users = []) {
    this.id = id;
    this.topic = topic;
    this.aiAgent = aiAgent;
    this.users = users;
    this.feedbacks = [];
    this.proposals = [];
    this.agreements = [];
    this.status = 'active';              // active, consensus-reached, failed
    this.startTime = Date.now();
    this.consensusLevel = 0;
  }

  /**
   * 피드백 추가
   */
  addFeedback(feedback) {
    this.feedbacks.push(feedback);
    this.analyzeConsensus();
    return this;
  }

  /**
   * 합의도 분석
   */
  analyzeConsensus() {
    if (this.feedbacks.length === 0) {
      this.consensusLevel = 0;
      return;
    }

    const positive = this.feedbacks.filter(f => f.rating === 1).length;
    const negative = this.feedbacks.filter(f => f.rating === -1).length;
    const neutral = this.feedbacks.filter(f => f.rating === 0).length;

    const positiveRatio = positive / this.feedbacks.length;
    const negativeRatio = negative / this.feedbacks.length;

    // 합의도 = 긍정 비율 - 부정 비율
    this.consensusLevel = positiveRatio - negativeRatio * 0.5;

    // 합의 기준
    if (positiveRatio > 0.8) {
      this.status = 'consensus-reached';
    } else if (negativeRatio > 0.5) {
      this.status = 'failed';
    }
  }

  /**
   * AI 제안 추가
   */
  addProposal(proposal) {
    this.proposals.push({
      ...proposal,
      feedbackCount: 0,
      supportCount: 0,
      oppositionCount: 0
    });
    return this;
  }

  /**
   * 제안에 대한 동의
   */
  agreeWithProposal(proposalIndex, agreement) {
    if (proposalIndex < this.proposals.length) {
      const proposal = this.proposals[proposalIndex];
      proposal.feedbackCount++;

      if (agreement.type === 'support') {
        proposal.supportCount++;
      } else if (agreement.type === 'oppose') {
        proposal.oppositionCount++;
      }

      this.agreements.push(agreement);
    }
    return this;
  }

  /**
   * 세션 요약
   */
  summarize() {
    return {
      id: this.id,
      topic: this.topic,
      status: this.status,
      consensusLevel: this.consensusLevel,
      feedbackCount: this.feedbacks.length,
      proposalCount: this.proposals.length,
      duration: Date.now() - this.startTime,
      participants: this.users.length
    };
  }
}

/**
 * 상호작용 분석기
 */
class InteractionAnalyzer {
  /**
   * 상호작용 패턴 분석
   */
  static analyzePatterns(session) {
    const patterns = {
      totalInteractions: session.feedbacks.length + session.agreements.length,
      feedbackTypes: {},
      userEngagement: {},
      conversationFlow: 'linear'
    };

    // 피드백 유형 분포
    for (const feedback of session.feedbacks) {
      patterns.feedbackTypes[feedback.feedbackType] =
        (patterns.feedbackTypes[feedback.feedbackType] || 0) + 1;
    }

    // 사용자별 참여도
    for (const feedback of session.feedbacks) {
      patterns.userEngagement[feedback.userId] =
        (patterns.userEngagement[feedback.userId] || 0) + 1;
    }

    return patterns;
  }

  /**
   * 주요 합의점 식별
   */
  static identifyConsensusPoints(session) {
    const consensusPoints = [];

    for (let i = 0; i < session.proposals.length; i++) {
      const proposal = session.proposals[i];

      if (proposal.supportCount > proposal.oppositionCount * 1.5) {
        consensusPoints.push({
          proposalIndex: i,
          proposal: proposal,
          consensusScore: proposal.supportCount / (proposal.feedbackCount || 1)
        });
      }
    }

    return consensusPoints.sort((a, b) => b.consensusScore - a.consensusScore);
  }

  /**
   * 갈등 영역 식별
   */
  static identifyConflictAreas(session) {
    const conflicts = [];

    for (let i = 0; i < session.proposals.length; i++) {
      const proposal = session.proposals[i];
      const total = proposal.supportCount + proposal.oppositionCount;

      if (total > 0) {
        const disagreement = Math.abs(
          proposal.supportCount - proposal.oppositionCount
        ) / total;

        if (disagreement < 0.5) {
          conflicts.push({
            proposalIndex: i,
            disagreementRatio: 1 - disagreement,
            needsMediation: true
          });
        }
      }
    }

    return conflicts;
  }

  /**
   * 신뢰도 평가
   */
  static evaluateTrustLevel(session) {
    if (session.feedbacks.length === 0) return 0;

    const validations = session.feedbacks
      .filter(f => f.feedbackType === 'validation').length;

    const corrections = session.feedbacks
      .filter(f => f.feedbackType === 'correction').length;

    const suggestions = session.feedbacks
      .filter(f => f.feedbackType === 'suggestion').length;

    // 신뢰도 = (검증 + 제안) / (수정 + 우려) - 낮을수록 좋음
    const positive = validations + suggestions;
    const negative = corrections + session.feedbacks
      .filter(f => f.feedbackType === 'concern').length;

    return positive / (positive + negative || 1);
  }
}

/**
 * 인간-AI 협력기
 */
class HumanAICollaborator {
  constructor(config = {}) {
    this.config = {
      consensusThreshold: config.consensusThreshold || 0.7,
      maxIterations: config.maxIterations || 5,
      ...config
    };

    this.sessions = [];
    this.collaborationHistory = [];
  }

  /**
   * 협력 세션 생성
   */
  createSession(topic, aiAgent, users) {
    const id = `session-${Date.now()}`;
    const session = new CollaborationSession(id, topic, aiAgent, users);
    this.sessions.push(session);
    return session;
  }

  /**
   * 협력 루프 실행
   */
  async runCollaborationLoop(session) {
    const history = {
      sessionId: session.id,
      iterations: 0,
      result: null,
      consensusReached: false,
      finalConsensusLevel: 0
    };

    for (let i = 0; i < this.config.maxIterations; i++) {
      history.iterations++;

      // 1. AI 제안 생성
      const proposal = await this.generateAIProposal(session);
      session.addProposal(proposal);

      // 2. 사용자 피드백 수집
      const feedbacks = await this.collectUserFeedback(session, proposal);

      for (const feedback of feedbacks) {
        session.addFeedback(feedback);
      }

      // 3. 합의도 평가
      const consensusPoints = InteractionAnalyzer.identifyConsensusPoints(session);

      if (session.consensusLevel >= this.config.consensusThreshold) {
        history.consensusReached = true;
        history.finalConsensusLevel = session.consensusLevel;
        break;
      }

      // 4. 갈등 영역 중재
      const conflicts = InteractionAnalyzer.identifyConflictAreas(session);
      if (conflicts.length > 0) {
        await this.mediateConflicts(session, conflicts);
      }
    }

    this.collaborationHistory.push(history);
    return history;
  }

  /**
   * AI 제안 생성
   */
  async generateAIProposal(session) {
    // 시뮬레이션
    return {
      id: `proposal-${Date.now()}`,
      content: `AI Proposal for ${session.topic}`,
      reasoning: 'Based on current consensus analysis',
      confidence: Math.random() * 0.5 + 0.5
    };
  }

  /**
   * 사용자 피드백 수집
   */
  async collectUserFeedback(session, proposal) {
    // 시뮬레이션
    const feedbacks = [];

    for (const user of session.users) {
      const feedbackType = ['suggestion', 'validation', 'correction', 'concern'][
        Math.floor(Math.random() * 4)
      ];

      const rating = Math.random() > 0.5 ? 1 : -1;

      feedbacks.push(
        new UserFeedback(
          user,
          feedbackType,
          `User feedback on ${proposal.id}`,
          rating
        )
      );
    }

    return feedbacks;
  }

  /**
   * 갈등 중재
   */
  async mediateConflicts(session, conflicts) {
    for (const conflict of conflicts) {
      // 중재 프로세스
      // 1. 양측의 관점 분석
      // 2. 공통점 찾기
      // 3. 수정된 제안 제시
    }
  }

  /**
   * 협력 보고서 생성
   */
  generateCollaborationReport(sessionId) {
    const session = this.sessions.find(s => s.id === sessionId);
    if (!session) return null;

    const patterns = InteractionAnalyzer.analyzePatterns(session);
    const consensusPoints = InteractionAnalyzer.identifyConsensusPoints(session);
    const conflicts = InteractionAnalyzer.identifyConflictAreas(session);
    const trustLevel = InteractionAnalyzer.evaluateTrustLevel(session);

    return {
      session: session.summarize(),
      patterns,
      consensusPoints: consensusPoints.slice(0, 3),
      conflicts: conflicts.slice(0, 3),
      trustLevel,
      recommendations: this.generateRecommendations(
        consensusPoints, conflicts, trustLevel
      )
    };
  }

  /**
   * 추천사항 생성
   */
  generateRecommendations(consensusPoints, conflicts, trustLevel) {
    const recommendations = [];

    if (consensusPoints.length > 0) {
      recommendations.push({
        type: 'implement',
        proposal: consensusPoints[0],
        reason: '높은 합의도'
      });
    }

    if (conflicts.length > 0) {
      recommendations.push({
        type: 'mediate',
        conflict: conflicts[0],
        reason: '의견 불일치 해소 필요'
      });
    }

    if (trustLevel < 0.5) {
      recommendations.push({
        type: 'review',
        reason: '신뢰도 향상 필요'
      });
    }

    return recommendations;
  }

  /**
   * JSON 내보내기
   */
  toJSON() {
    return {
      activeSessions: this.sessions.length,
      completedCollaborations: this.collaborationHistory.length,
      averageConsensusLevel: this.collaborationHistory.reduce((sum, h) => {
        return sum + h.finalConsensusLevel;
      }, 0) / (this.collaborationHistory.length || 1),
      recentHistory: this.collaborationHistory.slice(-3)
    };
  }
}

