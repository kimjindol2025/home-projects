#### 영향 분석 예제
```javascript
import { ChangeItem, SystemComponent, ImpactSimulator } from './impact-simulator.js';

const sim = new ImpactSimulator();
sim.addComponent('api', 'API', 'critical');
sim.addComponent('db', 'DB', 'critical');

const change = new ChangeItem('ch1', 'API 배포', 'code');
change.setSeverity('high');
change.addAffectedComponent('api');
sim.addChange(change);

const analysis = sim.analyzeImpact('ch1');
console.log(`위험도: ${analysis.riskLevel}`);

const strategies = sim.suggestMitigation(analysis);
strategies.forEach(s => console.log(`- ${s.action}`));
