  console.log(`Time: ${snapshot.timestamp}`);
  Object.entries(snapshot.metrics).forEach(([name, stats]) => {
    console.log(`${name}: avg=${stats.avg.toFixed(2)}`);
  });
});

dashboard.start();
setTimeout(() => dashboard.stop(), 10000);
```

