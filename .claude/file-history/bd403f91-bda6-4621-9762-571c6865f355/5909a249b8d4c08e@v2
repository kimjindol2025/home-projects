#!/usr/bin/env node

/**
 * Heatmap Generator - 히트맵 생성
 * Phase 9.3: 고급 시각화
 *
 * 기능:
 * - 메트릭 기반 히트맵
 * - 색상 매핑
 * - 시간 시리즈 시각화
 * - 상관관계 분석
 */

/**
 * 히트맵 셀
 */
class HeatmapCell {
  constructor(x, y, value) {
    this.x = x;
    this.y = y;
    this.value = value;
    this.color = '#ffffff';
    this.intensity = 0;
  }

  /**
   * 강도 계산 (0-1)
   */
  calculateIntensity(minValue, maxValue) {
    if (maxValue === minValue) {
      this.intensity = 0.5;
    } else {
      this.intensity = (this.value - minValue) / (maxValue - minValue);
    }
    return this.intensity;
  }

  /**
   * 색상 설정 (강도 기반)
   */
  setColorFromIntensity() {
    const hue = (1 - this.intensity) * 240; // 파란색(240) ~ 빨간색(0)
    const saturation = this.intensity * 100;
    const lightness = 50 - this.intensity * 30;

    this.color = `hsl(${hue}, ${saturation}%, ${lightness}%)`;
    return this;
  }
}

/**
 * 히트맵 생성기
 */
class HeatmapGenerator {
  constructor(config = {}) {
    this.config = {
      colorScheme: config.colorScheme || 'heatmap', // heatmap, cool, warm, grayscale
      minValue: config.minValue || 0,
      maxValue: config.maxValue || 100,
      cellSize: config.cellSize || 20,
      ...config
    };

    this.data = [];
    this.width = 0;
    this.height = 0;
  }

  /**
   * 메트릭 데이터 로드
   */
  loadData(matrix) {
    this.data = [];
    this.height = matrix.length;
    this.width = matrix[0].length;

    for (let y = 0; y < matrix.length; y++) {
      for (let x = 0; x < matrix[y].length; x++) {
        const cell = new HeatmapCell(x, y, matrix[y][x]);
        this.data.push(cell);
      }
    }

    this.normalize();
    return this;
  }

  /**
   * 데이터 정규화
   */
  normalize() {
    let minValue = Infinity;
    let maxValue = -Infinity;

    for (const cell of this.data) {
      minValue = Math.min(minValue, cell.value);
      maxValue = Math.max(maxValue, cell.value);
    }

    for (const cell of this.data) {
      cell.calculateIntensity(minValue, maxValue);
      cell.setColorFromIntensity();
    }
  }

  /**
   * SVG 생성
   */
  toSVG(width = 600, height = 400) {
    const cellWidth = width / this.width;
    const cellHeight = height / this.height;

    let svg = `<svg width="${width}" height="${height}" xmlns="http://www.w3.org/2000/svg">\n`;
    svg += `  <defs>\n`;
    svg += `    <style>\n`;
    svg += `      .heatmap-cell { stroke: none; }\n`;
    svg += `      .heatmap-cell:hover { stroke: black; stroke-width: 2; }\n`;
    svg += `    </style>\n`;
    svg += `  </defs>\n`;

    // 그리드
    for (const cell of this.data) {
      const x = cell.x * cellWidth;
      const y = cell.y * cellHeight;

      svg += `  <rect class="heatmap-cell" x="${x}" y="${y}" width="${cellWidth}" height="${cellHeight}" fill="${cell.color}" title="${cell.value.toFixed(2)}"/>\n`;
    }

    // 범례
    svg += this.generateLegend(width, height);

    svg += `</svg>`;
    return svg;
  }

  /**
   * 범례 생성
   */
  generateLegend(width, height) {
    const legendX = width - 100;
    const legendY = 20;
    const legendHeight = 150;
    const legendWidth = 20;

    let legend = `  <!-- Legend -->\n`;

    // 그래디언트
    for (let i = 0; i <= 10; i++) {
      const intensity = i / 10;
      const hue = (1 - intensity) * 240;
      const saturation = intensity * 100;
      const lightness = 50 - intensity * 30;
      const color = `hsl(${hue}, ${saturation}%, ${lightness}%)`;

      const y = legendY + (i * legendHeight / 10);
      legend += `  <rect x="${legendX}" y="${y}" width="${legendWidth}" height="${legendHeight / 10}" fill="${color}" stroke="black" stroke-width="1"/>\n`;
    }

    // 라벨
    legend += `  <text x="${legendX + legendWidth + 5}" y="${legendY}" font-size="10">${this.config.maxValue.toFixed(0)}</text>\n`;
    legend += `  <text x="${legendX + legendWidth + 5}" y="${legendY + legendHeight / 2}" font-size="10">${((this.config.maxValue + this.config.minValue) / 2).toFixed(0)}</text>\n`;
    legend += `  <text x="${legendX + legendWidth + 5}" y="${legendY + legendHeight}" font-size="10">${this.config.minValue.toFixed(0)}</text>\n`;

    return legend;
  }

  /**
   * HTML 캔버스 명령 생성
   */
  toCanvasCommands(width = 600, height = 400) {
    const cellWidth = width / this.width;
    const cellHeight = height / this.height;
    const commands = [];

    for (const cell of this.data) {
      commands.push({
        type: 'fillRect',
        x: cell.x * cellWidth,
        y: cell.y * cellHeight,
        width: cellWidth,
        height: cellHeight,
        color: cell.color,
        value: cell.value
      });
    }

    return commands;
  }

  /**
   * JSON 내보내기
   */
  toJSON() {
    const heatmapData = [];

    for (const cell of this.data) {
      heatmapData.push({
        x: cell.x,
        y: cell.y,
        value: cell.value,
        intensity: cell.intensity,
        color: cell.color
      });
    }

    return {
      width: this.width,
      height: this.height,
      data: heatmapData,
      config: this.config
    };
  }
}

/**
 * 상관관계 히트맵
 */
class CorrelationHeatmap {
  /**
   * 상관계수 계산
   */
  static calculateCorrelation(arrayA, arrayB) {
    const n = Math.min(arrayA.length, arrayB.length);
    const meanA = arrayA.reduce((a, b) => a + b) / n;
    const meanB = arrayB.reduce((a, b) => a + b) / n;

    let numerator = 0;
    let denomA = 0;
    let denomB = 0;

    for (let i = 0; i < n; i++) {
      const diffA = arrayA[i] - meanA;
      const diffB = arrayB[i] - meanB;

      numerator += diffA * diffB;
      denomA += diffA * diffA;
      denomB += diffB * diffB;
    }

    const denominator = Math.sqrt(denomA * denomB);
    return denominator === 0 ? 0 : numerator / denominator;
  }

  /**
   * 상관관계 행렬 생성
   */
  static generateCorrelationMatrix(datasets) {
    const size = datasets.length;
    const matrix = Array(size).fill(0).map(() => Array(size).fill(0));

    for (let i = 0; i < size; i++) {
      for (let j = 0; j < size; j++) {
        if (i === j) {
          matrix[i][j] = 1; // 자기 상관
        } else {
          matrix[i][j] = this.calculateCorrelation(datasets[i], datasets[j]);
        }
      }
    }

    return matrix;
  }
}

/**
 * 시간 시리즈 히트맵
 */
class TimeSeriesHeatmap {
  /**
   * 시계열 데이터로부터 히트맵 생성
   */
  static generateFromTimeSeries(timeSeries, binSize = 10) {
    const days = Math.ceil(timeSeries.length / binSize);
    const matrix = Array(24).fill(0).map(() => Array(days).fill(0));

    for (let i = 0; i < timeSeries.length; i++) {
      const day = Math.floor(i / binSize);
      const hour = Math.floor((i % binSize) * 24 / binSize);

      if (day < days && hour < 24) {
        matrix[hour][day] = timeSeries[i];
      }
    }

    return matrix;
  }

  /**
   * 요일별 활동성 히트맵
   */
  static generateActivityHeatmap(activityData) {
    // 7일 x 24시간 매트릭스
    const matrix = Array(24).fill(0).map(() => Array(7).fill(0));

    for (const { day, hour, value } of activityData) {
      if (day >= 0 && day < 7 && hour >= 0 && hour < 24) {
        matrix[hour][day] = value;
      }
    }

    return matrix;
  }
}

