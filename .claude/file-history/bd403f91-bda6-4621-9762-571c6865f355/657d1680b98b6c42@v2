#!/usr/bin/env node

/**
 * QAOA Optimizer - 양자 근사 최적화 알고리즘
 * Phase 10.2: Advanced Quantum Optimization
 *
 * 기능:
 * - 그래프 문제 정의 (MaxCut, TSP)
 * - 비용 해밀토니안 구성
 * - 혼합 해밀토니안 구성
 * - QAOA 회로 최적화
 */

/**
 * 최적화 문제
 */
class OptimizationProblem {
  constructor(problemType, nodes, edges, weights = []) {
    this.problemType = problemType;  // MaxCut, TSP, MIS, etc.
    this.nodes = nodes;
    this.edges = edges;  // [[i, j], ...]
    this.weights = weights.length > 0 ? weights : edges.map(() => 1.0);
    this.costMatrix = this.buildCostMatrix();
  }

  /**
   * 비용 행렬 구성
   */
  buildCostMatrix() {
    const n = this.nodes.length;
    const matrix = Array(n).fill(0).map(() => Array(n).fill(0));

    for (let i = 0; i < this.edges.length; i++) {
      const [u, v] = this.edges[i];
      const weight = this.weights[i];

      matrix[u][v] = weight;
      matrix[v][u] = weight;
    }

    return matrix;
  }

  /**
   * 문제 정보
   */
  getInfo() {
    return {
      problemType: this.problemType,
      nodes: this.nodes.length,
      edges: this.edges.length,
      totalWeight: this.weights.reduce((a, b) => a + b, 0),
      density: (2 * this.edges.length) / (this.nodes.length * (this.nodes.length - 1))
    };
  }

  /**
   * 솔루션 평가 (비용)
   */
  evaluateSolution(bitstring) {
    let cost = 0;

    if (this.problemType === 'MaxCut') {
      // MaxCut: 컷 크기 최대화
      for (let i = 0; i < this.edges.length; i++) {
        const [u, v] = this.edges[i];
        if (bitstring[u] !== bitstring[v]) {
          cost += this.weights[i];
        }
      }
    } else if (this.problemType === 'MIS') {
      // Maximum Independent Set: 독립 집합 크기
      for (let i = 0; i < this.nodes.length; i++) {
        if (bitstring[i] === 1) {
          cost += 1;
        }
      }

      // 인접한 노드 페널티
      for (let i = 0; i < this.edges.length; i++) {
        const [u, v] = this.edges[i];
        if (bitstring[u] === 1 && bitstring[v] === 1) {
          cost -= 10;  // 큰 페널티
        }
      }
    }

    return cost;
  }
}

/**
 * QAOA 해밀토니안
 */
class QAOAHamiltonian {
  constructor(problem) {
    this.problem = problem;
    this.costHamiltonian = null;
    this.mixerHamiltonian = null;
    this.constructHamiltonians();
  }

  /**
   * 해밀토니안 구성
   */
  constructHamiltonians() {
    const n = this.problem.nodes.length;

    // 비용 해밀토니안 구성
    this.costHamiltonian = {
      terms: [],
      description: 'Cost Hamiltonian for ' + this.problem.problemType
    };

    // MaxCut의 경우: H_C = (1 - Z_i*Z_j) / 2 for each edge
    for (let i = 0; i < this.problem.edges.length; i++) {
      const [u, v] = this.problem.edges[i];
      const weight = this.problem.weights[i];

      const pauliStr = 'I'.repeat(n);
      // Z_u * Z_v 항 구성
      this.costHamiltonian.terms.push({
        operator: `Z${u}Z${v}`,
        coefficient: weight / 2
      });
    }

    // 혼합 해밀토니안: H_M = Σ_i X_i
    this.mixerHamiltonian = {
      terms: [],
      description: 'Mixer Hamiltonian'
    };

    for (let i = 0; i < n; i++) {
      this.mixerHamiltonian.terms.push({
        operator: `X${i}`,
        coefficient: 1.0
      });
    }
  }

  /**
   * 비용 해밀토니안 정보
   */
  getCostInfo() {
    return {
      terms: this.costHamiltonian.terms.length,
      description: this.costHamiltonian.description
    };
  }

  /**
   * 혼합 해밀토니안 정보
   */
  getMixerInfo() {
    return {
      terms: this.mixerHamiltonian.terms.length,
      description: this.mixerHamiltonian.description
    };
  }
}

/**
 * QAOA 회로
 */
class QAOACircuit {
  constructor(problemSize, layers = 1) {
    this.problemSize = problemSize;
    this.layers = layers;
    this.parameters = [];
    this.initializeParameters();
  }

  /**
   * 파라미터 초기화 (γ, β)
   */
  initializeParameters() {
    // 각 레이어마다 γ (cost) 과 β (mixer) 파라미터
    for (let i = 0; i < this.layers; i++) {
      this.parameters.push(Math.random() * Math.PI);      // γ
      this.parameters.push(Math.random() * Math.PI);      // β
    }
  }

  /**
   * 회로 구성
   */
  buildCircuit() {
    const gates = [];

    // 초기 중첩 상태
    for (let q = 0; q < this.problemSize; q++) {
      gates.push({ gate: 'H', qubits: [q] });
    }

    // QAOA 레이어
    for (let layer = 0; layer < this.layers; layer++) {
      const gamma = this.parameters[layer * 2];
      const beta = this.parameters[layer * 2 + 1];

      // 비용 해밀토니안 적용
      gates.push({
        gate: 'CostUnitary',
        gamma,
        description: 'Cost Hamiltonian'
      });

      // 혼합 해밀토니안 적용
      for (let q = 0; q < this.problemSize; q++) {
        gates.push({
          gate: 'RX',
          qubits: [q],
          params: [2 * beta]
        });
      }
    }

    return gates;
  }

  /**
   * 파라미터 업데이트
   */
  updateParameters(newParams) {
    this.parameters = newParams;
  }

  /**
   * 회로 정보
   */
  getInfo() {
    return {
      problemSize: this.problemSize,
      layers: this.layers,
      parameterCount: this.parameters.length,
      parameters: this.parameters.map(p => p.toFixed(3))
    };
  }
}

/**
 * QAOA 최적화기
 */
class QAOAOptimizer {
  constructor(problem, layers = 1) {
    this.problem = problem;
    this.hamiltonian = new QAOAHamiltonian(problem);
    this.circuit = new QAOACircuit(problem.nodes.length, layers);
    this.history = [];
    this.bestSolution = null;
    this.bestCost = -Infinity;
    this.iteration = 0;
  }

  /**
   * 샘플링 (회로 실행)
   */
  sampleCircuit(shots = 1000) {
    const bitstrings = [];

    for (let i = 0; i < shots; i++) {
      const bitstring = this.circuit.problemSize;
      let bs = '';

      for (let q = 0; q < this.circuit.problemSize; q++) {
        bs += Math.random() > 0.5 ? '1' : '0';
      }

      bitstrings.push(bs);
    }

    return bitstrings;
  }

  /**
   * 기댓값 계산
   */
  computeExpectation(shots = 1000) {
    const bitstrings = this.sampleCircuit(shots);
    let totalCost = 0;

    for (const bs of bitstrings) {
      const bitarray = bs.split('').map(b => parseInt(b));
      const cost = this.problem.evaluateSolution(bitarray);
      totalCost += cost;

      // 최적 솔루션 추적
      if (cost > this.bestCost) {
        this.bestCost = cost;
        this.bestSolution = bs;
      }
    }

    return totalCost / shots;
  }

  /**
   * 최적화 단계 (동시 섭동 확률 경사 근사)
   */
  optimizeStep(shots = 1000) {
    const expectation = this.computeExpectation(shots);

    // SPSA: 무작위 방향으로 섭동
    const perturbation = 0.01;
    const learningRate = 0.05;

    for (let i = 0; i < this.circuit.parameters.length; i++) {
      const delta = (Math.random() - 0.5) * 2;

      this.circuit.parameters[i] -= learningRate * delta * (expectation / shots);
      this.circuit.parameters[i] = ((this.circuit.parameters[i] + Math.PI) % (2 * Math.PI)) - Math.PI;
    }

    this.iteration++;
    this.history.push({
      iteration: this.iteration,
      expectation,
      bestCost: this.bestCost,
      approximationRatio: this.bestCost > 0 ? this.bestCost : 0
    });

    return expectation;
  }

  /**
   * 전체 최적화 실행
   */
  optimize(maxIterations = 50, shots = 1000) {
    for (let i = 0; i < maxIterations; i++) {
      this.optimizeStep(shots);
    }

    return {
      bestSolution: this.bestSolution,
      bestCost: this.bestCost,
      iterations: this.iteration,
      approximationRatio: this.computeApproximationRatio()
    };
  }

  /**
   * 근사 비율 계산
   */
  computeApproximationRatio() {
    // 클래식 알고리즘으로 구한 최적값과의 비교
    const classicalOptimum = this.problem.edges.reduce((sum, _, i) =>
      sum + this.problem.weights[i], 0) / 2;  // MaxCut의 경우

    return this.bestCost / classicalOptimum;
  }

  /**
   * 최적화 히스토리
   */
  getHistory(limit = 10) {
    return this.history.slice(-limit);
  }

  /**
   * 최종 결과
   */
  getFinalResult() {
    return {
      problemType: this.problem.problemType,
      bestSolution: this.bestSolution,
      bestCost: this.bestCost,
      iterations: this.iteration,
      approximationRatio: this.computeApproximationRatio(),
      layers: this.circuit.layers
    };
  }
}

