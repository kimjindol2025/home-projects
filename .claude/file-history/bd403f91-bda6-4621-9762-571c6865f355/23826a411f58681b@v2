#!/usr/bin/env node

/**
 * Auto Learning Engine - 자동 학습 엔진
 * Phase 9.5: 자율 지식
 *
 * 기능:
 * - 경험 기반 학습
 * - 지식 추출
 * - 피드백 처리
 * - 모델 개선
 */

/**
 * 학습 경험
 */
class LearningExperience {
  constructor(id, input, output, outcome, feedback = {}) {
    this.id = id;
    this.input = input;                    // 입력 데이터
    this.output = output;                  // 출력
    this.outcome = outcome;                // 결과 (success, fail, partial)
    this.feedback = feedback;              // 사용자 피드백
    this.timestamp = Date.now();
    this.value = 0;                        // 학습 가치 점수
    this.confidence = 0;                   // 신뢰도
  }
}

/**
 * 경험 수집기
 */
class ExperienceCollector {
  constructor(maxSize = 10000) {
    this.experiences = [];
    this.maxSize = maxSize;
    this.distribution = {};
  }

  /**
   * 경험 추가
   */
  addExperience(experience) {
    this.experiences.push(experience);

    // 분포 추적
    const key = `${experience.outcome}`;
    this.distribution[key] = (this.distribution[key] || 0) + 1;

    // 크기 제한
    if (this.experiences.length > this.maxSize) {
      const removed = this.experiences.shift();
      this.distribution[`${removed.outcome}`]--;
    }

    return this;
  }

  /**
   * 고가치 경험 필터링
   */
  getHighValueExperiences(minValue = 0.7) {
    return this.experiences.filter(exp => exp.value >= minValue);
  }

  /**
   * 실패 사례 분석
   */
  getFailurePatterns() {
    const failures = this.experiences.filter(exp => exp.outcome === 'fail');
    const patterns = {};

    for (const fail of failures) {
      const key = JSON.stringify(fail.input);
      patterns[key] = (patterns[key] || 0) + 1;
    }

    return Object.entries(patterns)
      .sort((a, b) => b[1] - a[1])
      .slice(0, 10)
      .map(([key, count]) => ({
        pattern: JSON.parse(key),
        frequency: count
      }));
  }

  /**
   * 성공 패턴
   */
  getSuccessPatterns() {
    const successes = this.experiences.filter(exp => exp.outcome === 'success');
    const patterns = [];

    for (const success of successes.slice(-100)) {
      patterns.push({
        input: success.input,
        output: success.output,
        feedback: success.feedback
      });
    }

    return patterns.slice(0, 20);
  }
}

/**
 * 지식 추출기
 */
class KnowledgeExtractor {
  /**
   * 규칙 추출
   */
  static extractRules(experiences) {
    const rules = [];

    // 빈도가 높은 패턴에서 규칙 추출
    for (let i = 0; i < experiences.length; i++) {
      const exp1 = experiences[i];

      for (let j = i + 1; j < experiences.length; j++) {
        const exp2 = experiences[j];

        // 유사 입력, 동일 출력 → 규칙
        if (this.isSimilarInput(exp1.input, exp2.input) &&
            exp1.output === exp2.output) {
          rules.push({
            condition: exp1.input,
            action: exp1.output,
            confidence: 0.8,
            support: 2
          });
        }
      }
    }

    return rules.slice(0, 10);
  }

  /**
   * 유사도 판정
   */
  static isSimilarInput(input1, input2, threshold = 0.8) {
    if (typeof input1 !== typeof input2) return false;

    if (typeof input1 === 'object') {
      const keys = Object.keys(input1);
      let matches = 0;

      for (const key of keys) {
        if (input1[key] === input2[key]) matches++;
      }

      return matches / keys.length >= threshold;
    }

    return input1 === input2;
  }

  /**
   * 인사이트 추출
   */
  static extractInsights(experiences) {
    const insights = [];

    // 1. 가장 효과적인 패턴
    const successPatterns = experiences
      .filter(exp => exp.outcome === 'success')
      .slice(-20);

    if (successPatterns.length > 0) {
      insights.push({
        type: 'success-pattern',
        description: '높은 성공률 패턴 감지',
        examples: successPatterns.slice(0, 3).map(p => p.input),
        actionability: 0.9
      });
    }

    // 2. 위험 패턴
    const failPatterns = experiences
      .filter(exp => exp.outcome === 'fail')
      .slice(-20);

    if (failPatterns.length > 0) {
      insights.push({
        type: 'risk-pattern',
        description: '높은 실패율 패턴 식별',
        examples: failPatterns.slice(0, 3).map(p => p.input),
        actionability: 0.85
      });
    }

    // 3. 경향 변화
    const recent = experiences.slice(-50);
    const success_rate = recent.filter(e => e.outcome === 'success').length / recent.length;

    if (success_rate > 0.8) {
      insights.push({
        type: 'improvement-trend',
        description: '최근 성능 개선 추세',
        value: success_rate,
        actionability: 0.7
      });
    }

    return insights;
  }
}

/**
 * 피드백 처리기
 */
class FeedbackProcessor {
  constructor() {
    this.feedbackHistory = [];
  }

  /**
   * 피드백 처리
   */
  processFeedback(feedback) {
    this.feedbackHistory.push({
      ...feedback,
      timestamp: Date.now(),
      processed: true
    });

    // 가중치 계산
    const weight = this.calculateFeedbackWeight(feedback);

    return {
      feedback,
      weight,
      processed: true,
      actionable: weight > 0.5
    };
  }

  /**
   * 피드백 가중치 계산
   */
  calculateFeedbackWeight(feedback) {
    let weight = 0.5;

    // 명확성
    if (feedback.clarity === 'high') weight += 0.2;
    if (feedback.clarity === 'medium') weight += 0.1;

    // 신뢰성
    if (feedback.reliability === 'high') weight += 0.15;
    if (feedback.reliability === 'medium') weight += 0.08;

    // 실행가능성
    if (feedback.actionable === true) weight += 0.15;

    return Math.min(weight, 1.0);
  }

  /**
   * 피드백 종합
   */
  synthesizeFeedback(feedbacks) {
    const weighted = feedbacks
      .map(fb => ({
        ...fb,
        weight: this.calculateFeedbackWeight(fb)
      }))
      .sort((a, b) => b.weight - a.weight);

    return {
      topFeedback: weighted.slice(0, 3),
      consensusScore: weighted.reduce((s, f) => s + f.weight, 0) / weighted.length,
      theme: this.identifyTheme(weighted)
    };
  }

  /**
   * 주제 식별
   */
  identifyTheme(feedbacks) {
    const themes = {};

    for (const fb of feedbacks) {
      const theme = fb.category || 'general';
      themes[theme] = (themes[theme] || 0) + 1;
    }

    const sorted = Object.entries(themes)
      .sort((a, b) => b[1] - a[1]);

    return sorted[0] ? sorted[0][0] : 'general';
  }
}

/**
 * 자동 학습 엔진
 */
class AutoLearningEngine {
  constructor(config = {}) {
    this.config = {
      learningRate: config.learningRate || 0.1,
      batchSize: config.batchSize || 32,
      epochs: config.epochs || 10,
      ...config
    };

    this.experienceCollector = new ExperienceCollector(config.maxExperiences || 10000);
    this.feedbackProcessor = new FeedbackProcessor();
    this.learnedKnowledge = [];
    this.models = {};
    this.generalizationAbility = 0;
  }

  /**
   * 경험으로부터 학습
   */
  learn(experience) {
    // 1. 경험 저장
    this.experienceCollector.addExperience(experience);

    // 2. 경험 가치 평가
    experience.value = this.evaluateExperience(experience);
    experience.confidence = this.calculateConfidence(experience);

    // 3. 고가치 경험에서 지식 추출
    if (experience.value > 0.6) {
      const extracted = KnowledgeExtractor.extractRules([experience]);
      this.learnedKnowledge.push(...extracted);
    }

    // 4. 모델 업데이트
    this.updateModel();

    return {
      learned: true,
      value: experience.value,
      confidence: experience.confidence,
      knowledgeCount: this.learnedKnowledge.length
    };
  }

  /**
   * 경험 가치 평가
   */
  evaluateExperience(experience) {
    let value = 0.5;

    if (experience.outcome === 'success') {
      value = 0.9;
    } else if (experience.outcome === 'partial') {
      value = 0.6;
    } else {
      value = 0.3;
    }

    // 피드백 고려
    if (experience.feedback && experience.feedback.value) {
      value = value * 0.7 + experience.feedback.value * 0.3;
    }

    return value;
  }

  /**
   * 신뢰도 계산
   */
  calculateConfidence(experience) {
    const successExperiences = this.experienceCollector.experiences
      .filter(exp => exp.outcome === 'success');

    const similarCount = successExperiences
      .filter(exp => KnowledgeExtractor.isSimilarInput(
        exp.input, experience.input, 0.7
      )).length;

    return Math.min(0.9, 0.5 + (similarCount / 10) * 0.4);
  }

  /**
   * 피드백 통합
   */
  incorporateFeedback(feedback) {
    const processed = this.feedbackProcessor.processFeedback(feedback);

    if (processed.actionable) {
      // 피드백 기반 모델 조정
      if (feedback.suggestion) {
        this.learnedKnowledge.push({
          source: 'human-feedback',
          suggestion: feedback.suggestion,
          confidence: processed.weight,
          timestamp: Date.now()
        });
      }
    }

    return processed;
  }

  /**
   * 모델 업데이트
   */
  updateModel() {
    const highValueExp = this.experienceCollector.getHighValueExperiences(0.7);

    if (highValueExp.length > this.config.batchSize) {
      // 배치 학습
      const batch = highValueExp.slice(-this.config.batchSize);

      for (let epoch = 0; epoch < this.config.epochs; epoch++) {
        for (const exp of batch) {
          // 그래디언트 계산 및 모델 업데이트
          this.updateModelWeights(exp);
        }
      }

      // 일반화 능력 계산
      this.generalizationAbility = this.calculateGeneralization();
    }
  }

  /**
   * 모델 가중치 업데이트
   */
  updateModelWeights(experience) {
    const prediction = this.predict(experience.input);
    const error = experience.outcome === 'success' ? 0 : 1;
    const delta = (error - prediction) * this.config.learningRate;

    // 간단한 가중치 업데이트
    if (!this.models.weights) {
      this.models.weights = {};
    }

    for (const key in experience.input) {
      const w = this.models.weights[key] || 0.5;
      this.models.weights[key] = w + delta * 0.01;
    }
  }

  /**
   * 예측
   */
  predict(input) {
    if (!this.learnedKnowledge.length) return 0.5;

    // 학습된 규칙 기반 예측
    for (const rule of this.learnedKnowledge) {
      if (KnowledgeExtractor.isSimilarInput(rule.condition, input, 0.7)) {
        return rule.confidence;
      }
    }

    return 0.5;
  }

  /**
   * 일반화 능력 계산
   */
  calculateGeneralization() {
    if (this.learnedKnowledge.length === 0) return 0;

    // 규칙의 일반성 평가
    const generality = this.learnedKnowledge.filter(k => k.confidence > 0.7).length
      / this.learnedKnowledge.length;

    // 경험 다양성
    const diversity = this.experienceCollector.experiences.length / 1000;

    return Math.min(1, (generality * 0.6 + diversity * 0.4));
  }

  /**
   * 학습 상태
   */
  getStatus() {
    const insights = KnowledgeExtractor.extractInsights(
      this.experienceCollector.experiences
    );

    return {
      experienceCount: this.experienceCollector.experiences.length,
      knowledgeCount: this.learnedKnowledge.length,
      generalizationAbility: this.generalizationAbility,
      insights,
      distribution: this.experienceCollector.distribution
    };
  }

  /**
   * JSON 내보내기
   */
  toJSON() {
    return {
      experiences: this.experienceCollector.experiences.length,
      knowledge: this.learnedKnowledge.slice(0, 5),
      generalization: this.generalizationAbility,
      insights: KnowledgeExtractor.extractInsights(
        this.experienceCollector.experiences
      )
    };
  }
}

