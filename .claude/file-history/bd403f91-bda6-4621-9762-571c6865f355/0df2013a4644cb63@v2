#!/usr/bin/env node

/**
 * 3D Architecture Graph - 3D 아키텍처 그래프
 * Phase 9.3: 고급 시각화
 *
 * 기능:
 * - 3D 모듈 그래프 생성
 * - 레이어 시각화
 * - 의존성 시각화
 * - 상호작용 시뮬레이션
 */

/**
 * 3D 노드 클래스
 */
class Node3D {
  constructor(id, label, type = 'module') {
    this.id = id;
    this.label = label;
    this.type = type;
    this.position = { x: 0, y: 0, z: 0 };
    this.size = 1;
    this.color = '#3498db';
    this.metadata = {};
  }

  /**
   * 위치 설정
   */
  setPosition(x, y, z) {
    this.position = { x, y, z };
    return this;
  }

  /**
   * 크기 설정
   */
  setSize(size) {
    this.size = size;
    return this;
  }

  /**
   * 색상 설정
   */
  setColor(color) {
    this.color = color;
    return this;
  }

  /**
   * 메타데이터 추가
   */
  addMetadata(key, value) {
    this.metadata[key] = value;
    return this;
  }

  /**
   * 거리 계산
   */
  distanceTo(other) {
    const dx = this.position.x - other.position.x;
    const dy = this.position.y - other.position.y;
    const dz = this.position.z - other.position.z;
    return Math.sqrt(dx * dx + dy * dy + dz * dz);
  }
}

/**
 * 3D 에지 클래스
 */
class Edge3D {
  constructor(source, target, weight = 1) {
    this.source = source;
    this.target = target;
    this.weight = weight;
    this.color = '#95a5a6';
    this.style = 'solid';
  }

  /**
   * 에지 강도 설정
   */
  setStrength(strength) {
    this.weight = strength;
    return this;
  }

  /**
   * 스타일 설정
   */
  setStyle(style) {
    this.style = style; // solid, dashed, dotted
    return this;
  }
}

/**
 * 3D 그래프 생성기
 */
class Graph3DBuilder {
  constructor(config = {}) {
    this.config = {
      width: config.width || 1000,
      height: config.height || 800,
      depth: config.depth || 600,
      spacing: config.spacing || 200,
      ...config
    };

    this.nodes = [];
    this.edges = [];
  }

  /**
   * 노드 추가
   */
  addNode(id, label, type) {
    const node = new Node3D(id, label, type);
    this.nodes.push(node);
    return node;
  }

  /**
   * 에지 추가
   */
  addEdge(sourceId, targetId, weight) {
    const source = this.nodes.find(n => n.id === sourceId);
    const target = this.nodes.find(n => n.id === targetId);

    if (source && target) {
      const edge = new Edge3D(source, target, weight);
      this.edges.push(edge);
      return edge;
    }

    return null;
  }

  /**
   * 포스 기반 레이아웃 (Force-Directed Layout)
   */
  calculateLayout() {
    const iterations = 50;
    const k = 100; // 최적 거리
    const c = 0.1; // 감쇠
    const maxDisplace = 10;

    // 초기 위치 설정
    this.nodes.forEach((node, i) => {
      node.setPosition(
        Math.random() * this.config.width,
        Math.random() * this.config.height,
        Math.random() * this.config.depth
      );
    });

    // 반복
    for (let iter = 0; iter < iterations; iter++) {
      const forces = new Map();

      // 힘 계산
      for (const node of this.nodes) {
        forces.set(node.id, { x: 0, y: 0, z: 0 });
      }

      // 斥力 (Repulsive force)
      for (let i = 0; i < this.nodes.length; i++) {
        for (let j = i + 1; j < this.nodes.length; j++) {
          const nodeA = this.nodes[i];
          const nodeB = this.nodes[j];
          const dist = nodeA.distanceTo(nodeB) || 1;
          const dx = nodeB.position.x - nodeA.position.x;
          const dy = nodeB.position.y - nodeA.position.y;
          const dz = nodeB.position.z - nodeA.position.z;

          const repulsion = (k * k) / dist;
          const fx = (dx / dist) * repulsion;
          const fy = (dy / dist) * repulsion;
          const fz = (dz / dist) * repulsion;

          forces.get(nodeA.id).x -= fx;
          forces.get(nodeA.id).y -= fy;
          forces.get(nodeA.id).z -= fz;

          forces.get(nodeB.id).x += fx;
          forces.get(nodeB.id).y += fy;
          forces.get(nodeB.id).z += fz;
        }
      }

      // 인력 (Attractive force)
      for (const edge of this.edges) {
        const dist = edge.source.distanceTo(edge.target) || 1;
        const dx = edge.target.position.x - edge.source.position.x;
        const dy = edge.target.position.y - edge.source.position.y;
        const dz = edge.target.position.z - edge.source.position.z;

        const attraction = (dist * dist) / k * edge.weight;
        const fx = (dx / dist) * attraction;
        const fy = (dy / dist) * attraction;
        const fz = (dz / dist) * attraction;

        forces.get(edge.source.id).x += fx;
        forces.get(edge.source.id).y += fy;
        forces.get(edge.source.id).z += fz;

        forces.get(edge.target.id).x -= fx;
        forces.get(edge.target.id).y -= fy;
        forces.get(edge.target.id).z -= fz;
      }

      // 위치 업데이트
      for (const node of this.nodes) {
        const force = forces.get(node.id);
        const magnitude = Math.sqrt(force.x * force.x + force.y * force.y + force.z * force.z);
        const displacement = Math.min(magnitude * c, maxDisplace);

        if (magnitude > 0) {
          node.position.x += (force.x / magnitude) * displacement;
          node.position.y += (force.y / magnitude) * displacement;
          node.position.z += (force.z / magnitude) * displacement;
        }

        // 경계 제약
        node.position.x = Math.max(0, Math.min(this.config.width, node.position.x));
        node.position.y = Math.max(0, Math.min(this.config.height, node.position.y));
        node.position.z = Math.max(0, Math.min(this.config.depth, node.position.z));
      }
    }

    return this.nodes;
  }

  /**
   * 계층적 레이아웃
   */
  calculateHierarchicalLayout(rootId) {
    const levels = new Map();
    const visited = new Set();
    const queue = [{ id: rootId, level: 0 }];

    // BFS로 레벨 할당
    while (queue.length > 0) {
      const { id, level } = queue.shift();

      if (visited.has(id)) continue;
      visited.add(id);

      if (!levels.has(level)) {
        levels.set(level, []);
      }
      levels.get(level).push(id);

      const node = this.nodes.find(n => n.id === id);
      for (const edge of this.edges) {
        if (edge.source.id === id) {
          queue.push({ id: edge.target.id, level: level + 1 });
        }
      }
    }

    // 위치 할당
    for (const [level, nodeIds] of levels.entries()) {
      const count = nodeIds.length;
      const yOffset = level * this.config.spacing;

      for (let i = 0; i < count; i++) {
        const node = this.nodes.find(n => n.id === nodeIds[i]);
        if (node) {
          const xOffset = (i - count / 2) * this.config.spacing;
          node.setPosition(
            this.config.width / 2 + xOffset,
            yOffset,
            0
          );
        }
      }
    }

    return this.nodes;
  }

  /**
   * JSON 내보내기
   */
  toJSON() {
    return {
      nodes: this.nodes.map(n => ({
        id: n.id,
        label: n.label,
        type: n.type,
        position: n.position,
        size: n.size,
        color: n.color,
        metadata: n.metadata
      })),
      edges: this.edges.map(e => ({
        source: e.source.id,
        target: e.target.id,
        weight: e.weight,
        color: e.color,
        style: e.style
      }))
    };
  }

  /**
   * WebGL 형식으로 변환
   */
  toWebGLFormat() {
    const vertices = [];
    const colors = [];
    const indices = [];
    let vertexCount = 0;

    // 노드를 큐브로 렌더링
    for (const node of this.nodes) {
      const size = node.size;
      const x = node.position.x;
      const y = node.position.y;
      const z = node.position.z;

      // 큐브 꼭짓점
      const cubeVertices = [
        x - size, y - size, z - size,
        x + size, y - size, z - size,
        x + size, y + size, z - size,
        x - size, y + size, z - size,
        x - size, y - size, z + size,
        x + size, y - size, z + size,
        x + size, y + size, z + size,
        x - size, y + size, z + size
      ];

      vertices.push(...cubeVertices);

      // 색상
      const rgb = this.hexToRgb(node.color);
      for (let i = 0; i < 8; i++) {
        colors.push(rgb.r / 255, rgb.g / 255, rgb.b / 255, 1.0);
      }

      // 인덱스
      const baseIndex = vertexCount;
      const cubeIndices = [
        0, 1, 2, 2, 3, 0,
        4, 6, 5, 4, 7, 6,
        0, 4, 5, 5, 1, 0,
        2, 6, 7, 7, 3, 2,
        0, 3, 7, 7, 4, 0,
        1, 5, 6, 6, 2, 1
      ];

      for (const idx of cubeIndices) {
        indices.push(baseIndex + idx);
      }

      vertexCount += 8;
    }

    return { vertices, colors, indices };
  }

  /**
   * 16진수 색상을 RGB로 변환
   */
  hexToRgb(hex) {
    const result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
    return result ? {
      r: parseInt(result[1], 16),
      g: parseInt(result[2], 16),
      b: parseInt(result[3], 16)
    } : { r: 52, g: 152, b: 219 };
  }
}

/**
 * 3D 그래프 렌더러
 */
class Graph3DRenderer {
  /**
   * SVG로 2D 프로젝션 렌더링
   */
  renderSVG(graph, width = 1000, height = 800) {
    let svg = `<svg width="${width}" height="${height}" xmlns="http://www.w3.org/2000/svg">\n`;
    svg += `  <style>.node { cursor: pointer; } .edge { fill: none; } .label { font-size: 12px; }</style>\n`;

    // 에지 그리기
    for (const edge of graph.edges) {
      const x1 = edge.source.position.x * (width / graph.config.width);
      const y1 = edge.source.position.y * (height / graph.config.height);
      const x2 = edge.target.position.x * (width / graph.config.width);
      const y2 = edge.target.position.y * (height / graph.config.height);

      svg += `  <line x1="${x1}" y1="${y1}" x2="${x2}" y2="${y2}" stroke="${edge.color}" stroke-width="2" stroke-dasharray="${edge.style === 'dashed' ? '5,5' : '0'}"/>\n`;
    }

    // 노드 그리기
    for (const node of graph.nodes) {
      const x = node.position.x * (width / graph.config.width);
      const y = node.position.y * (height / graph.config.height);
      const r = node.size * 5;

      svg += `  <circle class="node" cx="${x}" cy="${y}" r="${r}" fill="${node.color}" stroke="black" stroke-width="2"/>\n`;
      svg += `  <text class="label" x="${x}" y="${y + 20}" text-anchor="middle" fill="black">${node.label}</text>\n`;
    }

    svg += `</svg>`;
    return svg;
  }

  /**
   * HTML 캔버스 좌표 생성
   */
  getCanvasCoordinates(graph, width = 1000, height = 800) {
    const coords = {
      nodes: [],
      edges: []
    };

    for (const node of graph.nodes) {
      coords.nodes.push({
        id: node.id,
        label: node.label,
        x: (node.position.x / graph.config.width) * width,
        y: (node.position.y / graph.config.height) * height,
        size: node.size * 5,
        color: node.color
      });
    }

    for (const edge of graph.edges) {
      coords.edges.push({
        source: edge.source.id,
        target: edge.target.id,
        x1: (edge.source.position.x / graph.config.width) * width,
        y1: (edge.source.position.y / graph.config.height) * height,
        x2: (edge.target.position.x / graph.config.width) * width,
        y2: (edge.target.position.y / graph.config.height) * height,
        color: edge.color
      });
    }

    return coords;
  }
}

