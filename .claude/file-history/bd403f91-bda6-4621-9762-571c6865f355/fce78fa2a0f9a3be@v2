#!/usr/bin/env node

/**
 * SLA Monitor - SLA 모니터링
 * Phase 10.4: Enterprise Deployment
 *
 * 기능:
 * - 가용성 모니터링 (99.9%)
 * - 응답 시간 추적
 * - 에러율 모니터링
 * - SLA 위반 감지
 */

/**
 * 가용성 추적기
 */
class AvailabilityTracker {
  constructor(targetAvailability = 99.9) {
    this.targetAvailability = targetAvailability;
    this.checks = [];
    this.downtime = 0;
    this.uptime = 0;
  }

  /**
   * 상태 확인
   */
  recordCheck(healthy) {
    const check = {
      timestamp: Date.now(),
      healthy,
      duration: 60000  // 1분 간격
    };

    this.checks.push(check);

    if (healthy) {
      this.uptime += check.duration;
    } else {
      this.downtime += check.duration;
    }

    return check;
  }

  /**
   * 현재 가용성 계산
   */
  calculateAvailability() {
    const totalTime = this.uptime + this.downtime;

    if (totalTime === 0) {
      return { uptime: '100%', downtime: '0%', availability: '100%', healthy: true };
    }

    const availability = (this.uptime / totalTime) * 100;
    const targetMet = availability >= this.targetAvailability;

    return {
      uptime: (this.uptime / totalTime * 100).toFixed(2) + '%',
      downtime: (this.downtime / totalTime * 100).toFixed(2) + '%',
      availability: availability.toFixed(3) + '%',
      targetAvailability: this.targetAvailability + '%',
      targetMet,
      status: targetMet ? 'PASSING' : 'FAILING'
    };
  }

  /**
   * 가용성 정보
   */
  getInfo() {
    return {
      totalChecks: this.checks.length,
      uptime: this.uptime,
      downtime: this.downtime,
      availability: this.calculateAvailability()
    };
  }
}

/**
 * 응답 시간 모니터
 */
class ResponseTimeMonitor {
  constructor(targetLatency = 200) {
    this.targetLatency = targetLatency;  // ms
    this.measurements = [];
  }

  /**
   * 응답 시간 기록
   */
  recordLatency(latency) {
    this.measurements.push({
      timestamp: Date.now(),
      latency  // ms
    });

    // 최근 1000개만 유지
    if (this.measurements.length > 1000) {
      this.measurements.shift();
    }

    return {
      latency,
      breached: latency > this.targetLatency
    };
  }

  /**
   * 통계 계산
   */
  getStatistics() {
    if (this.measurements.length === 0) {
      return null;
    }

    const latencies = this.measurements.map(m => m.latency).sort((a, b) => a - b);
    const sum = latencies.reduce((a, b) => a + b, 0);
    const count = latencies.length;

    return {
      min: latencies[0],
      max: latencies[latencies.length - 1],
      avg: (sum / count).toFixed(2),
      p50: latencies[Math.floor(count * 0.5)],
      p95: latencies[Math.floor(count * 0.95)],
      p99: latencies[Math.floor(count * 0.99)],
      targetLatency: this.targetLatency,
      breachRate: ((latencies.filter(l => l > this.targetLatency).length / count) * 100).toFixed(2) + '%'
    };
  }

  /**
   * 모니터 정보
   */
  getInfo() {
    return {
      measurements: this.measurements.length,
      statistics: this.getStatistics()
    };
  }
}

/**
 * 에러율 모니터
 */
class ErrorRateMonitor {
  constructor(targetErrorRate = 0.1) {
    this.targetErrorRate = targetErrorRate;  // %
    this.requests = [];
  }

  /**
   * 요청 기록
   */
  recordRequest(successful) {
    this.requests.push({
      timestamp: Date.now(),
      successful
    });

    // 최근 10000개만 유지
    if (this.requests.length > 10000) {
      this.requests.shift();
    }

    return {
      successful,
      totalRequests: this.requests.length
    };
  }

  /**
   * 에러율 계산
   */
  calculateErrorRate() {
    if (this.requests.length === 0) {
      return { errorRate: '0%', breached: false };
    }

    const failed = this.requests.filter(r => !r.successful).length;
    const errorRate = (failed / this.requests.length) * 100;

    return {
      errorRate: errorRate.toFixed(2) + '%',
      failedRequests: failed,
      totalRequests: this.requests.length,
      targetErrorRate: this.targetErrorRate + '%',
      breached: errorRate > this.targetErrorRate
    };
  }

  /**
   * 모니터 정보
   */
  getInfo() {
    return {
      requests: this.requests.length,
      errorRate: this.calculateErrorRate()
    };
  }
}

/**
 * SLA 모니터
 */
class SLAMonitor {
  constructor(targetAvailability = 99.9) {
    this.targetAvailability = targetAvailability;
    this.availabilityTracker = new AvailabilityTracker(targetAvailability);
    this.responseTimeMonitor = new ResponseTimeMonitor(200);
    this.errorRateMonitor = new ErrorRateMonitor(0.1);
    this.violations = [];
  }

  /**
   * 메트릭 수집
   */
  recordMetric(healthy, latency, successful) {
    const timestamp = Date.now();

    this.availabilityTracker.recordCheck(healthy);
    this.responseTimeMonitor.recordLatency(latency);
    this.errorRateMonitor.recordRequest(successful);

    // 위반 확인
    const stats = this.responseTimeMonitor.getStatistics();
    const errorRate = this.errorRateMonitor.calculateErrorRate();
    const availability = this.availabilityTracker.calculateAvailability();

    const violations = [];

    if (errorRate.breached) {
      violations.push('error-rate');
    }

    if (stats && parseFloat(stats.p95) > 200) {
      violations.push('latency-p95');
    }

    if (availability.status === 'FAILING') {
      violations.push('availability');
    }

    if (violations.length > 0) {
      this.violations.push({
        timestamp,
        violations,
        metrics: {
          availability: availability.availability,
          errorRate: errorRate.errorRate,
          latencyP95: stats ? stats.p95 + 'ms' : 'N/A'
        }
      });
    }

    return {
      healthy,
      latency,
      successful,
      violationDetected: violations.length > 0
    };
  }

  /**
   * SLA 보고서
   */
  generateReport() {
    const availability = this.availabilityTracker.calculateAvailability();
    const responseTime = this.responseTimeMonitor.getStatistics();
    const errorRate = this.errorRateMonitor.calculateErrorRate();

    return {
      reportTime: new Date(Date.now()).toISOString(),
      availability,
      responseTime,
      errorRate,
      violations: this.violations.slice(-10),  // 최근 10개
      summary: {
        allTargetsMet: (
          availability.status === 'PASSING' &&
          !errorRate.breached &&
          (responseTime ? parseFloat(responseTime.p95) <= 200 : true)
        ),
        violationCount: this.violations.length
      }
    };
  }

  /**
   * 모니터 상태
   */
  getStatus() {
    const report = this.generateReport();

    return {
      availability: report.availability.availability,
      errorRate: report.errorRate.errorRate,
      latencyP95: report.responseTime ? report.responseTime.p95 + 'ms' : 'N/A',
      recentViolations: this.violations.length,
      allTargetsMet: report.summary.allTargetsMet,
      status: report.summary.allTargetsMet ? 'HEALTHY' : 'DEGRADED'
    };
  }
}

