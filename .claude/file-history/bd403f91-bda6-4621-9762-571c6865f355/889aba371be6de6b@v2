/**
 * Quantum Simulator - 양자 시뮬레이터
 * Phase 10: Quantum-Ready Intelligence
 *
 * 기능:
 * - 큐빗 관리
 * - 양자 게이트
 * - 상태 벡터 진화
 * - 측정
 */

/**
 * 복소수 (양자 진폭)
 */
class ComplexNumber {
  constructor(real = 0, imag = 0) {
    this.real = real;
    this.imag = imag;
  }

  /**
   * 절댓값
   */
  magnitude() {
    return Math.sqrt(this.real ** 2 + this.imag ** 2);
  }

  /**
   * 확률 (|ψ|²)
   */
  probability() {
    return this.magnitude() ** 2;
  }

  /**
   * 덧셈
   */
  add(other) {
    return new ComplexNumber(
      this.real + other.real,
      this.imag + other.imag
    );
  }

  /**
   * 곱셈
   */
  multiply(other) {
    return new ComplexNumber(
      this.real * other.real - this.imag * other.imag,
      this.real * other.imag + this.imag * other.real
    );
  }

  /**
   * 켤레
   */
  conjugate() {
    return new ComplexNumber(this.real, -this.imag);
  }
}

/**
 * 큐빗 상태
 */
class QubitState {
  constructor(numQubits = 1) {
    this.numQubits = numQubits;
    this.dimension = 2 ** numQubits;

    // 상태 벡터 (복소수 배열)
    this.state = new Array(this.dimension);
    for (let i = 0; i < this.dimension; i++) {
      this.state[i] = new ComplexNumber(0, 0);
    }

    // |0...0⟩ 상태로 초기화
    this.state[0] = new ComplexNumber(1, 0);
  }

  /**
   * 상태 정규화
   */
  normalize() {
    let norm = 0;
    for (let i = 0; i < this.dimension; i++) {
      norm += this.state[i].probability();
    }
    norm = Math.sqrt(norm);

    if (norm > 0) {
      for (let i = 0; i < this.dimension; i++) {
        const mag = this.state[i].magnitude();
        if (mag > 0) {
          const phase = Math.atan2(this.state[i].imag, this.state[i].real);
          const newMag = mag / norm;
          this.state[i] = new ComplexNumber(
            newMag * Math.cos(phase),
            newMag * Math.sin(phase)
          );
        }
      }
    }

    return this;
  }

  /**
   * 상태 벡터 복사
   */
  clone() {
    const cloned = new QubitState(this.numQubits);
    for (let i = 0; i < this.dimension; i++) {
      cloned.state[i] = new ComplexNumber(
        this.state[i].real,
        this.state[i].imag
      );
    }
    return cloned;
  }

  /**
   * 측정 (기저 상태로 붕괴)
   */
  measure() {
    let rand = Math.random();
    let cumulative = 0;

    for (let i = 0; i < this.dimension; i++) {
      const prob = this.state[i].probability();
      cumulative += prob;

      if (rand < cumulative) {
        // 측정 후 상태 붕괴
        const result = new QubitState(this.numQubits);
        result.state[i] = new ComplexNumber(1, 0);

        return {
          outcome: i,
          binary: i.toString(2).padStart(this.numQubits, '0'),
          collapsed: result
        };
      }
    }

    return { outcome: 0, binary: '0'.repeat(this.numQubits) };
  }

  /**
   * 기댓값 계산
   */
  expectationValue(observable) {
    let expectation = 0;

    for (let i = 0; i < this.dimension; i++) {
      const prob = this.state[i].probability();
      const eigenvalue = observable[i] || 0;
      expectation += prob * eigenvalue;
    }

    return expectation;
  }
}

/**
 * 양자 게이트
 */
class QuantumGate {
  /**
   * Pauli X (NOT 게이트)
   */
  static X() {
    return [
      [0, 1],
      [1, 0]
    ];
  }

  /**
   * Pauli Y
   */
  static Y() {
    return [
      [0, new ComplexNumber(0, -1)],
      [new ComplexNumber(0, 1), 0]
    ];
  }

  /**
   * Pauli Z
   */
  static Z() {
    return [
      [1, 0],
      [0, -1]
    ];
  }

  /**
   * Hadamard (중첩)
   */
  static H() {
    const factor = 1 / Math.sqrt(2);
    return [
      [factor, factor],
      [factor, -factor]
    ];
  }

  /**
   * Phase 게이트
   */
  static S() {
    return [
      [1, 0],
      [0, new ComplexNumber(0, 1)]
    ];
  }

  /**
   * T 게이트
   */
  static T() {
    const phase = Math.PI / 4;
    return [
      [1, 0],
      [0, new ComplexNumber(Math.cos(phase), Math.sin(phase))]
    ];
  }

  /**
   * CNOT (Controlled NOT)
   */
  static CNOT(numQubits = 2) {
    const dim = 2 ** numQubits;
    const matrix = Array(dim).fill(0).map(() => Array(dim).fill(0));

    for (let i = 0; i < dim; i++) {
      matrix[i][i] = 1;
    }

    // CNOT: control가 1이면 target flip
    for (let i = 0; i < dim; i++) {
      const controlBit = (i >> (numQubits - 1)) & 1;
      if (controlBit === 1) {
        const j = i ^ 1;  // flip last qubit
        matrix[i][i] = 0;
        matrix[i][j] = 1;
        matrix[j][i] = 1;
        matrix[j][j] = 0;
      }
    }

    return matrix;
  }

  /**
   * 회전 게이트 (Rx, Ry, Rz)
   */
  static Rotation(axis, angle) {
    const c = Math.cos(angle / 2);
    const s = Math.sin(angle / 2);

    if (axis === 'x') {
      return [
        [c, new ComplexNumber(0, -s)],
        [new ComplexNumber(0, -s), c]
      ];
    } else if (axis === 'y') {
      return [
        [c, -s],
        [s, c]
      ];
    } else if (axis === 'z') {
      return [
        [new ComplexNumber(Math.cos(-angle / 2), Math.sin(-angle / 2)), 0],
        [0, new ComplexNumber(Math.cos(angle / 2), Math.sin(angle / 2))]
      ];
    }

    return [[1, 0], [0, 1]];
  }
}

/**
 * 양자 회로
 */
class QuantumCircuit {
  constructor(numQubits = 2) {
    this.numQubits = numQubits;
    this.state = new QubitState(numQubits);
    this.gates = [];
    this.measurements = [];
  }

  /**
   * 게이트 적용
   */
  applyGate(gate, qubits) {
    this.gates.push({ gate, qubits, timestamp: Date.now() });

    // 단일 큐빗 게이트
    if (qubits.length === 1) {
      const target = qubits[0];
      this.applySingleQubitGate(gate, target);
    }

    return this;
  }

  /**
   * 단일 큐빗 게이트 적용
   */
  applySingleQubitGate(gate, target) {
    const newState = new QubitState(this.numQubits);

    for (let i = 0; i < this.state.dimension; i++) {
      const bit = (i >> (this.numQubits - 1 - target)) & 1;

      for (let j = 0; j < 2; j++) {
        const coeff = gate[bit][j];
        const otherBit = j;

        const newI = (i & ~(1 << (this.numQubits - 1 - target))) |
                     (otherBit << (this.numQubits - 1 - target));

        if (typeof coeff === 'number') {
          const amp = new ComplexNumber(coeff, 0);
          newState.state[newI] = newState.state[newI].add(
            amp.multiply(this.state.state[i])
          );
        } else {
          newState.state[newI] = newState.state[newI].add(
            coeff.multiply(this.state.state[i])
          );
        }
      }
    }

    newState.normalize();
    this.state = newState;
  }

  /**
   * 측정
   */
  measure(qubit = null) {
    const result = this.state.measure();
    this.measurements.push({ qubit, result, timestamp: Date.now() });
    return result;
  }

  /**
   * 여러 번 측정 (샘플링)
   */
  sample(shots = 1000) {
    const counts = {};

    for (let i = 0; i < shots; i++) {
      const result = this.state.measure();
      const binary = result.binary;
      counts[binary] = (counts[binary] || 0) + 1;
    }

    return {
      counts,
      shots,
      probabilities: Object.fromEntries(
        Object.entries(counts).map(([k, v]) => [k, v / shots])
      )
    };
  }

  /**
   * 회로 상태
   */
  getStatus() {
    return {
      numQubits: this.numQubits,
      gateCount: this.gates.length,
      measurementCount: this.measurements.length,
      stateVector: this.state.state.map(c => ({
        real: c.real,
        imag: c.imag,
        prob: c.probability()
      }))
    };
  }
}

