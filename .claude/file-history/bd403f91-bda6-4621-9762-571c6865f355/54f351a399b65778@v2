#!/usr/bin/env node

/**
 * Continuous Improvement Engine - 지속적 개선 엔진
 * Phase 9.5: 자율 지식
 *
 * 기능:
 * - 메트릭 추적
 * - 개선 감지
 * - 적응형 전략
 * - 자동 최적화
 */

/**
 * 메트릭
 */
class Metric {
  constructor(name, value, timestamp = Date.now()) {
    this.name = name;
    this.value = value;
    this.timestamp = timestamp;
    this.category = 'general';
  }
}

/**
 * 메트릭 추적기
 */
class MetricTracker {
  constructor(windowSize = 100) {
    this.metrics = [];
    this.windowSize = windowSize;
    this.aggregates = {};
  }

  /**
   * 메트릭 기록
   */
  recordMetric(name, value) {
    const metric = new Metric(name, value);
    this.metrics.push(metric);

    // 윈도우 크기 제한
    if (this.metrics.length > this.windowSize * 2) {
      this.metrics = this.metrics.slice(-this.windowSize);
    }

    this.updateAggregates();
    return this;
  }

  /**
   * 통계 업데이트
   */
  updateAggregates() {
    const grouped = {};

    for (const metric of this.metrics) {
      if (!grouped[metric.name]) {
        grouped[metric.name] = [];
      }
      grouped[metric.name].push(metric.value);
    }

    for (const name in grouped) {
      const values = grouped[name];
      const sorted = [...values].sort((a, b) => a - b);

      this.aggregates[name] = {
        current: values[values.length - 1],
        average: values.reduce((a, b) => a + b, 0) / values.length,
        min: Math.min(...values),
        max: Math.max(...values),
        median: sorted[Math.floor(sorted.length / 2)],
        stdDev: this.calculateStdDev(values)
      };
    }
  }

  /**
   * 표준편차 계산
   */
  calculateStdDev(values) {
    const avg = values.reduce((a, b) => a + b, 0) / values.length;
    const squareDiffs = values.map(v => Math.pow(v - avg, 2));
    const avgSquareDiff = squareDiffs.reduce((a, b) => a + b, 0) / values.length;
    return Math.sqrt(avgSquareDiff);
  }

  /**
   * 추세 분석
   */
  getTrend(name, window = 10) {
    const recent = this.metrics
      .filter(m => m.name === name)
      .slice(-window)
      .map(m => m.value);

    if (recent.length < 2) return 'stable';

    const firstHalf = recent.slice(0, Math.floor(recent.length / 2));
    const secondHalf = recent.slice(Math.floor(recent.length / 2));

    const firstAvg = firstHalf.reduce((a, b) => a + b, 0) / firstHalf.length;
    const secondAvg = secondHalf.reduce((a, b) => a + b, 0) / secondHalf.length;

    const changePercent = ((secondAvg - firstAvg) / firstAvg) * 100;

    if (changePercent > 5) return 'improving';
    if (changePercent < -5) return 'degrading';
    return 'stable';
  }

  /**
   * 메트릭 조회
   */
  getMetric(name) {
    return this.aggregates[name];
  }
}

/**
 * 개선 감지기
 */
class ImprovementDetector {
  /**
   * 개선 기회 감지
   */
  static detectOpportunities(tracker) {
    const opportunities = [];

    for (const name in tracker.aggregates) {
      const agg = tracker.aggregates[name];
      const trend = tracker.getTrend(name);

      // 1. 안정적인 메트릭이 낮은 경우
      if (trend === 'stable' && agg.current < agg.average * 0.8) {
        opportunities.push({
          type: 'low-performer',
          metric: name,
          current: agg.current,
          target: agg.average * 1.1,
          priority: 'high'
        });
      }

      // 2. 고변동 메트릭
      if (agg.stdDev > agg.average * 0.3) {
        opportunities.push({
          type: 'high-volatility',
          metric: name,
          stdDev: agg.stdDev,
          priority: 'medium'
        });
      }

      // 3. 개선 중인 메트릭
      if (trend === 'improving') {
        opportunities.push({
          type: 'improving-trend',
          metric: name,
          trend,
          priority: 'low'
        });
      }
    }

    return opportunities.sort((a, b) => {
      const priorityOrder = { high: 0, medium: 1, low: 2 };
      return priorityOrder[a.priority] - priorityOrder[b.priority];
    });
  }

  /**
   * 성능 이상 감지
   */
  static detectAnomalies(tracker, threshold = 2) {
    const anomalies = [];

    for (const name in tracker.aggregates) {
      const agg = tracker.aggregates[name];
      const zScore = Math.abs((agg.current - agg.average) / (agg.stdDev || 1));

      if (zScore > threshold) {
        anomalies.push({
          metric: name,
          value: agg.current,
          zScore,
          severity: zScore > 3 ? 'critical' : 'warning'
        });
      }
    }

    return anomalies.sort((a, b) => b.zScore - a.zScore);
  }
}

/**
 * 적응형 전략
 */
class AdaptiveStrategy {
  constructor(name) {
    this.name = name;
    this.adjustments = [];
    this.effectiveness = 0;
  }

  /**
   * 전략 적용
   */
  apply(metric, target) {
    const adjustment = {
      metric,
      target,
      applied: Date.now(),
      result: null,
      effectiveness: 0
    };

    this.adjustments.push(adjustment);
    return adjustment;
  }

  /**
   * 효과 평가
   */
  evaluate(result) {
    if (this.adjustments.length === 0) return 0;

    const lastAdjustment = this.adjustments[this.adjustments.length - 1];
    const improvement = (result - lastAdjustment.target) / lastAdjustment.target;

    lastAdjustment.result = result;
    lastAdjustment.effectiveness = Math.max(0, Math.min(1, improvement + 0.5));

    // 전체 효과도 계산
    this.effectiveness = this.adjustments.reduce((sum, adj) => {
      return sum + (adj.effectiveness || 0);
    }, 0) / this.adjustments.length;

    return this.effectiveness;
  }

  /**
   * 다음 조정값 예측
   */
  predictNextAdjustment(current, target) {
    if (this.adjustments.length === 0) {
      return target * 1.1;
    }

    // 수렴 속도 학습
    const recent = this.adjustments.slice(-5);
    const improvements = recent
      .filter(adj => adj.result !== null)
      .map(adj => adj.result - adj.target);

    if (improvements.length === 0) {
      return target * 1.2;
    }

    const avgImprovement = improvements.reduce((a, b) => a + b, 0) / improvements.length;
    const convergenceRate = Math.min(1, Math.abs(avgImprovement / target));

    return target * (1 + convergenceRate * 0.15);
  }
}

/**
 * 지속적 개선 엔진
 */
class ContinuousImprovementEngine {
  constructor(config = {}) {
    this.config = {
      checkInterval: config.checkInterval || 5000,
      targetWindow: config.targetWindow || 20,
      ...config
    };

    this.tracker = new MetricTracker(config.windowSize || 100);
    this.strategies = new Map();
    this.improvements = [];
    this.cycleCount = 0;
    this.running = false;
  }

  /**
   * 전략 등록
   */
  registerStrategy(metricName, strategyName, implementation) {
    const strategy = new AdaptiveStrategy(strategyName);
    if (!this.strategies.has(metricName)) {
      this.strategies.set(metricName, []);
    }
    this.strategies.get(metricName).push({
      strategy,
      implementation
    });
    return this;
  }

  /**
   * 개선 사이클 실행
   */
  async runCycle() {
    this.cycleCount++;

    // 1. 개선 기회 감지
    const opportunities = ImprovementDetector.detectOpportunities(this.tracker);

    // 2. 이상 감지
    const anomalies = ImprovementDetector.detectAnomalies(this.tracker);

    // 3. 전략 적용
    const actions = [];
    for (const opp of opportunities.slice(0, 3)) {
      const strategies = this.strategies.get(opp.metric) || [];

      for (const { strategy, implementation } of strategies) {
        try {
          const result = await implementation();
          strategy.apply(opp.metric, opp.target);
          strategy.evaluate(result);

          actions.push({
            opportunity: opp,
            strategy: strategy.name,
            result,
            effectiveness: strategy.effectiveness
          });
        } catch (error) {
          // 전략 실패
        }
      }
    }

    this.improvements.push({
      cycle: this.cycleCount,
      timestamp: Date.now(),
      opportunities: opportunities.length,
      actions: actions.length,
      anomalies: anomalies.length,
      details: actions
    });

    return {
      cycleCount: this.cycleCount,
      opportunities: opportunities.length,
      actions: actions.length,
      anomalies: anomalies.length
    };
  }

  /**
   * 지속적 모니터링 시작
   */
  startMonitoring() {
    if (this.running) return;
    this.running = true;

    const interval = setInterval(async () => {
      if (!this.running) {
        clearInterval(interval);
        return;
      }

      try {
        await this.runCycle();
      } catch (error) {
        console.error('Improvement cycle error:', error);
      }
    }, this.config.checkInterval);

    return this;
  }

  /**
   * 모니터링 중지
   */
  stopMonitoring() {
    this.running = false;
    return this;
  }

  /**
   * 개선 보고서
   */
  generateReport() {
    const recentImprovements = this.improvements.slice(-10);

    return {
      totalCycles: this.cycleCount,
      recentCycles: recentImprovements,
      currentMetrics: this.tracker.aggregates,
      strategies: Array.from(this.strategies.entries()).map(([metric, strats]) => ({
        metric,
        strategyCount: strats.length,
        effectiveness: strats.reduce((sum, s) => sum + s.strategy.effectiveness, 0) /
          (strats.length || 1)
      }))
    };
  }

  /**
   * JSON 내보내기
   */
  toJSON() {
    return {
      cycles: this.cycleCount,
      improvements: this.improvements.slice(-5),
      metrics: this.tracker.aggregates,
      status: this.running ? 'monitoring' : 'stopped'
    };
  }
}

