#!/usr/bin/env node

/**
 * Quantum Reinforcement Learning - 양자 강화학습
 * Phase 10.2: Advanced Quantum Optimization
 *
 * 기능:
 * - 양자 환경 정의
 * - 양자 정책 네트워크
 * - Q-학습 알고리즘
 * - 경험 재생
 */

/**
 * 양자 환경
 */
class QuantumEnvironment {
  constructor(qubitCount, actionSpace) {
    this.qubitCount = qubitCount;
    this.actionSpace = actionSpace;  // 가능한 액션 목록
    this.state = null;
    this.reset();
  }

  /**
   * 환경 초기화
   */
  reset() {
    // 초기 상태: 모든 큐빗이 |0⟩
    this.state = new Array(this.qubitCount).fill(0);
    return this.state;
  }

  /**
   * 환경 스텝 (액션 적용)
   */
  step(action) {
    const reward = this.computeReward(action);
    const done = this.isTerminal();
    const nextState = this.applyAction(action);

    return {
      state: nextState,
      reward,
      done,
      info: {
        action: action.name,
        qubits: action.qubits,
        angle: action.angle
      }
    };
  }

  /**
   * 액션 적용
   */
  applyAction(action) {
    const newState = [...this.state];

    // 양자 게이트 시뮬레이션
    if (action.name === 'RX') {
      for (const q of action.qubits) {
        newState[q] = (newState[q] + action.angle) % (2 * Math.PI);
      }
    } else if (action.name === 'RY') {
      for (const q of action.qubits) {
        newState[q] = (newState[q] + action.angle) % (2 * Math.PI);
      }
    } else if (action.name === 'CNOT') {
      // 단순화된 CNOT 시뮬레이션
      if (action.qubits.length === 2) {
        newState[action.qubits[1]] = (newState[action.qubits[1]] + newState[action.qubits[0]]) % 2;
      }
    }

    this.state = newState;
    return newState;
  }

  /**
   * 보상 계산
   */
  computeReward(action) {
    // 상태 벡터의 특정 빗을 달성하는 것에 대한 보상
    let targetValue = 0;
    const stateSum = this.state.reduce((sum, val) => sum + Math.abs(val), 0);

    // 목표: 특정 상태에 도달
    targetValue = Math.cos(stateSum / this.qubitCount) * 2 - 1;  // -1 ~ 1

    // 에너지 기반 보상
    const energyReward = -stateSum / this.qubitCount;

    return 0.7 * targetValue + 0.3 * energyReward;
  }

  /**
   * 종료 조건 확인
   */
  isTerminal() {
    // 최대 스텝에 도달한 경우
    return Math.random() < 0.05;  // 5% 확률로 종료
  }

  /**
   * 환경 정보
   */
  getInfo() {
    return {
      qubits: this.qubitCount,
      actionSpace: this.actionSpace.length,
      currentState: this.state.slice(0, 3).map(s => s.toFixed(3))
    };
  }
}

/**
 * 양자 정책 네트워크
 */
class QuantumPolicyNetwork {
  constructor(inputSize, outputSize) {
    this.inputSize = inputSize;
    this.outputSize = outputSize;
    this.weights = [];
    this.bias = [];
    this.initializeNetwork();
  }

  /**
   * 네트워크 초기화
   */
  initializeNetwork() {
    // 첫 번째 레이어
    this.weights[0] = Array(this.inputSize).fill(0).map(() =>
      Array(16).fill(0).map(() => (Math.random() - 0.5) * 2)
    );
    this.bias[0] = Array(16).fill(0).map(() => (Math.random() - 0.5) * 2);

    // 두 번째 레이어
    this.weights[1] = Array(16).fill(0).map(() =>
      Array(this.outputSize).fill(0).map(() => (Math.random() - 0.5) * 2)
    );
    this.bias[1] = Array(this.outputSize).fill(0).map(() => (Math.random() - 0.5) * 2);
  }

  /**
   * 액션 선택 (정책)
   */
  chooseAction(state, temperature = 1.0) {
    // 상태를 통해 정책 계산
    let hidden = Array(16).fill(0);

    // 첫 번째 레이어
    for (let i = 0; i < 16; i++) {
      for (let j = 0; j < this.inputSize; j++) {
        hidden[i] += state[j] * this.weights[0][j][i];
      }
      hidden[i] += this.bias[0][i];
      hidden[i] = Math.tanh(hidden[i]);  // 활성화
    }

    // 두 번째 레이어
    let output = Array(this.outputSize).fill(0);
    for (let i = 0; i < this.outputSize; i++) {
      for (let j = 0; j < 16; j++) {
        output[i] += hidden[j] * this.weights[1][j][i];
      }
      output[i] += this.bias[1][i];
    }

    // Softmax
    const expOutput = output.map(x => Math.exp(x / temperature));
    const sumExp = expOutput.reduce((a, b) => a + b, 1);
    const probabilities = expOutput.map(x => x / sumExp);

    // 확률에 따라 액션 선택
    let random = Math.random();
    let selectedAction = 0;
    for (let i = 0; i < probabilities.length; i++) {
      random -= probabilities[i];
      if (random <= 0) {
        selectedAction = i;
        break;
      }
    }

    return {
      action: selectedAction,
      probabilities,
      logProb: Math.log(probabilities[selectedAction] + 1e-8)
    };
  }

  /**
   * 정책 그래디언트 계산
   */
  computePolicyGradient(state, action, advantage) {
    const { logProb } = this.chooseAction(state);
    return logProb * advantage;
  }

  /**
   * 가중치 업데이트
   */
  updateWeights(gradient, learningRate = 0.01) {
    // 단순화된 업데이트
    for (let i = 0; i < this.weights.length; i++) {
      for (let j = 0; j < this.weights[i].length; j++) {
        for (let k = 0; k < this.weights[i][j].length; k++) {
          this.weights[i][j][k] += learningRate * gradient * 0.01;
        }
      }
    }
  }

  /**
   * 네트워크 정보
   */
  getInfo() {
    return {
      inputSize: this.inputSize,
      outputSize: this.outputSize,
      hiddenSize: 16,
      layers: 2
    };
  }
}

/**
 * 경험 재생 메모리
 */
class ExperienceReplay {
  constructor(maxSize = 1000) {
    this.buffer = [];
    this.maxSize = maxSize;
  }

  /**
   * 경험 저장
   */
  store(experience) {
    this.buffer.push(experience);
    if (this.buffer.length > this.maxSize) {
      this.buffer.shift();
    }
  }

  /**
   * 배치 샘플링
   */
  sample(batchSize) {
    const batch = [];
    for (let i = 0; i < batchSize; i++) {
      const idx = Math.floor(Math.random() * this.buffer.length);
      batch.push(this.buffer[idx]);
    }
    return batch;
  }

  /**
   * 메모리 상태
   */
  getStatus() {
    return {
      stored: this.buffer.length,
      maxSize: this.maxSize,
      utilizationRate: (this.buffer.length / this.maxSize * 100).toFixed(1) + '%'
    };
  }
}

/**
 * 양자 강화학습 에이전트
 */
class QuantumRLAgent {
  constructor(qubitCount, actionSpace) {
    this.environment = new QuantumEnvironment(qubitCount, actionSpace);
    this.policy = new QuantumPolicyNetwork(qubitCount, actionSpace.length);
    this.memory = new ExperienceReplay(1000);
    this.actionSpace = actionSpace;
    this.episodeRewards = [];
    this.episodeLength = 0;
  }

  /**
   * 에피소드 실행
   */
  runEpisode(maxSteps = 100, renderMode = 'none') {
    let state = this.environment.reset();
    let episodeReward = 0;
    let stepCount = 0;

    for (let step = 0; step < maxSteps; step++) {
      // 정책에서 액션 선택
      const actionInfo = this.policy.chooseAction(state, 1.0 / (1 + step / 10));
      const action = this.actionSpace[actionInfo.action];

      // 환경 스텝
      const { state: nextState, reward, done, info } = this.environment.step(action);

      // 경험 저장
      this.memory.store({
        state,
        action: actionInfo.action,
        reward,
        nextState,
        done,
        logProb: actionInfo.logProb
      });

      episodeReward += reward;
      stepCount++;
      state = nextState;

      if (done) break;
    }

    this.episodeRewards.push(episodeReward);
    this.episodeLength = stepCount;

    return {
      episodeReward,
      episodeLength: stepCount,
      averageReward: episodeReward / stepCount
    };
  }

  /**
   * 정책 학습
   */
  learnFromBatch(batchSize = 32) {
    if (this.memory.buffer.length < batchSize) {
      return { loss: 0, batchSize: 0 };
    }

    const batch = this.memory.sample(batchSize);
    let totalLoss = 0;

    for (const experience of batch) {
      // 어드밴티지 계산 (단순화)
      const advantage = experience.reward;

      // 정책 그래디언트 계산
      const gradient = this.policy.computePolicyGradient(
        experience.state,
        experience.action,
        advantage
      );

      // 가중치 업데이트
      this.policy.updateWeights(gradient, 0.01);

      totalLoss += Math.abs(gradient);
    }

    return {
      loss: totalLoss / batchSize,
      batchSize
    };
  }

  /**
   * 완전한 학습
   */
  train(episodes = 50, maxStepsPerEpisode = 100) {
    const results = [];

    for (let ep = 0; ep < episodes; ep++) {
      // 에피소드 실행
      const episodeResult = this.runEpisode(maxStepsPerEpisode);

      // 배치 학습
      const learningResult = this.learnFromBatch(32);

      results.push({
        episode: ep + 1,
        reward: episodeResult.episodeReward,
        length: episodeResult.episodeLength,
        loss: learningResult.loss
      });
    }

    return {
      episodes,
      results,
      averageReward: this.episodeRewards.reduce((a, b) => a + b, 0) / episodes,
      bestReward: Math.max(...this.episodeRewards)
    };
  }

  /**
   * 에이전트 정보
   */
  getInfo() {
    return {
      qubits: this.environment.qubitCount,
      actionSpace: this.actionSpace.length,
      memory: this.memory.getStatus(),
      episodesRun: this.episodeRewards.length,
      averageReward: this.episodeRewards.length > 0 ?
        (this.episodeRewards.reduce((a, b) => a + b, 0) / this.episodeRewards.length).toFixed(3) :
        'N/A'
    };
  }
}

