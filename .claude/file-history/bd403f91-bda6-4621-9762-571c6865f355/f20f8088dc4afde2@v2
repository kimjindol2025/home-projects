#!/usr/bin/env node

/**
 * AI Performance Profiler - 성능 분석
 * Phase 9.0: AI 강화
 *
 * 기능:
 * - 성능 병목 분석
 * - 메모리 누수 탐지
 * - 알고리즘 복잡도 분석
 * - 최적화 제안
 */

class PerformanceProfiler {
  constructor() {
    this.metrics = [];
    this.bottlenecks = [];
    this.suggestions = [];
  }

  /**
   * 알고리즘 복잡도 분석
   */
  analyzeTimeComplexity(code) {
    const analysis = {
      loops: [],
      nested: 0,
      complexity: 'O(1)',
      issues: []
    };

    const lines = code.split('\n');
    let loopDepth = 0;
    let maxLoopDepth = 0;

    for (let i = 0; i < lines.length; i++) {
      const line = lines[i];

      // 루프 탐지
      if (/for|while/.test(line)) {
        loopDepth++;
        maxLoopDepth = Math.max(maxLoopDepth, loopDepth);

        analysis.loops.push({
          type: /for/.test(line) ? 'for' : 'while',
          line: i + 1,
          depth: loopDepth,
          code: line.trim()
        });

        if (loopDepth > 2) {
          analysis.issues.push({
            severity: 'HIGH',
            message: `3중 이상 중첩 루프 (깊이: ${loopDepth})`,
            line: i + 1,
            suggestion: '루프 단순화 또는 알고리즘 개선'
          });
        }
      }

      if (/}/.test(line)) {
        loopDepth = Math.max(0, loopDepth - 1);
      }

      // 재귀 호출 탐지
      if (/function\s+\w+[\s\S]*?\1\s*\(/.test(code)) {
        analysis.issues.push({
          severity: 'MEDIUM',
          message: '재귀 호출 감지 (스택 오버플로우 위험)',
          suggestion: '동적 프로그래밍 또는 반복문 사용'
        });
      }
    }

    // 복잡도 계산
    if (maxLoopDepth === 0) {
      analysis.complexity = 'O(1)';
    } else if (maxLoopDepth === 1) {
      analysis.complexity = 'O(n)';
    } else if (maxLoopDepth === 2) {
      analysis.complexity = 'O(n²)';
    } else if (maxLoopDepth === 3) {
      analysis.complexity = 'O(n³)';
    } else {
      analysis.complexity = `O(n^${maxLoopDepth})`;
    }

    analysis.nested = maxLoopDepth;

    return analysis;
  }

  /**
   * 공간 복잡도 분석
   */
  analyzeSpaceComplexity(code) {
    const analysis = {
      allocations: [],
      spaceComplexity: 'O(1)',
      issues: []
    };

    const lines = code.split('\n');

    for (let i = 0; i < lines.length; i++) {
      const line = lines[i];

      // 배열/객체 할당
      if (/=\s*\[\]|=\s*\{|new Array|new Object/.test(line)) {
        analysis.allocations.push({
          line: i + 1,
          type: /\[\]/.test(line) ? 'array' : 'object',
          code: line.trim()
        });
      }

      // 메모리 사용
      if (/=\s*new|push|concat/.test(line)) {
        analysis.spaceComplexity = 'O(n)';
      }

      // 재귀 (스택 사용)
      if (/function\s+\w+[\s\S]*?\1\s*\(/.test(code)) {
        analysis.spaceComplexity = 'O(n)';
        analysis.issues.push({
          severity: 'MEDIUM',
          message: '재귀로 인한 스택 메모리 사용',
          suggestion: '꼬리 재귀 최적화 또는 반복문 사용'
        });
      }
    }

    return analysis;
  }

  /**
   * 메모리 누수 패턴 탐지
   */
  detectMemoryLeaks(code) {
    const leaks = [];
    const lines = code.split('\n');

    for (let i = 0; i < lines.length; i++) {
      const line = lines[i];

      // 1. addEventListener without removeEventListener
      if (/addEventListener/.test(line) && !/removeEventListener/.test(code.substring(i, i + 500))) {
        leaks.push({
          severity: 'HIGH',
          type: 'EVENT_LISTENER',
          line: i + 1,
          message: '이벤트 리스너 제거 없음',
          code: line.trim(),
          suggestion: '정리 함수에서 removeEventListener 호출'
        });
      }

      // 2. Timer without clearInterval/clearTimeout
      if (/setInterval|setTimeout/.test(line) && !/clearInterval|clearTimeout/.test(code.substring(i, i + 500))) {
        leaks.push({
          severity: 'MEDIUM',
          type: 'TIMER',
          line: i + 1,
          message: '타이머 정리 부재',
          code: line.trim(),
          suggestion: '컴포넌트 언마운트 시 타이머 정리'
        });
      }

      // 3. Observable subscription without unsubscribe
      if (/subscribe/.test(line) && !/unsubscribe/.test(code.substring(i, i + 500))) {
        leaks.push({
          severity: 'HIGH',
          type: 'SUBSCRIPTION',
          line: i + 1,
          message: '옵저버블 구독 해제 없음',
          code: line.trim(),
          suggestion: 'ngOnDestroy 또는 정리 함수에서 unsubscribe'
        });
      }

      // 4. Global variable accumulation
      if (/window\.\w+\s*=|global\.\w+\s*=/.test(line)) {
        leaks.push({
          severity: 'MEDIUM',
          type: 'GLOBAL_VAR',
          line: i + 1,
          message: '전역 변수에 누적되는 데이터',
          code: line.trim(),
          suggestion: '지역 범위 사용 또는 정기적 정리'
        });
      }

      // 5. Large cache without eviction
      if (/cache|store|map|set/.test(line) && !/delete|clear|evict/.test(code)) {
        leaks.push({
          severity: 'LOW',
          type: 'UNBOUNDED_CACHE',
          line: i + 1,
          message: '경계 없는 캐시 축적',
          suggestion: 'LRU 캐시 또는 만료 정책 구현'
        });
      }
    }

    return leaks;
  }

  /**
   * 병목 구간 탐지
   */
  detectBottlenecks(code) {
    const bottlenecks = [];
    const lines = code.split('\n');

    for (let i = 0; i < lines.length; i++) {
      const line = lines[i];

      // 1. 동기 작업 (블로킹)
      if (/readFileSync|fetchSync|sleepSync|join/.test(line)) {
        bottlenecks.push({
          severity: 'CRITICAL',
          type: 'BLOCKING',
          line: i + 1,
          message: '블로킹 작업 감지',
          code: line.trim(),
          suggestion: '비동기 대체 사용 (async/await, Promise)'
        });
      }

      // 2. 루프 내 I/O
      if (/for|while/.test(line)) {
        const loopBlock = code.substring(
          code.indexOf(line),
          code.indexOf('}', code.indexOf(line))
        );

        if (/fetch|query|request|read|write/.test(loopBlock)) {
          bottlenecks.push({
            severity: 'HIGH',
            type: 'LOOP_IO',
            line: i + 1,
            message: '루프 내 I/O 작업',
            code: line.trim(),
            suggestion: 'Promise.all로 병렬 처리 또는 배치 작업'
          });
        }
      }

      // 3. 큰 데이터셋 동기 처리
      if (/(filter|map|reduce|forEach|join)\([\s\S]*?\)/.test(line)) {
        bottlenecks.push({
          severity: 'MEDIUM',
          type: 'LARGE_ARRAY_OP',
          line: i + 1,
          message: '대용량 배열 동기 처리',
          code: line.trim().substring(0, 60),
          suggestion: 'Web Worker 또는 청크 단위 처리'
        });
      }

      // 4. N+1 쿼리
      if (/for|forEach/.test(line)) {
        const block = code.substring(i * 50, (i + 10) * 50);
        if ((block.match(/query|execute|fetch/gi) || []).length > 1) {
          bottlenecks.push({
            severity: 'CRITICAL',
            type: 'N_PLUS_ONE',
            line: i + 1,
            message: 'N+1 쿼리 패턴',
            suggestion: 'JOIN 또는 배치 쿼리 사용'
          });
        }
      }

      // 5. 과도한 정규식
      if (/\/.*\/[gimuy]*/.test(line) && /\.match|\.replace|\.test|\.split/.test(line)) {
        bottlenecks.push({
          severity: 'LOW',
          type: 'EXPENSIVE_REGEX',
          line: i + 1,
          message: '복잡한 정규식',
          code: line.trim().substring(0, 60),
          suggestion: '정규식 최적화 또는 문자열 메서드 사용'
        });
      }
    }

    this.bottlenecks = bottlenecks;
    return bottlenecks;
  }

  /**
   * 성능 최적화 제안
   */
  suggestOptimizations(code) {
    const suggestions = [];

    // 1. 메모이제이션
    if (/function.*\(.*\).*\{[\s\S]*?for|while|fibonacci|factorial/.test(code)) {
      suggestions.push({
        type: 'MEMOIZATION',
        priority: 'HIGH',
        message: '반복 계산 최적화 기회',
        suggestion: '메모이제이션 또는 동적 프로그래밍 사용',
        benefit: '10-100배 성능 향상 가능'
      });
    }

    // 2. 불필요한 복사
    if (/\.slice\(\)|\.concat\(\)|\.spread/.test(code)) {
      suggestions.push({
        type: 'UNNECESSARY_COPY',
        priority: 'MEDIUM',
        message: '불필요한 배열 복사',
        suggestion: '참조 활용 또는 원본 수정',
        benefit: '메모리 사용 30-50% 감소'
      });
    }

    // 3. 캐싱
    if (/\.map|\.filter|\.reduce|\.find/.test(code) && !/cache|memo|stored/.test(code)) {
      suggestions.push({
        type: 'CACHING',
        priority: 'MEDIUM',
        message: '계산 결과 캐싱 기회',
        suggestion: 'Map/Set으로 계산 결과 저장',
        benefit: '반복 계산 5-10배 성능 향상'
      });
    }

    // 4. 지연 로딩
    if (/import\s+|require\(/.test(code)) {
      suggestions.push({
        type: 'LAZY_LOADING',
        priority: 'MEDIUM',
        message: '모듈 동적 로딩 고려',
        suggestion: '필요시에만 로드하는 동적 import 사용',
        benefit: '초기 로딩 시간 20-40% 감소'
      });
    }

    // 5. 알고리즘 개선
    const complexity = this.analyzeTimeComplexity(code);
    if (complexity.complexity.includes('n³') || complexity.complexity.includes('n²')) {
      suggestions.push({
        type: 'ALGORITHM',
        priority: 'CRITICAL',
        message: `높은 시간 복잡도: ${complexity.complexity}`,
        suggestion: '더 효율적인 알고리즘 사용',
        benefit: '10-1000배 성능 향상 가능'
      });
    }

    this.suggestions = suggestions;
    return suggestions;
  }

  /**
   * 종합 성능 분석
   */
  generatePerformanceReport(code) {
    const report = {
      timeComplexity: this.analyzeTimeComplexity(code),
      spaceComplexity: this.analyzeSpaceComplexity(code),
      memoryLeaks: this.detectMemoryLeaks(code),
      bottlenecks: this.detectBottlenecks(code),
      optimizations: this.suggestOptimizations(code),
      summary: {
        totalIssues: 0,
        critical: 0,
        high: 0,
        medium: 0
      },
      performanceScore: 100
    };

    // 문제점 계산
    const allIssues = [
      ...report.timeComplexity.issues,
      ...report.memoryLeaks,
      ...report.bottlenecks
    ];

    report.summary.totalIssues = allIssues.length;
    report.summary.critical = allIssues.filter(i => i.severity === 'CRITICAL').length;
    report.summary.high = allIssues.filter(i => i.severity === 'HIGH').length;
    report.summary.medium = allIssues.filter(i => i.severity === 'MEDIUM').length;

    // 점수 계산
    report.performanceScore = Math.max(0, 100 - (
      report.summary.critical * 15 +
      report.summary.high * 8 +
      report.summary.medium * 3
    ));

    return report;
  }

  /**
   * 보고서 포맷팅
   */
  formatReport(report) {
    let output = '';
    output += '═'.repeat(70) + '\n';
    output += '⚡ PERFORMANCE ANALYSIS REPORT\n';
    output += '═'.repeat(70) + '\n\n';

    output += `Performance Score: ${report.performanceScore}/100\n`;
    output += `Time Complexity: ${report.timeComplexity.complexity}\n`;
    output += `Space Complexity: ${report.spaceComplexity.spaceComplexity}\n\n`;

    output += `⚠️  Issues:\n`;
    output += `  • Critical: ${report.summary.critical}\n`;
    output += `  • High: ${report.summary.high}\n`;
    output += `  • Medium: ${report.summary.medium}\n`;
    output += `  • Total: ${report.summary.totalIssues}\n\n`;

    if (report.memoryLeaks.length > 0) {
      output += `💾 Memory Leaks: ${report.memoryLeaks.length}\n`;
      for (const leak of report.memoryLeaks.slice(0, 3)) {
        output += `  [${leak.severity}] ${leak.type}: ${leak.message}\n`;
      }
      if (report.memoryLeaks.length > 3) {
        output += `  ... and ${report.memoryLeaks.length - 3} more\n`;
      }
      output += '\n';
    }

    if (report.bottlenecks.length > 0) {
      output += `🔴 Bottlenecks: ${report.bottlenecks.length}\n`;
      output += '  Top issues found\n\n';
    }

    return output;
  }
}

