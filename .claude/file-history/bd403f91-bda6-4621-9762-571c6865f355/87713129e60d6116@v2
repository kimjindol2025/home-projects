/**
 * Calibration Engine - 캘리브레이션 엔진
 * Phase 10.1: Real Quantum Hardware Integration
 *
 * 기능:
 * - 게이트 타이밍 캘리브레이션
 * - 진폭 캘리브레이션
 * - 위상 교정
 * - 드리프트 보정
 */

/**
 * 캘리브레이션 매개변수
 */
class CalibrationParameters {
  constructor() {
    this.gateTimings = new Map();      // 게이트별 실행 시간
    this.amplitudes = new Map();       // 게이트별 진폭
    this.phases = new Map();           // 게이트별 위상
    this.driftCorrections = new Map(); // 드리프트 보정
    this.lastCalibrationTime = null;
    this.calibrationAccuracy = 0.0;
  }

  /**
   * 게이트 타이밍 설정
   */
  setGateTiming(gate, duration) {
    this.gateTimings.set(gate, {
      nominal: duration,
      current: duration,
      variance: 0.0,
      lastUpdated: Date.now()
    });
  }

  /**
   * 게이트 진폭 설정
   */
  setAmplitude(gate, amplitude) {
    this.amplitudes.set(gate, {
      target: amplitude,
      current: amplitude,
      error: 0.0,
      lastUpdated: Date.now()
    });
  }

  /**
   * 게이트 위상 설정
   */
  setPhase(gate, phase) {
    this.phases.set(gate, {
      target: phase,
      current: phase,
      error: 0.0,
      lastUpdated: Date.now()
    });
  }

  /**
   * 캘리브레이션 데이터 조회
   */
  getCalibrationData(gate) {
    return {
      gate,
      timing: this.gateTimings.get(gate),
      amplitude: this.amplitudes.get(gate),
      phase: this.phases.get(gate)
    };
  }
}

/**
 * 게이트 타이밍 캘리브레이션
 */
class GateTimingCalibrator {
  constructor() {
    this.measurements = [];
    this.calibrationPoints = [];
  }

  /**
   * 타이밍 측정
   */
  measureTiming(gate, iterations = 100) {
    const measurements = [];

    for (let i = 0; i < iterations; i++) {
      // 실행 시간 시뮬레이션 (나노초)
      const baseTiming = {
        'H': 20,
        'X': 20,
        'RX': 25,
        'RY': 25,
        'RZ': 10,
        'CNOT': 40,
        'CZ': 40,
        'SWAP': 120
      };

      const nominal = baseTiming[gate] || 20;
      const noise = (Math.random() - 0.5) * 2;  // ±1ns

      measurements.push(nominal + noise);
    }

    this.measurements = measurements;
    return {
      gate,
      mean: measurements.reduce((a, b) => a + b) / measurements.length,
      stddev: this.calculateStddev(measurements),
      min: Math.min(...measurements),
      max: Math.max(...measurements)
    };
  }

  /**
   * 표준편차 계산
   */
  calculateStddev(values) {
    const mean = values.reduce((a, b) => a + b) / values.length;
    const variance = values.reduce((sum, val) => sum + Math.pow(val - mean, 2), 0) / values.length;
    return Math.sqrt(variance);
  }

  /**
   * 드리프트 감지
   */
  detectDrift(baseline, current) {
    const drift = {
      delta: current - baseline,
      percentChange: ((current - baseline) / baseline * 100).toFixed(2),
      significant: Math.abs(current - baseline) > 0.5  // 0.5ns 이상
    };

    return drift;
  }

  /**
   * 최적 타이밍 계산
   */
  optimizeTiming(measurements) {
    const mean = measurements.reduce((a, b) => a + b) / measurements.length;
    const q1 = measurements.sort((a, b) => a - b)[Math.floor(measurements.length * 0.25)];
    const q3 = measurements[Math.floor(measurements.length * 0.75)];

    // 이상치 제거
    const filtered = measurements.filter(m => m >= q1 - 1.5 * (q3 - q1) && m <= q3 + 1.5 * (q3 - q1));

    return filtered.reduce((a, b) => a + b) / filtered.length;
  }
}

/**
 * 진폭 캘리브레이션
 */
class AmplitudeCalibrator {
  constructor() {
    this.rabi_oscillations = [];
    this.calibrationPulses = [];
  }

  /**
   * Rabi 진동 측정
   */
  measureRabiOscillations(gate, amplitudes, iterations = 50) {
    const results = [];

    for (const amp of amplitudes) {
      let excitation = 0;

      for (let i = 0; i < iterations; i++) {
        // Rabi 진동: sin²(Ωt/2), Ω = amplitude
        const frequency = amp * 10;  // 임의 단위
        const time = i * 0.1;        // 임의 시간
        const excitationProb = Math.pow(Math.sin((frequency * time) / 2), 2);

        excitation += excitationProb;
      }

      results.push({
        amplitude: amp,
        averageExcitation: excitation / iterations,
        oscillationFrequency: amp * 10
      });
    }

    this.rabi_oscillations = results;
    return results;
  }

  /**
   * 최적 진폭 찾기
   */
  findOptimalAmplitude() {
    if (this.rabi_oscillations.length === 0) {
      return null;
    }

    // π 펄스 찾기 (excitation ≈ 1.0)
    let optimal = this.rabi_oscillations[0];

    for (const point of this.rabi_oscillations) {
      if (Math.abs(point.averageExcitation - 1.0) < Math.abs(optimal.averageExcitation - 1.0)) {
        optimal = point;
      }
    }

    return optimal;
  }

  /**
   * 드리프트 보정
   */
  correctDrift(target, measured) {
    const error = measured - target;
    const correctionFactor = 1 - (error / target);

    return {
      error,
      correctionFactor,
      correctedAmplitude: target * correctionFactor
    };
  }
}

/**
 * 위상 캘리브레이션
 */
class PhaseCalibrator {
  constructor() {
    this.phase_responses = [];
    this.phase_errors = [];
  }

  /**
   * 위상 응답 측정
   */
  measurePhaseResponse(gate, phases, iterations = 50) {
    const results = [];

    for (const phase of phases) {
      let fidelity = 0;

      for (let i = 0; i < iterations; i++) {
        // 위상 오류: 실제 위상이 목표와 다를 수 있음
        const phaseNoise = (Math.random() - 0.5) * 0.1;  // ±0.05 rad
        const actualPhase = phase + phaseNoise;
        const phaseError = Math.abs(actualPhase - phase);

        // 충실도: 위상 오류가 작을수록 높음
        const phaseFidelity = 1 - (phaseError / Math.PI);

        fidelity += Math.max(0, phaseFidelity);
      }

      results.push({
        targetPhase: phase,
        averageFidelity: fidelity / iterations,
        phaseError: Math.PI / 100  // 시뮬레이션
      });
    }

    this.phase_responses = results;
    return results;
  }

  /**
   * 위상 오류 교정
   */
  correctPhaseError(measured, target) {
    const error = measured - target;

    // 2π 범위로 정규화
    const normalizedError = ((error + Math.PI) % (2 * Math.PI)) - Math.PI;

    return {
      measuredPhase: measured,
      targetPhase: target,
      error: normalizedError,
      correctedPhase: target - normalizedError
    };
  }

  /**
   * 위상 드리프트 감지
   */
  detectPhaseDrift(previousMeasurements, currentMeasurements) {
    const driftArray = [];

    for (let i = 0; i < Math.min(previousMeasurements.length, currentMeasurements.length); i++) {
      const drift = currentMeasurements[i].phaseError - previousMeasurements[i].phaseError;
      driftArray.push(drift);
    }

    const avgDrift = driftArray.reduce((a, b) => a + b) / driftArray.length;

    return {
      averageDrift: avgDrift,
      driftRate: avgDrift / 1000,  // per ms
      significant: Math.abs(avgDrift) > 0.01
    };
  }
}

/**
 * 통합 캘리브레이션 엔진
 */
class CalibrationEngine {
  constructor() {
    this.parameters = new CalibrationParameters();
    this.timingCalibrator = new GateTimingCalibrator();
    this.amplitudeCalibrator = new AmplitudeCalibrator();
    this.phaseCalibrator = new PhaseCalibrator();
    this.calibrationSchedule = new Map();
    this.lastCalibrationTime = null;
    this.calibrationInterval = 24 * 3600 * 1000;  // 24시간
  }

  /**
   * 전체 캘리브레이션
   */
  async runFullCalibration(gates = ['H', 'X', 'RX', 'RY', 'RZ', 'CNOT']) {
    const calibrationResults = {};

    console.log('🔧 Starting full calibration...');

    for (const gate of gates) {
      // 1. 타이밍 캘리브레이션
      const timing = this.timingCalibrator.measureTiming(gate);
      this.parameters.setGateTiming(gate, timing.mean);

      // 2. 진폭 캘리브레이션
      const amplitudes = [0.8, 0.9, 1.0, 1.1, 1.2];
      const rabiResults = this.amplitudeCalibrator.measureRabiOscillations(gate, amplitudes);
      const optimalAmp = this.amplitudeCalibrator.findOptimalAmplitude();
      this.parameters.setAmplitude(gate, optimalAmp.amplitude);

      // 3. 위상 캘리브레이션
      const phases = [0, Math.PI / 2, Math.PI, 3 * Math.PI / 2];
      const phaseResults = this.phaseCalibrator.measurePhaseResponse(gate, phases);
      this.parameters.setPhase(gate, 0);  // 위상 0으로 정렬

      calibrationResults[gate] = {
        timing: timing.mean,
        timingStddev: timing.stddev,
        optimalAmplitude: optimalAmp.amplitude,
        amplitudeExcitation: optimalAmp.averageExcitation,
        averagePhaseError: phaseResults.reduce((sum, r) => sum + r.phaseError, 0) / phaseResults.length
      };
    }

    this.lastCalibrationTime = Date.now();
    return calibrationResults;
  }

  /**
   * 캘리브레이션 상태 체크
   */
  checkCalibrationStatus() {
    const timeSinceCalibration = this.lastCalibrationTime ?
      Date.now() - this.lastCalibrationTime : null;

    const needsCalibration = !this.lastCalibrationTime ||
      timeSinceCalibration > this.calibrationInterval;

    return {
      lastCalibrationTime: this.lastCalibrationTime,
      timeSinceCalibration,
      needsCalibration,
      calibrationInterval: this.calibrationInterval
    };
  }

  /**
   * 캘리브레이션 데이터 보고서
   */
  getCalibrationReport() {
    const gates = ['H', 'X', 'RX', 'RY', 'RZ', 'CNOT'];
    const report = {
      timestamp: Date.now(),
      lastCalibrationTime: this.lastCalibrationTime,
      gates: {}
    };

    for (const gate of gates) {
      report.gates[gate] = this.parameters.getCalibrationData(gate);
    }

    return report;
  }
}

