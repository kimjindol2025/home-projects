#!/usr/bin/env node

/**
 * Auto Module Splitting - 모듈 자동 분할
 * Phase 9.2: 자동 진화
 *
 * 기능:
 * - 큰 모듈 감지
 * - 자동 분할 제안
 * - 문제 해결 (순환 참조 체크)
 * - 변환 실행
 */

/**
 * 모듈 분석기
 */
class ModuleAnalyzer {
  constructor(config = {}) {
    this.config = {
      sizeThreshold: config.sizeThreshold || 1000,  // 줄 수
      complexityThreshold: config.complexityThreshold || 50,  // 순환 복잡도
      dependencyThreshold: config.dependencyThreshold || 15,  // 의존성 수
      ...config
    };
  }

  /**
   * 모듈 크기 분석
   */
  analyzeModuleSize(moduleCode) {
    const lines = moduleCode.split('\n').length;
    const nonEmptyLines = moduleCode.split('\n')
      .filter(l => l.trim() && !l.trim().startsWith('//'))
      .length;

    return {
      totalLines: lines,
      nonEmptyLines,
      isLarge: nonEmptyLines > this.config.sizeThreshold
    };
  }

  /**
   * 순환 복잡도 계산
   */
  calculateCyclomaticComplexity(moduleCode) {
    let complexity = 1;
    const patterns = [
      /\bif\s*\(/g,
      /\belse\s+if\s*\(/g,
      /\belse\s*\{/g,
      /\bfor\s*\(/g,
      /\bwhile\s*\(/g,
      /\bdo\s*\{/g,
      /\bcase\s+/g,
      /\bcatch\s*\(/g,
      /\?\s*:/g,
      /\|\|/g,
      /&&/g
    ];

    for (const pattern of patterns) {
      const matches = (moduleCode.match(pattern) || []).length;
      complexity += matches;
    }

    return {
      complexity,
      isTooComplex: complexity > this.config.complexityThreshold
    };
  }

  /**
   * 의존성 분석
   */
  analyzeDependencies(moduleCode) {
    const importRegex = /^import\s+.*from\s+['"]([^'"]+)['"];/gm;
    const requireRegex = /require\s*\(\s*['"]([^'"]+)['"]\s*\)/g;

    const imports = new Set();
    let match;

    while ((match = importRegex.exec(moduleCode)) !== null) {
      imports.add(match[1]);
    }

    while ((match = requireRegex.exec(moduleCode)) !== null) {
      imports.add(match[1]);
    }

    return {
      dependencies: Array.from(imports),
      dependencyCount: imports.size,
      isTooMany: imports.size > this.config.dependencyThreshold
    };
  }

  /**
   * 클래스/함수 추출
   */
  extractClasses(moduleCode) {
    const classRegex = /class\s+(\w+)\s*(?:extends\s+(\w+))?\s*\{/g;
    const classes = [];
    let match;

    while ((match = classRegex.exec(moduleCode)) !== null) {
      classes.push({
        name: match[1],
        extends: match[2] || null,
        methods: this.extractMethods(moduleCode, match[1])
      });
    }

    return classes;
  }

  /**
   * 메서드 추출
   */
  extractMethods(moduleCode, className) {
    const methodRegex = /(\w+)\s*\(([^)]*)\)\s*\{/g;
    const methods = [];
    let match;

    while ((match = methodRegex.exec(moduleCode)) !== null) {
      methods.push({
        name: match[1],
        params: match[2].split(',').map(p => p.trim()).filter(p => p),
        complexity: this.calculateMethodComplexity(moduleCode, match[1])
      });
    }

    return methods;
  }

  /**
   * 메서드 복잡도 계산
   */
  calculateMethodComplexity(moduleCode, methodName) {
    const methodRegex = new RegExp(
      `${methodName}\\s*\\([^)]*\\)\\s*\\{([^}]*)\\}`,
      's'
    );
    const match = moduleCode.match(methodRegex);

    if (!match) return 1;

    const methodBody = match[1];
    const complexity = (methodBody.match(/\bif\b/g) || []).length +
                      (methodBody.match(/\belse\b/g) || []).length +
                      (methodBody.match(/\bfor\b/g) || []).length +
                      (methodBody.match(/\bwhile\b/g) || []).length +
                      (methodBody.match(/\bcatch\b/g) || []).length + 1;

    return complexity;
  }

  /**
   * 전체 모듈 분석
   */
  analyzeModule(moduleName, moduleCode) {
    const size = this.analyzeModuleSize(moduleCode);
    const complexity = this.calculateCyclomaticComplexity(moduleCode);
    const dependencies = this.analyzeDependencies(moduleCode);
    const classes = this.extractClasses(moduleCode);

    return {
      moduleName,
      size,
      complexity,
      dependencies,
      classes,
      needsSplitting: size.isLarge || complexity.isTooComplex || dependencies.isTooMany,
      splitScore: (
        (size.nonEmptyLines / this.config.sizeThreshold) +
        (complexity.complexity / this.config.complexityThreshold) +
        (dependencies.dependencyCount / this.config.dependencyThreshold)
      ) / 3
    };
  }
}

/**
 * 분할 제안자
 */
class SplitSuggester {
  /**
   * 분할 전략 제안
   */
  suggestSplitStrategy(analysis) {
    const suggestions = [];

    if (analysis.size.isLarge) {
      suggestions.push({
        type: 'size',
        reason: `모듈 크기가 ${analysis.size.nonEmptyLines}줄로 너무 큼`,
        action: '기능별로 분할 추천',
        priority: 'HIGH'
      });
    }

    if (analysis.complexity.isTooComplex) {
      suggestions.push({
        type: 'complexity',
        reason: `순환 복잡도가 ${analysis.complexity.complexity}로 너무 높음`,
        action: '복잡한 로직을 별도 모듈로 추출',
        priority: 'HIGH'
      });
    }

    if (analysis.dependencies.isTooMany) {
      suggestions.push({
        type: 'dependencies',
        reason: `의존성이 ${analysis.dependencies.dependencyCount}개로 너무 많음`,
        action: '의존성 그룹화 및 파사드 패턴 적용',
        priority: 'MEDIUM'
      });
    }

    return {
      shouldSplit: suggestions.length > 0,
      suggestions,
      confidence: Math.min(100, analysis.splitScore * 100)
    };
  }

  /**
   * 클래스 기반 분할 계획
   */
  suggestClassBasedSplit(classes) {
    const groups = [];
    const classByRelation = new Map();

    // 상속 관계 그룹화
    for (const cls of classes) {
      if (cls.extends) {
        if (!classByRelation.has(cls.extends)) {
          classByRelation.set(cls.extends, []);
        }
        classByRelation.get(cls.extends).push(cls);
      } else {
        if (!classByRelation.has('Root')) {
          classByRelation.set('Root', []);
        }
        classByRelation.get('Root').push(cls);
      }
    }

    // 분할 계획 생성
    for (const [parent, children] of classByRelation.entries()) {
      if (children.length > 1 || parent !== 'Root') {
        groups.push({
          parent,
          classes: children.map(c => c.name),
          moduleName: `${parent.toLowerCase()}-module.js`
        });
      }
    }

    return groups;
  }

  /**
   * 함수 크기 기반 분할
   */
  suggestFunctionBasedSplit(classes) {
    const largeClasses = [];

    for (const cls of classes) {
      const totalMethods = cls.methods.length;
      const avgComplexity = cls.methods.length > 0
        ? cls.methods.reduce((sum, m) => sum + m.complexity, 0) / cls.methods.length
        : 0;

      if (totalMethods > 10 || avgComplexity > 5) {
        largeClasses.push({
          className: cls.name,
          methodCount: totalMethods,
          avgComplexity: avgComplexity.toFixed(2),
          suggestion: `${cls.name}을(를) ${Math.ceil(totalMethods / 5)}개의 모듈로 분할`,
          methods: cls.methods.slice(0, 5).map(m => m.name)
        });
      }
    }

    return largeClasses;
  }
}

/**
 * 순환 참조 검사기
 */
class CircularReferenceDetector {
  /**
   * 순환 참조 감지
   */
  detectCircularReferences(moduleCode, imports) {
    const graph = this.buildDependencyGraph(moduleCode, imports);
    const cycles = [];

    for (const node of graph.keys()) {
      const visited = new Set();
      const cycle = this.findCycle(node, graph, visited, []);
      if (cycle) {
        cycles.push(cycle);
      }
    }

    return cycles;
  }

  /**
   * 의존성 그래프 구성
   */
  buildDependencyGraph(moduleCode, imports) {
    const graph = new Map();

    for (const imp of imports) {
      graph.set(imp, this.extractDependencies(moduleCode, imp));
    }

    return graph;
  }

  /**
   * 의존성 추출
   */
  extractDependencies(moduleCode, moduleName) {
    const pattern = new RegExp(`from\\s+['"]${moduleName}['"]`, 'g');
    return pattern.test(moduleCode) ? [moduleName] : [];
  }

  /**
   * 순환 찾기 (DFS)
   */
  findCycle(node, graph, visited, path) {
    if (visited.has(node)) {
      const cycleStart = path.indexOf(node);
      if (cycleStart !== -1) {
        return path.slice(cycleStart).concat([node]);
      }
      return null;
    }

    visited.add(node);
    path.push(node);

    const neighbors = graph.get(node) || [];
    for (const neighbor of neighbors) {
      const cycle = this.findCycle(neighbor, graph, new Set(visited), [...path]);
      if (cycle) return cycle;
    }

    return null;
  }

  /**
   * 순환 참조 해결 제안
   */
  suggestCircularFix(cycles) {
    const fixes = [];

    for (const cycle of cycles) {
      fixes.push({
        cycle: cycle.join(' -> '),
        solutions: [
          '공통 모듈로 의존성 추출',
          '인터페이스 기반 의존성 주입',
          '단방향 의존성으로 변경',
          'Facade 패턴 적용'
        ],
        recommendedSolution: '공통 모듈로 의존성 추출'
      });
    }

    return fixes;
  }
}

/**
 * 분할 실행기
 */
class SplitExecutor {
  /**
   * 분할 계획 실행
   */
  executeSplit(moduleCode, classes, splitPlan) {
    const modules = {};

    for (const group of splitPlan) {
      modules[group.moduleName] = this.extractClassesToModule(
        moduleCode,
        group.classes
      );
    }

    modules['index.js'] = this.generateIndexFile(splitPlan);
    return modules;
  }

  /**
   * 클래스를 모듈로 추출
   */
  extractClassesToModule(moduleCode, classNames) {
    let moduleContent = moduleCode;

    // 필요한 import/require만 유지
    const relevantImports = this.extractRelevantImports(moduleCode, classNames);

    let result = relevantImports + '\n\n';

    for (const className of classNames) {
      const classRegex = new RegExp(
        `class\\s+${className}\\s*(?:extends\\s+\\w+)?\\s*\\{[^}]*\\}`,
        's'
      );
      const match = moduleCode.match(classRegex);
      if (match) {
        result += match[0] + '\n\n';
      }
    }

    result += `\nexport { ${classNames.join(', ')} };\n`;
    return result;
  }

  /**
   * 관련 import 추출
   */
  extractRelevantImports(moduleCode, classNames) {
    const importRegex = /^import\s+.*from\s+['"]([^'"]+)['"];/gm;
    const imports = [];
    let match;

    while ((match = importRegex.exec(moduleCode)) !== null) {
      imports.push(match[0]);
    }

    return imports.join('\n');
  }

  /**
   * 인덱스 파일 생성
   */
  generateIndexFile(splitPlan) {
    let indexContent = '/**\n';
    indexContent += ' * Auto-generated Index File\n';
    indexContent += ' * This file re-exports all classes from split modules\n';
    indexContent += ' */\n\n';

    for (const group of splitPlan) {
      const modulePath = `./${group.moduleName}`;
      const exports = group.classes.join(', ');
      indexContent += `export { ${exports} } from '${modulePath}';\n`;
    }

    return indexContent;
  }
}

