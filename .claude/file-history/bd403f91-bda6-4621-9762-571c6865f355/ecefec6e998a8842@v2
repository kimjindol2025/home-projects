/**
 * Noise Model - 노이즈 모델
 * Phase 10.1: Real Quantum Hardware Integration
 *
 * 기능:
 * - T1/T2 이완 시뮬레이션
 * - 게이트 오류 모델링
 * - 측정 오류 모델링
 * - 크라우스 연산자 적용
 */

/**
 * 노이즈 파라미터
 */
class NoiseParameters {
  constructor(config = {}) {
    // T1/T2 이완 시간 (마이크로초)
    this.T1 = config.T1 || 100.0;      // 에너지 이완
    this.T2 = config.T2 || 50.0;       // 위상 이완
    this.temperature = config.temperature || 0.01;  // 온도 (K)

    // 게이트 오류율
    this.singleQubitErrorRate = config.singleQubitErrorRate || 0.001;
    this.twoQubitErrorRate = config.twoQubitErrorRate || 0.01;
    this.measurementErrorRate = config.measurementErrorRate || 0.005;

    // 크라우스 연산자
    this.krausOperators = [];
    this.generateKrausOperators();
  }

  /**
   * 크라우스 연산자 생성
   */
  generateKrausOperators() {
    // 0 → 0 (성공)
    this.krausOperators.push({
      name: 'Identity',
      amplitude: Math.sqrt(1 - this.singleQubitErrorRate),
      matrix: [[1, 0], [0, 1]]
    });

    // 0 → 1 (플립)
    this.krausOperators.push({
      name: 'BitFlip',
      amplitude: Math.sqrt(this.singleQubitErrorRate),
      matrix: [[0, 1], [1, 0]]
    });

    // 위상 다시짐
    this.krausOperators.push({
      name: 'PhaseDamping',
      amplitude: Math.sqrt(this.T2 / (2 * this.T1)),
      matrix: [[1, 0], [0, Math.exp(-1 / (2 * this.T1))]]
    });
  }

  /**
   * 단일 큐빗 오류율 계산
   */
  calculateSingleQubitErrorRate(gateTime) {
    const T1decay = Math.exp(-gateTime / this.T1);
    const T2decay = Math.exp(-gateTime / this.T2);
    return 1 - (T1decay * T2decay);
  }

  /**
   * 두 큐빗 오류율 계산
   */
  calculateTwoQubitErrorRate(gateTime) {
    return this.twoQubitErrorRate * (1 - Math.exp(-gateTime / 50));
  }

  /**
   * 노이즈 영향 시뮬레이션
   */
  simulateNoise(state) {
    // 상태 벡터에 노이즈 적용
    const noisyState = state.map(amplitude => {
      const noiseFactorT1 = Math.exp(-1 / (2 * this.T1));
      const noiseFactorT2 = Math.exp(-1 / (2 * this.T2));
      return amplitude * noiseFactorT1 * noiseFactorT2;
    });

    // 정규화
    const norm = Math.sqrt(
      noisyState.reduce((sum, amp) => sum + Math.abs(amp) ** 2, 0)
    );

    return noisyState.map(amp => amp / norm);
  }
}

/**
 * 게이트 오류 모델
 */
class GateErrorModel {
  constructor(noiseParams) {
    this.params = noiseParams;
    this.gateErrors = new Map();
    this.initializeGateErrors();
  }

  /**
   * 게이트 오류 초기화
   */
  initializeGateErrors() {
    // 단일 큐빗 게이트
    const singleQubitGates = ['H', 'X', 'Y', 'Z', 'S', 'T', 'RX', 'RY', 'RZ'];
    for (const gate of singleQubitGates) {
      this.gateErrors.set(gate, {
        errorRate: this.params.singleQubitErrorRate,
        duration: 20,  // ns
        type: 'single'
      });
    }

    // 두 큐빗 게이트
    const twoQubitGates = ['CNOT', 'CZ', 'SWAP', 'iSWAP'];
    for (const gate of twoQubitGates) {
      this.gateErrors.set(gate, {
        errorRate: this.params.twoQubitErrorRate,
        duration: 40,  // ns
        type: 'two'
      });
    }
  }

  /**
   * 게이트 오류 적용
   */
  applyGateError(gate, state) {
    const gateInfo = this.gateErrors.get(gate);
    if (!gateInfo) {
      return state;
    }

    // 오류 확률
    const errorProb = gateInfo.errorRate;
    const noError = 1 - errorProb;

    // 오류 시뮬레이션
    if (Math.random() < errorProb) {
      // 오류 발생 - 상태 반전
      return state.map(amp => -amp);
    }

    return state;
  }

  /**
   * 게이트 특성 획득
   */
  getGateCharacteristics(gate) {
    return this.gateErrors.get(gate) || { error: 'Unknown gate' };
  }

  /**
   * 오류율 업데이트
   */
  updateErrorRate(gate, newRate) {
    const info = this.gateErrors.get(gate);
    if (info) {
      info.errorRate = newRate;
    }
  }
}

/**
 * 측정 오류 모델
 */
class MeasurementErrorModel {
  constructor(noiseParams) {
    this.params = noiseParams;
    this.confusionMatrix = null;
    this.generateConfusionMatrix();
  }

  /**
   * 혼동 행렬 생성 (측정 오류)
   */
  generateConfusionMatrix() {
    const p = this.params.measurementErrorRate;
    const q = 1 - p;

    // 2x2 혼동 행렬 (0→0, 0→1, 1→0, 1→1)
    this.confusionMatrix = [
      [q, p],      // 0 측정 확률
      [p, q]       // 1 측정 확률
    ];
  }

  /**
   * 측정 오류 적용
   */
  applyMeasurementError(counts) {
    const erroredCounts = {};
    const totalShots = Object.values(counts).reduce((a, b) => a + b, 0);

    // 각 상태에 오류 적용
    for (const [state, count] of Object.entries(counts)) {
      // 0 상태 확률
      if (state === '0') {
        erroredCounts['0'] = Math.round(count * this.confusionMatrix[0][0]);
        erroredCounts['1'] = Math.round(count * this.confusionMatrix[1][0]);
      }
      // 1 상태 확률
      else if (state === '1') {
        erroredCounts['0'] = (erroredCounts['0'] || 0) + Math.round(count * this.confusionMatrix[0][1]);
        erroredCounts['1'] = (erroredCounts['1'] || 0) + Math.round(count * this.confusionMatrix[1][1]);
      }
    }

    return erroredCounts;
  }

  /**
   * 혼동 행렬 조회
   */
  getConfusionMatrix() {
    return this.confusionMatrix;
  }

  /**
   * 오류 확률 업데이트
   */
  updateErrorRate(newRate) {
    this.params.measurementErrorRate = newRate;
    this.generateConfusionMatrix();
  }
}

/**
 * 통합 노이즈 모델
 */
class IntegratedNoiseModel {
  constructor(config = {}) {
    this.noiseParams = new NoiseParameters(config);
    this.gateErrorModel = new GateErrorModel(this.noiseParams);
    this.measurementErrorModel = new MeasurementErrorModel(this.noiseParams);
    this.noiseProfile = 'realistic';  // realistic, ideal
    this.environment = {
      temperature: config.temperature || 0.01,
      magneticField: config.magneticField || 50,  // mT
      vibration: config.vibration || 0.1
    };
  }

  /**
   * 완전한 노이즈 적용
   */
  applyCompleteNoise(circuit, counts) {
    if (this.noiseProfile === 'ideal') {
      return counts;
    }

    // 1단계: 게이트 오류 (회로 실행 중)
    let noisyCircuit = JSON.parse(JSON.stringify(circuit));
    for (let i = 0; i < noisyCircuit.gates.length; i++) {
      const gate = noisyCircuit.gates[i];
      if (Math.random() < this.noiseParams.singleQubitErrorRate) {
        noisyCircuit.gates[i] = { ...gate, corrupted: true };
      }
    }

    // 2단계: 환경 노이즈
    const environmentalNoise = this.environment.vibration * 0.01;
    const noiseFactor = 1 - environmentalNoise;

    // 3단계: 측정 오류
    const finalCounts = this.measurementErrorModel.applyMeasurementError(counts);

    return finalCounts;
  }

  /**
   * 노이즈 프로파일 설정
   */
  setNoiseProfile(profile) {
    this.noiseProfile = profile;
  }

  /**
   * 환경 파라미터 업데이트
   */
  updateEnvironment(env) {
    this.environment = { ...this.environment, ...env };
  }

  /**
   * 노이즈 요약
   */
  getNoiseReport() {
    return {
      profile: this.noiseProfile,
      T1: this.noiseParams.T1,
      T2: this.noiseParams.T2,
      singleQubitError: this.noiseParams.singleQubitErrorRate,
      twoQubitError: this.noiseParams.twoQubitErrorRate,
      measurementError: this.noiseParams.measurementErrorRate,
      environment: this.environment,
      confusionMatrix: this.measurementErrorModel.getConfusionMatrix()
    };
  }
}

