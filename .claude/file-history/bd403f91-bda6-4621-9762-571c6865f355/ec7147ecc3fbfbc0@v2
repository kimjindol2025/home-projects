/**
 * Quantum Knowledge Base - 양자 지식베이스
 * Phase 10: Quantum-Ready Intelligence
 *
 * 기능:
 * - 양자 상태 저장
 * - 상태 복구
 * - 진화 추적
 * - 양자 데이터 구조
 */

/**
 * 양자 정보 단위
 */
class QuantumInformation {
  constructor(id, content) {
    this.id = id;
    this.content = content;
    this.quantumState = null;             // 양자 상태
    this.classicalRepresentation = content;
    this.entanglementDegree = 0;
    this.retrievalCost = 0;
  }

  /**
   * 양자 상태로 인코딩
   */
  encodeToQuantumState(dimension = 4) {
    const amplitudes = [];

    // 내용을 복소 진폭으로 변환
    for (let i = 0; i < dimension; i++) {
      const phase = (this.content.charCodeAt(i % this.content.length) * 2 * Math.PI) / 256;
      const magnitude = 1 / Math.sqrt(dimension);

      amplitudes.push({
        real: magnitude * Math.cos(phase),
        imag: magnitude * Math.sin(phase)
      });
    }

    this.quantumState = {
      amplitudes,
      dimension,
      encoded: true,
      timestamp: Date.now()
    };

    return this.quantumState;
  }

  /**
   * 양자 상태에서 디코딩
   */
  decodeFromQuantumState() {
    if (!this.quantumState) return null;

    let recovered = '';
    for (const amplitude of this.quantumState.amplitudes) {
      const phase = Math.atan2(amplitude.imag, amplitude.real);
      const charCode = Math.round((phase / (2 * Math.PI)) * 256);
      recovered += String.fromCharCode(Math.abs(charCode) % 256);
    }

    return recovered;
  }

  /**
   * 검색 비용 계산
   */
  calculateRetrievalCost(algorithm = 'grover') {
    const classicalCost = this.content.length;

    if (algorithm === 'grover') {
      // Grover's search: O(√N)
      this.retrievalCost = Math.sqrt(classicalCost);
    } else if (algorithm === 'direct-access') {
      // 직접 접근: O(1) with quantum indexing
      this.retrievalCost = 1;
    } else {
      this.retrievalCost = classicalCost;
    }

    return this.retrievalCost;
  }
}

/**
 * 양자 인덱스
 */
class QuantumIndex {
  constructor() {
    this.entries = new Map();
    this.indexStructure = null;
    this.amplitude = null;
  }

  /**
   * 항목 추가
   */
  addEntry(key, value) {
    const info = new QuantumInformation(key, value);
    info.encodeToQuantumState();
    this.entries.set(key, info);
    return this;
  }

  /**
   * 양자 상태 인덱스 구축
   */
  buildQuantumIndex() {
    const size = this.entries.size;
    const dimension = 2 ** Math.ceil(Math.log2(size));

    const amplitudes = [];
    const amplitude = 1 / Math.sqrt(dimension);

    for (let i = 0; i < dimension; i++) {
      amplitudes.push({
        real: amplitude * Math.cos(2 * Math.PI * i / dimension),
        imag: amplitude * Math.sin(2 * Math.PI * i / dimension)
      });
    }

    this.amplitude = amplitudes;
    this.indexStructure = {
      type: 'quantum-index',
      size,
      dimension,
      amplitudes,
      built: Date.now()
    };

    return this.indexStructure;
  }

  /**
   * 양자 검색
   */
  quantumSearch(key) {
    if (!this.entries.has(key)) {
      return { found: false, key };
    }

    const entry = this.entries.get(key);
    const searchCost = entry.calculateRetrievalCost('grover');

    return {
      found: true,
      key,
      value: entry.content,
      quantumState: entry.quantumState,
      searchCost,
      classicalCostComparison: entry.content.length / searchCost
    };
  }

  /**
   * 범위 검색
   */
  rangeQuantumSearch(pattern) {
    const results = [];

    for (const [key, info] of this.entries) {
      if (key.includes(pattern)) {
        results.push({
          key,
          value: info.content,
          relevance: this.calculateRelevance(key, pattern)
        });
      }
    }

    return {
      pattern,
      resultsFound: results.length,
      results,
      searchCost: `O(√${this.entries.size})`
    };
  }

  /**
   * 관련성 계산
   */
  calculateRelevance(key, pattern) {
    const patternIndex = key.indexOf(pattern);
    return 1 - (patternIndex / key.length);
  }
}

/**
 * 양자 상태 메모리
 */
class QuantumMemory {
  constructor(capacity = 100) {
    this.capacity = capacity;
    this.states = [];
    this.coherenceTime = 1000;            // ms
    this.decoherenceRate = 0.01;
  }

  /**
   * 양자 상태 저장
   */
  storeQuantumState(state) {
    if (this.states.length >= this.capacity) {
      // 가장 오래된 상태 제거
      this.states.shift();
    }

    const storedState = {
      id: Math.random().toString(36).substr(2, 9),
      state,
      storedAt: Date.now(),
      coherence: 1.0
    };

    this.states.push(storedState);
    return storedState.id;
  }

  /**
   * 양자 상태 복구
   */
  retrieveQuantumState(stateId) {
    const stored = this.states.find(s => s.id === stateId);
    if (!stored) return null;

    // 시간 경과에 따른 디코히어런스 시뮬레이션
    const timePassed = Date.now() - stored.storedAt;
    const decoherence = Math.exp(-this.decoherenceRate * timePassed);
    stored.coherence = decoherence;

    return {
      state: stored.state,
      coherence: decoherence,
      retrieved: true
    };
  }

  /**
   * 상태 목록
   */
  listStoredStates() {
    return this.states.map(s => ({
      id: s.id,
      age: Date.now() - s.storedAt,
      coherence: (s.coherence * 100).toFixed(1) + '%'
    }));
  }

  /**
   * 메모리 상태
   */
  getMemoryStatus() {
    return {
      capacity: this.capacity,
      used: this.states.length,
      available: this.capacity - this.states.length,
      utilizationRate: (this.states.length / this.capacity * 100).toFixed(1) + '%'
    };
  }
}

/**
 * 양자 지식베이스
 */
class QuantumKnowledgeBase {
  constructor(config = {}) {
    this.config = {
      indexSize: config.indexSize || 1000,
      memoryCapacity: config.memoryCapacity || 100,
      ...config
    };

    this.index = new QuantumIndex();
    this.memory = new QuantumMemory(this.config.memoryCapacity);
    this.evolution = [];
    this.version = 1;
  }

  /**
   * 지식 항목 추가
   */
  addKnowledge(key, value, priority = 0.5) {
    this.index.addEntry(key, value);

    const entry = this.index.entries.get(key);
    const stateId = this.memory.storeQuantumState(entry.quantumState);

    const evolutionEntry = {
      version: this.version,
      timestamp: Date.now(),
      action: 'add-knowledge',
      key,
      stateId,
      priority
    };

    this.evolution.push(evolutionEntry);
    return { stateId, version: this.version };
  }

  /**
   * 지식 검색
   */
  searchKnowledge(key) {
    const searchResult = this.index.quantumSearch(key);

    if (searchResult.found) {
      const memoryState = this.memory.retrieveQuantumState(
        // 상태 ID 대신 키 기반으로 찾기
        Array.from(this.index.entries.keys()).indexOf(key)
      );

      return {
        ...searchResult,
        memoryCoherence: memoryState ? memoryState.coherence : null
      };
    }

    return searchResult;
  }

  /**
   * 지식 범위 검색
   */
  searchKnowledgeRange(pattern) {
    return this.index.rangeQuantumSearch(pattern);
  }

  /**
   * 지식 베이스 최적화
   */
  optimizeKnowledgeBase() {
    // 인덱스 재구축
    this.index.buildQuantumIndex();

    // 낮은 코히어런스 상태 정리
    const beforeSize = this.memory.states.length;
    this.memory.states = this.memory.states.filter(s => s.coherence > 0.5);

    this.evolution.push({
      version: this.version++,
      timestamp: Date.now(),
      action: 'optimize',
      statesRemoved: beforeSize - this.memory.states.length
    });

    return {
      statesRemoved: beforeSize - this.memory.states.length,
      newSize: this.memory.states.length
    };
  }

  /**
   * 진화 히스토리
   */
  getEvolutionHistory(limit = 10) {
    return this.evolution.slice(-limit);
  }

  /**
   * 지식베이스 상태
   */
  getStatus() {
    return {
      version: this.version,
      totalKnowledge: this.index.entries.size,
      memoryUsage: this.memory.getMemoryStatus(),
      evolutionEvents: this.evolution.length,
      averageCoherence: this.memory.states.length > 0 ?
        (this.memory.states.reduce((sum, s) => sum + s.coherence, 0) / this.memory.states.length * 100).toFixed(1) + '%' :
        'N/A'
    };
  }
}

