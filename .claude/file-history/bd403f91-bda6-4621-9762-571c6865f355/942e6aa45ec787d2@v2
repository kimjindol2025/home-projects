/**
 * Performance Benchmarker - 성능 벤치마크
 * Phase 10.5: Production Validation
 *
 * 기능:
 * - 처리량 측정
 * - 지연 시간 분석
 * - 메모리 사용 추적
 * - 성능 비교
 */

/**
 * 처리량 벤치마커
 */
class ThroughputBenchmark {
  constructor() {
    this.results = [];
  }

  /**
   * 처리량 테스트
   */
  runTest(operationName, operationFn, iterations = 1000) {
    const startTime = Date.now();
    const startMemory = process.memoryUsage().heapUsed;

    for (let i = 0; i < iterations; i++) {
      operationFn();
    }

    const endTime = Date.now();
    const endMemory = process.memoryUsage().heapUsed;

    const duration = (endTime - startTime) / 1000;  // seconds
    const throughput = iterations / duration;  // ops/sec
    const memoryUsed = (endMemory - startMemory) / 1024 / 1024;  // MB

    const result = {
      operationName,
      iterations,
      duration: duration.toFixed(2) + 's',
      throughput: Math.round(throughput) + ' ops/s',
      memoryUsed: memoryUsed.toFixed(2) + ' MB',
      avgTimePerOp: ((duration * 1000) / iterations).toFixed(2) + 'ms'
    };

    this.results.push(result);

    return result;
  }

  /**
   * 벤치마크 정보
   */
  getInfo() {
    if (this.results.length === 0) {
      return null;
    }

    return {
      totalBenchmarks: this.results.length,
      results: this.results
    };
  }
}

/**
 * 지연 시간 벤치마커
 */
class LatencyBenchmark {
  constructor() {
    this.measurements = [];
  }

  /**
   * 지연 시간 측정
   */
  measureLatency(operationName, operationFn, iterations = 100) {
    const latencies = [];

    for (let i = 0; i < iterations; i++) {
      const startTime = process.hrtime.bigint();
      operationFn();
      const endTime = process.hrtime.bigint();

      const latency = Number(endTime - startTime) / 1000000;  // convert to ms
      latencies.push(latency);
    }

    // 통계 계산
    const sorted = latencies.sort((a, b) => a - b);
    const min = sorted[0];
    const max = sorted[sorted.length - 1];
    const avg = latencies.reduce((a, b) => a + b) / latencies.length;
    const p50 = sorted[Math.floor(sorted.length * 0.5)];
    const p95 = sorted[Math.floor(sorted.length * 0.95)];
    const p99 = sorted[Math.floor(sorted.length * 0.99)];

    const result = {
      operationName,
      iterations,
      min: min.toFixed(3) + 'ms',
      max: max.toFixed(3) + 'ms',
      avg: avg.toFixed(3) + 'ms',
      p50: p50.toFixed(3) + 'ms',
      p95: p95.toFixed(3) + 'ms',
      p99: p99.toFixed(3) + 'ms'
    };

    this.measurements.push(result);

    return result;
  }

  /**
   * 벤치마크 정보
   */
  getInfo() {
    if (this.measurements.length === 0) {
      return null;
    }

    return {
      totalMeasurements: this.measurements.length,
      measurements: this.measurements
    };
  }
}

/**
 * 메모리 벤치마커
 */
class MemoryBenchmark {
  constructor() {
    this.snapshots = [];
  }

  /**
   * 메모리 스냅샷
   */
  takeSnapshot(label) {
    const memUsage = process.memoryUsage();

    const snapshot = {
      label,
      timestamp: Date.now(),
      heapUsed: (memUsage.heapUsed / 1024 / 1024).toFixed(2) + ' MB',
      heapTotal: (memUsage.heapTotal / 1024 / 1024).toFixed(2) + ' MB',
      external: (memUsage.external / 1024 / 1024).toFixed(2) + ' MB',
      rss: (memUsage.rss / 1024 / 1024).toFixed(2) + ' MB'
    };

    this.snapshots.push(snapshot);

    return snapshot;
  }

  /**
   * 메모리 차이 분석
   */
  analyzeDifference(label1, label2) {
    const snap1 = this.snapshots.find(s => s.label === label1);
    const snap2 = this.snapshots.find(s => s.label === label2);

    if (!snap1 || !snap2) {
      return { error: 'Snapshot not found' };
    }

    const heap1 = parseFloat(snap1.heapUsed);
    const heap2 = parseFloat(snap2.heapUsed);
    const diff = heap2 - heap1;

    return {
      from: label1,
      to: label2,
      heapDiff: diff.toFixed(2) + ' MB',
      percentChange: (((heap2 - heap1) / heap1) * 100).toFixed(2) + '%'
    };
  }

  /**
   * 벤치마크 정보
   */
  getInfo() {
    if (this.snapshots.length === 0) {
      return null;
    }

    return {
      totalSnapshots: this.snapshots.length,
      snapshots: this.snapshots
    };
  }
}

/**
 * 성능 비교기
 */
class PerformanceComparator {
  constructor() {
    this.baselines = {};
    this.results = [];
  }

  /**
   * 기준선 설정
   */
  setBaseline(name, throughput, latency) {
    this.baselines[name] = {
      throughput,
      latency
    };
  }

  /**
   * 성능 비교
   */
  compare(name, currentThroughput, currentLatency) {
    const baseline = this.baselines[name];

    if (!baseline) {
      return { error: 'Baseline not found' };
    }

    const throughputImprovement = ((currentThroughput - baseline.throughput) / baseline.throughput) * 100;
    const latencyImprovement = ((baseline.latency - currentLatency) / baseline.latency) * 100;

    const result = {
      name,
      baseline: baseline,
      current: {
        throughput: currentThroughput,
        latency: currentLatency
      },
      improvement: {
        throughput: throughputImprovement.toFixed(2) + '%',
        latency: latencyImprovement.toFixed(2) + '%'
      },
      better: throughputImprovement > 0 || latencyImprovement > 0
    };

    this.results.push(result);

    return result;
  }

  /**
   * 비교 정보
   */
  getInfo() {
    return {
      totalComparisons: this.results.length,
      results: this.results
    };
  }
}

/**
 * 벤치마크 러너
 */
class BenchmarkRunner {
  constructor() {
    this.throughputBench = new ThroughputBenchmark();
    this.latencyBench = new LatencyBenchmark();
    this.memoryBench = new MemoryBenchmark();
    this.comparator = new PerformanceComparator();
  }

  /**
   * 전체 벤치마크 실행
   */
  runAllBenchmarks() {
    // Throughput 벤치마크
    this.throughputBench.runTest('simple-operation', () => {
      let sum = 0;
      for (let i = 0; i < 100; i++) {
        sum += i;
      }
    }, 1000);

    // Latency 벤치마크
    this.latencyBench.measureLatency('array-operation', () => {
      const arr = [];
      for (let i = 0; i < 100; i++) {
        arr.push(i);
      }
    }, 100);

    // Memory 벤치마크
    this.memoryBench.takeSnapshot('start');
    for (let i = 0; i < 1000; i++) {
      const obj = { data: new Array(100).fill(Math.random()) };
    }
    this.memoryBench.takeSnapshot('end');

    return {
      throughput: this.throughputBench.getInfo(),
      latency: this.latencyBench.getInfo(),
      memory: this.memoryBench.getInfo()
    };
  }

  /**
   * 종합 리포트
   */
  generateReport() {
    const benchmarkResults = this.runAllBenchmarks();

    return {
      timestamp: new Date().toISOString(),
      throughput: benchmarkResults.throughput,
      latency: benchmarkResults.latency,
      memory: benchmarkResults.memory,
      comparisons: this.comparator.getInfo(),
      status: 'COMPLETED'
    };
  }
}

