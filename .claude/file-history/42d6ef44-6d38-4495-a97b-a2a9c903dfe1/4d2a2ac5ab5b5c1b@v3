  let pool = newBufferPool(1, 1048576, 65536)
  manager.pools[1] = pool
  let result = allocateBuffer(manager, 1, 4096, 100)
  (result.ok == true)

fn testOwnershipTransfer()
  let manager = newZeroCopyManager()
  let pool = newBufferPool(1, 1048576, 65536)
  manager.pools[1] = pool
  let allocResult = allocateBuffer(manager, 1, 4096, 100)
  if allocResult.ok
    let buffer = allocResult.value
    let transferResult = transferOwnership(manager, buffer, 100, 200)
    (transferResult.ok == true)
  else
    false

