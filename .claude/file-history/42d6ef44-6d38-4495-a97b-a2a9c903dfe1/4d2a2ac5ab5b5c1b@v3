fn testEndToEndZeroCopyTransfer()
  let config = newRDMAConfig()
  let rdmaContext = newRDMAContext(0, config)
  let manager = newZeroCopyManager()
  let pool = newBufferPool(1, 1048576, 65536)
  manager.pools[1] = pool
  let allocResult = allocateBuffer(manager, 1, 1024, 1)
  if allocResult.ok
    let buffer = allocResult.value
    let descriptor = registerBufferForDMA(manager, 1, buffer)
    var data = []
    for i = 0 to 256
      data.append(i % 256)
    let sendResult = postSend(rdmaContext, 1, data, 0)
    (sendResult.ok == true && descriptor >= 0)
  else
    false

fn testConcurrentDMAOperations()
  let config = newRDMAConfig()
  let context = newRDMAContext(0, config)
  var results = []
  for i = 0 to 10
    var buffer = []
    for j = 0 to 512
      buffer.append(j % 256)
    let result = postSend(context, i, buffer, 0)
    if result.ok
      results.append(1)
    else
      results.append(0)
  (results.length() == 10)

fn testProtocolCompilerIntegration()
  let compiler = newProtocolCompiler()
  var schema = createSchema("NetworkPacket")
  schema = addField(schema, "src", "i32", 1)
  schema = addField(schema, "dst", "i32", 2)
  schema = addField(schema, "payload", "bytes", 3)
  let compiled = compileProtocol(compiler, schema)
  let data = {
    "src": 1,
    "dst": 2,
    "payload": []
  }
  let encoded = encodeZeroCopy(compiler, "NetworkPacket", data)
  (encoded.length() > 0)

fn testRouterWithConsensusIntegration()
  let router = newContentRouter(1)
  let pattern = {
    "dataType": "metadata",
    "sizeRange": [128, 512],
    "frequencyHint": 25,
    "affinity": [2, 3],
    "timestamp": 1740998400
  }
  let decision = selectOptimalPath(router, pattern)
  if decision.consensusRequired
    let packet = prepareConsensusPacket(router, decision)
    (packet["consensusRequired"] == true)
  else
    (decision.nextHop >= 0)

