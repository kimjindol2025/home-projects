fn testRDMAInitialization()
  let config = newRDMAConfig()
  let transport = newRDMATransport(config)
  let result = initRDMA(transport, 0)
  (result.ok == true)

fn testRingBufferManagement()
  let config = newRDMAConfig()
  let context = newRDMAContext(0, config)
  let txSize = context.txRingBuffer.length()
  let rxSize = context.rxRingBuffer.length()
  (txSize == config.ringBufferSize && rxSize == config.ringBufferSize)

fn testDMATransmission()
  let config = newRDMAConfig()
  let context = newRDMAContext(0, config)
  var buffer = []
  for i = 0 to 1024
    buffer.append(i % 256)
  let result = postSend(context, 1, buffer, 0)
  (result.ok == true)

fn testInterruptCoalescing()
  let config = newRDMAConfig()
  let context = newRDMAContext(0, config)
  let updated = enableInterruptCoalescing(context, 64)
  (updated.stats["interruptCount"] as number == 1)

