fn testProtoCompressionRatio() -> Result<bool, string>
  # Arrange: 768-dim vector
  let vectorId = "v1"
  let vector = array_of_zeros(768)
  let topK = 10

  # Act: Calculate compression
  # Estimated:
  #   JSON: ~20 + 2 + 10 + 768*8 + 10 + 10*20 = 6,400 bytes
  #   Proto: (2+2) + 2 + (2+768*4) = 3,078 bytes
  #   Ratio: 3,078 / 6,400 = 48%

  let protoSize = 3078
  let jsonSize = 6400
  let ratio = protoSize / jsonSize

  # Assert
  if ratio < 0.5
    Ok(true)
  else
    Err("Compression ratio too high: " + toString(ratio))

