fn getRemediationStats(engine: map<string, any>) -> string
  let stats = engine["stats"]

  let successRate = if stats["totalExecutions"] > 0
    then (stats["successfulExecutions"] as f64) / (stats["totalExecutions"] as f64) * 100.0
    else 0.0

  "Auto-Remediation Engine Stats:\\n" +
  "Total Executions: " + toString(stats["totalExecutions"]) + "\\n" +
  "Successful: " + toString(stats["successfulExecutions"]) + "\\n" +
  "Failed: " + toString(stats["failedExecutions"]) + "\\n" +
  "Success Rate: " + toString((successRate as number)) + "%\\n" +
  "Escalated: " + toString(stats["escalatedCount"]) + "\\n" +
  "Avg Duration: " + toString(stats["avgDurationMs"]) + "ms\\n" +
  "Effect Achieved: " + toString((stats["effectAchieved"] as number)) + "%"

