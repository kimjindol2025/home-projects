struct Metric
  name: string
  value: number
  unit: string
  timestamp: number
  labels: map<string, string>

struct MetricTimeSeries
  metric: Metric
  samples: array<tuple<number, number>>

struct PerformanceMetrics
  requestLatency: number
  throughput: number
  errorRate: number
  cpuUsage: number
  memoryUsage: number
  diskIO: number
  cacheHitRatio: number
  timestamp: number

struct DashboardConfig
  promUrl: string
  grafanaUrl: string
  scrapeInterval: number
  retentionDays: number

struct PerformanceDashboard
  config: DashboardConfig
  metrics: array<Metric>
  currentMetrics: PerformanceMetrics
  alertRules: array<map<string, any>>

fn newPerformanceDashboard(config: DashboardConfig) -> PerformanceDashboard
  {
    "config": config,
    "metrics": [],
    "currentMetrics": {
      "requestLatency": 0,
      "throughput": 0,
      "errorRate": 0,
      "cpuUsage": 0,
      "memoryUsage": 0,
      "diskIO": 0,
      "cacheHitRatio": 0,
      "timestamp": getCurrentTime()
    },
    "alertRules": []
  }

fn recordMetric(dashboard: PerformanceDashboard, metric: Metric) -> Result<bool, string>
  dashboard["metrics"].append(metric)

  match metric["name"]
    "request_latency_p99" ->
      dashboard["currentMetrics"]["requestLatency"] = metric["value"]
    "throughput_req_sec" ->
      dashboard["currentMetrics"]["throughput"] = metric["value"]
    "error_rate_percent" ->
      dashboard["currentMetrics"]["errorRate"] = metric["value"]
    "cpu_usage_percent" ->
      dashboard["currentMetrics"]["cpuUsage"] = metric["value"]
    "memory_usage_mb" ->
      dashboard["currentMetrics"]["memoryUsage"] = metric["value"]
    _ -> ()

  Ok(true)

fn getMetrics(
  dashboard: PerformanceDashboard,
  metricName: string,
  timeRange: number
) -> Result<array<Metric>, string>
  let result = []
  let now = getCurrentTime()

  for metric in dashboard["metrics"]
    if metric["name"] == metricName && (now - metric["timestamp"]) <= timeRange
      result.append(metric)

  Ok(result)

fn getLatencyPercentiles(
  dashboard: PerformanceDashboard,
  endpoint: string
) -> map<string, number>
  let p50 = 0
  let p95 = 0
  let p99 = 0

  for metric in dashboard["metrics"]
    if metric["name"].find("latency") >= 0 && metric["name"].find(endpoint) >= 0
      match metric["name"]
        "latency_p50" -> p50 = metric["value"]
        "latency_p95" -> p95 = metric["value"]
        "latency_p99" -> p99 = metric["value"]
        _ -> ()

  { "p50": p50, "p95": p95, "p99": p99 }

fn calculateAverageLatency(
  dashboard: PerformanceDashboard,
  startTime: number,
  endTime: number
) -> number
  let sum = 0
  let count = 0

  for metric in dashboard["metrics"]
    if metric["name"].find("latency") >= 0 && metric["timestamp"] >= startTime && metric["timestamp"] <= endTime
      sum = sum + metric["value"]
      count = count + 1

  if count == 0 then 0 else sum / count

fn getErrorRateByEndpoint(
  dashboard: PerformanceDashboard
) -> map<string, number>
  let result = {}

  for metric in dashboard["metrics"]
    if metric["name"].find("error_rate") >= 0
      let endpoint = metric["labels"]["endpoint"] || "unknown"
      result[endpoint] = metric["value"]

  result

fn generateDashboardSnapshot(dashboard: PerformanceDashboard) -> string
  let json = "{\n"
  json = json + "  \"timestamp\": " + toString(getCurrentTime()) + ",\n"
  json = json + "  \"requestLatency\": " + toString(dashboard["currentMetrics"]["requestLatency"]) + ",\n"
  json = json + "  \"throughput\": " + toString(dashboard["currentMetrics"]["throughput"]) + ",\n"
  json = json + "  \"errorRate\": " + toString(dashboard["currentMetrics"]["errorRate"]) + ",\n"
  json = json + "  \"cpuUsage\": " + toString(dashboard["currentMetrics"]["cpuUsage"]) + ",\n"
  json = json + "  \"memoryUsage\": " + toString(dashboard["currentMetrics"]["memoryUsage"]) + ",\n"
  json = json + "  \"cacheHitRatio\": " + toString(dashboard["currentMetrics"]["cacheHitRatio"]) + "\n"
  json = json + "}"
  json

fn exportMetricsToPrometheus(dashboard: PerformanceDashboard) -> Result<string, string>
  let prometheus = ""

  for metric in dashboard["metrics"]
    let labelsStr = "{"
    for labelKey in metric["labels"].keys()
      labelsStr = labelsStr + labelKey + "=\"" + metric["labels"][labelKey] + "\","
    labelsStr = labelsStr + "}"

    prometheus = prometheus + metric["name"] + labelsStr + " " + toString(metric["value"]) + "\n"

  Ok(prometheus)

fn getHealthScore(dashboard: PerformanceDashboard) -> number
  let score = 100

  let latency = dashboard["currentMetrics"]["requestLatency"]
  if latency > 1000 -> score = score - 30
  else if latency > 500 -> score = score - 20
  else if latency > 100 -> score = score - 10

  let errorRate = dashboard["currentMetrics"]["errorRate"]
  if errorRate > 5 -> score = score - 40
  else if errorRate > 1 -> score = score - 20

  let cpuUsage = dashboard["currentMetrics"]["cpuUsage"]
  if cpuUsage > 90 -> score = score - 20
  else if cpuUsage > 75 -> score = score - 10

  if score < 0 -> score = 0
  if score > 100 -> score = 100
  score

fn getDashboardReport(dashboard: PerformanceDashboard) -> string
  let report = "=== Performance Dashboard ===\n\n"
  report = report + "Request Latency (P99): " + toString(dashboard["currentMetrics"]["requestLatency"]) + "ms\n"
  report = report + "Throughput: " + toString(dashboard["currentMetrics"]["throughput"]) + " req/sec\n"
  report = report + "Error Rate: " + toString(dashboard["currentMetrics"]["errorRate"]) + "%\n"
  report = report + "CPU Usage: " + toString(dashboard["currentMetrics"]["cpuUsage"]) + "%\n"
  report = report + "Memory Usage: " + toString(dashboard["currentMetrics"]["memoryUsage"]) + "MB\n"
  report = report + "Cache Hit Ratio: " + toString(dashboard["currentMetrics"]["cacheHitRatio"]) + "%\n"
  report = report + "Health Score: " + toString(getHealthScore(dashboard)) + "/100\n"
  report

fn getCurrentTime() -> number
  1740998400
