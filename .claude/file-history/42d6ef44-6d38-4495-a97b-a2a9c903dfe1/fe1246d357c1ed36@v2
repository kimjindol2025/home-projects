// ============================================================================
// Core Data Structures
// ============================================================================

struct ContentPattern
  dataType: string      // "vector", "metadata", "query", "result"
  sizeRange: array<number>  // [min, max]
  frequencyHint: number  // 1-100
  affinity: array<number>  // preferred nodeIds
  timestamp: number

struct PathMetric
  nodeId: number
  nextNodeId: number
  latencyMs: f64
  successRate: f64
  bandwidthMbps: f64
  lastUpdated: number
  hopCount: number

struct RoutingDecision
  nextHop: number
  pathCost: f64
  estimatedLatencyMs: f64
  consensusRequired: bool
  cacheHint: string
  alternative: number  // Failover node
  confidence: f64

struct ContentRouter
  nodeId: number
  pathMetrics: map<string, PathMetric>
  contentPatterns: array<ContentPattern>
  routingTable: map<string, RoutingDecision>
  learningBuffer: array<ContentPattern>
  consensusState: number  // 0=IDLE, 1=VOTING, 2=COMMITTED
  stats: RouterStats

struct RouterStats
  routingDecisions: number
  cacheHits: number
  pathAdaptations: number
  failovers: number
  avgLatencyMs: f64
  successRate: f64

// ============================================================================
// Initialization
// ============================================================================

fn newContentRouter(nodeId: number) -> ContentRouter
  {
    "nodeId": nodeId,
    "pathMetrics": {},
    "contentPatterns": [],
    "routingTable": {},
    "learningBuffer": [],
    "consensusState": 0,
    "stats": {
      "routingDecisions": 0,
      "cacheHits": 0,
      "pathAdaptations": 0,
      "failovers": 0,
      "avgLatencyMs": 0.0,
      "successRate": 100.0
    }
  }

// ============================================================================
// Content Pattern Learning
// ============================================================================

fn recordContentAccess(router: ContentRouter, pattern: ContentPattern) -> ContentRouter
  router.contentPatterns.append(pattern)
  router.learningBuffer.append(pattern)

  // Maintain buffer size
  if router.learningBuffer.length() > 10000
    // Remove oldest
    var newBuffer = []
    for i = 1000 to router.learningBuffer.length()
      newBuffer.append(router.learningBuffer[i])
    router.learningBuffer = newBuffer

  router

fn learnTrafficPattern(router: ContentRouter) -> map<string, RoutingDecision>
  var patterns = {}

  // Analyze learning buffer
  for i = 0 to router.learningBuffer.length()
    let pattern = router.learningBuffer[i]
    let key = pattern.dataType + ":" + (pattern.sizeRange[0] as string)

    if patterns[key] == nil
      patterns[key] = {
        "nextHop": 0,
        "pathCost": 0.0,
        "estimatedLatencyMs": 0.0,
        "consensusRequired": false,
        "cacheHint": "default",
        "alternative": 0,
        "confidence": 0.0
      }

  patterns

// ============================================================================
// Path Selection & Metrics
// ============================================================================

fn selectOptimalPath(router: ContentRouter, content: ContentPattern) -> RoutingDecision
  router.stats["routingDecisions"] = (router.stats["routingDecisions"] as number) + 1

  // Step 1: Check if in routing table
  let key = content.dataType + ":" + (content.sizeRange[0] as string)
  let cached = router.routingTable[key]
  if cached != nil
    router.stats["cacheHits"] = (router.stats["cacheHits"] as number) + 1
    return cached

  // Step 2: Select best path from affinity list
  var bestPath = 0
  var bestCost = 999999.0

  for i = 0 to content.affinity.length()
    let nodeId = content.affinity[i]
    let metric = getPathMetric(router, router.nodeId, nodeId)
    if metric.successRate > 0.95 && metric.latencyMs < bestCost
      bestPath = nodeId
      bestCost = metric.latencyMs

  // Step 3: Determine if consensus needed
  let consensusNeeded = content.frequencyHint < 10

  let decision = {
    "nextHop": bestPath,
    "pathCost": bestCost,
    "estimatedLatencyMs": bestCost,
    "consensusRequired": consensusNeeded,
    "cacheHint": key,
    "alternative": 0,
    "confidence": 0.95
  }

  router.routingTable[key] = decision
  decision

fn getPathMetric(router: ContentRouter, fromNode: number, toNode: number) -> PathMetric
  let key = fromNode as string + "->" + toNode as string
  let metric = router.pathMetrics[key]

  if metric != nil
    return metric

  // Default metric if not found
  {
    "nodeId": fromNode,
    "nextNodeId": toNode,
    "latencyMs": 1.0,
    "successRate": 0.99,
    "bandwidthMbps": 1000.0,
    "lastUpdated": getCurrentTime(),
    "hopCount": 1
  }

fn updatePathMetrics(router: ContentRouter, fromNode: number, toNode: number, latency: f64, success: bool) -> ContentRouter
  let key = fromNode as string + "->" + toNode as string
  let currentMetric = router.pathMetrics[key]

  if currentMetric == nil
    router.pathMetrics[key] = {
      "nodeId": fromNode,
      "nextNodeId": toNode,
      "latencyMs": latency,
      "successRate": if success then 1.0 else 0.0,
      "bandwidthMbps": 1000.0,
      "lastUpdated": getCurrentTime(),
      "hopCount": 1
    }
  else
    // EMA update
    let oldLatency = currentMetric.latencyMs
    currentMetric.latencyMs = (0.3 * latency) + (0.7 * oldLatency)

    let oldSuccess = currentMetric.successRate
    let successVal = if success then 1.0 else 0.0
    currentMetric.successRate = (0.2 * successVal) + (0.8 * oldSuccess)

    currentMetric.lastUpdated = getCurrentTime()
    router.pathMetrics[key] = currentMetric

  // Update global stats
  let oldAvgLatency = router.stats["avgLatencyMs"] as f64
  router.stats["avgLatencyMs"] = (0.3 * latency) + (0.7 * oldAvgLatency)

  router.stats["pathAdaptations"] = (router.stats["pathAdaptations"] as number) + 1

  router

// ============================================================================
// Consensus Integration
// ============================================================================

fn prepareConsensusPacket(router: ContentRouter, decision: RoutingDecision) -> map<string, any>
  {
    "nodeId": router.nodeId,
    "nextHop": decision.nextHop,
    "pathCost": decision.pathCost,
    "timestamp": getCurrentTime(),
    "consensusRequired": decision.consensusRequired
  }

fn processConsensusVote(router: ContentRouter, vote: map<string, any>) -> bool
  // Simplified consensus: majority voting
  let agreement = vote["nextHop"] == vote["nextHop"]
  agreement

fn commitConsensusDecision(router: ContentRouter, decision: RoutingDecision) -> ContentRouter
  router.consensusState = 2  // COMMITTED
  decision

// ============================================================================
// Failover & Load Balancing
// ============================================================================

fn handlePathFailure(router: ContentRouter, failedNode: number) -> ContentRouter
  // Mark failed paths
  var keysToUpdate = []
  for key in router.pathMetrics
    let metric = router.pathMetrics[key]
    if metric.nextNodeId == failedNode
      metric.successRate = 0.0
      router.pathMetrics[key] = metric
      keysToUpdate.append(key)

  router.stats["failovers"] = (router.stats["failovers"] as number) + 1

  router

fn selectFailoverNode(router: ContentRouter, primaryNode: number, content: ContentPattern) -> number
  // Select alternative path
  for i = 0 to content.affinity.length()
    let candidate = content.affinity[i]
    if candidate != primaryNode
      let metric = getPathMetric(router, router.nodeId, candidate)
      if metric.successRate > 0.90
        return candidate

  0  // No suitable alternative

// ============================================================================
// Dynamic Rerouting
// ============================================================================

fn adaptivePathSelection(router: ContentRouter, content: ContentPattern) -> RoutingDecision
  let decision = selectOptimalPath(router, content)

  // Check if rerouting needed
  let metric = getPathMetric(router, router.nodeId, decision.nextHop)
  if metric.successRate < 0.85
    // Try failover
    let alternative = selectFailoverNode(router, decision.nextHop, content)
    if alternative != 0
      let altMetric = getPathMetric(router, router.nodeId, alternative)
      if altMetric.successRate > metric.successRate
        return {
          "nextHop": alternative,
          "pathCost": altMetric.latencyMs,
          "estimatedLatencyMs": altMetric.latencyMs,
          "consensusRequired": decision.consensusRequired,
          "cacheHint": decision.cacheHint,
          "alternative": decision.nextHop,
          "confidence": 0.85
        }

  decision

// ============================================================================
// Statistics & Monitoring
// ============================================================================

fn getRouterStats(router: ContentRouter) -> string
  var report = "=== CONTENT ROUTER STATS ===\n"
  report = report + "Node ID: " + router.nodeId as string + "\n"
  report = report + "Routing Decisions: " + (router.stats["routingDecisions"] as number) as string + "\n"
  report = report + "Cache Hits: " + (router.stats["cacheHits"] as number) as string + "\n"
  report = report + "Path Adaptations: " + (router.stats["pathAdaptations"] as number) as string + "\n"
  report = report + "Failovers: " + (router.stats["failovers"] as number) as string + "\n"
  report = report + "Avg Latency: " + (router.stats["avgLatencyMs"] as f64) as string + "ms\n"
  report = report + "Success Rate: " + (router.stats["successRate"] as f64) as string + "%\n"
  report = report + "Known Paths: " + (router.pathMetrics.length()) as string + "\n"
  report = report + "Cached Routes: " + (router.routingTable.length()) as string + "\n"
  report

fn getPathMetricsReport(router: ContentRouter) -> string
  var report = "=== PATH METRICS ===\n"

  var pathCount = 0
  for key in router.pathMetrics
    let metric = router.pathMetrics[key]
    report = report + key + ": " + (metric.latencyMs as f64) as string + "ms (success: " + (metric.successRate as f64) as string + ")\n"
    pathCount = pathCount + 1

    if pathCount > 10
      report = report + "... and " + ((router.pathMetrics.length()) - 10) as string + " more paths\n"
      break

  report

fn getCurrentTime() -> number
  1740998400

