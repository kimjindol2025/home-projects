fn testStackLeakDetection()
  // 스택 포인터가 원위치로 안 돌아옴
  var task = newTask(1, 10, 4096)
  task.registers.rsp = 1500.0
  task.stack.stackPointer = 1500.0

  let originalRsp = 1500.0
  let currentRsp = 1400.0  // 100바이트 누수!

  task.registers.rsp = currentRsp

  let report = detectStackLeak(task, originalRsp)

  // 누수 감지됨
  (report.stackLeakDetected) && (report.leakBytes == 100)

fn testZeroStackLeak()
  // 스택 포인터가 정확히 복원
  var task = newTask(1, 10, 4096)
  let originalRsp = 2000.0
  task.registers.rsp = originalRsp

  let report = detectStackLeak(task, originalRsp)

  // 누수 없음 (이상적)
  (!report.stackLeakDetected) && (report.leakBytes == 0)

fn testLargeStackLeak()
  // 심각한 스택 누수 (킬로바이트)
  var task = newTask(1, 10, 4096)
  task.stack.stackPointer = 3000.0

  let originalRsp = 3000.0
  task.registers.rsp = 1000.0  // 2000바이트 누수!

  let report = detectStackLeak(task, originalRsp)

  // 심각한 누수
  (report.stackLeakDetected) && (report.leakBytes == 2000) &&
  (report.severity == "CRITICAL")

