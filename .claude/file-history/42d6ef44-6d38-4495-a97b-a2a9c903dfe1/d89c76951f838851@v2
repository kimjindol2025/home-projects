  (scheduler.stats["registryDriftCount"] as number) == 0

fn testNestedInterruptsDuringSwitch()
  // 중첩 인터럽트 + 컨텍스트 스위치
  var scheduler = newScheduler()

  let task1 = newTask(1, 10, 4096)
  let task2 = newTask(2, 10, 4096)
  let task3 = newTask(3, 10, 4096)
  scheduler.tasks.append(task1)
  scheduler.tasks.append(task2)
  scheduler.tasks.append(task3)

  // 컨텍스트 스위치
  scheduler = contextSwitch(scheduler, 0, 1)

  // 스위치 중 인터럽트
  scheduler = handleInterruptDuringSwitch(scheduler, 32, 0, 1)

  // 다시 스위치
  scheduler = contextSwitch(scheduler, 1, 2)

  // 모든 레지스터/스택 무결성 보장
  (scheduler.stats["panicCount"] as number) == 0

fn testHighPriorityInterruptDuringSwitch()
  // 높은 우선순위 인터럽트 (0번 - CPU 예외)
  var scheduler = newScheduler()

  let task1 = newTask(1, 10, 4096)
  let task2 = newTask(2, 10, 4096)
  scheduler.tasks.append(task1)
  scheduler.tasks.append(task2)

  // CPU 예외 발생
  scheduler = handleInterruptDuringSwitch(scheduler, 0, 0, 1)  // Divide by zero

  // 무관용: 처리됨
  (scheduler.stats["registryDriftCount"] as number) == 0

