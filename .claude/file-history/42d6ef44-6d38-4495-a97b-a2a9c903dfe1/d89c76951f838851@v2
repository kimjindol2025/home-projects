// Group A: Basic Context Switch (3 tests)
// ============================================================================

fn testBasicContextSwitch()
  // 기본 컨텍스트 스위치 (인터럽트/Syscall 없음)
  var scheduler = newScheduler()

  // 2개 태스크 생성
  let task1 = newTask(1, 10, 4096)
  let task2 = newTask(2, 10, 4096)
  scheduler.tasks.append(task1)
  scheduler.tasks.append(task2)
  scheduler.readyQueue.append(2)

  // 스위치 전 레지스터 저장
  let savedRax = 100.0
  let savedRsp = 1000.0

  // 스위치 실행
  scheduler = contextSwitch(scheduler, 0, 1)

  // 무관용: 레지스터/스택 손상 없음
  (scheduler.stats["registryDriftCount"] as number) == 0 &&
  (scheduler.stats["stackLeakCount"] as number) == 0

fn testContextSwitchWithReturnValue()
  // 복원된 레지스터 값 검증
  var scheduler = newScheduler()

  let task1 = newTask(1, 10, 4096)
  let task2 = newTask(2, 10, 4096)
  scheduler.tasks.append(task1)
  scheduler.tasks.append(task2)

  // RAX에 특정 값 저장
  task2.registers.rax = 42.0
  task2.registers.rbx = 43.0
  task2.registers.rcx = 44.0
  scheduler.tasks[1] = task2

  // 복원
  let (newScheduler, restoredValue) = restoreContext(scheduler, 1)

  // 레지스터가 정확히 복원되어야 함 (무관용!)
  (newScheduler.tasks[1].registers.rax == 42.0)

fn testStackPointerRestoration()
  // 스택 포인터 복원 검증
  var scheduler = newScheduler()

  let task = newTask(1, 10, 4096)
  task.stack.stackPointer = 2000.0
  task.registers.rsp = 2000.0
  scheduler.tasks.append(task)

  // 검증: RSP가 정확히 복원됨
  let originalRsp = task.stack.stackPointer
  let isValid = validateStackPointerRestoration(originalRsp, scheduler.tasks[0].registers.rsp)

  isValid

