fn testConcurrentInterruptAndSyscall()
  // 동시에 인터럽트 + Syscall 발생!
  var scheduler = newScheduler()

  let task1 = newTask(1, 10, 4096)
  let task2 = newTask(2, 10, 4096)
  scheduler.tasks.append(task1)
  scheduler.tasks.append(task2)

  // 동시 이벤트
  scheduler = handleConcurrentEvents(scheduler, 0, 1, 32, 1)

  // 무관용: panic이 없어야 함
  (scheduler.stats["panicCount"] as number) == 0 &&
  (scheduler.stats["registryDriftCount"] as number) == 0

fn testOneThousandConcurrentEvents()
  // 1000번의 동시 이벤트 반복
  var scheduler = newScheduler()

  let task1 = newTask(1, 10, 4096)
  let task2 = newTask(2, 10, 4096)
  scheduler.tasks.append(task1)
  scheduler.tasks.append(task2)

  for i = 0 to 1000
    let interrupt = 32 + (i % 32)
    let syscall = i % 256
    scheduler = handleConcurrentEvents(scheduler, 0, 1, interrupt, syscall)

  // 1000번 모두 안전하게 처리
  (scheduler.stats["panicCount"] as number) == 0

fn testRapidFire1MicrosecondWindow()
  // 1μs 내 수십 개 이벤트
  var scheduler = newScheduler()

  let task1 = newTask(1, 10, 4096)
  let task2 = newTask(2, 10, 4096)
  scheduler.tasks.append(task1)
  scheduler.tasks.append(task2)

  // 10개 이벤트, 1μs 내
  for i = 0 to 10
    scheduler = handleConcurrentEvents(scheduler, 0, 1, 32 + i, i)

  (scheduler.stats["registryDriftCount"] as number) == 0 &&
  (scheduler.stats["stackLeakCount"] as number) == 0

