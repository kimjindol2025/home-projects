    "cs": 0.0, "ss": 0.0, "ds": 0.0, "es": 0.0, "fs": 0.0, "gs": 0.0,
    "registerHash": 0
  }

  let afterReg = {
    "rax": 101.0, "rbx": 200.0, "rcx": 300.0, "rdx": 400.0,
    "rsi": 500.0, "rdi": 600.0, "rbp": 700.0,
    "r8": 800.0, "r9": 900.0, "r10": 1000.0, "r11": 1100.0,
    "r12": 1200.0, "r13": 1300.0, "r14": 1400.0, "r15": 1500.0,
