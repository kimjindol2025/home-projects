fn testInterruptDuringSwitch()
  // 스위치 중 인터럽트 발생
  var scheduler = newScheduler()

  let task1 = newTask(1, 10, 4096)
  let task2 = newTask(2, 10, 4096)
  scheduler.tasks.append(task1)
  scheduler.tasks.append(task2)

  // 스위치 중 인터럽트
  scheduler = handleInterruptDuringSwitch(scheduler, 32, 0, 1)

  // 무관용: 스위치가 안전하게 완료됨
  (scheduler.stats["registryDriftCount"] as number) == 0 &&
  (scheduler.stats["stackLeakCount"] as number) == 0

fn testMultipleInterruptsDuringSwitch()
  // 스위치 중 여러 인터럽트 발생
  var scheduler = newScheduler()

  let task1 = newTask(1, 10, 4096)
  let task2 = newTask(2, 10, 4096)
  scheduler.tasks.append(task1)
  scheduler.tasks.append(task2)

  // 3개 인터럽트 동시 발생
  scheduler = handleInterruptDuringSwitch(scheduler, 32, 0, 1)
  scheduler = handleInterruptDuringSwitch(scheduler, 33, 0, 1)
  scheduler = handleInterruptDuringSwitch(scheduler, 34, 0, 1)

