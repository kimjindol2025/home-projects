fn testSyscallWithLargeData()
  // 대용량 데이터 전송하는 Syscall
  var scheduler = newScheduler()

  let task1 = newTask(1, 10, 8192)
  let task2 = newTask(2, 10, 8192)
  scheduler.tasks.append(task1)
  scheduler.tasks.append(task2)

  // 스택 사용량 증가
  task2.stack.stackUsed = 5000
  scheduler.tasks[1] = task2

  // Syscall
  scheduler = handleSyscallDuringSwitch(scheduler, 1, 0, 1)

  // 스택이 원위치로 복원
  (scheduler.stats["stackLeakCount"] as number) == 0

fn testSyscallWithSignalInterception()
  // Syscall 실행 중 시그널 전달
  var scheduler = newScheduler()

  let task = newTask(1, 10, 4096)
  scheduler.tasks.append(task)

  // Syscall 시작
  scheduler = handleSyscallDuringSwitch(scheduler, 1, 0, 0)

  // 즉시 인터럽트 (시그널)
  scheduler = handleInterruptDuringSwitch(scheduler, 32, 0, 0)

  (scheduler.stats["registryDriftCount"] as number) == 0

