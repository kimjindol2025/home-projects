struct AnomalyScore
  timestamp: number
  value: f64
  isAnomaly: bool
  confidence: f64
  method: string
  zScore: f64
  iqrScore: f64
  isolationScore: f64

struct IsolationTreeNode
  feature: number
  threshold: f64
  left: IsolationTreeNode | null
  right: IsolationTreeNode | null
  depth: number

struct IsolationForest
  trees: array<IsolationTreeNode>
  numTrees: number
  maxDepth: number
  anomalyThreshold: f64

// ============================================================================
// Z-Score Method
// ============================================================================

fn calculate_zscore(values: array<f64>) -> array<f64>
  if values.length() < 2
    return values

  // Calculate mean
  var sum = 0.0
  for i = 0 to values.length()
    sum = sum + values[i]

  let mean = sum / (values.length() as f64)

  // Calculate standard deviation
  var sum_sq = 0.0
  for i = 0 to values.length()
    let diff = values[i] - mean
    sum_sq = sum_sq + (diff * diff)

  let variance = sum_sq / ((values.length() - 1) as f64)
  let std_dev = variance  // Avoid sqrt for speed

  // Calculate z-scores
  var z_scores = []
  for i = 0 to values.length()
    let z = if std_dev > 0.0
      then (values[i] - mean) / std_dev
      else 0.0
    z_scores.append(z)

  z_scores

fn detect_zscore_anomalies(
  values: array<f64>,
  threshold: f64
) -> array<bool>
  let z_scores = calculate_zscore(values)

  var anomalies = []
  for i = 0 to z_scores.length()
    let is_anomaly = z_scores[i] > threshold || z_scores[i] < -threshold
    anomalies.append(is_anomaly)

  anomalies

// ============================================================================
// Percentile Calculation (for IQR)
// ============================================================================

fn find_percentile(
  values: array<f64>,
  percentile: f64
) -> f64
  if values.length() == 0
    return 0.0

  // Simple percentile: sort and interpolate
  var sorted = values

  // Bubble sort (simplified)
  for i = 0 to sorted.length()
    for j = i to sorted.length() - 1
      if sorted[j] < sorted[i]
        let temp = sorted[i]
        sorted[i] = sorted[j]
        sorted[j] = temp

  let index = ((percentile / 100.0) * (sorted.length() as f64)) as number
  if index >= sorted.length()
    index = sorted.length() - 1

  sorted[index]

// ============================================================================
// IQR (Interquartile Range) Method - Tukey's Fences
// ============================================================================

fn detect_iqr_anomalies(
  values: array<f64>
) -> array<bool>
  if values.length() < 4
    return []

  // Calculate Q1 (25th percentile)
  let q1 = find_percentile(values, 25.0)

  // Calculate Q3 (75th percentile)
  let q3 = find_percentile(values, 75.0)

  // Calculate IQR
  let iqr = q3 - q1

  // Tukey's fences
  let lower_fence = q1 - (1.5 * iqr)
  let upper_fence = q3 + (1.5 * iqr)

  // Detect anomalies
  var anomalies = []
  for i = 0 to values.length()
    let is_anomaly = values[i] < lower_fence || values[i] > upper_fence
    anomalies.append(is_anomaly)

  anomalies

// ============================================================================
// Isolation Forest - Build Tree
// ============================================================================

fn random_feature(
  num_features: number,
  seed: number
) -> number
  ((seed * 1664525 + 1013904223) % num_features)

fn random_threshold(
  feature_values: array<f64>,
  seed: number
) -> f64
  if feature_values.length() < 2
    return 0.5

  let min_val = feature_values[0]
  let max_val = feature_values[feature_values.length() - 1]

  let range = max_val - min_val
  if range == 0.0
    return min_val

  let normalized = ((seed * 1.0) % 100) / 100.0
  min_val + (normalized * range)

fn build_isolation_tree(
  data: array<array<f64>>,
  num_features: number,
  depth: number,
  max_depth: number,
  seed: number
) -> IsolationTreeNode
  // Base case: reached max depth or only 1 sample
  if depth >= max_depth || data.length() <= 1
    let leaf = {
      "feature": -1,
      "threshold": 0.0,
      "left": null,
      "right": null,
      "depth": depth
    }
    return leaf

  // Select random feature
  let feature = random_feature(num_features, seed)

  // Extract feature values
  var feature_values = []
  for i = 0 to data.length()
    feature_values.append(data[i][feature])

  // Select random threshold
  let threshold = random_threshold(feature_values, seed + 1)

  // Split data
  var left_data = []
  var right_data = []

  for i = 0 to data.length()
    if data[i][feature] < threshold
      left_data.append(data[i])
    else
      right_data.append(data[i])

  // Handle edge case where split is empty
  if left_data.length() == 0 || right_data.length() == 0
    let leaf = {
      "feature": -1,
      "threshold": 0.0,
      "left": null,
      "right": null,
      "depth": depth
    }
    return leaf

  // Recursively build subtrees
  let left_tree = build_isolation_tree(
    left_data, num_features, depth + 1, max_depth, seed + 10
  )

  let right_tree = build_isolation_tree(
    right_data, num_features, depth + 1, max_depth, seed + 20
  )

  let node = {
    "feature": feature,
    "threshold": threshold,
    "left": left_tree,
    "right": right_tree,
    "depth": depth
  }

  node

// ============================================================================
// Isolation Forest - Predict Anomaly Score
// ============================================================================

fn isolation_path_length(
  node: IsolationTreeNode,
  sample: array<f64>,
  depth: number
) -> number
  // Leaf node: return depth
  if node.feature == -1
    return depth

  // Internal node: recurse left or right
  if node.feature < sample.length()
    if sample[node.feature] < node.threshold
      if node.left != null
        return isolation_path_length(node.left, sample, depth + 1)
    else
      if node.right != null
        return isolation_path_length(node.right, sample, depth + 1)

  depth + 1

fn isolation_forest_anomaly_score(
  forest: IsolationForest,
  sample: array<f64>
) -> f64
  if forest.trees.length() == 0
    return 0.5

  // Get path lengths from all trees
  var path_lengths = []
  for t = 0 to forest.trees.length()
    let path_len = isolation_path_length(forest.trees[t], sample, 0)
    path_lengths.append(path_len)

  // Average path length
  var sum = 0.0
  for i = 0 to path_lengths.length()
    sum = sum + (path_lengths[i] as f64)

  let avg_path = sum / (path_lengths.length() as f64)

  // Anomaly score: shorter path = more anomalous
  // Normalized to [0, 1]
  let max_path = (forest.maxDepth as f64)
  let score = if max_path > 0.0
    then 1.0 - (avg_path / max_path)
    else 0.5

  score

fn train_isolation_forest(
  data: array<array<f64>>,
  num_trees: number,
  max_depth: number
) -> Result<IsolationForest, string>
  if data.length() == 0
    return Err("No data provided")

  let num_features = data[0].length()

  var trees = []

  // Build num_trees isolation trees
  for t = 0 to num_trees
    let tree = build_isolation_tree(data, num_features, 0, max_depth, t * 100)
    trees.append(tree)

  let forest = {
    "trees": trees,
    "numTrees": trees.length(),
    "maxDepth": max_depth,
    "anomalyThreshold": 0.5
  }

  Ok(forest)

// ============================================================================
// Ensemble Anomaly Detection (Combining 3 Methods)
// ============================================================================

fn ensemble_anomaly_detection(
  values: array<f64>,
  forest: IsolationForest,
  zscore_threshold: f64,
  iqr_enabled: bool
) -> Result<array<AnomalyScore>, string>
  if values.length() == 0
    return Ok([])

  // Method 1: Z-Score
  let z_scores = calculate_zscore(values)
  let zscore_anomalies = detect_zscore_anomalies(values, zscore_threshold)

  // Method 2: IQR
  var iqr_anomalies = []
  if iqr_enabled
    iqr_anomalies = detect_iqr_anomalies(values)

  // Method 3: Isolation Forest
  var iso_scores = []
  for i = 0 to values.length()
    let sample = [values[i]]
    let score = isolation_forest_anomaly_score(forest, sample)
    iso_scores.append(score)

  // Combine results
  var results = []
  for i = 0 to values.length()
    var vote_count = 0
    var confidence_sum = 0.0

    // Count votes
    if zscore_anomalies[i]
      vote_count = vote_count + 1
      confidence_sum = confidence_sum + 0.8

    if i < iqr_anomalies.length()
      if iqr_anomalies[i]
        vote_count = vote_count + 1
        confidence_sum = confidence_sum + 0.8

    if iso_scores[i] > forest.anomalyThreshold
      vote_count = vote_count + 1
      confidence_sum = confidence_sum + iso_scores[i]

    // Ensemble decision: >= 2/3 methods vote = anomaly
    let is_anomaly = vote_count >= 2

    let confidence = if vote_count > 0
      then confidence_sum / (vote_count as f64)
      else 0.0

    let score = {
      "timestamp": i,
      "value": values[i],
      "isAnomaly": is_anomaly,
      "confidence": confidence,
      "method": "ensemble",
      "zScore": z_scores[i],
      "iqrScore": if i < iqr_anomalies.length()
        then (if iqr_anomalies[i] then 1.0 else 0.0)
        else 0.0,
      "isolationScore": iso_scores[i]
    }

    results.append(score)

  Ok(results)

// ============================================================================
// Context-Based Adjustment
// ============================================================================

fn adjust_anomaly_threshold(
  base_threshold: f64,
  context: map<string, any>
) -> f64
  var adjusted = base_threshold

  // Deployment happening: relax threshold
  if context.contains("deploymentInProgress")
    if context["deploymentInProgress"]
      adjusted = adjusted + 0.1

  // Scaling in progress: relax threshold
  if context.contains("scalingInProgress")
    if context["scalingInProgress"]
      adjusted = adjusted + 0.08

  // Incident ongoing: relax threshold
  if context.contains("incidentHappening")
    if context["incidentHappening"]
      adjusted = adjusted + 0.05

  // Night time: tighten threshold
  if context.contains("timeOfDay")
    let hour = context["timeOfDay"]
    if (hour as number) < 6 || (hour as number) > 22
      adjusted = adjusted - 0.05

  // Ensure bounds
  if adjusted < 0.1
    adjusted = 0.1
  if adjusted > 0.9
    adjusted = 0.9

  adjusted

// ============================================================================
// Main Detection Function
// ============================================================================

fn detect_anomalies(
  metrics: array<f64>,
  forestModel: IsolationForest
) -> Result<array<AnomalyScore>, string>
  if metrics.length() < 3
    return Err("Insufficient data")

  let result = ensemble_anomaly_detection(metrics, forestModel, 3.0, true)
  result

