// ============================================================================
// Semantic Validator: Output Mismatch & Async Race Detection
// Unforgiving Differential Testing at Character-Level Precision
// 800 lines - Zero Tolerance for Semantic Drift
// ============================================================================

// ============================================================================
// Output Comparison Structures
// ============================================================================

struct OutputDiffReport
  outputMismatch: bool
  totalCharacters: number
  mismatchedCharacters: number
  mismatchPositions: array<number>
  expectedOutput: string
  actualOutput: string
  severity: string      // "NONE", "WARNING", "CRITICAL"

struct AsyncRaceReport
  raceDetected: bool
  sharedVariables: array<string>
  racyOperations: array<string>
  raceLocations: array<number>
  severity: string      // "NONE", "LOW", "MEDIUM", "HIGH", "CRITICAL"

struct DifferentialTestReport
  outputDiff: OutputDiffReport
  asyncRace: AsyncRaceReport
  semanticsPreserved: bool
  score: number         // 0 or 1 (무관용!)

// ============================================================================
// Character-Level Output Comparison
// ============================================================================

fn compareOutputCharacterByCharacter(
  expected: string,
  actual: string
) -> OutputDiffReport
  var mismatchedCount = 0
  var mismatchPositions = []

  // 무관용: 길이가 다르면 이미 실패
  if expected.length() != actual.length()
    return {
      "outputMismatch": true,
      "totalCharacters": if expected.length() > actual.length() then expected.length() else actual.length(),
      "mismatchedCharacters": (expected.length() as number) - (actual.length() as number),
      "mismatchPositions": [0],  // 첫 번째에서 실패
      "expectedOutput": expected,
      "actualOutput": actual,
      "severity": "CRITICAL"
    }

  // 문자 단위 비교
  for i = 0 to expected.length()
    let expectedChar = expected.substring(i, 1)
    let actualChar = actual.substring(i, 1)

    if expectedChar != actualChar
      mismatchedCount = mismatchedCount + 1
      mismatchPositions.append(i)

  let hasMismatch = mismatchedCount > 0

  {
    "outputMismatch": hasMismatch,
    "totalCharacters": expected.length(),
    "mismatchedCharacters": mismatchedCount,
    "mismatchPositions": mismatchPositions,
    "expectedOutput": expected,
    "actualOutput": actual,
    "severity": if hasMismatch then "CRITICAL" else "NONE"
  }

// ============================================================================
// Output Stream Comparison (무관용!)
// ============================================================================

fn compareOutputStreams(
  expectedStream: array<string>,
  actualStream: array<string>
) -> OutputDiffReport
  // 무관용: 모든 항목이 일치해야 함

  if expectedStream.length() != actualStream.length()
    return {
      "outputMismatch": true,
      "totalCharacters": expectedStream.length(),
      "mismatchedCharacters": (expectedStream.length() as number) - (actualStream.length() as number),
      "mismatchPositions": [0],
      "expectedOutput": "Stream length mismatch",
      "actualOutput": "",
      "severity": "CRITICAL"
    }

  var mismatchCount = 0
  var mismatchIndices = []

  for i = 0 to expectedStream.length()
    if expectedStream[i] != actualStream[i]
      mismatchCount = mismatchCount + 1
      mismatchIndices.append(i)

  {
    "outputMismatch": (mismatchCount > 0),
    "totalCharacters": expectedStream.length(),
    "mismatchedCharacters": mismatchCount,
    "mismatchPositions": mismatchIndices,
    "expectedOutput": "Stream items: " + expectedStream.length() as string,
    "actualOutput": "Stream items: " + actualStream.length() as string,
    "severity": if mismatchCount > 0 then "CRITICAL" else "NONE"
  }

// ============================================================================
// Async Race Condition Detection
// ============================================================================

fn detectAsyncRaces(
  spawnTasks: array<SpawnTask>,
  globalVariables: array<string>
) -> AsyncRaceReport
  // 무관용: 데이터 레이스 감지

  var racyOperations = []
  var sharedVars = []
  var raceLocations = []

  // 각 spawn task의 공유 변수 분석
  for i = 0 to spawnTasks.length()
    let task = spawnTasks[i]

    // 태스크가 전역 변수에 접근?
    for j = 0 to globalVariables.length()
      let varName = globalVariables[j]

      // 간단한 휴리스틱: 변수 이름이 코드에 포함?
      if task.code.contains(varName) || task.code.contains(varName + " =")
        sharedVars.append(varName)
        racyOperations.append("Task " + (i as string) + " accesses " + varName)
        raceLocations.append(i)

  let hasRace = sharedVars.length() > 0

  {
    "raceDetected": hasRace,
    "sharedVariables": sharedVars,
    "racyOperations": racyOperations,
    "raceLocations": raceLocations,
    "severity": if hasRace then "HIGH" else "NONE"
  }

// ============================================================================
// Variable Synchronization Check
// ============================================================================

fn checkVariableSynchronization(
  spawnTasks: array<SpawnTask>,
  locks: array<string>
) -> bool
  // 무관용: 모든 공유 변수가 동기화되어야 함

  for i = 0 to spawnTasks.length()
    let task = spawnTasks[i]

    // 뮤텍스나 lock이 사용되어야 함
    let hasSynchronization = false
    for j = 0 to locks.length()
      if task.code.contains("lock(" + locks[j] + ")")
        hasSynchronization = true

    if !hasSynchronization && task.outputStreams.length() > 0
      return false  // 공유 변수에 접근하는데 동기화 없음 = RACE!

  true

// ============================================================================
// Semantic Preservation Validation
// ============================================================================

fn validateSemanticPreservation(
  freeLangOutput: string,
  zLangOutput: string,
  expectedOutputs: array<string>,
  actualOutputs: array<string>
) -> DifferentialTestReport
  // 무관용: 의미가 완벽하게 보존되어야 함

  // Step 1: 출력 비교 (문자 단위)
  let outputDiff = compareOutputCharacterByCharacter(freeLangOutput, zLangOutput)

  // Step 2: 출력 스트림 비교
  let streamDiff = compareOutputStreams(expectedOutputs, actualOutputs)

  // Step 3: 비동기 레이스 (나중에 spawnTasks 사용)
  let asyncRace = {
    "raceDetected": false,
    "sharedVariables": [],
    "racyOperations": [],
    "raceLocations": [],
    "severity": "NONE"
  }

  // 최종 검증: 어느 것도 실패하면 안 됨 (무관용!)
  let semanticsPreserved = (!outputDiff.outputMismatch) && (!streamDiff.outputMismatch) && (!asyncRace.raceDetected)

  {
    "outputDiff": outputDiff,
    "asyncRace": asyncRace,
    "semanticsPreserved": semanticsPreserved,
    "score": if semanticsPreserved then 1 else 0  // 0 or 1!
  }

// ============================================================================
// Differential Testing Framework
// ============================================================================

struct DifferentialTest
  testId: number
  freeLangCode: string
  expectedOutput: string
  expectedStream: array<string>
  zLangCode: string
  actualOutput: string
  actualStream: array<string>
  passed: bool

fn runDifferentialTest(test: DifferentialTest) -> tuple<DifferentialTest, DifferentialTestReport>
  // 미분 테스트: FreeLang vs Z-Lang 실행 결과 비교

  // Step 1: 예상 vs 실제 출력 비교
  let report = validateSemanticPreservation(
    test.expectedOutput,
    test.actualOutput,
    test.expectedStream,
    test.actualStream
  )

  // Step 2: 결과 업데이트
  test.passed = report.semanticsPreserved

  (test, report)

// ============================================================================
// Batch Testing (5,000줄 코드)
// ============================================================================

fn runBatchDifferentialTests(
  tests: array<DifferentialTest>
) -> tuple<array<DifferentialTest>, number>
  // 여러 테스트를 순차적으로 실행
  var passedCount = 0
  var updatedTests = []

  for i = 0 to tests.length()
    let test = tests[i]
    let (updatedTest, report) = runDifferentialTest(test)

    if updatedTest.passed
      passedCount = passedCount + 1

    updatedTests.append(updatedTest)

  (updatedTests, passedCount)

// ============================================================================
// Report Generation
// ============================================================================

fn generateDifferentialTestReport(
  report: DifferentialTestReport
) -> string
  var output = "=== SEMANTIC PRESERVATION TEST REPORT ===\\n"
  output = output + "\\n--- Output Mismatch ---\\n"
  output = output + "Mismatch Detected: " + if report.outputDiff.outputMismatch then "YES ❌" else "NO ✓" + "\\n"

  if report.outputDiff.outputMismatch
    output = output + "Total Characters: " + (report.outputDiff.totalCharacters as string) + "\\n"
    output = output + "Mismatched Characters: " + (report.outputDiff.mismatchedCharacters as string) + "\\n"
    output = output + "Mismatch Positions: " + (report.outputDiff.mismatchPositions.length() as string) + "\\n"

  output = output + "Severity: " + report.outputDiff.severity + "\\n"
  output = output + "\\n--- Async Race ---\\n"
  output = output + "Race Detected: " + if report.asyncRace.raceDetected then "YES ❌" else "NO ✓" + "\\n"

  if report.asyncRace.raceDetected
    output = output + "Shared Variables: " + (report.asyncRace.sharedVariables.length() as string) + "\\n"
    output = output + "Racy Operations: " + (report.asyncRace.racyOperations.length() as string) + "\\n"

  output = output + "Severity: " + report.asyncRace.severity + "\\n"
  output = output + "\\n--- Overall Result ---\\n"
  output = output + "Semantics Preserved: " + if report.semanticsPreserved then "YES ✓" else "NO ❌" + "\\n"
  output = output + "Score: " + (report.score as string) + " (0 or 1, no middle!)\\n"

  output

fn generateBatchTestReport(
  tests: array<DifferentialTest>,
  passedCount: number
) -> string
  var report = "=== BATCH DIFFERENTIAL TEST REPORT ===\\n"
  report = report + "Total Tests: " + (tests.length() as string) + "\\n"
  report = report + "Passed: " + (passedCount as string) + "\\n"
  report = report + "Failed: " + ((tests.length() as number) - passedCount as string) + "\\n"

  let passRate = (passedCount as f64) / (tests.length() as f64)
  report = report + "Pass Rate: " + (passRate as string) + " (" + (passRate * 100.0 as number as string) + "%)\\n"

  // 무관용: 100%이어야 함!
  if passRate < 1.0
    report = report + "❌ FAILED - Not all tests passed!\\n"
  else
    report = report + "✓ PASSED - All tests preserved semantics!\\n"

  report
