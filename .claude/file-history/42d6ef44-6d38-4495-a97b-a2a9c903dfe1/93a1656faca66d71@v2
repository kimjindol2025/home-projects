struct DecisionTreeNode
  feature: string
  threshold: f64
  left: DecisionTreeNode | null
  right: DecisionTreeNode | null
  value: string
  isLeaf: bool

struct RandomForestEnsemble
  trees: array<DecisionTreeNode>
  numTrees: number
  numFeatures: number
  oobError: f64
  featureImportance: map<string, f64>
  outOfBagSamples: array<array<number>>

struct BootstrapSample
  indices: array<number>
  outOfBagIndices: array<number>

// ============================================================================
// Random Sampling
// ============================================================================

fn random_number(seed: number) -> number
  ((seed * 1103515245 + 12345) % 2147483648) / 2147483648.0

fn bootstrap_sample(
  n: number,
  seed: number
) -> Result<BootstrapSample, string>
  if n <= 0
    return Err("Invalid sample size")

  var sampled_indices = []
  var in_sample = []

  // Initialize in_sample array
  for i = 0 to n
    in_sample.append(false)

  // Sample with replacement (approximately 63.2% unique samples)
  for i = 0 to n
    let r = random_number(seed + i)
    let idx = ((r * (n as f64)) as number) % n
    sampled_indices.append(idx)
    in_sample[idx] = true

  // Collect out-of-bag indices
  var oob_indices = []
  for i = 0 to n
    if !in_sample[i]
      oob_indices.append(i)

  let bootstrap = {
    "indices": sampled_indices,
    "outOfBagIndices": oob_indices
  }

  Ok(bootstrap)

// ============================================================================
// Feature Subsampling (Random Subset Selection)
// ============================================================================

fn random_feature_subset(
  allFeatures: array<string>,
  mtry: number
) -> array<string>
  if mtry >= allFeatures.length()
    return allFeatures

  var subset = []
  var used = []

  for i = 0 to mtry
    // Simplified: take first mtry features
    if i < allFeatures.length()
      subset.append(allFeatures[i])

  subset

fn calculate_mtry(numFeatures: number) -> number
  // For classification: mtry = sqrt(p)
  // For regression: mtry = p/3
  let mtry_sqrt = 1
  if numFeatures > 1
    mtry_sqrt = numFeatures / 2  // Simplified sqrt

  mtry_sqrt

// ============================================================================
// Tree Building for Forest
// ============================================================================

fn build_forest_tree(
  samples: array<map<string, any>>,
  features: array<string>,
  depth: number,
  max_depth: number
) -> DecisionTreeNode
  // Base case: pure node or max depth
  if samples.length() == 0 || depth >= max_depth
    let leaf = {
      "feature": "leaf",
      "threshold": 0.0,
      "left": null,
      "right": null,
      "value": "default",
      "isLeaf": true
    }
    return leaf

  // Check if pure
  var labels = []
  for i = 0 to samples.length()
    labels.append(samples[i]["label"])

  var all_same = true
  if labels.length() > 0
    let first = labels[0]
    for i = 1 to labels.length()
      if labels[i] != first
        all_same = false
        break

  if all_same
    let leaf = {
      "feature": "leaf",
      "threshold": 0.0,
      "left": null,
      "right": null,
      "value": if labels.length() > 0 then labels[0] else "unknown",
      "isLeaf": true
    }
    return leaf

  // Select random feature subset
  let mtry = calculate_mtry(features.length())
  let feature_subset = random_feature_subset(features, mtry)

  // Find best split
  var best_feature = ""
  var best_threshold = 0.0
  var left_samples = []
  var right_samples = []

  if feature_subset.length() > 0
    best_feature = feature_subset[0]

    // Try different thresholds
    for t = 0 to 5
      let threshold = ((t as f64) * 0.2) + 0.1

      // Split
      for i = 0 to samples.length()
        let sample = samples[i]
        if sample.contains(best_feature)
          let value = sample[best_feature]
          if (value as f64) < threshold
            left_samples.append(sample)
          else
            right_samples.append(sample)

      if left_samples.length() > 0 && right_samples.length() > 0
        best_threshold = threshold
        break

  // Recursively build subtrees
  var left_node = null
  var right_node = null

  if left_samples.length() > 0
    left_node = build_forest_tree(left_samples, feature_subset, depth + 1, max_depth)
  if right_samples.length() > 0
    right_node = build_forest_tree(right_samples, feature_subset, depth + 1, max_depth)

  let internal_node = {
    "feature": best_feature,
    "threshold": best_threshold,
    "left": left_node,
    "right": right_node,
    "value": "",
    "isLeaf": false
  }

  internal_node

// ============================================================================
// Forest Training
// ============================================================================

fn train_random_forest(
  training_samples: array<map<string, any>>,
  features: array<string>,
  numTrees: number,
  maxDepth: number
) -> Result<RandomForestEnsemble, string>
  if training_samples.length() == 0
    return Err("No training samples")

  var trees = []
  var oob_samples = []

  // Build numTrees trees
  for t = 0 to numTrees
    let bootstrapResult = bootstrap_sample(training_samples.length(), t)

    match bootstrapResult
      Ok(bootstrap) ->
        // Create bootstrap sample
        var bootstrap_data = []
        for idx = 0 to bootstrap.indices.length()
          let i = bootstrap.indices[idx]
          if i < training_samples.length()
            bootstrap_data.append(training_samples[i])

        // Build tree
        let tree = build_forest_tree(bootstrap_data, features, 0, maxDepth)
        trees.append(tree)
        oob_samples.append(bootstrap.outOfBagIndices)

      Err(e) ->
        ()

  let forest = {
    "trees": trees,
    "numTrees": trees.length(),
    "numFeatures": features.length(),
    "oobError": 0.0,
    "featureImportance": {},
    "outOfBagSamples": oob_samples
  }

  Ok(forest)

// ============================================================================
// Tree Prediction
// ============================================================================

fn predict_sample_in_tree(node: DecisionTreeNode, sample: map<string, any>) -> string
  if node.isLeaf
    return node.value

  if sample.contains(node.feature)
    let value = sample[node.feature]
    if (value as f64) < node.threshold
      if node.left != null
        return predict_sample_in_tree(node.left, sample)
    else
      if node.right != null
        return predict_sample_in_tree(node.right, sample)

  node.value

// ============================================================================
// Forest Prediction (Majority Voting)
// ============================================================================

fn predict_forest(
  forest: RandomForestEnsemble,
  samples: array<map<string, any>>
) -> array<string>
  var predictions = []

  for i = 0 to samples.length()
    var votes = {}

    // Get prediction from each tree
    for t = 0 to forest.trees.length()
      let pred = predict_sample_in_tree(forest.trees[t], samples[i])

      if votes.contains(pred)
        votes[pred] = votes[pred] + 1
      else
        votes[pred] = 1

    // Majority vote
    var best_label = ""
    var max_votes = 0

    for label in votes
      let vote_count = votes[label]
      if vote_count > max_votes
        max_votes = vote_count
        best_label = label

    predictions.append(best_label)

  predictions

// ============================================================================
// Out-of-Bag Error Estimation
// ============================================================================

fn estimate_oob_error(
  forest: RandomForestEnsemble,
  training_samples: array<map<string, any>>
) -> Result<f64, string>
  if training_samples.length() == 0
    return Ok(0.0)

  var oob_predictions = []
  var oob_votes = []

  // Initialize vote arrays
  for i = 0 to training_samples.length()
    oob_votes.append({})

  // For each tree
  for t = 0 to forest.trees.length()
    let oob_indices = forest.outOfBagSamples[t]

    // Predict OOB samples
    for idx_pos = 0 to oob_indices.length()
      let i = oob_indices[idx_pos]

      if i < training_samples.length()
        let pred = predict_sample_in_tree(forest.trees[t], training_samples[i])

        // Add vote
        let votes = oob_votes[i]
        if votes.contains(pred)
          votes[pred] = votes[pred] + 1
        else
          votes[pred] = 1

  // Calculate OOB error
  var correct = 0
  var total = 0

  for i = 0 to training_samples.length()
    let votes = oob_votes[i]

    // Find majority vote
    if votes.length() > 0
      var best_label = ""
      var max_votes = 0

      for label in votes
        let count = votes[label]
        if count > max_votes
          max_votes = count
          best_label = label

      if best_label == training_samples[i]["label"]
        correct = correct + 1

      total = total + 1

  let oob_error = if total > 0
    then 1.0 - ((correct as f64) / (total as f64))
    else 0.0

  Ok(oob_error)

// ============================================================================
// Feature Importance (Mean Decrease in Impurity)
// ============================================================================

fn calculate_feature_importance(forest: RandomForestEnsemble) -> map<string, f64>
  var importance = {}

  // Aggregate importance across trees
  for t = 0 to forest.trees.length()
    let tree_importance = tree_feature_importance(forest.trees[t])

    for feature in tree_importance
      if importance.contains(feature)
        importance[feature] = importance[feature] + tree_importance[feature]
      else
        importance[feature] = tree_importance[feature]

  // Normalize by number of trees
  for feature in importance
    importance[feature] = importance[feature] / (forest.numTrees as f64)

  importance

fn tree_feature_importance(node: DecisionTreeNode) -> map<string, f64>
  var importance = {}

  fn dfs(n: DecisionTreeNode)
    if !n.isLeaf
      // Add importance for this feature's split
      if importance.contains(n.feature)
        importance[n.feature] = importance[n.feature] + 1.0
      else
        importance[n.feature] = 1.0

      if n.left != null
        dfs(n.left)
      if n.right != null
        dfs(n.right)

  dfs(node)
  importance

// ============================================================================
// Evaluation
// ============================================================================

fn evaluate_forest(
  forest: RandomForestEnsemble,
  test_samples: array<map<string, any>>
) -> Result<f64, string>
  let predictions = predict_forest(forest, test_samples)

  var correct = 0
  for i = 0 to test_samples.length()
    if i < predictions.length()
      if predictions[i] == test_samples[i]["label"]
        correct = correct + 1

  let accuracy = (correct as f64) / (test_samples.length() as f64)
  Ok(accuracy)

