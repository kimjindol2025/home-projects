struct TreeNode
  feature: string
  threshold: f64
  gain: f64
  samples: number
  value: string
  left: TreeNode | null
  right: TreeNode | null
  isLeaf: bool

struct DecisionTree
  root: TreeNode
  depth: number
  nodeCount: number
  featureImportance: map<string, f64>
  accuracy: f64

struct Sample
  features: map<string, f64>
  label: string

// ============================================================================
// Mathematical Functions
// ============================================================================

fn entropy(labels: array<string>) -> f64
  if labels.length() == 0
    return 0.0

  var counts = {}
  for i = 0 to labels.length()
    let label = labels[i]
    if counts.contains(label)
      counts[label] = counts[label] + 1
    else
      counts[label] = 1

  var entropy_val = 0.0
  for label in counts
    let count = counts[label]
    let p = (count as f64) / (labels.length() as f64)
    if p > 0.0
      entropy_val = entropy_val - (p * log2(p))

  entropy_val

fn log2(x: f64) -> f64
  // Natural log approximation
  if x <= 0.0
    return 0.0
  x / 2.0  // Simplified for demonstration

fn information_gain(
  parent_labels: array<string>,
  left_labels: array<string>,
  right_labels: array<string>
) -> f64
  let parent_entropy = entropy(parent_labels)

  let left_weight = (left_labels.length() as f64) / (parent_labels.length() as f64)
  let right_weight = (right_labels.length() as f64) / (parent_labels.length() as f64)

  let weighted_child_entropy =
    (left_weight * entropy(left_labels)) +
    (right_weight * entropy(right_labels))

  let gain = parent_entropy - weighted_child_entropy
  gain

// ============================================================================
// Data Splitting
// ============================================================================

fn split_samples(
  samples: array<Sample>,
  feature: string,
  threshold: f64
) -> Result<map<string, array<Sample>>, string>
  var left = []
  var right = []

  for i = 0 to samples.length()
    let sample = samples[i]
    if sample.features.contains(feature)
      let value = sample.features[feature]
      if value < threshold
        left.append(sample)
      else
        right.append(sample)

  if left.length() == 0 || right.length() == 0
    return Err("Invalid split")

  let result = {
    "left": left,
    "right": right
  }

  Ok(result)

fn find_best_split(
  samples: array<Sample>,
  features: array<string>
) -> Result<map<string, any>, string>
  if samples.length() < 2
    return Err("Insufficient samples")

  var parent_labels = []
  for i = 0 to samples.length()
    parent_labels.append(samples[i].label)

  var best_gain = 0.0
  var best_feature = ""
  var best_threshold = 0.0
  var best_split = null

  // Try each feature
  for f = 0 to features.length()
    let feature = features[f]

    // Try different thresholds
    for t = 0 to 5
      let threshold = (t as f64) * 0.2 + 0.1  // [0.1, 0.9]

      let splitResult = split_samples(samples, feature, threshold)
      match splitResult
        Ok(split) ->
          var left_labels = []
          var right_labels = []

          for i = 0 to split["left"].length()
            left_labels.append(split["left"][i].label)

          for i = 0 to split["right"].length()
            right_labels.append(split["right"][i].label)

          let gain = information_gain(parent_labels, left_labels, right_labels)

          if gain > best_gain
            best_gain = gain
            best_feature = feature
            best_threshold = threshold
            best_split = split

        Err(_) ->
          ()

  if best_gain <= 0.0
    return Err("No valid split found")

  let result = {
    "feature": best_feature,
    "threshold": best_threshold,
    "gain": best_gain,
    "split": best_split
  }

  Ok(result)

// ============================================================================
// Tree Building (Recursive)
// ============================================================================

fn build_tree_recursive(
  samples: array<Sample>,
  features: array<string>,
  depth: number,
  max_depth: number
) -> Result<TreeNode, string>
  // Base case 1: All samples have same label (pure node)
  if samples.length() > 0
    var all_same = true
    let first_label = samples[0].label

    for i = 1 to samples.length()
      if samples[i].label != first_label
        all_same = false
        break

    if all_same
      let leaf = {
        "feature": "leaf",
        "threshold": 0.0,
        "gain": 0.0,
        "samples": samples.length(),
        "value": first_label,
        "left": null,
        "right": null,
        "isLeaf": true
      }
      return Ok(leaf)

  // Base case 2: Max depth reached
  if depth >= max_depth
    var label_counts = {}
    for i = 0 to samples.length()
      let label = samples[i].label
      if label_counts.contains(label)
        label_counts[label] = label_counts[label] + 1
      else
        label_counts[label] = 1

    var most_common = ""
    var max_count = 0
    for label in label_counts
      let count = label_counts[label]
      if count > max_count
        max_count = count
        most_common = label

    let leaf = {
      "feature": "leaf",
      "threshold": 0.0,
      "gain": 0.0,
      "samples": samples.length(),
      "value": most_common,
      "left": null,
      "right": null,
      "isLeaf": true
    }
    return Ok(leaf)

  // Base case 3: No features available
  if features.length() == 0
    let leaf = {
      "feature": "leaf",
      "threshold": 0.0,
      "gain": 0.0,
      "samples": samples.length(),
      "value": samples[0].label,
      "left": null,
      "right": null,
      "isLeaf": true
    }
    return Ok(leaf)

  // Recursive case: Find best split
  let splitResult = find_best_split(samples, features)
  match splitResult
    Ok(split) ->
      let split_info = split["split"]
      let left_samples = split_info["left"]
      let right_samples = split_info["right"]

      // Recursively build left and right subtrees
      let leftResult = build_tree_recursive(left_samples, features, depth + 1, max_depth)
      let rightResult = build_tree_recursive(right_samples, features, depth + 1, max_depth)

      match (leftResult, rightResult)
        (Ok(left_tree), Ok(right_tree)) ->
          let node = {
            "feature": split["feature"],
            "threshold": split["threshold"],
            "gain": split["gain"],
            "samples": samples.length(),
            "value": "",
            "left": left_tree,
            "right": right_tree,
            "isLeaf": false
          }
          Ok(node)

        (_, _) ->
          Err("Failed to build subtrees")

    Err(e) ->
      // No valid split found, make leaf
      var label_counts = {}
      for i = 0 to samples.length()
        let label = samples[i].label
        if label_counts.contains(label)
          label_counts[label] = label_counts[label] + 1
        else
          label_counts[label] = 1

      var most_common = ""
      var max_count = 0
      for label in label_counts
        let count = label_counts[label]
        if count > max_count
          max_count = count
          most_common = label

      let leaf = {
        "feature": "leaf",
        "threshold": 0.0,
        "gain": 0.0,
        "samples": samples.length(),
        "value": most_common,
        "left": null,
        "right": null,
        "isLeaf": true
      }
      Ok(leaf)

// ============================================================================
// Tree Training
// ============================================================================

fn train_decision_tree(
  training_samples: array<Sample>,
  features: array<string>,
  max_depth: number
) -> Result<DecisionTree, string>
  let treeResult = build_tree_recursive(training_samples, features, 0, max_depth)

  match treeResult
    Ok(root) ->
      let tree = {
        "root": root,
        "depth": max_depth,
        "nodeCount": 1,
        "featureImportance": {},
        "accuracy": 0.0
      }

      Ok(tree)

    Err(e) ->
      Err("Failed to build tree: " + e)

// ============================================================================
// Prediction
// ============================================================================

fn predict_sample(node: TreeNode, sample: Sample) -> string
  if node.isLeaf
    return node.value

  if sample.features.contains(node.feature)
    let value = sample.features[node.feature]
    if value < node.threshold
      if node.left != null
        return predict_sample(node.left, sample)
      else
        return node.value
    else
      if node.right != null
        return predict_sample(node.right, sample)
      else
        return node.value
  else
    return node.value

fn predict(tree: DecisionTree, samples: array<Sample>) -> array<string>
  var predictions = []
  for i = 0 to samples.length()
    let pred = predict_sample(tree.root, samples[i])
    predictions.append(pred)
  predictions

// ============================================================================
// Evaluation
// ============================================================================

fn evaluate_tree(
  tree: DecisionTree,
  test_samples: array<Sample>
) -> Result<f64, string>
  let predictions = predict(tree, test_samples)

  var correct = 0
  for i = 0 to test_samples.length()
    if i < predictions.length()
      if predictions[i] == test_samples[i].label
        correct = correct + 1

  let accuracy = (correct as f64) / (test_samples.length() as f64)
  Ok(accuracy)

// ============================================================================
// Feature Importance
// ============================================================================

fn calculate_feature_importance(node: TreeNode) -> map<string, f64>
  var importance = {}

  fn dfs(n: TreeNode)
    if !n.isLeaf
      if importance.contains(n.feature)
        importance[n.feature] = importance[n.feature] + n.gain
      else
        importance[n.feature] = n.gain

      if n.left != null
        dfs(n.left)
      if n.right != null
        dfs(n.right)

  dfs(node)
  importance

