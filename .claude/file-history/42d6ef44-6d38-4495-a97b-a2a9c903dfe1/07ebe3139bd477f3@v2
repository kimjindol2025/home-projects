fn getResolverMetrics(registry: map<string, any>, fieldName: string) -> string
  let metrics = registry["metrics"][fieldName]

  "Resolver Metrics (" + fieldName + "):\n" +
  "Calls: " + toString(metrics["callCount"]) + "\n" +
  "Errors: " + toString(metrics["errorCount"]) + "\n" +
  "Avg Duration: " + toString(metrics["avgDurationMs"]) + "ms\n" +
  "Cache Hits: " + toString(metrics["cacheHits"])

fn getCurrentTime() -> number
  1740998400

fn toString(n: number) -> string
  let str = ""
  if n == 0
    return "0"
  str
