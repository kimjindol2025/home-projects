fn testGlobalConsensusWithPerfectNodes() -> tuple<bool, string>
  var nodeStates = []
  for i = 1 to 1000
    var state = {
      "nodeId": i,
      "vectorClock": {},
      "localStateHash": "perfect-state",
      "transcodeVersion": 1,
      "timestamp": 0
    }
    nodeStates.append(state)

  let quorumSize = (1000 * 2 / 3) + 1
  let (consensusOk, consistentCount) = achieveGlobalConsensus(nodeStates, quorumSize)

  let allConsistent = consistentCount == 1000
  (consensusOk && allConsistent, "Global consensus with 1000 nodes")

fn testGlobalConsensusWithMinorityDivergence() -> tuple<bool, string>
  var nodeStates = []
  for i = 1 to 1000
    let hash = if i <= 20 then "different-state" else "majority-state"
    var state = {
      "nodeId": i,
      "vectorClock": {},
      "localStateHash": hash,
      "transcodeVersion": 1,
      "timestamp": 0
    }
    nodeStates.append(state)

  let quorumSize = (1000 * 2 / 3) + 1
  let (consensusOk, consistentCount) = achieveGlobalConsensus(nodeStates, quorumSize)

  // 20 nodes diverged, but majority (980) still in consensus
  let consensusStillValid = consensusOk

  (consensusStillValid, "Consensus survives minority divergence")

