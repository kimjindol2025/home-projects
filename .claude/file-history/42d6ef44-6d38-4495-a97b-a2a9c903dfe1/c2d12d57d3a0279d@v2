fn testEscalationOnFailure()
  // Setup
  let engine = newAutoRemediationEngine()

  let action = {
    "actionId": "action_1",
    "name": "restartDatabase",
    "parameters": {},
    "preconditions": ["alwaysFails"],
    "expectedEffectMs": 5000,
    "riskLevel": "HIGH"
  }

  let result = executeRemediationAction(engine, action)

  match result
    Ok(_) ->
      ()
    Err(_) ->
      let escalateResult = escalateToHuman(engine, action, "Remediation failed")
      match escalateResult
        Ok(success) ->
          assert(success == true)
        Err(e) ->
          failTest("Escalation failed: " + e)

