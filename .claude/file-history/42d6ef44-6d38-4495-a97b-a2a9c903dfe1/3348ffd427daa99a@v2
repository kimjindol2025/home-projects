  reorderBufferSize: number    // ROB entries
  loadStoreQueueSize: number   // LSQ entries
  branchPredictorSize: number  // Branch prediction table

struct CPUOptimizationMetrics
  simdEfficiency: f64          // 0-1, target > 0.85
  ilpScore: f64                // Instruction Level Parallelism (0-100)
  branchAccuracy: f64          // Branch prediction accuracy (0-1)
  cacheUtilization: f64        // L1/L2/L3 combined (0-1)
  energyPerOp: f64             // Joules per operation
  thermalBudget: f64           // Current/max temp ratio

struct CPUOptimizationReport
  coreCount: number
