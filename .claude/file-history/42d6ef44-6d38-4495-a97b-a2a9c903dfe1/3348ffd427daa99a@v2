struct CPUCoreMetrics
  coreId: number
  cpuFrequencyGhz: f64
  cacheLineSize: number        // 64 bytes (typical)
  tlbEntries: number           // Translation Lookaside Buffer
  simdWidth: number            // 128/256/512 bits
