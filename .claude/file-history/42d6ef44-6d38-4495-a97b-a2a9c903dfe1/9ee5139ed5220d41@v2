  }

fn newZeroCopyManager() -> ZeroCopyManager
  {
    "pools": {},
    "transferLog": [],
    "pageCache": {},
    "stats": {
      "poolCount": 0,
      "totalBuffers": 0,
      "totalTransfers": 0,
      "pageHits": 0,
      "pageMisses": 0,
      "memoryRecovered": 0
    }
  }

// ============================================================================
// Buffer Allocation
// ============================================================================

fn allocateBuffer(manager: ZeroCopyManager, poolId: number, size: number, owner: number) -> Result<MemoryBuffer, string>
  let pool = manager.pools[poolId]
  if pool == nil
    return Err("Pool " + poolId as string + " not found")

  if size > pool.maxBufferSize
    return Err("Size exceeds max buffer size")

  // Try to reuse available buffer
  var buffer = nil
  var reuseIndex = -1

  for i = 0 to pool.availableBuffers.length()
    let candidate = pool.availableBuffers[i]
    if candidate.size >= size && candidate.state == 0
      buffer = candidate
      reuseIndex = i
      break

  // Allocate new if none available
  if buffer == nil
    buffer = {
      "bufferId": manager.stats["totalBuffers"] + 1,
      "address": 0,  // Would be actual memory address
      "size": size,
      "refCount": 1,
      "owner": owner,
      "dmaDescriptors": [],
      "creationTime": getCurrentTime(),
      "lastAccessTime": getCurrentTime(),
      "expiryTime": getCurrentTime() + 60000,  // 60 seconds
      "state": 1  // OWNED
    }
    pool.allocatedBuffers[buffer.bufferId] = buffer
    manager.stats["totalBuffers"] = manager.stats["totalBuffers"] + 1
  else
    // Reuse existing buffer
    if reuseIndex >= 0
      pool.availableBuffers.remove(reuseIndex)
    buffer.owner = owner
    buffer.refCount = 1
    buffer.state = 1  // OWNED
    buffer.lastAccessTime = getCurrentTime()
    buffer.expiryTime = getCurrentTime() + 60000
    pool.allocatedBuffers[buffer.bufferId] = buffer

  pool.stats["totalAllocations"] = (pool.stats["totalAllocations"] as number) + 1
  pool.stats["activeBuffers"] = (pool.stats["activeBuffers"] as number) + 1

  Ok(buffer)

// ============================================================================
// DMA Registration
// ============================================================================

fn registerBufferForDMA(manager: ZeroCopyManager, poolId: number, buffer: MemoryBuffer) -> number
  let pool = manager.pools[poolId]
  if pool == nil
    return -1

  // Create DMA descriptor (simplified)
  let descriptorId = buffer.bufferId * 1000 + pool.stats["totalAllocations"] as number

  buffer.dmaDescriptors.append(descriptorId)
  pool.allocatedBuffers[buffer.bufferId] = buffer

  descriptorId

fn deregisterBufferFromDMA(manager: ZeroCopyManager, poolId: number, buffer: MemoryBuffer, descriptorId: number) -> bool
  let pool = manager.pools[poolId]
  if pool == nil
    return false

  var newDescriptors = []
  for i = 0 to buffer.dmaDescriptors.length()
    if buffer.dmaDescriptors[i] != descriptorId
      newDescriptors.append(buffer.dmaDescriptors[i])

  buffer.dmaDescriptors = newDescriptors
  pool.allocatedBuffers[buffer.bufferId] = buffer
  true

// ============================================================================
// Ownership Management
// ============================================================================

fn transferOwnership(manager: ZeroCopyManager, buffer: MemoryBuffer, fromPid: number, toPid: number) -> Result<bool, string>
  if buffer.owner != fromPid
    return Err("Buffer not owned by process " + fromPid as string)

  buffer.owner = toPid
  buffer.state = 2  // TRANSFERRED
  buffer.refCount = buffer.refCount + 1
  buffer.lastAccessTime = getCurrentTime()

  let transfer = {
    "bufferId": buffer.bufferId,
    "fromPid": fromPid,
    "toPid": toPid,
    "timestamp": getCurrentTime(),
    "transferCount": buffer.refCount,
    "success": true
  }

  manager.transferLog.append(transfer)
  manager.stats["totalTransfers"] = manager.stats["totalTransfers"] + 1

  Ok(true)

// ============================================================================
// Buffer Reclamation
// ============================================================================

fn reclaimBufferOnCompletion(manager: ZeroCopyManager, poolId: number, buffer: MemoryBuffer) -> Result<bool, string>
  let pool = manager.pools[poolId]
  if pool == nil
    return Err("Pool not found")

  // Check if all DMA operations complete
  if buffer.dmaDescriptors.length() > 0
    return Err("DMA operations still pending")

  // Move to available list
  buffer.state = 0  // AVAILABLE
  buffer.refCount = 0
  buffer.owner = 0

  pool.availableBuffers.append(buffer)
  pool.stats["totalDeallocations"] = (pool.stats["totalDeallocations"] as number) + 1
  pool.stats["activeBuffers"] = (pool.stats["activeBuffers"] as number) - 1

  // Update reuse rate
  let reusedCount = pool.stats["totalDeallocations"] as number
  let totalCount = pool.stats["totalAllocations"] as number
  if totalCount > 0
    pool.stats["reuseRate"] = (reusedCount as f64) / (totalCount as f64)

  Ok(true)

// ============================================================================
// Garbage Collection
// ============================================================================

fn triggerGarbageCollection(manager: ZeroCopyManager, poolId: number) -> Result<number, string>
  let pool = manager.pools[poolId]
  if pool == nil
    return Err("Pool not found")

  let now = getCurrentTime()
  if now - pool.lastGCTime < pool.gcInterval
    return Ok(0)  // GC not needed yet

  var reclaimed = 0
  var buffersToReclaim = []

  for bufferId in pool.allocatedBuffers
    let buffer = pool.allocatedBuffers[bufferId]
    // Reclaim expired or orphaned buffers
    if buffer.expiryTime < now && buffer.refCount == 0
      buffersToReclaim.append(bufferId)

  // Actually reclaim
  for i = 0 to buffersToReclaim.length()
    let bufferId = buffersToReclaim[i]
    let buffer = pool.allocatedBuffers[bufferId]
    let result = reclaimBufferOnCompletion(manager, poolId, buffer)
    if result.ok
      reclaimed = reclaimed + 1

  pool.lastGCTime = now
  pool.stats["gcTriggered"] = (pool.stats["gcTriggered"] as number) + 1

  manager.stats["memoryRecovered"] = manager.stats["memoryRecovered"] + reclaimed

  Ok(reclaimed)

// ============================================================================
// Page Cache Management
// ============================================================================

fn cachePageAccess(manager: ZeroCopyManager, bufferId: number, pageIndex: number) -> bool
  let cached = manager.pageCache[bufferId]

  if cached != nil && cached == pageIndex
    manager.stats["pageHits"] = manager.stats["pageHits"] + 1
  else
    manager.stats["pageMisses"] = manager.stats["pageMisses"] + 1

  manager.pageCache[bufferId] = pageIndex
  true

