    "totalSize": totalSize,
    "maxBufferSize": maxBufferSize,
    "availableBuffers": [],
    "allocatedBuffers": {},
    "pendingReclamation": [],
    "bufferWaitlist": [],
    "stats": {
      "totalAllocations": 0,
      "totalDeallocations": 0,
      "activeBuffers": 0,
      "reuseRate": 0.0,
      "gcTriggered": 0,
      "totalBytesManaged": totalSize,
      "avgLifetimeMs": 0.0
    },
    "lastGCTime": getCurrentTime(),
