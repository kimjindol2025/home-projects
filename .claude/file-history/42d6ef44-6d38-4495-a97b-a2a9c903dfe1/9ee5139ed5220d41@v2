fn getPoolStats(pool: BufferPool) -> string
  var report = "=== BUFFER POOL " + pool.poolId as string + " STATS ===\n"
  report = report + "Total Size: " + pool.totalSize as string + " bytes\n"
  report = report + "Max Buffer Size: " + pool.maxBufferSize as string + " bytes\n"
  report = report + "Total Allocations: " + (pool.stats["totalAllocations"] as number) as string + "\n"
  report = report + "Total Deallocations: " + (pool.stats["totalDeallocations"] as number) as string + "\n"
  report = report + "Active Buffers: " + (pool.stats["activeBuffers"] as number) as string + "\n"
  report = report + "Reuse Rate: " + (pool.stats["reuseRate"] as f64) as string + "\n"
  report = report + "GC Triggered: " + (pool.stats["gcTriggered"] as number) as string + "\n"
  report

fn getManagerStats(manager: ZeroCopyManager) -> string
  var report = "=== ZERO-COPY MANAGER STATS ===\n"
  report = report + "Pool Count: " + manager.stats["poolCount"] as string + "\n"
  report = report + "Total Buffers: " + manager.stats["totalBuffers"] as string + "\n"
  report = report + "Total Transfers: " + manager.stats["totalTransfers"] as string + "\n"
  report = report + "Page Hits: " + manager.stats["pageHits"] as string + "\n"
  report = report + "Page Misses: " + manager.stats["pageMisses"] as string + "\n"
  report = report + "Memory Recovered: " + manager.stats["memoryRecovered"] as string + " buffers\n"
  report

fn getTransferLog(manager: ZeroCopyManager) -> string
  var report = "=== OWNERSHIP TRANSFER LOG ===\n"
  report = report + "Total Transfers: " + (manager.transferLog.length()) as string + "\n"

  var successCount = 0
  for i = 0 to manager.transferLog.length()
    let transfer = manager.transferLog[i]
    if transfer.success
      successCount = successCount + 1

  report = report + "Successful: " + successCount as string + "\n"
  report = report + "Failed: " + ((manager.transferLog.length()) - successCount) as string + "\n"
  report

fn getCurrentTime() -> number
  1740998400

