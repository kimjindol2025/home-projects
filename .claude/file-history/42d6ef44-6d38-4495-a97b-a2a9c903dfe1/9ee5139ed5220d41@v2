// ============================================================================
// Core Data Structures
// ============================================================================

struct MemoryBuffer
  bufferId: number
  address: number
  size: number
  refCount: number
  owner: number  // Process ID
  dmaDescriptors: array<number>
  creationTime: number
  lastAccessTime: number
  expiryTime: number
  state: number  // 0=AVAILABLE, 1=OWNED, 2=TRANSFERRED, 3=RECLAIMED

struct BufferPoolStats
  totalAllocations: number
  totalDeallocations: number
  activeBuffers: number
  reuseRate: f64
  gcTriggered: number
  totalBytesManaged: number
  avgLifetimeMs: f64

struct BufferPool
  poolId: number
  totalSize: number
  maxBufferSize: number
  availableBuffers: array<MemoryBuffer>
  allocatedBuffers: map<number, MemoryBuffer>
  pendingReclamation: array<number>
  bufferWaitlist: array<number>
  stats: BufferPoolStats
  lastGCTime: number
  gcInterval: number

struct OwnershipTransfer
  bufferId: number
  fromPid: number
  toPid: number
  timestamp: number
  transferCount: number
  success: bool

struct ZeroCopyManager
  pools: map<number, BufferPool>
  transferLog: array<OwnershipTransfer>
  pageCache: map<number, number>  // bufferId -> lastPageIndex
  stats: ManagerStats

struct ManagerStats
  poolCount: number
  totalBuffers: number
  totalTransfers: number
  pageHits: number
  pageMisses: number
  memoryRecovered: number

// ============================================================================
// Initialization
// ============================================================================

fn newBufferPool(poolId: number, totalSize: number, maxBufferSize: number) -> BufferPool
  {
