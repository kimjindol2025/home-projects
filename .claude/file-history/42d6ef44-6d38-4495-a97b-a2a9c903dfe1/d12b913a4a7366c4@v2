fn testIncidentRecordingAndResolution()
  // Setup
  let service = newSloMonitoringService()
  let sloResult = defineSlo(service, "api-service", 99.95, "30-day", "API service")

  match sloResult
    Ok(slo) ->
      let incidentResult = recordIncident(
        service,
        slo["sloId"],
        "HIGH",
        "Database connection failure"
      )

      match incidentResult
        Ok(incident) ->
          let resolveResult = resolveIncident(
            service,
            incident["incidentId"],
            "Restarted database pool"
          )

          match resolveResult
            Ok(success) ->
              assert(success == true)
            Err(e) ->
              failTest("Incident resolution failed: " + e)
        Err(e) ->
          failTest("Incident recording failed: " + e)
    Err(e) ->
      failTest("SLO definition failed: " + e)

fn testPostMortemGeneration()
  // Setup
  let service = newSloMonitoringService()
  let sloResult = defineSlo(service, "api-service", 99.95, "30-day", "API service")

  match sloResult
    Ok(slo) ->
      let incidentResult = recordIncident(
        service,
        slo["sloId"],
        "HIGH",
        "Database connection failure"
      )

      match incidentResult
        Ok(incident) ->
          let actionItems = ["Increase pool size", "Add health checks"]
          let pmResult = generatePostMortem(
            service,
            incident["incidentId"],
            "Insufficient database connection pool",
            actionItems
          )

          match pmResult
            Ok(postMortem) ->
              assert(postMortem["status"] == "DRAFT")
            Err(e) ->
              failTest("Post-mortem generation failed: " + e)
        Err(e) ->
          failTest("Incident recording failed: " + e)
    Err(e) ->
      failTest("SLO definition failed: " + e)

