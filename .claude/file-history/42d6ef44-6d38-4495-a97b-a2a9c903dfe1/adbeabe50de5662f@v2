fn testConcurrentSpawnExecution() -> tuple<bool, string>
  var spawnTasks = []

  for i = 1 to 4
    var task = {
      "taskId": i,
      "taskName": "concurrent_" + (i as string),
      "code": "execute task " + (i as string),
      "asyncType": "spawn_async",
      "outputStreams": []
    }
    spawnTasks.append(task)

  var codes = []
  for i = 0 to spawnTasks.length()
    let code = transpileSpawnTask(spawnTasks[i])
    codes.append(code)

  let allGenerated = codes.length() == 4
  let allAsync = codes[0].contains("async") && codes[1].contains("async") &&
                 codes[2].contains("async") && codes[3].contains("async")

  (allGenerated && allAsync, "Concurrent spawn execution")

