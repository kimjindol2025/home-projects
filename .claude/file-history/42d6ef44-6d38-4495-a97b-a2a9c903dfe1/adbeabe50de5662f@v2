fn testMatchExpressionOutputValidation() -> tuple<bool, string>
  let matchExpr = {
    "expr": "result",
    "patterns": ["ok", "error"],
    "bodies": ["print(\"success\")", "print(\"failed\")"],
    "defaultBody": "print(\"unknown\")"
  }

  let code = transpileMatchExpression(matchExpr)

  var expectedOutputs = ["success", "failed", "unknown"]
  var report = compareOutputCharacterByCharacter(
    "success failed unknown",
    "success failed unknown"
  )

  let outputMatchesExpected = !report.outputMismatch

  (outputMatchesExpected, "Match expression output validation")

fn testMatchWithoutRace() -> tuple<bool, string>
  var patterns = ["A", "B", "C"]
