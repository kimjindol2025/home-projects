  let matchExpr = {
    "expr": "input",
    "patterns": patterns,
    "bodies": bodies,
    "defaultBody": "x = 0"
  }

  let code = transpileMatchExpression(matchExpr)

  var spawnTasks = []
  let raceReport = detectAsyncRaces(spawnTasks, ["x"])

  let noRaceDetected = !raceReport.raceDetected

