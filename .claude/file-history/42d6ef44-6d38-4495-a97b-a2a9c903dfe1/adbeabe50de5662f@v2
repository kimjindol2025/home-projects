fn testBasicOutputStreaming() -> tuple<bool, string>
  let source = "print(\"hello\"); print(\"world\");"
  var ctx = {
    "source": source,
    "ast": [],
    "output": "",
    "outputStream": [],
    "functions": {},
    "matchExpressions": [],
    "spawnTasks": [],
    "raceDetected": false,
    "outputMismatches": []
  }

  ctx.ast = buildAst(source)
  ctx = transpile(ctx)
  ctx = recordOutput(ctx, "hello")
  ctx = recordOutput(ctx, "world")

  let streamContains = ctx.outputStream.length() == 2
  let firstCorrect = ctx.outputStream[0] == "hello"
  let secondCorrect = ctx.outputStream[1] == "world"

  (streamContains && firstCorrect && secondCorrect, "Basic output streaming")

