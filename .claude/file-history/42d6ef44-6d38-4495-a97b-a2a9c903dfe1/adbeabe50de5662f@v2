fn testAsyncRaceDetectionWithSharedVar() -> tuple<bool, string>
  var spawnTasks = []

  var task1 = {
    "taskId": 1,
    "taskName": "reader",
    "code": "read globalCounter",
    "asyncType": "spawn_async",
    "outputStreams": []
  }
  spawnTasks.append(task1)

  var task2 = {
    "taskId": 2,
    "taskName": "writer",
    "code": "globalCounter = globalCounter + 1",
    "asyncType": "spawn_async",
    "outputStreams": []
  }
  spawnTasks.append(task2)

  var globalVars = ["globalCounter"]

  let report = detectAsyncRaces(spawnTasks, globalVars)

  let raceDetected = report.raceDetected
  let sharedVarsIdentified = report.sharedVariables.length() > 0

  (raceDetected && sharedVarsIdentified, "Async race detection with shared variable")

fn testSynchronizationValidation() -> tuple<bool, string>
  var spawnTasks = []

  var unsyncedTask = {
    "taskId": 1,
    "taskName": "unsync",
    "code": "value = sharedData",
    "asyncType": "spawn_async",
    "outputStreams": ["sharedData"]
  }
  spawnTasks.append(unsyncedTask)

  var locks = ["lock1"]

  let isValid = checkVariableSynchronization(spawnTasks, locks)

  let unsyncDetected = !isValid

  (unsyncDetected, "Synchronization validation detects unsynchronized access")

fn testCompleteSemanticPreservation() -> tuple<bool, string>
  let freeLangOutput = "result: 42"
  let zLangOutput = "result: 42"

  var expectedOutputs = ["result:", "42"]
  var actualOutputs = ["result:", "42"]

  let report = validateSemanticPreservation(
    freeLangOutput,
    zLangOutput,
    expectedOutputs,
    actualOutputs
  )

  let semanticsPreserved = report.semanticsPreserved
  let score = report.score == 1  // Binary scoring: 0 or 1

  (semanticsPreserved && score, "Complete semantic preservation")

