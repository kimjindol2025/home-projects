// Group A: Basic Transpilation (3 tests)
// ============================================================================

fn testBasicFunctionTranspilation() -> tuple<bool, string>
  let source = "fn add(a: number, b: number) -> number { a + b }"
  var ctx = {
    "source": source,
    "ast": [],
    "output": "",
    "outputStream": [],
    "functions": {},
    "matchExpressions": [],
    "spawnTasks": [],
    "raceDetected": false,
    "outputMismatches": []
  }

  ctx.ast = buildAst(source)
  ctx = transpile(ctx)

  let hasFunction = ctx.functions.length() > 0 || ctx.output.contains("function add")
  let noMismatch = ctx.outputMismatches.length() == 0

  (hasFunction && noMismatch, "Basic function transpilation")

