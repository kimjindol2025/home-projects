fn setupTranspiler() -> tuple<Transpiler, SemanticValidator>
  var transpiler = {
    "source": "",
    "ast": [],
    "output": "",
    "outputStream": [],
    "functions": {},
    "matchExpressions": [],
    "spawnTasks": [],
