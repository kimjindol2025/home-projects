fn testSimpleMatchTranspilation() -> tuple<bool, string>
  let matchExpr = {
    "expr": "status",
    "patterns": ["200", "404"],
    "bodies": ["return ok", "return error"],
    "defaultBody": "return unknown"
  }

  let code = transpileMatchExpression(matchExpr)
  let hasSwitch = code.contains("switch")
  let hasCase200 = code.contains("case 200")
  let hasCase404 = code.contains("case 404")
  let hasDefault = code.contains("default")

  (hasSwitch && hasCase200 && hasCase404 && hasDefault, "Simple match transpilation")

