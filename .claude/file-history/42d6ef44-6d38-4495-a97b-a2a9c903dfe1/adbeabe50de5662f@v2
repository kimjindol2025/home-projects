fn testCharacterByCharacterComparison() -> tuple<bool, string>
  let expected = "hello world"
  let actual = "hello world"

  let report = compareOutputCharacterByCharacter(expected, actual)

  let noMismatch = !report.outputMismatch
  let correctLength = report.totalCharacters == 11
  let noMismatchedChars = report.mismatchedCharacters == 0

  (noMismatch && correctLength && noMismatchedChars, "Character-by-character comparison")

fn testOutputMismatchDetection() -> tuple<bool, string>
  let expected = "expected output"
  let actual = "different output"

  let report = compareOutputCharacterByCharacter(expected, actual)

  let mismatchDetected = report.outputMismatch
  let severityCorrect = report.severity == "CRITICAL"

  (mismatchDetected && severityCorrect, "Output mismatch detection")

fn testOutputStreamComparison() -> tuple<bool, string>
  var expectedStream = ["line1", "line2", "line3"]
  var actualStream = ["line1", "line2", "line3"]

  let report = compareOutputStreams(expectedStream, actualStream)

  let noMismatch = !report.outputMismatch
  let streamLength = report.totalCharacters == 3

  (noMismatch && streamLength, "Output stream comparison")

