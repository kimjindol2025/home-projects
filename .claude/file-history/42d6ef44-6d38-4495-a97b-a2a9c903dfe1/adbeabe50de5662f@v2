fn testSimpleSpawnTranspilation() -> tuple<bool, string>
  let spawnTask = {
    "taskId": 1,
    "taskName": "task1",
    "code": "result = x + y",
    "asyncType": "spawn_async",
    "outputStreams": []
  }

  let code = transpileSpawnTask(spawnTask)
  let hasAsync = code.contains("async")
  let hasFunction = code.contains("function")
  let hasTaskName = code.contains("task_task1")

  (hasAsync && hasFunction && hasTaskName, "Simple spawn transpilation")

fn testMultipleSpawnTasks() -> tuple<bool, string>
  var tasks = []

  var task1 = {
    "taskId": 1,
    "taskName": "worker1",
    "code": "compute a",
    "asyncType": "spawn_async",
    "outputStreams": []
  }
  tasks.append(task1)

  var task2 = {
    "taskId": 2,
    "taskName": "worker2",
    "code": "compute b",
    "asyncType": "spawn_async",
    "outputStreams": []
  }
  tasks.append(task2)

  var generatedCodes = []
  for i = 0 to tasks.length()
    let code = transpileSpawnTask(tasks[i])
    generatedCodes.append(code)

  let task1Code = generatedCodes[0]
  let task2Code = generatedCodes[1]

  let bothHaveAsync = task1Code.contains("async") && task2Code.contains("async")
  let bothUnique = task1Code.contains("task_worker1") && task2Code.contains("task_worker2")

  (bothHaveAsync && bothUnique, "Multiple spawn tasks")

fn testSpawnWithSharedVariables() -> tuple<bool, string>
  var spawnTasks = []

  var task = {
    "taskId": 1,
    "taskName": "updater",
    "code": "counter = counter + 1; print(counter)",
    "asyncType": "spawn_async",
    "outputStreams": ["counter"]
  }
  spawnTasks.append(task)

  var globalVars = ["counter"]

  let raceReport = detectAsyncRaces(spawnTasks, globalVars)

  let raceDetected = raceReport.raceDetected

  (raceDetected, "Spawn with shared variables triggers race detection")

fn testSpawnWithOutputStreams() -> tuple<bool, string>
