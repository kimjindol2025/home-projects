  verificationId: string
  snapshotId: string
  checksumValid: bool
  integrityCheck: bool
  recoveryTestPassed: bool
  timestamp: number

struct BackupStats
  totalSnapshots: number
  successfulBackups: number
  failedBackups: number
  avgBackupDurationMs: number
  rpoAchieved: number
  rtoAchieved: number

