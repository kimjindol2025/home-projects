// ============================================================================
// Core Data Structures
// ============================================================================

struct SchemaField
  name: string
  fieldType: string  // "i32", "i64", "f32", "f64", "bytes", "string"
  fieldNumber: number
  required: bool
  repeated: bool

struct ProtocolSchema
  name: string
  version: number
  fields: array<SchemaField>
  alignment: number  // 64, 128, 256 bits
  varintEncoding: bool
  checksumEnabled: bool

struct CompiledField
  fieldName: string
  fieldType: string
  fieldNumber: number
  offset: number
  size: number
  encodeFn: string  // Function name
  decodeFn: string

struct CompiledProtocol
  schemaName: string
  version: number
  compiledFields: array<CompiledField>
  totalSize: number
  optimization: string  // "none", "simd", "avx2", "neon"
  targetArch: string  // "x86_64", "aarch64", "risc-v"
  compressionRatio: f64
  estimatedLatencyNs: f64

struct ProtocolCompiler
  targetArch: string
  simdEnabled: bool
  varintCache: map<number, array<number>>
  compiledProtocols: map<string, CompiledProtocol>
  stats: CompilerStats

struct CompilerStats
  schemasCompiled: number
  totalFields: number
  avgCompressionRatio: f64
  simdOptimizations: number
  architectureAdaptations: number

