fn getCompilerStats(compiler: ProtocolCompiler) -> string
  var report = "=== PROTOCOL COMPILER STATS ===\n"
  report = report + "Target Architecture: " + compiler.targetArch + "\n"
  report = report + "Schemas Compiled: " + (compiler.stats["schemasCompiled"] as number) as string + "\n"
  report = report + "Total Fields: " + (compiler.stats["totalFields"] as number) as string + "\n"
  report = report + "SIMD Optimizations: " + (compiler.stats["simdOptimizations"] as number) as string + "\n"
  report = report + "Architecture Adaptations: " + (compiler.stats["architectureAdaptations"] as number) as string + "\n"
  report = report + "Avg Compression Ratio: " + (compiler.stats["avgCompressionRatio"] as f64) as string + "\n"
  report

fn getCompiledProtocolInfo(compiled: CompiledProtocol) -> string
  var report = "=== COMPILED PROTOCOL: " + compiled.schemaName + " ===\n"
  report = report + "Total Size: " + compiled.totalSize as string + " bytes\n"
  report = report + "Optimization: " + compiled.optimization + "\n"
  report = report + "Compression Ratio: " + (compiled.compressionRatio as f64) as string + "\n"
  report = report + "Est. Latency: " + (compiled.estimatedLatencyNs as f64) as string + "ns\n"
  report = report + "Fields: " + (compiled.compiledFields.length()) as string + "\n"
  report

