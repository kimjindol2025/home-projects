  let activities = []

  activities.append({
    "processId": "proc_1",
    "purpose": "User authentication",
    "dataCategories": ["identity"],
    "legalBasis": "Contractual necessity",
    "retention": "Until account deletion"
  })

  activities.append({
    "processId": "proc_2",
    "purpose": "Analytics and improvement",
    "dataCategories": ["activity", "preferences"],
    "legalBasis": "Legitimate interest",
    "retention": "24 months"
  })

  activities.append({
    "processId": "proc_3",
    "purpose": "Marketing communications",
    "dataCategories": ["contact", "preferences"],
    "legalBasis": "Explicit consent",
