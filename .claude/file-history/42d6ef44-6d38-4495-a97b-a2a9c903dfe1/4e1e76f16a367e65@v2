struct DataSubject
  subjectId: string
  email: string
  consentStatus: map<string, bool>
  dataCategories: array<string>
  registeredAt: number

struct ConsentRecord
  recordId: string
  subjectId: string
  category: string
  purpose: string
  status: string
  grantedAt: number
  withdrawnAt: number

struct DataExport
  exportId: string
  subjectId: string
  dataTypes: array<string>
  format: string
  createdAt: number
  completedAt: number
  status: string
  fileUrl: string

struct DataDeletion
  deletionId: string
  subjectId: string
  reason: string
  status: string
  requestedAt: number
  completedAt: number

fn registerDataSubject(email: string) -> Result<DataSubject, string>
  if email.length() == 0 || !email.find("@") > 0
    return Err("Invalid email")

  let subject = {
    "subjectId": generateSubjectId(),
    "email": email,
    "consentStatus": {
      "marketing": false,
      "analytics": false,
      "personalization": false
    },
    "dataCategories": ["profile", "activity"],
    "registeredAt": getCurrentTime()
  }

  Ok(subject)

fn requestConsent(
  subjectId: string,
  category: string,
  purpose: string
) -> Result<ConsentRecord, string>
  if category.length() == 0 || purpose.length() == 0
    return Err("Invalid consent request")

  let record = {
    "recordId": generateConsentId(),
    "subjectId": subjectId,
    "category": category,
    "purpose": purpose,
    "status": "PENDING",
    "grantedAt": 0,
    "withdrawnAt": 0
  }

  Ok(record)

fn grantConsent(
  recordId: string,
  subjectId: string,
  category: string
) -> Result<ConsentRecord, string>
  let record = {
    "recordId": recordId,
    "subjectId": subjectId,
    "category": category,
    "purpose": "User consented",
    "status": "GRANTED",
    "grantedAt": getCurrentTime(),
    "withdrawnAt": 0
  }

  Ok(record)

fn withdrawConsent(
  subjectId: string,
  category: string
) -> Result<bool, string>
  Ok(true)

fn exportUserData(
  subjectId: string,
  format: string
) -> Result<DataExport, string>
  let export = {
    "exportId": generateExportId(),
    "subjectId": subjectId,
    "dataTypes": ["profile", "activity", "preferences", "consent_records"],
    "format": format,
    "createdAt": getCurrentTime(),
    "completedAt": getCurrentTime() + 3600,
    "status": "COMPLETED",
    "fileUrl": "https://example.com/exports/export_" + subjectId + "." + format
  }

  Ok(export)

fn deleteUserData(
  subjectId: string,
  reason: string
) -> Result<DataDeletion, string>
  let deletion = {
    "deletionId": generateDeletionId(),
    "subjectId": subjectId,
    "reason": reason,
    "status": "IN_PROGRESS",
    "requestedAt": getCurrentTime(),
    "completedAt": 0
  }

  deletion["status"] = "COMPLETED"
  deletion["completedAt"] = getCurrentTime() + 86400

  Ok(deletion)

fn validateConsentStatus(
  subjectId: string,
  category: string
) -> Result<bool, string>
  // Simulate consent validation
  if category == "marketing"
    return Ok(false)
  if category == "analytics"
    return Ok(true)
  if category == "personalization"
    return Ok(false)

  Ok(false)

