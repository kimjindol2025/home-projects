struct Role
  roleId: string
  name: string
  description: string
  permissions: array<string>
  scope: string
  createdAt: number

struct Permission
  permissionId: string
  resource: string
  action: string
  effect: string
  conditions: map<string, any>

struct PolicyBinding
  bindingId: string
  principalId: string
  roleId: string
  resourceId: string
  condition: map<string, any>
  grantedAt: number

struct RoleAssignment
  assignmentId: string
  principalId: string
  roleId: string
  scope: string
  expiresAt: number

fn newRole(
  name: string,
  description: string,
  scope: string
) -> Role
  {
    "roleId": generateRoleId(),
    "name": name,
    "description": description,
    "permissions": [],
    "scope": scope,
    "createdAt": getCurrentTime()
  }

