// ============================================================================
// Register Hash & Integrity Check
// ============================================================================

fn computeRegisterHash(registers: TaskRegisters) -> number
  // 간단한 해시: 모든 레지스터 XOR
  var hash = 0
  hash = hash + registers.rax as number
  hash = hash + registers.rbx as number
  hash = hash + registers.rcx as number
  hash = hash + registers.rdx as number
  hash = hash + registers.rsi as number
  hash = hash + registers.rdi as number
  hash = hash + registers.r8 as number
  hash = hash + registers.r9 as number
  hash = hash + registers.r10 as number
  hash = hash + registers.r11 as number
  hash = hash + registers.r12 as number
  hash = hash + registers.r13 as number
  hash = hash + registers.r14 as number
  hash = hash + registers.r15 as number
  hash = (hash * 2654435761) as number  // FNV-1a 스타일
  hash

fn saveRegisterState(task: Task) -> Task
  // 레지스터 상태 저장
  task.registers.registerHash = computeRegisterHash(task.registers)
  task

fn validateRegisterIntegrity(registers: TaskRegisters) -> bool
  // 저장된 해시와 현재 해시 비교
  let currentHash = computeRegisterHash(registers)
  currentHash == registers.registerHash

// ============================================================================
// Stack Management
// ============================================================================

fn updateStackUsage(task: Task, currentRsp: number) -> Task
  // 스택 사용량 업데이트
  let stackPointer = task.stack.stackPointer
  let stackBase = task.stack.stackBase

  // 사용된 크기 계산
  if currentRsp < stackBase
    task.stack.stackUsed = stackBase - currentRsp
    if task.stack.stackUsed > task.stack.stackWatermark
      task.stack.stackWatermark = task.stack.stackUsed
  else
    task.stack.stackUsed = 0

  task

fn validateStackLeak(task: Task, expectedRsp: number) -> bool
  // 스택 포인터가 원래 위치로 돌아왔는지 검증
  // 무관용: 1비트라도 틀리면 실패
  (task.stack.stackPointer == expectedRsp)

fn detectStackOverflow(task: Task) -> bool
  // 스택 오버플로우 감지
  if task.stack.stackUsed > task.stack.stackSize
    return true  // Overflow!

  false

// ============================================================================
// Context Save (Task → Registers)
// ============================================================================

fn saveContext(
  scheduler: TaskScheduler,
  taskId: number,
  rax: number, rbx: number, rcx: number, rdx: number,
  rsi: number, rdi: number, rbp: number, rsp: number
) -> TaskScheduler
  // 현재 실행 중인 태스크의 레지스터 상태 저장
  if taskId < 0 || taskId >= scheduler.tasks.length()
    return scheduler

  var task = scheduler.tasks[taskId]

  // 레지스터 저장
  task.registers.rax = rax
  task.registers.rbx = rbx
  task.registers.rcx = rcx
  task.registers.rdx = rdx
  task.registers.rsi = rsi
  task.registers.rdi = rdi
  task.registers.rbp = rbp
  task.registers.rsp = rsp

  // 스택 포인터 저장
  task.stack.stackPointer = rsp
  task = updateStackUsage(task, rsp)

  // 레지스터 해시 계산
  task = saveRegisterState(task)

  task.stats["contextSwitches"] = (task.stats["contextSwitches"] as number) + 1

  scheduler.tasks[taskId] = task
  scheduler

// ============================================================================
// Context Restore (Registers → Task)
// ============================================================================

fn restoreContext(scheduler: TaskScheduler, taskId: number) -> tuple<TaskScheduler, number>
  // 태스크의 레지스터 상태 복원
  if taskId < 0 || taskId >= scheduler.tasks.length()
    return (scheduler, 0)

  let task = scheduler.tasks[taskId]

  // 무관용 검증: 레지스터 무결성
  if !validateRegisterIntegrity(task.registers)
    scheduler.stats["registryDriftCount"] = (scheduler.stats["registryDriftCount"] as number) + 1
    return (scheduler, 0)

  // 스택 무결성 검증
  if !validateStackLeak(task, task.registers.rsp)
    scheduler.stats["stackLeakCount"] = (scheduler.stats["stackLeakCount"] as number) + 1
    return (scheduler, 0)

  // 모든 검증 통과
  scheduler.stats["successfulSwitches"] = (scheduler.stats["successfulSwitches"] as number) + 1

  (scheduler, task.registers.rax)  // 복원된 RAX 반환

// ============================================================================
// Context Switch - Core Logic
// ============================================================================

fn contextSwitch(
  scheduler: TaskScheduler,
  fromTaskId: number,
  toTaskId: number
) -> TaskScheduler
  // 무관용: Context Switch 중 일관성 보장
  scheduler.contextSwitchInProgress = true

  // Step 1: 현재 태스크 컨텍스트 저장
  // (실제 구현에서는 실제 레지스터 값 사용)
  scheduler = saveContext(scheduler, fromTaskId,
    100.0, 101.0, 102.0, 103.0,  // 식별 가능한 값
    104.0, 105.0, 106.0, 1000.0   // rsp
  )

  // Step 2: 다음 태스크의 컨텍스트 복원
  let (newScheduler, restoredValue) = restoreContext(scheduler, toTaskId)
  scheduler = newScheduler

  // Step 3: 태스크 상태 업데이트
  if fromTaskId >= 0 && fromTaskId < scheduler.tasks.length()
    scheduler.tasks[fromTaskId].metadata["state"] = "READY"

  if toTaskId >= 0 && toTaskId < scheduler.tasks.length()
    scheduler.tasks[toTaskId].metadata["state"] = "RUNNING"
    scheduler.tasks[toTaskId].metadata["lastScheduledTime"] = getCurrentTime()

  scheduler.runningTask = toTaskId
  scheduler.contextSwitchInProgress = false

  scheduler

// ============================================================================
// Interrupt During Context Switch Handling
// ============================================================================

fn handleInterruptDuringSwitch(
  scheduler: TaskScheduler,
  interruptNumber: number,
  fromTaskId: number,
  toTaskId: number
) -> TaskScheduler
  // 컨텍스트 스위치 중 인터럽트 발생!
  // 무관용: 레지스터/스택이 손상되지 않아야 함

  // 인터럽트 큐에 추가 (나중에 처리)
  scheduler.interruptsPending.append(interruptNumber)

  // 통계 업데이트
  var task = scheduler.tasks[toTaskId]
  task.stats["interruptsDuringSwitch"] = (task.stats["interruptsDuringSwitch"] as number) + 1
  scheduler.tasks[toTaskId] = task

  // 스위치는 계속 진행
  scheduler = contextSwitch(scheduler, fromTaskId, toTaskId)

  scheduler

// ============================================================================
// Syscall During Context Switch Handling
// ============================================================================

fn handleSyscallDuringSwitch(
  scheduler: TaskScheduler,
  syscallNumber: number,
  fromTaskId: number,
  toTaskId: number
) -> TaskScheduler
  // 컨텍스트 스위치 중 Syscall 발생!
  // 무관용: 원자성 유지

  // Syscall 기록
  var task = scheduler.tasks[toTaskId]
  task.stats["syscallsDuringSwitch"] = (task.stats["syscallsDuringSwitch"] as number) + 1
  scheduler.tasks[toTaskId] = task

  // 스위치 계속
  scheduler = contextSwitch(scheduler, fromTaskId, toTaskId)

  scheduler

// ============================================================================
// Concurrent Event Handling
// ============================================================================

fn handleConcurrentEvents(
  scheduler: TaskScheduler,
  fromTaskId: number,
  toTaskId: number,
  interruptNumber: number,
  syscallNumber: number
) -> TaskScheduler
  // 동시에 인터럽트 + Syscall 발생!

  // Step 1: 인터럽트 처리
  scheduler = handleInterruptDuringSwitch(scheduler, interruptNumber, fromTaskId, toTaskId)

  // Step 2: Syscall 처리
  scheduler = handleSyscallDuringSwitch(scheduler, syscallNumber, fromTaskId, toTaskId)

  // 무관용 검증: 레지스터/스택이 여전히 유효해야 함
  if scheduler.stats["registryDriftCount"] as number > 0
    scheduler.stats["panicCount"] = (scheduler.stats["panicCount"] as number) + 1

  if scheduler.stats["stackLeakCount"] as number > 0
    scheduler.stats["panicCount"] = (scheduler.stats["panicCount"] as number) + 1

  scheduler

// ============================================================================
// Scheduling Logic
// ============================================================================

fn selectNextTask(scheduler: TaskScheduler) -> number
  // 준비된 큐에서 다음 태스크 선택
  if scheduler.readyQueue.length() > 0
    return scheduler.readyQueue[0]

  return -1

fn scheduleNextTask(scheduler: TaskScheduler) -> TaskScheduler
  // 다음 실행할 태스크 선택 및 스위치
  let nextTaskId = selectNextTask(scheduler)

  if nextTaskId >= 0
    let currentTaskId = scheduler.runningTask
    scheduler = contextSwitch(scheduler, currentTaskId, nextTaskId)

  scheduler

// ============================================================================
// Statistics & Reporting
// ============================================================================

fn getSchedulerStats(scheduler: TaskScheduler) -> string
  var report = "=== SCHEDULER STATISTICS ===\\n"
  report = report + "Total Context Switches: " + (scheduler.stats["totalContextSwitches"] as number) as string + "\\n"
  report = report + "Total Interrupts: " + (scheduler.stats["totalInterrupts"] as number) as string + "\\n"
  report = report + "Total Syscalls: " + (scheduler.stats["totalSyscalls"] as number) as string + "\\n"
  report = report + "Registry Drift Count: " + (scheduler.stats["registryDriftCount"] as number) as string + " (MUST BE 0)\\n"
  report = report + "Stack Leak Count: " + (scheduler.stats["stackLeakCount"] as number) as string + " (MUST BE 0)\\n"
  report = report + "Panic Count: " + (scheduler.stats["panicCount"] as number) as string + " (MUST BE 0)\\n"
  report = report + "Successful Switches: " + (scheduler.stats["successfulSwitches"] as number) as string + "\\n"

  report

fn getCurrentTime() -> number
  1740998400 + 20000
