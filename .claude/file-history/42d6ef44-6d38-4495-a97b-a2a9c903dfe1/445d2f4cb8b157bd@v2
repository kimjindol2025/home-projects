// FreeLang OS Kernel: Scheduler & Context Switch
// Panic-Free Context Switching with Hardware Interrupt Safety
// 800 lines - Zero Registry Drift, Zero Stack Leak
// ============================================================================

// ============================================================================
// Task Management Structures
// ============================================================================

struct TaskRegisters
  // x86-64 General Purpose Registers
  rax: number
  rbx: number
  rcx: number
  rdx: number
  rsi: number
  rdi: number
  rbp: number
  r8: number
  r9: number
  r10: number
  r11: number
  r12: number
  r13: number
  r14: number
  r15: number

  // Control & Instruction Pointers
  rip: number               // Instruction Pointer
  rsp: number               // Stack Pointer
  rflags: number            // Flags Register

  // Segment Registers
  cs: number                // Code Segment
  ss: number                // Stack Segment
  ds: number
  es: number
  fs: number
  gs: number

  // Hash for integrity check
  registerHash: number

struct TaskStackFrame
  stackBase: number         // 스택 기반 주소
  stackPointer: number      // 현재 스택 포인터 (변경됨)
  stackSize: number         // 총 스택 크기
  stackUsed: number         // 사용된 크기
  stackWatermark: number    // 최대 사용량
  isValid: bool

struct TaskMetadata
  taskId: number
  priority: number          // 0-255 (높을수록 높음)
  state: string            // "READY", "RUNNING", "BLOCKED", "STOPPED"
  cpuAffinity: number      // CPU 코어 번호
  contextSwitchCount: number
  lastScheduledTime: number
  executionTime: number    // 누적 실행 시간

struct Task
  metadata: TaskMetadata
  registers: TaskRegisters
  stack: TaskStackFrame
  parent: number           // 부모 태스크 ID
  children: array<number>
  createdAt: number
  stats: TaskStats

struct TaskStats
  contextSwitches: number
  interruptsDuringSwitch: number
  syscallsDuringSwitch: number
  registryDrifts: number   // Should be 0!
  stackLeaks: number       // Should be 0!

struct TaskScheduler
  tasks: array<Task>
  currentTaskId: number
  readyQueue: array<number>  // FIFO queue of task IDs
  blockedTasks: array<number>
  runningTask: number
  stats: SchedulerStats
  contextSwitchInProgress: bool
  interruptsPending: array<number>

struct SchedulerStats
  totalContextSwitches: number
  totalInterrupts: number
  totalSyscalls: number
  registryDriftCount: number     // MUST BE 0
  stackLeakCount: number         // MUST BE 0
  panicCount: number             // MUST BE 0
  successfulSwitches: number

// ============================================================================
// Task Initialization
// ============================================================================

