      "r8": 0, "r9": 0, "r10": 0, "r11": 0,
      "r12": 0, "r13": 0, "r14": 0, "r15": 0,
      "rip": 0, "rsp": 0, "rflags": 0,
      "cs": 0, "ss": 0, "ds": 0, "es": 0, "fs": 0, "gs": 0,
