// Validation Rule
struct ValidationRule
  fieldName: string
  fieldType: string  // "string", "number", "array", "object"
  required: bool
  minLength: number
  maxLength: number
  pattern: string    // Regex pattern
  minValue: number
  maxValue: number
  allowedValues: array<string>

// JSON Schema
struct JsonSchema
  title: string
  version: string
  properties: map<string, ValidationRule>
  required: array<string>

// Validation Error
struct ValidationError
  field: string
  message: string
  code: string
  value: string

// Validation Result
struct ValidationResult
  valid: bool
  errors: array<ValidationError>

// Create validation rule
fn createValidationRule(
  fieldName: string,
  fieldType: string,
  required: bool
) -> ValidationRule
  {
    "fieldName": fieldName,
    "fieldType": fieldType,
    "required": required,
    "minLength": 0,
    "maxLength": 65536,
    "pattern": "",
    "minValue": 0,
    "maxValue": 2147483647,
    "allowedValues": []
  }

// Create JSON schema
fn createJsonSchema(title: string, version: string) -> JsonSchema
  {
    "title": title,
    "version": version,
    "properties": {},
    "required": []
  }

// Add field to schema
fn addFieldToSchema(
  schema: JsonSchema,
  rule: ValidationRule,
  required: bool
) -> JsonSchema
  schema["properties"][rule["fieldName"]] = rule
  if required
    schema["required"].append(rule["fieldName"])
  schema

// Validate string field
fn validateString(
  value: string,
  rule: ValidationRule
) -> Result<bool, ValidationError>
  // Check required
  if rule["required"] && value.length() == 0
    return Err({
      "field": rule["fieldName"],
      "message": "Field is required",
      "code": "REQUIRED",
      "value": value
    })

  // Check length
  if value.length() < rule["minLength"]
    return Err({
      "field": rule["fieldName"],
      "message": "String too short",
      "code": "MIN_LENGTH",
      "value": value
    })

  if value.length() > rule["maxLength"]
    return Err({
      "field": rule["fieldName"],
      "message": "String too long",
      "code": "MAX_LENGTH",
      "value": value
    })

  // Check pattern (simplified)
  if rule["pattern"].length() > 0
    if !matchesPattern(value, rule["pattern"])
      return Err({
        "field": rule["fieldName"],
        "message": "String does not match pattern",
        "code": "PATTERN",
        "value": value
      })

  // Check allowed values
  if rule["allowedValues"].length() > 0
    let found = false
    for allowed in rule["allowedValues"]
      if value == allowed
        found = true
    if !found
      return Err({
        "field": rule["fieldName"],
        "message": "Value not in allowed list",
        "code": "INVALID_VALUE",
        "value": value
      })

  Ok(true)

// Validate number field
fn validateNumber(
  value: number,
  rule: ValidationRule
) -> Result<bool, ValidationError>
  // Check range
  if value < rule["minValue"]
    return Err({
      "field": rule["fieldName"],
      "message": "Number too small",
      "code": "MIN_VALUE",
      "value": toString(value)
    })

  if value > rule["maxValue"]
    return Err({
      "field": rule["fieldName"],
      "message": "Number too large",
      "code": "MAX_VALUE",
      "value": toString(value)
    })

  Ok(true)

// Validate array field
fn validateArray(
  array: array<any>,
  rule: ValidationRule
) -> Result<bool, ValidationError>
  // Check length
  if array.length() < rule["minLength"]
    return Err({
      "field": rule["fieldName"],
      "message": "Array too small",
      "code": "MIN_LENGTH",
      "value": toString(array.length())
    })

  if array.length() > rule["maxLength"]
    return Err({
      "field": rule["fieldName"],
      "message": "Array too large",
      "code": "MAX_LENGTH",
      "value": toString(array.length())
    })

  Ok(true)

// Validate object against schema
fn validateObject(
  object: map<string, any>,
  schema: JsonSchema
) -> ValidationResult
  let errors = []

  // Check required fields
  for field in schema["required"]
    if object[field] == nil
      errors.append({
        "field": field,
        "message": "Required field missing",
        "code": "REQUIRED",
        "value": ""
      })

  // Validate each field
  for fieldName in object.keys()
    let rule = schema["properties"][fieldName]
    if rule == nil
      continue

    let value = object[fieldName]
    match rule["fieldType"]
      "string" ->
        let result = validateString(value, rule)
        match result
          Ok(_) -> ()
          Err(err) -> errors.append(err)
      "number" ->
        let result = validateNumber(value, rule)
        match result
          Ok(_) -> ()
          Err(err) -> errors.append(err)
      "array" ->
        let result = validateArray(value, rule)
        match result
          Ok(_) -> ()
          Err(err) -> errors.append(err)
      _ -> ()

  {
    "valid": errors.length() == 0,
    "errors": errors
  }

// Safe error response (no internal details exposed)
fn createSafeErrorResponse(
  statusCode: number,
  errorCode: string,
  publicMessage: string
) -> map<string, any>
  {
    "status": "error",
    "statusCode": statusCode,
    "error": {
      "code": errorCode,
      "message": publicMessage
    },
    "timestamp": getCurrentTime()
  }

// Create safe error responses for common errors
fn createValidationErrorResponse(errors: array<ValidationError>) -> map<string, any>
  let fieldErrors = {}
  for err in errors
    fieldErrors[err["field"]] = err["code"]

  createSafeErrorResponse(
    400,
    "VALIDATION_ERROR",
    "Request validation failed"
  )

fn createAuthenticationErrorResponse() -> map<string, any>
  createSafeErrorResponse(
    401,
    "UNAUTHORIZED",
    "Authentication required"
  )

fn createAuthorizationErrorResponse() -> map<string, any>
  createSafeErrorResponse(
    403,
    "FORBIDDEN",
    "Access denied"
  )

fn createRateLimitErrorResponse() -> map<string, any>
  createSafeErrorResponse(
    429,
    "RATE_LIMIT_EXCEEDED",
    "Too many requests"
  )

fn createInternalErrorResponse() -> map<string, any>
  createSafeErrorResponse(
    500,
    "INTERNAL_ERROR",
    "An internal error occurred"
  )

// Request logging
struct RequestLog
  requestId: string
  timestamp: number
  method: string
  path: string
  statusCode: number
  userId: string
  ipAddress: string
  duration: number
  success: bool
  error: string

fn logRequest(
  requestId: string,
  method: string,
  path: string,
  statusCode: number,
  userId: string,
  ipAddress: string,
  duration: number,
  success: bool,
  error: string
) -> RequestLog
  {
    "requestId": requestId,
    "timestamp": getCurrentTime(),
    "method": method,
    "path": path,
    "statusCode": statusCode,
    "userId": userId,
    "ipAddress": ipAddress,
    "duration": duration,
    "success": success,
    "error": error
  }

// Sanitize log entries (remove sensitive data)
fn sanitizeLogEntry(entry: RequestLog) -> RequestLog
  entry["userId"] = redactSensitive(entry["userId"])
  entry["ipAddress"] = redactSensitive(entry["ipAddress"])
  entry

// Redact sensitive information
fn redactSensitive(value: string) -> string
  if value.length() == 0
    return value
  let firstChar = value[0]
  let lastChar = value[value.length() - 1]
  firstChar + "****" + lastChar

// Pattern matching (simplified)
fn matchesPattern(value: string, pattern: string) -> bool
  // Simplified: just check if pattern appears in value
  match pattern
    "email" -> value.length() > 0 && value.length() < 255
    "uuid" -> value.length() == 36
    "url" -> value.length() > 10
    _ -> true

// Size limit validation
fn checkPayloadSize(
  payload: array<number>,
  maxSize: number
) -> bool
  payload.length() <= maxSize

// SQL Injection prevention (parameterized queries)
fn escapeQueryString(input: string) -> string
  let escaped = ""
  for i = 0 to input.length()
    let c = input[i]
    match c
      "'" -> escaped = escaped + "''"
      "\"" -> escaped = escaped + "\"\""
      "\\" -> escaped = escaped + "\\\\"
      _ -> escaped = escaped + c
  escaped

// XSS prevention (HTML escape)
fn escapeHtml(input: string) -> string
  let escaped = ""
  for i = 0 to input.length()
    let c = input[i]
    match c
      "<" -> escaped = escaped + "&lt;"
      ">" -> escaped = escaped + "&gt;"
      "\"" -> escaped = escaped + "&quot;"
      "'" -> escaped = escaped + "&#x27;"
      "&" -> escaped = escaped + "&amp;"
      _ -> escaped = escaped + c
  escaped

// Get validation statistics
fn getValidationStats(logs: array<RequestLog>) -> string
  let totalRequests = logs.length()
  let successfulRequests = 0
  let failedRequests = 0
  let avgDuration = 0

  for log in logs
    if log["success"]
      successfulRequests = successfulRequests + 1
    else
      failedRequests = failedRequests + 1
    avgDuration = avgDuration + log["duration"]

  if totalRequests > 0
    avgDuration = avgDuration / totalRequests

  "Validation Statistics:\n" +
  "  Total Requests: " + toString(totalRequests) + "\n" +
  "  Successful: " + toString(successfulRequests) + "\n" +
  "  Failed: " + toString(failedRequests) + "\n" +
  "  Avg Duration: " + toString(avgDuration) + "ms"

