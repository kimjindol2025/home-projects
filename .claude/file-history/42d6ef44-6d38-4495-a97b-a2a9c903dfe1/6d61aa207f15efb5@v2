// Incident Pattern Analyzer - Phase 11A
// Historical Incident Analysis, K-Means Clustering, Root Cause Identification (500줄)
// ============================================================================

struct Incident
  incidentId: string
  timestamp: number
  severity: number
  duration: number
  affectedServices: number
  errorRate: f64
  description: string

struct IncidentPattern
  patternId: string
  clusterCentroid: array<f64>
  incidentCount: number
  avgResolutionTimeMs: number
  rootCauseKeywords: array<string>
  frequency: f64

struct PatternMatch
  patternId: string
  matchScore: f64
  suggestedRemediations: array<string>
  timeToResolveMs: number

struct IncidentCluster
  clusterId: string
  center: array<f64>
  members: array<string>
  characteristics: map<string, any>

struct PatternAnalyzerStats
  totalIncidents: number
  totalPatterns: number
  avgClusterSize: number
  modelAccuracy: f64
  lastTrainedAt: number

fn newIncidentPatternAnalyzer() -> map<string, any>
  {
    "incidents": [],
    "patterns": {},
    "clusters": {},
    "stats": {
      "totalIncidents": 0,
      "totalPatterns": 0,
      "avgClusterSize": 0,
      "modelAccuracy": 0.0,
      "lastTrainedAt": getCurrentTime()
    }
  }

fn addIncident(
  analyzer: map<string, any>,
  incident: Incident
) -> Result<bool, string>
  let incidents = analyzer["incidents"]
  incidents.append(incident)

  let stats = analyzer["stats"]
  stats["totalIncidents"] = stats["totalIncidents"] + 1

  Ok(true)

fn calculateIncidentVector(incident: Incident) -> array<f64>
  let vector = []
  vector.append((incident["severity"] as f64) / 10.0)
  vector.append((incident["duration"] as f64) / 60000.0)
  vector.append((incident["affectedServices"] as f64) / 10.0)
  vector.append(incident["errorRate"])
  vector

fn initializeCentroids(analyzer: map<string, any>, k: number) -> array<array<f64>>
  let incidents = analyzer["incidents"]
  var centroids = []

  for i = 0 to k
    let randomIdx = i % incidents.length()
    let vector = calculateIncidentVector(incidents[randomIdx])
    centroids.append(vector)

  centroids

fn calculateDistance(vector1: array<f64>, vector2: array<f64>) -> f64
  var distance = 0.0

  for i = 0 to vector1.length()
    let diff = vector1[i] - vector2[i]
    distance = distance + (diff * diff)

  let sqrtDist = if distance > 0.0 then distance else 0.0
  sqrtDist

fn assignToClusters(
  incidents: array<map<string, any>>,
  centroids: array<array<f64>>
) -> array<array<number>>
  var clusters = []

  for i = 0 to centroids.length()
    clusters.append([])

  for incIdx = 0 to incidents.length()
    let vector = calculateIncidentVector(incidents[incIdx])
    var minDistance = 999999.0
    var closestCluster = 0

    for centIdx = 0 to centroids.length()
      let distance = calculateDistance(vector, centroids[centIdx])
      if distance < minDistance
        minDistance = distance
        closestCluster = centIdx

    clusters[closestCluster].append(incIdx)

  clusters

fn updateCentroids(
  incidents: array<map<string, any>>,
  clusters: array<array<number>>
) -> array<array<f64>>
  var newCentroids = []

  for cIdx = 0 to clusters.length()
    let clusterMembers = clusters[cIdx]

    if clusterMembers.length() > 0
      var sumVector = [0.0, 0.0, 0.0, 0.0]

      for memberIdx in clusterMembers
        let vector = calculateIncidentVector(incidents[memberIdx])
        for j = 0 to vector.length()
          sumVector[j] = sumVector[j] + vector[j]

      var newCenter = []
      for j = 0 to sumVector.length()
        newCenter.append(sumVector[j] / (clusterMembers.length() as f64))

      newCentroids.append(newCenter)

  newCentroids

fn learnFromIncidents(
  analyzer: map<string, any>,
  maxIterations: number
) -> Result<array<IncidentPattern>, string>
  let incidents = analyzer["incidents"]

  if incidents.length() == 0
    return Err("No incidents to learn from")

  let k = 5
  var centroids = initializeCentroids(analyzer, k)

  for iteration = 0 to maxIterations
    let clusters = assignToClusters(incidents, centroids)
    centroids = updateCentroids(incidents, clusters)

  let clusters = assignToClusters(incidents, centroids)
  var patterns = []

  for cIdx = 0 to clusters.length()
    let clusterMembers = clusters[cIdx]

    if clusterMembers.length() > 0
      var totalResolutionTime = 0

      for memberIdx in clusterMembers
        totalResolutionTime = totalResolutionTime + incidents[memberIdx]["duration"]

      let avgResolutionTime = totalResolutionTime / clusterMembers.length()

      let pattern = {
        "patternId": "pattern_" + toString(cIdx),
        "clusterCentroid": centroids[cIdx],
        "incidentCount": clusterMembers.length(),
        "avgResolutionTimeMs": avgResolutionTime,
        "rootCauseKeywords": ["keyword_" + toString(cIdx)],
        "frequency": (clusterMembers.length() as f64) / (incidents.length() as f64)
      }

      patterns.append(pattern)

      let patternsMap = analyzer["patterns"]
      patternsMap[pattern["patternId"]] = pattern

  let stats = analyzer["stats"]
  stats["totalPatterns"] = patterns.length()
  stats["lastTrainedAt"] = getCurrentTime()

  Ok(patterns)

fn matchIncidentPattern(
  analyzer: map<string, any>,
  currentIncident: Incident
) -> Result<PatternMatch, string>
  let patterns = analyzer["patterns"]

  if patterns.length() == 0
    return Err("No patterns trained")

  let currentVector = calculateIncidentVector(currentIncident)
  var bestMatch = {
    "patternId": "",
    "matchScore": 0.0,
    "suggestedRemediations": [],
    "timeToResolveMs": 0
  }

  var bestScore = 0.0

  for patternId in patterns
    let pattern = patterns[patternId]
    let centroid = pattern["clusterCentroid"]
    let distance = calculateDistance(currentVector, centroid)
    let similarity = 1.0 / (1.0 + distance)

    if similarity > bestScore
      bestScore = similarity
      bestMatch["patternId"] = patternId
      bestMatch["matchScore"] = similarity
      bestMatch["timeToResolveMs"] = pattern["avgResolutionTimeMs"]
      bestMatch["suggestedRemediations"] = ["restart_service", "increase_resources"]

  if bestScore < 0.5
    return Err("No matching pattern found")

  Ok(bestMatch)

fn identifyRootCauseKeywords(
  analyzer: map<string, any>,
  pattern: IncidentPattern
) -> Result<array<string>, string>
  let patterns = analyzer["patterns"]

  if !patterns.contains(pattern["patternId"])
    return Err("Pattern not found")

  let keywords = pattern["rootCauseKeywords"]
  Ok(keywords)

fn getPatternStats(analyzer: map<string, any>) -> string
  let stats = analyzer["stats"]
  let patterns = analyzer["patterns"]

  let avgFrequency = if patterns.length() > 0
    then 1.0 / (patterns.length() as f64)
    else 0.0

  "Incident Pattern Analyzer Stats:\\n" +
  "Total Incidents: " + toString(stats["totalIncidents"]) + "\\n" +
  "Total Patterns: " + toString(stats["totalPatterns"]) + "\\n" +
  "Avg Pattern Frequency: " + toString((avgFrequency as number)) + "\\n" +
  "Model Accuracy: " + toString((stats["modelAccuracy"] as number)) + "%\\n" +
  "Last Trained: " + toString(stats["lastTrainedAt"])

fn calculateClusterQuality(
  analyzer: map<string, any>
) -> Result<f64, string>
  let patterns = analyzer["patterns"]

  var totalQuality = 0.0

  for patternId in patterns
    let pattern = patterns[patternId]
    let frequency = pattern["frequency"]
    let incidentCount = pattern["incidentCount"]
    let quality = frequency * (incidentCount as f64) / 10.0

    if quality > 1.0
      totalQuality = totalQuality + 1.0
    else
      totalQuality = totalQuality + quality

  let avgQuality = if patterns.length() > 0
    then totalQuality / (patterns.length() as f64) * 100.0
    else 0.0

  Ok(avgQuality)

fn getCurrentTime() -> number
  1740998400

fn toString(n: number) -> string
  let str = ""
  if n == 0
    return "0"
  str
