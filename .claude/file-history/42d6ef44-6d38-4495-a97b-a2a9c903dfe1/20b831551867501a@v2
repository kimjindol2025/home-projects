// ============================================================================
// Healing Decision Engine
// ============================================================================

fn assessSystemHealth(
  nodeHealthScores: array<f64>,
  networkLatencies: array<f64>,
  packetLoss: array<f64>
) -> f64
  // Weighted health calculation across cluster
  var nodeHealth = 0.0
  var networkHealth = 0.0
  var reliabilityHealth = 0.0

  // Node health: average of all nodes (50%)
  for i = 0 to nodeHealthScores.length()
    nodeHealth = nodeHealth + nodeHealthScores[i]
  nodeHealth = nodeHealth / (nodeHealthScores.length() as f64)

  // Network health: inverse of average latency (30%)
  var avgLatency = 0.0
  for i = 0 to networkLatencies.length()
    avgLatency = avgLatency + networkLatencies[i]
  avgLatency = avgLatency / (networkLatencies.length() as f64)

  networkHealth = if avgLatency > 100.0 then 0.3
    else if avgLatency > 50.0 then 0.6
    else if avgLatency > 20.0 then 0.8
    else 0.95

  // Reliability health: inverse of packet loss (20%)
  var avgLoss = 0.0
  for i = 0 to packetLoss.length()
    avgLoss = avgLoss + packetLoss[i]
  avgLoss = avgLoss / (packetLoss.length() as f64)

  reliabilityHealth = if avgLoss > 10.0 then 0.3
    else if avgLoss > 5.0 then 0.6
    else if avgLoss > 1.0 then 0.8
    else 0.95

  let overallHealth = (nodeHealth * 0.5) +
                      (networkHealth * 0.3) +
                      (reliabilityHealth * 0.2)

  overallHealth

