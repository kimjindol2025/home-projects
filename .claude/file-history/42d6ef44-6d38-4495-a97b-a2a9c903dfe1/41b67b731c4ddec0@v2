  output = output + "L1 Hit Rate: " + (report.l1HitRate * 100.0 as number as string) + "%\\\\n"
  output = output + "L2 Hit Rate: " + (report.l2HitRate * 100.0 as number as string) + "%\\\\n"
  output = output + "L3 Hit Rate: " + (report.l3HitRate * 100.0 as number as string) + "%\\\\n"
  output = output + "Overall Hit Rate: " + (report.hitRate * 100.0 as number as string) + "%\\\\n"

  output = output + "\\\\n--- Performance ---\\\\n"
  output = output + "Average Latency: " + (report.averageLatencyNs as string) + "ns\\\\n"
  output = output + "Cache Efficiency: " + report.cacheEfficiency + "\\\\n"
  output = output + "Optimization Score: " + (report.optimizationScore as string) + "/100\\\\n"

  output = output + "\\\\n--- Invariants ---\\\\n"
  output = output + "Hit Rate > 95%: " + if report.hitRate > 0.95 then "YES ✓" else "NO ⚠️" + "\\\\n"
  output = output + "Miss Rate < 5%: " + if report.missRate < 0.05 then "YES ✓" else "NO ⚠️" + "\\\\n"

  output
