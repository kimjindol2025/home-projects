fn testOptimalBatchSizeCalculation()
  // 무관용: Batch size 계산이 정확 (network latency 고려)

  let batchSize = findOptimalBatchSize(100, 2, 100)  // 100µs net, 2µs proc, 100µs max

  assert(batchSize >= 1, "Batch size must be at least 1")
  assert(batchSize <= 128, "Batch size must not exceed 128")
  // Expected: (100-100)/2 = 0, clamped to 1
  assert(batchSize == 1, "Extremely tight budget should result in batch size 1")

fn testOptimalBatchSizeWithSlack()
  // 무관용: Network 여유 있을 때 큰 batch

  let batchSize = findOptimalBatchSize(100, 2, 500)  // 100µs net, 2µs proc, 500µs max

  // Expected: (500-100)/2 = 200, clamped to 128
  assert(batchSize == 128, "Abundant budget should max out batch size at 128")

fn testOptimalPrefetchDistance()
  // 무관용: Prefetch distance 계산 (memory latency 기반)

  let distance = findOptimalPrefetchDistance(3.5, 4000, 64)

  assert(distance >= 1, "Prefetch distance must be at least 1")
  assert(distance <= 10, "Prefetch distance limited to 10 cache lines")

fn testConvergenceDetection()
  // 무관용: Convergence 감지 (< 1% change over 10 iterations)

  let history = {
    "parameters": [],
    "feedbacks": [
      { "parameterId": "p1", "previousValue": 32, "newValue": 33, "metricsImprovement": 0.5, "timestamp": 0, "isPositive": true },
      { "parameterId": "p1", "previousValue": 33, "newValue": 33, "metricsImprovement": 0.1, "timestamp": 1, "isPositive": true },
      { "parameterId": "p1", "previousValue": 33, "newValue": 33, "metricsImprovement": 0.1, "timestamp": 2, "isPositive": false },
      { "parameterId": "p1", "previousValue": 33, "newValue": 33, "metricsImprovement": 0.0, "timestamp": 3, "isPositive": false },
      { "parameterId": "p1", "previousValue": 33, "newValue": 33, "metricsImprovement": 0.05, "timestamp": 4, "isPositive": false },
      { "parameterId": "p1", "previousValue": 33, "newValue": 33, "metricsImprovement": 0.0, "timestamp": 5, "isPositive": false },
      { "parameterId": "p1", "previousValue": 33, "newValue": 33, "metricsImprovement": 0.1, "timestamp": 6, "isPositive": true },
      { "parameterId": "p1", "previousValue": 33, "newValue": 33, "metricsImprovement": 0.05, "timestamp": 7, "isPositive": false },
      { "parameterId": "p1", "previousValue": 33, "newValue": 33, "metricsImprovement": 0.0, "timestamp": 8, "isPositive": false },
      { "parameterId": "p1", "previousValue": 33, "newValue": 33, "metricsImprovement": 0.1, "timestamp": 9, "isPositive": true }
    ],
    "bestLatencyUs": 820,
    "iterationCount": 10,
    "convergenceReached": false
  }

  let (converged, iterations) = trackParameterConvergence(history)
  // Average change = (0.5 + 0.1 + 0.1 + 0 + 0.05 + 0 + 0.1 + 0.05 + 0 + 0.1) / 10 = 0.09%
  assert(converged == true, "Should detect convergence with <1% avg change")

