fn testWorkloadClassification_CacheIntensive()
  // 무관용: Cache-intensive workload 정확히 분류 (accuracy > 95%)

  let profile = buildWorkloadProfile(0.9, 2000000, 50, 0.1, 0.02)
  let decision = recommendOptimizationLayer(profile, 850)

  // Assert: Cache-intensive should recommend "cache" layer
  assert(decision.recommendedLayer == "cache", "Cache-intensive workload should recommend 'cache' layer")
  assert(decision.priority == 4, "Cache optimization should have highest priority (4)")
  assert(decision.confidence > 0.80, "Decision confidence should exceed 80%")
  assert(decision.estimatedImprovement > 0.40, "Cache opt should achieve > 40% improvement")

