fn buildDefaultSchema(schema: GraphQLSchema) -> Result<GraphQLSchema, string>
  // Define scalar types
  defineType(schema, "String", {}, "String scalar")
  defineType(schema, "Int", {}, "Integer scalar")
  defineType(schema, "Float", {}, "Float scalar")
  defineType(schema, "Boolean", {}, "Boolean scalar")
  defineType(schema, "ID", {}, "ID scalar")

  // Define custom types
  defineType(schema, "Vector", {
    "id": { "type": "ID", "nullable": false },
    "dimensions": { "type": "[Float]", "nullable": false },
    "metadata": { "type": "String", "nullable": true },
    "timestamp": { "type": "Int", "nullable": false }
  }, "Vector type")

  defineType(schema, "SearchResult", {
    "vectorId": { "type": "ID", "nullable": false },
    "score": { "type": "Float", "nullable": false },
    "vector": { "type": "Vector", "nullable": false }
  }, "Search result type")

  defineType(schema, "InsertResult", {
    "success": { "type": "Boolean", "nullable": false },
    "vectorId": { "type": "ID", "nullable": true },
    "quorumAchieved": { "type": "Boolean", "nullable": false }
  }, "Insert result type")

  defineType(schema, "DeleteResult", {
    "success": { "type": "Boolean", "nullable": false },
    "deletedId": { "type": "ID", "nullable": true }
  }, "Delete result type")

  defineType(schema, "Metrics", {
    "requestsPerSecond": { "type": "Float", "nullable": false },
    "latencyP99": { "type": "Float", "nullable": false },
    "cacheHitRate": { "type": "Float", "nullable": false },
    "timestamp": { "type": "Int", "nullable": false }
  }, "Metrics type")

  defineType(schema, "ClusterStatus", {
    "activeNodes": { "type": "Int", "nullable": false },
    "deadNodes": { "type": "Int", "nullable": false },
    "health": { "type": "String", "nullable": false }
  }, "Cluster status type")

  defineType(schema, "ConfigResult", {
    "success": { "type": "Boolean", "nullable": false },
    "message": { "type": "String", "nullable": false }
  }, "Config result type")

  defineType(schema, "BackupResult", {
    "success": { "type": "Boolean", "nullable": false },
    "snapshotId": { "type": "ID", "nullable": true }
  }, "Backup result type")

  defineType(schema, "DeleteEvent", {
    "vectorId": { "type": "ID", "nullable": false },
    "timestamp": { "type": "Int", "nullable": false }
  }, "Delete event type")

  defineEnumType(schema, "Environment", ["DEVELOPMENT", "STAGING", "PRODUCTION"], "Deployment environment")

  // Define root types
  defineQueryType(schema)
  defineMutationType(schema)
  defineSubscriptionType(schema)

  Ok(schema)

fn validateSchema(schema: GraphQLSchema) -> Result<bool, string>
  let types = schema["types"]

  if !types.contains(schema["queryType"])
    return Err("Query type not defined")

  if !types.contains(schema["mutationType"])
    return Err("Mutation type not defined")

  Ok(true)

fn generateSdl(schema: GraphQLSchema) -> Result<string, string>
  let sdl = "# FreeLang Distributed Vector Index GraphQL Schema\n\n"

  let types = schema["types"]
  for typeName in types
    let graphQLType = types[typeName]
    let fields = graphQLType["fields"]

    if graphQLType["isEnum"]
      sdl = sdl + "enum " + typeName + " {\n"
      let values = graphQLType["enumValues"]
      for i = 0 to values.length()
        sdl = sdl + "  " + values[i] + "\n"
      sdl = sdl + "}\n\n"
    else
      sdl = sdl + "type " + typeName + " {\n"
      for fieldName in fields
        sdl = sdl + "  " + fieldName + ": " + fields[fieldName]["type"] + "\n"
      sdl = sdl + "}\n\n"

  Ok(sdl)

fn introspect(schema: GraphQLSchema) -> Result<IntrospectionResult, string>
  let types = schema["types"]
  let typesList = []

  for typeName in types
    typesList.append({
      "name": typeName,
      "kind": "OBJECT",
      "description": types[typeName]["description"]
    })

  let result = {
    "types": typesList,
    "queryType": schema["queryType"],
    "mutationType": schema["mutationType"],
    "directives": ["skip", "include", "deprecated"]
  }

  Ok(result)

fn getSchemaStats(schema: GraphQLSchema) -> string
  let types = schema["types"]
  var fieldCount = 0

  for typeName in types
    let graphQLType = types[typeName]
    fieldCount = fieldCount + graphQLType["fields"].length()

  "GraphQL Schema Stats:\n" +
  "Total Types: " + toString(types.length()) + "\n" +
  "Total Fields: " + toString(fieldCount) + "\n" +
  "Query Type: " + schema["queryType"] + "\n" +
  "Mutation Type: " + schema["mutationType"] + "\n" +
  "Subscription Type: " + schema["subscriptionType"]

fn toString(n: number) -> string
  let str = ""
  if n == 0
    return "0"
  str
