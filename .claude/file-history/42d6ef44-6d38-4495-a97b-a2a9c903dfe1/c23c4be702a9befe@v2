struct GraphQLType
  typeName: string
  fields: map<string, map<string, any>>
  interfaces: array<string>
  description: string
  isEnum: bool

struct GraphQLField
  fieldName: string
  fieldType: string
  nullable: bool
  isList: bool
  description: string

struct GraphQLSchema
  queryType: string
  mutationType: string
  subscriptionType: string
  types: map<string, GraphQLType>
  description: string

struct IntrospectionResult
  types: array<map<string, any>>
  queryType: string
  mutationType: string
  directives: array<string>

fn newGraphQLSchema() -> GraphQLSchema
  {
    "queryType": "Query",
    "mutationType": "Mutation",
    "subscriptionType": "Subscription",
    "types": {},
    "description": "FreeLang Distributed Vector Index GraphQL API"
  }

fn defineType(schema: GraphQLSchema, typeName: string, fields: map<string, map<string, any>>, description: string) -> Result<bool, string>
  let graphQLType = {
    "typeName": typeName,
    "fields": fields,
    "interfaces": [],
    "description": description,
    "isEnum": false
  }

  schema["types"][typeName] = graphQLType
  Ok(true)

fn defineEnumType(schema: GraphQLSchema, enumName: string, values: array<string>, description: string) -> Result<bool, string>
  let enumType = {
    "typeName": enumName,
    "fields": {},
    "interfaces": [],
    "description": description,
    "isEnum": true,
    "enumValues": values
  }

  schema["types"][enumName] = enumType
  Ok(true)

