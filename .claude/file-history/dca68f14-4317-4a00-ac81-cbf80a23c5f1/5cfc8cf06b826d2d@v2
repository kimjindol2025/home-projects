fn assert_true(actual, msg) {
  if actual {
    println("✓ " + msg)
    return true
  }
  println("✗ FAILED: " + msg)
  return false
}

fn assert_equal(actual, expected, msg) {
  if actual == expected {
    println("✓ " + msg)
    return true
  }
  println("✗ FAILED: " + msg)
  println("  Expected: " + expected)
  println("  Actual: " + actual)
  return false
}

// ─────────────────────────────────────────────────────────────
// Setup Helper: Initialize Plan with Task IDs
// ─────────────────────────────────────────────────────────────

fn setup_plan(agent, task_count) {
  if task_count >= 1 { Task_setId(0, "task-1") }
  if task_count >= 2 { Task_setId(1, "task-2") }
  if task_count >= 3 { Task_setId(2, "task-3") }
  if task_count >= 4 { Task_setId(3, "task-4") }
  if task_count >= 5 { Task_setId(4, "task-5") }

  return 1
}

// ─────────────────────────────────────────────────────────────
// TEST 1: Successful Execution (No Replan)
// ─────────────────────────────────────────────────────────────

fn test_01_no_replan_success() {
  println("")
  println("🧪 TEST 1: Successful Execution (No Replan Needed)")

  let agent = Agent_new(3)
  setup_plan(agent, 3)

  // No failure
  let success = Agent_run(agent, -1, 2)

  assert_true(success, "Execution completed successfully")
  assert_equal(Agent_state(), STATE_COMPLETED, "Final state: Completed")
  assert_equal(Agent_taskCount(), 3, "Task count unchanged (3)")
  assert_equal(Agent_replanCount(), 0, "Replan count: 0")

  println("✅ TEST 1 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 2: Failure → Add Task Via Replan
// ─────────────────────────────────────────────────────────────

fn test_02_replan_add_task() {
  println("")
  println("🧪 TEST 2: Failure → Add Task Via Replan")

  let agent = Agent_new(3)
  setup_plan(agent, 3)

  // Task 1 fails
  let success = Agent_run(agent, 1, 2)

  assert_true(success, "Execution completed after replan")
  assert_equal(Agent_state(), STATE_COMPLETED, "Final state: Completed")
  assert_equal(Agent_taskCount(), 4, "Task count increased to 4 (replan added 1)")
  assert_equal(Agent_replanCount(), 1, "Replan count: 1")

  // Verify new task was inserted at index 1
  let new_task_id = Task_getId(1)
  assert_true(new_task_id != "task-2", "New task inserted at index 1")

  println("✅ TEST 2 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 3: MaxReplans Exceeded → Failed
// ─────────────────────────────────────────────────────────────

fn test_03_maxreplans_exceeded() {
  println("")
  println("🧪 TEST 3: MaxReplans Exceeded → Failed")

  let agent = Agent_new(3)
  setup_plan(agent, 3)

  // Task 1 fails, but max_replans = 0 (no retries allowed)
  let success = Agent_run(agent, 1, 0)

  assert_true(success == false, "Execution failed")
  assert_equal(Agent_state(), STATE_FAILED, "Final state: Failed")
  assert_equal(Agent_replanCount(), 0, "Replan count: 0 (not allowed)")

  println("✅ TEST 3 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 4: Task Replacement Verification
// ─────────────────────────────────────────────────────────────

fn test_04_task_replacement() {
  println("")
  println("🧪 TEST 4: Task Replacement via PlanDelta")

  let agent = Agent_new(3)
  setup_plan(agent, 3)

  // Create REPLACE delta
  let delta = PlanDelta_new(PLAN_DELTA_REPLACE, 1, "task-modified")

  let applied = Plan_applyDelta(delta)

  assert_true(applied, "Delta applied successfully")
  assert_equal(Task_getId(1), "task-modified", "Task at index 1 replaced")
  assert_equal(Agent_taskCount(), 3, "Task count unchanged (3)")
  assert_equal(Task_getStatus(1), TASK_STATUS_PENDING, "Replaced task is Pending")

  println("✅ TEST 4 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 5: Plan Integrity Validation
// ─────────────────────────────────────────────────────────────

fn test_05_plan_integrity() {
  println("")
  println("🧪 TEST 5: Plan Integrity Validation")

  // Valid count
  let valid_3 = Plan_validate(3)
  assert_true(valid_3, "3 tasks is valid")

  // Valid count (max)
  let valid_5 = Plan_validate(5)
  assert_true(valid_5, "5 tasks (max) is valid")

  // Invalid count (too many)
  let invalid_6 = Plan_validate(6)
  assert_true(invalid_6 == false, "6 tasks exceeds max")

  // Invalid count (too few)
  let invalid_0 = Plan_validate(0)
  assert_true(invalid_0 == false, "0 tasks is invalid")

  println("✅ TEST 5 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 6: Current Index Recalculation After Replan
// ─────────────────────────────────────────────────────────────

fn test_06_index_recalculation() {
  println("")
  println("🧪 TEST 6: Current Index Recalculation After Replan")

  let agent = Agent_new(2)
  setup_plan(agent, 2)

  // Manually simulate replan: add task at index 0
  let delta = PlanDelta_new(PLAN_DELTA_ADD, 0, "task-new")

  let initial_count = Agent_taskCount()
  assert_equal(initial_count, 2, "Initial task count: 2")

  let applied = Plan_applyDelta(delta)
  assert_true(applied, "Delta applied")

  let new_count = Agent_taskCount()
  assert_equal(new_count, 3, "Task count increased to 3")

  // Old tasks should still be there, shifted
  let task_0_id = Task_getId(0)
  let task_1_id = Task_getId(1)
  let task_2_id = Task_getId(2)

  assert_equal(task_0_id, "task-new", "New task at index 0")
  assert_equal(task_1_id, "task-1", "Original task-1 now at index 1")
  assert_equal(task_2_id, "task-2", "Original task-2 now at index 2")

  println("✅ TEST 6 PASSED")
}

