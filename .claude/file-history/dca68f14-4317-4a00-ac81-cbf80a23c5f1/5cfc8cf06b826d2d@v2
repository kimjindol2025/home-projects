// ─────────────────────────────────────────────────────────────
// Mock Tool Execution
// ─────────────────────────────────────────────────────────────

fn execute_task_tool(task_index, should_fail) {
  if should_fail {
    return Observation_new(OBSERVATION_FAILURE, "Task execution failed")
  }

  let task_id = Task_getId(task_index)
  return Observation_new(OBSERVATION_SUCCESS, task_id + " completed")
}

// ─────────────────────────────────────────────────────────────
// Reflector Interface
// ─────────────────────────────────────────────────────────────

fn Reflector_evaluate(observation) {
  if Observation_isSuccess(observation) {
    return REFLECTION_CONTINUE
  }

  return REFLECTION_ABORT
}

// ─────────────────────────────────────────────────────────────
// Replanner Interface
// ─────────────────────────────────────────────────────────────

fn Replanner_canReplan(replan_count, max_replans) {
  if replan_count >= max_replans {
    return false
  }

  return true
}

fn Replanner_generateDelta(current_index, error_message) {
  // 실패한 task 다음에 새 task 추가
  // 예: task 1이 실패 → task-retry 추가

  let new_task_id = "task-retry-" + current_index

  // ADD operation: current_index 위치에 새 task 추가
  return PlanDelta_new(PLAN_DELTA_ADD, current_index, new_task_id)
}

// ─────────────────────────────────────────────────────────────
// Plan Integrity Validation
// ─────────────────────────────────────────────────────────────

fn Plan_validate(total_count) {
  // Task count는 최대 5개 제한
  if total_count > 5 {
    return false
  }

  if total_count < 1 {
    return false
  }

  return true
}

// ─────────────────────────────────────────────────────────────
// Plan Delta Application
// ─────────────────────────────────────────────────────────────

fn Plan_applyDelta(delta) {
  let operation = PlanDelta_operation(delta)
  let task_index = PlanDelta_taskIndex(delta)
  let new_task_id = PlanDelta_newTaskId(delta)

  let current_count = Agent_taskCount()

  // ADD: current_index 위치에 새 task 삽입 후 뒤의 것들 밀어내기
  if operation == PLAN_DELTA_ADD {
    // 현재 plan: [t0, t1, t2], add t-new at index 1 → [t0, t-new, t1, t2]

    if current_count >= 5 {
      return false  // 최대 개수 초과
    }

    // 뒤에서부터 앞으로 한 칸씩 이동
    if current_count > task_index {
      // 4번 task를 5번으로 (만약 있으면)
      let last_id = Task_getId(current_count - 1)
      if last_id != "" {
        Task_setId(current_count, last_id)
        Task_setStatus(current_count, Task_getStatus(current_count - 1))
        Task_setOutput(current_count, Task_getOutput(current_count - 1))
      }

      // 3번 task를 4번으로
      if current_count > task_index + 1 {
        let prev_id = Task_getId(current_count - 2)
        if prev_id != "" {
          Task_setId(current_count - 1, prev_id)
          Task_setStatus(current_count - 1, Task_getStatus(current_count - 2))
          Task_setOutput(current_count - 1, Task_getOutput(current_count - 2))
        }
      }
    }

    // 새 task를 현재 위치에 삽입
    Task_setId(task_index, new_task_id)
    Task_setStatus(task_index, TASK_STATUS_PENDING)
    Task_setOutput(task_index, "")

    // Task 개수 증가
    let new_count = current_count + 1
    Agent_setTaskCount(new_count)

    return Plan_validate(new_count)
  }

  // REPLACE: task_index의 task 교체
  if operation == PLAN_DELTA_REPLACE {
    Task_setId(task_index, new_task_id)
    Task_setStatus(task_index, TASK_STATUS_PENDING)
    Task_setOutput(task_index, "")

    return true
  }

  // REMOVE: task_index의 task 제거 후 뒤의 것들 당기기
  if operation == PLAN_DELTA_REMOVE {
    if current_count <= 1 {
      return false  // 최소 1개 task 필요
    }

    // task_index부터 뒤의 것들을 한 칸씩 앞으로 이동
    if task_index < current_count - 1 {
      // 현재 index+1 → index
      let next_id = Task_getId(task_index + 1)
      Task_setId(task_index, next_id)
      Task_setStatus(task_index, Task_getStatus(task_index + 1))
      Task_setOutput(task_index, Task_getOutput(task_index + 1))
    }

    // Task 개수 감소
    let new_count = current_count - 1
    Agent_setTaskCount(new_count)

    return Plan_validate(new_count)
  }

  return false
}

// ─────────────────────────────────────────────────────────────
// Execution Loop with Replanning
// ─────────────────────────────────────────────────────────────

fn Agent_run(agent, should_fail_task_index, max_replans) {
  Agent_setState(STATE_EXECUTING)

  let current_index = Agent_currentIndex()
  let task_count = Agent_taskCount()
  let step_counter = 0
  let max_steps = 50

  // Main execution loop
  while current_index < task_count {
    // MaxSteps guard
    if step_counter >= max_steps {
      GLOBAL_EXECUTION_ERROR = "MaxSteps exceeded"
      Agent_setState(STATE_FAILED)
      return false
    }

    // Execute task
    let task_id = Task_getId(current_index)
    Task_setStatus(current_index, TASK_STATUS_RUNNING)

    let should_fail = (current_index == should_fail_task_index)
    let observation = execute_task_tool(current_index, should_fail)

    // Reflection stage
    Agent_setState(STATE_REFLECTING)

    let reflection_result = Reflector_evaluate(observation)

    if reflection_result == REFLECTION_CONTINUE {
      // Success: mark as done and advance
      Task_setStatus(current_index, TASK_STATUS_DONE)
      Task_setOutput(current_index, Observation_message(observation))

      current_index = current_index + 1
      Agent_setCurrentIndex(current_index)
      step_counter = step_counter + 1

      Agent_setState(STATE_EXECUTING)
    } else if reflection_result == REFLECTION_ABORT {
      // Failure: attempt replan
      Agent_setState(STATE_REPLANNING)

      let replan_count = Agent_replanCount()

      if Replanner_canReplan(replan_count, max_replans) {
        // Generate delta
        let delta = Replanner_generateDelta(current_index, Observation_message(observation))

        // Apply delta
        let delta_applied = Plan_applyDelta(delta)

        if delta_applied {
          // Replan succeeded
          Agent_incrementReplanCount()

          // current_index는 유지 (새로운 task가 현재 위치에 삽입됨)
          // task_count는 증가함
          task_count = Agent_taskCount()

          step_counter = step_counter + 1
          Agent_setState(STATE_EXECUTING)
        } else {
          // Delta application failed
          GLOBAL_EXECUTION_ERROR = "Plan modification failed"
          Agent_setState(STATE_FAILED)
          return false
        }
      } else {
        // Max replans exceeded
        Task_setStatus(current_index, TASK_STATUS_ERROR)
        GLOBAL_EXECUTION_ERROR = "Max replans exceeded"
        Agent_setState(STATE_FAILED)
        return false
      }
    }
  }

  // All tasks completed
  Agent_setState(STATE_COMPLETED)
  return true
}

