// ─────────────────────────────────────────────────────────────
// Agent State Constants
// ─────────────────────────────────────────────────────────────

let STATE_IDLE = 0
let STATE_PLANNING = 1
let STATE_EXECUTING = 2
let STATE_REFLECTING = 3
let STATE_REPLANNING = 6
let STATE_COMPLETED = 4
let STATE_FAILED = 5

fn state_name(state) {
  if state == STATE_IDLE { return "Idle" }
  if state == STATE_PLANNING { return "Planning" }
  if state == STATE_EXECUTING { return "Executing" }
  if state == STATE_REFLECTING { return "Reflecting" }
  if state == STATE_REPLANNING { return "Replanning" }
  if state == STATE_COMPLETED { return "Completed" }
  if state == STATE_FAILED { return "Failed" }
  return "Unknown"
}

// ─────────────────────────────────────────────────────────────
// Task Status Constants
// ─────────────────────────────────────────────────────────────

let TASK_STATUS_PENDING = 0
let TASK_STATUS_RUNNING = 1
let TASK_STATUS_DONE = 2
let TASK_STATUS_ERROR = 3

fn task_status_name(status) {
  if status == TASK_STATUS_PENDING { return "Pending" }
  if status == TASK_STATUS_RUNNING { return "Running" }
  if status == TASK_STATUS_DONE { return "Done" }
  if status == TASK_STATUS_ERROR { return "Error" }
  return "Unknown"
}

// ─────────────────────────────────────────────────────────────
// Reflection Result Constants
// ─────────────────────────────────────────────────────────────

let REFLECTION_CONTINUE = 1
let REFLECTION_RETRY = 2
let REFLECTION_ABORT = 3

fn reflection_result_name(result) {
  if result == REFLECTION_CONTINUE { return "Continue" }
  if result == REFLECTION_RETRY { return "Retry" }
  if result == REFLECTION_ABORT { return "Abort" }
  return "Unknown"
}

// ─────────────────────────────────────────────────────────────
// PlanDelta Operation Constants
// ─────────────────────────────────────────────────────────────

let PLAN_DELTA_ADD = 1
let PLAN_DELTA_REPLACE = 2
let PLAN_DELTA_REMOVE = 3

fn plan_delta_op_name(op) {
  if op == PLAN_DELTA_ADD { return "Add" }
  if op == PLAN_DELTA_REPLACE { return "Replace" }
  if op == PLAN_DELTA_REMOVE { return "Remove" }
  return "Unknown"
}

// ─────────────────────────────────────────────────────────────
// Observation (Task 실행 결과)
// ─────────────────────────────────────────────────────────────

let OBSERVATION_SUCCESS = 0
let OBSERVATION_FAILURE = 1

fn Observation_new(is_success, message) {
  return [is_success, message]
}

fn Observation_isSuccess(obs) {
  return obs[0] == OBSERVATION_SUCCESS
}

fn Observation_message(obs) {
  return obs[1]
}

// ─────────────────────────────────────────────────────────────
// PlanDelta Structure
// [operation, task_index, new_task_id]
// ─────────────────────────────────────────────────────────────

fn PlanDelta_new(operation, task_index, new_task_id) {
  return [operation, task_index, new_task_id]
}

fn PlanDelta_operation(delta) {
  return delta[0]
}

fn PlanDelta_taskIndex(delta) {
  return delta[1]
}

fn PlanDelta_newTaskId(delta) {
  return delta[2]
}

