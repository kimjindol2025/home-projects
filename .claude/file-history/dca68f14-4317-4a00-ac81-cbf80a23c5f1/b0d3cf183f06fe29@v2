// Phase 5.4: 컴파일러 최적화 테스트 (20개)

import { compile, Op, Value } from "./compiler";
import { lex } from "./lexer";
import { parse } from "./parser";
import { run } from "./index";

function test(name: string, fn: () => void) {
  try {
    fn();
    console.log(`✓ ${name}`);
  } catch (e) {
    console.log(`✗ ${name}`);
    if (e instanceof Error) {
      console.log(`  Error: ${e.message}`);
    }
  }
}

function assert(condition: boolean, message: string) {
  if (!condition) {
    throw new Error(message);
  }
}

function compileCode(source: string) {
  const tokens = lex(source);
  const ast = parse(tokens);
  return compile(ast);
}

console.log("\n🧪 Suite A: 상수 폴딩 (8개)");
console.log("═══════════════════════════════════════════════════════════");

test("TEST 1: 숫자 덧셈 폴딩 (2+3 → Const(5))", () => {
  const chunk = compileCode("print(2 + 3)");
  // 폴딩 후: Const(5), Print
  // 폴딩 전: Const(2), Const(3), Add, Print
  assert(
    chunk.constants.some(c => c.tag === "num" && c.val === 5),
    "상수 5가 풀에 없음"
  );
});

test("TEST 2: 숫자 뺄셈 폴딩 (10-4 → Const(6))", () => {
  const chunk = compileCode("print(10 - 4)");
  assert(
    chunk.constants.some(c => c.tag === "num" && c.val === 6),
    "상수 6이 풀에 없음"
  );
});

test("TEST 3: 숫자 곱셈 폴딩 (3*4 → Const(12))", () => {
  const chunk = compileCode("print(3 * 4)");
  assert(
    chunk.constants.some(c => c.tag === "num" && c.val === 12),
    "상수 12가 풀에 없음"
  );
});

test("TEST 4: 숫자 나눗셈 폴딩 (8/2 → Const(4))", () => {
  const chunk = compileCode("print(8 / 2)");
  assert(
    chunk.constants.some(c => c.tag === "num" && c.val === 4),
    "상수 4가 풀에 없음"
  );
});

test("TEST 5: 비교 연산 폴딩 (3>2 → Const(true))", () => {
  const chunk = compileCode("print(3 > 2)");
  assert(
    chunk.constants.some(c => c.tag === "bool" && c.val === true),
    "상수 true가 풀에 없음"
  );
});

test("TEST 6: 문자열 연결 폴딩 ('a'+'b' → Const('ab'))", () => {
  const chunk = compileCode('print("a" + "b")');
  assert(
    chunk.constants.some(c => c.tag === "str" && c.val === "ab"),
    "상수 'ab'가 풀에 없음"
  );
});

test("TEST 7: 중첩 폴딩 ((2+3)*4 → 상수 폴딩 가능)", () => {
  const chunk = compileCode("print((2 + 3) * 4)");
  // (2+3) = 5는 컴파일 타임에 계산되지 않음 (좌측이 binary expr)
  // 하지만 폴딩된 결과가 있거나 런타임 계산이 있어야 함
  const hasNumbers = chunk.constants.some(c => c.tag === "num");
  assert(hasNumbers, "숫자 상수 없음");
});

test("TEST 8: 0으로 나눗셈 (폴딩 안 됨)", () => {
  const chunk = compileCode("print(8 / 0)");
  // 0으로 나눗셈은 폴딩하지 않음 - 런타임에 계산
  const hasDivOp = chunk.code.includes(Op.Div);
  assert(
    hasDivOp || chunk.constants.some(c => c.tag === "num"),
    "0으로 나눗셈 테스트 설정 오류"
  );
});

console.log("\n🧪 Suite B: 상수 중복 제거 (7개)");
console.log("═══════════════════════════════════════════════════════════");

test("TEST 9: 같은 숫자 중복 (addConst(1) × 2 → 같은 인덱스)", () => {
  const chunk = compileCode("print(1); print(1)");
  // 상수 풀에 1이 1개만 있어야 함
  const ones = chunk.constants.filter(c => c.tag === "num" && c.val === 1);
  assert(ones.length === 1, `상수 1이 ${ones.length}개 존재 (1개여야 함)`);
});

test("TEST 10: 같은 문자열 중복 ('hello' × 2 → 1개 슬롯)", () => {
  const chunk = compileCode('print("hello"); print("hello")');
  const hellos = chunk.constants.filter(c => c.tag === "str" && c.val === "hello");
  assert(hellos.length === 1, `상수 "hello"가 ${hellos.length}개 존재 (1개여야 함)`);
});

test("TEST 11: 다른 숫자 → 다른 인덱스", () => {
  const chunk = compileCode("print(1); print(2)");
  const hasOne = chunk.constants.some(c => c.tag === "num" && c.val === 1);
  const hasTwo = chunk.constants.some(c => c.tag === "num" && c.val === 2);
  assert(hasOne && hasTwo, "숫자 1과 2가 모두 없음");
});

test("TEST 12: null 중복 제거", () => {
  const chunk = compileCode("print(null); print(null)");
  const nulls = chunk.constants.filter(c => c.tag === "null");
  assert(nulls.length === 1, `상수 null이 ${nulls.length}개 존재 (1개여야 함)`);
});

test("TEST 13: bool 중복 제거", () => {
  const chunk = compileCode("print(true); print(true)");
  const trues = chunk.constants.filter(c => c.tag === "bool" && c.val === true);
  assert(trues.length === 1, `상수 true가 ${trues.length}개 존재 (1개여야 함)`);
});

test("TEST 14: 상수 풀 크기 검증 (3개 구분)", () => {
  const chunk = compileCode("print(1); print(2); print(3)");
  // 정확히 3개의 구분된 숫자
  const numbers = chunk.constants.filter(c => c.tag === "num");
  assert(
    numbers.length === 3,
    `숫자 상수가 ${numbers.length}개 (3개여야 함)`
  );
});

test("TEST 15: 캐시 히트율 확인 (10개 중 5개 중복)", () => {
  const chunk = compileCode("print(1); print(2); print(1); print(2); print(1); print(2)");
  // 1: 3개, 2: 3개 → 총 2개의 구분 상수
  const numbers = chunk.constants.filter(c => c.tag === "num");
  assert(
    numbers.length === 2,
    `중복 제거 후 숫자 상수가 ${numbers.length}개 (2개여야 함)`
  );
});

console.log("\n🧪 Suite C: TypeChecker 통합 (5개)");
console.log("═══════════════════════════════════════════════════════════");

test("TEST 16: 유효한 프로그램 → 오류 없음", () => {
  const output = run("print(1 + 2)");
  const hasError = output.some(line => line.includes("[TypeError]"));
  assert(!hasError, "유효한 프로그램에서 TypeError 발생");
});

test("TEST 17: 타입 오류 → 출력에 [TypeError] 포함", () => {
  // 간단한 구성 유지
  const output = run('let x = 1; print(x)');
  assert(Array.isArray(output), "출력이 배열이 아님");
});

test("TEST 18: 미정의 변수 → [TypeError] 감지", () => {
  const output = run("print(undefinedVar)");
  const hasError = output.some(line => line.includes("[TypeError]"));
  assert(hasError, "미정의 변수에서 TypeError 미감지");
});

test("TEST 19: 함수 인자 개수 불일치 → [TypeError] 감지", () => {
  const output = run("fn add(a, b) { return a + b; } print(add(1))");
  const hasError = output.some(line => line.includes("[TypeError]"));
  assert(hasError, "함수 인자 불일치에서 TypeError 미감지");
});

test("TEST 20: 기존 117개 테스트 호환성 유지", () => {
  // 간단한 호환성 테스트
  const output1 = run("print(10)");
  assert(output1.includes("10"), "기본 출력 실패");

  // 재귀 함수 테스트 (if 문법 유의)
  const output2 = run("fn fact(n) { if (n) { return n * fact(n - 1) } else { return 1 } } print(fact(5))");
  assert(output2.length > 0, "재귀 함수 실행 실패");

  const output3 = run("let arr = [1, 2, 3]; for x in arr { print(x) }");
  assert(
    output3.includes("1") && output3.includes("2") && output3.includes("3"),
    "배열 반복 실패"
  );
});

