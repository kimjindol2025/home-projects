// ─────────────────────────────────────────────────────────────
// REFLECTOR FUNCTION (v1.7)
// ─────────────────────────────────────────────────────────────

fn Reflector_evaluate(observation, retry_count) {
  if Observation_isSuccess(observation) {
    return REFLECTION_CONTINUE
  }

  if retry_count < 1 {
    return REFLECTION_RETRY
  }

  return REFLECTION_ABORT
}

// ─────────────────────────────────────────────────────────────
// CONSTRAINT ENGINE (v1.9)
// ─────────────────────────────────────────────────────────────

fn ConstraintEngine_checkPre(step_counter, time_elapsed) {
  if step_counter >= GLOBAL_CONSTRAINT_MAX_STEPS {
    return CONSTRAINT_FAIL
  }

  if time_elapsed >= GLOBAL_CONSTRAINT_TIME_LIMIT {
    return CONSTRAINT_FAIL
  }

  return CONSTRAINT_PASS
}

fn ConstraintEngine_checkPost(output) {
  if output == "" {
    return CONSTRAINT_FAIL
  }

  if GLOBAL_CONSTRAINT_OUTPUT_FORMAT == "json" {
    if output != "" {
      return CONSTRAINT_PASS
    }
  }

  return CONSTRAINT_PASS
}

// ─────────────────────────────────────────────────────────────
// INTEGRATED EXECUTION LOOP (v1.5 + v1.7 + v1.8 + v1.9)
// ─────────────────────────────────────────────────────────────

fn Agent_run(should_fail_at_index, max_replans) {
  Agent_setState(STATE_PLANNING)

  // Step 1: Planning
  let task_count = Agent_taskCount()

  // Step 2: Transition to Executing
  Agent_setState(STATE_EXECUTING)

  let current_index = Agent_currentIndex()

  // Main execution loop
  while current_index < task_count {
    // ═════════════════════════════════════════
    // PRE-EXECUTION CONSTRAINT CHECK (v1.9)
    // ═════════════════════════════════════════

    let step_counter = GLOBAL_EXECUTION_STEP_COUNTER
    let time_elapsed = GLOBAL_EXECUTION_TIME_ELAPSED

    let pre_check = ConstraintEngine_checkPre(step_counter, time_elapsed)

    if pre_check == CONSTRAINT_FAIL {
      GLOBAL_EXECUTION_ERROR = "Constraint violated (pre-check)"
      Agent_setState(STATE_FAILED)
      return false
    }

    // ═════════════════════════════════════════
    // TASK EXECUTION
    // ═════════════════════════════════════════

    Task_setStatus(current_index, TASK_STATUS_RUNNING)

    let should_fail = (current_index == should_fail_at_index)

    let observation = ""
    if current_index == 0 {
      observation = MockTool_analyze(should_fail)
    } else if current_index == 1 {
      observation = MockTool_process(should_fail)
    } else if current_index == 2 {
      observation = MockTool_validate(should_fail)
    }

    // ═════════════════════════════════════════
    // POST-EXECUTION CONSTRAINT CHECK (v1.9)
    // ═════════════════════════════════════════

    let output = Observation_message(observation)
    let post_check = ConstraintEngine_checkPost(output)

    if post_check == CONSTRAINT_FAIL {
      GLOBAL_EXECUTION_ERROR = "Constraint violated (post-check)"
      Task_setStatus(current_index, TASK_STATUS_ERROR)
      Agent_setState(STATE_FAILED)
      return false
    }

    // ═════════════════════════════════════════
    // REFLECTION STAGE (v1.7)
    // ═════════════════════════════════════════

    Agent_setState(STATE_REFLECTING)

    let retry_count = Task_getRetryCount(current_index)
    let reflection_result = Reflector_evaluate(observation, retry_count)

    // Store observation in memory (v1.6)
    Memory_store(observation)

    if reflection_result == REFLECTION_CONTINUE {
      // Success: mark done and advance
      Task_setStatus(current_index, TASK_STATUS_DONE)
      Task_setOutput(current_index, output)

      current_index = current_index + 1
      Agent_setCurrentIndex(current_index)

      Agent_setState(STATE_EXECUTING)

    } else if reflection_result == REFLECTION_RETRY {
      // Retry: increment retry count, keep index
      Task_incrementRetryCount(current_index)

      Agent_setState(STATE_EXECUTING)

    } else if reflection_result == REFLECTION_ABORT {
      // Abort: attempt replan (v1.8)
      Agent_setState(STATE_REPLANNING)

      let replan_count = Agent_replanCount()

      if replan_count < max_replans {
        // Add new task at current index
        let current_task_count = Agent_taskCount()

        if current_task_count < 5 {
          // Shift tasks: add retry task at current index
          Agent_incrementReplanCount()

          Task_setId(current_index, "task-retry-" + current_index)
          Task_setStatus(current_index, TASK_STATUS_PENDING)
          Agent_setTaskCount(current_task_count + 1)

          task_count = Agent_taskCount()

          Agent_setState(STATE_EXECUTING)
        } else {
          // Too many tasks
          GLOBAL_EXECUTION_ERROR = "Plan modification failed (max tasks)"
          Agent_setState(STATE_FAILED)
          return false
        }
      } else {
        // Max replans exceeded
        GLOBAL_EXECUTION_ERROR = "Max replans exceeded"
        Task_setStatus(current_index, TASK_STATUS_ERROR)
        Agent_setState(STATE_FAILED)
        return false
      }
    }

    // ═════════════════════════════════════════
    // INCREMENT COUNTERS
    // ═════════════════════════════════════════

    Agent_incrementStep()
    Agent_incrementTime(1)
  }

  // All tasks completed
  Agent_setState(STATE_COMPLETED)
  return true
}

