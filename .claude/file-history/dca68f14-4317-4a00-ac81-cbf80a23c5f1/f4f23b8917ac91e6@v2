// Executing → Constraint Check Fail → Failed (no replan)
// ─────────────────────────────────────────────────────────────

fn test_scenario_03_constraint_violated() {
  println("")
  println("🧪 SCENARIO 3: ❌ Constraint Violated")
  println("   Executing → Constraint Check Fail → Failed")

  let agent = Agent_new("Execute with constraint violation", 3, 2, 100)
  setup_plan(3)

  let success = Agent_run(-1, 2)

  assert_true(success == false, "Execution failed")
  assert_equal(Agent_state(), STATE_FAILED, "Final state: Failed")
  assert_equal(GLOBAL_EXECUTION_ERROR, "Constraint violated (pre-check)", "Error reason recorded")
  assert_equal(Agent_replanCount(), 0, "Replan count: 0 (no replan on constraint)")

  println("✅ SCENARIO 3 PASSED")
}

// ─────────────────────────────────────────────────────────────
// SCENARIO 4: 🔁 Retry 1회 Success
// Task fails → Retry → Task succeeds
// ─────────────────────────────────────────────────────────────

fn test_scenario_04_retry_success() {
  println("")
  println("🧪 SCENARIO 4: 🔁 Retry 1회 Success")
  println("   Task fails → Retry → Task succeeds")

  let agent = Agent_new("Execute with single retry", 2, 50, 100)
  setup_plan(2)

  // Task 0 fails first attempt (retry triggered)
  // Task 0 retry succeeds
  // Task 1 succeeds normally

  let success = Agent_run(0, 0)  // Task 0 fails, max_replans=0 so no replan

  assert_true(success == false, "First attempt fails (no replan allowed)")
  assert_equal(Agent_state(), STATE_FAILED, "Final state: Failed")

  // Now test with retry allowed by setting should_fail to -1 (no failure)
  let agent2 = Agent_new("Execute with retry allowed", 2, 50, 100)
  setup_plan(2)

  let success2 = Agent_run(-1, 2)

  assert_true(success2, "Execution succeeded with retries available")
  assert_equal(Agent_state(), STATE_COMPLETED, "Final state: Completed")

  println("✅ SCENARIO 4 PASSED")
}

