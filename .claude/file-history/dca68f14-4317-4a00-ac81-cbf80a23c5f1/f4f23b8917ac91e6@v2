// SCENARIO 1: ✅ Normal Completion
// Idle → Planning → Executing → Reflecting → Completed
// ─────────────────────────────────────────────────────────────

fn test_scenario_01_normal_completion() {
  println("")
  println("🧪 SCENARIO 1: ✅ Normal Completion Flow")
  println("   Idle → Planning → Executing → Reflecting → Completed")

  let agent = Agent_new("Complete all tasks", 3, 50, 100)
  setup_plan(3)

  let success = Agent_run(-1, 2)

  assert_true(success, "Execution succeeded")
  assert_equal(Agent_state(), STATE_COMPLETED, "Final state: Completed")
  assert_equal(Agent_currentIndex(), 3, "All 3 tasks executed")
  assert_equal(Task_getStatus(0), TASK_STATUS_DONE, "Task 0: Done")
  assert_equal(Task_getStatus(1), TASK_STATUS_DONE, "Task 1: Done")
  assert_equal(Task_getStatus(2), TASK_STATUS_DONE, "Task 2: Done")
  assert_equal(Memory_length(), 3, "Memory: 3 observations recorded")
  assert_equal(Agent_replanCount(), 0, "Replan count: 0 (no replan needed)")

  println("✅ SCENARIO 1 PASSED")
}

