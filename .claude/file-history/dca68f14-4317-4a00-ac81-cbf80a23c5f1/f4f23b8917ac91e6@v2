// SCENARIO 2: ❌ Failure → Replan → Success
// Executing → Reflecting → Abort → Replanning → Executing → Completed
// ─────────────────────────────────────────────────────────────

fn test_scenario_02_failure_replan_success() {
  println("")
  println("🧪 SCENARIO 2: ❌ Failure → Replan → Success")
  println("   Executing → Reflecting → Abort → Replanning → Executing → Completed")

  let agent = Agent_new("Execute with failure recovery", 3, 50, 100)
  setup_plan(3)

  // Task 1 fails first attempt, then replan adds retry task, succeeds on retry
  let success = Agent_run(1, 2)

  assert_true(success, "Execution succeeded after replan")
  assert_equal(Agent_state(), STATE_COMPLETED, "Final state: Completed")
  assert_equal(Agent_taskCount(), 4, "Task count increased to 4 (replan added 1)")
  assert_equal(Agent_replanCount(), 1, "Replan count: 1")
  assert_equal(Task_getRetryCount(1), 1, "Task 1 retried once")
  assert_equal(Memory_length(), 4, "Memory: 4 observations (1 failure + 1 retry + 2 others)")

  println("✅ SCENARIO 2 PASSED")
}

