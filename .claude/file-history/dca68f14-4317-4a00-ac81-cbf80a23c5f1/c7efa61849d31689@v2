use freelang::core::{Agent, Goal, Plan, Task, TaskStatus, AgentState};
use freelang::memory::Memory;
use freelang::collections::{Map, Vec};


// ─────────────────────────────────────────────────────────────
// TEST 1: Goal 생성 및 Agent 초기화
// ─────────────────────────────────────────────────────────────

fn test_01_agent_initialization() {
    println!("\n🧪 TEST 1: Agent Initialization");
    println!("═".repeat(50));

    // Goal 생성
    let goal = Goal {
        description: "Answer user question about AI",
        constraints: vec![
            "Time < 30 seconds".to_string(),
            "Error rate < 1%".to_string(),
            "No internet required".to_string()
        ],
        success_criteria: "User understands the answer".to_string()
    };

    println!("✓ Goal created:");
    println!("  Description: {}", goal.description);
    println!("  Constraints: {:?}", goal.constraints);
    println!("  Success Criteria: {}", goal.success_criteria);

    // Agent 생성
    let agent = Agent::new(
        id: "agent-001",
        goal: goal.clone()
    );

    // 검증 1: ID가 올바른가?
    assert_eq!(agent.id, "agent-001", "Agent ID mismatch!");
    println!("✓ Agent ID verified: {}", agent.id);

    // 검증 2: 초기 상태가 Idle인가?
    assert_eq!(agent.state, AgentState::Idle, "Initial state should be Idle!");
    println!("✓ Initial state verified: {:?}", agent.state);

    // 검증 3: Goal이 정확히 설정됐는가?
    assert_eq!(agent.goal.description, goal.description, "Goal mismatch!");
    println!("✓ Goal verified: {}", agent.goal.description);

    // 검증 4: Plan이 비어있는가?
    assert_eq!(agent.plan.tasks.len(), 0, "Initial plan should be empty!");
    println!("✓ Initial plan is empty (0 tasks)");

    // 검증 5: Memory가 초기화됐는가?
    assert_eq!(agent.memory.data.len(), 0, "Initial memory should be empty!");
    println!("✓ Memory initialized and empty");

    println!("\n✅ TEST 1 PASSED\n");
}


// ─────────────────────────────────────────────────────────────
// TEST 2: Task 추가 및 상태 조회
// ─────────────────────────────────────────────────────────────

fn test_02_task_management() {
    println!("\n🧪 TEST 2: Task Management");
    println!("═".repeat(50));

    // Agent 생성
    let goal = Goal {
        description: "Process user request",
        constraints: vec![],
        success_criteria: "Request completed".to_string()
    };

    let mut agent = Agent::new(id: "agent-002", goal: goal);

    // Task 생성
    let task1 = Task {
        id: "task-1",
        description: "Search for information",
        tool: "web_search",
        status: TaskStatus::Pending,
        input: Map::from([("query", "What is AI?")]),
        output: None
    };

    let task2 = Task {
        id: "task-2",
        description: "Analyze results",
        tool: "analyze_text",
        status: TaskStatus::Pending,
        input: Map::new(),
        output: None
    };

    let task3 = Task {
        id: "task-3",
        description: "Generate response",
        tool: "llm_response",
        status: TaskStatus::Pending,
        input: Map::new(),
        output: None
    };

    // Plan에 Task 추가
    agent.plan.add_task(task1.clone());
    agent.plan.add_task(task2.clone());
    agent.plan.add_task(task3.clone());

    // 검증 1: Task가 추가됐는가?
    assert_eq!(agent.plan.tasks.len(), 3, "Should have 3 tasks!");
    println!("✓ 3 tasks added to plan");

    // 검증 2: 첫 번째 Task가 올바른가?
    assert_eq!(agent.plan.tasks[0].id, "task-1", "First task ID mismatch!");
    println!("✓ Task 1 verified: {}", agent.plan.tasks[0].description);

    // 검증 3: 모든 Task 상태가 Pending인가?
    for (idx, task) in agent.plan.tasks.iter().enumerate() {
        assert_eq!(task.status, TaskStatus::Pending, "Task {} should be Pending!", idx);
    }
    println!("✓ All tasks initialized with Pending status");

    // 검증 4: current_index 초기값
    assert_eq!(agent.plan.current_index, 0, "current_index should start at 0!");
    println!("✓ current_index initialized to 0");

    // 검증 5: Memory에 접근 가능한가?
    agent.memory.set("init_info", "Agent ready".to_string());
    assert_eq!(
        agent.memory.get("init_info"),
        Some("Agent ready".to_string()),
        "Memory set/get failed!"
    );
    println!("✓ Memory operations working (set/get)");

    println!("\n✅ TEST 2 PASSED\n");
}


// ─────────────────────────────────────────────────────────────
// TEST 3: 상태 전이 (Complete State Machine Trace)
// ─────────────────────────────────────────────────────────────

fn test_03_state_transitions() {
    println!("\n🧪 TEST 3: State Machine Transitions");
    println!("═".repeat(50));

    // Agent 생성
    let goal = Goal {
        description: "Simple task execution",
        constraints: vec![],
        success_criteria: "Completed".to_string()
    };

    let mut agent = Agent::new(id: "agent-003", goal: goal);

    // Task 생성 (간단한 버전)
    let task = Task {
        id: "task-simple",
        description: "Store value in memory",
        tool: "memory_store",
        status: TaskStatus::Pending,
        input: Map::from([("key", "test_data"), ("value", "hello")]),
        output: None
    };

    agent.plan.add_task(task);

    // ─────────────────────────────────────────────────────────
    // State 1: Idle (초기 상태)
    // ─────────────────────────────────────────────────────────

    println!("\n📍 State 1: Idle");
    assert_eq!(agent.state, AgentState::Idle, "Should start in Idle!");
    println!("   ✓ Agent in Idle state");
    println!("   ✓ Memory empty: {} entries", agent.memory.data.len());

    // ─────────────────────────────────────────────────────────
    // State 2: Planning (Goal 분석)
    // ─────────────────────────────────────────────────────────

    println!("\n📍 State 2: Planning");
    agent.transition_to(AgentState::Planning);
    assert_eq!(agent.state, AgentState::Planning, "Should transition to Planning!");
    println!("   ✓ Transitioned to Planning");
    println!("   ✓ Goal analyzed: {}", agent.goal.description);
    println!("   ✓ Tasks in plan: {}", agent.plan.tasks.len());

    // ─────────────────────────────────────────────────────────
    // State 3: Executing (Task 실행)
    // ─────────────────────────────────────────────────────────

    println!("\n📍 State 3: Executing");
    agent.transition_to(AgentState::Executing);
    assert_eq!(agent.state, AgentState::Executing, "Should transition to Executing!");

    // 현재 Task 실행
    let current_task = &mut agent.plan.tasks[agent.plan.current_index];
    println!("   ✓ Executing task: {}", current_task.description);

    // Task 상태 업데이트
    current_task.status = TaskStatus::Running;
    println!("   ✓ Task status: {:?}", current_task.status);

    // Tool 실행 시뮬레이션
    let tool_result = format!("Stored: {:?}", current_task.input);
    current_task.output = Some(tool_result.clone());
    current_task.status = TaskStatus::Done;
    println!("   ✓ Tool executed successfully");
    println!("   ✓ Output: {}", tool_result);

    // ─────────────────────────────────────────────────────────
    // State 4: Observing (결과 관찰)
    // ─────────────────────────────────────────────────────────

    println!("\n📍 State 4: Observing");
    agent.transition_to(AgentState::Observing);
    assert_eq!(agent.state, AgentState::Observing, "Should transition to Observing!");

    // 결과 저장
    let completed_task = &agent.plan.tasks[agent.plan.current_index];
    agent.memory.set(
        "last_task_output",
        completed_task.output.clone().unwrap_or_default()
    );
    println!("   ✓ Result collected");
    println!("   ✓ Task status: {:?}", completed_task.status);
    println!("   ✓ Result stored in memory");

    // ─────────────────────────────────────────────────────────
    // State 5: Reflecting (결과 평가)
    // ─────────────────────────────────────────────────────────

    println!("\n📍 State 5: Reflecting");
    agent.transition_to(AgentState::Reflecting);
    assert_eq!(agent.state, AgentState::Reflecting, "Should transition to Reflecting!");

    println!("   ✓ Evaluating result...");
    println!("   ✓ All tasks completed: {}/{}",
        agent.plan.tasks.iter().filter(|t| t.status == TaskStatus::Done).count(),
        agent.plan.tasks.len()
    );

    // ─────────────────────────────────────────────────────────
    // State 6: Completed (목표 달성)
    // ─────────────────────────────────────────────────────────

    println!("\n📍 State 6: Completed");
    agent.transition_to(AgentState::Completed);
    assert_eq!(agent.state, AgentState::Completed, "Should transition to Completed!");
    println!("   ✓ Goal achieved! ✅");
    println!("   ✓ Agent transitioned to terminal state");

    // ─────────────────────────────────────────────────────────
    // Final Verification
    // ─────────────────────────────────────────────────────────

    println!("\n📊 Final Agent State:");
    println!("   ID: {}", agent.id);
    println!("   Current State: {:?}", agent.state);
    println!("   Tasks Completed: {}/{}",
        agent.plan.tasks.iter().filter(|t| t.status == TaskStatus::Done).count(),
        agent.plan.tasks.len()
    );
    println!("   Memory Entries: {}", agent.memory.data.len());
    println!("   Stored Data: {:?}", agent.memory.get("last_task_output"));

    println!("\n✅ TEST 3 PASSED\n");
}


