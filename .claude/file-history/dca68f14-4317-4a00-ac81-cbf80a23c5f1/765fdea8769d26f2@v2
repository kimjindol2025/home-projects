// ─────────────────────────────────────────────────────────────
// Goal 구조 (배열 기반)
// ─────────────────────────────────────────────────────────────

fn Goal_new(description, success_criteria) {
  let goal = []
  goal.push(description)    // 0: description
  goal.push(success_criteria) // 1: success_criteria
  return goal
}

fn Goal_description(goal) {
  return goal[0]
}

fn Goal_criteria(goal) {
  return goal[1]
}

// ─────────────────────────────────────────────────────────────
// Goal 검증 함수
// ─────────────────────────────────────────────────────────────

fn Goal_validate(goal) {
  // 검증 1: description이 비어있지 않은가?
  if Goal_description(goal) == "" {
    return false
  }

  // 검증 2: description이 최소 3글자 이상인가?
  let desc = Goal_description(goal)
  if desc.length < 3 {
    return false
  }

  // 검증 3: success_criteria가 비어있지 않은가?
  if Goal_criteria(goal) == "" {
    return false
  }

  // 검증 4: success_criteria가 최소 3글자 이상인가?
  let criteria = Goal_criteria(goal)
  if criteria.length < 3 {
    return false
  }

  return true
}

// ─────────────────────────────────────────────────────────────
// 상세 검증 (오류 메시지 포함)
// ─────────────────────────────────────────────────────────────

fn Goal_validate_detailed(goal) {
  let desc = Goal_description(goal)
  let criteria = Goal_criteria(goal)

  if desc == "" {
    return "ERROR: Description is empty"
  }

  if desc.length < 3 {
    return "ERROR: Description too short (min 3 chars)"
  }

  if criteria == "" {
    return "ERROR: Success criteria is empty"
  }

  if criteria.length < 3 {
    return "ERROR: Success criteria too short (min 3 chars)"
  }

  return "VALID"
}

// ─────────────────────────────────────────────────────────────
// 테스트 유틸
// ─────────────────────────────────────────────────────────────

fn assert_true(actual, msg) {
  if actual {
    println("✓ " + msg)
    return true
  }
  println("✗ FAILED: " + msg)
  return false
}

fn assert_false(actual, msg) {
  if actual == false {
    println("✓ " + msg)
    return true
  }
  println("✗ FAILED: " + msg)
  return false
}

// ─────────────────────────────────────────────────────────────
// TEST 1: 유효한 Goal 검증
// ─────────────────────────────────────────────────────────────

fn test_01_valid_goal() {
  println("")
  println("🧪 TEST 1: Valid Goal Validation")

  let goal = Goal_new(
    "Answer user question about AI",
    "User understands the answer"
  )

  assert_true(Goal_validate(goal), "Valid goal passes validation")

  let result = Goal_validate_detailed(goal)
  assert_true(result == "VALID", "Detailed validation returns VALID")

  println("✅ TEST 1 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 2: 무효한 Goal 거부
// ─────────────────────────────────────────────────────────────

fn test_02_invalid_goal() {
  println("")
  println("🧪 TEST 2: Invalid Goal Rejection")

  // Empty description
  let goal1 = Goal_new("", "Valid criteria")
  assert_false(Goal_validate(goal1), "Empty description rejected")

  // Empty criteria
  let goal2 = Goal_new("Valid description", "")
  assert_false(Goal_validate(goal2), "Empty criteria rejected")

  // Too short description
  let goal3 = Goal_new("ab", "Valid criteria")
  assert_false(Goal_validate(goal3), "Short description rejected")

  // Too short criteria
  let goal4 = Goal_new("Valid description", "ab")
  assert_false(Goal_validate(goal4), "Short criteria rejected")

  println("✅ TEST 2 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 3: 오류 메시지
// ─────────────────────────────────────────────────────────────

fn test_03_error_messages() {
  println("")
  println("🧪 TEST 3: Error Messages")

  let goal1 = Goal_new("", "criteria")
  let msg1 = Goal_validate_detailed(goal1)
  assert_true(msg1 == "ERROR: Description is empty", "Empty description error")

  let goal2 = Goal_new("Valid description", "")
  let msg2 = Goal_validate_detailed(goal2)
  assert_true(msg2 == "ERROR: Success criteria is empty", "Empty criteria error")

  let goal3 = Goal_new("ab", "Valid criteria")
  let msg3 = Goal_validate_detailed(goal3)
  assert_true(msg3 == "ERROR: Description too short (min 3 chars)", "Short description error")

  println("✅ TEST 3 PASSED")
}

