fn test_04_parallelizable_tasks() {
  println("")
  println("🧪 TEST 4: Parallel Task Identification")

  let success = Planner_decompose("website_development")

  // In high complexity: task-1 has no deps, task-2 and task-3 can run after task-1
  let parallelizable = Graph_getParallelizable()
  assert_equal(parallelizable, 1, "1 task can start immediately (task-1)")

  // Task 2 and 3 are parallelizable with each other (both depend only on task-1)
  let task2_deps = Graph_getDependencyCount(2)
  let task3_deps = Graph_getDependencyCount(3)

  assert_equal(task2_deps, 1, "Task 2 has 1 dependency")
  assert_equal(task3_deps, 1, "Task 3 has 1 dependency")

  // Both depend on same task, so can run in parallel
  let task2_dep = Graph_getDependency(2, 1)
  let task3_dep = Graph_getDependency(3, 1)

  assert_equal(task2_dep, task3_dep, "Task 2 and 3 have same dependency (parallelizable)")

  println("✅ TEST 4 PASSED")
