  GLOBAL_TASK_GRAPH_COUNT = GLOBAL_TASK_GRAPH_COUNT + 1
  let idx = GLOBAL_TASK_GRAPH_COUNT

  let task = TaskBlueprint_new(task_id, task_name)

  if idx == 1 { GLOBAL_TASK_BP_1 = task }
  if idx == 2 { GLOBAL_TASK_BP_2 = task }
  if idx == 3 { GLOBAL_TASK_BP_3 = task }
  if idx == 4 { GLOBAL_TASK_BP_4 = task }
