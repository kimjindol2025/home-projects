// ─────────────────────────────────────────────────────────────
// Cycle Detection (DFS-based)
// ─────────────────────────────────────────────────────────────

let CYCLE_DFS_VISITED_COUNT = 0
let CYCLE_DFS_REC_STACK_1 = 0
let CYCLE_DFS_REC_STACK_2 = 0
let CYCLE_DFS_REC_STACK_3 = 0
let CYCLE_DFS_REC_STACK_4 = 0
let CYCLE_DFS_REC_STACK_5 = 0
let CYCLE_DFS_REC_STACK_6 = 0

fn Graph_hasCycle() {
  // Simple cycle detection for small graphs
  // Check if any task depends on itself or creates a cycle

  let task_count = Graph_taskCount()

  // Check each task
  let i = 1
  while i <= task_count {
    let dep_count = Graph_getDependencyCount(i)

    // Check if task depends on itself
    let j = 1
    while j <= dep_count {
      let dep_id = Graph_getDependency(i, j)

      let task_bp = Graph_getTask(i)
      let task_id = TaskBlueprint_id(task_bp)

      if dep_id == task_id {
        // Self-dependency detected
        GLOBAL_CYCLE_DETECTED = true
        GLOBAL_CYCLE_ERROR = "Cycle detected: " + task_id + " depends on itself"
        return true
      }

      j = j + 1
    }

    i = i + 1
  }

  // Check for multi-level cycles (simplified: just check if all deps have higher index)
  i = 1
  while i <= task_count {
    let dep_count = Graph_getDependencyCount(i)

    let j = 1
    while j <= dep_count {
      let dep_id = Graph_getDependency(i, j)

      // Try to find which task has this ID
      let k = 1
      let dep_task_index = 0
      while k <= task_count {
        let task_bp = Graph_getTask(k)
        let tid = TaskBlueprint_id(task_bp)

        if tid == dep_id {
          dep_task_index = k
        }

        k = k + 1
      }

      // If dependency is at higher index, potential cycle
      // (Simplified: assume linear ordering means no cycle if index increases)
      if dep_task_index > i {
        // Backwards dependency = potential cycle
        GLOBAL_CYCLE_DETECTED = true
        GLOBAL_CYCLE_ERROR = "Cycle detected: backwards dependency"
        return true
      }

      j = j + 1
    }

    i = i + 1
  }

  return false
}

// ─────────────────────────────────────────────────────────────
// Parallel Task Identification
// ─────────────────────────────────────────────────────────────

fn Graph_getParallelizable() {
  // Tasks that can run in parallel: tasks with no dependencies
  let task_count = Graph_taskCount()
  let parallel_count = 0

  let i = 1
  while i <= task_count {
    let dep_count = Graph_getDependencyCount(i)

    if dep_count == 0 {
      parallel_count = parallel_count + 1
    }

    i = i + 1
  }

  return parallel_count
}

// ─────────────────────────────────────────────────────────────
// Goal Analyzer
// ─────────────────────────────────────────────────────────────

fn Analyzer_analyzeGoal(goal) {
  // Analyze goal and return complexity level (1-3)

  if goal == "" {
    return 0
  }

  // Simple heuristic: count key phrases
  let complexity = 1

  // If goal mentions multiple stages
  if goal == "website_development" {
    complexity = 3
  }

  if goal == "data_pipeline" {
    complexity = 2
  }

  return complexity
}

// ─────────────────────────────────────────────────────────────
// Goal Decomposer (Main Planning Engine)
// ─────────────────────────────────────────────────────────────

fn Planner_decompose(goal) {
  GLOBAL_GOAL_DESCRIPTION = goal
  GLOBAL_TASK_GRAPH_COUNT = 0
  GLOBAL_CYCLE_DETECTED = false

  let complexity = Analyzer_analyzeGoal(goal)

  if complexity == 0 {
    return false  // Invalid goal
  }

  // Low complexity: 2-3 tasks
  if complexity == 1 {
    Graph_addTask("task-1", "Analyze requirements")
    Graph_setOutput(1, "requirements")

    Graph_addTask("task-2", "Execute implementation")
    Graph_addDependency(2, "task-1")
    Graph_setOutput(2, "implementation")

    return true
  }

  // Medium complexity: 4-5 tasks
  if complexity == 2 {
    Graph_addTask("task-1", "Analyze input data")
    Graph_setOutput(1, "data_schema")

    Graph_addTask("task-2", "Validate data")
    Graph_addDependency(2, "task-1")
    Graph_setOutput(2, "validation_report")

    Graph_addTask("task-3", "Process pipeline")
    Graph_addDependency(3, "task-2")
    Graph_setOutput(3, "processed_data")

    Graph_addTask("task-4", "Verify results")
    Graph_addDependency(4, "task-3")
    Graph_setOutput(4, "verification_report")

    return true
  }

  // High complexity: 6 tasks with parallelization
  if complexity == 3 {
    // Phase 1: Analysis (no dependencies)
    Graph_addTask("task-1", "Gather requirements")
    Graph_setOutput(1, "requirements_doc")

    // Phase 2: Design (depends on requirements)
    Graph_addTask("task-2", "Design database schema")
    Graph_addDependency(2, "task-1")
    Graph_setOutput(2, "db_schema")

    Graph_addTask("task-3", "Design API specification")
    Graph_addDependency(3, "task-1")
    Graph_setOutput(3, "api_spec")

    // Phase 3: Implementation (depends on designs)
    Graph_addTask("task-4", "Implement backend")
    Graph_addDependency(4, "task-2")
    Graph_addDependency(4, "task-3")
    Graph_setOutput(4, "backend_code")

    Graph_addTask("task-5", "Implement frontend")
    Graph_addDependency(5, "task-3")
    Graph_setOutput(5, "frontend_code")

    // Phase 4: Integration
    Graph_addTask("task-6", "Integration testing")
    Graph_addDependency(6, "task-4")
    Graph_addDependency(6, "task-5")
    Graph_setOutput(6, "test_report")

    return true
  }

  return false
}

