// SUITE 1: 배열 연산 (6개 테스트)
// ═══════════════════════════════════════════════════════════

function test_01_array_create_access(): void {
  console.log("\n🧪 TEST 1: 배열 생성 및 요소 접근");

  const code = `
    arr = [10, 20, 30]
    x = arr[0]
    y = arr[1]
    z = arr[2]
    println(x)
    println(y)
    println(z)
  `;

  const tokens = lex(code);
  const ast = parse(tokens);
  const chunk = compile(ast);
  const vm = new VM(chunk);
  const { output } = vm.run();

  assertEqual(output.length, 3, "3개 출력");
  assertEqual(output[0], "10", "arr[0] = 10");
  assertEqual(output[1], "20", "arr[1] = 20");
  assertEqual(output[2], "30", "arr[2] = 30");

  const heap = vm.getHeapManager();
  const stats = heap.getStats();
  console.log(`  [Heap Stats] allocated=${stats.totalAllocated}`);
  assert(stats.totalAllocated >= 6, "배열과 요소들이 heap에 할당됨");

  console.log("✅ TEST 1 PASSED\n");
}

