// GC 디버그 테스트: getRoots와 Globals 확인

import { compile } from "./compiler";
import { VM } from "./vm";
import { lex } from "./lexer";
import { parse } from "./parser";

function test_gc_debug(): void {
  console.log("\n🧪 GC Debug: getRoots와 Globals 상태 확인");

  const code = `
    obj = {value: 42}
    println(obj.value)
  `;

  const tokens = lex(code);
  const ast = parse(tokens);
  const chunk = compile(ast);
  const vm = new VM(chunk);
  const { output } = vm.run();

  console.log(`[Output] ${output[0]}`);

  const heap = vm.getHeapManager();
  console.log(`\n[Before GC]`);
  const globalsBefore = vm.getGlobals();
  console.log(`  Globals entries: ${globalsBefore.size}`);
  let ptrCount = 0;
  globalsBefore.forEach((val, key) => {
    const tag = (val as any).tag;
    if (tag === "ptr") {
      ptrCount++;
      console.log(`  - ${key}: ptr(addr=${(val as any).addr})`);
    } else {
      console.log(`  - ${key}: ${tag}`);
    }
  });
  console.log(`  Pointers in globals: ${ptrCount}`);

  const statsBefore = heap.getStats();
  console.log(`\n[Heap Stats Before]`);
  console.log(`  allocated=${statsBefore.totalAllocated}, current=${statsBefore.currentObjects}`);

  const gcResult = heap.forceGC();
  console.log(`\n[GC Result]`);
  console.log(`  marked=${gcResult.markedCount}, swept=${gcResult.sweptCount}`);

  const statsAfter = heap.getStats();
  console.log(`\n[Heap Stats After]`);
  console.log(`  allocated=${statsAfter.totalAllocated}, current=${statsAfter.currentObjects}`);
}

test_gc_debug();
