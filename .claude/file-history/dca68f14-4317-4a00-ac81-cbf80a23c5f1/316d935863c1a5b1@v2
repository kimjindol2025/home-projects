## 🔧 구현 상세

### 1. UnsafeManager 구현

```typescript
export class UnsafeManager {
  public createZone(maxSize: number): number {
    const id = this.nextZoneId++;
    const zone: UnsafeZone = {
      id,
      startAddr: Math.random() * 1000000,
      endAddr: startAddr + maxSize,
      maxSize,
      currentSize: 0,
      data: Buffer.alloc(maxSize),
      permissions: new Set(),
      createdAt: Date.now(),
      lastAccess: Date.now()
    };
    this.zones.set(id, zone);
    this.stats.totalZones++;
    this.stats.totalMemory += maxSize;
    return id;
  }

  public validateAccess(
    zoneId: number,
    offset: number,
    size: number
  ): boolean {
    const zone = this.zones.get(zoneId);
    if (!zone) return false;

    if (offset < 0 || offset + size > zone.maxSize) {
      this.stats.violationCount++;
      return false;
    }
    zone.lastAccess = Date.now();
    return true;
  }

  public detectOverflow(
    zoneId: number,
    offset: number,
    size: number
  ): boolean {
    return !this.validateAccess(zoneId, offset, size);
  }
}
```

### 2. VM 통합

```typescript
// VM에 추가
private unsafeManager: UnsafeManager = new UnsafeManager()
private currentUnsafeZone: number = -1
private unsafeDepth: number = 0

case Op.Malloc: {
  if (this.currentUnsafeZone < 0) {
    this.runtimeError("malloc outside unsafe block")
  }
  const size = this.pop()
  const zoneId = this.unsafeManager.createZone(size.val)
  this.stack.push({ tag: "ptr", addr: zoneId })
  break
}

case Op.UnsafeRead: {
  const offset = this.pop()
  const ptr = this.pop()

  if (this.currentUnsafeZone < 0) {
    this.runtimeError("Memory access outside unsafe block")
  }

  if (!this.unsafeManager.validateAccess(
    ptr.addr,
    offset.val,
    1
  )) {
    this.runtimeError("Buffer overflow detected")
  }

  const data = this.unsafeManager.read(ptr.addr, offset.val, 1)
  this.stack.push({ tag: "num", val: data[0] })
  break
}
```

### 3. 컴파일러 지원 (향후)

```typescript
case "unsafe":
  emit(Op.UnsafeBegin)
  compileStmts(s.body)
  emit(Op.UnsafeEnd)
  break
```

