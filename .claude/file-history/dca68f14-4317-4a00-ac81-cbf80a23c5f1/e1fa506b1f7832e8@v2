// ─────────────────────────────────────────────────────────────
// TEST 8: Decision Sequence (Success → Failure → Retry → Success)
// ─────────────────────────────────────────────────────────────

fn test_08_decision_sequence() {
  println("")
  println("🧪 TEST 8: Decision Sequence (Multiple Decisions)")

  SequentialConservativePolicy_initialize()

  // Task A succeeds
  let d1 = policy_onTaskSuccess("task-A")
  assert_equal(d1, POLICY_DECISION_PROCEED, "1. Task A: Proceed")

  // Task B fails (first time)
  let d2 = policy_onTaskFailure("task-B", 0)
  assert_equal(d2, POLICY_DECISION_RETRY, "2. Task B: Retry")

  // Task B fails again (after retry)
  let d3 = policy_onTaskFailure("task-B", 1)
  assert_equal(d3, POLICY_DECISION_ABORT, "3. Task B: Abort")

  assert_equal(GLOBAL_POLICY_DECISIONS_MADE, 3, "Total decisions: 3")

  println("✅ TEST 8 PASSED")
}

