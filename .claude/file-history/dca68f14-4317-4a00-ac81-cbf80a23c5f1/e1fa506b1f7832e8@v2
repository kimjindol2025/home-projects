// Test Utilities
// ─────────────────────────────────────────────────────────────

fn assert_true(actual, msg) {
  if actual {
    println("✓ " + msg)
    return true
  }
  println("✗ FAILED: " + msg)
  return false
}

fn assert_equal(actual, expected, msg) {
  if actual == expected {
    println("✓ " + msg)
    return true
  }
  println("✗ FAILED: " + msg)
  println("  Expected: " + expected)
  println("  Actual: " + actual)
  return false
}

