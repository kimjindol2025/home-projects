// ─────────────────────────────────────────────────────────────
// TEST 7: Scheduler Isolation (Kernel 무시)
// ─────────────────────────────────────────────────────────────

fn test_07_scheduler_isolation() {
  println("")
  println("🧪 TEST 7: Scheduler Isolation from Kernel")

  // Scheduler는 Policy 내부에서만 작동
  // Kernel은 selectNext() 호출하지 않음 (0줄)

  Policy_setScheduler(SCHEDULER_STRATEGY_FIFO)

  ReadyQueue_add("task-A")
  ReadyQueue_add("task-B")

  // Policy가 선택
  let selected = Policy_selectNext()
  assert_true(selected != "", "Scheduler selects from queue")

  // Kernel과 분리됨 (Kernel은 호출 안 함)
  assert_true(ReadyQueue_length() == 2, "Queue unmodified by scheduler")

  println("✅ TEST 7 PASSED")
}

