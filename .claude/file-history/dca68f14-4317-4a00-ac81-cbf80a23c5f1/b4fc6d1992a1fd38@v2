// ─────────────────────────────────────────────────────────────

fn test_03_scheduler_switching() {
  println("")
  println("🧪 TEST 3: Scheduler Strategy Switching")

  // Switch FIFO
  Policy_setScheduler(SCHEDULER_STRATEGY_FIFO)
  assert_equal(GLOBAL_SCHEDULER_STRATEGY, SCHEDULER_STRATEGY_FIFO, "Switched to FIFO")

  // Switch Priority
  Policy_setScheduler(SCHEDULER_STRATEGY_PRIORITY)
  assert_equal(GLOBAL_SCHEDULER_STRATEGY, SCHEDULER_STRATEGY_PRIORITY, "Switched to Priority")

  println("✅ TEST 3 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 4: FIFO with Multiple Tasks
// ─────────────────────────────────────────────────────────────

fn test_04_fifo_multiple() {
  println("")
  println("🧪 TEST 4: FIFO — Multiple Task Execution")

  Policy_setScheduler(SCHEDULER_STRATEGY_FIFO)

  // Clear queue
  GLOBAL_READY_QUEUE_COUNT = 0
  GLOBAL_READY_QUEUE_1 = ""

  // Add tasks
  ReadyQueue_add("task-D")
  ReadyQueue_add("task-E")
  ReadyQueue_add("task-F")

  let executed = 0

  let t1 = Policy_selectNext()
  if t1 == "task-D" {
    executed = executed + 1
    ReadyQueue_dequeue()
  }

  let t2 = Policy_selectNext()
  if t2 == "task-E" {
    executed = executed + 1
    ReadyQueue_dequeue()
  }

  let t3 = Policy_selectNext()
  if t3 == "task-F" {
    executed = executed + 1
  }

  assert_equal(executed, 3, "FIFO executed 3 tasks in order")

  println("✅ TEST 4 PASSED")
}

