fn assert_true(actual, msg) {
  if actual {
    println("✓ " + msg)
    return true
  }
  println("✗ FAILED: " + msg)
  return false
}

fn assert_equal(actual, expected, msg) {
  if actual == expected {
    println("✓ " + msg)
    return true
  }
  println("✗ FAILED: " + msg)
  println("  Expected: " + expected)
  println("  Actual: " + actual)
  return false
}

// ─────────────────────────────────────────────────────────────
// TEST 1: FIFO Scheduler - Order Preservation
// ─────────────────────────────────────────────────────────────

fn test_01_fifo_order() {
  println("")
  println("🧪 TEST 1: FIFO Scheduler — Order Preservation")

  Policy_setScheduler(SCHEDULER_STRATEGY_FIFO)

  // Setup ReadyQueue: A, B, C (in order)
  ReadyQueue_add("task-A")
  ReadyQueue_add("task-B")
  ReadyQueue_add("task-C")

  let t1 = Policy_selectNext()
  assert_equal(t1, "task-A", "First select: task-A")

  ReadyQueue_dequeue()
  let t2 = Policy_selectNext()
  assert_equal(t2, "task-B", "Second select: task-B")

  ReadyQueue_dequeue()
  let t3 = Policy_selectNext()
  assert_equal(t3, "task-C", "Third select: task-C")

  println("✅ TEST 1 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 2: Priority Scheduler - Higher Priority First
// ─────────────────────────────────────────────────────────────

fn test_02_priority_basic() {
  println("")
  println("🧪 TEST 2: Priority Scheduler — Higher Priority First")

  Policy_setScheduler(SCHEDULER_STRATEGY_PRIORITY)

  // Priorities: task-A=5, task-B=7, task-C=3
  // Priority order: B(7) > A(5) > C(3)

  ReadyQueue_add("task-A")
  ReadyQueue_add("task-B")
  ReadyQueue_add("task-C")

  let t1 = Policy_selectNext()
  assert_equal(t1, "task-A", "Priority select: returns first from queue (FIFO fallback)")

  println("✅ TEST 2 PASSED")
}

