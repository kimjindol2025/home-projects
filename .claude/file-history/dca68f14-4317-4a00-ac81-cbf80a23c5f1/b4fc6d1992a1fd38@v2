// Task 선택을 Policy로 완전 분리: FIFO vs Priority 전략

// ─────────────────────────────────────────────────────────────
// Scheduler Strategy Interface
// ─────────────────────────────────────────────────────────────

// selectNext(ready_queue) → task_id
//
// ReadyQueue에서 다음 실행할 Task를 선택
// Scheduler 구현체가 이 계약을 만족

let SCHEDULER_STRATEGY_FIFO = 1
let SCHEDULER_STRATEGY_PRIORITY = 2

fn scheduler_strategy_name(strategy) {
  if strategy == SCHEDULER_STRATEGY_FIFO { return "FIFO" }
  if strategy == SCHEDULER_STRATEGY_PRIORITY { return "Priority" }
  return "Unknown"
}

// ─────────────────────────────────────────────────────────────
// Task Priority Information (Policy에서 관리)
// ─────────────────────────────────────────────────────────────

// Task별 메타데이터 (static priority + depth 기반)
let GLOBAL_TASK_1_PRIORITY = 5          // 기본값 5
let GLOBAL_TASK_2_PRIORITY = 7
let GLOBAL_TASK_3_PRIORITY = 3
let GLOBAL_TASK_4_PRIORITY = 5
let GLOBAL_TASK_5_PRIORITY = 6
let GLOBAL_TASK_6_PRIORITY = 4

// DAG Depth (Planner에서 계산됨)
let GLOBAL_TASK_1_DEPTH = 0
let GLOBAL_TASK_2_DEPTH = 1
let GLOBAL_TASK_3_DEPTH = 1
let GLOBAL_TASK_4_DEPTH = 2
let GLOBAL_TASK_5_DEPTH = 2
let GLOBAL_TASK_6_DEPTH = 3

// ─────────────────────────────────────────────────────────────
// Scheduler: FIFO Implementation
// ─────────────────────────────────────────────────────────────
// ReadyQueue의 첫 번째 Task를 그대로 반환

fn Scheduler_FIFO_selectNext() {
  // ReadyQueue의 첫 번째 (이미 순서대로 정렬됨)
  return ReadyQueue_peek()
}

// ─────────────────────────────────────────────────────────────
// Scheduler: Priority Implementation
// ─────────────────────────────────────────────────────────────
// ReadyQueue에서 priority 가장 높은 Task 선택

fn Task_getPriority(task_id) {
  if task_id == "task-A" { return GLOBAL_TASK_1_PRIORITY }
  if task_id == "task-B" { return GLOBAL_TASK_2_PRIORITY }
  if task_id == "task-C" { return GLOBAL_TASK_3_PRIORITY }
  if task_id == "task-D" { return GLOBAL_TASK_4_PRIORITY }
  if task_id == "task-E" { return GLOBAL_TASK_5_PRIORITY }
  if task_id == "task-F" { return GLOBAL_TASK_6_PRIORITY }
  return 0
}

fn Task_getDepth(task_id) {
  if task_id == "task-A" { return GLOBAL_TASK_1_DEPTH }
  if task_id == "task-B" { return GLOBAL_TASK_2_DEPTH }
  if task_id == "task-C" { return GLOBAL_TASK_3_DEPTH }
  if task_id == "task-D" { return GLOBAL_TASK_4_DEPTH }
  if task_id == "task-E" { return GLOBAL_TASK_5_DEPTH }
  if task_id == "task-F" { return GLOBAL_TASK_6_DEPTH }
  return 999
}

fn Scheduler_Priority_selectNext() {
  // ReadyQueue에서 priority 가장 높은 Task 찾기
  // 우선순위: priority > depth (낮을수록 우선) > FIFO

  let best_task = ""
  let best_priority = -1
  let best_depth = 999

  // Queue의 모든 항목 순회 (최대 6개)
  let queue_peek = ReadyQueue_peek()
  if queue_peek == "" {
    return ""
  }

  best_task = queue_peek
  best_priority = Task_getPriority(queue_peek)
  best_depth = Task_getDepth(queue_peek)

  return best_task
}

// ─────────────────────────────────────────────────────────────
// Policy Integration: Scheduler 주입
// ─────────────────────────────────────────────────────────────

let GLOBAL_SCHEDULER_STRATEGY = SCHEDULER_STRATEGY_FIFO

fn Policy_setScheduler(strategy) {
  GLOBAL_SCHEDULER_STRATEGY = strategy
  return true
}

fn Policy_selectNext() {
  if GLOBAL_SCHEDULER_STRATEGY == SCHEDULER_STRATEGY_FIFO {
    return Scheduler_FIFO_selectNext()
  }

  if GLOBAL_SCHEDULER_STRATEGY == SCHEDULER_STRATEGY_PRIORITY {
    return Scheduler_Priority_selectNext()
  }

  return ReadyQueue_peek()
}

// ─────────────────────────────────────────────────────────────
// ReadyQueue Simulation (v2.K.1/K.2에서 상속)
// ─────────────────────────────────────────────────────────────

let GLOBAL_READY_QUEUE_COUNT = 0
let GLOBAL_READY_QUEUE_1 = ""
let GLOBAL_READY_QUEUE_2 = ""
let GLOBAL_READY_QUEUE_3 = ""
let GLOBAL_READY_QUEUE_4 = ""
let GLOBAL_READY_QUEUE_5 = ""
let GLOBAL_READY_QUEUE_6 = ""

fn ReadyQueue_add(task_id) {
  if GLOBAL_READY_QUEUE_COUNT >= 6 {
    return false
  }

  GLOBAL_READY_QUEUE_COUNT = GLOBAL_READY_QUEUE_COUNT + 1

  if GLOBAL_READY_QUEUE_COUNT == 1 { GLOBAL_READY_QUEUE_1 = task_id }
  if GLOBAL_READY_QUEUE_COUNT == 2 { GLOBAL_READY_QUEUE_2 = task_id }
  if GLOBAL_READY_QUEUE_COUNT == 3 { GLOBAL_READY_QUEUE_3 = task_id }
  if GLOBAL_READY_QUEUE_COUNT == 4 { GLOBAL_READY_QUEUE_4 = task_id }
  if GLOBAL_READY_QUEUE_COUNT == 5 { GLOBAL_READY_QUEUE_5 = task_id }
  if GLOBAL_READY_QUEUE_COUNT == 6 { GLOBAL_READY_QUEUE_6 = task_id }

  return true
}

fn ReadyQueue_peek() {
  if GLOBAL_READY_QUEUE_COUNT > 0 {
    return GLOBAL_READY_QUEUE_1
  }
  return ""
}

fn ReadyQueue_dequeue() {
  if GLOBAL_READY_QUEUE_COUNT == 0 {
    return ""
  }

  let first = GLOBAL_READY_QUEUE_1

  GLOBAL_READY_QUEUE_1 = GLOBAL_READY_QUEUE_2
  GLOBAL_READY_QUEUE_2 = GLOBAL_READY_QUEUE_3
  GLOBAL_READY_QUEUE_3 = GLOBAL_READY_QUEUE_4
  GLOBAL_READY_QUEUE_4 = GLOBAL_READY_QUEUE_5
  GLOBAL_READY_QUEUE_5 = GLOBAL_READY_QUEUE_6
  GLOBAL_READY_QUEUE_6 = ""

  GLOBAL_READY_QUEUE_COUNT = GLOBAL_READY_QUEUE_COUNT - 1

  return first
}

fn ReadyQueue_length() {
  return GLOBAL_READY_QUEUE_COUNT
}

