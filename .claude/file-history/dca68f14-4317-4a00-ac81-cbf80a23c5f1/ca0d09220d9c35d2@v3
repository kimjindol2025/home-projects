// ─────────────────────────────────────────────────────────────
// TEST 5: Reflect 단계 상태 전이 검증
// ─────────────────────────────────────────────────────────────

fn test_05_reflection_state_transitions() {
  println("")
  println("🧪 TEST 5: Reflect Stage State Transitions")

  let agent = Agent_new("Test state transitions", 2, 10)

  // Observation 생성
  let obs_success = Observation_new(OBSERVATION_SUCCESS, "Success")
  let obs_failure = Observation_new(OBSERVATION_FAILURE, "Failure")

  // Continue 평가
  let result_continue = Reflector_evaluate(STATE_REFLECTING, obs_success, 0, 0)
  assert_equal(result_continue, REFLECTION_CONTINUE, "Success observation → Continue")

  // Retry 평가 (첫 번째 실패)
  let result_retry = Reflector_evaluate(STATE_REFLECTING, obs_failure, 1, 0)
  assert_equal(result_retry, REFLECTION_RETRY, "First failure → Retry")

  // Abort 평가 (두 번째 실패)
  let result_abort = Reflector_evaluate(STATE_REFLECTING, obs_failure, 1, 1)
  assert_equal(result_abort, REFLECTION_ABORT, "Second failure → Abort")

  println("✅ TEST 5 PASSED")
}

