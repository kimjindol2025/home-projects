// Test Utilities
// ─────────────────────────────────────────────────────────────

fn assert_true(actual, msg) {
  if actual {
    println("✓ " + msg)
    return true
  }
  println("✗ FAILED: " + msg)
  return false
}

fn assert_equal(actual, expected, msg) {
  if actual == expected {
    println("✓ " + msg)
    return true
  }
  println("✗ FAILED: " + msg)
  println("  Expected: " + expected)
  println("  Actual: " + actual)
  return false
}

// ─────────────────────────────────────────────────────────────
// TEST 1: Continue → 다음 Task 진행
// ─────────────────────────────────────────────────────────────

fn test_01_reflection_continue() {
  println("")
  println("🧪 TEST 1: Reflection Continue → Next Task")

  let agent = Agent_new("Execute with reflection", 3, 10)

  let success = Agent_run(agent, -1)

  assert_true(success, "Execution completed successfully")
  assert_equal(Agent_state(), STATE_COMPLETED, "Final state: Completed")
  assert_equal(Task_getStatus(0), TASK_STATUS_DONE, "Task 0 done")
  assert_equal(Task_getStatus(1), TASK_STATUS_DONE, "Task 1 done")
  assert_equal(Task_getStatus(2), TASK_STATUS_DONE, "Task 2 done")
  assert_equal(Task_getRetryCount(0), 0, "Task 0 no retries")
  assert_equal(Task_getRetryCount(1), 0, "Task 1 no retries")
  assert_equal(Task_getRetryCount(2), 0, "Task 2 no retries")

  println("✅ TEST 1 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 2: Retry → 동일 Task 1회 재실행
// ─────────────────────────────────────────────────────────────

fn test_02_reflection_retry_once() {
  println("")
  println("🧪 TEST 2: Reflection Retry → Reexecute Same Task (1 retry)")

  let agent = Agent_new("Execute with retry", 3, 10)

  // should_fail_task_index = 1 (Task 1 fails once)
  let success = Agent_run(agent, 1)

  assert_true(success, "Execution completed successfully after retry")
  assert_equal(Agent_state(), STATE_COMPLETED, "Final state: Completed")
  assert_equal(Task_getStatus(0), TASK_STATUS_DONE, "Task 0 done")
  assert_equal(Task_getStatus(1), TASK_STATUS_DONE, "Task 1 done (after retry)")
  assert_equal(Task_getStatus(2), TASK_STATUS_DONE, "Task 2 done")
  assert_equal(Task_getRetryCount(0), 0, "Task 0 no retries")
  assert_equal(Task_getRetryCount(1), 1, "Task 1 retried 1 time")
  assert_equal(Task_getRetryCount(2), 0, "Task 2 no retries")

  println("✅ TEST 2 PASSED")
}

