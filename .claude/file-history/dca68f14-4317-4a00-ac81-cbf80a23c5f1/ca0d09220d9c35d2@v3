  assert_equal(Task_getRetryCount(2), 0, "Initial retry count 0")

  // Run agent
  Agent_run(agent, 1)

  assert_equal(Task_getRetryCount(0), 0, "Task 0 not retried")
  assert_equal(Task_getRetryCount(1), 1, "Task 1 retried once")
  assert_equal(Task_getRetryCount(2), 0, "Task 2 not retried")

  println("✅ TEST 6 PASSED")
}

