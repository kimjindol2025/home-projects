// TEST 1: Policy Initialization with Replan
// ─────────────────────────────────────────────────────────────

fn test_01_policy_initialization() {
  println("")
  println("🧪 TEST 1: Optimistic Replan Policy Initialization")

  OptimisticReplanPolicy_initialize()

  assert_true(GLOBAL_POLICY_INITIALIZED, "Policy initialized")
  assert_equal(POLICY_REPLAN_ALLOWED, true, "Replan allowed: true")
  assert_equal(POLICY_MAX_REPLAN, 2, "Max replan: 2")

  println("✅ TEST 1 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 2: First Failure → Retry
// ─────────────────────────────────────────────────────────────

fn test_02_first_failure_retry() {
  println("")
  println("🧪 TEST 2: First Failure → Retry")

  OptimisticReplanPolicy_initialize()

  let decision = policy_onTaskFailure("task-A", 0)

  assert_equal(decision, POLICY_DECISION_RETRY, "Decision: Retry")
  assert_equal(GLOBAL_POLICY_RETRY_COUNT, 1, "Retry count: 1")

  println("✅ TEST 2 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 3: Second Failure → Replan
// ─────────────────────────────────────────────────────────────

fn test_03_second_failure_replan() {
  println("")
  println("🧪 TEST 3: Second Failure → Replan")

  OptimisticReplanPolicy_initialize()

  // First failure
  policy_onTaskFailure("task-B", 0)

  // Second failure (after retry)
  let decision = policy_onTaskFailure("task-B", 1)

  assert_equal(decision, POLICY_DECISION_REPLAN, "Decision: Replan")
  assert_equal(GLOBAL_POLICY_REPLAN_COUNT, 1, "Replan count: 1")
  assert_equal(GLOBAL_PLAN_DELTA_TYPE, "ADD", "Delta type: ADD")

  println("✅ TEST 3 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 4: MaxReplan Limit (1회 만 허용)
// ─────────────────────────────────────────────────────────────

fn test_04_maxreplan_limit() {
  println("")
  println("🧪 TEST 4: MaxReplan=1 Limit")

  OptimisticReplanPolicy_initialize()

  // First failure: Retry
  let d1 = policy_onTaskFailure("task-C", 0)
  assert_equal(d1, POLICY_DECISION_RETRY, "First fail: Retry")

  // Second failure (after retry): Replan (최대 1회만)
  let d2 = policy_onTaskFailure("task-C", 1)
  assert_equal(d2, POLICY_DECISION_REPLAN, "Second fail: Replan")
  assert_equal(GLOBAL_POLICY_REPLAN_COUNT, 1, "Replan count: 1")

  // Third failure (after replan): Abort (MaxReplan exceeded)
  let d3 = policy_onTaskFailure("task-C", 0)
  assert_equal(d3, POLICY_DECISION_RETRY, "After replan retry: Retry")

  let d4 = policy_onTaskFailure("task-C", 1)
  assert_equal(d4, POLICY_DECISION_ABORT, "After replan fail: Abort (MaxReplan=1 exceeded)")
  assert_equal(GLOBAL_POLICY_REPLAN_COUNT, 1, "Replan count: 1 (no more replan)")

  println("✅ TEST 4 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 5: Task Success After Replan
// ─────────────────────────────────────────────────────────────

fn test_05_success_after_replan() {
  println("")
  println("🧪 TEST 5: Task Success After Replan")

  OptimisticReplanPolicy_initialize()

  // Failure cycle leading to replan
  policy_onTaskFailure("task-D", 0)
  policy_onTaskFailure("task-D", 1)

  // Success after replan
  let decision = policy_onTaskSuccess("task-D")

  assert_equal(decision, POLICY_DECISION_PROCEED, "After replan success: Proceed")
  assert_equal(GLOBAL_POLICY_REPLAN_COUNT, 1, "Replan happened once")

  println("✅ TEST 5 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 6: Constraint Violation Overrides Replan
// ─────────────────────────────────────────────────────────────

fn test_06_constraint_hard_stop() {
  println("")
  println("🧪 TEST 6: Constraint Violation → Hard Stop (No Replan)")

  OptimisticReplanPolicy_initialize()

  // Constraint violation (무조건 Abort, 재계획도 불가)
  let decision = policy_onConstraintViolation("MaxSteps")

  assert_equal(decision, POLICY_DECISION_ABORT, "Constraint: Abort (hard stop)")
  assert_equal(GLOBAL_POLICY_REPLAN_COUNT, 0, "No replan attempted")

  println("✅ TEST 6 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 7: Decision Sequence (Multiple Tasks)
// ─────────────────────────────────────────────────────────────

fn test_07_complex_decision_sequence() {
  println("")
  println("🧪 TEST 7: Complex Decision Sequence")

  OptimisticReplanPolicy_initialize()

  // Task A: success
  let d1 = policy_onTaskSuccess("task-A")
  assert_equal(d1, POLICY_DECISION_PROCEED, "1. Task A success: Proceed")

  // Task B: fail → retry → replan
  policy_onTaskFailure("task-B", 0)
  let d2 = policy_onTaskFailure("task-B", 1)
  assert_equal(d2, POLICY_DECISION_REPLAN, "2. Task B: Replan")

  // Task C: fail → fail → abort (maxreplan exceeded)
  let d3 = policy_onTaskFailure("task-C", 0)
  assert_equal(d3, POLICY_DECISION_RETRY, "3. Task C fail 1: Retry")

  let d4 = policy_onTaskFailure("task-C", 1)
  assert_equal(d4, POLICY_DECISION_REPLAN, "4. Task C fail 2: Replan")

  let d5 = policy_onTaskFailure("task-C", 0)
  assert_equal(d5, POLICY_DECISION_RETRY, "5. Task C after replan: Retry")

  let d6 = policy_onTaskFailure("task-C", 1)
  assert_equal(d6, POLICY_DECISION_ABORT, "6. Task C final: Abort (maxreplan=1 exceeded)")

  println("✅ TEST 7 PASSED")
}

