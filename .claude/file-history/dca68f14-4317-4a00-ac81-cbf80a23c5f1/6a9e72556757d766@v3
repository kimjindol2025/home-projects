// TEST 8: Kernel Application with Replan
// ─────────────────────────────────────────────────────────────

fn test_08_kernel_apply_replan() {
  println("")
  println("🧪 TEST 8: Kernel Apply Replan Decision")

  OptimisticReplanPolicy_initialize()

  // Generate replan decision
  policy_onTaskFailure("task-E", 0)
  let decision = policy_onTaskFailure("task-E", 1)

  // Apply to kernel
  let apply_result = Kernel_applyPolicyDecision(decision, "task-E")

  assert_equal(decision, POLICY_DECISION_REPLAN, "Decision is Replan")
  assert_true(apply_result, "Kernel applied replan")
  assert_equal(GLOBAL_PLAN_DELTA_TYPE, "ADD", "PlanDelta generated")

  println("✅ TEST 8 PASSED")
}

