// ─────────────────────────────────────────────────────────────
// PolicyDecision Enum (v2.K.1에서 확장)
// ─────────────────────────────────────────────────────────────

let POLICY_DECISION_PROCEED = 1      // 정상 진행
let POLICY_DECISION_RETRY = 2        // Task 재실행
let POLICY_DECISION_REPLAN = 3       // 재계획 (새로운)
let POLICY_DECISION_ABORT = 4        // 중단

fn policy_decision_name(decision) {
  if decision == POLICY_DECISION_PROCEED { return "Proceed" }
  if decision == POLICY_DECISION_RETRY { return "Retry" }
  if decision == POLICY_DECISION_REPLAN { return "Replan" }
  if decision == POLICY_DECISION_ABORT { return "Abort" }
  return "Unknown"
}

// ─────────────────────────────────────────────────────────────
// Optimistic Replan Policy Configuration
// ─────────────────────────────────────────────────────────────

let POLICY_MAX_RETRY = 1              // 한 번만 재시도
let POLICY_MAX_REPLAN = 1             // 최대 1회 재계획 (사용자 요구)
let POLICY_REPLAN_ALLOWED = true      // 재계획 허용 (v2.K.1과의 차이)
let POLICY_MAX_PARALLEL = 1           // 순차 실행
let POLICY_FAILURE_STRATEGY = 1       // FAIL_FAST

// ─────────────────────────────────────────────────────────────
// Global Policy State (v2.K.1 + 재계획 추가)
// ─────────────────────────────────────────────────────────────

let GLOBAL_POLICY_INITIALIZED = false
let GLOBAL_POLICY_RETRY_COUNT = 0
let GLOBAL_POLICY_REPLAN_COUNT = 0
let GLOBAL_POLICY_DECISIONS_MADE = 0

let GLOBAL_POLICY_LAST_DECISION = 0
let GLOBAL_POLICY_LAST_CONTEXT = ""

// PlanDelta (v1.8에서 재사용)
let GLOBAL_PLAN_DELTA_TYPE = ""        // ADD, REPLACE, REMOVE
let GLOBAL_PLAN_DELTA_TASK_ID = ""
let GLOBAL_PLAN_DELTA_POSITION = 0

// ─────────────────────────────────────────────────────────────
// Policy Initialization
// ─────────────────────────────────────────────────────────────

fn OptimisticReplanPolicy_initialize() {
  GLOBAL_POLICY_INITIALIZED = true
  GLOBAL_POLICY_RETRY_COUNT = 0
  GLOBAL_POLICY_REPLAN_COUNT = 0
  GLOBAL_POLICY_DECISIONS_MADE = 0

  return true
}

// ─────────────────────────────────────────────────────────────
// PlanDelta Generation (재계획 구성 요소)
// ─────────────────────────────────────────────────────────────

fn createPlanDelta_addRecoveryTask(failed_task_id, position) {
  // 재계획 시나리오: 실패한 Task 근처에 복구 Task 추가
  // 예: task-A 실패 → recovery-task 추가 → task-A 재시도
  GLOBAL_PLAN_DELTA_TYPE = "ADD"
  GLOBAL_PLAN_DELTA_TASK_ID = "recovery-" + failed_task_id
  GLOBAL_PLAN_DELTA_POSITION = position

  return true
}

// ─────────────────────────────────────────────────────────────
// Policy Decision Functions (AgentPolicy Interface)
// ─────────────────────────────────────────────────────────────

// Policy: onTaskSuccess
fn policy_onTaskSuccess(task_id) {
  GLOBAL_POLICY_DECISIONS_MADE = GLOBAL_POLICY_DECISIONS_MADE + 1
  GLOBAL_POLICY_LAST_DECISION = POLICY_DECISION_PROCEED
  GLOBAL_POLICY_LAST_CONTEXT = task_id

  return POLICY_DECISION_PROCEED
}

// Policy: onTaskFailure
// → 순차: Retry → Replan → Abort
fn policy_onTaskFailure(task_id, retry_count) {
  GLOBAL_POLICY_DECISIONS_MADE = GLOBAL_POLICY_DECISIONS_MADE + 1
  GLOBAL_POLICY_LAST_CONTEXT = task_id

  // 첫 번째 실패: Retry
  if retry_count == 0 {
    GLOBAL_POLICY_RETRY_COUNT = GLOBAL_POLICY_RETRY_COUNT + 1
    GLOBAL_POLICY_LAST_DECISION = POLICY_DECISION_RETRY
    return POLICY_DECISION_RETRY
  }

  // 두 번째 실패: 재계획 시도
  if retry_count == 1 {
    if GLOBAL_POLICY_REPLAN_COUNT >= POLICY_MAX_REPLAN {
      // 재계획 횟수 초과: Abort
      GLOBAL_POLICY_LAST_DECISION = POLICY_DECISION_ABORT
      return POLICY_DECISION_ABORT
    }

    // 재계획 허용
    GLOBAL_POLICY_REPLAN_COUNT = GLOBAL_POLICY_REPLAN_COUNT + 1
    createPlanDelta_addRecoveryTask(task_id, 0)
    GLOBAL_POLICY_LAST_DECISION = POLICY_DECISION_REPLAN
    return POLICY_DECISION_REPLAN
  }

  // 재계획 이후에도 실패: Abort
  GLOBAL_POLICY_LAST_DECISION = POLICY_DECISION_ABORT
  return POLICY_DECISION_ABORT
}

// Policy: onConstraintViolation
fn policy_onConstraintViolation(constraint_name) {
  GLOBAL_POLICY_DECISIONS_MADE = GLOBAL_POLICY_DECISIONS_MADE + 1
  GLOBAL_POLICY_LAST_DECISION = POLICY_DECISION_ABORT
  GLOBAL_POLICY_LAST_CONTEXT = constraint_name

  return POLICY_DECISION_ABORT
}

// ─────────────────────────────────────────────────────────────
// Kernel Abstraction (Policy 결정 집행)
// ─────────────────────────────────────────────────────────────

fn Kernel_applyPolicyDecision(decision, task_id) {
  if decision == POLICY_DECISION_PROCEED {
    return true
  }

  if decision == POLICY_DECISION_RETRY {
    return true
  }

  if decision == POLICY_DECISION_REPLAN {
    // DAG 수정 (역방향 흐름)
    // 실제 구현에서는 PlanDelta를 DAG에 적용
    return true
  }

  if decision == POLICY_DECISION_ABORT {
    return false
  }

  return false
}

// ─────────────────────────────────────────────────────────────
// Test Utilities
// ─────────────────────────────────────────────────────────────

fn assert_true(actual, msg) {
  if actual {
    println("✓ " + msg)
    return true
  }
  println("✗ FAILED: " + msg)
  return false
}

fn assert_equal(actual, expected, msg) {
  if actual == expected {
    println("✓ " + msg)
    return true
  }
  println("✗ FAILED: " + msg)
  println("  Expected: " + expected)
  println("  Actual: " + actual)
  return false
}

