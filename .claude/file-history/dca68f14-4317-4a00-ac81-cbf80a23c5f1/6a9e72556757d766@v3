// ─────────────────────────────────────────────────────────────
// TEST 10: Reverse Flow Validation (Planner ↔ Execution)
// ─────────────────────────────────────────────────────────────

fn test_10_reverse_flow() {
  println("")
  println("🧪 TEST 10: Reverse Flow (Planner ↔ Execution)")

  OptimisticReplanPolicy_initialize()

  // Forward flow: Planner → Execution
  let d1 = policy_onTaskSuccess("task-initial")
  assert_equal(d1, POLICY_DECISION_PROCEED, "Forward: Execution → Success")

  // Failure triggers reverse flow
  policy_onTaskFailure("task-failed", 0)
  let d2 = policy_onTaskFailure("task-failed", 1)

  // Reverse flow: Execution → Planner (via Replan)
  assert_equal(d2, POLICY_DECISION_REPLAN, "Reverse: Execution → Planner")

  // After replan, forward again
  let d3 = policy_onTaskSuccess("task-replanned")
  assert_equal(d3, POLICY_DECISION_PROCEED, "Forward again: Replanned → Success")

  println("✅ TEST 10 PASSED")
}

