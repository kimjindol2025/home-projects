// ─────────────────────────────────────────────────────────────
// Task Status Constants
// ─────────────────────────────────────────────────────────────

let TASK_STATUS_PENDING = 0
let TASK_STATUS_RUNNING = 1
let TASK_STATUS_DONE = 2
let TASK_STATUS_ERROR = 3

fn task_status_name(status) {
  if status == TASK_STATUS_PENDING { return "Pending" }
  if status == TASK_STATUS_RUNNING { return "Running" }
  if status == TASK_STATUS_DONE { return "Done" }
  if status == TASK_STATUS_ERROR { return "Error" }
  return "Unknown"
}

// ─────────────────────────────────────────────────────────────
// Tool Types (정의만)
// ─────────────────────────────────────────────────────────────

let TOOL_TYPE_ANALYZER = 1
let TOOL_TYPE_PROCESSOR = 2
let TOOL_TYPE_VALIDATOR = 3

fn tool_type_name(ttype) {
  if ttype == TOOL_TYPE_ANALYZER { return "Analyzer" }
  if ttype == TOOL_TYPE_PROCESSOR { return "Processor" }
  if ttype == TOOL_TYPE_VALIDATOR { return "Validator" }
  return "Unknown"
}

// ─────────────────────────────────────────────────────────────
// Observation (실행 결과)
// ─────────────────────────────────────────────────────────────

let OBSERVATION_SUCCESS = 0
let OBSERVATION_FAILURE = 1

fn Observation_new(is_success, message, data) {
  return [is_success, message, data]
}

fn Observation_isSuccess(obs) {
  return obs[0] == OBSERVATION_SUCCESS
}

fn Observation_message(obs) {
  return obs[1]
}

fn Observation_data(obs) {
  return obs[2]
}

// ─────────────────────────────────────────────────────────────
// ExecutionContext (Tool 실행 환경)
// ─────────────────────────────────────────────────────────────

let GLOBAL_CONTEXT_GOAL = ""
let GLOBAL_CONTEXT_MEMORY = ""

fn ExecutionContext_new(goal_description, memory_state) {
  GLOBAL_CONTEXT_GOAL = goal_description
  GLOBAL_CONTEXT_MEMORY = memory_state
  return 1
}

fn ExecutionContext_goal(ctx) {
  return GLOBAL_CONTEXT_GOAL
}

fn ExecutionContext_memory(ctx) {
  return GLOBAL_CONTEXT_MEMORY
}

// ─────────────────────────────────────────────────────────────
// Tool Interface (함수 기반)
// Tool이 구현해야 할 메서드
// ─────────────────────────────────────────────────────────────

// Tool의 execute 함수 패턴
// fn Tool_execute(tool_id, ctx, input) -> Observation

fn MockTool_analyze(ctx, input) {
  let goal = ExecutionContext_goal(ctx)

  if input == "" {
    return Observation_new(OBSERVATION_FAILURE, "Empty input", "")
  }

  if goal == "" {
    return Observation_new(OBSERVATION_FAILURE, "No goal context", "")
  }

  return Observation_new(OBSERVATION_SUCCESS, "Analysis complete", input + " analyzed")
}

fn MockTool_process(ctx, input) {
  if input == "fail" {
    return Observation_new(OBSERVATION_FAILURE, "Processing failed", "")
  }

  return Observation_new(OBSERVATION_SUCCESS, "Processing complete", input + " processed")
}

fn MockTool_validate(ctx, input) {
  if input == "" {
    return Observation_new(OBSERVATION_FAILURE, "Validation error: empty", "")
  }

  return Observation_new(OBSERVATION_SUCCESS, "Validation passed", input + " valid")
}

// ─────────────────────────────────────────────────────────────
// ToolRef (Tool 참조)
// ─────────────────────────────────────────────────────────────

let TOOL_REF_ANALYZE = 1
let TOOL_REF_PROCESS = 2
let TOOL_REF_VALIDATE = 3

fn ToolRef_execute(tool_ref, ctx, input) {
  if tool_ref == TOOL_REF_ANALYZE {
    return MockTool_analyze(ctx, input)
  }

  if tool_ref == TOOL_REF_PROCESS {
    return MockTool_process(ctx, input)
  }

  if tool_ref == TOOL_REF_VALIDATE {
    return MockTool_validate(ctx, input)
  }

  return Observation_new(OBSERVATION_FAILURE, "Unknown tool", "")
}

fn ToolRef_name(tool_ref) {
  if tool_ref == TOOL_REF_ANALYZE { return "Analyze" }
  if tool_ref == TOOL_REF_PROCESS { return "Process" }
  if tool_ref == TOOL_REF_VALIDATE { return "Validate" }
  return "Unknown"
}

// ─────────────────────────────────────────────────────────────
// Task State Management (전역)
// ─────────────────────────────────────────────────────────────

let GLOBAL_TASK_STATUS = TASK_STATUS_PENDING
let GLOBAL_TASK_OUTPUT = ""
let GLOBAL_TASK_ERROR_MSG = ""

fn Task_getStatus() {
  return GLOBAL_TASK_STATUS
}

fn Task_setStatus(status) {
  GLOBAL_TASK_STATUS = status
  return status
}

fn Task_getOutput() {
  return GLOBAL_TASK_OUTPUT
}

fn Task_setOutput(output) {
  GLOBAL_TASK_OUTPUT = output
  return output
}

fn Task_getError() {
  return GLOBAL_TASK_ERROR_MSG
}

fn Task_setError(error) {
  GLOBAL_TASK_ERROR_MSG = error
  return error
}

// ─────────────────────────────────────────────────────────────
// TaskExecutor (핵심 실행 엔진)
// ─────────────────────────────────────────────────────────────

fn TaskExecutor_execute(tool_ref, ctx, input_data, goal_description) {
  // 초기화
  Task_setStatus(TASK_STATUS_PENDING)
  Task_setOutput("")
  Task_setError("")

  // 상태: Running
  Task_setStatus(TASK_STATUS_RUNNING)

  // Context 설정
  ExecutionContext_new(goal_description, "memory_state")

  // Tool 실행
  let observation = ToolRef_execute(tool_ref, ctx, input_data)

  // 결과 처리
  if Observation_isSuccess(observation) {
    // 성공: Done
    Task_setStatus(TASK_STATUS_DONE)
    Task_setOutput(Observation_data(observation))
    return observation
  } else {
    // 실패: Error
    Task_setStatus(TASK_STATUS_ERROR)
    Task_setError(Observation_message(observation))
    return observation
  }
}

// ─────────────────────────────────────────────────────────────
// Test Utilities
// ─────────────────────────────────────────────────────────────

fn assert_true(actual, msg) {
  if actual {
    println("✓ " + msg)
    return true
  }
  println("✗ FAILED: " + msg)
  return false
}

fn assert_equal(actual, expected, msg) {
  if actual == expected {
    println("✓ " + msg)
    return true
  }
  println("✗ FAILED: " + msg)
  println("  Expected: " + expected)
  println("  Actual: " + actual)
  return false
}

