// Phase 5.2: TypeInference - 자동 타입 추론 엔진

import { Stmt } from "./ast"
import {
  Type,
  PrimitiveType,
  Constraint,
  widenType,
  BUILTIN_TYPES,
} from "./type-system"

/**
 * TypeInference: 타입 미정 변수 자동 추론
 */
export class TypeInference {
  private constraints: Constraint[] = []
  private solutions: Map<string, Type> = new Map()

  /**
   * 제약 조건 추가
   */
  public addConstraint(
    variable: string,
    expectedType: Type,
    actualType?: Type,
    location?: { line: number; column: number }
  ): void {
    this.constraints.push({
      variable,
      expectedType,
      actualType,
      location,
    })
  }

  /**
   * 제약 조건 풀기
   */
  public solve(): Map<string, Type> {
    this.solutions.clear()

    const varConstraints = new Map<string, Constraint[]>()
    for (const constraint of this.constraints) {
      if (!varConstraints.has(constraint.variable)) {
        varConstraints.set(constraint.variable, [])
      }
      varConstraints.get(constraint.variable)!.push(constraint)
    }

    for (const [variable, constraints] of varConstraints.entries()) {
      if (constraints.length === 0) {
        this.solutions.set(variable, BUILTIN_TYPES.UNKNOWN)
        continue
      }

      let resultType = constraints[0].expectedType
      for (let i = 1; i < constraints.length; i++) {
        const unified = this.unify(resultType, constraints[i].expectedType)
        if (unified) {
          resultType = unified
        }
      }

      this.solutions.set(variable, resultType)
    }

    return new Map(this.solutions)
  }

  /**
   * Hindley-Milner 스타일 타입 통일
   */
  public unify(t1: Type, t2: Type): Type | null {
    if (JSON.stringify(t1) === JSON.stringify(t2)) {
      return t1
    }

    if (t1.kind === "primitive" && t1.type === PrimitiveType.UNKNOWN) {
      return t2
    }

    if (t2.kind === "primitive" && t2.type === PrimitiveType.UNKNOWN) {
      return t1
    }

    if (t1.kind === "primitive" && t2.kind === "primitive") {
      return t1.type === t2.type ? t1 : null
    }

    if (t1.kind === "array" && t2.kind === "array") {
      const elemUnified = this.unify(t1.elementType, t2.elementType)
      if (elemUnified) {
        return { kind: "array", elementType: elemUnified }
      }
      return null
    }

    if (t1.kind === "fn" && t2.kind === "fn") {
      if (t1.paramTypes.length !== t2.paramTypes.length) {
        return null
      }

      const unifiedParams: Type[] = []
      for (let i = 0; i < t1.paramTypes.length; i++) {
        const paramUnified = this.unify(t1.paramTypes[i], t2.paramTypes[i])
        if (!paramUnified) {
          return null
        }
        unifiedParams.push(paramUnified)
      }

      const returnUnified = this.unify(t1.returnType, t2.returnType)
      if (!returnUnified) {
        return null
      }

      return {
        kind: "fn",
        paramTypes: unifiedParams,
        returnType: returnUnified,
      }
    }

    if (t1.kind === "object" && t2.kind === "object") {
      const keys1 = Array.from(t1.properties.keys()).sort()
      const keys2 = Array.from(t2.properties.keys()).sort()

      if (keys1.length !== keys2.length) {
        return null
      }

      if (!keys1.every((k, i) => k === keys2[i])) {
        return null
      }

      const unifiedProps = new Map<string, Type>()
      for (const key of keys1) {
        const propUnified = this.unify(
          t1.properties.get(key)!,
          t2.properties.get(key)!
        )
        if (!propUnified) {
          return null
        }
        unifiedProps.set(key, propUnified)
      }

      return {
        kind: "object",
        properties: unifiedProps,
      }
    }

    return null
  }

  /**
   * 함수 반환 타입 추론
   */
  public inferReturnType(
    body: Stmt[],
    env: Map<string, Type>,
    checker: any
  ): Type {
    const returnTypes: Type[] = []

    const findReturns = (stmts: Stmt[]) => {
      for (const stmt of stmts) {
        if (stmt.kind === "return") {
          const returnStmt = stmt as any
          if (returnStmt.value) {
            const retType = checker.checkExpr(returnStmt.value)
            returnTypes.push(retType)
          }
        } else if (stmt.kind === "if") {
          const ifStmt = stmt as any
          findReturns(ifStmt.then || [])
          if (ifStmt.else) {
            findReturns(ifStmt.else)
          }
        } else if (stmt.kind === "block") {
          const blockStmt = stmt as any
          findReturns(blockStmt.body || [])
        } else if (stmt.kind === "while" || stmt.kind === "for") {
          const loopStmt = stmt as any
          findReturns(loopStmt.body || [])
        }
      }
    }

    findReturns(body)

    if (returnTypes.length === 0) {
      return BUILTIN_TYPES.NULL
    }

    if (returnTypes.length === 1) {
      return returnTypes[0]
    }

    return widenType(...returnTypes)
  }

  /**
   * for 루프 변수 타입 추론
   */
  public inferLoopVarType(iterType: Type): Type {
    if (iterType.kind === "array") {
      return iterType.elementType
    }
    return BUILTIN_TYPES.UNKNOWN
  }

  /**
   * 제약 개수 조회
   */
  public getConstraintCount(): number {
    return this.constraints.length
  }

  /**
   * 제약 목록 조회
   */
  public getConstraints(): Constraint[] {
    return [...this.constraints]
  }

  /**
   * 해결된 타입 조회
   */
  public getSolution(variable: string): Type | undefined {
    return this.solutions.get(variable)
  }
}
