/**
 * TEST 5: RefCount 추적
 */
function test_05_refcount_tracking(): void {
  console.log("\n🧪 TEST 5: RefCount 추적");

  const code = `
    let x = 100
    let y = x
    println(x)
  `;

  const tokens = lex(code);
  const ast = parse(tokens);
  const chunk = compile(ast);
  const vm = new VM(chunk);

  const { output } = vm.run();

  assertEqual(output[0], "100", "값 올바름");

  const heap = vm.getHeapManager();
  const stats = heap.getStats();

  console.log(`  [Heap Stats] allocated=${stats.totalAllocated}, freed=${stats.totalFreed}`);

  assert(stats.totalAllocated > 0, "최소 1개 이상 할당");

  console.log("✅ TEST 5 PASSED\n");
}

/**
 * TEST 6: 복수 상수
 */
function test_06_multiple_constants(): void {
  console.log("\n🧪 TEST 6: 복수 상수");

  const code = `
    let a = 1
    let b = 2
    let c = 3
    let d = 4
    let e = 5
    println(a)
    println(b)
    println(c)
    println(d)
    println(e)
  `;

  const tokens = lex(code);
  const ast = parse(tokens);
  const chunk = compile(ast);
  const vm = new VM(chunk);

  const { output } = vm.run();

  assertEqual(output.length, 5, "5개 출력");
  assertEqual(output[0], "1", "첫 번째: 1");
  assertEqual(output[4], "5", "다섯 번째: 5");

  const heap = vm.getHeapManager();
  const stats = heap.getStats();

  console.log(`  [Heap Stats] allocated=${stats.totalAllocated}`);

  assert(stats.totalAllocated >= 5, "5개 이상 할당");

  console.log("✅ TEST 6 PASSED\n");
}

