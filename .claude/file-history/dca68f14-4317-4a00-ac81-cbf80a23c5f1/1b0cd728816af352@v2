// Phase 2 Step 4 Test: Load/Store (지역 변수) Heap 기반 변환

import { compile } from "./compiler";
import { VM } from "./vm";
import { lex } from "./lexer";
import { parse } from "./parser";

function assert(condition: boolean, msg: string): void {
  if (condition) {
    console.log(`✓ ${msg}`);
  } else {
    console.error(`✗ FAILED: ${msg}`);
    process.exit(1);
  }
}

function assertEqual(actual: any, expected: any, msg: string): void {
  const actualStr = typeof actual === "string" ? actual.trim() : actual;
  const expectedStr = typeof expected === "string" ? expected.trim() : expected;

  if (actualStr === expectedStr) {
    console.log(`✓ ${msg}`);
  } else {
    console.error(`✗ FAILED: ${msg} (expected ${expectedStr}, got ${actualStr})`);
    process.exit(1);
  }
}

/**
 * TEST 1: 함수 내 지역 변수
 */
function test_01_local_variable(): void {
  console.log("\n🧪 TEST 1: 함수 내 지역 변수 (Load/Store Heap)");

  const code = `
    fn test() {
      x = 42
      println(x)
    }

    test()
  `;

  const tokens = lex(code);
  const ast = parse(tokens);
  const chunk = compile(ast);
  const vm = new VM(chunk);

  const { output } = vm.run();

  assertEqual(output[0], "42", "지역 변수 x = 42");

  const heap = vm.getHeapManager();
  const stats = heap.getStats();
  console.log(`  [Heap Stats] allocated=${stats.totalAllocated}`);

  assert(stats.totalAllocated > 0, "지역 변수가 heap에 할당됨");

  console.log("✅ TEST 1 PASSED\n");
}

/**
 * TEST 2: 함수 인자 처리
 */
function test_02_function_parameters(): void {
  console.log("\n🧪 TEST 2: 함수 인자 처리 (Load Heap)");

  const code = `
    fn add(a, b) {
      sum = a + b
      return sum
    }

    result = add(10, 20)
    println(result)
  `;

  const tokens = lex(code);
  const ast = parse(tokens);
  const chunk = compile(ast);
  const vm = new VM(chunk);

  const { output } = vm.run();

  assertEqual(output[0], "30", "add(10, 20) = 30");

  const heap = vm.getHeapManager();
  const stats = heap.getStats();
  console.log(`  [Heap Stats] allocated=${stats.totalAllocated}`);

  assert(stats.totalAllocated >= 4, "함수 인자와 결과가 heap에 할당됨");

  console.log("✅ TEST 2 PASSED\n");
}

/**
 * TEST 3: 지역 변수 재할당
 */
function test_03_local_reassignment(): void {
  console.log("\n🧪 TEST 3: 지역 변수 재할당");

  const code = `
    fn counter() {
      count = 0
      count = count + 1
      count = count + 1
      count = count + 1
      return count
    }

    result = counter()
    println(result)
  `;

  const tokens = lex(code);
  const ast = parse(tokens);
  const chunk = compile(ast);
  const vm = new VM(chunk);

  const { output } = vm.run();

  assertEqual(output[0], "3", "count = 0+1+1+1 = 3");

  const heap = vm.getHeapManager();
  const stats = heap.getStats();
  console.log(`  [Heap Stats] allocated=${stats.totalAllocated}`);

  assert(stats.totalAllocated >= 5, "모든 중간값이 heap에 할당됨");

  console.log("✅ TEST 3 PASSED\n");
}

/**
 * TEST 4: 중첩 함수 호출
 */
function test_04_nested_calls(): void {
  console.log("\n🧪 TEST 4: 중첩 함수 호출");

  const code = `
    fn double(x) {
      return x * 2
    }

    fn quadruple(x) {
      doubled = double(x)
      return double(doubled)
    }

    result = quadruple(5)
    println(result)
  `;

  const tokens = lex(code);
  const ast = parse(tokens);
  const chunk = compile(ast);
  const vm = new VM(chunk);

  const { output } = vm.run();

  assertEqual(output[0], "20", "quadruple(5) = 20");

  const heap = vm.getHeapManager();
  const stats = heap.getStats();
  console.log(`  [Heap Stats] allocated=${stats.totalAllocated}`);

  assert(stats.totalAllocated >= 5, "중첩 호출의 모든 지역 변수가 heap에 할당됨");

  console.log("✅ TEST 4 PASSED\n");
}

/**
 * TEST 5: 지역 변수와 글로벌 변수 혼합
 */
function test_05_local_and_global(): void {
  console.log("\n🧪 TEST 5: 지역 변수와 글로벌 변수 혼합");

  const code = `
    global_x = 100

    fn process() {
      local_y = 50
      result = global_x + local_y
      return result
    }

    answer = process()
    println(answer)
  `;

  const tokens = lex(code);
  const ast = parse(tokens);
  const chunk = compile(ast);
  const vm = new VM(chunk);

  const { output } = vm.run();

  assertEqual(output[0], "150", "global(100) + local(50) = 150");

  const heap = vm.getHeapManager();
  const stats = heap.getStats();
  console.log(`  [Heap Stats] allocated=${stats.totalAllocated}`);

  assert(stats.totalAllocated >= 4, "글로벌과 지역 변수가 모두 heap에 할당됨");

  console.log("✅ TEST 5 PASSED\n");
}

/**
 * TEST 6: 배열을 지역 변수로
 */
function test_06_array_local(): void {
  console.log("\n🧪 TEST 6: 배열을 지역 변수로");

  const code = `
    fn sum_array() {
      arr = [1, 2, 3, 4, 5]
      sum = 0
      for i in arr {
        sum = sum + i
      }
      return sum
    }

    total = sum_array()
    println(total)
  `;

  const tokens = lex(code);
  const ast = parse(tokens);
  const chunk = compile(ast);
  const vm = new VM(chunk);

  const { output } = vm.run();

  assertEqual(output[0], "15", "배열 [1,2,3,4,5]의 합 = 15");

  const heap = vm.getHeapManager();
  const stats = heap.getStats();
  console.log(`  [Heap Stats] allocated=${stats.totalAllocated}`);

  assert(stats.totalAllocated >= 6, "배열과 루프 변수가 heap에 할당됨");

  console.log("✅ TEST 6 PASSED\n");
}

