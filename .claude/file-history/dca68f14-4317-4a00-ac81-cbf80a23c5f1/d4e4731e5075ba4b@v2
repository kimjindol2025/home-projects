// Phase 3 GC Test: 순환 참조 및 Mark-Sweep 검증

import { compile } from "./compiler";
import { VM } from "./vm";
import { lex } from "./lexer";
import { parse } from "./parser";

function assert(condition: boolean, msg: string): void {
  if (condition) {
    console.log(`✓ ${msg}`);
  } else {
    console.error(`✗ FAILED: ${msg}`);
    process.exit(1);
  }
}

function assertEqual(actual: any, expected: any, msg: string): void {
  const actualStr = typeof actual === "string" ? actual.trim() : actual;
  const expectedStr = typeof expected === "string" ? expected.trim() : expected;

  if (actualStr === expectedStr) {
    console.log(`✓ ${msg}`);
  } else {
    console.error(`✗ FAILED: ${msg} (expected ${expectedStr}, got ${actualStr})`);
    process.exit(1);
  }
}

