// ─────────────────────────────────────────────────────────────
// 🔧 Agent State Constants
// ─────────────────────────────────────────────────────────────

let STATE_IDLE = 0
let STATE_PLANNING = 1
let STATE_EXECUTING = 2
let STATE_OBSERVING = 3
let STATE_REFLECTING = 4
let STATE_COMPLETED = 5
let STATE_FAILED = 6

fn state_to_string(state) {
  if state == STATE_IDLE {
    return "Idle"
  }
  if state == STATE_PLANNING {
    return "Planning"
  }
  if state == STATE_EXECUTING {
    return "Executing"
  }
  if state == STATE_OBSERVING {
    return "Observing"
  }
  if state == STATE_REFLECTING {
    return "Reflecting"
  }
  if state == STATE_COMPLETED {
    return "Completed"
  }
  if state == STATE_FAILED {
    return "Failed"
  }
  return "Unknown"
}

// Task Status Constants
let TASK_PENDING = 0
let TASK_RUNNING = 1
let TASK_DONE = 2
let TASK_ERROR = 3

fn task_status_to_string(status) {
  if status == TASK_PENDING {
    return "Pending"
  }
  if status == TASK_RUNNING {
    return "Running"
  }
  if status == TASK_DONE {
    return "Done"
  }
  if status == TASK_ERROR {
    return "Error"
  }
  return "Unknown"
}


// ─────────────────────────────────────────────────────────────
// 📦 Goal (Array-based implementation)
// ─────────────────────────────────────────────────────────────

fn Goal_new(description, success_criteria) {
  let goal = []
  goal.push(description)    // 0: description
  goal.push(success_criteria) // 1: success_criteria
  return goal
}

fn Goal_desc(goal) {
  return goal[0]
}

fn Goal_criteria(goal) {
  return goal[1]
}


// ─────────────────────────────────────────────────────────────
// 📌 Task (Array-based implementation)
// ─────────────────────────────────────────────────────────────

fn Task_new(id, description, tool) {
  let task = []
  task.push(id)          // 0: id
  task.push(description) // 1: description
  task.push(tool)        // 2: tool
  task.push(TASK_PENDING) // 3: status
  task.push("")          // 4: output
  return task
}

fn Task_id(task) {
  return task[0]
}

fn Task_desc(task) {
  return task[1]
}

fn Task_tool(task) {
  return task[2]
}

fn Task_status(task) {
  return task[3]
}

fn Task_output(task) {
  return task[4]
}

fn Task_setStatus(task, status) {
  task[3] = status
  return task
}

fn Task_setOutput(task, output) {
  task[4] = output
  return task
}


// ─────────────────────────────────────────────────────────────
// 🗂️ Plan (Task 목록 관리)
// ─────────────────────────────────────────────────────────────

fn Plan_new() {
  let plan = []
  plan.push([])     // 0: tasks array
  plan.push(0)      // 1: current_index
  return plan
}

fn Plan_tasks(plan) {
  return plan[0]
}

fn Plan_currentIndex(plan) {
  return plan[1]
}

fn Plan_addTask(plan, task) {
  let tasks = plan[0]
  tasks.push(task)
  return plan
}

fn Plan_getCurrentTask(plan) {
  let tasks = plan[0]
  let idx = plan[1]
  if idx < tasks.length {
    return tasks[idx]
  }
  return ""
}

fn Plan_advanceIndex(plan) {
  plan[1] = plan[1] + 1
  return plan
}

fn Plan_allTasksDone(plan) {
  let tasks = plan[0]
  let i = 0
  let count = 0
  while i < tasks.length {
    if tasks[i][3] == TASK_DONE {
      count = count + 1
    }
    i = i + 1
  }
  return count == tasks.length
}


// ─────────────────────────────────────────────────────────────
// 💾 Memory (Key-Value 저장소)
// ─────────────────────────────────────────────────────────────

fn Memory_new() {
  let memory = []
  memory.push([])  // 0: keys array
  memory.push([])  // 1: values array
  return memory
}

fn Memory_set(memory, key, value) {
  let keys = memory[0]
  let values = memory[1]
  let i = 0
  while i < keys.length {
    if keys[i] == key {
      values[i] = value
      return memory
    }
    i = i + 1
  }
  keys.push(key)
  values.push(value)
  return memory
}

fn Memory_get(memory, key) {
  let keys = memory[0]
  let values = memory[1]
  let i = 0
  while i < keys.length {
    if keys[i] == key {
      return values[i]
    }
    i = i + 1
  }
  return ""
}

fn Memory_size(memory) {
  return memory[0].length
}


// ─────────────────────────────────────────────────────────────
// 🤖 Agent (핵심 구조)
// ─────────────────────────────────────────────────────────────

fn Agent_new(agent_id, goal) {
  let agent = []
  agent.push(agent_id)    // 0: id
  agent.push(goal)        // 1: goal
  agent.push(Plan_new())  // 2: plan
  agent.push(Memory_new()) // 3: memory
  agent.push(STATE_IDLE)  // 4: state
  return agent
}

fn Agent_id(agent) {
  return agent[0]
}

fn Agent_goal(agent) {
  return agent[1]
}

fn Agent_plan(agent) {
  return agent[2]
}

fn Agent_memory(agent) {
  return agent[3]
}

fn Agent_state(agent) {
  return agent[4]
}

fn Agent_setState(agent, new_state) {
  agent[4] = new_state
  return agent
}


// ─────────────────────────────────────────────────────────────
// 🔄 상태 전이 로직
// ─────────────────────────────────────────────────────────────

fn Agent_nextState(agent) {
  let current_state = agent["state"]

  if current_state == AgentState_Idle() {
    println("📍 State: Idle")
    println("   → Setting state to Planning")
    agent = Agent_setState(agent, AgentState_Planning())
    return agent
  }

  if current_state == AgentState_Planning() {
    println("📍 State: Planning")
    println("   → Goal: " + agent["goal"]["description"])
    println("   → Creating tasks...")

    // Simulate task creation (v2.x에서 Planner로 자동화)
    let task1 = Task_new("task-1", "Analyze goal", "analyzer")
    let task2 = Task_new("task-2", "Execute plan", "executor")
    let task3 = Task_new("task-3", "Verify result", "validator")

    agent["plan"] = Plan_addTask(agent["plan"], task1)
    agent["plan"] = Plan_addTask(agent["plan"], task2)
    agent["plan"] = Plan_addTask(agent["plan"], task3)

    println("   → Created " + agent["plan"]["tasks"].length + " tasks")
    agent = Agent_setState(agent, AgentState_Executing())
    return agent
  }

  if current_state == AgentState_Executing() {
    println("📍 State: Executing")

    let current_task = Plan_getCurrentTask(agent["plan"])

    if current_task != "" {
      println("   → Executing task: " + current_task["description"])

      // Simulate task execution
      current_task = Task_setStatus(current_task, TaskStatus_Running())
      current_task = Task_setOutput(current_task, "Execution successful")
      current_task = Task_setStatus(current_task, TaskStatus_Done())

      // Update task in plan
      agent["plan"]["tasks"][agent["plan"]["current_index"]] = current_task

      println("   → Task completed: " + current_task["description"])
    }

    agent = Agent_setState(agent, AgentState_Observing())
    return agent
  }

  if current_state == AgentState_Observing() {
    println("📍 State: Observing")

    let current_task = Plan_getCurrentTask(agent["plan"])
    if current_task != "" {
      println("   → Result: " + current_task["output"])
      agent["memory"] = Memory_set(agent["memory"], "last_output", current_task["output"])
      println("   → Stored in memory")
    }

    // Check if all tasks done
    if Plan_allTasksDone(agent["plan"]) {
      println("   → All tasks completed!")
      agent = Agent_setState(agent, AgentState_Reflecting())
    } else {
      println("   → More tasks remaining")
      agent["plan"] = Plan_advanceIndex(agent["plan"])
      agent = Agent_setState(agent, AgentState_Executing())
    }

    return agent
  }

  if current_state == AgentState_Reflecting() {
    println("📍 State: Reflecting")
    println("   → Evaluating results...")
    println("   → All tasks successful!")
    println("   → Goal achieved!")
    agent = Agent_setState(agent, AgentState_Completed())
    return agent
  }

  if current_state == AgentState_Completed() {
    println("📍 State: Completed")
    println("   ✅ Agent finished successfully")
    return agent
  }

  if current_state == AgentState_Failed() {
    println("📍 State: Failed")
    println("   ❌ Agent failed")
    return agent
  }

  return agent
}


