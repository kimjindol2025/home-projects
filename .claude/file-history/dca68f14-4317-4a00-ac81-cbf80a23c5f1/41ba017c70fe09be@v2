// Phase 2 Step 2 Test: LoadGlobal/StoreGlobal Heap 기반 변환

import { compile } from "./compiler";
import { VM } from "./vm";
import { lex } from "./lexer";
import { parse } from "./parser";

function assert(condition: boolean, msg: string): void {
  if (condition) {
    console.log(`✓ ${msg}`);
  } else {
    console.error(`✗ FAILED: ${msg}`);
    process.exit(1);
  }
}

function assertEqual(actual: any, expected: any, msg: string): void {
  // 문자열 비교 시 양쪽 모두 trim
  const actualStr = typeof actual === "string" ? actual.trim() : actual;
  const expectedStr = typeof expected === "string" ? expected.trim() : expected;

  if (actualStr === expectedStr) {
    console.log(`✓ ${msg}`);
  } else {
    console.error(`✗ FAILED: ${msg} (expected ${expectedStr}, got ${actualStr})`);
    process.exit(1);
  }
}

/**
 * TEST 1: 단일 글로벌 변수 저장/로드
 */
function test_01_global_store_load(): void {
  console.log("\n🧪 TEST 1: 글로벌 변수 저장/로드");

  const code = `
    x = 100
    println(x)
  `;

  const tokens = lex(code);
  const ast = parse(tokens);
  const chunk = compile(ast);
  const vm = new VM(chunk);

  const { output } = vm.run();

  assertEqual(output[0], "100", "글로벌 변수 100 저장/로드");

  const heap = vm.getHeapManager();
  const stats = heap.getStats();
  console.log(`  [Heap Stats] allocated=${stats.totalAllocated}, objects=${stats.currentObjects}`);

  assert(stats.totalAllocated > 0, "Heap에 글로벌 변수 할당됨");

  console.log("✅ TEST 1 PASSED\n");
}

/**
 * TEST 2: 글로벌 변수 수정
 */
function test_02_global_reassign(): void {
  console.log("\n🧪 TEST 2: 글로벌 변수 수정");

  const code = `
    x = 50
    x = 75
    println(x)
  `;

  const tokens = lex(code);
  const ast = parse(tokens);
  const chunk = compile(ast);
  const vm = new VM(chunk);

  const { output } = vm.run();

  assertEqual(output[0], "75", "글로벌 변수 재할당: 75");

  const heap = vm.getHeapManager();
  const stats = heap.getStats();
  console.log(`  [Heap Stats] allocated=${stats.totalAllocated}`);

  // 50과 75를 모두 할당했으므로 최소 2개
  assert(stats.totalAllocated >= 2, "여러 값이 heap에 할당됨");

  console.log("✅ TEST 2 PASSED\n");
}

/**
 * TEST 3: 여러 글로벌 변수
 */
function test_03_multiple_globals(): void {
  console.log("\n🧪 TEST 3: 여러 글로벌 변수");

  const code = `
    a = 10
    b = 20
    c = 30
    println(a)
    println(b)
    println(c)
  `;

  const tokens = lex(code);
  const ast = parse(tokens);
  const chunk = compile(ast);
  const vm = new VM(chunk);

  const { output } = vm.run();

  assertEqual(output.length, 3, "3개 출력");
  assertEqual(output[0], "10", "a = 10");
  assertEqual(output[1], "20", "b = 20");
  assertEqual(output[2], "30", "c = 30");

  const heap = vm.getHeapManager();
  const stats = heap.getStats();
  console.log(`  [Heap Stats] allocated=${stats.totalAllocated}`);

  assert(stats.totalAllocated >= 3, "3개 이상 heap 할당");

  console.log("✅ TEST 3 PASSED\n");
}

/**
 * TEST 4: 글로벌 변수 산술 연산
 */
function test_04_global_arithmetic(): void {
  console.log("\n🧪 TEST 4: 글로벌 변수 산술 연산");

  const code = `
    x = 100
    y = 50
    z = x + y
    println(z)
  `;

  const tokens = lex(code);
  const ast = parse(tokens);
  const chunk = compile(ast);
  const vm = new VM(chunk);

  const { output } = vm.run();

  assertEqual(output[0], "150", "100 + 50 = 150");

  const heap = vm.getHeapManager();
  const stats = heap.getStats();
  console.log(`  [Heap Stats] allocated=${stats.totalAllocated}`);

  // x, y, z 할당
  assert(stats.totalAllocated >= 3, "산술 연산 결과도 heap에 할당");

  console.log("✅ TEST 4 PASSED\n");
}

/**
 * TEST 5: 유형별 글로벌 (숫자, 문자열, 불린)
 */
function test_05_global_types(): void {
  console.log("\n🧪 TEST 5: 유형별 글로벌 변수");

  const code = `
    num = 42
    str = "hello"
    bool = true
    println(num)
    println(str)
    println(bool)
  `;

  const tokens = lex(code);
  const ast = parse(tokens);
  const chunk = compile(ast);
  const vm = new VM(chunk);

  const { output } = vm.run();

  assertEqual(output.length, 3, "3개 출력");
  assertEqual(output[0], "42", "숫자 글로벌");
  assertEqual(output[1], "hello", "문자열 글로벌");
  assertEqual(output[2], "true", "불린 글로벌");

  const heap = vm.getHeapManager();
  const stats = heap.getStats();
  console.log(`  [Heap Stats] allocated=${stats.totalAllocated}`);

  assert(stats.totalAllocated >= 3, "다양한 타입이 heap에 할당");

  console.log("✅ TEST 5 PASSED\n");
}

/**
 * TEST 6: 글로벌 변수 배열
 */
function test_06_global_array(): void {
  console.log("\n🧪 TEST 6: 글로벌 배열 변수");

  const code = `
    arr = [1, 2, 3]
    println(arr)
  `;

  const tokens = lex(code);
  const ast = parse(tokens);
  const chunk = compile(ast);
  const vm = new VM(chunk);

  const { output } = vm.run();

  // 배열은 [1, 2, 3] 형태로 출력됨
  assert(output[0].includes("1"), "배열 요소 1 포함");
  assert(output[0].includes("2"), "배열 요소 2 포함");
  assert(output[0].includes("3"), "배열 요소 3 포함");

  const heap = vm.getHeapManager();
  const stats = heap.getStats();
  console.log(`  [Heap Stats] allocated=${stats.totalAllocated}`);

  assert(stats.totalAllocated >= 1, "배열도 heap에 할당");

  console.log("✅ TEST 6 PASSED\n");
}

