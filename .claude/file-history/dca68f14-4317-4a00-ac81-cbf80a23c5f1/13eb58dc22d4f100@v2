// Phase 5.3: TypeConstraints - 제약 조건 관리 및 충돌 감지

import {
  Type,
  Constraint,
  ConflictReport,
  typesCompatible,
  widenType,
  typeToString,
  BUILTIN_TYPES,
} from "./type-system"

/**
 * TypeConstraints: 제약 조건 기반 타입 검증
 */
export class TypeConstraints {
  private constraints: Constraint[] = []
  private conflicts: ConflictReport[] = []
  private resolved: Map<string, Type> = new Map()

  /**
   * 제약 조건 추가 (충돌 즉시 감지)
   */
  public addConstraint(constraint: Constraint): void {
    // 같은 변수의 기존 제약 검색
    const existing = this.constraints.find(
      (c) => c.variable === constraint.variable
    )

    if (existing) {
      // UNKNOWN 타입은 모든 타입과 호환됨
      const isExistingUnknown =
        existing.expectedType.kind === "primitive" &&
        (existing.expectedType as any).type === "unknown"
      const isNewUnknown =
        constraint.expectedType.kind === "primitive" &&
        (constraint.expectedType as any).type === "unknown"

      // 양쪽 모두 UNKNOWN이 아니고, 호환 불가능하면 충돌
      if (!isExistingUnknown && !isNewUnknown) {
        if (!typesCompatible(existing.expectedType, constraint.expectedType)) {
          this.conflicts.push({
            variable: constraint.variable,
            type1: existing.expectedType,
            type2: constraint.expectedType,
            message: `Type mismatch for '${constraint.variable}': expected ${typeToString(
              existing.expectedType
            )}, got ${typeToString(constraint.expectedType)}`,
          })
        }
      }
    }

    this.constraints.push(constraint)
  }

  /**
   * 감지된 모든 충돌 반환
   */
  public detectConflicts(): ConflictReport[] {
    return [...this.conflicts]
  }

  /**
   * 충돌 여부 확인
   */
  public hasConflicts(): boolean {
    return this.conflicts.length > 0
  }

  /**
   * 모든 제약 해결 (변수별 최종 타입 결정)
   */
  public resolveAll(): Map<string, Type> {
    this.resolved.clear()

    // 변수별 제약 그룹화
    const varConstraints = new Map<string, Constraint[]>()
    for (const constraint of this.constraints) {
      if (!varConstraints.has(constraint.variable)) {
        varConstraints.set(constraint.variable, [])
      }
      varConstraints.get(constraint.variable)!.push(constraint)
    }

    // 각 변수의 제약들 병합
    for (const [variable, constraints] of varConstraints.entries()) {
      if (constraints.length === 0) {
        this.resolved.set(variable, BUILTIN_TYPES.UNKNOWN)
        continue
      }

      if (constraints.length === 1) {
        this.resolved.set(variable, constraints[0].expectedType)
        continue
      }

      // 여러 제약: UNKNOWN 포함하면 제외하고 병합
      const nonUnknownTypes = constraints
        .map((c) => c.expectedType)
        .filter((t) => {
          // UNKNOWN 타입 제외
          if (t.kind === "primitive" && (t as any).type === "unknown") {
            return false
          }
          return true
        })

      if (nonUnknownTypes.length === 0) {
        // 모두 UNKNOWN이면
        this.resolved.set(variable, BUILTIN_TYPES.UNKNOWN)
      } else if (nonUnknownTypes.length === 1) {
        // 하나만 남으면
        this.resolved.set(variable, nonUnknownTypes[0])
      } else {
        // 여러 개면 widenType
        this.resolved.set(variable, widenType(...nonUnknownTypes))
      }
    }

    return new Map(this.resolved)
  }

  /**
   * 특정 변수의 해결된 타입 조회
   */
  public getResolved(variable: string): Type | undefined {
    return this.resolved.get(variable)
  }

  /**
   * 제약 개수
   */
  public getConstraintCount(): number {
    return this.constraints.length
  }

  /**
   * 제약 목록
   */
  public getConstraints(): Constraint[] {
    return [...this.constraints]
  }

  /**
   * 충돌 개수
   */
  public getConflictCount(): number {
    return this.conflicts.length
  }

  /**
   * 전체 리셋
   */
  public clear(): void {
    this.constraints = []
    this.conflicts = []
    this.resolved.clear()
  }
}
