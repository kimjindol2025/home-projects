/**
 * TEST 5: Comparison (비교) 연산
 */
function test_05_comparison(): void {
  console.log("\n🧪 TEST 5: 비교 연산 (Heap)");

  const code = `
    a = 10
    b = 20
    c = a < b
    d = b > a
    e = a == a
    println(c)
    println(d)
    println(e)
  `;

  const tokens = lex(code);
  const ast = parse(tokens);
  const chunk = compile(ast);
  const vm = new VM(chunk);

  const { output } = vm.run();
  assertEqual(output.length, 3, "3개 출력");
  assertEqual(output[0], "true", "10 < 20 = true");
  assertEqual(output[1], "true", "20 > 10 = true");
  assertEqual(output[2], "true", "10 == 10 = true");

  const heap = vm.getHeapManager();
  const stats = heap.getStats();
  console.log(`  [Heap Stats] allocated=${stats.totalAllocated}`);
  assert(stats.totalAllocated >= 5, "비교 결과들이 heap에 할당됨");

  console.log("✅ TEST 5 PASSED\n");
}

