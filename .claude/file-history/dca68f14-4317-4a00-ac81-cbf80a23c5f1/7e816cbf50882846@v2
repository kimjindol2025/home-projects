// ─────────────────────────────────────────────────────────────
// Constraint Engine: Pre-Check (실행 전 검사)
// ─────────────────────────────────────────────────────────────

fn ConstraintEngine_checkPre(step_counter, time_elapsed) {
  // Check MaxSteps constraint
  if step_counter >= GLOBAL_CONSTRAINT_MAX_STEPS {
    GLOBAL_CONSTRAINT_VIOLATION_TYPE = CONSTRAINT_MAX_STEPS
    GLOBAL_CONSTRAINT_VIOLATION_MSG = "MaxSteps exceeded"
    return CONSTRAINT_FAIL
  }

  // Check TimeLimit constraint
  if time_elapsed >= GLOBAL_CONSTRAINT_TIME_LIMIT {
    GLOBAL_CONSTRAINT_VIOLATION_TYPE = CONSTRAINT_TIME_LIMIT
    GLOBAL_CONSTRAINT_VIOLATION_MSG = "TimeLimit exceeded"
    return CONSTRAINT_FAIL
  }

  return CONSTRAINT_PASS
}

// ─────────────────────────────────────────────────────────────
// Constraint Engine: Post-Check (실행 후 검사)
// ─────────────────────────────────────────────────────────────

fn ConstraintEngine_checkPost(output) {
  // Check OutputFormat constraint
  if GLOBAL_CONSTRAINT_OUTPUT_FORMAT == "json" {
    // Simple JSON format check: must contain curly braces
    let has_open_brace = false
    let has_close_brace = false

    // Check if string contains "{"
    if output == "" {
      GLOBAL_CONSTRAINT_VIOLATION_TYPE = CONSTRAINT_OUTPUT_FORMAT
      GLOBAL_CONSTRAINT_VIOLATION_MSG = "Output format must be JSON (empty)"
      return CONSTRAINT_FAIL
    }

    // For simplicity: check if output looks like JSON
    // In real implementation, would use more sophisticated parsing
    if output != "" {
      // Check first character
      let first_char = output
      if first_char == "{" {
        has_open_brace = true
      }
    }

    if has_open_brace == false {
      GLOBAL_CONSTRAINT_VIOLATION_TYPE = CONSTRAINT_OUTPUT_FORMAT
      GLOBAL_CONSTRAINT_VIOLATION_MSG = "Output format must be JSON (missing {)"
      return CONSTRAINT_FAIL
    }
  }

  return CONSTRAINT_PASS
}

