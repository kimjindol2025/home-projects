// ─────────────────────────────────────────────────────────────
// Execution Loop with Constraint Enforcement
// ─────────────────────────────────────────────────────────────

fn Agent_run(agent, should_fail_task_index) {
  Agent_setState(STATE_EXECUTING)

  let current_index = Agent_currentIndex()
  let task_count = Agent_taskCount()

  // Main execution loop
  while current_index < task_count {
    // ═══════════════════════════════════════════════════════
    // CONSTRAINT CHECK (Pre-execution)
    // ═══════════════════════════════════════════════════════

    let step_counter = Agent_stepCounter()
    let time_elapsed = Agent_timeElapsed()

    let pre_check = ConstraintEngine_checkPre(step_counter, time_elapsed)

    if pre_check == CONSTRAINT_FAIL {
      // Constraint violation: immediate failure (no replan)
      GLOBAL_EXECUTION_ERROR = "Pre-execution constraint violated: " + ConstraintEngine_violationMessage()
      Agent_setState(STATE_FAILED)
      return false
    }

    // ═══════════════════════════════════════════════════════
    // TASK EXECUTION
    // ═══════════════════════════════════════════════════════

    Task_setStatus(current_index, TASK_STATUS_RUNNING)

    let should_fail = (current_index == should_fail_task_index)
    let observation = execute_task_tool(current_index, should_fail)

    // ═══════════════════════════════════════════════════════
    // CONSTRAINT CHECK (Post-execution)
    // ═══════════════════════════════════════════════════════

    let output = Observation_message(observation)
    let post_check = ConstraintEngine_checkPost(output)

    if post_check == CONSTRAINT_FAIL {
      // Constraint violation: immediate failure (no replan)
      GLOBAL_EXECUTION_ERROR = "Post-execution constraint violated: " + ConstraintEngine_violationMessage()
      Task_setStatus(current_index, TASK_STATUS_ERROR)
      Agent_setState(STATE_FAILED)
      return false
    }

    // ═══════════════════════════════════════════════════════
    // TASK SUCCESS: Mark and Advance
    // ═══════════════════════════════════════════════════════

    if Observation_isSuccess(observation) {
      Task_setStatus(current_index, TASK_STATUS_DONE)
      Task_setOutput(current_index, output)

      current_index = current_index + 1
      Agent_setCurrentIndex(current_index)
    } else {
      // Observation failure (not constraint violation)
      Task_setStatus(current_index, TASK_STATUS_ERROR)
      GLOBAL_EXECUTION_ERROR = Observation_message(observation)
      Agent_setState(STATE_FAILED)
      return false
    }

    // ═══════════════════════════════════════════════════════
    // INCREMENT COUNTERS
    // ═══════════════════════════════════════════════════════

    Agent_incrementStep()
    Agent_incrementTime(1)  // Simulate time passage (1 unit per task)
  }

  // All tasks completed
  Agent_setState(STATE_COMPLETED)
  return true
}

