// ─────────────────────────────────────────────────────────────
// Agent State Constants
// ─────────────────────────────────────────────────────────────

let STATE_IDLE = 0
let STATE_PLANNING = 1
let STATE_EXECUTING = 2
let STATE_REFLECTING = 3
let STATE_COMPLETED = 4
let STATE_FAILED = 5

fn state_name(state) {
  if state == STATE_IDLE { return "Idle" }
  if state == STATE_PLANNING { return "Planning" }
  if state == STATE_EXECUTING { return "Executing" }
  if state == STATE_REFLECTING { return "Reflecting" }
  if state == STATE_COMPLETED { return "Completed" }
  if state == STATE_FAILED { return "Failed" }
  return "Unknown"
}

// ─────────────────────────────────────────────────────────────
// Task Status Constants
// ─────────────────────────────────────────────────────────────

let TASK_STATUS_PENDING = 0
let TASK_STATUS_RUNNING = 1
let TASK_STATUS_DONE = 2
let TASK_STATUS_ERROR = 3

fn task_status_name(status) {
  if status == TASK_STATUS_PENDING { return "Pending" }
  if status == TASK_STATUS_RUNNING { return "Running" }
  if status == TASK_STATUS_DONE { return "Done" }
  if status == TASK_STATUS_ERROR { return "Error" }
  return "Unknown"
}

// ─────────────────────────────────────────────────────────────
// Tool Type & Execution
// ─────────────────────────────────────────────────────────────

let TOOL_TYPE_ANALYZE = 1
let TOOL_TYPE_PROCESS = 2
let TOOL_TYPE_VALIDATE = 3

let OBSERVATION_SUCCESS = 0
let OBSERVATION_FAILURE = 1

fn Observation_new(is_success, message) {
  return [is_success, message]
}

fn Observation_isSuccess(obs) {
  return obs[0] == OBSERVATION_SUCCESS
}

fn Observation_message(obs) {
  return obs[1]
}

// ─────────────────────────────────────────────────────────────
// Agent Global State
// ─────────────────────────────────────────────────────────────

let GLOBAL_AGENT_STATE = STATE_IDLE
let GLOBAL_AGENT_GOAL = ""
let GLOBAL_AGENT_TASK_COUNT = 0
let GLOBAL_AGENT_CURRENT_INDEX = 0
let GLOBAL_AGENT_MAX_STEPS = 10

// Task States
let GLOBAL_TASK_1_STATUS = TASK_STATUS_PENDING
let GLOBAL_TASK_2_STATUS = TASK_STATUS_PENDING
let GLOBAL_TASK_3_STATUS = TASK_STATUS_PENDING

let GLOBAL_TASK_1_OUTPUT = ""
let GLOBAL_TASK_2_OUTPUT = ""
let GLOBAL_TASK_3_OUTPUT = ""

let GLOBAL_EXECUTION_ERROR = ""

// ─────────────────────────────────────────────────────────────
// Agent Initialization
// ─────────────────────────────────────────────────────────────

fn Agent_new(goal_description, task_count, max_steps) {
  GLOBAL_AGENT_STATE = STATE_IDLE
  GLOBAL_AGENT_GOAL = goal_description
  GLOBAL_AGENT_TASK_COUNT = task_count
  GLOBAL_AGENT_CURRENT_INDEX = 0
  GLOBAL_AGENT_MAX_STEPS = max_steps

  GLOBAL_TASK_1_STATUS = TASK_STATUS_PENDING
  GLOBAL_TASK_2_STATUS = TASK_STATUS_PENDING
  GLOBAL_TASK_3_STATUS = TASK_STATUS_PENDING

  GLOBAL_EXECUTION_ERROR = ""

  return 1
}

fn Agent_state() {
  return GLOBAL_AGENT_STATE
}

fn Agent_setState(state) {
  GLOBAL_AGENT_STATE = state
  return state
}

fn Agent_currentIndex() {
  return GLOBAL_AGENT_CURRENT_INDEX
}

fn Agent_advanceIndex() {
  GLOBAL_AGENT_CURRENT_INDEX = GLOBAL_AGENT_CURRENT_INDEX + 1
  return GLOBAL_AGENT_CURRENT_INDEX
}

fn Agent_taskCount() {
  return GLOBAL_AGENT_TASK_COUNT
}

fn Agent_maxSteps() {
  return GLOBAL_AGENT_MAX_STEPS
}

// ─────────────────────────────────────────────────────────────
// Task Status Management
// ─────────────────────────────────────────────────────────────

fn Task_getStatus(task_index) {
  if task_index == 0 { return GLOBAL_TASK_1_STATUS }
  if task_index == 1 { return GLOBAL_TASK_2_STATUS }
  if task_index == 2 { return GLOBAL_TASK_3_STATUS }
  return TASK_STATUS_PENDING
}

fn Task_setStatus(task_index, status) {
  if task_index == 0 { GLOBAL_TASK_1_STATUS = status }
  if task_index == 1 { GLOBAL_TASK_2_STATUS = status }
  if task_index == 2 { GLOBAL_TASK_3_STATUS = status }
  return status
}

fn Task_getOutput(task_index) {
  if task_index == 0 { return GLOBAL_TASK_1_OUTPUT }
  if task_index == 1 { return GLOBAL_TASK_2_OUTPUT }
  if task_index == 2 { return GLOBAL_TASK_3_OUTPUT }
  return ""
}

fn Task_setOutput(task_index, output) {
  if task_index == 0 { GLOBAL_TASK_1_OUTPUT = output }
  if task_index == 1 { GLOBAL_TASK_2_OUTPUT = output }
  if task_index == 2 { GLOBAL_TASK_3_OUTPUT = output }
  return output
}

// ─────────────────────────────────────────────────────────────
// Mock Tool Execution
// ─────────────────────────────────────────────────────────────

fn execute_task_tool(task_index, should_fail) {
  if should_fail {
    return Observation_new(OBSERVATION_FAILURE, "Task execution failed")
  }

  return Observation_new(OBSERVATION_SUCCESS, "Task " + task_index + " completed")
}

// ─────────────────────────────────────────────────────────────
// Execution Loop v1
// ─────────────────────────────────────────────────────────────

fn Agent_run(agent, should_fail_task_index) {
  // State: Planning → Executing
  Agent_setState(STATE_EXECUTING)

  let current_index = Agent_currentIndex()
  let task_count = Agent_taskCount()
  let max_steps = Agent_maxSteps()
  let step_counter = 0

  // Execution loop
  while current_index < task_count {
    // Guard: MaxSteps 초과 확인
    if step_counter >= max_steps {
      GLOBAL_EXECUTION_ERROR = "MaxSteps exceeded"
      Agent_setState(STATE_FAILED)
      return false
    }

    // 현재 Task 상태: Running
    Task_setStatus(current_index, TASK_STATUS_RUNNING)

    // Task 실행 (Mock Tool)
    let should_fail = (current_index == should_fail_task_index)
    let observation = execute_task_tool(current_index, should_fail)

    // 결과 처리
    if Observation_isSuccess(observation) {
      // 성공: Done
      Task_setStatus(current_index, TASK_STATUS_DONE)
      Task_setOutput(current_index, Observation_message(observation))
    } else {
      // 실패: Error → 즉시 중단
      Task_setStatus(current_index, TASK_STATUS_ERROR)
      GLOBAL_EXECUTION_ERROR = Observation_message(observation)
      Agent_setState(STATE_REFLECTING)
      Agent_setState(STATE_FAILED)
      return false
    }

    // Index 증가
    GLOBAL_AGENT_CURRENT_INDEX = current_index + 1
    current_index = Agent_currentIndex()
    step_counter = step_counter + 1
  }

  // 모든 Task 완료: Reflecting → Completed
  Agent_setState(STATE_REFLECTING)
  Agent_setState(STATE_COMPLETED)

  return true
}

// ─────────────────────────────────────────────────────────────
// Test Utilities
// ─────────────────────────────────────────────────────────────

fn assert_true(actual, msg) {
  if actual {
    println("✓ " + msg)
    return true
  }
  println("✗ FAILED: " + msg)
  return false
}

fn assert_equal(actual, expected, msg) {
  if actual == expected {
    println("✓ " + msg)
    return true
  }
  println("✗ FAILED: " + msg)
  println("  Expected: " + expected)
  println("  Actual: " + actual)
  return false
}

// ─────────────────────────────────────────────────────────────
// TEST 1: Three Tasks Normal Execution → Completed
// ─────────────────────────────────────────────────────────────

fn test_01_three_tasks_success() {
  println("")
  println("🧪 TEST 1: Three Tasks Normal Execution → Completed")

  let agent = Agent_new("Execute three tasks", 3, 10)

  assert_equal(Agent_state(), STATE_IDLE, "Initial state: Idle")

  let success = Agent_run(agent, -1)

  assert_true(success, "Execution completed successfully")
  assert_equal(Agent_state(), STATE_COMPLETED, "Final state: Completed")
  assert_equal(Task_getStatus(0), TASK_STATUS_DONE, "Task 0 done")
  assert_equal(Task_getStatus(1), TASK_STATUS_DONE, "Task 1 done")
  assert_equal(Task_getStatus(2), TASK_STATUS_DONE, "Task 2 done")

  println("✅ TEST 1 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 2: Task Failure Mid-Execution → Failed
// ─────────────────────────────────────────────────────────────

fn test_02_task_failure_stops() {
  println("")
  println("🧪 TEST 2: Task Failure Mid-Execution → Failed")

  let agent = Agent_new("Execute with failure", 3, 10)

  let success = Agent_run(agent, 1)

  assert_true(success == false, "Execution stopped on failure")
  assert_equal(Agent_state(), STATE_FAILED, "Final state: Failed")
  assert_equal(Task_getStatus(0), TASK_STATUS_DONE, "Task 0 completed before failure")
  assert_equal(Task_getStatus(1), TASK_STATUS_ERROR, "Task 1 failed")
  assert_equal(Task_getStatus(2), TASK_STATUS_PENDING, "Task 2 not reached")

  println("✅ TEST 2 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 3: current_index Increment Verification
// ─────────────────────────────────────────────────────────────

fn test_03_index_increment() {
  println("")
  println("🧪 TEST 3: current_index Increment Verification")

  let agent = Agent_new("Test index", 3, 10)

  assert_equal(Agent_currentIndex(), 0, "Initial index: 0")

  Agent_run(agent, -1)

  assert_equal(Agent_currentIndex(), 3, "Final index: 3 (all tasks executed)")

  println("✅ TEST 3 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 4: MaxSteps Guard Exceeded
// ─────────────────────────────────────────────────────────────

fn test_04_maxsteps_exceeded() {
  println("")
  println("🧪 TEST 4: MaxSteps Guard Exceeded")

  let agent = Agent_new("Test max steps", 3, 1)

  let success = Agent_run(agent, -1)

  assert_true(success == false, "Execution stopped at MaxSteps")
  assert_equal(Agent_state(), STATE_FAILED, "Final state: Failed")
  assert_equal(GLOBAL_EXECUTION_ERROR, "MaxSteps exceeded", "Error message set")

  println("✅ TEST 4 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 5: State Transitions
// ─────────────────────────────────────────────────────────────

fn test_05_state_transitions() {
  println("")
  println("🧪 TEST 5: State Transitions (Idle → Executing → Completed)")

  let agent = Agent_new("Test transitions", 3, 10)

  assert_equal(Agent_state(), STATE_IDLE, "Start: Idle")

  Agent_run(agent, -1)

  assert_equal(Agent_state(), STATE_COMPLETED, "End: Completed")
  assert_equal(state_name(STATE_EXECUTING), "Executing", "State enum working")

  println("✅ TEST 5 PASSED")
}

