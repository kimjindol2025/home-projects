// ─────────────────────────────────────────────────────────────
// Task Status Constants
// ─────────────────────────────────────────────────────────────

let TASK_STATUS_PENDING = 0
let TASK_STATUS_RUNNING = 1
let TASK_STATUS_DONE = 2
let TASK_STATUS_ERROR = 3

fn task_status_name(status) {
  if status == TASK_STATUS_PENDING { return "Pending" }
  if status == TASK_STATUS_RUNNING { return "Running" }
  if status == TASK_STATUS_DONE { return "Done" }
  if status == TASK_STATUS_ERROR { return "Error" }
  return "Unknown"
}

// ─────────────────────────────────────────────────────────────
// Task ID Generator (전역)
// ─────────────────────────────────────────────────────────────

let GLOBAL_TASK_ID_COUNTER = 0

fn TaskID_generate() {
  GLOBAL_TASK_ID_COUNTER = GLOBAL_TASK_ID_COUNTER + 1
  return "task-" + GLOBAL_TASK_ID_COUNTER
}

fn TaskID_reset() {
  GLOBAL_TASK_ID_COUNTER = 0
}

// ─────────────────────────────────────────────────────────────
// Task Type Constants
// ─────────────────────────────────────────────────────────────

let TASK_TYPE_ANALYZE = 1
let TASK_TYPE_DECOMPOSE = 2
let TASK_TYPE_EXECUTE = 3

fn task_type_name(ttype) {
  if ttype == TASK_TYPE_ANALYZE { return "AnalyzeGoal" }
  if ttype == TASK_TYPE_DECOMPOSE { return "Decompose" }
  if ttype == TASK_TYPE_EXECUTE { return "Execute" }
  return "Unknown"
}

// ─────────────────────────────────────────────────────────────
// Task Creation (상태 저장, 값 반환만)
// ─────────────────────────────────────────────────────────────

let GLOBAL_TASK_ID_1 = ""
let GLOBAL_TASK_ID_2 = ""
let GLOBAL_TASK_ID_3 = ""
let GLOBAL_TASK_COUNT = 0

fn Task_create(task_type, goal_description) {
  let task_id = TaskID_generate()
  let task_name = task_type_name(task_type)

  if task_type == TASK_TYPE_ANALYZE {
    GLOBAL_TASK_ID_1 = task_id
  }
  if task_type == TASK_TYPE_DECOMPOSE {
    GLOBAL_TASK_ID_2 = task_id
  }
  if task_type == TASK_TYPE_EXECUTE {
    GLOBAL_TASK_ID_3 = task_id
  }

  return task_id
}

fn Task_id(task_id) {
  return task_id
}

fn Task_name(task_id) {
  if task_id == GLOBAL_TASK_ID_1 { return "AnalyzeGoal" }
  if task_id == GLOBAL_TASK_ID_2 { return "Decompose" }
  if task_id == GLOBAL_TASK_ID_3 { return "Execute" }
  return "Task"
}

fn Task_status(task_id) {
  return TASK_STATUS_PENDING
}

// ─────────────────────────────────────────────────────────────
// Plan Structure (함수 기반)
// ─────────────────────────────────────────────────────────────

let GLOBAL_PLAN_TASK_COUNT = 0
let GLOBAL_PLAN_CURRENT_INDEX = 0

fn Plan_create() {
  GLOBAL_PLAN_TASK_COUNT = 0
  GLOBAL_PLAN_CURRENT_INDEX = 0
  return 1  // plan_id (valid)
}

fn Plan_addTask(plan_id, task) {
  if plan_id > 0 {
    GLOBAL_PLAN_TASK_COUNT = GLOBAL_PLAN_TASK_COUNT + 1
  }
  return plan_id
}

fn Plan_taskCount(plan_id) {
  if plan_id > 0 {
    return GLOBAL_PLAN_TASK_COUNT
  }
  return 0
}

fn Plan_currentIndex(plan_id) {
  return GLOBAL_PLAN_CURRENT_INDEX
}

// ─────────────────────────────────────────────────────────────
// Plan Skeleton Builder
// ─────────────────────────────────────────────────────────────

fn PlanBuilder_buildSkeleton(goal_description, goal_criteria) {
  // Validation
  if goal_description == "" {
    return -1
  }

  // Reset counters
  TaskID_reset()
  GLOBAL_TASK_COUNT = 0

  // Create plan
  let plan_id = Plan_create()

  // Generate skeleton tasks (3 standard steps)
  // Step 1: AnalyzeGoal
  Task_create(TASK_TYPE_ANALYZE, goal_description)
  GLOBAL_TASK_COUNT = GLOBAL_TASK_COUNT + 1

  // Step 2: Decompose
  Task_create(TASK_TYPE_DECOMPOSE, goal_description)
  GLOBAL_TASK_COUNT = GLOBAL_TASK_COUNT + 1

  // Step 3: Execute
  Task_create(TASK_TYPE_EXECUTE, goal_description)
  GLOBAL_TASK_COUNT = GLOBAL_TASK_COUNT + 1

  return plan_id
}

fn PlanBuilder_isValid(plan_id) {
  if plan_id < 1 { return false }
  let count = GLOBAL_TASK_COUNT
  if count < 1 { return false }
  return true
}

fn PlanBuilder_getTaskCount(plan_id) {
  return GLOBAL_TASK_COUNT
}

fn PlanBuilder_getCurrentIndex(plan_id) {
  return Plan_currentIndex(plan_id)
}

