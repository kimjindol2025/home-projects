function test_01_unsafe_basic_allocation(): void {
  console.log("\n🧪 UNSAFE TEST 1: 기본 메모리 할당/해제");

  const vm = new VM({ code: [0], constants: [], lines: [] });
  const unsafe = vm.getUnsafeManager();

  // 메모리 영역 생성
  const zoneId = unsafe.createZone(100);
  assert(zoneId >= 0, "메모리 할당 성공");

  // 메모리 쓰기/읽기
  const writeResult = unsafe.writeByte(zoneId, 0, 42);
  assert(writeResult, "메모리 쓰기 성공");

  const readValue = unsafe.readByte(zoneId, 0);
  assertEqual(readValue, 42, "메모리 읽기 = 42");

  // 메모리 해제
  const freeResult = unsafe.free(zoneId);
  assert(freeResult, "메모리 해제 성공");

  const stats = unsafe.getStats();
  console.log(
    `  [Stats] zones=${stats.totalZones}, memory=${stats.totalMemory}, violations=${stats.overflowViolations}`
  );

  console.log("✅ UNSAFE TEST 1 PASSED\n");
}

function test_02_buffer_overflow_detection(): void {
  console.log("🧪 UNSAFE TEST 2: 버퍼 오버플로우 감지");

  const vm = new VM({ code: [0], constants: [], lines: [] });
  const unsafe = vm.getUnsafeManager();

  const zoneId = unsafe.createZone(10);
  assert(zoneId >= 0, "메모리 할당");

  // 정상 접근
  const normalAccess = unsafe.validateAccess(zoneId, 5, 1);
  assert(normalAccess.valid, "범위 내 접근 = 정상");

  // 오버플로우 접근
  const overflowAccess = unsafe.validateAccess(zoneId, 15, 1);
  assert(!overflowAccess.valid, "범위 밖 접근 = 감지됨");

  const stats = unsafe.getStats();
  console.log(`  [Stats] violations=${stats.overflowViolations}`);
  assert(stats.overflowViolations > 0, "위반 기록됨");

  unsafe.free(zoneId);
  console.log("✅ UNSAFE TEST 2 PASSED\n");
}

function test_03_memory_expansion(): void {
  console.log("🧪 UNSAFE TEST 3: 메모리 확장 (realloc)");

  const vm = new VM({ code: [0], constants: [], lines: [] });
  const unsafe = vm.getUnsafeManager();

  const zoneId1 = unsafe.createZone(10);
  unsafe.writeByte(zoneId1, 0, 100);
  unsafe.writeByte(zoneId1, 9, 200);

  // 메모리 확장
  const result = unsafe.realloc(zoneId1, 20);
  assert(result.success, "메모리 확장 성공");
  assert(result.newZoneId !== undefined, "새 zoneId 반환");

  const newZoneId = result.newZoneId!;

  // 기존 데이터 확인
  const val1 = unsafe.readByte(newZoneId, 0);
  assertEqual(val1, 100, "확장 후 기존 데이터 [0] = 100");

  const val2 = unsafe.readByte(newZoneId, 9);
  assertEqual(val2, 200, "확장 후 기존 데이터 [9] = 200");

  // 새 영역 접근 가능
  unsafe.writeByte(newZoneId, 19, 300);
  const val3 = unsafe.readByte(newZoneId, 19);
  assertEqual(val3, 300, "확장 후 새 영역 [19] = 300");

  unsafe.free(newZoneId);
  console.log("✅ UNSAFE TEST 3 PASSED\n");
}

function test_04_multiple_zones(): void {
  console.log("🧪 UNSAFE TEST 4: 다중 메모리 영역 관리");

  const vm = new VM({ code: [0], constants: [], lines: [] });
  const unsafe = vm.getUnsafeManager();

  const zone1 = unsafe.createZone(10);
  const zone2 = unsafe.createZone(20);
  const zone3 = unsafe.createZone(5);

  assert(zone1 !== zone2 && zone2 !== zone3, "다른 zoneId 할당됨");

  // 각 영역에 값 쓰기
  unsafe.writeByte(zone1, 5, 11);
  unsafe.writeByte(zone2, 15, 22);
  unsafe.writeByte(zone3, 2, 33);

  // 각 영역에서 값 읽기
  assertEqual(unsafe.readByte(zone1, 5), 11, "zone1[5] = 11");
  assertEqual(unsafe.readByte(zone2, 15), 22, "zone2[15] = 22");
  assertEqual(unsafe.readByte(zone3, 2), 33, "zone3[2] = 33");

  // 각 영역 해제
  unsafe.free(zone1);
  unsafe.free(zone2);
  unsafe.free(zone3);

  const stats = unsafe.getStats();
  console.log(`  [Stats] zones=${stats.totalZones}, memory=${stats.totalMemory}`);

  console.log("✅ UNSAFE TEST 4 PASSED\n");
}

function test_05_overflow_tracking(): void {
  console.log("🧪 UNSAFE TEST 5: 오버플로우 추적");

  const vm = new VM({ code: [0], constants: [], lines: [] });
  const unsafe = vm.getUnsafeManager();

  const zoneId = unsafe.createZone(5);

  // 정상 접근들
  unsafe.validateAccess(zoneId, 0, 1);
  unsafe.validateAccess(zoneId, 1, 1);
  unsafe.validateAccess(zoneId, 4, 1);

  // 오버플로우 시도들
  unsafe.validateAccess(zoneId, 5, 1);  // 위반 1
  unsafe.validateAccess(zoneId, 10, 1); // 위반 2
  unsafe.validateAccess(zoneId, -1, 1); // 위반 3

  const stats = unsafe.getStats();
  console.log(`  [Stats] violations=${stats.overflowViolations}`);
  assert(stats.overflowViolations === 3, "오버플로우 3회 기록됨");

  unsafe.free(zoneId);
  console.log("✅ UNSAFE TEST 5 PASSED\n");
}

function test_06_zone_info(): void {
  console.log("🧪 UNSAFE TEST 6: 메모리 영역 정보 조회");

  const vm = new VM({ code: [0], constants: [], lines: [] });
  const unsafe = vm.getUnsafeManager();

  const zoneId = unsafe.createZone(100);

  const zone = unsafe.getZoneInfo(zoneId);
  assert(zone !== null, "영역 정보 조회 성공");
  assert(zone!.maxSize === 100, "최대 크기 = 100");
  assert(zone!.currentSize === 0, "초기 사용량 = 0");

  unsafe.writeByte(zoneId, 50, 99);
  const zone2 = unsafe.getZoneInfo(zoneId);
  assert(zone2!.currentSize > 0, "쓰기 후 사용량 증가");

  unsafe.free(zoneId);
  console.log("✅ UNSAFE TEST 6 PASSED\n");
}

function test_07_active_zones(): void {
  console.log("🧪 UNSAFE TEST 7: 활성 영역 목록");

  const vm = new VM({ code: [0], constants: [], lines: [] });
  const unsafe = vm.getUnsafeManager();

  const zone1 = unsafe.createZone(10);
  const zone2 = unsafe.createZone(20);

  const active = unsafe.getActiveZones();
  console.log(`  [Active zones] count=${active.length}`);
  assert(active.length === 2, "활성 영역 2개");

  unsafe.free(zone1);
  const active2 = unsafe.getActiveZones();
  assert(active2.length === 1, "zone1 해제 후 1개");

  unsafe.free(zone2);
  console.log("✅ UNSAFE TEST 7 PASSED\n");
}

function test_08_memory_leaks(): void {
  console.log("🧪 UNSAFE TEST 8: 메모리 누수 감지");

  const vm = new VM({ code: [0], constants: [], lines: [] });
  const unsafe = vm.getUnsafeManager();

  const zone1 = unsafe.createZone(10);
  unsafe.writeByte(zone1, 0, 42);

  const zone2 = unsafe.createZone(20);
  unsafe.writeByte(zone2, 5, 100);

  // zone1은 해제, zone2는 해제 안 함 (누수)
  unsafe.free(zone1);

  const leaks = unsafe.checkLeaks();
  console.log(`  [Leaks] leakedZones=${leaks.leakedZones}, totalLeaked=${leaks.totalLeaked}`);
  assert(leaks.leakedZones === 1, "누수된 영역 1개");

  unsafe.free(zone2);
  console.log("✅ UNSAFE TEST 8 PASSED\n");
}

function test_09_boundary_validation(): void {
  console.log("🧪 UNSAFE TEST 9: 경계 검증 정확성");

  const vm = new VM({ code: [0], constants: [], lines: [] });
  const unsafe = vm.getUnsafeManager();

  const zoneId = unsafe.createZone(100);

  // 경계 정확히 테스트
  const edgeCases = [
    { offset: 0, size: 1, shouldPass: true },       // 시작
    { offset: 99, size: 1, shouldPass: true },      // 끝
    { offset: 100, size: 1, shouldPass: false },    // 끝+1
    { offset: 50, size: 50, shouldPass: true },     // 중간 범위
    { offset: 50, size: 51, shouldPass: false },    // 범위 초과
    { offset: -1, size: 1, shouldPass: false },     // 음수
  ];

  let passed = 0;
  for (const test of edgeCases) {
    const result = unsafe.validateAccess(zoneId, test.offset, test.size);
    if (result.valid === test.shouldPass) {
      passed++;
    } else {
      console.error(
        `  ✗ offset=${test.offset}, size=${test.size}: expected=${test.shouldPass}, got=${result.valid}`
      );
    }
  }

  assert(passed === edgeCases.length, `경계 검증 ${passed}/${edgeCases.length}`);

  unsafe.free(zoneId);
  console.log("✅ UNSAFE TEST 9 PASSED\n");
}

