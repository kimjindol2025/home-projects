// 🪞 v1.7 — Reflection Hook v1: Post-Execution Evaluation
// ════════════════════════════════════════════════════════════════
// Reflection: 실행 후 결과를 평가하고 전략을 조정하는 단계

// ─────────────────────────────────────────────────────────────
// State Constants
// ─────────────────────────────────────────────────────────────

let STATE_IDLE = 0
let STATE_PLANNING = 1
let STATE_EXECUTING = 2
let STATE_REFLECTING = 3
let STATE_COMPLETED = 4
let STATE_FAILED = 5

fn state_name(state) {
  if state == STATE_IDLE { return "Idle" }
  if state == STATE_PLANNING { return "Planning" }
  if state == STATE_EXECUTING { return "Executing" }
  if state == STATE_REFLECTING { return "Reflecting" }
  if state == STATE_COMPLETED { return "Completed" }
  if state == STATE_FAILED { return "Failed" }
  return "Unknown"
}

// ─────────────────────────────────────────────────────────────
// Task Status Constants
// ─────────────────────────────────────────────────────────────

let TASK_STATUS_PENDING = 0
let TASK_STATUS_RUNNING = 1
let TASK_STATUS_DONE = 2
let TASK_STATUS_ERROR = 3

fn task_status_name(status) {
  if status == TASK_STATUS_PENDING { return "Pending" }
  if status == TASK_STATUS_RUNNING { return "Running" }
  if status == TASK_STATUS_DONE { return "Done" }
  if status == TASK_STATUS_ERROR { return "Error" }
  return "Unknown"
}

// ─────────────────────────────────────────────────────────────
// Reflection Result Constants
// ─────────────────────────────────────────────────────────────

let REFLECTION_SUCCESS = 1
let REFLECTION_RETRY_POSSIBLE = 2
let REFLECTION_UNRECOVERABLE = 3

fn reflection_result_name(result) {
  if result == REFLECTION_SUCCESS { return "Success" }
  if result == REFLECTION_RETRY_POSSIBLE { return "RetryPossible" }
  if result == REFLECTION_UNRECOVERABLE { return "Unrecoverable" }
  return "Unknown"
}

// ─────────────────────────────────────────────────────────────
// Reflection Analysis Structure
// [success_count, failure_count, last_error, retry_strategy]
// ─────────────────────────────────────────────────────────────

fn ReflectionAnalysis_new() {
  return [0, 0, "", ""]
}

fn ReflectionAnalysis_successCount(analysis) {
  return analysis[0]
}

fn ReflectionAnalysis_failureCount(analysis) {
  return analysis[1]
}

fn ReflectionAnalysis_lastError(analysis) {
  return analysis[2]
}

fn ReflectionAnalysis_retryStrategy(analysis) {
  return analysis[3]
}

// ─────────────────────────────────────────────────────────────
// Reflection State (전역)
// ─────────────────────────────────────────────────────────────

let GLOBAL_REFLECTION_ACTIVE = false
let GLOBAL_REFLECTION_ANALYSIS = ""
let GLOBAL_REFLECTION_RESULT = 0
let GLOBAL_REFLECTION_RECOMMENDATION = ""
let GLOBAL_REFLECTION_RETRY_COUNT = 0

fn ReflectionHook_isActive() {
  return GLOBAL_REFLECTION_ACTIVE
}

fn ReflectionHook_analysis() {
  return GLOBAL_REFLECTION_ANALYSIS
}

fn ReflectionHook_result() {
  return GLOBAL_REFLECTION_RESULT
}

fn ReflectionHook_recommendation() {
  return GLOBAL_REFLECTION_RECOMMENDATION
}

fn ReflectionHook_retryCount() {
  return GLOBAL_REFLECTION_RETRY_COUNT
}

// ─────────────────────────────────────────────────────────────
// Analysis Engine: Evaluate Execution Results
// ─────────────────────────────────────────────────────────────

fn Reflection_analyzeExecution(task_count, completed_count, error_message) {
  let analysis = ReflectionAnalysis_new()

  // Create new analysis with results
  let success_count = completed_count
  let failure_count = task_count - completed_count
  let last_error = error_message

  let result = [success_count, failure_count, last_error, ""]

  return result
}

// ─────────────────────────────────────────────────────────────
// Strategy Adjustment: Determine Next Course of Action
// ─────────────────────────────────────────────────────────────

fn Reflection_evaluateStrategy(analysis, max_retries, current_retry_count) {
  let success_count = ReflectionAnalysis_successCount(analysis)
  let failure_count = ReflectionAnalysis_failureCount(analysis)
  let last_error = ReflectionAnalysis_lastError(analysis)

  // Determine reflection result
  if failure_count == 0 {
    // All tasks succeeded
    return REFLECTION_SUCCESS
  }

  // Check if retry is possible
  if current_retry_count < max_retries {
    return REFLECTION_RETRY_POSSIBLE
  }

  // Retry limit exceeded
  return REFLECTION_UNRECOVERABLE
}

// ─────────────────────────────────────────────────────────────
// Strategy Recommendation Engine
// ─────────────────────────────────────────────────────────────

fn Reflection_generateStrategy(reflection_result, error_message, task_count) {
  if reflection_result == REFLECTION_SUCCESS {
    return "All tasks completed successfully. Proceeding to completion."
  }

  if reflection_result == REFLECTION_RETRY_POSSIBLE {
    return "Task failure detected (" + error_message + "). Recommend retry with adjusted parameters."
  }

  if reflection_result == REFLECTION_UNRECOVERABLE {
    return "Retry limit exceeded. Unable to recover from repeated failures."
  }

  return "Unknown reflection result."
}

// ─────────────────────────────────────────────────────────────
// Memory Review: Analyze Past Observations
// ─────────────────────────────────────────────────────────────

fn Reflection_reviewMemory(memory_length) {
  if memory_length == 0 {
    return "No observations recorded yet."
  }

  if memory_length > 0 {
    return "Reviewed " + memory_length + " observations from execution history."
  }

  return "Memory review incomplete."
}

// ─────────────────────────────────────────────────────────────
// Reflection Hook Main Engine
// ─────────────────────────────────────────────────────────────

fn ReflectionHook_execute(agent_state, task_count, completed_count, error_message, memory_length, max_retries) {
  // Verify agent is in Reflecting state
  if agent_state != STATE_REFLECTING {
    return false
  }

  // Activate reflection
  GLOBAL_REFLECTION_ACTIVE = true

  // Step 1: Analyze execution results
  let analysis = Reflection_analyzeExecution(task_count, completed_count, error_message)
  GLOBAL_REFLECTION_ANALYSIS = analysis

  // Step 2: Evaluate strategy (current retry is 0 on first pass)
  let current_retry = GLOBAL_REFLECTION_RETRY_COUNT
  let reflection_result = Reflection_evaluateStrategy(analysis, max_retries, current_retry)
  GLOBAL_REFLECTION_RESULT = reflection_result

  // Step 3: Generate strategy recommendation
  let recommendation = Reflection_generateStrategy(reflection_result, error_message, task_count)
  GLOBAL_REFLECTION_RECOMMENDATION = recommendation

  // Step 4: Review memory
  let memory_review = Reflection_reviewMemory(memory_length)

  // Step 5: Increment retry counter if retry is recommended
  if reflection_result == REFLECTION_RETRY_POSSIBLE {
    GLOBAL_REFLECTION_RETRY_COUNT = current_retry + 1
  }

  return true
}

// ─────────────────────────────────────────────────────────────
// State Transition: Post-Reflection
// ─────────────────────────────────────────────────────────────

fn ReflectionHook_determineNextState(reflection_result) {
  if reflection_result == REFLECTION_SUCCESS {
    return STATE_COMPLETED
  }

  if reflection_result == REFLECTION_RETRY_POSSIBLE {
    // Return to executing (retry)
    return STATE_EXECUTING
  }

  if reflection_result == REFLECTION_UNRECOVERABLE {
    return STATE_FAILED
  }

  return STATE_IDLE
}

// ─────────────────────────────────────────────────────────────
// Reflection Display Helper
// ─────────────────────────────────────────────────────────────

fn ReflectionHook_display() {
  let active = GLOBAL_REFLECTION_ACTIVE
  let result = GLOBAL_REFLECTION_RESULT
  let recommendation = GLOBAL_REFLECTION_RECOMMENDATION
  let retry_count = GLOBAL_REFLECTION_RETRY_COUNT

  if active {
    println("  [Reflection] Result: " + reflection_result_name(result))
    println("  [Reflection] Recommendation: " + recommendation)
    println("  [Reflection] Retry Count: " + retry_count)
  }
}

// ─────────────────────────────────────────────────────────────
// Reset Hook
// ─────────────────────────────────────────────────────────────

fn ReflectionHook_reset() {
  GLOBAL_REFLECTION_ACTIVE = false
  GLOBAL_REFLECTION_ANALYSIS = ""
  GLOBAL_REFLECTION_RESULT = 0
  GLOBAL_REFLECTION_RECOMMENDATION = ""
  GLOBAL_REFLECTION_RETRY_COUNT = 0
  return 1
}

// ─────────────────────────────────────────────────────────────
// Test Utilities
// ─────────────────────────────────────────────────────────────

fn assert_true(actual, msg) {
  if actual {
    println("✓ " + msg)
    return true
  }
  println("✗ FAILED: " + msg)
  return false
}

fn assert_equal(actual, expected, msg) {
  if actual == expected {
    println("✓ " + msg)
    return true
  }
  println("✗ FAILED: " + msg)
  println("  Expected: " + expected)
  println("  Actual: " + actual)
  return false
}

// ─────────────────────────────────────────────────────────────
// TEST 1: Successful Execution Reflection → Completed
// ─────────────────────────────────────────────────────────────

fn test_01_reflection_all_success() {
  println("")
  println("🧪 TEST 1: Successful Execution Reflection → Completed")

  ReflectionHook_reset()

  // All tasks succeeded (3 completed out of 3)
  let result = ReflectionHook_execute(STATE_REFLECTING, 3, 3, "", 3, 3)

  assert_true(result, "Reflection executed successfully")
  assert_equal(ReflectionHook_result(), REFLECTION_SUCCESS, "Reflection result: Success")
  assert_equal(ReflectionHook_retryCount(), 0, "Retry count remains 0 (no retry needed)")

  let next_state = ReflectionHook_determineNextState(ReflectionHook_result())
  assert_equal(next_state, STATE_COMPLETED, "Next state: Completed")

  println("✅ TEST 1 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 2: Failed Task Reflection → RetryPossible
// ─────────────────────────────────────────────────────────────

fn test_02_reflection_retry_possible() {
  println("")
  println("🧪 TEST 2: Failed Task Reflection → RetryPossible")

  ReflectionHook_reset()

  // 1 task failed out of 3, retry count is 0, max_retries is 3
  let result = ReflectionHook_execute(STATE_REFLECTING, 3, 2, "Task 2 failed", 2, 3)

  assert_true(result, "Reflection executed successfully")
  assert_equal(ReflectionHook_result(), REFLECTION_RETRY_POSSIBLE, "Reflection result: RetryPossible")
  assert_equal(ReflectionHook_retryCount(), 1, "Retry count incremented to 1")

  let next_state = ReflectionHook_determineNextState(ReflectionHook_result())
  assert_equal(next_state, STATE_EXECUTING, "Next state: Executing (retry)")

  println("✅ TEST 2 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 3: Retry Limit Exceeded → Unrecoverable
// ─────────────────────────────────────────────────────────────

fn test_03_reflection_unrecoverable() {
  println("")
  println("🧪 TEST 3: Retry Limit Exceeded → Unrecoverable")

  ReflectionHook_reset()

  // Set retry count to 3 (equal to max_retries)
  GLOBAL_REFLECTION_RETRY_COUNT = 3

  // Task failed, current_retry is 3, max_retries is 3
  let result = ReflectionHook_execute(STATE_REFLECTING, 3, 1, "Persistent failure", 3, 3)

  assert_true(result, "Reflection executed successfully")
  assert_equal(ReflectionHook_result(), REFLECTION_UNRECOVERABLE, "Reflection result: Unrecoverable")

  let next_state = ReflectionHook_determineNextState(ReflectionHook_result())
  assert_equal(next_state, STATE_FAILED, "Next state: Failed")

  println("✅ TEST 3 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 4: Strategy Recommendation Generation
// ─────────────────────────────────────────────────────────────

fn test_04_strategy_recommendation() {
  println("")
  println("🧪 TEST 4: Strategy Recommendation Generation")

  ReflectionHook_reset()

  // Test success recommendation
  let recommendation_success = Reflection_generateStrategy(REFLECTION_SUCCESS, "", 3)
  assert_true(recommendation_success != "", "Success recommendation generated")

  // Test retry recommendation
  let recommendation_retry = Reflection_generateStrategy(REFLECTION_RETRY_POSSIBLE, "Network timeout", 3)
  assert_true(recommendation_retry != "", "Retry recommendation generated")
  assert_true(recommendation_retry != recommendation_success, "Different recommendations for different results")

  println("✅ TEST 4 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 5: Memory Review During Reflection
// ─────────────────────────────────────────────────────────────

fn test_05_memory_review() {
  println("")
  println("🧪 TEST 5: Memory Review During Reflection")

  ReflectionHook_reset()

  // Review with observations
  let review_with_memory = Reflection_reviewMemory(5)
  assert_true(review_with_memory != "", "Memory review with 5 observations generated")
  assert_true(review_with_memory != "No observations recorded yet.", "Non-empty memory recognized")

  // Review with empty memory
  let review_empty = Reflection_reviewMemory(0)
  assert_equal(review_empty, "No observations recorded yet.", "Empty memory recognized")

  println("✅ TEST 5 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 6: Multiple Retry Cycles
// ─────────────────────────────────────────────────────────────

fn test_06_multiple_retries() {
  println("")
  println("🧪 TEST 6: Multiple Retry Cycles")

  ReflectionHook_reset()

  // First retry
  ReflectionHook_execute(STATE_REFLECTING, 3, 2, "Error", 2, 3)
  let retry_count_1 = ReflectionHook_retryCount()
  assert_equal(retry_count_1, 1, "First retry increments to 1")

  // Reset for second retry
  GLOBAL_REFLECTION_ACTIVE = false
  ReflectionHook_execute(STATE_REFLECTING, 3, 2, "Error", 3, 3)
  let retry_count_2 = ReflectionHook_retryCount()
  assert_equal(retry_count_2, 2, "Second retry increments to 2")

  // Reset for third retry
  GLOBAL_REFLECTION_ACTIVE = false
  ReflectionHook_execute(STATE_REFLECTING, 3, 2, "Error", 4, 3)
  let retry_count_3 = ReflectionHook_retryCount()
  assert_equal(retry_count_3, 3, "Third retry increments to 3")

  // Next attempt should be unrecoverable
  GLOBAL_REFLECTION_ACTIVE = false
  ReflectionHook_execute(STATE_REFLECTING, 3, 1, "Error", 5, 3)
  let result = ReflectionHook_result()
  assert_equal(result, REFLECTION_UNRECOVERABLE, "Retry limit reached → Unrecoverable")

  println("✅ TEST 6 PASSED")
}

