### 5. GetProp (객체 속성 접근)

**현재 코드:**
```typescript
case Op.GetProp: {
  const name = this.chunk.constants[this.chunk.code[this.ip++]] as { tag: "str"; val: string };
  const obj = this.pop();
  if (obj.tag === "object")
    this.stack.push(obj.val.get(name.val) ?? { tag: "null" });  // Value 직접 push
}
```

**Step 5 변경:**
```typescript
case Op.GetProp: {
  const name = this.chunk.constants[this.chunk.code[this.ip++]] as { tag: "str"; val: string };
  const obj = this.pop();
  if (obj.tag === "object") {
    const prop = obj.val.get(name.val) ?? { tag: "null" };
    // STEP 5: 속성값도 Heap 기반으로
    this.stack.push(this.heapPtrToValue(this.valueToHeapPtr(prop)));
  }
}
```

---

### 6. SetProp (객체 속성 설정)

**현재 코드:**
```typescript
case Op.SetProp: {
  const propName = this.pop();
  const obj = this.pop();
  const val = this.peek();
  if (obj.tag === "object" && propName.tag === "str") {
    obj.val.set(propName.val, val);  // Value 직접 저장
  }
}
```

**Step 5 변경:**
```typescript
case Op.SetProp: {
  const propName = this.pop();
  const obj = this.pop();
  const val = this.peek();
  if (obj.tag === "object" && propName.tag === "str") {
    // STEP 5: 속성값도 Heap에 할당
    obj.val.set(propName.val, this.heapPtrToValue(this.valueToHeapPtr(val)));
  }
}
```

