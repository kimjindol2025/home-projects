### 3. SetIndex (배열/객체 요소 설정)

**현재 코드:**
```typescript
case Op.SetIndex: {
  const idx = this.pop();
  const obj = this.pop();
  const val = this.pop();
  if (obj.tag === "array" && idx.tag === "num") {
    obj.val[Math.floor(idx.val)] = val;  // Value 직접 저장
  }
  this.stack.push(val);
}
```

**Step 5 변경:**
```typescript
case Op.SetIndex: {
  const idx = this.pop();
  const obj = this.pop();
  const val = this.pop();
  if (obj.tag === "array" && idx.tag === "num") {
    // STEP 5: 요소도 Heap에 할당
    obj.val[Math.floor(idx.val)] = this.heapPtrToValue(this.valueToHeapPtr(val));
  }
  this.stack.push(val);
}
```

