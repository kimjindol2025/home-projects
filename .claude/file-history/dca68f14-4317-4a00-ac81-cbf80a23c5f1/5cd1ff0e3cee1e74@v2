### 4. NewObject (객체 생성)

**현재 코드:**
```typescript
case Op.NewObject: {
  const count = this.chunk.code[this.ip++];
  const map = new Map<string, Value>();
  const items = this.stack.splice(this.stack.length - count * 2, count * 2);
  for (let i = 0; i < items.length; i += 2) {
    map.set((items[i] as { tag: "str"; val: string }).val, items[i + 1]);
  }
  this.stack.push({ tag: "object", val: map });  // Value 직접 생성
}
```

**Step 5 변경:**
```typescript
case Op.NewObject: {
  const count = this.chunk.code[this.ip++];
  const map = new Map<string, Value>();
  const items = this.stack.splice(this.stack.length - count * 2, count * 2);
  for (let i = 0; i < items.length; i += 2) {
    const key = (items[i] as { tag: "str"; val: string }).val;
    // STEP 5: 객체의 값도 Heap에 할당
    map.set(key, this.heapPtrToValue(this.valueToHeapPtr(items[i + 1])));
  }
  const objValue = { tag: "object", val: map };
  // STEP 5: 객체 자체도 Heap에 할당
  this.stack.push(this.heapPtrToValue(this.valueToHeapPtr(objValue)));
}
```

