fn assert_eq(actual, expected, msg) {
  if actual == expected {
    println("✓ " + msg)
    return true
  }
  println("✗ FAILED: " + msg)
  println("  Expected: " + expected)
  println("  Actual: " + actual)
  return false
}

fn test_01_valid_sequence() {
  println("")
  println("🧪 TEST 1: Valid State Sequence")

  let state = STATE_IDLE
  assert_eq(state, STATE_IDLE, "Start at Idle")

  state = transition(state, STATE_PLANNING)
  assert_eq(state, STATE_PLANNING, "Idle → Planning")

  state = transition(state, STATE_EXECUTING)
  assert_eq(state, STATE_EXECUTING, "Planning → Executing")

  state = transition(state, STATE_OBSERVING)
  assert_eq(state, STATE_OBSERVING, "Executing → Observing")

  state = transition(state, STATE_REFLECTING)
  assert_eq(state, STATE_REFLECTING, "Observing → Reflecting")

  state = transition(state, STATE_COMPLETED)
  assert_eq(state, STATE_COMPLETED, "Reflecting → Completed")

  println("✅ TEST 1 PASSED")
}

fn test_02_invalid_idle_transition() {
  println("")
  println("🧪 TEST 2: Invalid Idle Transitions")

  let state = STATE_IDLE
  let original = state

  // Invalid transitions from Idle
  state = transition(state, STATE_OBSERVING)
  assert_eq(state, original, "Idle -X→ Observing (blocked)")

  state = transition(state, STATE_REFLECTING)
  assert_eq(state, original, "Idle -X→ Reflecting (blocked)")

  state = transition(state, STATE_COMPLETED)
  assert_eq(state, original, "Idle -X→ Completed (blocked)")

  println("✅ TEST 2 PASSED")
}

fn test_03_invalid_planning_transition() {
  println("")
  println("🧪 TEST 3: Invalid Planning Transitions")

  let state = STATE_PLANNING
  let original = state

  // Invalid transitions from Planning
  state = transition(state, STATE_IDLE)
  assert_eq(state, original, "Planning -X→ Idle (blocked)")

  state = transition(state, STATE_OBSERVING)
  assert_eq(state, original, "Planning -X→ Observing (blocked)")

  state = transition(state, STATE_COMPLETED)
  assert_eq(state, original, "Planning -X→ Completed (blocked)")

  println("✅ TEST 3 PASSED")
}

fn test_04_multiple_valid_paths() {
  println("")
  println("🧪 TEST 4: Multiple Valid Paths from Reflecting")

  // Path 1: Reflecting → Completed
  let state = STATE_REFLECTING
  state = transition(state, STATE_COMPLETED)
  assert_eq(state, STATE_COMPLETED, "Path 1: Reflecting → Completed")

  // Path 2: Reflecting → Failed
  state = STATE_REFLECTING
  state = transition(state, STATE_FAILED)
  assert_eq(state, STATE_FAILED, "Path 2: Reflecting → Failed")

  // Path 3: Reflecting → Planning (retry)
  state = STATE_REFLECTING
  state = transition(state, STATE_PLANNING)
  assert_eq(state, STATE_PLANNING, "Path 3: Reflecting → Planning")

  println("✅ TEST 4 PASSED")
}

fn test_05_terminal_state_no_exit() {
  println("")
  println("🧪 TEST 5: Terminal States Block Transitions")

  // Completed is terminal
  let state = STATE_COMPLETED
  state = transition(state, STATE_IDLE)
  assert_eq(state, STATE_COMPLETED, "Completed -X→ Idle (blocked)")

  state = transition(state, STATE_PLANNING)
  assert_eq(state, STATE_COMPLETED, "Completed -X→ Planning (blocked)")

  // Failed is terminal
  state = STATE_FAILED
  state = transition(state, STATE_IDLE)
  assert_eq(state, STATE_FAILED, "Failed -X→ Idle (blocked)")

  state = transition(state, STATE_PLANNING)
  assert_eq(state, STATE_FAILED, "Failed -X→ Planning (blocked)")

  println("✅ TEST 5 PASSED")
}

