let STATE_IDLE = 0
let STATE_PLANNING = 1
let STATE_EXECUTING = 2
let STATE_OBSERVING = 3
let STATE_REFLECTING = 4
let STATE_COMPLETED = 5
let STATE_FAILED = 6

fn state_name(state) {
  if state == STATE_IDLE { return "Idle" }
  if state == STATE_PLANNING { return "Planning" }
  if state == STATE_EXECUTING { return "Executing" }
  if state == STATE_OBSERVING { return "Observing" }
  if state == STATE_REFLECTING { return "Reflecting" }
  if state == STATE_COMPLETED { return "Completed" }
  if state == STATE_FAILED { return "Failed" }
  return "Unknown"
}

// ─────────────────────────────────────────────────────────────
// 상태 전이 매트릭스
// ─────────────────────────────────────────────────────────────

fn is_valid_transition(from_state, to_state) {
  // Idle
  if from_state == STATE_IDLE {
    if to_state == STATE_PLANNING { return true }
    if to_state == STATE_EXECUTING { return true }
    return false
  }

  // Planning
  if from_state == STATE_PLANNING {
    if to_state == STATE_EXECUTING { return true }
    if to_state == STATE_FAILED { return true }
    return false
  }

  // Executing
  if from_state == STATE_EXECUTING {
    if to_state == STATE_OBSERVING { return true }
    if to_state == STATE_REFLECTING { return true }
    return false
  }

  // Observing
  if from_state == STATE_OBSERVING {
    if to_state == STATE_EXECUTING { return true }
    if to_state == STATE_REFLECTING { return true }
    if to_state == STATE_COMPLETED { return true }
    return false
  }

  // Reflecting
  if from_state == STATE_REFLECTING {
    if to_state == STATE_PLANNING { return true }
    if to_state == STATE_EXECUTING { return true }
    if to_state == STATE_COMPLETED { return true }
    if to_state == STATE_FAILED { return true }
    return false
  }

  // Completed, Failed (terminal states)
  if from_state == STATE_COMPLETED { return false }
  if from_state == STATE_FAILED { return false }

  return false
}

fn transition(from_state, to_state) {
  if is_valid_transition(from_state, to_state) {
    return to_state
  }
  return from_state
}

