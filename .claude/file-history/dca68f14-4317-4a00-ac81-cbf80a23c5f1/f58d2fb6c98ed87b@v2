// ─────────────────────────────────────────────────────────────
// Task Status Constants
// ─────────────────────────────────────────────────────────────

let TASK_STATUS_PENDING = 0
let TASK_STATUS_RUNNING = 1
let TASK_STATUS_DONE = 2
let TASK_STATUS_ERROR = 3

fn task_status_name(status) {
  if status == TASK_STATUS_PENDING { return "Pending" }
  if status == TASK_STATUS_RUNNING { return "Running" }
  if status == TASK_STATUS_DONE { return "Done" }
  if status == TASK_STATUS_ERROR { return "Error" }
  return "Unknown"
}

// ─────────────────────────────────────────────────────────────
// Timestamp Generator (전역)
// ─────────────────────────────────────────────────────────────

let GLOBAL_TIMESTAMP_COUNTER = 0

fn timestamp_generate() {
  GLOBAL_TIMESTAMP_COUNTER = GLOBAL_TIMESTAMP_COUNTER + 1
  return GLOBAL_TIMESTAMP_COUNTER
}

fn timestamp_reset() {
  GLOBAL_TIMESTAMP_COUNTER = 0
}

// ─────────────────────────────────────────────────────────────
// Observation 구조
// [task_id, output, status, timestamp]
// ─────────────────────────────────────────────────────────────

fn Observation_new(task_id, output, status) {
  let ts = timestamp_generate()
  return [task_id, output, status, ts]
}

fn Observation_taskId(obs) {
  return obs[0]
}

fn Observation_output(obs) {
  return obs[1]
}

fn Observation_status(obs) {
  return obs[2]
}

fn Observation_timestamp(obs) {
  return obs[3]
}

// ─────────────────────────────────────────────────────────────
// Memory v1: Append-only Storage (전역)
// ─────────────────────────────────────────────────────────────

let GLOBAL_MEMORY_COUNT = 0
let GLOBAL_MEMORY_GOAL = ""

// Observation 저장소 (최대 10개)
let MEMORY_OBS_1 = ""
let MEMORY_OBS_2 = ""
let MEMORY_OBS_3 = ""
let MEMORY_OBS_4 = ""
let MEMORY_OBS_5 = ""
let MEMORY_OBS_6 = ""
let MEMORY_OBS_7 = ""
let MEMORY_OBS_8 = ""
let MEMORY_OBS_9 = ""
let MEMORY_OBS_10 = ""

fn Memory_new(goal_description) {
  GLOBAL_MEMORY_COUNT = 0
  GLOBAL_MEMORY_GOAL = goal_description
  return 1
}

fn Memory_goal() {
  return GLOBAL_MEMORY_GOAL
}

fn Memory_store(observation) {
  if GLOBAL_MEMORY_COUNT >= 10 {
    return false  // 메모리 가득참
  }

  GLOBAL_MEMORY_COUNT = GLOBAL_MEMORY_COUNT + 1

  // 저장 (전역 변수에)
  if GLOBAL_MEMORY_COUNT == 1 { MEMORY_OBS_1 = observation }
  if GLOBAL_MEMORY_COUNT == 2 { MEMORY_OBS_2 = observation }
  if GLOBAL_MEMORY_COUNT == 3 { MEMORY_OBS_3 = observation }
  if GLOBAL_MEMORY_COUNT == 4 { MEMORY_OBS_4 = observation }
  if GLOBAL_MEMORY_COUNT == 5 { MEMORY_OBS_5 = observation }
  if GLOBAL_MEMORY_COUNT == 6 { MEMORY_OBS_6 = observation }
  if GLOBAL_MEMORY_COUNT == 7 { MEMORY_OBS_7 = observation }
  if GLOBAL_MEMORY_COUNT == 8 { MEMORY_OBS_8 = observation }
  if GLOBAL_MEMORY_COUNT == 9 { MEMORY_OBS_9 = observation }
  if GLOBAL_MEMORY_COUNT == 10 { MEMORY_OBS_10 = observation }

  return true
}

fn Memory_length() {
  return GLOBAL_MEMORY_COUNT
}

fn Memory_recall(index) {
  if index < 1 { return "" }
  if index > GLOBAL_MEMORY_COUNT { return "" }

  if index == 1 { return MEMORY_OBS_1 }
  if index == 2 { return MEMORY_OBS_2 }
  if index == 3 { return MEMORY_OBS_3 }
  if index == 4 { return MEMORY_OBS_4 }
  if index == 5 { return MEMORY_OBS_5 }
  if index == 6 { return MEMORY_OBS_6 }
  if index == 7 { return MEMORY_OBS_7 }
  if index == 8 { return MEMORY_OBS_8 }
  if index == 9 { return MEMORY_OBS_9 }
  if index == 10 { return MEMORY_OBS_10 }

  return ""
}

fn Memory_getAllCount() {
  return GLOBAL_MEMORY_COUNT
}

// ─────────────────────────────────────────────────────────────
// Observation Helper Functions
// ─────────────────────────────────────────────────────────────

fn Observation_display(obs) {
  let task_id = Observation_taskId(obs)
  let output = Observation_output(obs)
  let status = Observation_status(obs)
  let ts = Observation_timestamp(obs)

  println("  [" + ts + "] Task: " + task_id + " | Status: " + task_status_name(status) + " | Output: " + output)
}

// ─────────────────────────────────────────────────────────────
// Execution with Memory Storage
// ─────────────────────────────────────────────────────────────

fn execute_and_store(memory, task_id, should_fail) {
  let status = TASK_STATUS_DONE
  let output = "Task executed"

  if should_fail {
    status = TASK_STATUS_ERROR
    output = "Task failed"
  }

  let observation = Observation_new(task_id, output, status)

  // Memory에 저장
  Memory_store(observation)

  return observation
}

// ─────────────────────────────────────────────────────────────
// Test Utilities
// ─────────────────────────────────────────────────────────────

fn assert_true(actual, msg) {
  if actual {
    println("✓ " + msg)
    return true
  }
  println("✗ FAILED: " + msg)
  return false
}

fn assert_equal(actual, expected, msg) {
  if actual == expected {
    println("✓ " + msg)
    return true
  }
  println("✗ FAILED: " + msg)
  println("  Expected: " + expected)
  println("  Actual: " + actual)
  return false
}

// ─────────────────────────────────────────────────────────────
// TEST 1: Memory Length Increment
// ─────────────────────────────────────────────────────────────

fn test_01_memory_length() {
  println("")
  println("🧪 TEST 1: Memory Length Increment After Execution")

  timestamp_reset()
  let memory = Memory_new("Test goal")

  assert_equal(Memory_length(), 0, "Initial memory empty")

  execute_and_store(memory, "task-1", false)
  assert_equal(Memory_length(), 1, "Memory length = 1 after 1st execution")

  execute_and_store(memory, "task-2", false)
  assert_equal(Memory_length(), 2, "Memory length = 2 after 2nd execution")

  execute_and_store(memory, "task-3", false)
  assert_equal(Memory_length(), 3, "Memory length = 3 after 3rd execution")

  println("✅ TEST 1 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 2: Observation Field Validation
// ─────────────────────────────────────────────────────────────

fn test_02_observation_fields() {
  println("")
  println("🧪 TEST 2: Observation Field Accuracy")

  timestamp_reset()
  let memory = Memory_new("Validate fields")

  let obs = Observation_new("task-A", "output-A", TASK_STATUS_DONE)

  assert_equal(Observation_taskId(obs), "task-A", "task_id correct")
  assert_equal(Observation_output(obs), "output-A", "output correct")
  assert_equal(Observation_status(obs), TASK_STATUS_DONE, "status correct")
  assert_equal(Observation_timestamp(obs), 1, "timestamp correct")

  println("✅ TEST 2 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 3: Failed Task Recording
// ─────────────────────────────────────────────────────────────

fn test_03_failed_task_stored() {
  println("")
  println("🧪 TEST 3: Failed Task Also Recorded")

  timestamp_reset()
  let memory = Memory_new("Record failures")

  execute_and_store(memory, "task-success", false)
  execute_and_store(memory, "task-fail", true)
  execute_and_store(memory, "task-success2", false)

  assert_equal(Memory_length(), 3, "All tasks recorded (including failures)")

  let obs2 = Memory_recall(2)
  let status2 = Observation_status(obs2)
  assert_equal(status2, TASK_STATUS_ERROR, "Failed task status is ERROR")

  println("✅ TEST 3 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 4: Memory Recall Function
// ─────────────────────────────────────────────────────────────

fn test_04_memory_recall() {
  println("")
  println("🧪 TEST 4: Memory Recall() Function")

  timestamp_reset()
  let memory = Memory_new("Test recall")

  execute_and_store(memory, "task-1", false)
  execute_and_store(memory, "task-2", false)
  execute_and_store(memory, "task-3", false)

  let obs1 = Memory_recall(1)
  let obs2 = Memory_recall(2)
  let obs3 = Memory_recall(3)

  assert_equal(Observation_taskId(obs1), "task-1", "Recall index 1 correct")
  assert_equal(Observation_taskId(obs2), "task-2", "Recall index 2 correct")
  assert_equal(Observation_taskId(obs3), "task-3", "Recall index 3 correct")

  let obs_invalid = Memory_recall(10)
  assert_equal(obs_invalid, "", "Recall out of range returns empty")

  println("✅ TEST 4 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 5: Goal Access from Memory
// ─────────────────────────────────────────────────────────────

fn test_05_goal_access() {
  println("")
  println("🧪 TEST 5: Goal Access from Memory")

  let memory = Memory_new("Execute user request")

  assert_equal(Memory_goal(), "Execute user request", "Goal accessible from memory")

  println("✅ TEST 5 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 6: Append-only Semantics
// ─────────────────────────────────────────────────────────────

fn test_06_append_only() {
  println("")
  println("🧪 TEST 6: Append-only Memory Structure")

  timestamp_reset()
  let memory = Memory_new("Test append-only")

  execute_and_store(memory, "task-A", false)
  let len1 = Memory_length()

  execute_and_store(memory, "task-B", false)
  let len2 = Memory_length()

  assert_equal(len2 - len1, 1, "Each store increments length by 1")
  assert_equal(len2, 2, "No deletions or overwrites (append-only)")

  println("✅ TEST 6 PASSED")
}

