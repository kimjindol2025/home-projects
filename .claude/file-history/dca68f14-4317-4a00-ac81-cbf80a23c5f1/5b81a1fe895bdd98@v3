## 구현 3: src/compiler.ts - 상수 폴딩

```typescript
// 현재 (src/compiler.ts:437-447): 모든 이진 연산 → 3개 옵코드 생성
case "binary": {
  compileExpr(e.left);
  compileExpr(e.right);
  emit(ops[e.op]);
  break;
}

// 변경 후: num+num이면 컴파일 타임 계산
case "binary": {
  if (e.left.kind === "number" && e.right.kind === "number") {
    const l = e.left.value, r = e.right.value
    let result: Value | null = null
    if (e.op === "+") result = { tag: "num", val: l + r }
    else if (e.op === "-") result = { tag: "num", val: l - r }
    else if (e.op === "*") result = { tag: "num", val: l * r }
    else if (e.op === "/" && r !== 0) result = { tag: "num", val: l / r }
    else if (e.op === "%") result = { tag: "num", val: l % r }
    else if (e.op === "==") result = { tag: "bool", val: l === r }
    else if (e.op === "!=") result = { tag: "bool", val: l !== r }
    else if (e.op === "<")  result = { tag: "bool", val: l < r }
    else if (e.op === ">")  result = { tag: "bool", val: l > r }
    else if (e.op === "<=") result = { tag: "bool", val: l <= r }
    else if (e.op === ">=") result = { tag: "bool", val: l >= r }
    if (result) { emitArg(Op.Const, addConst(result)); break; }
  }
  // 문자열 + 문자열 폴딩
  if (e.left.kind === "string" && e.right.kind === "string" && e.op === "+") {
    emitArg(Op.Const, addConst({ tag: "str", val: e.left.value + e.right.value }))
    break
  }
  // 폴딩 불가 → 기존 방식
  compileExpr(e.left);
  compileExpr(e.right);
  emit(ops[e.op]);
  break;
}
```

