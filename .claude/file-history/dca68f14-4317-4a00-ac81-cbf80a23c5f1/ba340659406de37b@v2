fn ExecutionPool_add(task_id) {
  if GLOBAL_EXECUTION_POOL_COUNT >= GLOBAL_MAX_PARALLEL {
    return false
  }

  GLOBAL_EXECUTION_POOL_COUNT = GLOBAL_EXECUTION_POOL_COUNT + 1

  if GLOBAL_EXECUTION_POOL_COUNT == 1 { GLOBAL_EXECUTION_POOL_1 = task_id }
  if GLOBAL_EXECUTION_POOL_COUNT == 2 { GLOBAL_EXECUTION_POOL_2 = task_id }
  if GLOBAL_EXECUTION_POOL_COUNT == 3 { GLOBAL_EXECUTION_POOL_3 = task_id }
  if GLOBAL_EXECUTION_POOL_COUNT == 4 { GLOBAL_EXECUTION_POOL_4 = task_id }
  if GLOBAL_EXECUTION_POOL_COUNT == 5 { GLOBAL_EXECUTION_POOL_5 = task_id }
  if GLOBAL_EXECUTION_POOL_COUNT == 6 { GLOBAL_EXECUTION_POOL_6 = task_id }

  return true
}

fn ExecutionPool_remove(task_id) {
  let found = false
  let i = 1

  while i <= GLOBAL_EXECUTION_POOL_COUNT {
    if !found {
      let pool_id = ""
      if i == 1 { pool_id = GLOBAL_EXECUTION_POOL_1 }
      if i == 2 { pool_id = GLOBAL_EXECUTION_POOL_2 }
      if i == 3 { pool_id = GLOBAL_EXECUTION_POOL_3 }
      if i == 4 { pool_id = GLOBAL_EXECUTION_POOL_4 }
      if i == 5 { pool_id = GLOBAL_EXECUTION_POOL_5 }
      if i == 6 { pool_id = GLOBAL_EXECUTION_POOL_6 }

      if pool_id == task_id {
        found = true
        // Shift remaining tasks
        if i < GLOBAL_EXECUTION_POOL_COUNT {
          let j = i
          while j < GLOBAL_EXECUTION_POOL_COUNT {
            let next_idx = j + 1
            let next_id = ""
            if next_idx == 1 { next_id = GLOBAL_EXECUTION_POOL_1 }
            if next_idx == 2 { next_id = GLOBAL_EXECUTION_POOL_2 }
            if next_idx == 3 { next_id = GLOBAL_EXECUTION_POOL_3 }
            if next_idx == 4 { next_id = GLOBAL_EXECUTION_POOL_4 }
            if next_idx == 5 { next_id = GLOBAL_EXECUTION_POOL_5 }
            if next_idx == 6 { next_id = GLOBAL_EXECUTION_POOL_6 }

            if j == 1 { GLOBAL_EXECUTION_POOL_1 = next_id }
            if j == 2 { GLOBAL_EXECUTION_POOL_2 = next_id }
            if j == 3 { GLOBAL_EXECUTION_POOL_3 = next_id }
            if j == 4 { GLOBAL_EXECUTION_POOL_4 = next_id }
            if j == 5 { GLOBAL_EXECUTION_POOL_5 = next_id }
            if j == 6 { GLOBAL_EXECUTION_POOL_6 = next_id }

            j = j + 1
          }
        }

        // Clear last slot
        if GLOBAL_EXECUTION_POOL_COUNT == 1 { GLOBAL_EXECUTION_POOL_1 = "" }
        if GLOBAL_EXECUTION_POOL_COUNT == 2 { GLOBAL_EXECUTION_POOL_2 = "" }
        if GLOBAL_EXECUTION_POOL_COUNT == 3 { GLOBAL_EXECUTION_POOL_3 = "" }
        if GLOBAL_EXECUTION_POOL_COUNT == 4 { GLOBAL_EXECUTION_POOL_4 = "" }
        if GLOBAL_EXECUTION_POOL_COUNT == 5 { GLOBAL_EXECUTION_POOL_5 = "" }
        if GLOBAL_EXECUTION_POOL_COUNT == 6 { GLOBAL_EXECUTION_POOL_6 = "" }

        GLOBAL_EXECUTION_POOL_COUNT = GLOBAL_EXECUTION_POOL_COUNT - 1
      }
    }

    i = i + 1
  }

  return found
}

fn ExecutionPool_length() {
  return GLOBAL_EXECUTION_POOL_COUNT
}

// ─────────────────────────────────────────────────────────────
// Dependency Checking (v2.1 same)
// ─────────────────────────────────────────────────────────────

fn findTaskIndexById(task_id) {
  let i = 1
  while i <= GLOBAL_TASK_GRAPH_COUNT {
    let id = Graph_getTaskId(i)
    if id == task_id {
      return i
    }
    i = i + 1
  }
  return 0
}

fn isReady(task_index) {
  let dep_count = Graph_getDependencyCount(task_index)

  if dep_count == 0 {
    return true
  }

  let i = 1
  while i <= dep_count {
    let dep_id = Graph_getDependency(task_index, i)
    let dep_index = findTaskIndexById(dep_id)

    if dep_index == 0 {
      return false
    }

    let dep_status = Task_getStatus(dep_index)

    if dep_status == TASK_STATUS_ERROR {
      return false
    }

    if dep_status != TASK_STATUS_DONE {
      return false
    }

    i = i + 1
  }

  return true
}

// ─────────────────────────────────────────────────────────────
// Upstream Dependency Discovery (v2.1 same)
// ─────────────────────────────────────────────────────────────

fn findDownstream(completed_task_id) {
  let i = 1
  while i <= GLOBAL_TASK_GRAPH_COUNT {
    let dep_count = Graph_getDependencyCount(i)

    let j = 1
    while j <= dep_count {
      let dep_id = Graph_getDependency(i, j)

      if dep_id == completed_task_id {
        if isReady(i) {
          let task_id = Graph_getTaskId(i)
          ReadyQueue_add(task_id)
          Task_setStatus(i, TASK_STATUS_READY)
        }
      }

      j = j + 1
    }

    i = i + 1
  }
}

// ─────────────────────────────────────────────────────────────
// ParallelExecutor (New: Concurrent execution control)
// ─────────────────────────────────────────────────────────────

fn ParallelExecutor_initialize(graph_task_count, max_parallel, failure_policy) {
  GLOBAL_TASK_GRAPH_COUNT = graph_task_count
  GLOBAL_MAX_PARALLEL = max_parallel
  GLOBAL_FAILURE_POLICY = failure_policy
  GLOBAL_READY_QUEUE_COUNT = 0
  GLOBAL_EXECUTION_POOL_COUNT = 0
  GLOBAL_COMPLETED_COUNT = 0
  GLOBAL_ERROR_DETECTED = false

  let i = 1
  while i <= graph_task_count {
    Task_setStatus(i, TASK_STATUS_PENDING)

    if isReady(i) {
      let task_id = Graph_getTaskId(i)
      ReadyQueue_add(task_id)
      Task_setStatus(i, TASK_STATUS_READY)
    }

    i = i + 1
  }

  return true
}

fn spawn(task_id, should_fail) {
  // Try to add to ExecutionPool
  if !ExecutionPool_add(task_id) {
    // Pool full
    return false
  }

  let task_index = findTaskIndexById(task_id)
  if task_index == 0 {
    ExecutionPool_remove(task_id)
    return false
  }

  // Execute the task
  Task_setStatus(task_index, TASK_STATUS_RUNNING)

  if should_fail {
    Task_setStatus(task_index, TASK_STATUS_ERROR)
    GLOBAL_ERROR_DETECTED = true
    GLOBAL_EXECUTION_ERROR = "Task " + task_id + " failed"
  } else {
    let output = "{\"status\": \"completed\", \"task\": \"" + task_id + "\"}"
    Task_setStatus(task_index, TASK_STATUS_DONE)
    Task_setOutput(task_index, output)
    GLOBAL_COMPLETED_COUNT = GLOBAL_COMPLETED_COUNT + 1
    findDownstream(task_id)
  }

  ExecutionPool_remove(task_id)
  return true
}

fn ParallelExecutor_runAll(should_fail_task_id) {
  let max_iterations = 100
  let iteration = 0

  let has_work = true
  while has_work {
    if iteration >= max_iterations { break }

    // Spawn as many ready tasks as pool capacity allows
    while ReadyQueue_length() > 0 {
      if ExecutionPool_length() >= GLOBAL_MAX_PARALLEL { break }

      let task_id = ReadyQueue_dequeue()
      if task_id == "" { break }

      let should_fail = (task_id == should_fail_task_id)
      spawn(task_id, should_fail)
    }

    // Check if there's more work
    if ReadyQueue_length() > 0 {
      has_work = true
    } else {
      if ExecutionPool_length() > 0 {
        has_work = true
      } else {
        has_work = false
      }
    }

    iteration = iteration + 1
  }

  // Check if all tasks are done
  let all_done = (GLOBAL_COMPLETED_COUNT == GLOBAL_TASK_GRAPH_COUNT)

  if all_done {
    return true
  } else {
    if GLOBAL_ERROR_DETECTED == false {
      GLOBAL_EXECUTION_ERROR = "Not all tasks completed"
    }
    return false
  }
}

