// TEST 1: MaxParallel=1 (Sequential Mode)
// ─────────────────────────────────────────────────────────────

fn test_01_sequential_mode() {
  println("")
  println("🧪 TEST 1: MaxParallel=1 (Sequential Mode)")

  ParallelPolicy_initialize(1, SCHEDULER_STRATEGY_FIFO, 1)

  ReadyQueue_add("task-A")
  ReadyQueue_add("task-B")
  ReadyQueue_add("task-C")

  let running = Policy_spawnReadyTasks()

  assert_equal(running, 1, "Only 1 task running")
  assert_equal(ExecutionPool_length(), 1, "Pool length: 1")

  println("✅ TEST 1 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 2: MaxParallel=2 (Parallel Mode)
// ─────────────────────────────────────────────────────────────

fn test_02_parallel_mode() {
  println("")
  println("🧪 TEST 2: MaxParallel=2 (Parallel Mode)")

  ParallelPolicy_initialize(2, SCHEDULER_STRATEGY_FIFO, 1)

  ReadyQueue_add("task-A")
  ReadyQueue_add("task-B")
  ReadyQueue_add("task-C")

  let running = Policy_spawnReadyTasks()

  assert_equal(running, 2, "2 tasks running")
  assert_equal(ExecutionPool_length(), 2, "Pool length: 2")
