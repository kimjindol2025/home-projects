// ─────────────────────────────────────────────────────────────
// PolicyDecision (v2.K.1/K.2/K.3 통합)
// ─────────────────────────────────────────────────────────────

let POLICY_DECISION_PROCEED = 1
let POLICY_DECISION_RETRY = 2
let POLICY_DECISION_REPLAN = 3
let POLICY_DECISION_ABORT = 4

fn policy_decision_name(decision) {
  if decision == POLICY_DECISION_PROCEED { return "Proceed" }
  if decision == POLICY_DECISION_RETRY { return "Retry" }
  if decision == POLICY_DECISION_REPLAN { return "Replan" }
  if decision == POLICY_DECISION_ABORT { return "Abort" }
  return "Unknown"
}

// ─────────────────────────────────────────────────────────────
// Scheduler Strategy (v2.K.3 상속)
// ─────────────────────────────────────────────────────────────

let SCHEDULER_STRATEGY_FIFO = 1
let SCHEDULER_STRATEGY_PRIORITY = 2

// ─────────────────────────────────────────────────────────────
// Parallel Policy Configuration
// ─────────────────────────────────────────────────────────────

let POLICY_MAX_PARALLEL = 2          // 동시 실행 수
let POLICY_SCHEDULER = SCHEDULER_STRATEGY_FIFO
let POLICY_MAX_RETRY = 1
let POLICY_MAX_REPLAN = 1
let POLICY_FAILURE_MODE = 1          // FAIL_FAST=1, FAIL_CONTINUE=2

// ─────────────────────────────────────────────────────────────
// ExecutionPool (v2.2에서 상속)
// ─────────────────────────────────────────────────────────────

let GLOBAL_EXECUTION_POOL_COUNT = 0
let GLOBAL_EXECUTION_POOL_1 = ""
let GLOBAL_EXECUTION_POOL_2 = ""
let GLOBAL_EXECUTION_POOL_3 = ""
let GLOBAL_EXECUTION_POOL_4 = ""
let GLOBAL_EXECUTION_POOL_5 = ""
let GLOBAL_EXECUTION_POOL_6 = ""

// ─────────────────────────────────────────────────────────────
// Policy State
// ─────────────────────────────────────────────────────────────

let GLOBAL_POLICY_INITIALIZED = false
let GLOBAL_POLICY_TOTAL_DECISIONS = 0
let GLOBAL_POLICY_TASKS_COMPLETED = 0
let GLOBAL_POLICY_TASKS_FAILED = 0

// ─────────────────────────────────────────────────────────────
// ReadyQueue (v2.K.3에서 상속)
// ─────────────────────────────────────────────────────────────

let GLOBAL_READY_QUEUE_COUNT = 0
let GLOBAL_READY_QUEUE_1 = ""
let GLOBAL_READY_QUEUE_2 = ""
let GLOBAL_READY_QUEUE_3 = ""
let GLOBAL_READY_QUEUE_4 = ""
let GLOBAL_READY_QUEUE_5 = ""
let GLOBAL_READY_QUEUE_6 = ""

fn ReadyQueue_add(task_id) {
  if GLOBAL_READY_QUEUE_COUNT >= 6 {
    return false
  }

  GLOBAL_READY_QUEUE_COUNT = GLOBAL_READY_QUEUE_COUNT + 1

  if GLOBAL_READY_QUEUE_COUNT == 1 { GLOBAL_READY_QUEUE_1 = task_id }
  if GLOBAL_READY_QUEUE_COUNT == 2 { GLOBAL_READY_QUEUE_2 = task_id }
  if GLOBAL_READY_QUEUE_COUNT == 3 { GLOBAL_READY_QUEUE_3 = task_id }
  if GLOBAL_READY_QUEUE_COUNT == 4 { GLOBAL_READY_QUEUE_4 = task_id }
  if GLOBAL_READY_QUEUE_COUNT == 5 { GLOBAL_READY_QUEUE_5 = task_id }
  if GLOBAL_READY_QUEUE_COUNT == 6 { GLOBAL_READY_QUEUE_6 = task_id }

  return true
}

fn ReadyQueue_peek() {
  if GLOBAL_READY_QUEUE_COUNT > 0 {
    return GLOBAL_READY_QUEUE_1
  }
  return ""
}

fn ReadyQueue_dequeue() {
  if GLOBAL_READY_QUEUE_COUNT == 0 {
    return ""
  }

  let first = GLOBAL_READY_QUEUE_1

  GLOBAL_READY_QUEUE_1 = GLOBAL_READY_QUEUE_2
  GLOBAL_READY_QUEUE_2 = GLOBAL_READY_QUEUE_3
  GLOBAL_READY_QUEUE_3 = GLOBAL_READY_QUEUE_4
  GLOBAL_READY_QUEUE_4 = GLOBAL_READY_QUEUE_5
  GLOBAL_READY_QUEUE_5 = GLOBAL_READY_QUEUE_6
  GLOBAL_READY_QUEUE_6 = ""

  GLOBAL_READY_QUEUE_COUNT = GLOBAL_READY_QUEUE_COUNT - 1

  return first
}

fn ReadyQueue_length() {
  return GLOBAL_READY_QUEUE_COUNT
}

// ─────────────────────────────────────────────────────────────
// ExecutionPool Management
// ─────────────────────────────────────────────────────────────

fn ExecutionPool_add(task_id) {
  if GLOBAL_EXECUTION_POOL_COUNT >= POLICY_MAX_PARALLEL {
    return false
  }

  GLOBAL_EXECUTION_POOL_COUNT = GLOBAL_EXECUTION_POOL_COUNT + 1

  if GLOBAL_EXECUTION_POOL_COUNT == 1 { GLOBAL_EXECUTION_POOL_1 = task_id }
  if GLOBAL_EXECUTION_POOL_COUNT == 2 { GLOBAL_EXECUTION_POOL_2 = task_id }
  if GLOBAL_EXECUTION_POOL_COUNT == 3 { GLOBAL_EXECUTION_POOL_3 = task_id }
  if GLOBAL_EXECUTION_POOL_COUNT == 4 { GLOBAL_EXECUTION_POOL_4 = task_id }
  if GLOBAL_EXECUTION_POOL_COUNT == 5 { GLOBAL_EXECUTION_POOL_5 = task_id }
  if GLOBAL_EXECUTION_POOL_COUNT == 6 { GLOBAL_EXECUTION_POOL_6 = task_id }

  return true
}

fn ExecutionPool_remove(task_id) {
  let found = false
  let i = 1

  while i <= GLOBAL_EXECUTION_POOL_COUNT {
    if !found {
      let pool_id = ""
      if i == 1 { pool_id = GLOBAL_EXECUTION_POOL_1 }
      if i == 2 { pool_id = GLOBAL_EXECUTION_POOL_2 }
      if i == 3 { pool_id = GLOBAL_EXECUTION_POOL_3 }
      if i == 4 { pool_id = GLOBAL_EXECUTION_POOL_4 }
      if i == 5 { pool_id = GLOBAL_EXECUTION_POOL_5 }
      if i == 6 { pool_id = GLOBAL_EXECUTION_POOL_6 }

      if pool_id == task_id {
        found = true
        if i < GLOBAL_EXECUTION_POOL_COUNT {
          let j = i
          while j < GLOBAL_EXECUTION_POOL_COUNT {
            let next_idx = j + 1
            let next_id = ""
            if next_idx == 1 { next_id = GLOBAL_EXECUTION_POOL_1 }
            if next_idx == 2 { next_id = GLOBAL_EXECUTION_POOL_2 }
            if next_idx == 3 { next_id = GLOBAL_EXECUTION_POOL_3 }
            if next_idx == 4 { next_id = GLOBAL_EXECUTION_POOL_4 }
            if next_idx == 5 { next_id = GLOBAL_EXECUTION_POOL_5 }
            if next_idx == 6 { next_id = GLOBAL_EXECUTION_POOL_6 }

            if j == 1 { GLOBAL_EXECUTION_POOL_1 = next_id }
            if j == 2 { GLOBAL_EXECUTION_POOL_2 = next_id }
            if j == 3 { GLOBAL_EXECUTION_POOL_3 = next_id }
            if j == 4 { GLOBAL_EXECUTION_POOL_4 = next_id }
            if j == 5 { GLOBAL_EXECUTION_POOL_5 = next_id }
            if j == 6 { GLOBAL_EXECUTION_POOL_6 = next_id }

            j = j + 1
          }
        }

        if GLOBAL_EXECUTION_POOL_COUNT == 1 { GLOBAL_EXECUTION_POOL_1 = "" }
        if GLOBAL_EXECUTION_POOL_COUNT == 2 { GLOBAL_EXECUTION_POOL_2 = "" }
        if GLOBAL_EXECUTION_POOL_COUNT == 3 { GLOBAL_EXECUTION_POOL_3 = "" }
        if GLOBAL_EXECUTION_POOL_COUNT == 4 { GLOBAL_EXECUTION_POOL_4 = "" }
        if GLOBAL_EXECUTION_POOL_COUNT == 5 { GLOBAL_EXECUTION_POOL_5 = "" }
        if GLOBAL_EXECUTION_POOL_COUNT == 6 { GLOBAL_EXECUTION_POOL_6 = "" }

        GLOBAL_EXECUTION_POOL_COUNT = GLOBAL_EXECUTION_POOL_COUNT - 1
      }
    }

    i = i + 1
  }

  return found
}

fn ExecutionPool_length() {
  return GLOBAL_EXECUTION_POOL_COUNT
}

// ─────────────────────────────────────────────────────────────
// Scheduler Selection (v2.K.3에서 상속)
// ─────────────────────────────────────────────────────────────

fn Policy_selectNext() {
  if POLICY_SCHEDULER == SCHEDULER_STRATEGY_FIFO {
    return ReadyQueue_peek()
  }

  if POLICY_SCHEDULER == SCHEDULER_STRATEGY_PRIORITY {
    return ReadyQueue_peek()  // Placeholder: priority 로직
  }

  return ReadyQueue_peek()
}

// ─────────────────────────────────────────────────────────────
// Parallel Policy Interface
// ─────────────────────────────────────────────────────────────

fn ParallelPolicy_initialize(max_parallel, scheduler_strategy, failure_mode) {
  GLOBAL_POLICY_INITIALIZED = true
  POLICY_MAX_PARALLEL = max_parallel
  POLICY_SCHEDULER = scheduler_strategy
  POLICY_FAILURE_MODE = failure_mode

  GLOBAL_POLICY_TOTAL_DECISIONS = 0
  GLOBAL_POLICY_TASKS_COMPLETED = 0
  GLOBAL_POLICY_TASKS_FAILED = 0

  GLOBAL_EXECUTION_POOL_COUNT = 0
  GLOBAL_READY_QUEUE_COUNT = 0

  return true
}

// ─────────────────────────────────────────────────────────────
// Policy Decision on Events
// ─────────────────────────────────────────────────────────────

fn policy_onTaskSuccess(task_id) {
  GLOBAL_POLICY_TOTAL_DECISIONS = GLOBAL_POLICY_TOTAL_DECISIONS + 1
  GLOBAL_POLICY_TASKS_COMPLETED = GLOBAL_POLICY_TASKS_COMPLETED + 1

  ExecutionPool_remove(task_id)

  return POLICY_DECISION_PROCEED
}

fn policy_onTaskFailure(task_id, retry_count) {
  GLOBAL_POLICY_TOTAL_DECISIONS = GLOBAL_POLICY_TOTAL_DECISIONS + 1
  GLOBAL_POLICY_TASKS_FAILED = GLOBAL_POLICY_TASKS_FAILED + 1

  ExecutionPool_remove(task_id)

  if retry_count == 0 {
    return POLICY_DECISION_RETRY
  }

  if retry_count == 1 {
    if POLICY_FAILURE_MODE == 1 {
      return POLICY_DECISION_ABORT
    }

    return POLICY_DECISION_ABORT
  }

  return POLICY_DECISION_ABORT
}

fn policy_onConstraintViolation(constraint_name) {
  GLOBAL_POLICY_TOTAL_DECISIONS = GLOBAL_POLICY_TOTAL_DECISIONS + 1
  return POLICY_DECISION_ABORT
}

// ─────────────────────────────────────────────────────────────
// Core: Policy가 N개의 Task를 Spawn
// ─────────────────────────────────────────────────────────────

fn Policy_spawnReadyTasks() {
  // Pool에 여유가 있는 동안 Ready Task를 실행
  while ReadyQueue_length() > 0 {
    if ExecutionPool_length() >= POLICY_MAX_PARALLEL {
      break
    }

    let task_id = Policy_selectNext()
    if task_id == "" {
      break
    }

    ReadyQueue_dequeue()

    if ExecutionPool_add(task_id) {
      // Task 시작 이벤트 (Memory에 기록됨)
    }
  }

  return ExecutionPool_length()
}

