// ─────────────────────────────────────────────────────────────
// TEST 8: No Race Condition (State Coherence)
// ─────────────────────────────────────────────────────────────

fn test_08_state_coherence() {
  println("")
  println("🧪 TEST 8: No Race Condition (State Coherence)")

  ParallelPolicy_initialize(3, SCHEDULER_STRATEGY_FIFO, 1)

  ReadyQueue_add("task-A")
  ReadyQueue_add("task-B")
  ReadyQueue_add("task-C")

  Policy_spawnReadyTasks()
  assert_equal(ExecutionPool_length(), 3, "Pool: 3 tasks")

  let pool_consistent = (ExecutionPool_length() == 3)
  assert_true(pool_consistent, "Pool state consistent")

  policy_onTaskSuccess(GLOBAL_EXECUTION_POOL_1)
  policy_onTaskSuccess(GLOBAL_EXECUTION_POOL_2)
  policy_onTaskSuccess(GLOBAL_EXECUTION_POOL_3)

  assert_equal(ExecutionPool_length(), 0, "Pool emptied correctly")
  assert_equal(GLOBAL_POLICY_TASKS_COMPLETED, 3, "All 3 tasks completed")

  println("✅ TEST 8 PASSED")
}

