// ─────────────────────────────────────────────────────────────
// TEST 3: Pool Slot Release on Task Completion
// ─────────────────────────────────────────────────────────────

fn test_03_slot_release() {
  println("")
  println("🧪 TEST 3: Pool Slot Release on Task Completion")

  ParallelPolicy_initialize(2, SCHEDULER_STRATEGY_FIFO, 1)

  ReadyQueue_add("task-A")
  ReadyQueue_add("task-B")
  ReadyQueue_add("task-C")

  Policy_spawnReadyTasks()
  assert_equal(ExecutionPool_length(), 2, "Pool: 2 tasks running")

  let first = GLOBAL_EXECUTION_POOL_1
  policy_onTaskSuccess(first)

  assert_equal(ExecutionPool_length(), 1, "Pool: 1 task (after completion)")

  println("✅ TEST 3 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 4: Fill Pool After Slot Release
// ─────────────────────────────────────────────────────────────

fn test_04_refill_pool() {
  println("")
  println("🧪 TEST 4: Refill Pool After Slot Release")

  ParallelPolicy_initialize(2, SCHEDULER_STRATEGY_FIFO, 1)

  ReadyQueue_add("task-A")
  ReadyQueue_add("task-B")
  ReadyQueue_add("task-C")

  Policy_spawnReadyTasks()
  let first = GLOBAL_EXECUTION_POOL_1
  policy_onTaskSuccess(first)

  assert_equal(ReadyQueue_length(), 1, "1 task in queue")
  assert_equal(ExecutionPool_length(), 1, "1 task in pool")

  println("✅ TEST 4 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 5: Failure with FAIL_FAST
// ─────────────────────────────────────────────────────────────

fn test_05_failure_fail_fast() {
  println("")
  println("🧪 TEST 5: Failure with FAIL_FAST Policy")

  ParallelPolicy_initialize(2, SCHEDULER_STRATEGY_FIFO, 1)

  ReadyQueue_add("task-A")
  ReadyQueue_add("task-B")

  Policy_spawnReadyTasks()

  let first = GLOBAL_EXECUTION_POOL_1
  let decision = policy_onTaskFailure(first, 1)

  assert_equal(decision, POLICY_DECISION_ABORT, "Decision: Abort")
  assert_equal(ExecutionPool_length(), 1, "Pool reduced")
  assert_equal(GLOBAL_POLICY_TASKS_FAILED, 1, "Failure counted")

  println("✅ TEST 5 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 6: Constraint Violation (Hard Stop)
// ─────────────────────────────────────────────────────────────

fn test_06_constraint_hard_stop() {
  println("")
  println("🧪 TEST 6: Constraint Violation (Hard Stop)")

  ParallelPolicy_initialize(2, SCHEDULER_STRATEGY_FIFO, 1)

  ReadyQueue_add("task-A")
  Policy_spawnReadyTasks()

  let decision = policy_onConstraintViolation("MaxSteps")

  assert_equal(decision, POLICY_DECISION_ABORT, "Constraint: Abort (hard stop)")

  println("✅ TEST 6 PASSED")
}

