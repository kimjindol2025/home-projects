## 🔧 구현 상세

### Step 1: 타입 정의

```typescript
// type-system.ts
export type Type =
  | PrimitiveType
  | ArrayType
  | ObjectType
  | FunctionType
  | UnionType

export interface ArrayType {
  kind: "array"
  elementType: Type
}

export interface ObjectType {
  kind: "object"
  properties: Map<string, Type>
}

export interface FunctionType {
  kind: "fn"
  paramTypes: Type[]
  returnType: Type
}
```

### Step 2: TypeChecker 구현

```typescript
// type-checker.ts
export class TypeChecker {
  private env: Map<string, Type> = new Map()
  private errors: TypeCheckError[] = []

  check(program: Program): TypeCheckResult {
    for (const stmt of program.statements) {
      this.checkStmt(stmt)
    }
    return {
      success: this.errors.length === 0,
      errors: this.errors
    }
  }

  checkExpr(expr: Expr): Type {
    switch (expr.kind) {
      case "number":
        return { kind: "primitive", type: PrimitiveType.NUM }
      case "string":
        return { kind: "primitive", type: PrimitiveType.STR }
      case "variable":
        const varType = this.env.get(expr.name)
        if (!varType) this.addError(`Undefined variable: ${expr.name}`)
        return varType || { kind: "never" }
      // ... 더 많은 케이스
    }
  }

  checkBinaryOp(op: string, left: Type, right: Type): Type {
    // Add, Sub, Mul 등에 따른 타입 결정
    if (op === "Add") {
      if (left.type === "num" && right.type === "num") {
        return { kind: "primitive", type: "num" }
      }
      if (left.type === "str" || right.type === "str") {
        return { kind: "primitive", type: "str" }
      }
    }
    // ... 더 많은 연산
  }
}
```

### Step 3: TypeInference 구현

```typescript
// type-inference.ts
export class TypeInference {
  private constraints: Constraint[] = []
  private solutions: Map<string, Type> = new Map()

  infer(expr: Expr): Type {
    // 표현식으로부터 타입 추론
    if (expr.kind === "number") {
      return { kind: "primitive", type: "num" }
    }
    if (expr.kind === "variable") {
      // 변수에 대한 제약에서 타입 추론
      return this.solveFor(expr.name)
    }
  }

  addConstraint(variable: string, expectedType: Type) {
    this.constraints.push({
      variable,
      expectedType,
      actualType: null
    })
  }

  solve(): Map<string, Type> {
    // 제약 조건들을 통합하여 각 변수의 타입 결정
    for (const constraint of this.constraints) {
      this.solutions.set(constraint.variable, constraint.expectedType)
    }
    return this.solutions
  }
}
```

### Step 4: TypeConstraints 구현

```typescript
// type-constraints.ts
export class TypeConstraints {
  private constraints: Constraint[] = []
  private conflicts: ConflictReport[] = []

  addConstraint(constraint: Constraint) {
    // 충돌 확인
    const existing = this.constraints.find(c => c.variable === constraint.variable)
    if (existing && !this.typesCompatible(existing.expectedType, constraint.expectedType)) {
      this.conflicts.push({
        variable: constraint.variable,
        type1: existing.expectedType,
        type2: constraint.expectedType,
        message: `Type mismatch for ${constraint.variable}`
      })
    }
    this.constraints.push(constraint)
  }

  detectConflicts(): ConflictReport[] {
    return this.conflicts
  }

  private typesCompatible(type1: Type, type2: Type): boolean {
    // 두 타입이 호환 가능한지 확인
    if (type1.kind === type2.kind) {
      if (type1.kind === "primitive") {
        return type1.type === type2.type
      }
      // ... 더 많은 타입 비교
    }
    return false
  }
}
```

