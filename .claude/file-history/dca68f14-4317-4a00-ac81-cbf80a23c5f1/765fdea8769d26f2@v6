// TEST 1: Valid Goal → Planning Success
// ─────────────────────────────────────────────────────────────

fn test_01_valid_goal_planning() {
  println("")
  println("🧪 TEST 1: Valid Goal → Planning Admission")

  let desc = "Process user request"
  let criteria = "Request completed successfully"
  let can_plan = can_enter_planning(desc, criteria, 3, 15, "json", 5, 30, "json")

  assert_true(can_plan, "Valid goal enters Planning")

  println("✅ TEST 1 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 2: Constraint Violation → Planning Blocked
// ─────────────────────────────────────────────────────────────

fn test_02_constraint_violation() {
  println("")
  println("🧪 TEST 2: Constraint Violation → Planning Blocked")

  let desc = "Quick task"
  let criteria = "Done fast"

  // Violation 1: Too many steps
  let can_plan1 = can_enter_planning(desc, criteria, 5, 8, "json", 3, 10, "json")
  assert_false(can_plan1, "Exceeding MaxSteps blocks Planning")

  let error1 = get_planning_error(desc, criteria, 5, 8, "json", 3, 10, "json")
  assert_true(error1 != "", "Error message provided for MaxSteps violation")
  println("  Error: " + error1)

  // Violation 2: Exceeds time limit
  let can_plan2 = can_enter_planning(desc, criteria, 2, 15, "json", 5, 10, "json")
  assert_false(can_plan2, "Exceeding TimeLimit blocks Planning")

  let error2 = get_planning_error(desc, criteria, 2, 15, "json", 5, 10, "json")
  assert_true(error2 != "", "Error message provided for TimeLimit violation")
  println("  Error: " + error2)

  println("✅ TEST 2 PASSED")
}

// ─────────────────────────────────────────────────────────────
// TEST 3: Output Format Constraint Validation
// ─────────────────────────────────────────────────────────────

fn test_03_output_format() {
  println("")
  println("🧪 TEST 3: Output Format Constraint")

  let desc = "Generate JSON response"
  let criteria = "Valid JSON returned"

  // Matching format
  let valid_format = can_enter_planning(desc, criteria, 2, 10, "json", 5, 30, "json")
  assert_true(valid_format, "Matching output format allowed")

  // Mismatched format
  let invalid_format = can_enter_planning(desc, criteria, 2, 10, "xml", 5, 30, "json")
  assert_false(invalid_format, "Mismatched output format blocked")

  let error = get_planning_error(desc, criteria, 2, 10, "xml", 5, 30, "json")
  assert_true(error != "", "Error message for format mismatch")
  println("  Error: " + error)

  println("✅ TEST 3 PASSED")
}

