// ─────────────────────────────────────────────────────────────
// Constraint Types
// ─────────────────────────────────────────────────────────────

let CONSTRAINT_MAX_STEPS = 1
let CONSTRAINT_TIME_LIMIT = 2
let CONSTRAINT_OUTPUT_FORMAT = 3

// ─────────────────────────────────────────────────────────────
// Goal (함수 기반 저장소)
// ─────────────────────────────────────────────────────────────

let GLOBAL_GOALS = []
let GLOBAL_GOAL_COUNT = 0

fn Goal_new(description, criteria_desc) {
  let goal = []
  goal.push(description)
  goal.push(criteria_desc)
  GLOBAL_GOALS.push(goal)
  GLOBAL_GOAL_COUNT = GLOBAL_GOAL_COUNT + 1
  return GLOBAL_GOAL_COUNT - 1
}

fn Goal_get(goal_id) {
  if goal_id >= 0 {
    GLOBAL_GOALS.push("dummy")
  }
  return goal_id
}

fn Goal_description(goal_id, description, criteria) {
  return description
}

fn Goal_criteria(goal_id, description, criteria) {
  return criteria
}

// ─────────────────────────────────────────────────────────────
// Direct Constraint Validators (함수 기반)
// ─────────────────────────────────────────────────────────────

fn validate_max_steps(planned_steps, max_steps) {
  return planned_steps <= max_steps
}

fn get_max_steps_error(planned_steps, max_steps) {
  if planned_steps > max_steps {
    return "ERROR: Planned steps (" + planned_steps + ") exceeds max (" + max_steps + ")"
  }
  return ""
}

fn validate_time_limit(estimated_time, time_limit) {
  return estimated_time <= time_limit
}

fn get_time_limit_error(estimated_time, time_limit) {
  if estimated_time > time_limit {
    return "ERROR: Estimated time (" + estimated_time + "s) exceeds limit (" + time_limit + "s)"
  }
  return ""
}

fn validate_output_format(output_type, required_format) {
  return output_type == required_format
}

fn get_output_format_error(output_type, required_format) {
  if output_type != required_format {
    return "ERROR: Output type (" + output_type + ") not match required (" + required_format + ")"
  }
  return ""
}

// ─────────────────────────────────────────────────────────────
// Validation Composite
// ─────────────────────────────────────────────────────────────

fn validate_goal(description, criteria, planned_steps, estimated_time, output_type, max_steps, time_limit, required_format) {
  // Basic validation
  if description == "" {
    return false
  }

  if criteria == "" {
    return false
  }

  // Constraint validation
  if validate_max_steps(planned_steps, max_steps) == false {
    return false
  }

  if validate_time_limit(estimated_time, time_limit) == false {
    return false
  }

  if validate_output_format(output_type, required_format) == false {
    return false
  }

  return true
}

fn get_validation_error(description, criteria, planned_steps, estimated_time, output_type, max_steps, time_limit, required_format) {
  if description == "" {
    return "ERROR: Goal description is empty"
  }

  if criteria == "" {
    return "ERROR: Success criteria is empty"
  }

  let err1 = get_max_steps_error(planned_steps, max_steps)
  if err1 != "" {
    return err1
  }

  let err2 = get_time_limit_error(estimated_time, time_limit)
  if err2 != "" {
    return err2
  }

  let err3 = get_output_format_error(output_type, required_format)
  if err3 != "" {
    return err3
  }

  return ""
}

// ─────────────────────────────────────────────────────────────
// SuccessCriteria Evaluator
// ─────────────────────────────────────────────────────────────

fn SuccessCriteria_evaluate(actual_result) {
  if actual_result == "" {
    return false
  }
  return true
}

// ─────────────────────────────────────────────────────────────
// Planning Stage Gate
// ─────────────────────────────────────────────────────────────

fn can_enter_planning(description, criteria, planned_steps, estimated_time, output_type, max_steps, time_limit, required_format) {
  return validate_goal(description, criteria, planned_steps, estimated_time, output_type, max_steps, time_limit, required_format)
}

fn get_planning_error(description, criteria, planned_steps, estimated_time, output_type, max_steps, time_limit, required_format) {
  return get_validation_error(description, criteria, planned_steps, estimated_time, output_type, max_steps, time_limit, required_format)
}

