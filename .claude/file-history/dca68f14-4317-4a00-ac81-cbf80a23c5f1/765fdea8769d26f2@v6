// Test Utilities
// ─────────────────────────────────────────────────────────────

fn assert_true(actual, msg) {
  if actual {
    println("✓ " + msg)
    return true
  }
  println("✗ FAILED: " + msg)
  return false
}

fn assert_false(actual, msg) {
  if actual == false {
    println("✓ " + msg)
    return true
  }
  println("✗ FAILED: " + msg)
  return false
}

