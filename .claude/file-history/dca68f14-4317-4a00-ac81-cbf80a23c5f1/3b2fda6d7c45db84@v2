function test_nested_operations(): void {
  console.log("📌 Test: 복합 연산 호환성");

  const code = `
    fn multiply(x, y) {
      return x * y
    }

    a = 5
    b = 10
    c = multiply(a, b)
    if c > 40 {
      result = c - 10
    } else {
      result = c + 10
    }
    println(result)
  `;

  const tokens = lex(code);
  const ast = parse(tokens);
  const chunk = compile(ast);
  const vm = new VM(chunk);
  const { output } = vm.run();

  console.log(`   Output: ${output[0]}`);
  if (output[0].trim() === "40") {
    console.log("   ✅ 복합 연산 정상\n");
  } else {
    console.log("   ❌ 복합 연산 오류\n");
    process.exit(1);
  }
}

