// 호환성 검증: 기존 기능과의 호환성 확인

import { compile } from "./compiler";
import { VM } from "./vm";
import { lex } from "./lexer";
import { parse } from "./parser";

function test_function_call(): void {
  console.log("\n📌 Test: 함수 호출 호환성");

  const code = `
    fn add(a, b) {
      return a + b
    }

    result = add(10, 20)
    println(result)
  `;

  const tokens = lex(code);
  const ast = parse(tokens);
  const chunk = compile(ast);
  const vm = new VM(chunk);
  const { output } = vm.run();

  console.log(`   Output: ${output[0]}`);
  if (output[0].trim() === "30") {
    console.log("   ✅ 함수 호출 정상\n");
  } else {
    console.log("   ❌ 함수 호출 오류\n");
    process.exit(1);
  }
}

function test_if_statement(): void {
  console.log("📌 Test: If 조건문 호환성");

  const code = `
    x = 10
    if x > 5 {
      println("greater")
    } else {
      println("less")
    }
  `;

  const tokens = lex(code);
  const ast = parse(tokens);
  const chunk = compile(ast);
  const vm = new VM(chunk);
  const { output } = vm.run();

  console.log(`   Output: ${output[0]}`);
  if (output[0].trim() === "greater") {
    console.log("   ✅ If 조건문 정상\n");
  } else {
    console.log("   ❌ If 조건문 오류\n");
    process.exit(1);
  }
}

