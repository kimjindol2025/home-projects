#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_version_parsing() {
        let v = Version::parse("1.2.3").unwrap();
        assert_eq!(v.major, 1);
        assert_eq!(v.minor, 2);
        assert_eq!(v.patch, 3);
    }

    #[test]
    fn test_version_compatibility() {
        let v1 = Version::new(1, 5, 0);
        let v2 = Version::new(1, 0, 0);
        assert!(v1.is_compatible(&v2));
    }

    #[test]
    fn test_version_incompatibility() {
        let v1 = Version::new(2, 0, 0);
        let v2 = Version::new(1, 0, 0);
        assert!(!v1.is_compatible(&v2));
    }

    #[test]
    fn test_new_project() {
        let pm = PackageManager::new();
        let toml = pm.new_project("test_project");
        assert_eq!(toml.package.name, "test_project");
        assert_eq!(toml.package.version, "0.1.0");
    }

    #[test]
    fn test_add_dependency() {
        let mut pm = PackageManager::new();
        let mut toml = pm.new_project("test");
        assert!(pm.add_dependency(&mut toml, "gogs_http", "1.2.0").is_ok());
        assert_eq!(toml.dependencies.len(), 1);
    }

    #[test]
    fn test_search_packages() {
        let pm = PackageManager::new();
        let results = pm.search_packages("http");
        assert!(!results.is_empty());
    }

    #[test]
    fn test_registry_find_version() {
        let registry = PackageRegistry::new();
        let version = registry.find_compatible_version("gogs_http", "1.0.0");
        assert!(version.is_ok());
    }

    #[test]
    fn test_stdlib_modules() {
        let pm = PackageManager::new();
        let stdlib = pm.list_stdlib();
        assert_eq!(stdlib.len(), 7);
    }

    #[test]
    fn test_dependency_resolver() {
        let mut pm = PackageManager::new();
        let mut toml = pm.new_project("test");
        pm.add_dependency(&mut toml, "gogs_http", "*").ok();

        let resolver = DependencyResolver::new(pm.registry);
        let plan = resolver.resolve(&toml);
        assert!(plan.is_ok());
    }

    #[test]
    fn test_build_settings() {
        let settings = BuildSettings {
            opt_level: 3,
            debug: false,
            lto: true,
            codegen_units: 1,
        };
        assert_eq!(settings.opt_level, 3);
        assert!(!settings.debug);
    }

    #[test]
    fn test_package_metadata() {
        let meta = PackageMetadata {
            name: "test".to_string(),
            version: "0.1.0".to_string(),
            authors: vec!["Alice".to_string()],
            description: "Test package".to_string(),
            license: "MIT".to_string(),
            repository: Some("https://example.com".to_string()),
            homepage: None,
            edition: "2026".to_string(),
        };
        assert_eq!(meta.name, "test");
        assert_eq!(meta.license, "MIT");
    }

    #[test]
    fn test_dependency_struct() {
        let dep = Dependency {
            name: "gogs_http".to_string(),
            version: "1.0.0".to_string(),
            path: None,
            git: None,
            features: vec!["async".to_string()],
        };
        assert_eq!(dep.name, "gogs_http");
        assert_eq!(dep.features.len(), 1);
    }
}
