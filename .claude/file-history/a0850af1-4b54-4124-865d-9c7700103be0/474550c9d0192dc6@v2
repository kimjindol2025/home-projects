#[derive(Debug, Clone, PartialEq, Eq, Hash)]
pub enum StdlibModule {
    Core,           // 기본 타입 및 연산
    Io,             // 입출력
    Collections,    // 자료구조 (Vec, Map, Set)
    String,         // 문자열 처리
    Async,          // 비동기 프로그래밍
    System,         // 시스템 인터페이스
    Testing,        // 테스트 프레임워크
}

impl fmt::Display for StdlibModule {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        match self {
            StdlibModule::Core => write!(f, "core"),
            StdlibModule::Io => write!(f, "io"),
            StdlibModule::Collections => write!(f, "collections"),
            StdlibModule::String => write!(f, "string"),
            StdlibModule::Async => write!(f, "async"),
            StdlibModule::System => write!(f, "system"),
            StdlibModule::Testing => write!(f, "testing"),
        }
    }
}

// ============================================================================
// 버전 관리 (Semantic Versioning)
// ============================================================================

#[derive(Debug, Clone, PartialEq, Eq, PartialOrd, Ord)]
pub struct Version {
    pub major: u32,
    pub minor: u32,
    pub patch: u32,
}

impl Version {
    pub fn new(major: u32, minor: u32, patch: u32) -> Self {
        Version { major, minor, patch }
    }

    pub fn parse(s: &str) -> Result<Self, String> {
        let parts: Vec<&str> = s.split('.').collect();
        if parts.len() != 3 {
            return Err("버전 형식: MAJOR.MINOR.PATCH".to_string());
        }

        let major = parts[0].parse().map_err(|_| "MAJOR는 숫자여야 함")?;
        let minor = parts[1].parse().map_err(|_| "MINOR는 숫자여야 함")?;
        let patch = parts[2].parse().map_err(|_| "PATCH는 숫자여야 함")?;

        Ok(Version { major, minor, patch })
    }

    pub fn is_compatible(&self, required: &Version) -> bool {
        // required와 호환 가능한가?
        // 같은 MAJOR 버전이면 호환
        self.major == required.major && self >= required
    }
}

impl fmt::Display for Version {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        write!(f, "{}.{}.{}", self.major, self.minor, self.patch)
    }
}

// ============================================================================
// 의존성 해결
// ============================================================================

pub struct DependencyResolver {
    registry: PackageRegistry,
}

impl DependencyResolver {
    pub fn new(registry: PackageRegistry) -> Self {
        DependencyResolver { registry }
    }

    /// 의존성을 해결하고 다운로드 계획 수립
    pub fn resolve(&self, toml: &GogsToml) -> Result<ResolutionPlan, String> {
        let mut plan = ResolutionPlan::new();

        // 모든 의존성을 처리
        for (name, dep) in &toml.dependencies {
            self.resolve_dependency(name, dep, &mut plan)?;
        }

        Ok(plan)
    }

    fn resolve_dependency(
        &self,
        name: &str,
        dep: &Dependency,
        plan: &mut ResolutionPlan,
    ) -> Result<(), String> {
        // 로컬 경로 의존성
        if let Some(path) = &dep.path {
            plan.add_local(name.to_string(), path.clone());
            return Ok(());
        }

        // Git 의존성
        if let Some(git) = &dep.git {
            plan.add_git(name.to_string(), git.clone());
            return Ok(());
        }

        // 레지스트리 의존성 (SemVer 해결)
        let resolved_version = self.registry.find_compatible_version(name, &dep.version)?;
        plan.add_registry(name.to_string(), resolved_version);

        Ok(())
    }
}

#[derive(Debug, Clone)]
pub struct ResolutionPlan {
    local_deps: HashMap<String, String>,        // name → path
    git_deps: HashMap<String, String>,          // name → git url
    registry_deps: HashMap<String, Version>,    // name → version
}

impl ResolutionPlan {
    pub fn new() -> Self {
        ResolutionPlan {
            local_deps: HashMap::new(),
            git_deps: HashMap::new(),
            registry_deps: HashMap::new(),
        }
    }

    pub fn add_local(&mut self, name: String, path: String) {
        self.local_deps.insert(name, path);
    }

    pub fn add_git(&mut self, name: String, url: String) {
        self.git_deps.insert(name, url);
    }

    pub fn add_registry(&mut self, name: String, version: Version) {
        self.registry_deps.insert(name, version);
    }
}

// ============================================================================
// 패키지 레지스트리
// ============================================================================

pub struct PackageRegistry {
    packages: HashMap<String, RegistryPackage>,
}

#[derive(Debug, Clone)]
pub struct RegistryPackage {
    pub name: String,
    pub versions: Vec<Version>,
    pub description: String,
    pub authors: Vec<String>,
    pub downloads: u64,
    pub rating: f32,
}

impl PackageRegistry {
    pub fn new() -> Self {
        let mut registry = PackageRegistry {
            packages: HashMap::new(),
        };

        // 표준 라이브러리 추가
        registry.register_stdlib();

        // 인기 패키지 추가
        registry.register_popular_packages();

        registry
    }

    fn register_stdlib(&mut self) {
        let modules = vec![
            StdlibModule::Core,
            StdlibModule::Io,
            StdlibModule::Collections,
            StdlibModule::String,
            StdlibModule::Async,
            StdlibModule::System,
            StdlibModule::Testing,
        ];

        for module in modules {
            let name = format!("gogs_{}", module);
            self.packages.insert(
                name,
                RegistryPackage {
                    name: module.to_string(),
                    versions: vec![
                        Version::new(0, 1, 0),
                        Version::new(0, 5, 0),
                        Version::new(1, 0, 0),
                    ],
                    description: "표준 라이브러리".to_string(),
                    authors: vec!["Gogs Team".to_string()],
                    downloads: 100000,
                    rating: 4.9,
                },
            );
        }
    }

    fn register_popular_packages(&mut self) {
        let popular = vec![
            ("gogs_http", "HTTP 라이브러리"),
            ("gogs_json", "JSON 파서"),
            ("gogs_async", "비동기 런타임"),
            ("gogs_db", "데이터베이스 ORM"),
            ("gogs_web", "웹 프레임워크"),
        ];

        for (name, desc) in popular {
            self.packages.insert(
                name.to_string(),
                RegistryPackage {
                    name: name.to_string(),
                    versions: vec![Version::new(1, 0, 0), Version::new(1, 2, 0)],
                    description: desc.to_string(),
                    authors: vec!["Community".to_string()],
                    downloads: 50000,
                    rating: 4.5,
                },
            );
        }
    }

    pub fn find_compatible_version(&self, name: &str, requirement: &str) -> Result<Version, String> {
        let pkg = self
            .packages
            .get(name)
            .ok_or_else(|| format!("패키지 '{}' 을(를) 찾을 수 없음", name))?;

        // SemVer 규칙 적용
        if requirement == "*" {
            // 최신 버전 반환
            return Ok(pkg.versions.last().unwrap().clone());
        }

        let required = Version::parse(requirement)?;

        // 호환 가능한 버전 찾기
        for version in pkg.versions.iter().rev() {
            if version.is_compatible(&required) {
                return Ok(version.clone());
            }
        }

        Err(format!(
            "호환 가능한 버전을 찾을 수 없음: {} {}",
            name, requirement
        ))
    }

    pub fn search(&self, keyword: &str) -> Vec<&RegistryPackage> {
        self.packages
            .values()
            .filter(|pkg| pkg.name.contains(keyword) || pkg.description.contains(keyword))
            .collect()
    }

    pub fn list_all(&self) -> Vec<&RegistryPackage> {
        self.packages.values().collect()
    }
}

// ============================================================================
// 패키지 매니저 CLI
// ============================================================================

pub struct PackageManager {
    registry: PackageRegistry,
}

impl PackageManager {
    pub fn new() -> Self {
        PackageManager {
            registry: PackageRegistry::new(),
        }
    }

    pub fn new_project(&self, name: &str) -> GogsToml {
        GogsToml {
            package: PackageMetadata {
                name: name.to_string(),
                version: "0.1.0".to_string(),
                authors: vec!["Your Name".to_string()],
                description: "My Gogs project".to_string(),
                license: "MIT".to_string(),
                repository: None,
                homepage: None,
                edition: "2026".to_string(),
            },
            dependencies: HashMap::new(),
            dev_dependencies: HashMap::new(),
            build_settings: BuildSettings::default(),
        }
    }

    pub fn add_dependency(&mut self, toml: &mut GogsToml, name: &str, version: &str) -> Result<(), String> {
        // 레지스트리에서 확인
        self.registry.find_compatible_version(name, version)?;

        toml.dependencies.insert(
            name.to_string(),
            Dependency {
                name: name.to_string(),
                version: version.to_string(),
                path: None,
                git: None,
                features: Vec::new(),
            },
        );

        Ok(())
    }

    pub fn search_packages(&self, keyword: &str) -> Vec<PackageInfo> {
        self.registry
            .search(keyword)
            .iter()
            .map(|pkg| PackageInfo {
                name: pkg.name.clone(),
                latest_version: pkg.versions.last().unwrap().to_string(),
                description: pkg.description.clone(),
                downloads: pkg.downloads,
                rating: pkg.rating,
            })
            .collect()
    }

    pub fn list_stdlib(&self) -> Vec<String> {
        vec![
            "gogs_core".to_string(),
            "gogs_io".to_string(),
            "gogs_collections".to_string(),
            "gogs_string".to_string(),
            "gogs_async".to_string(),
            "gogs_system".to_string(),
            "gogs_testing".to_string(),
        ]
    }
}

#[derive(Debug, Clone)]
pub struct PackageInfo {
    pub name: String,
    pub latest_version: String,
    pub description: String,
    pub downloads: u64,
    pub rating: f32,
}

