def multi_consumer_worker():
    time.sleep(0.2)
    msg = broker.message_history[-1][1]

    t1 = threading.Thread(target=payment_service.process_payment, args=(msg,))
    t2 = threading.Thread(target=shipping_service.prepare_shipping, args=(msg,))
    t3 = threading.Thread(target=notification_service.send_notification, args=(msg,))

    for t in [t1, t2, t3]:
        t.daemon = True
        t.start()

    for t in [t1, t2, t3]:
        t.join()

