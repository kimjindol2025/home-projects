class EventLog:
    """이벤트 로그"""
    def __init__(self):
        self.events = []

    def log_event(self, event_type, entity_id, data):
        event = {
            "type": event_type,
            "entity_id": entity_id,
            "data": data,
            "timestamp": datetime.now().isoformat()
        }
        self.events.append(event)
        print(f"  📝 [{event_type}] {entity_id}: {data}")

    def replay(self, entity_id):
        """특정 엔티티의 모든 이벤트 재생"""
        events = [e for e in self.events if e["entity_id"] == entity_id]
        print(f"  🔄 {entity_id}의 변화 과정:")
        for e in events:
            print(f"     → {e['type']}")

