class SagaOrchestrator:
    """Saga 패턴: 분산 트랜잭션 관리"""
    def __init__(self, broker):
        self.broker = broker
        self.saga_state = "PENDING"

    def execute_order_saga(self, order_id):
        print(f"  🔄 [Saga] 주문 {order_id} 처리 시작")

        steps = [
            ("결제 처리", 0.2),
            ("배송 준비", 0.2),
            ("알림 발송", 0.1),
        ]

        for step_name, duration in steps:
            print(f"     📍 {step_name}...")
            time.sleep(duration)
            print(f"     ✅ {step_name} 완료")

        print(f"  🎉 [Saga] 전체 트랜잭션 완료!")

saga = SagaOrchestrator(broker)
saga.execute_order_saga("ORDER-0001")

print()

