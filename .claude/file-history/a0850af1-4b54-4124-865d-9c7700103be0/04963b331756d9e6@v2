class OrderService:
    """주문 서비스 (Producer - 메시지 생산)"""
    def __init__(self, broker):
        self.broker = broker
        self.order_count = 0

    def create_order(self, customer_id, product):
        self.order_count += 1
        order_id = f"ORDER-{self.order_count:04d}"

        msg = Message(
            message_id=order_id,
            sender="OrderService",
            content=f"고객 {customer_id}: {product} 주문",
            timestamp=datetime.now().isoformat()
        )

        self.broker.publish("orders", msg)
        return order_id

class PaymentService:
    """결제 서비스 (Consumer - 메시지 소비)"""
    def __init__(self, broker):
        self.broker = broker

    def process_payment(self, order_msg):
        print(f"  💳 [PaymentService] {order_msg.content} 결제 처리 중...")
        time.sleep(0.5)
        print(f"  ✅ [PaymentService] 결제 완료!")

