class ProductionMicroserviceSystem:
    """프로덕션급 마이크로서비스 시스템"""
    def __init__(self):
        self.broker = RobustMessageBroker()
        self.order_service = OrderService(self.broker)
        self.services = {
            "payment": PaymentService(self.broker),
            "shipping": ShippingService(self.broker),
            "notification": NotificationService(self.broker)
        }
        self.processed_orders = 0

    def process_orders(self, num_orders=5):
        """대량의 주문 처리"""
        print(f"  🚀 {num_orders}개 주문 처리 시작")

        for i in range(num_orders):
            # 주문 생성
            order_id = self.order_service.create_order(
                f"customer-{i+1}",
                f"Product {i+1}"
            )

            # 메시지 처리 (여러 서비스가 동시에)
            time.sleep(0.1)

            if i % 2 == 0:
                print(f"  ✅ 주문 {order_id} 처리 완료")
                self.processed_orders += 1

        print(f"  📊 총 {self.processed_orders}/{num_orders}개 주문 처리됨")

system = ProductionMicroserviceSystem()
system.process_orders(5)

