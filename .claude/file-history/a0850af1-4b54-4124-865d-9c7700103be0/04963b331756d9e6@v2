@dataclass
class Message:
    """메시지 형식"""
    message_id: str
    sender: str
    content: str
    timestamp: str

class MessageBroker:
    """중앙 메시지 브로커 (우체국 역할)"""
    def __init__(self):
        self.message_queue = queue.Queue()
        self.message_history = []
        self.subscribers = {}  # topic -> [callbacks]

    def publish(self, topic: str, message: Message):
        """메시지 발행"""
        print(f"  📬 [Broker] {topic} 주제로 메시지 접수")
        print(f"     발신자: {message.sender}")
        print(f"     내용: {message.content}")

        self.message_queue.put((topic, message))
        self.message_history.append((topic, message))

    def subscribe(self, topic: str):
        """메시지 구독 (대기)"""
        while True:
            if not self.message_queue.empty():
                topic_name, msg = self.message_queue.get()
                if topic_name == topic:
                    return msg
            time.sleep(0.1)

    def get_history(self, topic: str = None):
        """메시지 히스토리 조회"""
        if topic:
            return [m for t, m in self.message_history if t == topic]
        return self.message_history

