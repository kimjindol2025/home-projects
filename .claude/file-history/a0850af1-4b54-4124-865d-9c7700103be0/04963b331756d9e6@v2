class RobustMessageBroker:
    """신뢰할 수 있는 메시지 브로커"""
    def __init__(self):
        self.queues = {}  # topic -> queue
        self.dead_letter_queue = []  # 처리 실패한 메시지
        self.message_counter = 0

    def publish(self, topic: str, message: Message, retry_count: int = 3):
        """메시지 발행 (재시도 로직)"""
        if topic not in self.queues:
            self.queues[topic] = queue.Queue()

        self.queues[topic].put((self.message_counter, message))
        self.message_counter += 1

        print(f"  📬 [{topic}] 메시지 #{self.message_counter-1} 발행")

    def consume(self, topic: str, max_retries: int = 3):
        """메시지 소비 (에러 처리)"""
        if topic not in self.queues or self.queues[topic].empty():
            return None

        seq, message = self.queues[topic].get()
        return (seq, message)

    def handle_error(self, message: Message, error: str):
        """에러 처리 (Dead Letter Queue)"""
        print(f"  ⚠️ 에러: {error}")
        self.dead_letter_queue.append((message, error, datetime.now().isoformat()))
        print(f"  📮 [DLQ] 실패 메시지 저장 (나중에 재처리 가능)")

    def get_dead_letters(self):
        """실패한 메시지 조회"""
        return self.dead_letter_queue

