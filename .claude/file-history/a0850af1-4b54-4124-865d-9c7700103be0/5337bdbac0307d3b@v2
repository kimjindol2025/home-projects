// ============ Statement ============

#[derive(Debug, Clone, PartialEq)]
pub enum Statement {
    Let { name: String, value: Expression },
    Expression(Expression),
    Return(Expression),
}

// ============ FunctionCallable ============

#[derive(Clone)]
pub struct GogsFunction {
    pub parameters: Vec<String>,
    pub body: Vec<Statement>,
    pub env: FunctionEnvironment,
}

impl fmt::Debug for GogsFunction {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        f.debug_struct("GogsFunction")
            .field("parameters", &self.parameters)
            .field("body_len", &self.body.len())
            .finish()
    }
}

// ============ Extended Object (v14.5: Function 추가) ============

#[derive(Clone, Debug)]
pub enum FunctionObject {
    Integer(i32),
    Float(f64),
    Boolean(bool),
    Null,
    Function(GogsFunction),
    Error(String),
}

impl FunctionObject {
    pub fn is_error(&self) -> bool {
        matches!(self, FunctionObject::Error(_))
    }

    pub fn to_string(&self) -> String {
        match self {
            FunctionObject::Integer(i) => i.to_string(),
            FunctionObject::Float(f) => f.to_string(),
            FunctionObject::Boolean(b) => b.to_string(),
            FunctionObject::Null => "null".to_string(),
            FunctionObject::Function(func) => {
                format!("fn({}) {{ ... }}", func.parameters.join(", "))
            }
            FunctionObject::Error(e) => format!("Error: {}", e),
        }
    }
}

// ============ Environment (스코프 체인) ============

#[derive(Clone)]
pub struct FunctionEnvironment {
    store: HashMap<String, FunctionObject>,
    outer: Option<Box<FunctionEnvironment>>,
}

impl FunctionEnvironment {
    pub fn new() -> Self {
        FunctionEnvironment {
            store: HashMap::new(),
            outer: None,
        }
    }

    pub fn extend(outer: FunctionEnvironment) -> Self {
        FunctionEnvironment {
            store: HashMap::new(),
            outer: Some(Box::new(outer)),
        }
    }

    pub fn set(&mut self, name: String, value: FunctionObject) {
        self.store.insert(name, value);
    }

    pub fn get(&self, name: &str) -> Option<FunctionObject> {
        match self.store.get(name) {
            Some(val) => Some(val.clone()),
            None => self.outer.as_ref().and_then(|outer| outer.get(name)),
        }
    }

    pub fn contains(&self, name: &str) -> bool {
        if self.store.contains_key(name) {
            true
        } else {
            self.outer.as_ref().map_or(false, |outer| outer.contains(name))
        }
    }
}

impl fmt::Debug for FunctionEnvironment {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        f.debug_struct("FunctionEnvironment")
            .field("store_size", &self.store.len())
            .field("has_outer", &self.outer.is_some())
            .finish()
    }
}

// ============ Evaluator ============

pub struct FunctionEvaluator;

impl FunctionEvaluator {
    pub fn eval_statements(
        &self,
        statements: &[Statement],
        env: &mut FunctionEnvironment,
    ) -> Result<FunctionObject, String> {
        let mut result = FunctionObject::Null;

        for stmt in statements {
            result = self.eval_statement(stmt, env)?;

            if result.is_error() {
                return Ok(result);
            }

            if matches!(stmt, Statement::Return(_)) {
                return Ok(result);
            }
        }

        Ok(result)
    }

    fn eval_statement(
        &self,
        stmt: &Statement,
        env: &mut FunctionEnvironment,
    ) -> Result<FunctionObject, String> {
        match stmt {
            Statement::Let { name, value } => {
                let val = self.eval_expression_simple(value, env)?;
                env.set(name.clone(), val.clone());
                Ok(val)
            }
            Statement::Expression(expr) => self.eval_expression_simple(expr, env),
            Statement::Return(expr) => self.eval_expression_simple(expr, env),
        }
    }

    fn eval_expression_simple(
        &self,
        expr: &Expression,
        env: &FunctionEnvironment,
    ) -> Result<FunctionObject, String> {
        match expr {
            Expression::Literal(val) => Ok(FunctionObject::Integer(*val)),
            Expression::FloatLiteral(f) => Ok(FunctionObject::Float(*f)),
            Expression::Prefix { operator, operand } => {
                let val = self.eval_expression_simple(operand, env)?;
                self.eval_prefix(operator, val)
            }
            Expression::Infix { left, operator, right } => {
                let left_val = self.eval_expression_simple(left, env)?;
                let right_val = self.eval_expression_simple(right, env)?;
                self.eval_infix(left_val, operator, right_val)
            }
            Expression::Grouped(expr) => self.eval_expression_simple(expr, env),
        }
    }

    fn eval_prefix(&self, operator: &PrefixOp, operand: FunctionObject) -> Result<FunctionObject, String> {
        match operator {
            PrefixOp::Bang => Ok(FunctionObject::Boolean(!self.is_truthy(&operand))),
            PrefixOp::Minus => match operand {
                FunctionObject::Integer(i) => Ok(FunctionObject::Integer(-i)),
                FunctionObject::Float(f) => Ok(FunctionObject::Float(-f)),
                _ => Err(format!("invalid operand for -: {}", operand.to_string())),
            },
        }
    }

    fn eval_infix(
        &self,
        left: FunctionObject,
        operator: &InfixOp,
        right: FunctionObject,
    ) -> Result<FunctionObject, String> {
        match (left, right) {
            (FunctionObject::Integer(l), FunctionObject::Integer(r)) => {
                match operator {
                    InfixOp::Plus => Ok(FunctionObject::Integer(l + r)),
                    InfixOp::Minus => Ok(FunctionObject::Integer(l - r)),
                    InfixOp::Multiply => Ok(FunctionObject::Integer(l * r)),
                    InfixOp::Divide => {
                        if r == 0 {
                            Err("division by zero".to_string())
                        } else {
                            Ok(FunctionObject::Integer(l / r))
                        }
                    }
                    InfixOp::Equal => Ok(FunctionObject::Boolean(l == r)),
                    InfixOp::NotEqual => Ok(FunctionObject::Boolean(l != r)),
                    InfixOp::Less => Ok(FunctionObject::Boolean(l < r)),
                    InfixOp::Greater => Ok(FunctionObject::Boolean(l > r)),
                    _ => Err(format!("unsupported operator: {:?}", operator)),
                }
            }
            (FunctionObject::Float(l), FunctionObject::Float(r)) => {
                match operator {
                    InfixOp::Plus => Ok(FunctionObject::Float(l + r)),
                    InfixOp::Minus => Ok(FunctionObject::Float(l - r)),
                    InfixOp::Multiply => Ok(FunctionObject::Float(l * r)),
                    InfixOp::Divide => {
                        if r == 0.0 {
                            Err("division by zero".to_string())
                        } else {
                            Ok(FunctionObject::Float(l / r))
                        }
                    }
                    InfixOp::Equal => Ok(FunctionObject::Boolean((l - r).abs() < 1e-9)),
                    InfixOp::NotEqual => Ok(FunctionObject::Boolean((l - r).abs() >= 1e-9)),
                    InfixOp::Less => Ok(FunctionObject::Boolean(l < r)),
                    InfixOp::Greater => Ok(FunctionObject::Boolean(l > r)),
                    _ => Err(format!("unsupported operator: {:?}", operator)),
                }
            }
            (FunctionObject::Boolean(l), FunctionObject::Boolean(r)) => {
                match operator {
                    InfixOp::Equal => Ok(FunctionObject::Boolean(l == r)),
                    InfixOp::NotEqual => Ok(FunctionObject::Boolean(l != r)),
                    _ => Err(format!("invalid operator for boolean: {:?}", operator)),
                }
            }
            _ => Err("type mismatch".to_string()),
        }
    }

    fn is_truthy(&self, obj: &FunctionObject) -> bool {
        match obj {
            FunctionObject::Null => false,
            FunctionObject::Boolean(b) => *b,
            _ => true,
        }
    }

    fn apply_function(
        &self,
        func: GogsFunction,
        args: Vec<FunctionObject>,
    ) -> Result<FunctionObject, String> {
        if func.parameters.len() != args.len() {
            return Err(format!(
                "wrong number of arguments: expected {}, got {}",
                func.parameters.len(),
                args.len()
            ));
        }

        let mut local_env = FunctionEnvironment::extend(func.env.clone());

        for (param, arg) in func.parameters.iter().zip(args.iter()) {
            local_env.set(param.clone(), arg.clone());
        }

        self.eval_statements(&func.body, &mut local_env)
    }
}

