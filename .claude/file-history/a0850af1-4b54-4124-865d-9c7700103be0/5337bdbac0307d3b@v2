// ============ Tests ============

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_function_environment_basic() {
        let mut env = FunctionEnvironment::new();
        env.set("x".to_string(), FunctionObject::Integer(10));

        match env.get("x") {
            Some(FunctionObject::Integer(10)) => (),
            _ => panic!("expected Integer(10)"),
        }
    }

    #[test]
    fn test_function_environment_scope_chain() {
        let mut outer = FunctionEnvironment::new();
        outer.set("x".to_string(), FunctionObject::Integer(10));

        let mut inner = FunctionEnvironment::extend(outer);
        inner.set("y".to_string(), FunctionObject::Integer(20));

        match inner.get("x") {
            Some(FunctionObject::Integer(10)) => (),
            _ => panic!("expected x=10 from outer scope"),
        }

        match inner.get("y") {
            Some(FunctionObject::Integer(20)) => (),
            _ => panic!("expected y=20 from inner scope"),
        }
    }

    #[test]
    fn test_function_object_to_string() {
        let func = FunctionObject::Integer(42);
        assert_eq!(func.to_string(), "42");

        let func = FunctionObject::Float(3.14);
        assert_eq!(func.to_string(), "3.14");

        let func = FunctionObject::Boolean(true);
        assert_eq!(func.to_string(), "true");

        let func = FunctionObject::Null;
        assert_eq!(func.to_string(), "null");
    }

    #[test]
    fn test_gogs_function_creation() {
        let func = GogsFunction {
            parameters: vec!["x".to_string(), "y".to_string()],
            body: vec![],
            env: FunctionEnvironment::new(),
        };

        assert_eq!(func.parameters.len(), 2);
        assert_eq!(func.parameters[0], "x");
        assert_eq!(func.parameters[1], "y");
    }

    #[test]
    fn test_function_object_error() {
        let obj = FunctionObject::Error("test error".to_string());
        assert!(obj.is_error());

        let obj = FunctionObject::Integer(42);
        assert!(!obj.is_error());
    }

    #[test]
    fn test_integer_arithmetic() {
        let evaluator = FunctionEvaluator;
        let left = FunctionObject::Integer(5);
        let right = FunctionObject::Integer(3);

        let result = evaluator.eval_infix(left, &InfixOp::Plus, right).unwrap();
        match result {
            FunctionObject::Integer(8) => (),
            _ => panic!("expected 8"),
        }
    }

    #[test]
    fn test_prefix_negation() {
        let evaluator = FunctionEvaluator;
        let operand = FunctionObject::Integer(5);

        let result = evaluator.eval_prefix(&PrefixOp::Minus, operand).unwrap();
        match result {
            FunctionObject::Integer(-5) => (),
            _ => panic!("expected -5"),
        }
    }

    #[test]
    fn test_environment_contains() {
        let mut env = FunctionEnvironment::new();
        env.set("x".to_string(), FunctionObject::Integer(10));

        assert!(env.contains("x"));
        assert!(!env.contains("y"));
    }

    #[test]
    fn test_nested_scope_shadowing() {
        let mut outer = FunctionEnvironment::new();
        outer.set("x".to_string(), FunctionObject::Integer(10));

        let mut inner = FunctionEnvironment::extend(outer);
        inner.set("x".to_string(), FunctionObject::Integer(20));

        match inner.get("x") {
            Some(FunctionObject::Integer(20)) => (),
            _ => panic!("expected x=20 from inner scope (shadowing)"),
        }
    }

    #[test]
    fn test_comparison_operators() {
        let evaluator = FunctionEvaluator;
        let left = FunctionObject::Integer(5);
        let right = FunctionObject::Integer(3);

        let result = evaluator.eval_infix(left.clone(), &InfixOp::Greater, right.clone()).unwrap();
        match result {
            FunctionObject::Boolean(true) => (),
            _ => panic!("expected true for 5 > 3"),
        }
    }

    #[test]
    fn test_is_truthy() {
        let evaluator = FunctionEvaluator;

        assert!(!evaluator.is_truthy(&FunctionObject::Null));
        assert!(!evaluator.is_truthy(&FunctionObject::Boolean(false)));
        assert!(evaluator.is_truthy(&FunctionObject::Boolean(true)));
        assert!(evaluator.is_truthy(&FunctionObject::Integer(0)));
        assert!(evaluator.is_truthy(&FunctionObject::Integer(1)));
    }
}
