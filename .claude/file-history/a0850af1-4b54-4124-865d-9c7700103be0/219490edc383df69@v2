## 🔒 실전 안전 잠금 프로토콜

```rust
// 패턴 A: 순서를 명시적으로 보장
fn safe_multi_lock(res_a: &SecureResource, res_b: &SecureResource) {
    // 항상 ID가 낮은 것부터
    if res_a.id < res_b.id {
        let _lock_a = res_a.data.lock().unwrap();
        let _lock_b = res_b.data.lock().unwrap();
    } else {
        let _lock_b = res_b.data.lock().unwrap();
        let _lock_a = res_a.data.lock().unwrap();
    }
}

// 패턴 B: 필요한 만큼만 잠금
fn minimal_lock_scope() {
    let result = {
        let _guard = resource.data.lock().unwrap();
        // 1-2줄 작업만
        compute_something()
    }; // ← 여기서 자동 해제

    // 나머지는 락 없이
    process_result(result);
}

// 패턴 C: 재시도 로직 (데드락 감지 시)
fn safe_with_retry() {
    for attempt in 0..3 {
        match try_lock_with_timeout() {
            Ok(data) => return process(data),
            Err(_) if attempt < 2 => {
                eprintln!("Retry attempt {}", attempt);
                std::thread::sleep(Duration::from_millis(100));
            }
            Err(e) => panic!("Failed after retries: {:?}", e),
        }
    }
}
```

