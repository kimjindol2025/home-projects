fn demo_literal() {
    println!("[데모 1] 단순 정수 평가");
    println!("─────────────────────");

    let code = "42;";
    println!("Input: {}", code);

    let lexer = crate::v14_0_lexer::Lexer::new(code);
    let mut parser = crate::v14_2_pratt_parsing::Parser::new(lexer);

    match parser.parse_program() {
        Ok(exprs) => {
            let mut env = Environment::new();
            let evaluator = Evaluator;

            for expr in &exprs {
                let result = evaluator.eval(expr, &mut env);
                println!("AST: {}", expr);
                println!("결과: {}", result);
            }
        }
        Err(e) => println!("Error: {}", e),
    }
    println!();
}

