#[cfg(test)]
mod tests {
    use super::*;
    use crate::v14_0_lexer::Lexer;
    use crate::v14_2_pratt_parsing::Parser;

    fn eval_code(code: &str) -> Object {
        let lexer = Lexer::new(code);
        let mut parser = Parser::new(lexer);
        let exprs = parser.parse_program().unwrap();
        let mut env = Environment::new();
        let evaluator = Evaluator;
        evaluator.eval(&exprs[0], &mut env)
    }

    #[test]
    fn test_eval_integer_literal() {
        assert_eq!(eval_code("42;"), Object::Integer(42));
    }

    #[test]
    fn test_eval_addition() {
        assert_eq!(eval_code("2 + 3;"), Object::Integer(5));
    }

    #[test]
    fn test_eval_subtraction() {
        assert_eq!(eval_code("10 - 3;"), Object::Integer(7));
    }

    #[test]
    fn test_eval_multiplication() {
        assert_eq!(eval_code("4 * 3;"), Object::Integer(12));
    }

    #[test]
    fn test_eval_division() {
        assert_eq!(eval_code("10 / 2;"), Object::Integer(5));
    }

    #[test]
    fn test_eval_precedence() {
        assert_eq!(eval_code("2 + 3 * 4;"), Object::Integer(14));
    }

    #[test]
    fn test_eval_grouped_expression() {
        assert_eq!(eval_code("(2 + 3) * 4;"), Object::Integer(20));
    }

    #[test]
    fn test_eval_prefix_minus() {
        assert_eq!(eval_code("-5;"), Object::Integer(-5));
    }

    #[test]
    fn test_eval_comparison_greater() {
        assert_eq!(eval_code("5 > 3;"), Object::Boolean(true));
    }

    #[test]
    fn test_eval_comparison_less() {
        assert_eq!(eval_code("3 < 5;"), Object::Boolean(true));
    }

    #[test]
    fn test_eval_comparison_equal() {
        assert_eq!(eval_code("5 == 5;"), Object::Boolean(true));
    }

    #[test]
    fn test_eval_division_by_zero() {
        match eval_code("10 / 0;") {
            Object::Error(msg) => assert!(msg.contains("division by zero")),
            _ => panic!("Expected error"),
        }
    }

    #[test]
    fn test_eval_complex_expression() {
        assert_eq!(eval_code("1 + 2 * 3 + 4 * 5;"), Object::Integer(27));
    }
}
