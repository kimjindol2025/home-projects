// ============================================================================
// [1] 조건문 (Conditional Statements)
// ============================================================================
//
// if/else는 CPU의 다음 실행 주소를 결정합니다.
// 이것이 프로그램의 '의지'입니다.
//
fn conditional_examples() {
    println!("[1] 조건문 (if / else)");
    println!("────────────────────────────────────────────────────────────");

    // 기본 if/else
    {
        let x = 15;

        if x > 0 && x < 20 {
            println!("✓ if: x(={})는 0과 20 사이입니다.", x);
        } else if x >= 20 {
            println!("✓ else if: x(={})는 20 이상입니다.", x);
        } else {
            println!("✓ else: x(={})는 0 이하입니다.", x);
        }
    }

    // 나이 판정
    {
        let age = 25;

        if age >= 18 {
            println!("✓ 나이({}): 성인입니다.", age);
        } else {
            println!("✓ 나이({}): 미성년자입니다.", age);
        }
    }

    // 수온 판정
    {
        let temperature = 32;

        if temperature < 0 {
            println!("✓ 온도({}°C): 빙점 아래입니다.", temperature);
        } else if temperature == 0 {
            println!("✓ 온도({}°C): 정확히 빙점입니다.", temperature);
        } else if temperature < 100 {
            println!("✓ 온도({}°C): 액체 상태입니다.", temperature);
        } else {
            println!("✓ 온도({}°C): 끓는점 이상입니다.", temperature);
        }
    }

    println!();
}

// ============================================================================
// [2] 논리 연산자 (Logical Operators)
// ============================================================================
//
// AND (&&): 두 조건이 모두 true
// OR  (||): 두 조건 중 하나라도 true
// NOT (!):  조건을 반대로
//
fn logical_operators() {
    println!("[2] 논리 연산자");
    println!("────────────────────────────────────────────────────────────");

    // AND: 두 조건 모두 만족
    {
        let x = 5;
        let y = 10;

        if x > 0 && y > 0 {
            println!("✓ AND: x(={})와 y({})는 모두 양수입니다.", x, y);
        }

        if x > 0 && x < 10 && y < 15 {
            println!("✓ AND (복합): x={}, y={}는 범위 내입니다.", x, y);
        }
    }

    // OR: 하나라도 만족
    {
        let is_weekend = false;
        let is_holiday = true;

        if is_weekend || is_holiday {
            println!("✓ OR: 휴일 또는 주말입니다.");
        }
    }

    // NOT: 조건 반대
    {
        let is_raining = false;

        if !is_raining {
            println!("✓ NOT: 비가 오지 않습니다.");
        }
    }

    // 복합 논리
    {
        let age = 25;
        let has_license = true;

        if age >= 18 && has_license {
            println!("✓ 복합: 나이(={})가 충분하고 면허증이 있습니다.", age);
        }
    }

    println!();
}

// ============================================================================
// [3] 패턴 매칭 (Pattern Matching)
// ============================================================================
//
// match는 값을 여러 패턴과 비교하고 일치하는 코드를 실행합니다.
// 모든 경우를 처리해야 하므로 '_'는 필수입니다.
//
fn match_examples() {
    println!("[3] 패턴 매칭 (match)");
    println!("────────────────────────────────────────────────────────────");

    // 기본 match
    {
        let day = 3;

        match day {
            1 => println!("✓ 월요일"),
            2 => println!("✓ 화요일"),
            3 => println!("✓ 수요일"),
            4 => println!("✓ 목요일"),
            5 => println!("✓ 금요일"),
            6 => println!("✓ 토요일"),
            7 => println!("✓ 일요일"),
            _ => println!("✓ 알 수 없는 요일"),
        }
    }

    // 범위 매칭
    {
        let score = 85;

        match score {
            90..=100 => println!("✓ 점수({}): A학점", score),
            80..=89 => println!("✓ 점수({}): B학점", score),
            70..=79 => println!("✓ 점수({}): C학점", score),
            _ => println!("✓ 점수({}): F학점", score),
        }
    }

    // 조건 매칭
    {
        let x = 25;

        match x {
            n if n < 0 => println!("✓ 조건: {}는 음수", n),
            n if n == 0 => println!("✓ 조건: {}는 0", n),
            n if n < 10 => println!("✓ 조건: {}는 10 미만의 양수", n),
            _ => println!("✓ 조건: {}는 10 이상의 수", x),
        }
    }

    println!();
}

// ============================================================================
// [4] Loop: 무한 루프 (명시적 탈출 필수)
// ============================================================================
//
// loop는 무한히 반복됩니다. break로만 탈출할 수 있습니다.
// 반드시 탈출 조건을 명확히 해야 합니다.
//
fn loop_examples() {
    println!("[4] Loop: 무한 루프");
    println!("────────────────────────────────────────────────────────────");

    // 기본 루프
    {
        let mut count = 1;

        loop {
            println!("✓ Loop count: {}", count);

            count += 1;

            // 탈출 조건: 명확해야 함!
            if count > 3 {
                println!("  → 루프 탈출");
                break;
            }
        }
    }

    // 루프에서 값 반환
    {
        let mut counter = 0;
        let result = loop {
            counter += 1;

            if counter == 5 {
                break counter * 10;  // 50을 반환
            }
        };

        println!("✓ Loop 반환값: {}", result);
    }

    println!();
}

// ============================================================================
// [5] While: 조건 기반 루프
// ============================================================================
//
// while은 조건이 true인 동안 반복합니다.
// 조건이 false가 되면 자동 탈출합니다.
//
fn while_examples() {
    println!("[5] While: 조건 루프");
    println!("────────────────────────────────────────────────────────────");

    // 기본 while
    {
        let mut n = 5;

        print!("✓ While countdown: ");
        while n > 0 {
            print!("{} ", n);
            n -= 1;
        }
        println!("발사!");
    }

    // 합계 계산
    {
        let mut sum = 0;
        let mut i = 1;

        while i <= 5 {
            sum += i;
            i += 1;
        }

        println!("✓ While 합계: 1+2+3+4+5 = {}", sum);
    }

    // 사용자 입력 시뮬레이션 (실제로는 입력 받음)
    {
        let mut attempts = 0;
        let max_attempts = 3;

        while attempts < max_attempts {
            attempts += 1;
            println!("✓ While 시도 {}/{}", attempts, max_attempts);
        }
        println!("  → 최대 시도 횟수 도달");
    }

    println!();
}

// ============================================================================
// [6] For: 범위 기반 루프 (가장 안전)
// ============================================================================
//
// for는 범위의 각 값에 대해 반복합니다.
// 범위가 유한하므로 무한 루프 걱정이 없습니다.
//
fn for_examples() {
    println!("[6] For: 범위 루프");
    println!("────────────────────────────────────────────────────────────");

    // 기본 범위 (1..5: 1~4)
    {
        print!("✓ For 1..5: ");
        for i in 1..5 {
            print!("{} ", i);
        }
        println!();
    }

    // 포함 범위 (1..=5: 1~5)
    {
        print!("✓ For 1..=5: ");
        for i in 1..=5 {
            print!("{} ", i);
        }
        println!();
    }

    // 구구단
    {
        println!("✓ For 구구단 (2단):");
        for i in 1..=9 {
            println!("  2 × {} = {}", i, 2 * i);
        }
    }

    println!();
}

// ============================================================================
// [7] 루프 제어: break와 continue
// ============================================================================
//
// break: 루프 즉시 탈출
// continue: 다음 반복으로 건너뜀
//
fn loop_control() {
    println!("[7] 루프 제어 (break / continue)");
    println!("────────────────────────────────────────────────────────────");

    // break: 찾으면 탈출
    {
        print!("✓ Break (3 찾기): ");
        for i in 1..=10 {
            if i == 3 {
                println!("찾음! {}", i);
                break;
            }
            print!("{} ", i);
        }
    }

    // continue: 짝수 건너뜀
    {
        print!("✓ Continue (홀수만): ");
        for i in 1..=5 {
            if i % 2 == 0 {
                continue;  // 짝수는 건너뜀
            }
            print!("{} ", i);
        }
        println!();
    }

    // 루프 라벨: 다층 루프 제어
    {
        println!("✓ 루프 라벨 (외부 루프 탈출):");
        let mut found = false;

        'outer: for i in 1..=3 {
            for j in 1..=3 {
                println!("  ({}, {})", i, j);
                if i == 2 && j == 2 {
                    println!("  → 타겟 발견! 외부 루프 탈출");
                    found = true;
                    break 'outer;
                }
            }
        }
    }

    println!();
}

// ============================================================================
// [8] 논리적 무결성 검증 (Logic Integrity Check)
// ============================================================================
//
// v3.0의 가장 무서운 적:
// 1. 무한 루프 (Infinite Loop)
// 2. 도달할 수 없는 코드 (Unreachable Code)
//
fn logic_integrity_check() {
    println!("[8] 논리적 무결성 검증");
    println!("────────────────────────────────────────────────────────────");

    // 검증 1: 모든 경로가 처리되는가? (match의 _)
    {
        let value = 42;

        match value {
            1 | 2 | 3 => println!("✓ 검증 1a: 1~3"),
            _ => println!("✓ 검증 1b: 모든 다른 경우가 처리됨"),
        }
    }

    // 검증 2: 루프가 반드시 끝나는가? (탈출 조건)
    {
        let mut counter = 0;
        let limit = 3;

        loop {
            counter += 1;

            if counter >= limit {
                println!("✓ 검증 2: 루프 조건이 명확하게 충족됨 (counter={}, limit={})", counter, limit);
                break;
            }
        }
    }

    // 검증 3: 모든 분기가 의도된가? (else 필수)
    {
        let score = 75;

        if score >= 90 {
            println!("✓ 검증 3a: A학점");
        } else if score >= 80 {
            println!("✓ 검증 3b: B학점");
        } else {
            println!("✓ 검증 3c: C학점 (모든 경우가 처리됨)");
        }
    }

    // 검증 4: 변수가 정확히 변하는가? (부작용 확인)
    {
        let mut x = 0;
        let target = 5;

        while x < target {
            x += 1;  // 반드시 증가!
        }

        println!("✓ 검증 4: x가 target에 도달함 (x={}, target={})", x, target);
    }

    println!();
}

