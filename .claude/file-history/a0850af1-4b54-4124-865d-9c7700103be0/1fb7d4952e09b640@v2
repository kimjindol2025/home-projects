"""
Python Elementary v1.3 - 리스트(List) — 데이터 바구니 만들기

탐구(초등학교): "여러 개의 데이터를 순서대로 모으기"

지금까지는 변수 하나에 값 하나만 담았습니다.
하지만 데이터가 많아지면 관리가 힘들어집니다.
그래서 파이썬은 여러 개의 데이터를 순서대로 담을 수 있는
'리스트(List)'라는 마법의 바구니를 제공합니다.

리스트의 특징:
1. 순서가 있어요: 데이터가 들어간 순서를 기억합니다.
2. 여러 종류를 담을 수 있어요: 숫자, 글자, 심지어 다른 리스트도 담을 수 있습니다.
3. 번호표(인덱스)가 있어요: 가장 중요한 규칙! 번호표는 0번부터 시작합니다.
"""

print("=" * 70)
print("# Python Elementary v1.3 - 리스트(List) — 데이터 바구니")
print("=" * 70)

# ============================================================================
# [1단계] 연구 장비 리스트 만들기 (리스트 선언)
# ============================================================================

print("\n[1단계] 리스트 만들기 - 실험실 장비")
print("-" * 70)

equipment = ["현미경", "비커", "시험관"]

print("리스트 선언: equipment = ['현미경', '비커', '시험관']")
print("전체 리스트:", equipment)

# ============================================================================
# [2단계] 인덱싱으로 데이터 꺼내기
# ============================================================================

print("\n[2단계] 인덱싱으로 데이터 꺼내기")
print("-" * 70)

print(f"첫 번째 장비 (0번): {equipment[0]}")
print(f"두 번째 장비 (1번): {equipment[1]}")
print(f"세 번째 장비 (2번): {equipment[2]}")

print("\n중요한 규칙:")
print("  ✓ 첫 번째는 1번이 아니라 0번입니다!")
print("  ✓ 컴퓨터는 '기준점으로부터 얼마나 떨어져 있는가'로 셉니다.")
print("  ✓ 이것이 러스트와 파이썬이 공유하는 컴퓨터 과학의 기초입니다.")

# ============================================================================
# [3단계] 뒤에서부터 세기 (음수 인덱싱)
# ============================================================================

print("\n[3단계] 파이썬의 신기한 기능 - 음수 인덱싱")
print("-" * 70)

print(f"마지막 장비 equipment[-1]: {equipment[-1]}")
print(f"끝에서 두 번째 equipment[-2]: {equipment[-2]}")
print(f"끝에서 세 번째 equipment[-3]: {equipment[-3]}")

print("\n신기한 규칙:")
print("  ✓ -1은 가장 마지막 데이터를 가져옵니다.")
print("  ✓ -2는 끝에서 두 번째입니다.")
print("  ✓ 이것도 나중에 고급 기능에서 유용합니다!")

# ============================================================================
# [4단계] 리스트의 길이 확인하기 (len 함수)
# ============================================================================

print("\n[4단계] 리스트의 길이 확인하기")
print("-" * 70)

print(f"현재 장비 개수: {len(equipment)}")
print(f"len(equipment) = {len(equipment)}")

print("\nlen() 함수:")
print("  ✓ 리스트에 몇 개의 데이터가 있는지 알려줍니다.")
print("  ✓ 나중에 고등학교 과정에서 배울 '순회'의 기초가 됩니다.")

# ============================================================================
# [5단계] 새 데이터 추가하기 (append 메서드)
# ============================================================================

print("\n[5단계] 새 데이터 추가하기")
print("-" * 70)

print("현재 리스트:", equipment)
equipment.append("온도계")
print("append('온도계') 후:", equipment)

equipment.append("저울")
print("append('저울') 후:", equipment)

print(f"이제 장비 개수: {len(equipment)}")

# ============================================================================
# [6단계] 값 수정하기 (인덱싱으로 변경)
# ============================================================================

print("\n[6단계] 기존 데이터 수정하기")
print("-" * 70)

print("수정 전:", equipment)
equipment[1] = "전자저울"  # 비커를 전자저울로 교체
print("equipment[1] = '전자저울' 후:", equipment)

equipment[0] = "전자현미경"
print("equipment[0] = '전자현미경' 후:", equipment)

# ============================================================================
# [7단계] 여러 종류의 데이터 담기
# ============================================================================

print("\n[7단계] 리스트는 여러 종류의 데이터를 담을 수 있어요")
print("-" * 70)

mixed_data = ["파이썬", 3, 1.4, True, ["중첩", "리스트"]]

print("혼합 리스트:", mixed_data)
print(f"첫 번째 (문자): {mixed_data[0]}")
print(f"두 번째 (숫자): {mixed_data[1]}")
print(f"세 번째 (실수): {mixed_data[2]}")
print(f"네 번째 (참/거짓): {mixed_data[3]}")
print(f"다섯 번째 (중첩 리스트): {mixed_data[4]}")

print("\n신기한 기능:")
print("  ✓ 리스트는 숫자, 글자, 참/거짓 모두 담을 수 있습니다!")
print("  ✓ 심지어 리스트 안에 리스트도 담을 수 있습니다!")

# ============================================================================
# [8단계] 리스트 조작 연습
# ============================================================================

print("\n[8단계] 리스트 조작 종합 연습")
print("-" * 70)

shopping_list = []
print("빈 리스트 생성:", shopping_list)

shopping_list.append("우유")
print("우유 추가:", shopping_list)

shopping_list.append("계란")
shopping_list.append("치즈")
print("계란, 치즈 추가:", shopping_list)

print(f"장바구니에 {len(shopping_list)}개의 물건이 있습니다.")

shopping_list[1] = "계란 (큰 것)"
print("계란 항목 수정:", shopping_list)

# ============================================================================
# [최종 증명]
# ============================================================================

print("\n" + "=" * 70)
print("# [최종 증명] 리스트의 마법")
print("=" * 70)

print("""
✓ [리스트 선언]
  equipment = [값1, 값2, 값3]
  대괄호로 여러 데이터를 순서대로 모읍니다.

✓ [인덱싱]
  equipment[0] = 첫 번째 데이터
  equipment[-1] = 마지막 데이터
  0번부터 시작하는 컴퓨터의 세기법입니다.

✓ [길이 확인]
  len(equipment) = 데이터 개수
  나중에 반복문에서 매우 유용합니다.

✓ [데이터 추가]
  equipment.append(새값)
  바구니 끝에 새 데이터를 추가합니다.

✓ [데이터 수정]
  equipment[번호] = 새값
  인덱싱으로 기존 데이터를 바꿉니다.

✓ [여러 종류 담기]
  리스트는 숫자, 글자, 다른 리스트 모두 담을 수 있습니다!

결론:
  리스트는 파이썬의 가장 기본적인 '데이터 구조'입니다.
  나중에 대학교 과정에서 배울 고급 개념의 기초입니다!

저장 필수 너는 기록이 증명이다 gogs
""")
