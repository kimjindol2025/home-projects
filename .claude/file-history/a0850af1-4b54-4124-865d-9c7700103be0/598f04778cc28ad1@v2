// [예제 4] String vs &str 비교
// ============================================================================
fn string_vs_str_comparison() {
    println!("\n[예제 4] String vs &str 비교");
    println!("═════════════════════════════════════════");

    println!("\n[메모리 위치]");
    let literal: &str = "hello";                    // 스택 + 바이너리
    let owned: String = String::from("hello");     // 스택 + 힙

    println!("&str 리터럴:");
    println!("  위치: 스택 (포인터) + 바이너리 (데이터)");
    println!("  소유권: 없음 (차용만)");
    println!("  크기: 16바이트 (스택의 ptr + len)");

    println!("String:");
    println!("  위치: 스택 (메타) + 힙 (데이터)");
    println!("  소유권: 있음 (소유)");
    println!("  크기: 24바이트 (스택의 ptr + len + cap)");

    println!("\n[함수 인자 패턴]");
    println!("❌ fn process(s: String) - String을 소비");
    println!("✅ fn process(s: &str) - &str을 빌려옴");

    println!("\n[저장 패턴]");
    struct Document {
        title: String,  // 소유 필요 (생명주기 관리)
    }

    let doc = Document {
        title: "My Document".to_string(),
    };
    println!("struct Document {{ title: String }}");
    println!("  title = \"{}\"", doc.title);

    println!("\n[변환]");
    let s1: &str = "hello";
    let s2: String = s1.to_string();      // &str → String
    let s3: &str = &s2;                    // String → &str
    println!("&str → String: to_string() 또는 String::from()");
    println!("String → &str: & 연산자");
}

// ============================================================================
// [예제 5] String의 메모리 레이아웃
// ============================================================================
fn string_memory_layout() {
    println!("\n[예제 5] String의 메모리 레이아웃");
    println!("═════════════════════════════════════════");

    println!("\n[초기 상태]");
    let mut s = String::new();
    println!("let mut s = String::new();");
    println!("  len()      = {}", s.len());
    println!("  capacity() = {}", s.capacity());

    println!("\n[처음 push]");
    s.push_str("Hello");
    println!("s.push_str(\"Hello\");");
    println!("  len()      = {} (사용)", s.len());
    println!("  capacity() = {} (할당)", s.capacity());

    println!("\n[여유 공간 내에서 추가]");
    s.push_str("!");
    println!("s.push_str(\"!\");");
    println!("  len()      = {}", s.len());
    println!("  capacity() = {} (여전히 할당됨)", s.capacity());

    println!("\n[재할당 발생]");
    s.push_str(" This is a longer string");
    println!("s.push_str(\" This is a longer string\");");
    println!("  len()      = {} (사용)", s.len());
    println!("  capacity() = {} (2배로 증가)", s.capacity());

    println!("\n[clear vs truncate]");
    let mut s2 = String::from("Hello");
    println!("s2 = \"{}\"", s2);
    println!("  len={}, capacity={}", s2.len(), s2.capacity());

    s2.clear();
    println!("s2.clear():");
    println!("  len={}, capacity={} (용량은 유지)", s2.len(), s2.capacity());

    println!("\n[스코프와 해제]");
    {
        let _temp = String::from("temporary");
        println!("_temp 생성");
    }
    println!("스코프 벗어남 → 자동 Drop (메모리 해제) ✓");
}

// ============================================================================
// [예제 6] 문자열 슬라이싱의 위험
// ============================================================================
fn string_slicing_safety() {
    println!("\n[예제 6] 문자열 슬라이싱의 안전성");
    println!("═════════════════════════════════════════");

    println!("\n[ASCII 슬라이싱]");
    let ascii = "hello";
    let slice1 = &ascii[0..1];  // "h"
    let slice2 = &ascii[1..2];  // "e"
    println!("\"hello\" → &[0..1] = \"{}\", &[1..2] = \"{}\"", slice1, slice2);

    println!("\n[멀티바이트 슬라이싱의 위험]");
    let korean = "한글";
    println!("\"한글\" 분석:");
    println!("  '한' = 3바이트 (UTF-8)");
    println!("  '글' = 3바이트 (UTF-8)");
    println!("  총 = 6바이트");

    let correct = &korean[0..3];  // "한" (정확한 경계)
    println!("&korean[0..3] = \"{}\" ✓", correct);

    // let wrong = &korean[0..1];  // ❌ 패닉! (바이트 경계 오류)

    println!("\n[안전한 문자 추출]");
    let first_char = korean.chars().next();
    println!("korean.chars().next() = {:?}", first_char);

    println!("\n[안전한 슬라이싱 함수]");
    fn first_n_chars(s: &str, n: usize) -> &str {
        s.char_indices()
            .nth(n)
            .map(|(i, _)| &s[..i])
            .unwrap_or(s)
    }

    let text = "Hello 한글";
    println!("text = \"{}\"", text);
    println!("first_n_chars(text, 3) = \"{}\"", first_n_chars(text, 3));
    println!("first_n_chars(text, 6) = \"{}\"", first_n_chars(text, 6));

    println!("\n[is_char_boundary()]");
    let s = "한글";
    println!("s = \"{}\" (6바이트)", s);
    println!("is_char_boundary(0) = {} ✓", s.is_char_boundary(0));
    println!("is_char_boundary(3) = {} ✓", s.is_char_boundary(3));
    println!("is_char_boundary(1) = {} ❌", s.is_char_boundary(1));
    println!("is_char_boundary(2) = {} ❌", s.is_char_boundary(2));
}

