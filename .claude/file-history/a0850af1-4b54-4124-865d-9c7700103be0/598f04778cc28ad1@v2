// [예제 7] String 성능 패턴
// ============================================================================
fn string_performance_patterns() {
    println!("\n[예제 7] String 성능 최적화 패턴");
    println!("═════════════════════════════════════════");

    println!("\n[패턴 1: 용량 예약]");
    let words = vec!["Rust", "is", "awesome"];
    let total_len: usize = words.iter().map(|w| w.len() + 1).sum();

    println!("❌ 효율적이지 않음:");
    let mut slow = String::new();
    for word in &words {
        slow.push_str(word);
        slow.push(' ');
    }
    println!("  for word {{ push_str + push }}");

    println!("✅ 효율적:");
    let mut fast = String::with_capacity(total_len);
    for word in &words {
        fast.push_str(word);
        fast.push(' ');
    }
    println!("  with_capacity({}) 후 push_str", total_len);
    println!("  결과: \"{}\"", fast.trim());

    println!("\n[패턴 2: concat vs join]");
    let parts = vec!["Hello", "World", "Rust"];

    println!("❌ 느림 (여러 번 할당):");
    let result1 = parts[0].to_string() + " " + parts[1] + " " + parts[2];
    println!("  \"{}\"", result1);

    println!("✅ 빠름 (한 번 할당):");
    let result2 = parts.join(" ");
    println!("  \"{}\"", result2);

    println!("\n[패턴 3: format! vs write!]");
    println!("❌ format! - 매번 String 할당");
    for i in 0..3 {
        let _s = format!("Item {}", i);
    }

    println!("✅ write! - 기존 String에 추가");
    use std::fmt::Write;
    let mut output = String::new();
    for i in 0..3 {
        writeln!(&mut output, "Item {}", i).unwrap();
    }
    print!("{}", output);

    println!("\n[패턴 4: 여러 슬라이스 연결]");
    let s1 = "Hello";
    let s2 = "World";
    let combined = format!("{} {}", s1, s2);
    println!("format!(\"{{}}{{}}\") = \"{}\"", combined);
}

// ============================================================================
// [예제 8] 실제 문자열 처리 패턴
// ============================================================================
fn real_world_string_patterns() {
    println!("\n[예제 8] 실제 문자열 처리 패턴");
    println!("═════════════════════════════════════════");

    println!("\n[패턴 1: CSV 파싱]");
    let line = "Alice, 30, admin";
    let fields: Vec<&str> = line.split(',')
        .map(|s| s.trim())
        .collect();
    println!("CSV: \"{}\"", line);
    for (idx, field) in fields.iter().enumerate() {
        println!("  필드[{}] = \"{}\"", idx, field);
    }

    println!("\n[패턴 2: 이메일 검증]");
    fn is_valid_email(email: &str) -> bool {
        email.contains('@') && email.contains('.')
            && email.len() > 5
    }

    let emails = vec!["user@example.com", "invalid.email", "test@co.uk"];
    for email in emails {
        println!("  {} → {}", email, is_valid_email(email));
    }

    println!("\n[패턴 3: 문자열 정규화]");
    fn normalize_case(s: &str) -> String {
        s.trim().to_lowercase()
    }

    let inputs = vec!["  HELLO  ", "World", "rUsT"];
    for input in inputs {
        println!("  \"{}\" → \"{}\"", input, normalize_case(input));
    }

    println!("\n[패턴 4: 공백 처리]");
    let text = "  hello   world  ";
    let trimmed = text.trim();
    let words: Vec<&str> = text.split_whitespace().collect();
    println!("원본: \"{}\"", text);
    println!("trim(): \"{}\"", trimmed);
    println!("words: {:?}", words);

    println!("\n[패턴 5: 문자열 치환]");
    let original = "Hello, World!";
    let replaced = original.replace("World", "Rust");
    println!("원본: \"{}\"", original);
    println!("replace: \"{}\"", replaced);

    println!("\n[패턴 6: 다국어 처리]");
    let texts = vec!["hello", "안녕하세요", "こんにちは"];
    for text in texts {
        println!("\"{}\":", text);
        println!("  문자 개수: {}", text.chars().count());
        println!("  바이트 개수: {}", text.len());
    }

    println!("\n[패턴 7: 시작/끝 확인]");
    let filename = "document.txt";
    println!("\"{}\":", filename);
    println!("  starts_with(\".rs\") = {}", filename.starts_with(".rs"));
    println!("  ends_with(\".txt\") = {}", filename.ends_with(".txt"));
    println!("  contains(\"ument\") = {}", filename.contains("ument"));
}

