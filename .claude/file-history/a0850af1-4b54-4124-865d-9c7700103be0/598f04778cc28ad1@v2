// ============================================================================
// [예제 1] String의 내부 구조
// ============================================================================
fn string_internal_structure() {
    println!("\n[예제 1] String의 내부 구조");
    println!("═════════════════════════════════════════");

    println!("\n[String 생성과 메모리]");
    let s = String::from("Hello");
    println!("String::from(\"Hello\")");
    println!("  len()      = {} (바이트 개수)", s.len());
    println!("  capacity() = {} (할당된 용량)", s.capacity());

    println!("\n[String은 Vec<u8>]");
    println!("String 내부 구조:");
    println!("  +--------+");
    println!("  | ptr    | → 힙의 데이터");
    println!("  | len    | = {} (사용 중)", s.len());
    println!("  | cap    | = {} (할당됨)", s.capacity());
    println!("  +--------+");

    println!("\n[용량 예약]");
    let mut s2 = String::with_capacity(20);
    println!("String::with_capacity(20)");
    println!("  len()      = {} (비어있음)", s2.len());
    println!("  capacity() = {} (미리 예약)", s2.capacity());

    s2.push_str("Hello");
    println!("push_str(\"Hello\") 후:");
    println!("  len()      = {} (사용 중)", s2.len());
    println!("  capacity() = {} (여전히 여유)", s2.capacity());

    println!("\n[비교: 스택 vs 힙]");
    let literal = "hello";      // 스택의 포인터 + 바이너리의 데이터
    let owned = String::from("hello");  // 스택의 포인터 + 힙의 데이터
    println!("&str 리터럴: 스택 포인터 + 바이너리 저장");
    println!("String:     스택 포인터 + 힙 저장");
}

// ============================================================================
// [예제 2] &str 슬라이싱의 기본
// ============================================================================
fn str_slice_basics() {
    println!("\n[예제 2] &str 슬라이싱의 기본");
    println!("═════════════════════════════════════════");

    println!("\n[&str의 정의]");
    let s = "Hello, World!";
    println!("&str = (pointer, length)");
    println!("  pointer → 바이트 데이터");
    println!("  length  → 유효한 바이트 개수");

    println!("\n[슬라이싱]");
    let hello = &s[0..5];
    println!("&s[0..5] = \"{}\"", hello);

    let world = &s[7..12];
    println!("&s[7..12] = \"{}\"", world);

    println!("\n[범위 표기법]");
    let all = &s[..];
    println!("&s[..]  = \"{}\" (전체)", all);

    let from_start = &s[..5];
    println!("&s[..5] = \"{}\" (처음부터)", from_start);

    let to_end = &s[7..];
    println!("&s[7..] = \"{}\" (끝까지)", to_end);

    println!("\n[String에서 &str 추출]");
    let owned = String::from("Rust");
    let borrowed: &str = &owned;
    println!("let owned = String::from(\"Rust\");");
    println!("let borrowed: &str = &owned;");
    println!("borrowed = \"{}\"", borrowed);
    println!("owned는 여전히 사용 가능: \"{}\" ✓", owned);
}

// ============================================================================
// [예제 3] UTF-8 인코딩의 복잡성
// ============================================================================
fn utf8_encoding_details() {
    println!("\n[예제 3] UTF-8 인코딩의 복잡성");
    println!("═════════════════════════════════════════");

    println!("\n[ASCII vs 다국어]");
    let ascii = "hello";
    println!("\"hello\" (ASCII):");
    println!("  len()           = {} (바이트)", ascii.len());
    println!("  chars().count() = {} (문자)", ascii.chars().count());

    let korean = "한글";
    println!("\"한글\" (한글):");
    println!("  len()           = {} (바이트)", korean.len());
    println!("  chars().count() = {} (문자)", korean.chars().count());

    let emoji = "🦀";
    println!("\"🦀\" (이모지):");
    println!("  len()           = {} (바이트)", emoji.len());
    println!("  chars().count() = {} (문자)", emoji.chars().count());

    println!("\n[bytes() - 바이트 순회]");
    print!("\"hello\" 바이트: ");
    for byte in "hello".bytes() {
        print!("{} ", byte);
    }
    println!();

    println!("\n[chars() - 문자 순회]");
    print!("\"hello\" 문자: ");
    for ch in "hello".chars() {
        print!("{} ", ch);
    }
    println!();

    print!("\"한글\" 문자: ");
    for ch in "한글".chars() {
        print!("{} ", ch);
    }
    println!();

    println!("\n[멀티바이트 인코딩]");
    let text = "안녕";
    for (idx, byte) in text.bytes().enumerate() {
        println!("  바이트[{}] = {}", idx, byte);
    }

    println!("\n[char_indices() - 인덱스와 함께]");
    for (idx, ch) in text.char_indices() {
        println!("  위치[{}] = '{}'", idx, ch);
    }
}

