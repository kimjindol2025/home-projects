"""
Python Elementary v1.2 - 연산자와 문자열 다루기 (Operators and String Handling)

탐구(초등학교): "데이터로 요리하기 (연산자)"

파이썬은 계산기처럼 아주 똑똑합니다.
숫자를 계산하는 방법과 글자를 합치는 방법을 알아봅시다.

1. 숫자 연산 (산술 연산자)
   +, -, * : 더하기, 빼기, 곱하기
   / : 나누기 (결과는 항상 실수형입니다. 예: 4 / 2는 2.0)
   // : 몫만 구하기 (예: 7 // 3은 2)
   % : 나머지만 구하기 (예: 7 % 3은 1)
   ** : 거듭제곱 (예: 2 ** 3은 8)

2. 문자열 연산 (글자 합치기)
   + : 글자와 글자를 이어 붙입니다.
   * : 글자를 숫자만큼 반복합니다. (예: "안녕" * 3)
"""

print("=" * 70)
print("# Python Elementary v1.2 - 연산자와 문자열 다루기")
print("=" * 70)

# ============================================================================
# [1단계] 숫자 요리 (사탕 나누기 게임)
# ============================================================================

print("\n[1단계] 숫자 요리 - 사탕 나누기 게임")
print("-" * 70)

total_candies = 10
friends = 3

candies_per_person = total_candies // friends  # 몫: 한 명당 3개씩
remaining_candies = total_candies % friends    # 나머지: 남은 1개

print("총 사탕 개수:", total_candies)
print("친구 수:", friends)
print("한 명당 사탕 개수:", candies_per_person)
print("남은 사탕 개수:", remaining_candies)
print(f"검증: {friends} × {candies_per_person} + {remaining_candies} = {friends * candies_per_person + remaining_candies}")

# ============================================================================
# [2단계] 문자 요리 (이름표 만들기)
# ============================================================================

print("\n[2단계] 문자 요리 - 이름표 만들기")
print("-" * 70)

first_name = "Gogs"
last_name = "Lang"
full_name = first_name + " " + last_name  # 글자 합치기

print("성:", first_name)
print("이름:", last_name)
print("전체 이름:", full_name)
print("강조 효과:", "★" * 5 + full_name + "★" * 5)

# ============================================================================
# [3단계] 산술 연산자 모두 시험해보기
# ============================================================================

print("\n[3단계] 산술 연산자 실험")
print("-" * 70)

a = 10
b = 3

print(f"a = {a}, b = {b}")
print(f"덧셈 (a + b) = {a + b}")
print(f"뺄셈 (a - b) = {a - b}")
print(f"곱셈 (a * b) = {a * b}")
print(f"나눗셈 (a / b) = {a / b}")
print(f"몫 (a // b) = {a // b}")
print(f"나머지 (a % b) = {a % b}")
print(f"거듭제곱 (a ** b) = {a ** b}")

# ============================================================================
# [4단계] 문자열 연산 모두 시험해보기
# ============================================================================

print("\n[4단계] 문자열 연산 실험")
print("-" * 70)

greeting = "안녕"
repeat_count = 3

print(f"문자: '{greeting}'")
print(f"반복 연산 (greeting * {repeat_count}) = '{greeting * repeat_count}'")
print(f"조합: '{greeting}' + '하세요' = '{greeting + '하세요'}'")

# ============================================================================
# [5단계] 연산 우선순위 (Order of Operations)
# ============================================================================

print("\n[5단계] 연산 우선순위 - 수학 시간과 같습니다!")
print("-" * 70)

result1 = 2 + 3 * 4       # 먼저 3 * 4 = 12, 그 다음 2 + 12 = 14
result2 = (2 + 3) * 4     # 괄호 먼저: 2 + 3 = 5, 그 다음 5 * 4 = 20

print(f"2 + 3 * 4 = {result1}  (곱셈을 먼저 계산)")
print(f"(2 + 3) * 4 = {result2}  (괄호를 먼저 계산)")

# ============================================================================
# [주의사항] 숫자와 글자는 그냥 더할 수 없어요!
# ============================================================================

print("\n[주의사항] 숫자와 글자는 직접 섞을 수 없습니다")
print("-" * 70)

age = 20
print(f"age 변수의 값: {age}")
print(f"age의 타입: {type(age)}")

print("\n만약 이렇게 하면 에러가 발생합니다:")
print("  print('나이: ' + age)  ← 에러!")
print("\n왜냐하면 '문자'와 '숫자'를 직접 더할 수 없기 때문입니다.")
print("나중에 중학교 과정에서 '형변환'을 배우면 해결됩니다!")

# ============================================================================
# [최종 증명]
# ============================================================================

print("\n" + "=" * 70)
print("# [최종 증명] 연산자와 문자열의 힘")
print("=" * 70)

