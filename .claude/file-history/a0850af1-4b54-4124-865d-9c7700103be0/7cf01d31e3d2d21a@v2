// ============================================================================
// [1] 단순 신호등 FSM (Simple Traffic Light)
// ============================================================================
//
// 신호등은 빨강 → 초록 → 노랑 → 빨강의 순환
//
fn simple_traffic_light() {
    println!("[1] 단순 신호등 FSM");
    println!("────────────────────────────────────────────────────────────");

    #[derive(Debug)]
    enum TrafficLight {
        Red,
        Yellow,
        Green,
    }

    let mut light = TrafficLight::Red;
    println!("✓ 신호등 상태: {:?}", light);

    // 신호 변경 1: 빨강 → 노랑
    light = match light {
        TrafficLight::Red => {
            println!("  신호: 빨강 → 노랑으로 변경");
            TrafficLight::Yellow
        }
        _ => light,
    };

    // 신호 변경 2: 노랑 → 초록
    light = match light {
        TrafficLight::Yellow => {
            println!("  신호: 노랑 → 초록으로 변경");
            TrafficLight::Green
        }
        _ => light,
    };

    // 신호 변경 3: 초록 → 빨강
    light = match light {
        TrafficLight::Green => {
            println!("  신호: 초록 → 빨강으로 변경");
            TrafficLight::Red
        }
        _ => light,
    };

    println!("  최종 상태: {:?}", light);
    println!();
}

// ============================================================================
// [2] Enum 상태 정의 (Enum State Definition)
// ============================================================================
//
// 상태가 단순 값일 수도, 데이터를 포함할 수도 있음
//
fn enum_state_definition() {
    println!("[2] Enum 상태 정의");
    println!("────────────────────────────────────────────────────────────");

    #[derive(Debug)]
    enum UserState {
        Logged_Out,
        Logged_In,
        Suspended,
        Banned,
    }

    let states = vec![
        UserState::Logged_Out,
        UserState::Logged_In,
        UserState::Suspended,
        UserState::Banned,
    ];

    println!("✓ 사용자 상태 열거형:");
    for (i, state) in states.iter().enumerate() {
        println!("  {}: {:?}", i + 1, state);
    }

    // 상태에 따른 권한 확인
    println!("✓ 상태별 권한 확인:");
    for state in &states {
        let can_access = match state {
            UserState::Logged_In => true,
            UserState::Logged_Out => false,
            UserState::Suspended => false,
            UserState::Banned => false,
        };
        println!("  {:?} → 접근 가능: {}", state, can_access);
    }

    println!();
}

// ============================================================================
// [3] 데이터를 가진 상태 (State with Data)
// ============================================================================
//
// 상태가 추가 정보를 가질 수 있음
// 예: Running(u8)은 "가동" 상태이면서 전력 수치를 보유
//
fn state_with_data() {
    println!("[3] 데이터를 가진 상태");
    println!("────────────────────────────────────────────────────────────");

    #[derive(Debug, Clone)]
    enum SystemState {
        Idle,
        Running(u8),           // 가동 상태 + 전력 수치
        Error(String),         // 에러 상태 + 메시지
        Maintenance { days: u32 }, // 유지보수 상태 + 남은 일수
    }

    let mut system = SystemState::Idle;
    println!("✓ 초기 상태: {:?}", system);

    // 상태 전환 1: Idle → Running(10)
    system = SystemState::Running(10);
    println!("  상태 변경: {:?}", system);

    // 상태 전환 2: Running → Error
    system = SystemState::Error("온도 초과".to_string());
    println!("  상태 변경: {:?}", system);

    // 상태 전환 3: Error → Maintenance
    system = SystemState::Maintenance { days: 5 };
    println!("  상태 변경: {:?}", system);

    // 상태별 처리
    println!("✓ 상태별 액션:");
    match system {
        SystemState::Idle => println!("  대기 중: 명령 수신 대기"),
        SystemState::Running(power) => println!("  가동 중: 전력 레벨 = {}", power),
        SystemState::Error(msg) => println!("  에러: {}", msg),
        SystemState::Maintenance { days } => println!("  유지보수: {} 일 남음", days),
    }

    println!();
}

// ============================================================================
// [4] 명령어 기반 상태 전환 (Command Handling)
// ============================================================================
//
// 외부 명령어에 따라 상태 전환
//
fn command_handling() {
    println!("[4] 명령어 기반 상태 전환");
    println!("────────────────────────────────────────────────────────────");

    #[derive(Debug)]
    enum State {
        Idle,
        Running(u8),
        Error(String),
    }

    let mut state = State::Idle;
    let commands = vec!["START", "POWER_UP", "ERROR_TRIGGER", "RECOVER", "STOP"];

    println!("✓ 명령어 시퀀스 실행:");
    for cmd in commands {
        println!("  [명령] {}", cmd);

        state = match state {
            State::Idle => {
                match cmd {
                    "START" => {
                        println!("    → Running(20)으로 전환");
                        State::Running(20)
                    }
                    _ => {
                        println!("    → Idle 유지 (명령 무시)");
                        State::Idle
                    }
                }
            }
            State::Running(power) => {
                match cmd {
                    "POWER_UP" => {
                        let new_power = power + 10;
                        println!("    → Running({}) 파워 증가", new_power);
                        State::Running(new_power)
                    }
                    "ERROR_TRIGGER" => {
                        println!("    → Error 상태로 전환");
                        State::Error("과부하!".to_string())
                    }
                    "STOP" => {
                        println!("    → Idle 상태로 정지");
                        State::Idle
                    }
                    _ => {
                        println!("    → Running({}) 유지", power);
                        State::Running(power)
                    }
                }
            }
            State::Error(ref msg) => {
                match cmd {
                    "RECOVER" => {
                        println!("    → Idle 복구됨");
                        State::Idle
                    }
                    _ => {
                        println!("    → Error 상태 유지: {}", msg);
                        state
                    }
                }
            }
        };
    }

    println!("  최종 상태: {:?}", state);
    println!();
}

// ============================================================================
// [5] 불가능한 전환 차단 (Invalid Transition Blocking)
// ============================================================================
//
// 타입 시스템이 불가능한 상태 전환을 원천 차단
//
fn invalid_transition_blocking() {
    println!("[5] 불가능한 전환 차단");
    println!("────────────────────────────────────────────────────────────");

    #[derive(Debug)]
    enum BankAccount {
        Closed,
        Active { balance: f64 },
        Frozen { reason: String },
    }

    let mut account = BankAccount::Active { balance: 1000.0 };
    println!("✓ 계좌 상태: {:?}", account);

    // 유효한 전환: Active → Frozen
    account = match account {
        BankAccount::Active { .. } => {
            println!("  유효한 전환: Active → Frozen");
            BankAccount::Frozen { reason: "의심 거래".to_string() }
        }
        _ => account,
    };

    // 유효한 전환: Frozen → Active (복구)
    account = match account {
        BankAccount::Frozen { .. } => {
            println!("  유효한 전환: Frozen → Active (복구)");
            BankAccount::Active { balance: 1000.0 }
        }
        _ => account,
    };

    // 유효한 전환: Active → Closed (폐쇄)
    account = match account {
        BankAccount::Active { .. } => {
            println!("  유효한 전환: Active → Closed");
            BankAccount::Closed
        }
        _ => account,
    };

    // 불가능한 전환 시도: Closed → Active
    // 컴파일러가 Closed 상태에서 Active로 갈 수 없음을 보장
    account = match account {
        BankAccount::Closed => {
            println!("  불가능: Closed 상태에서 벗어날 수 없음 (설계상 보장)");
            BankAccount::Closed
        }
        _ => account,
    };

    println!("  최종 상태: {:?}", account);
    println!();
}

// ============================================================================
// [6] 주문 처리 FSM (Order Processing FSM)
// ============================================================================
//
// 실무 예제: 주문 → 결제 → 배송 → 완료
//
fn order_processing() {
    println!("[6] 주문 처리 FSM");
    println!("────────────────────────────────────────────────────────────");

    #[derive(Debug, Clone)]
    enum OrderState {
        Pending,
        Paid { amount: f64 },
        Shipped { tracking: String },
        Delivered,
        Cancelled,
    }

    let mut order = OrderState::Pending;
    println!("✓ 주문 생성: {:?}", order);

    // 결제
    order = match order {
        OrderState::Pending => {
            println!("  [1] 결제 처리...");
            OrderState::Paid { amount: 29900.0 }
        }
        _ => order,
    };

    // 배송 준비
    order = match order {
        OrderState::Paid { .. } => {
            println!("  [2] 배송 준비...");
            OrderState::Shipped { tracking: "TRACK123".to_string() }
        }
        _ => order,
    };

    // 배송 완료
    order = match order {
        OrderState::Shipped { .. } => {
            println!("  [3] 배송 완료!");
            OrderState::Delivered
        }
        _ => order,
    };

    println!("  최종 상태: {:?}", order);
    println!();
}

// ============================================================================
// [7] 게임 상태 머신 (Game State Machine)
// ============================================================================
//
// 게임: Menu → Playing → GameOver → Menu
//
fn game_state_machine() {
    println!("[7] 게임 상태 머신");
    println!("────────────────────────────────────────────────────────────");

    #[derive(Debug)]
    enum GameState {
        Menu,
        Loading,
        Playing { level: u32, score: u32 },
        Paused { level: u32, score: u32 },
        GameOver { final_score: u32 },
    }

    let mut game = GameState::Menu;
    println!("✓ 게임 상태: {:?}", game);

    // Menu → Loading
    game = match game {
        GameState::Menu => {
            println!("  [MENU] 게임 로딩 중...");
            GameState::Loading
        }
        _ => game,
    };

    // Loading → Playing
    game = match game {
        GameState::Loading => {
            println!("  [LOADING] Level 1 시작!");
            GameState::Playing { level: 1, score: 0 }
        }
        _ => game,
    };

    // Playing → Playing (점수 증가)
    game = match game {
        GameState::Playing { level, score } => {
            println!("  [PLAYING] 점수: {} → {}", score, score + 100);
            GameState::Playing { level, score: score + 100 }
        }
        _ => game,
    };

    // Playing → Paused
    game = match game {
        GameState::Playing { level, score } => {
            println!("  [PAUSED] 게임 일시정지");
            GameState::Paused { level, score }
        }
        _ => game,
    };

    // Paused → Playing
    game = match game {
        GameState::Paused { level, score } => {
            println!("  [RESUME] 게임 재개");
            GameState::Playing { level, score }
        }
        _ => game,
    };

    // Playing → GameOver
    game = match game {
        GameState::Playing { score, .. } => {
            println!("  [GAMEOVER] 최종 점수: {}", score);
            GameState::GameOver { final_score: score }
        }
        _ => game,
    };

    // GameOver → Menu
    game = match game {
        GameState::GameOver { .. } => {
            println!("  [MENU] 메뉴로 돌아감");
            GameState::Menu
        }
        _ => game,
    };

    println!("  최종 상태: {:?}", game);
    println!();
}

// ============================================================================
// [8] 복잡한 FSM (Complex FSM Combination)
// ============================================================================
//
// 다중 상태 머신의 조합으로 복잡한 시스템 모델링
//
fn complex_fsm() {
    println!("[8] 복잡한 FSM 조합");
    println!("────────────────────────────────────────────────────────────");

    #[derive(Debug)]
    enum NetworkState {
        Disconnected,
        Connecting { retry: u32 },
        Connected { bandwidth: u32 },
        Reconnecting { reason: String },
    }

    #[derive(Debug)]
    enum DataSyncState {
        Idle,
        Syncing { progress: u32 },
        Complete,
        Failed { error: String },
    }

    let mut network = NetworkState::Disconnected;
    let mut sync = DataSyncState::Idle;

    println!("✓ 초기 상태:");
    println!("  Network: {:?}", network);
    println!("  Sync: {:?}", sync);

    // Step 1: 연결 시도
    network = match network {
        NetworkState::Disconnected => {
            println!("  [Step 1] 연결 시도...");
            NetworkState::Connecting { retry: 1 }
        }
        _ => network,
    };

    // Step 2: 연결 완료
    network = match network {
        NetworkState::Connecting { .. } => {
            println!("  [Step 2] 연결 성공!");
            NetworkState::Connected { bandwidth: 100 }
        }
        _ => network,
    };

    // Step 3: 동기화 시작
    sync = match sync {
        DataSyncState::Idle => {
            println!("  [Step 3] 동기화 시작...");
            DataSyncState::Syncing { progress: 0 }
        }
        _ => sync,
    };

    // Step 4: 동기화 진행
    sync = match sync {
        DataSyncState::Syncing { progress: _ } => {
            println!("  [Step 4] 동기화 진행: 0% → 100%");
            DataSyncState::Syncing { progress: 100 }
        }
        _ => sync,
    };

    // Step 5: 동기화 완료
    sync = match sync {
        DataSyncState::Syncing { progress: 100 } => {
            println!("  [Step 5] 동기화 완료!");
            DataSyncState::Complete
        }
        _ => sync,
    };

    println!("✓ 최종 상태:");
    println!("  Network: {:?}", network);
    println!("  Sync: {:?}", sync);

    println!();
}

// ============================================================================
// v3.7 핵심 학습 요소
// ============================================================================
//
// 1. Enum으로 상태 정의
//    - 단순 상태: Red, Green, Blue
//    - 데이터 포함: Running(u8), Error(String)
//    - 복잡한 상태: Maintenance { days: u32 }
//
// 2. Match로 전환 제어
//    - 현재 상태에서 가능한 다음 상태만 매칭
//    - 모든 경우 처리 (exhaustiveness 검사)
//    - 불가능한 전환 원천 차단
//
// 3. 상태 데이터 유지
//    - 상태 안에 필요한 정보 저장
//    - 전환 시 정보 전달
//    - 타입 안전성 보장
//
// 4. 명령어 처리
//    - 외부 입력(명령)에 따라 상태 전환
//    - 상태마다 다른 명령 처리
//    - 유효하지 않은 명령은 무시
//
// 5. 복잡한 FSM
//    - 다중 상태 머신 조합
//    - 독립적인 상태 전환
//    - 상호작용하는 시스템 모델링
//
// 6. 설계 원칙
//    - 명확성: 상태가 명확함
//    - 안전성: 불가능한 상태 불가
//    - 결정성: 같은 입력 → 같은 결과
//    - 완결성: 모든 경우 처리
//
// ============================================================================

