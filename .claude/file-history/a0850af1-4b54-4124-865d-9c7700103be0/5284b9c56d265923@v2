use std::marker::{PhantomData, PhantomPinned};
use std::sync::{Arc, Mutex};
use std::fmt;

/// ============================================================
/// [PART 1] Type-Level Security: 컴파일 타임 권한 제어
/// ============================================================

/// 권한의 기본 트레이트 - 모든 권한은 이를 구현해야 함
pub trait Permission: Send + Sync + fmt::Debug + Default {
    fn name(&self) -> &'static str;
}

/// 파일 시스템 접근 권한
#[derive(Debug, Clone, Copy, Default)]
pub struct FileAccess;
impl Permission for FileAccess {
    fn name(&self) -> &'static str {
        "FileAccess"
    }
}

/// 읽기 전용 권한
#[derive(Debug, Clone, Copy, Default)]
pub struct ReadOnly;
impl Permission for ReadOnly {
    fn name(&self) -> &'static str {
        "ReadOnly"
    }
}

/// 네트워크 접근 권한
#[derive(Debug, Clone, Copy, Default)]
pub struct NetworkAccess;
impl Permission for NetworkAccess {
    fn name(&self) -> &'static str {
        "NetworkAccess"
    }
}

/// 관리자 권한 (모든 권한을 포함)
#[derive(Debug, Clone, Copy, Default)]
pub struct AdminAccess;
impl Permission for AdminAccess {
    fn name(&self) -> &'static str {
        "AdminAccess (super-set)"
    }
}

/// ============================================================
/// [MASTER PATTERN 1] 타입 안전한 샌드박스 핸들
/// ============================================================
///
/// 핵심 아이디어:
/// - 권한을 타입 파라미터로 인코딩 (Zero-Cost)
/// - 권한 없는 객체는 특정 메서드를 호출할 수 없음 (컴파일 타임)
/// - PhantomData: 컴파일 타임만 존재, 런타임 오버헤드 0

pub struct GogsObject<P: Permission> {
    id: u64,
    data: Arc<Mutex<Vec<u8>>>,
    _permission: PhantomData<P>,
    _pin: PhantomPinned, // 메모리 주소 고정 (async-safe)
}

impl<P: Permission> GogsObject<P> {
    /// 권한 있는 생성자
    pub fn new(id: u64, initial_data: Vec<u8>) -> Self {
        GogsObject {
            id,
            data: Arc::new(Mutex::new(initial_data)),
            _permission: PhantomData,
            _pin: PhantomPinned,
        }
    }

    /// 현재 권한 확인
    pub fn check_permission(&self) -> String {
        format!("[SECURITY] Object {} has permission: {}",
                self.id, P::default().name())
    }

    /// 모든 권한이 호출 가능: 기본 읽기
    pub fn read_data(&self) -> Vec<u8> {
        self.data.lock().unwrap().clone()
    }
}

/// FileAccess 권한만 사용 가능한 메서드들
impl GogsObject<FileAccess> {
    pub fn write_file(&self, data: &[u8]) -> Result<(), String> {
        let mut guard = self.data.lock().unwrap();
        guard.clear();
        guard.extend_from_slice(data);
        println!("  [SECURITY] FileAccess confirmed. Writing {} bytes.", data.len());
        Ok(())
    }

    pub fn delete_file(&self) -> Result<(), String> {
        let mut guard = self.data.lock().unwrap();
        guard.clear();
        println!("  [SECURITY] FileAccess confirmed. File deleted.");
        Ok(())
    }
}

/// NetworkAccess 권한만 사용 가능한 메서드들
impl GogsObject<NetworkAccess> {
    pub fn send_network_packet(&self, dest: &str) -> Result<(), String> {
        let data = self.data.lock().unwrap();
        println!("  [SECURITY] NetworkAccess confirmed. Sending {} bytes to {}",
                 data.len(), dest);
        Ok(())
    }
}

/// AdminAccess 권한만 사용 가능한 메서드들
impl GogsObject<AdminAccess> {
    pub fn execute_system_command(&self, cmd: &str) -> Result<String, String> {
        println!("  [SECURITY] AdminAccess confirmed. Executing: {}", cmd);
        Ok(format!("Command '{}' executed", cmd))
    }

    pub fn shutdown_system(&self) -> Result<(), String> {
        println!("  [SECURITY] AdminAccess confirmed. System shutdown initiated.");
        Ok(())
    }
}

