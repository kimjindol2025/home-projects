#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_type_level_security_compile_time() {
        // ✅ 이 코드는 컴파일됨
        let admin: GogsObject<AdminAccess> = GogsObject::new(1, vec![1, 2, 3]);
        let _ = admin.check_permission();
        let _ = admin.execute_system_command("whoami");

        // ✅ 이 코드는 컴파일됨
        let file: GogsObject<FileAccess> = GogsObject::new(2, vec![4, 5, 6]);
        let _ = file.write_file(b"hello");

        // ✅ 읽기는 모두 가능
        let readonly: GogsObject<ReadOnly> = GogsObject::new(3, vec![7, 8, 9]);
        let _ = readonly.read_data();

        // ❌ 다음은 컴파일 에러 (권한 없음)
        // readonly.write_file(b"hack"); // <- Type error!
        // file.execute_system_command("rm -rf /"); // <- Type error!
    }

    #[test]
    fn test_stack_safety_macro_validation() {
        // ✅ 정상 프로그램
        let mut valid = StackTracker::new();
        valid.push(GogsOp::Push(5)).unwrap();
        valid.push(GogsOp::Push(3)).unwrap();
        valid.push(GogsOp::Add).unwrap();
        valid.push(GogsOp::Pop).unwrap();  // 결과값 팝해서 스택 비우기
        valid.validate().unwrap();

        println!("{}", valid.report());
        let bc = valid.bytecode();
        println!("✅ Valid bytecode: {:?}", bc);

        // ❌ 스택 언더플로우 감지
        let mut invalid1 = StackTracker::new();
        invalid1.push(GogsOp::Pop).unwrap_err(); // 즉시 에러

        // ❌ 불균형 스택 감지
        let mut invalid2 = StackTracker::new();
        invalid2.push(GogsOp::Push(10)).unwrap();
        invalid2.push(GogsOp::Push(20)).unwrap();
        invalid2.validate().unwrap_err(); // 끝에서 에러

        println!("✅ Stack validation works correctly");
    }

    #[test]
    fn test_async_ownership_safety() {
        // Arc<Mutex<>> = GC 안전한 공유
        let buffer = Arc::new(Mutex::new(AsyncBuffer::new(1, 256)));

        // 여러 태스크가 같은 버퍼 소유 가능
        let _task1 = AsyncTaskHandle::new(Arc::clone(&buffer), 1);
        let _task2 = AsyncTaskHandle::new(Arc::clone(&buffer), 2);

        // 데이터 써보기
        {
            let mut guard = buffer.lock().unwrap();
            guard.write(b"shared data").ok();
        }

        // 여러 태스크가 동시에 읽기 (GC 중단 필요 없음)
        {
            let guard = buffer.lock().unwrap();
            assert_eq!(guard.read()[..11], b"shared data"[..]);
        }

        println!("✅ Async ownership safety verified");
    }

    #[test]
    fn test_zero_cost_abstraction() {
        // PhantomData는 컴파일 타임만 존재 (런타임 오버헤드 0)
        let obj1: GogsObject<FileAccess> = GogsObject::new(1, vec![]);
        let obj2: GogsObject<ReadOnly> = GogsObject::new(2, vec![]);

        assert_eq!(
            std::mem::size_of_val(&obj1),
            std::mem::size_of_val(&obj2)
        );

        println!("✅ Zero-Cost Abstraction verified: {} bytes",
                 std::mem::size_of_val(&obj1));
    }
}

