print("\n" + "="*70)
print("# [패턴 4] 에러 처리 데코레이터")
print("="*70)

def safe_call(default_value=None):
    """
    함수 실행 중 에러가 발생해도 기본값을 반환합니다.

    프로덕션 환경에서 안정성을 높이는 데 사용합니다.
    """
    def decorator(func):
        @functools.wraps(func)
        def wrapper(*args, **kwargs):
            try:
                result = func(*args, **kwargs)
                print(f"  [SUCCESS] 실행 성공")
                return result
            except Exception as e:
                print(f"  [ERROR] {type(e).__name__}: {e}")
                print(f"  [FALLBACK] 기본값 반환: {default_value}")
                return default_value
        return wrapper
    return decorator


@safe_call(default_value=0)
def divide(a: int, b: int) -> float:
    """두 수를 나눕니다"""
    return a / b


print(f"\n[정상 실행]")
print(f"divide(10, 2):")
print(f"결과: {divide(10, 2)}")

print(f"\n[에러 처리]")
print(f"divide(10, 0):")
print(f"결과: {divide(10, 0)}")


