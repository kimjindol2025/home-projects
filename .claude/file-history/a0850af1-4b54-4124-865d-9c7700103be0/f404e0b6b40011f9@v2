print("\n" + "="*70)
print("# [패턴 3] 권한 검증 데코레이터")
print("="*70)

# 현재 사용자 시뮬레이션
current_user = {"username": "alice", "role": "admin"}


def require_role(required_role: str):
    """
    특정 역할(role)을 가진 사용자만 실행할 수 있게 제한합니다.

    Gogs 박사 과정(v30.2)의 '보안 검증'과 유사합니다.
    """
    def decorator(func):
        @functools.wraps(func)
        def wrapper(*args, **kwargs):
            user_role = current_user.get("role")

            if user_role != required_role:
                raise PermissionError(
                    f"'{required_role}' 역할 필요. 현재: '{user_role}'"
                )

            print(f"  [AUTH] '{current_user['username']}' ({user_role}) - 권한 승인")
            return func(*args, **kwargs)

        return wrapper
    return decorator


@require_role("admin")
def delete_user(user_id: int) -> str:
    """사용자를 삭제합니다 (admin만 가능)"""
    return f"사용자 {user_id} 삭제됨"


@require_role("user")
def view_profile(user_id: int) -> str:
    """프로필을 봅니다 (user 이상만 가능)"""
    return f"사용자 {user_id}의 프로필"


print(f"\n[권한 있음]")
print(f"현재 사용자: {current_user}")
print(f"delete_user(123):")
print(f"결과: {delete_user(123)}")

print(f"\n[권한 없음]")
try:
    print(f"view_profile(123):")
    print(f"결과: {view_profile(123)}")
except PermissionError as e:
    print(f"[ERROR] {e}")


