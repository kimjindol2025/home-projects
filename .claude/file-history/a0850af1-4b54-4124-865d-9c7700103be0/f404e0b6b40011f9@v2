"""
Python v1.3 - 데코레이터 패턴 (Decorator Patterns)

고급 기법:
1. 매개변수를 받는 데코레이터
2. 클래스 데코레이터
3. 메서드 데코레이터
4. 함수형 캐싱 (Memoization)
5. 권한 검증 (Authorization)
"""

import time
import functools
from typing import Callable, Any, Dict


# ============================================================================
# [패턴 1] 매개변수를 받는 데코레이터
# ============================================================================

print("\n" + "="*70)
print("# [패턴 1] 매개변수를 받는 데코레이터")
print("="*70)

def repeat_n_times(n: int):
    """
    함수 실행을 n번 반복하는 데코레이터 (매개변수 포함)

    구조:
      repeat_n_times(n)         ← 데코레이터 팩토리 (매개변수 처리)
        └─ decorator(func)      ← 데코레이터 (함수 감싸기)
            └─ wrapper(*args)   ← 실제 실행 (n번 반복)
    """
    def decorator(func):
        @functools.wraps(func)
        def wrapper(*args, **kwargs):
            results = []
            for i in range(n):
                result = func(*args, **kwargs)
                results.append(result)
            print(f"  실행 {n}회 완료")
            return results
        return wrapper
    return decorator


@repeat_n_times(3)
def greet(name):
    """인사"""
    return f"Hello, {name}!"


print(f"\n[실행]")
print(f"@repeat_n_times(3)")
print(f"def greet(name):")
print(f"\ngreet('Alice'):")
results = greet("Alice")
print(f"결과: {results}")


# ============================================================================
# [패턴 2] 메모이제이션 (Memoization) - 계산 결과 캐싱
# ============================================================================

print("\n" + "="*70)
print("# [패턴 2] 메모이제이션 - 계산 결과 캐싱")
print("="*70)

def memoize(func):
    """
    함수 호출의 결과를 캐시하는 데코레이터

    같은 인자로 다시 호출되면 캐시된 값을 반환합니다.
    """
    cache: Dict[tuple, Any] = {}

    @functools.wraps(func)
    def wrapper(*args, **kwargs):
        # 캐시 키 생성
        key = (args, tuple(sorted(kwargs.items())))

        if key in cache:
            print(f"  [CACHE HIT] '{func.__name__}({args})'")
            return cache[key]

        print(f"  [CACHE MISS] 계산 중...")
        result = func(*args, **kwargs)
        cache[key] = result

        return result

    wrapper.cache = cache  # 캐시에 직접 접근 가능
    wrapper.cache_clear = lambda: cache.clear()  # 캐시 초기화

    return wrapper


@memoize
def fibonacci(n: int) -> int:
    """재귀적 피보나치 계산 (느림)"""
    if n <= 1:
        return n
    return fibonacci(n - 1) + fibonacci(n - 2)


print(f"\n[첫 번째 계산 - 캐시 미스]")
print(f"fibonacci(10):")
result1 = fibonacci(10)
print(f"결과: {result1}")

print(f"\n[두 번째 계산 - 캐시 히트]")
print(f"fibonacci(10):")
result2 = fibonacci(10)
print(f"결과: {result2}")

print(f"\n[캐시 확인]")
print(f"캐시 크기: {len(fibonacci.cache)}")
print(f"캐시 초기화: {fibonacci.cache_clear()}")
print(f"초기화 후: {len(fibonacci.cache)}")


