print("\n" + "="*70)
print("# [패턴 5] 비율 제한 (Rate Limiting)")
print("="*70)

def rate_limit(calls_per_second: int):
    """
    함수 호출을 초당 제한합니다.

    API 서버에서 사용자 요청을 제한하는 데 활용됩니다.
    """
    min_interval = 1.0 / calls_per_second
    last_called = [0.0]  # 리스트를 사용해 클로저에서 수정 가능

    def decorator(func):
        @functools.wraps(func)
        def wrapper(*args, **kwargs):
            elapsed = time.time() - last_called[0]

            if elapsed < min_interval:
                sleep_time = min_interval - elapsed
                print(f"  [RATE LIMIT] {sleep_time:.3f}초 대기 중...")
                time.sleep(sleep_time)

            last_called[0] = time.time()
            return func(*args, **kwargs)

        return wrapper
    return decorator


@rate_limit(calls_per_second=2)
def api_call() -> str:
    """API 호출"""
    print(f"  [API] 요청 처리 중...")
    return "응답"


print(f"\n[비율 제한 데모]")
print(f"초당 2회 제한 (0.5초 간격)")
for i in range(4):
    print(f"\n[호출 {i+1}]")
    api_call()


