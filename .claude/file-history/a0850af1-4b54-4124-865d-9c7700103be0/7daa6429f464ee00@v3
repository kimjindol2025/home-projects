// ============================================================================
// [1] 기본 함수 정의 (Basic Function Definition)
// ============================================================================
//
// 함수의 기초: 이름, 매개변수, 반환 타입
//
fn basic_function_definition() {
    println!("[1] 기본 함수 정의");
    println!("────────────────────────────────────────────────────────────");

    // 함수 1: 매개변수 없음, 반환값 없음
    fn greet() {
        println!("✓ 기본 함수");
        println!("  안녕하세요!");
    }

    // 함수 2: 매개변수 있음, 반환값 없음
    fn greet_person(name: &str) {
        println!("✓ 매개변수 함수");
        println!("  안녕하세요, {}님!", name);
    }

    // 함수 3: 매개변수 있음, 반환값 있음
    fn double(x: i32) -> i32 {
        x * 2
    }

    // 함수 호출
    greet();
    greet_person("Alice");
    let result = double(5);
    println!("✓ 반환값 함수");
    println!("  5의 2배 = {}", result);

    println!();
}

// ============================================================================
// [2] 매개변수와 반환값 (Parameters and Return Types)
// ============================================================================
//
// 함수의 인터페이스: 명확한 데이터 흐름
//
fn parameter_and_return() {
    println!("[2] 매개변수와 반환값");
    println!("────────────────────────────────────────────────────────────");

    // 반환 타입 1: 단순값
    fn is_even(n: i32) -> bool {
        n % 2 == 0
    }

    // 반환 타입 2: 튜플 (여러 값)
    fn divide_with_remainder(a: i32, b: i32) -> (i32, i32) {
        (a / b, a % b)
    }

    // 반환 타입 3: Option (선택적 값)
    fn find_first_even(numbers: &[i32]) -> Option<i32> {
        numbers.iter().find(|&&n| n % 2 == 0).cloned()
    }

    // 반환 타입 4: Result (에러 처리)
    fn safe_divide(a: i32, b: i32) -> Result<i32, String> {
        if b == 0 {
            Err("Division by zero".to_string())
        } else {
            Ok(a / b)
        }
    }

    println!("✓ bool 반환");
    println!("  15는 짝수? {}", is_even(15));
    println!("  20은 짝수? {}", is_even(20));

    println!("✓ 튜플 반환");
    let (quotient, remainder) = divide_with_remainder(17, 5);
    println!("  17 ÷ 5 = {} 나머지 {}", quotient, remainder);

    println!("✓ Option 반환");
    let numbers = vec![1, 3, 5, 6, 7];
    match find_first_even(&numbers) {
        Some(n) => println!("  첫 짝수: {}", n),
        None => println!("  짝수 없음"),
    }

    println!("✓ Result 반환");
    match safe_divide(10, 2) {
        Ok(result) => println!("  10 ÷ 2 = {}", result),
        Err(e) => println!("  에러: {}", e),
    }

    println!();
}

// ============================================================================
// [3] 순수 함수 (Pure Functions)
// ============================================================================
//
// 입력에만 의존하고 외부 상태를 변경하지 않는 함수
//
fn pure_functions() {
    println!("[3] 순수 함수 (부수 효과 없음)");
    println!("────────────────────────────────────────────────────────────");

    // 순수 함수 1: 단순 계산
    fn square(x: i32) -> i32 {
        x * x
    }

    // 순수 함수 2: 문자열 변환
    fn uppercase(s: &str) -> String {
        s.to_uppercase()
    }

    // 순수 함수 3: 조건부 판단
    fn classify(score: i32) -> &'static str {
        match score {
            0..=40 => "F",
            41..=60 => "D",
            61..=80 => "B",
            81..=100 => "A",
            _ => "Invalid",
        }
    }

    println!("✓ 단순 계산");
    println!("  5² = {}", square(5));
    println!("  7² = {}", square(7));

    println!("✓ 문자열 변환");
    println!("  '{}' → '{}'", "hello", uppercase("hello"));

    println!("✓ 조건부 판단");
    println!("  85점 → 학점 {}", classify(85));
    println!("  45점 → 학점 {}", classify(45));

    println!("  특징: 같은 입력 → 항상 같은 출력");

    println!();
}

// ============================================================================
// [4] 캡슐화 패턴 (Encapsulation Pattern)
// ============================================================================
//
// 제2장의 복잡한 로직을 함수 내부로 숨김
//
fn encapsulation_pattern() {
    println!("[4] 캡슐화 패턴");
    println!("────────────────────────────────────────────────────────────");

    // 캡슐화 함수: v3.4의 패턴 매칭을 내부로 숨김
    fn analyze_sensor(value: i32) -> String {
        // 내부 복잡한 로직
        match value {
            x if x >= 100 => format!("[CRITICAL] 위험 수치 {}", x),
            x if x >= 80 => format!("[WARNING] 주의 수치 {}", x),
            x if x > 0 => format!("[NORMAL] 안정 수치 {}", x),
            _ => "[ERROR] 유효하지 않은 값".to_string(),
        }
    }

    println!("✓ 사용자 관점");
    println!("  입력 120 → 출력: {}", analyze_sensor(120));
    println!("  입력 85  → 출력: {}", analyze_sensor(85));
    println!("  입력 25  → 출력: {}", analyze_sensor(25));

    println!("  특징: 함수 이름만 보고도 무엇을 하는지 알 수 있음");
    println!("       내부 구현(match)은 블랙박스");

    println!();
}

// ============================================================================
// [5] 단일 책임 원칙 (Single Responsibility)
// ============================================================================
//
// 각 함수는 정확히 하나의 일만 수행
//
fn single_responsibility() {
    println!("[5] 단일 책임 원칙");
    println!("────────────────────────────────────────────────────────────");

    // 책임 1: 검증
    fn validate_age(age: i32) -> Result<i32, String> {
        if age < 0 {
            Err("Age cannot be negative".to_string())
        } else if age > 150 {
            Err("Age exceeds maximum".to_string())
        } else {
            Ok(age)
        }
    }

    // 책임 2: 분류
    fn categorize_age(age: i32) -> &'static str {
        match age {
            0..=12 => "Child",
            13..=19 => "Teenager",
            20..=65 => "Adult",
            _ => "Senior",
        }
    }

    // 책임 3: 포맷
    fn format_age_report(age: i32, category: &str) -> String {
        format!("나이: {}세 ({})", age, category)
    }

    println!("✓ 책임 분리");
    match validate_age(25) {
        Ok(valid_age) => {
            let category = categorize_age(valid_age);
            let report = format_age_report(valid_age, category);
            println!("  {}", report);
        }
        Err(e) => println!("  검증 실패: {}", e),
    }

    println!("  특징: 각 함수가 하나의 일만 함");
    println!("       함수 조합으로 복잡한 작업 처리");

    println!();
}

// ============================================================================
// [6] 데이터 변환 (Data Transformation)
// ============================================================================
//
// 입력 데이터를 다른 형식으로 변환하는 함수들
//
fn data_transformation() {
    println!("[6] 데이터 변환");
    println!("────────────────────────────────────────────────────────────");

    // 변환 1: 단위 변환
    fn celsius_to_fahrenheit(c: f64) -> f64 {
        c * 9.0 / 5.0 + 32.0
    }

    // 변환 2: 포맷팅
    fn format_temperature(celsius: f64) -> String {
        let fahrenheit = celsius_to_fahrenheit(celsius);
        format!("{}°C = {:.1}°F", celsius, fahrenheit)
    }

    // 변환 3: 리스트 변환
    fn celsius_list_to_fahrenheit(temps: &[f64]) -> Vec<f64> {
        temps.iter()
            .map(|&c| celsius_to_fahrenheit(c))
            .collect()
    }

    println!("✓ 단위 변환");
    println!("  0°C = {:.1}°F", celsius_to_fahrenheit(0.0));
    println!("  100°C = {:.1}°F", celsius_to_fahrenheit(100.0));

    println!("✓ 포맷팅");
    println!("  {}", format_temperature(25.0));
    println!("  {}", format_temperature(0.0));

    println!("✓ 리스트 변환");
    let celsius_temps = vec![0.0, 25.0, 100.0];
    let fahrenheit_temps = celsius_list_to_fahrenheit(&celsius_temps);
    println!("  {:?} → {:?}", celsius_temps, fahrenheit_temps);

    println!();
}

// ============================================================================
// [7] 재사용성 증명 (Reusability Demonstration)
// ============================================================================
//
// 같은 함수를 여러 컨텍스트에서 반복 사용
//
fn reusability_demo() {
    println!("[7] 재사용성 증명");
    println!("────────────────────────────────────────────────────────────");

    fn is_valid(x: i32) -> bool {
        x > 0 && x <= 100
    }

    fn process_value(x: i32) -> String {
        if is_valid(x) {
            format!("✓ {} (유효)", x)
        } else {
            format!("✗ {} (무효)", x)
        }
    }

    println!("✓ 같은 함수 여러 번 호출");

    let test_values = vec![25, 0, 50, 150, 75, -10, 100];
    println!("  처리 결과:");
    for value in test_values {
        println!("    {}", process_value(value));
    }

    println!("  특징: 함수를 작성하면 반복 사용 가능");
    println!("       복사-붙여넣기 필요 없음");

    println!();
}

// ============================================================================
// [8] 모듈화 아키텍처 (Modular Architecture)
// ============================================================================
//
// 작은 함수들을 조합하여 큰 기능 구성
//
fn modular_architecture() {
    println!("[8] 모듈화 아키텍처");
    println!("────────────────────────────────────────────────────────────");

    // 기본 함수들
    fn validate(x: i32) -> Result<i32, String> {
        if x < 0 || x > 100 {
            Err(format!("값이 범위를 벗어남: {}", x))
        } else {
            Ok(x)
        }
    }

    fn classify(x: i32) -> &'static str {
        match x {
            0..=40 => "LOW",
            41..=70 => "MEDIUM",
            71..=100 => "HIGH",
            _ => "INVALID",
        }
    }

    fn format_result(x: i32, class: &str) -> String {
        format!("값: {} 등급: {}", x, class)
    }

    // 조합 함수: 작은 함수들을 조합
    fn process(data: i32) -> String {
        match validate(data) {
            Ok(valid) => {
                let class = classify(valid);
                format_result(valid, class)
            }
            Err(e) => format!("오류: {}", e),
        }
    }

    println!("✓ 함수 조합");
    let test_data = vec![25, 55, 85, 150];

    for data in test_data {
        println!("  입력 {} → {}", data, process(data));
    }

    println!("  아키텍처:");
    println!("    process()");
    println!("    ├─ validate()");
    println!("    ├─ classify()");
    println!("    └─ format_result()");

    println!();
}

