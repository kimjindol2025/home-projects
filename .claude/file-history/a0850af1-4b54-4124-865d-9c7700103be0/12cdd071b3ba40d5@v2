#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_distributed_node_creation() {
        let node = DistributedNode::new(NodeID(1), 4);
        assert!(node.is_online());
        assert_eq!(node.local_weights.len(), 4);
        println!("✅ Distributed node creation test passed");
    }

    #[test]
    fn test_weight_snapshot() {
        let mut weights = BTreeMap::new();
        weights.insert(0, 0.4);
        weights.insert(1, 0.3);
        weights.insert(2, 0.2);
        weights.insert(3, 0.1);

        let snapshot = WeightSnapshot::new(NodeID(1), 0, weights, 1);
        assert!(snapshot.confidence > 0.0);
        println!("✅ Weight snapshot test passed");
    }

    #[test]
    fn test_node_local_learning() {
        let mut node = DistributedNode::new(NodeID(1), 4);
        let initial_gen = node.generation;

        node.learn_locally(0, true);
        assert_eq!(node.generation, initial_gen + 1);

        node.learn_locally(0, false);
        assert_eq!(node.generation, initial_gen + 2);

        println!("✅ Node local learning test passed");
    }

    #[test]
    fn test_global_broker() {
        let mut broker = GlobalWeightBroker::new();

        broker.register_node(NodeID(1), 4);
        broker.register_node(NodeID(2), 4);
        broker.register_node(NodeID(3), 4);

        assert_eq!(broker.node_count(), 3);
        assert_eq!(broker.online_node_count(), 3);

        println!("✅ Global broker test passed");
    }

    #[test]
    fn test_consensus_computation() {
        let broker = GlobalWeightBroker::new();
        let mut snapshots = BTreeMap::new();

        let mut weights1 = BTreeMap::new();
        weights1.insert(0, 0.5);
        weights1.insert(1, 0.5);

        let snapshot1 = WeightSnapshot::new(NodeID(1), 0, weights1, 1);
        snapshots.insert(NodeID(1), snapshot1);

        let result = broker.compute_consensus(&snapshots);
        assert!(result.is_ok());

        println!("✅ Consensus computation test passed");
    }

    #[test]
    fn test_node_failure_recovery() {
        let mut broker = GlobalWeightBroker::new();
        broker.register_node(NodeID(1), 4);

        assert!(broker.simulate_node_failure(NodeID(1)).is_ok());
        assert_eq!(broker.online_node_count(), 0);

        assert!(broker.simulate_node_recovery(NodeID(1)).is_ok());
        assert_eq!(broker.online_node_count(), 1);

        println!("✅ Node failure/recovery test passed");
    }

    #[test]
    fn test_planetary_simulation() {
        let mut sim = PlanetarySimulation::new();
        sim.deploy_regional_nodes();

        {
            let broker = sim.broker.lock().unwrap();
            assert!(broker.node_count() > 0);
        }

        sim.advance_time(1000, 10);
        sim.inject_fault(3);
        sim.advance_time(500, 5);
        sim.recover_nodes(3);

        let report = sim.final_report();
        assert!(!report.is_empty());

        println!("✅ Planetary simulation test passed");
        println!("{}", report);
    }
}

