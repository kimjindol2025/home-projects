/// 노드 ID (지구상의 고유 식별자)
#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash, PartialOrd, Ord)]
pub struct NodeID(u64);

impl fmt::Display for NodeID {
    fn fmt(&self, f: &mut fmt::Formatter) -> fmt::Result {
        write!(f, "Node-{:016x}", self.0)
    }
}

/// 가중치 스냅샷 (특정 시점의 신경망 상태)
#[derive(Debug, Clone)]
pub struct WeightSnapshot {
    pub node_id: NodeID,
    pub timestamp: u64,
    pub weights: BTreeMap<u32, f32>, // PathID → Weight
    pub generation: u32,
    pub confidence: f64,
}

impl WeightSnapshot {
    pub fn new(node_id: NodeID, timestamp: u64, weights: BTreeMap<u32, f32>, generation: u32) -> Self {
        let confidence = weights.values().map(|w| w.abs()).sum::<f32>() / weights.len().max(1) as f32;
        WeightSnapshot {
            node_id,
            timestamp,
            weights,
            generation,
            confidence: confidence as f64,
        }
    }

    /// 가중치 정규화
    pub fn normalized(&self) -> BTreeMap<u32, f32> {
        let sum: f32 = self.weights.values().sum();
        if sum > 0.0 {
            self.weights
                .iter()
                .map(|(k, v)| (*k, v / sum))
                .collect()
        } else {
            self.weights.clone()
        }
    }
}

/// 분산 노드 (지구상의 각 gogs 인스턴스)
pub struct DistributedNode {
    id: NodeID,
    local_weights: BTreeMap<u32, f32>,
    peer_snapshots: Vec<WeightSnapshot>,
    sync_history: Vec<WeightSnapshot>,
    consensus_weights: BTreeMap<u32, f32>,
    generation: u32,
    online: bool,
}

impl DistributedNode {
    pub fn new(id: NodeID, path_count: usize) -> Self {
        let mut weights = BTreeMap::new();
        for i in 0..path_count {
            weights.insert(i as u32, 1.0 / path_count as f32);
        }

        DistributedNode {
            id,
            local_weights: weights,
            peer_snapshots: Vec::new(),
            sync_history: Vec::new(),
            consensus_weights: BTreeMap::new(),
            generation: 0,
            online: true,
        }
    }

    pub fn node_id(&self) -> NodeID {
        self.id
    }

    pub fn is_online(&self) -> bool {
        self.online
    }

    pub fn set_online(&mut self, online: bool) {
        self.online = online;
        if online {
            println!("  [PLANETARY] Node {} came online", self.id);
        } else {
            println!("  [PLANETARY] Node {} went offline", self.id);
        }
    }

    /// 로컬 신경망 학습 (기존 v30.1 방식)
    pub fn learn_locally(&mut self, path_id: u32, success: bool) {
        if !self.online {
            return;
        }

        if let Some(weight) = self.local_weights.get_mut(&path_id) {
            let adjustment = if success { 0.05 } else { -0.1 };
            *weight += adjustment;
        }

        self.generation += 1;

        // 정규화
        let sum: f32 = self.local_weights.values().sum();
        if sum > 0.0 {
            for weight in self.local_weights.values_mut() {
                *weight /= sum;
            }
        }
    }

    /// 현재 가중치 스냅샷 생성
    pub fn create_snapshot(&self, timestamp: u64) -> WeightSnapshot {
        WeightSnapshot::new(
            self.id,
            timestamp,
            self.local_weights.clone(),
            self.generation,
        )
    }

    /// 다른 노드의 스냅샷 수신
    pub fn receive_peer_snapshot(&mut self, snapshot: WeightSnapshot) {
        if snapshot.node_id == self.id {
            return; // 자신의 스냅샷은 무시
        }
        self.peer_snapshots.push(snapshot);
    }

    /// 합의된 가중치 적용
    pub fn apply_consensus_weights(&mut self, consensus: BTreeMap<u32, f32>) {
        self.consensus_weights = consensus.clone();
        self.local_weights = consensus;
        self.generation += 1;
        println!(
            "  [PLANETARY] Node {} applied consensus weights (Gen: {})",
            self.id, self.generation
        );
    }
}

/// ============================================================
/// [PART 2] 글로벌 가중치 브로커 (Global Weight Broker)
/// ============================================================

pub struct GlobalWeightBroker {
    nodes: HashMap<NodeID, DistributedNode>,
    weight_history: Vec<WeightSnapshot>,
    consensus_log: Vec<(u64, BTreeMap<NodeID, WeightSnapshot>)>,
    sync_interval: u64,
    last_sync: u64,
}

impl GlobalWeightBroker {
    pub fn new() -> Self {
        GlobalWeightBroker {
            nodes: HashMap::new(),
            weight_history: Vec::new(),
            consensus_log: Vec::new(),
            sync_interval: 1000, // 1000ms마다 동기화
            last_sync: 0,
        }
    }

    /// 노드 등록 (지구에 새 gogs 인스턴스 참여)
    pub fn register_node(&mut self, id: NodeID, path_count: usize) -> NodeID {
        let node = DistributedNode::new(id, path_count);
        self.nodes.insert(id, node);
        println!(
            "  [PLANETARY] Node {} registered. Total nodes: {}",
            id,
            self.nodes.len()
        );
        id
    }

    /// 노드 개수
    pub fn node_count(&self) -> usize {
        self.nodes.len()
    }

    /// 온라인 노드 개수
    pub fn online_node_count(&self) -> usize {
        self.nodes.values().filter(|n| n.is_online()).count()
    }

    /// 노드 시뮬레이션: 로컬 학습
    pub fn simulate_node_learning(
        &mut self,
        node_id: NodeID,
        path_id: u32,
        success: bool,
    ) -> Result<(), String> {
        if let Some(node) = self.nodes.get_mut(&node_id) {
            node.learn_locally(path_id, success);
            Ok(())
        } else {
            Err(format!("Node {} not found", node_id))
        }
    }

    /// 글로벌 동기화 (Federated Learning)
    pub fn synchronize_global_weights(&mut self, timestamp: u64) -> Result<(), String> {
        if timestamp - self.last_sync < self.sync_interval {
            return Ok(());
        }

        println!(
            "\n  [PLANETARY-SYNC] Starting global synchronization at timestamp {}",
            timestamp
        );

        // Step 1: 모든 온라인 노드의 가중치 수집
        let mut snapshots: BTreeMap<NodeID, WeightSnapshot> = BTreeMap::new();
        for (node_id, node) in &self.nodes {
            if node.is_online() {
                snapshots.insert(*node_id, node.create_snapshot(timestamp));
            }
        }

        if snapshots.is_empty() {
            return Err("No online nodes available for synchronization".to_string());
        }

        // Step 2: 합의 알고리즘으로 글로벌 가중치 계산
        let consensus = self.compute_consensus(&snapshots)?;

        // Step 3: 모든 노드에 합의된 가중치 배포
        for (node_id, consensus_weights) in &consensus {
            if let Some(node) = self.nodes.get_mut(node_id) {
                node.apply_consensus_weights(consensus_weights.clone());
            }
        }

        // Step 4: 동기화 기록
        self.consensus_log.push((timestamp, snapshots.clone()));
        self.last_sync = timestamp;

        println!(
            "  [PLANETARY-SYNC] Synchronization complete. {} nodes updated",
            consensus.len()
        );
        Ok(())
    }

    /// 합의 알고리즘 (Byzantine Fault Tolerant Median)
    fn compute_consensus(
        &self,
        snapshots: &BTreeMap<NodeID, WeightSnapshot>,
    ) -> Result<BTreeMap<NodeID, BTreeMap<u32, f32>>, String> {
        if snapshots.is_empty() {
            return Err("No snapshots to compute consensus".to_string());
        }

        // 모든 경로에 대해 합의 계산
        let mut path_ids: Vec<u32> = Vec::new();
        for snapshot in snapshots.values() {
            for path_id in snapshot.weights.keys() {
                if !path_ids.contains(path_id) {
                    path_ids.push(*path_id);
                }
            }
        }

        let mut global_consensus = BTreeMap::new();

        for path_id in path_ids {
            let mut values: Vec<f32> = Vec::new();
            for snapshot in snapshots.values() {
                if let Some(&weight) = snapshot.weights.get(&path_id) {
                    values.push(weight);
                }
            }

            if values.is_empty() {
                continue;
            }

            // Byzantine Median: 값들을 정렬하고 중앙값 선택
            values.sort_by(|a, b| a.partial_cmp(b).unwrap_or(std::cmp::Ordering::Equal));
            let median = values[values.len() / 2];

            global_consensus.insert(path_id, median);
        }

        // 정규화
        let sum: f32 = global_consensus.values().sum();
        if sum > 0.0 {
            for weight in global_consensus.values_mut() {
                *weight /= sum;
            }
        }

        // 모든 노드에 동일한 합의 배포
        let mut result = BTreeMap::new();
        for node_id in snapshots.keys() {
            result.insert(*node_id, global_consensus.clone());
        }

        Ok(result)
    }

    /// 노드 장애 시뮬레이션
    pub fn simulate_node_failure(&mut self, node_id: NodeID) -> Result<(), String> {
        if let Some(node) = self.nodes.get_mut(&node_id) {
            node.set_online(false);
            Ok(())
        } else {
            Err(format!("Node {} not found", node_id))
        }
    }

    /// 노드 복구 시뮬레이션
    pub fn simulate_node_recovery(&mut self, node_id: NodeID) -> Result<(), String> {
        if let Some(node) = self.nodes.get_mut(&node_id) {
            node.set_online(true);
            Ok(())
        } else {
            Err(format!("Node {} not found", node_id))
        }
    }

    /// 글로벌 신경망 건강도
    pub fn global_health(&self) -> f64 {
        if self.nodes.is_empty() {
            return 0.0;
        }

        let avg_generation: f32 = self.nodes
            .values()
            .filter(|n| n.is_online())
            .map(|n| n.generation as f32)
            .sum::<f32>()
            / self.online_node_count().max(1) as f32;

        ((avg_generation / 100.0).min(1.0) * 100.0) as f64
    }

    /// 상세 리포트
    pub fn report(&self) -> String {
        let mut report = format!(
            "Planetary Distributed Intelligence Report\n  Total Nodes: {}\n  Online: {}\n  Global Health: {:.2}%\n\n",
            self.node_count(),
            self.online_node_count(),
            self.global_health()
        );

        for (node_id, node) in &self.nodes {
            let status = if node.is_online() { "🟢" } else { "🔴" };
            report.push_str(&format!(
                "  {} {} - Generation: {}, Paths: {}\n",
                status,
                node_id,
                node.generation,
                node.local_weights.len()
            ));
        }

        report.push_str(&format!(
            "\n  Synchronization Events: {}\n",
            self.consensus_log.len()
        ));

        report
    }
}

/// ============================================================
/// [PART 3] 행성 규모 시뮬레이션 (Planetary Scale Simulation)
/// ============================================================

pub struct PlanetarySimulation {
    broker: Arc<Mutex<GlobalWeightBroker>>,
    current_timestamp: u64,
    events: Vec<(u64, String)>,
}

impl PlanetarySimulation {
    pub fn new() -> Self {
        PlanetarySimulation {
            broker: Arc::new(Mutex::new(GlobalWeightBroker::new())),
            current_timestamp: 0,
            events: Vec::new(),
        }
    }

    /// 지역별 노드 배포 (시뮬레이션)
    pub fn deploy_regional_nodes(&mut self) {
        let regions = vec![
            ("북미", 10),
            ("유럽", 8),
            ("아시아", 15),
            ("남미", 5),
            ("아프리카", 4),
            ("오세아니아", 2),
        ];

        {
            let mut broker = self.broker.lock().unwrap();
            for (region, count) in regions {
                for i in 0..count {
                    let node_id = NodeID((region.len() as u64) << 32 | i as u64);
                    broker.register_node(node_id, 4); // 4개 경로
                }
                println!("  [DEPLOYMENT] {} region: {} nodes deployed", region, count);
            }
        }

        self.events
            .push((self.current_timestamp, format!("Regional deployment complete")));
    }

    /// 시간 진행 및 학습 시뮬레이션
    pub fn advance_time(&mut self, delta: u64, iterations: usize) {
        self.current_timestamp += delta;

        {
            let mut broker = self.broker.lock().unwrap();

            // 각 노드가 로컬 학습 수행
            for _ in 0..iterations {
                for node_id in broker.nodes.keys().cloned().collect::<Vec<_>>() {
                    let path_id = (self.current_timestamp % 4) as u32;
                    let success = (self.current_timestamp % 3) == 0; // 33% 성공률
                    broker.simulate_node_learning(node_id, path_id, success).ok();
                }
            }

            // 글로벌 동기화
            broker.synchronize_global_weights(self.current_timestamp).ok();
        }

        self.events.push((
            self.current_timestamp,
            format!("Time advanced by {}ms, {} learning iterations", delta, iterations),
        ));
    }

    /// 노드 장애 이벤트
    pub fn inject_fault(&mut self, node_count: usize) {
        let mut broker = self.broker.lock().unwrap();
        let mut failed = 0;

        for node_id in broker.nodes.keys().take(node_count).cloned().collect::<Vec<_>>() {
            broker.simulate_node_failure(node_id).ok();
            failed += 1;
        }

        self.events.push((
            self.current_timestamp,
            format!("{} nodes failed", failed),
        ));
    }

    /// 복구 이벤트
    pub fn recover_nodes(&mut self, node_count: usize) {
        let mut broker = self.broker.lock().unwrap();
        let mut recovered = 0;

        for node_id in broker
            .nodes
            .values()
            .filter(|n| !n.is_online())
            .take(node_count)
            .map(|n| n.id)
            .collect::<Vec<_>>()
        {
            broker.simulate_node_recovery(node_id).ok();
            recovered += 1;
        }

        self.events.push((
            self.current_timestamp,
            format!("{} nodes recovered", recovered),
        ));
    }

    pub fn final_report(&self) -> String {
        let broker = self.broker.lock().unwrap();
        let mut report = format!(
            "Planetary Simulation Report\n  Duration: {}ms\n  Events: {}\n\n",
            self.current_timestamp,
            self.events.len()
        );

        report.push_str(&broker.report());
        report.push_str("\nEvent Timeline:\n");

        for (timestamp, event) in &self.events {
            report.push_str(&format!("  [{}ms] {}\n", timestamp, event));
        }

        report
    }
}

