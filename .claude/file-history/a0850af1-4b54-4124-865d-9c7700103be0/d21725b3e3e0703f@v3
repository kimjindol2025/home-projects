### 6️⃣ 에러 핸들링의 내재화

```rust
// ❌ 나쁜 설계: 호출자에게 책임 전가
fn get_and_process(id: u32) -> Option<Result<Data, Error>> {
    // 혼란스러운 반환 타입
}

// ✅ 좋은 설계: 메서드 내에서 처리
impl System {
    fn process_safely(&mut self, id: u32) -> Result<(), String> {
        // find_and_validate, process, store 모두 포함
        let data = self.find(id)?;      // ? 연산자로 조기 반환
        let validated = data.validate()?;
        self.store(validated)?;
        Ok(())
    }
}

// 호출자는 단순한 Result만 처리하면 됨
match system.process_safely(42) {
    Ok(_) => println!("성공"),
    Err(e) => println!("실패: {}", e),
}
```

### 7️⃣ 가변성과 불변성의 의도적 설계

```rust
// 공개 읽기, 제한된 쓰기 패턴
pub struct Account {
    balance: i32,  // private
}

impl Account {
    // 누구나 읽을 수 있음 (불변 메서드)
    pub fn get_balance(&self) -> i32 {
        self.balance
    }

    // 검증된 방식으로만 쓸 수 있음
    pub fn deposit(&mut self, amount: i32) -> Result<(), String> {
        if amount <= 0 {
            return Err("양수만 가능".to_string());
        }
        self.balance += amount;
        Ok(())
    }

    // 직접 필드 수정 불가능
    // account.balance = 999;  // ❌ 컴파일 에러
}
```

### 8️⃣ 확장 가능성 설계: 내일의 요구사항을 오늘 대비하기

```rust
// v1: 간단한 상태
#[derive(Debug)]
enum TaskStatus {
    Pending,
    Done,
}

// v2: 실패 정보 추가 (하나의 배리언트만 추가)
#[derive(Debug)]
enum TaskStatus {
    Pending,
    Done,
    Failed(String),  // 새 배리언트
}

// v3: 진행률 추가 (새 배리언트)
#[derive(Debug)]
enum TaskStatus {
    Pending,
    InProgress { progress: u8 },  // 새 배리언트
    Done,
    Failed(String),
}

// 기존 코드 대부분은 유지되고, match 패턴만 추가하면 됨
match task.status {
    TaskStatus::Pending => { /* 기존 */ },
    TaskStatus::InProgress { progress } => { /* 신규 */ },
    TaskStatus::Done => { /* 기존 */ },
    TaskStatus::Failed(reason) => { /* 기존 */ },
}
```

