### 패턴 3: 권한 관리 시스템

```rust
#[derive(Debug, Clone, Eq, PartialEq, Hash)]
enum Permission {
    Read,
    Write,
    Delete,
    Admin,
}

struct User {
    id: u32,
    name: String,
    permissions: Vec<Permission>,
}

struct UserManager {
    users: HashMap<u32, User>,
}

impl UserManager {
    fn has_permission(&self, user_id: u32, perm: Permission) -> bool {
        self.users.get(&user_id)
            .map(|u| u.permissions.contains(&perm))
            .unwrap_or(false)
    }
}
```

