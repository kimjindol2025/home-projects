## 🎓 v5.8 설계 패턴

### 패턴 1: 문서 관리 시스템

```rust
// 계층 구조
#[derive(Debug, Clone)]
enum DocumentStatus {
    Draft,
    Review { reviewer_id: u32 },
    Published { published_date: String },
    Archived,
}

struct Document {
    id: u32,
    title: String,
    status: DocumentStatus,
}

struct DocumentSystem {
    documents: HashMap<u32, Document>,
    history: Vec<String>,
}

impl DocumentSystem {
    fn submit_for_review(&mut self, id: u32, reviewer_id: u32) -> Result<(), String> {
        let doc = self.documents.get_mut(&id)
            .ok_or("문서를 찾을 수 없음")?;

        if !matches!(doc.status, DocumentStatus::Draft) {
            return Err("Draft 상태만 리뷰 가능".to_string());
        }

        doc.status = DocumentStatus::Review { reviewer_id };
        self.history.push(format!("문서 {} 리뷰 요청", id));
        Ok(())
    }
}
```

