## 🎓 gogs.toml 파싱 로직

```rust
// 의사코드

struct Project {
  name: String,
  version: String,
  dependencies: Map<String, Dependency>,
}

struct Dependency {
  version: String,
  path: Option<String>,
  git: Option<String>,
  features: Vec<String>,
}

fn parse_gogs_toml(content: String) -> Project {
  // 1. TOML 파싱
  let toml = parse_toml(content);

  // 2. [package] 섹션 추출
  let package = toml["package"];
  let name = package["name"].as_string();
  let version = package["version"].as_string();

  // 3. [dependencies] 섹션 추출
  let mut deps = Map::new();
  for (key, value) in toml["dependencies"] {
    deps.insert(key, parse_dependency(value));
  }

  Project {
    name,
    version,
    dependencies: deps,
  }
}

fn resolve_dependencies(project: &Project) -> Result<Vec<Dependency>> {
  // 1. 각 의존성의 버전 해결
  for dep in project.dependencies {
    // SemVer 규칙 적용
    let resolved = resolve_version(&dep.version)?;

    // 2. 레지스트리에서 다운로드
    download_package(&dep.name, resolved)?;

    // 3. 의존성의 의존성 해결 (재귀)
    resolve_dependencies(&load_transitive_deps(...))?;
  }

  Ok(resolved_list)
}
```

