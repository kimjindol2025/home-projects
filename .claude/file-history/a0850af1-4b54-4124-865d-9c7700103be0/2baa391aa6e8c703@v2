## 🚀 함수형 매크로의 실무 예시

### 예시 1: 간단한 쿼리 빌더

```rust
#[proc_macro]
pub fn query(input: TokenStream) -> TokenStream {
    let query_str = input.to_string();

    // 간단한 SQL 검증
    if !query_str.starts_with("SELECT") {
        return quote! {
            compile_error!("Query must start with SELECT")
        }.into();
    }

    let cleaned = query_str.trim_matches(|c| c == '"' || c == '!');

    quote! {
        Query::new(#cleaned)
    }.into()
}

// 사용
let users = query!("SELECT * FROM users WHERE active = true");
```

### 예시 2: 상태 머신 정의

```rust
#[proc_macro]
pub fn state_machine(input: TokenStream) -> TokenStream {
    // input: "Init => Running => Complete"
    let states = parse_states(&input.to_string());

    quote! {
        StateMachine {
            states: vec![#(#states),*],
            current: 0,
        }
    }.into()
}

// 사용
let machine = state_machine!(Init => Running => Complete);
```

