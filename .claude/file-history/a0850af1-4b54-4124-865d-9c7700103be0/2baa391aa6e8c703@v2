### 커스텀 문법 예시 1: SQL

```rust
#[proc_macro]
pub fn sql(input: TokenStream) -> TokenStream {
    let input_str = input.to_string();

    // 간단한 SQL 검증
    if !input_str.contains("SELECT") && !input_str.contains("INSERT") {
        return quote! {
            compile_error!("Invalid SQL query")
        }.into();
    }

    // SQL을 Rust 구조로 변환
    let query = input_str.trim_matches(|c| c == '"' || c == '\'' || c == '!');

    quote! {
        DbQuery {
            raw_sql: #query,
            params: vec![],
        }
    }.into()
}

// 사용
let q = sql!("SELECT * FROM users WHERE id = ?");
```

### 커스텀 문법 예시 2: HTML

```rust
#[proc_macro]
pub fn html(input: TokenStream) -> TokenStream {
    let input_str = input.to_string();

    // 1. HTML 구조 검증 (트리 구조가 올바른지)
    if !is_valid_html(&input_str) {
        return quote! {
            compile_error!("Invalid HTML structure")
        }.into();
    }

    // 2. HTML을 구조로 파싱
    let dom = parse_html(&input_str);

    // 3. Rust 코드로 변환
    generate_rust_code(&dom).into()
}

// 사용
let elem = html!(<div class="container">
    <h1>Title</h1>
    <p>Content</p>
</div>);
```

