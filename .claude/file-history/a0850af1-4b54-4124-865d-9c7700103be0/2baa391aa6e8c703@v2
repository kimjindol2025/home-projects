## 💭 실무 속성 매크로 패턴

### 패턴 1: 로깅 주입

```rust
#[proc_macro_attribute]
pub fn log_calls(_attr: TokenStream, item: TokenStream) -> TokenStream {
    let input_fn = syn::parse_macro_input!(item as syn::ItemFn);
    let fn_name = &input_fn.sig.ident;
    let fn_sig = &input_fn.sig;
    let fn_block = &input_fn.block;
    let fn_vis = &input_fn.vis;

    quote! {
        #fn_vis #fn_sig {
            println!("[LOG] Entering: {}", stringify!(#fn_name));
            let result = (|| #fn_block)();
            println!("[LOG] Exiting: {}", stringify!(#fn_name));
            result
        }
    }.into()
}

// 사용
#[log_calls]
fn important_operation() {
    println!("실제 작업 중...");
}
// 호출 시 자동으로 시작/종료 로그 출력
```

### 패턴 2: 성능 측정

```rust
#[proc_macro_attribute]
pub fn measure_time(_attr: TokenStream, item: TokenStream) -> TokenStream {
    let input_fn = syn::parse_macro_input!(item as syn::ItemFn);
    let fn_name = &input_fn.sig.ident;
    let fn_sig = &input_fn.sig;
    let fn_block = &input_fn.block;
    let fn_vis = &input_fn.vis;

    quote! {
        #fn_vis #fn_sig {
            let start = std::time::Instant::now();
            let result = (|| #fn_block)();
            let elapsed = start.elapsed();
            println!("[PERF] {} took {:?}", stringify!(#fn_name), elapsed);
            result
        }
    }.into()
}

// 사용
#[measure_time]
fn expensive_computation() {
    // ... 무거운 계산 ...
}
// 호출 시 자동으로 실행 시간 측정 및 출력
```

### 패턴 3: 권한 검사

```rust
#[proc_macro_attribute]
pub fn require_auth(attr: TokenStream, item: TokenStream) -> TokenStream {
    let role_required = syn::parse_macro_input!(attr as syn::LitStr).value();
    let input_fn = syn::parse_macro_input!(item as syn::ItemFn);
    let fn_name = &input_fn.sig.ident;
    let fn_sig = &input_fn.sig;
    let fn_block = &input_fn.block;
    let fn_vis = &input_fn.vis;

    quote! {
        #fn_vis #fn_sig {
            if !check_permission(#role_required) {
                panic!("권한 부족: {}", #role_required);
            }
            (|| #fn_block)()
        }
    }.into()
}

// 사용
#[require_auth("admin")]
fn delete_database() {
    // ... 위험한 작업 ...
}
// 호출 시 자동으로 권한 확인
```

### 패턴 4: 캐싱 레이어

```rust
#[proc_macro_attribute]
pub fn cacheable(_attr: TokenStream, item: TokenStream) -> TokenStream {
    let input_fn = syn::parse_macro_input!(item as syn::ItemFn);
    let fn_name = &input_fn.sig.ident;
    let fn_sig = &input_fn.sig;
    let fn_block = &input_fn.block;
    let fn_vis = &input_fn.vis;

    quote! {
        #fn_vis #fn_sig {
            let cache_key = format!("{}:{:?}", stringify!(#fn_name), ());
            if let Some(cached) = get_cache(&cache_key) {
                return cached;
            }
            let result = (|| #fn_block)();
            set_cache(&cache_key, result.clone());
            result
        }
    }.into()
}

// 사용
#[cacheable]
fn expensive_db_query() -> Vec<User> {
    // ... 데이터베이스 조회 ...
}
// 호출 시 자동으로 캐시 확인
```

### 패턴 5: 보안 감사 (GOGS)

```rust
#[proc_macro_attribute]
pub fn gogs_audit(_attr: TokenStream, item: TokenStream) -> TokenStream {
    let input_fn = syn::parse_macro_input!(item as syn::ItemFn);
    let fn_name = &input_fn.sig.ident;
    let fn_sig = &input_fn.sig;
    let fn_block = &input_fn.block;
    let fn_vis = &input_fn.vis;

    quote! {
        #fn_vis #fn_sig {
            println!("  [GOGS AUDIT] 명령 실행 감지: '{}'", stringify!(#fn_name));
            println!("  [GOGS AUDIT] 기록이 증명이다 - 실행 시각: 2026-02-23");
            let result = (|| #fn_block)();
            println!("  [GOGS AUDIT] 명령 종료.");
            result
        }
    }.into()
}

// 사용
#[gogs_audit]
fn sensitive_operation() {
    // ... 중요한 작업 ...
}
// 모든 호출이 자동으로 기록됨
```

