# [탐구 6] 함수 조합 (Function Composition)
# ============================================================================

print("\n" + "="*70)
print("# [탐구 6] 함수 조합 (Function Composition)")
print("="*70)

def compose(f: Callable, g: Callable) -> Callable:
    """
    두 함수를 조합하여 f(g(x))를 계산하는 새로운 함수를 반환합니다.

    수학: (f ∘ g)(x) = f(g(x))
    """
    def composed(x):
        return f(g(x))
    return composed


print(f"\n[함수 조합]")

def add_one(x):
    return x + 1

def double(x):
    return x * 2

# (add_one ∘ double)(5) = add_one(double(5)) = add_one(10) = 11
add_then_double = compose(double, add_one)
double_then_add = compose(add_one, double)

print(f"  add_one(x) = x + 1")
print(f"  double(x) = x * 2")
print(f"  compose(double, add_one)(5) = double(add_one(5)) = {add_then_double(5)}")
print(f"  compose(add_one, double)(5) = add_one(double(5)) = {double_then_add(5)}")

print(f"\n[복잡한 조합]")

def square(x):
    return x ** 2

# 함수 체인 구축
step1 = compose(double, add_one)      # x+1, *2
step2 = compose(square, step1)        # 위 결과를 제곱

result = step2(3)  # ((3+1)*2)^2 = (8)^2 = 64
print(f"  step1(3) = (3+1)*2 = {step1(3)}")
print(f"  step2(3) = ((3+1)*2)^2 = {result}")


