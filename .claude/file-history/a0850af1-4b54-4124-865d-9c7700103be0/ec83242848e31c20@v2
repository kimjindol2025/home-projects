"""
Python v1.3 - 일급 객체로서의 함수 (First-class Functions)

탐구(대학): "함수는 데이터다"

파이썬에서 함수는 특별한 것이 아닙니다.
함수는 변수에 할당될 수 있고,
다른 함수의 인자로 전달될 수 있으며,
함수의 결과로 반환될 수도 있습니다.

이것이 '일급 객체(First-class Object)'의 정의입니다.
"""

import sys
from typing import Callable, Any


# ============================================================================
# [탐구 1] 함수는 객체다 - 메타데이터 확인
# ============================================================================

print("\n" + "="*70)
print("# [탐구 1] 함수는 객체다 - 메타데이터")
print("="*70)

def greet(name):
    """사람을 인사하는 함수"""
    return f"Hello, {name}!"


print(f"\n[함수는 객체]")
print(f"  함수: greet")
print(f"  타입: {type(greet)}")
print(f"  메모리: {sys.getsizeof(greet)} bytes")

print(f"\n[함수의 속성]")
print(f"  __name__: {greet.__name__}")
print(f"  __doc__: {greet.__doc__}")
print(f"  __module__: {greet.__module__}")
print(f"  __annotations__: {greet.__annotations__}")

print(f"\n[함수의 코드]")
print(f"  __code__: {greet.__code__}")
print(f"  __code__.co_varnames: {greet.__code__.co_varnames}")
print(f"  __code__.co_argcount: {greet.__code__.co_argcount}")


# ============================================================================
# [탐구 2] 함수를 변수에 할당하기
# ============================================================================

print("\n" + "="*70)
print("# [탐구 2] 함수를 변수에 할당")
print("="*70)

print(f"\n[할당]")
greet_func = greet  # 함수를 변수에 할당
print(f"  greet_func = greet")
print(f"  greet_func('Alice'): {greet_func('Alice')}")

print(f"\n[같은 객체인가?]")
print(f"  greet is greet_func: {greet is greet_func}")
print(f"  id(greet): {hex(id(greet))}")
print(f"  id(greet_func): {hex(id(greet_func))}")

print(f"\n[함수 컬렉션]")
functions = [greet, greet_func]
print(f"  functions = [greet, greet_func]")
print(f"  functions[0]('Bob'): {functions[0]('Bob')}")
print(f"  functions[1]('Charlie'): {functions[1]('Charlie')}")

print(f"\n[함수 딕셔너리]")
func_dict = {
    "greeting": greet,
    "farewell": lambda name: f"Goodbye, {name}!"
}
print(f"  func_dict['greeting']('David'): {func_dict['greeting']('David')}")
print(f"  func_dict['farewell']('Eve'): {func_dict['farewell']('Eve')}")


# ============================================================================
# [탐구 3] 함수를 인자로 전달하기 (고차 함수)
# ============================================================================

print("\n" + "="*70)
print("# [탐구 3] 함수를 인자로 전달 (Higher-order Function)")
print("="*70)

def apply_to_list(lst: list, func: Callable) -> list:
    """
    리스트의 각 요소에 함수를 적용합니다.

    매개변수:
      lst: 리스트
      func: 각 요소에 적용할 함수
    """
    return [func(item) for item in lst]


print(f"\n[기본 예제]")
numbers = [1, 2, 3, 4, 5]

def square(x):
    return x ** 2

def is_even(x):
    return x % 2 == 0

print(f"  numbers: {numbers}")
print(f"  apply_to_list(numbers, square): {apply_to_list(numbers, square)}")
print(f"  apply_to_list(numbers, is_even): {apply_to_list(numbers, is_even)}")

print(f"\n[람다 함수 사용]")
print(f"  apply_to_list(numbers, lambda x: x*2): {apply_to_list(numbers, lambda x: x*2)}")
print(f"  apply_to_list(numbers, lambda x: x > 2): {apply_to_list(numbers, lambda x: x > 2)}")

print(f"\n[함수 시그니처의 유연성]")
def process_data(data, processor, transformer):
    """
    데이터를 처리하고 변환합니다.
    """
    processed = processor(data)
    transformed = transformer(processed)
    return transformed

print(f"  process_data(10, lambda x: x*2, lambda x: x+5):")
result = process_data(10, lambda x: x*2, lambda x: x+5)
print(f"    (10*2)+5 = {result}")


# ============================================================================
# [탐구 4] 함수가 함수를 반환하기
# ============================================================================

print("\n" + "="*70)
print("# [탐구 4] 함수가 함수를 반환 (Function Returning Function)")
print("="*70)

def make_multiplier(factor: int) -> Callable:
    """
    지정된 배수만큼 곱하는 함수를 생성합니다.

    이것은 '함수 팩토리(Function Factory)'입니다.
    """
    def multiplier(x):
        return x * factor
    return multiplier


print(f"\n[함수 팩토리]")
double = make_multiplier(2)
triple = make_multiplier(3)

print(f"  double = make_multiplier(2)")
print(f"  triple = make_multiplier(3)")
print(f"  double(5): {double(5)}")
print(f"  triple(5): {triple(5)}")

print(f"\n[반환된 함수의 정보]")
print(f"  type(double): {type(double)}")
print(f"  double.__name__: {double.__name__}")
print(f"  double.__closure__: {double.__closure__}")  # 클로저 정보

print(f"\n[클로저의 의미]")
print(f"  반환된 함수는 make_multiplier의 factor를 '기억'합니다")
print(f"  factor = {double.__closure__[0].cell_contents}")


# ============================================================================
# [탐구 5] 클로저와 상태 보존
# ============================================================================

print("\n" + "="*70)
print("# [탐구 5] 클로저 (Closure) - 함수가 상태를 기억하다")
print("="*70)

def make_counter() -> Callable:
    """
    호출될 때마다 증가하는 카운터를 생성합니다.

    클로저: 함수가 정의된 스코프의 변수를 '기억'하는 메커니즘
    """
    count = 0

    def counter():
        nonlocal count  # 외부 스코프의 변수 수정
        count += 1
        return count

    return counter


print(f"\n[카운터 생성]")
counter1 = make_counter()
counter2 = make_counter()

print(f"  counter1 = make_counter()")
print(f"  counter1(): {counter1()}")
print(f"  counter1(): {counter1()}")
print(f"  counter1(): {counter1()}")

print(f"\n[독립적인 상태]")
print(f"  counter2 = make_counter()")
print(f"  counter2(): {counter2()}")
print(f"  counter2(): {counter2()}")

print(f"\n[클로저 변수 확인]")
print(f"  counter1 클로저 변수:")
for i, cell in enumerate(counter1.__closure__):
    print(f"    [{i}] {cell.cell_contents}")


