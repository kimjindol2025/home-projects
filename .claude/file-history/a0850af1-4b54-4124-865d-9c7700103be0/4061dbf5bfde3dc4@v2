## 🌳 AST 구조

```rust
#[derive(Debug, Clone, PartialEq)]
pub enum Expression {
    // 리터럴
    Literal(i32),

    // 전위 연산 (단항)
    Prefix {
        operator: PrefixOp,
        operand: Box<Expression>,
    },

    // 중위 연산 (이항)
    Infix {
        left: Box<Expression>,
        operator: InfixOp,
        right: Box<Expression>,
    },
}

#[derive(Debug, Clone, PartialEq)]
pub enum PrefixOp {
    Minus,    // -x
    Bang,     // !x (NOT)
}

#[derive(Debug, Clone, PartialEq)]
pub enum InfixOp {
    Plus,
    Minus,
    Multiply,
    Divide,
    Equal,
    NotEqual,
    Less,
    LessEqual,
    Greater,
    GreaterEqual,
}
```

