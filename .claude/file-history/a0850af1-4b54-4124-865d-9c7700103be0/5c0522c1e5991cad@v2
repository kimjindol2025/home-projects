"""
Python v1.4 - 연산자 오버로딩 (Operator Overloading)

증명(대학원): "Gogs 벡터 클래스 - 수학적 연산의 우아한 표현"

Gogs-Lang이나 Rust에서는 엄격한 Trait를 구현해야 했지만,
파이썬에서는 매직 메소드만 정의하면 됩니다.

예:
  v1 + v2             → v1.__add__(v2)
  v1 * 2              → v1.__mul__(2)
  -v1                 → v1.__neg__()
  len(v1)             → v1.__len__()
  v1[0]               → v1.__getitem__(0)
"""

import math
from typing import Union, Tuple


# ============================================================================
# [탐구] GogsVector - 수학적 벡터의 우아한 표현
# ============================================================================

print("\n" + "="*70)
print("# GogsVector - 매직 메소드를 통한 수학적 연산")
print("="*70)


class GogsVector:
    """
    2D 벡터를 나타내는 클래스.
    매직 메소드를 통해 수학적 연산을 자연스럽게 표현합니다.

    예:
      v1 = GogsVector(3, 4)
      v2 = GogsVector(1, 2)
      v1 + v2              # 벡터 덧셈
      v1 * 2               # 스칼라곱
      len(v1)              # 벡터의 크기
    """

    def __init__(self, x: float, y: float):
        """벡터 초기화"""
        self.x = x
        self.y = y

    def __repr__(self) -> str:
        """개발자용 표현"""
        return f"GogsVector({self.x}, {self.y})"

    def __str__(self) -> str:
        """사용자용 표현"""
        return f"({self.x}, {self.y})"

    # ====== 산술 연산 ======

    def __add__(self, other: "GogsVector") -> "GogsVector":
        """+ 연산자: 벡터 덧셈"""
        if isinstance(other, GogsVector):
            return GogsVector(self.x + other.x, self.y + other.y)
        return NotImplemented

    def __sub__(self, other: "GogsVector") -> "GogsVector":
        """- 연산자: 벡터 뺄셈"""
        if isinstance(other, GogsVector):
            return GogsVector(self.x - other.x, self.y - other.y)
        return NotImplemented

    def __mul__(self, scalar: Union[int, float]) -> "GogsVector":
        """* 연산자: 스칼라곱"""
        if isinstance(scalar, (int, float)):
            return GogsVector(self.x * scalar, self.y * scalar)
        return NotImplemented

    def __rmul__(self, scalar: Union[int, float]) -> "GogsVector":
        """역순 * 연산자: scalar * vector"""
        return self.__mul__(scalar)

    def __truediv__(self, scalar: Union[int, float]) -> "GogsVector":
        """/ 연산자: 스칼라 나눗셈"""
        if isinstance(scalar, (int, float)):
            if scalar == 0:
                raise ValueError("0으로 나눌 수 없습니다")
            return GogsVector(self.x / scalar, self.y / scalar)
        return NotImplemented

    def __neg__(self) -> "GogsVector":
        """단항 - 연산자: 벡터의 역벡터"""
        return GogsVector(-self.x, -self.y)

    def __pos__(self) -> "GogsVector":
        """단항 + 연산자: 양의 벡터"""
        return GogsVector(self.x, self.y)

    # ====== 비교 연산 ======

    def __eq__(self, other: "GogsVector") -> bool:
        """== 연산자"""
        if isinstance(other, GogsVector):
            return self.x == other.x and self.y == other.y
        return NotImplemented

    def __ne__(self, other: "GogsVector") -> bool:
        """!= 연산자"""
        result = self.__eq__(other)
        if result is NotImplemented:
            return result
        return not result

    # ====== 컨테이너 프로토콜 ======

    def __len__(self) -> int:
        """len() 함수: 벡터의 크기(정수로 반올림)"""
        return int(self.magnitude())

    def __getitem__(self, index: int) -> float:
        """인덱싱: v[0] = x, v[1] = y"""
        if index == 0:
            return self.x
        elif index == 1:
            return self.y
        else:
            raise IndexError(f"벡터는 2차원입니다. 인덱스 {index}는 범위 밖입니다")

    def __iter__(self):
        """이터레이션: for x, y in v:"""
        yield self.x
        yield self.y

    # ====== 해시 ======

    def __hash__(self) -> int:
        """딕셔너리 키로 사용 가능하게 만들기"""
        return hash((self.x, self.y))

    # ====== 유틸리티 메소드 ======

    def magnitude(self) -> float:
        """벡터의 크기 (크기)"""
        return math.sqrt(self.x**2 + self.y**2)

    def dot_product(self, other: "GogsVector") -> float:
        """내적 (dot product)"""
        if isinstance(other, GogsVector):
            return self.x * other.x + self.y * other.y
        return NotImplemented

    def normalize(self) -> "GogsVector":
        """정규화된 단위 벡터"""
        mag = self.magnitude()
        if mag == 0:
            raise ValueError("0 벡터는 정규화할 수 없습니다")
        return self / mag


# ============================================================================
# [실증 실험]
# ============================================================================

print(f"\n[벡터 생성]")
v1 = GogsVector(3, 4)
v2 = GogsVector(1, 2)

print(f"  v1 = {v1}")
print(f"  v2 = {v2}")

print(f"\n[덧셈 - __add__]")
v_sum = v1 + v2
print(f"  v1 + v2 = {v_sum}")

print(f"\n[뺄셈 - __sub__]")
v_diff = v1 - v2
print(f"  v1 - v2 = {v_diff}")

print(f"\n[스칼라곱 - __mul__, __rmul__]")
v_scaled = v1 * 2
print(f"  v1 * 2 = {v_scaled}")
v_scaled2 = 3 * v1
print(f"  3 * v1 = {v_scaled2}")

print(f"\n[스칼라 나눗셈 - __truediv__]")
v_div = v1 / 2
print(f"  v1 / 2 = {v_div}")

print(f"\n[역벡터 - __neg__]")
v_neg = -v1
print(f"  -v1 = {v_neg}")

print(f"\n[비교 - __eq__]")
v3 = GogsVector(3, 4)
print(f"  v1 == v3 (same values): {v1 == v3}")
print(f"  v1 == v2 (different): {v1 == v2}")
print(f"  v1 != v2: {v1 != v2}")

print(f"\n[크기 - __len__]")
print(f"  len(v1): {len(v1)}")
print(f"  len(v2): {len(v2)}")
print(f"  실제 크기: {v1.magnitude():.2f}")

print(f"\n[인덱싱 - __getitem__]")
print(f"  v1[0] (x): {v1[0]}")
print(f"  v1[1] (y): {v1[1]}")

print(f"\n[이터레이션 - __iter__]")
print(f"  좌표 추출: x, y = v1")
x, y = v1
print(f"    x={x}, y={y}")

print(f"\n  개별 반복:")
for coord in v1:
    print(f"    {coord}")

print(f"\n[해시 - __hash__]")
vector_dict = {v1: "벡터1", v2: "벡터2"}
print(f"  vector_dict[v1]: {vector_dict[v1]}")
print(f"  vector_dict[v2]: {vector_dict[v2]}")

print(f"\n[벡터 연산]")
print(f"  v1의 크기: {v1.magnitude():.2f}")
print(f"  v1·v2 (내적): {v1.dot_product(v2)}")
print(f"  v1 정규화: {v1.normalize()}")


