print("="*70)


class Book:
    """책을 나타내는 클래스"""

    def __init__(self, title: str, pages: int):
        self.title = title
        self.pages = pages

    def __repr__(self) -> str:
        return f"Book('{self.title}', {self.pages}p)"

    def __eq__(self, other) -> bool:
        """== 연산자"""
        if isinstance(other, Book):
            return self.pages == other.pages
        return NotImplemented

    def __lt__(self, other) -> bool:
        """< 연산자"""
        if isinstance(other, Book):
            return self.pages < other.pages
        return NotImplemented

    def __le__(self, other) -> bool:
        """<= 연산자"""
        if isinstance(other, Book):
            return self.pages <= other.pages
        return NotImplemented


book1 = Book("Python Guide", 500)
book2 = Book("JavaScript Intro", 500)
book3 = Book("Go Basics", 300)

print(f"\n[비교]")
print(f"  book1: {book1}")
print(f"  book2: {book2}")
print(f"  book3: {book3}")

print(f"\n[== 연산자]")
print(f"  book1 == book2: {book1 == book2}  (모두 500페이지)")
print(f"  book1 == book3: {book1 == book3}")

print(f"\n[< 연산자]")
print(f"  book3 < book1: {book3 < book1}  (300 < 500)")
print(f"  book1 < book3: {book1 < book3}")

print(f"\n[<= 연산자]")
print(f"  book1 <= book2: {book1 <= book2}")


