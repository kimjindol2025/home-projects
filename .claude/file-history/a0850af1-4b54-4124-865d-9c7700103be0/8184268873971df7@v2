print("="*70)


class Playlist:
    """음악 플레이리스트"""

    def __init__(self, name: str, songs: list):
        self.name = name
        self.songs = songs

    def __repr__(self) -> str:
        return f"Playlist('{self.name}', {len(self.songs)} songs)"

    def __len__(self) -> int:
        """len() 함수 지원"""
        return len(self.songs)

    def __getitem__(self, index: int) -> str:
        """인덱싱 지원: playlist[0]"""
        return self.songs[index]

    def __contains__(self, item: str) -> bool:
        """'in' 연산자 지원"""
        return item in self.songs


playlist = Playlist("Rock Classics", [
    "Bohemian Rhapsody",
    "Stairway to Heaven",
    "Hotel California"
])

print(f"\n[__len__()]")
print(f"  len(playlist): {len(playlist)}")

print(f"\n[__getitem__()]")
print(f"  playlist[0]: {playlist[0]}")
print(f"  playlist[1]: {playlist[1]}")

print(f"\n[__contains__()]")
print(f"  'Bohemian Rhapsody' in playlist: {'Bohemian Rhapsody' in playlist}")
print(f"  'Unknown Song' in playlist: {'Unknown Song' in playlist}")

print(f"\n[이터레이션]")
print(f"  for song in playlist:")
for song in playlist:
    print(f"    - {song}")


