"""
Python v1.4 - 매직 메소드의 기초 (Magic Methods)

탐구(대학): "객체는 어떻게 언어 문법과 대화하는가?"

더블 언더스코어(__) 메소드를 정의하는 것만으로
객체에 특수한 능력을 부여할 수 있습니다.

예:
  a + b           → a.__add__(b)
  len(a)          → a.__len__()
  print(a)        → a.__str__()
  a == b          → a.__eq__(b)
  a[0]            → a.__getitem__(0)
  for x in a:     → a.__iter__()
"""


# ============================================================================
# [탐구 1] 객체의 문자열 표현 - __repr__과 __str__
# ============================================================================

print("\n" + "="*70)
print("# [탐구 1] 객체의 문자열 표현")
print("="*70)


class Person:
    """사람을 나타내는 클래스"""

    def __init__(self, name: str, age: int):
        self.name = name
        self.age = age

    def __repr__(self) -> str:
        """
        개발자용 표현 (unambiguous)
        eval()로 실행 가능한 형태가 이상적
        """
        return f"Person('{self.name}', {self.age})"

    def __str__(self) -> str:
        """
        사용자용 표현 (readable)
        print()에서 호출됨
        """
        return f"{self.name}(age {self.age})"


person = Person("Alice", 30)

print(f"\n[__str__() - 사용자용]")
print(f"  str(person): {str(person)}")
print(f"  print(person): {person}")

print(f"\n[__repr__() - 개발자용]")
print(f"  repr(person): {repr(person)}")
print(f"  인터프리터: {person!r}")


