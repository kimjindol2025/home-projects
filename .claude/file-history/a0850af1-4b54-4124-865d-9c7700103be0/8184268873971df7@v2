class FileHandler:
    """파일을 안전하게 다루는 컨텍스트 매니저"""

    def __init__(self, filename: str, mode: str = 'r'):
        self.filename = filename
        self.mode = mode
        self.file = None

    def __enter__(self):
        """with 블록 진입 시"""
        print(f"  [ENTER] '{self.filename}' 파일 열기")
        # 실제로는 파일을 열지만, 여기서는 시뮬레이션
        self.file = f"<File '{self.filename}'>"
        return self.file

    def __exit__(self, exc_type, exc_val, exc_tb):
        """with 블록 퇴출 시 (에러 발생 여부와 관계없이)"""
        print(f"  [EXIT] '{self.filename}' 파일 닫기")

        if exc_type is not None:
            print(f"  [ERROR] {exc_type.__name__}: {exc_val}")

        return False  # 에러 전파


print(f"\n[정상 실행]")
with FileHandler("data.txt", "r") as f:
    print(f"  파일 내용: {f}")

print(f"\n[에러 발생 시에도 __exit__ 호출됨]")
try:
    with FileHandler("config.json", "r") as f:
        print(f"  파일: {f}")
        raise ValueError("설정 파싱 에러")
except ValueError as e:
    print(f"  예외 처리됨: {e}")


