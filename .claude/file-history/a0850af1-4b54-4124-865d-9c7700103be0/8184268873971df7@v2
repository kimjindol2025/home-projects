class SafeDict:
    """속성 접근을 로깅하는 딕셔너리"""

    def __init__(self, **kwargs):
        self._data = kwargs

    def __getattr__(self, name: str):
        """속성 접근 시"""
        if name.startswith('_'):
            return object.__getattribute__(self, name)

        print(f"  [GET] '{name}' 접근")
        return self._data.get(name, "Not found")

    def __setattr__(self, name: str, value) -> None:
        """속성 설정 시"""
        if name.startswith('_'):
            object.__setattr__(self, name, value)
        else:
            print(f"  [SET] '{name}' = {value}")
            self._data[name] = value

    def __repr__(self) -> str:
        return f"SafeDict({self._data})"


safe = SafeDict(name="Alice", age=30)

print(f"\n[__getattr__()]")
print(f"  safe.name: {safe.name}")
print(f"  safe.age: {safe.age}")
print(f"  safe.email: {safe.email}")

print(f"\n[__setattr__()]")
print(f"  safe.email = 'alice@example.com'")
safe.email = "alice@example.com"

print(f"\n[최종 상태]")
print(f"  {safe}")


