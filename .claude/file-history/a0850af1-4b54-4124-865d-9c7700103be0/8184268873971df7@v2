class Multiplier:
    """곱셈 함수처럼 작동하는 클래스"""

    def __init__(self, factor: int):
        self.factor = factor

    def __call__(self, x: int) -> int:
        """
        __call__을 구현하면 인스턴스를 함수처럼 호출할 수 있습니다.
        """
        return x * self.factor

    def __repr__(self) -> str:
        return f"Multiplier({self.factor})"


double = Multiplier(2)
triple = Multiplier(3)

print(f"\n[__call__() - 객체를 함수처럼 호출]")
print(f"  double = Multiplier(2)")
print(f"  double(5): {double(5)}")
print(f"  double(10): {double(10)}")

print(f"\n  triple = Multiplier(3)")
print(f"  triple(5): {triple(5)}")

print(f"\n[실제 함수와의 차이]")
print(f"  callable(double): {callable(double)}")
print(f"  type(double): {type(double)}")
print(f"  isinstance(double, Multiplier): {isinstance(double, Multiplier)}")


