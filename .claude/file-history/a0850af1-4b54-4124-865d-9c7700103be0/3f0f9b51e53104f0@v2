from flask import Flask, request, jsonify
import sqlite3
import json
from datetime import datetime
from typing import Dict, List, Tuple, Any


# ==================== Flask 앱 설정 ====================

app = Flask(__name__)
DB_FILE = 'gogs_research.db'


def get_db_connection():
    """데이터베이스 연결"""
    conn = sqlite3.connect(DB_FILE)
    conn.row_factory = sqlite3.Row  # 결과를 딕셔너리로 반환
    return conn


# ==================== PHASE 1: GET 메서드 (READ) ====================

@app.route('/api/researchers', methods=['GET'])
def get_researchers():
    """
    【 GET /api/researchers 】
    모든 연구자 목록 조회

    응답:
        200 OK: 연구자 목록
        500 Server Error: 데이터베이스 오류
    """
    try:
        conn = get_db_connection()
        cursor = conn.cursor()
        cursor.execute("SELECT * FROM researchers")
        researchers = [dict(row) for row in cursor.fetchall()]
        conn.close()

        return jsonify({
            'status': 'success',
            'count': len(researchers),
            'data': researchers
        }), 200

    except Exception as e:
        return jsonify({
            'status': 'error',
            'message': str(e)
        }), 500


@app.route('/api/researchers/<int:researcher_id>', methods=['GET'])
def get_researcher(researcher_id):
    """
    【 GET /api/researchers/{id} 】
    특정 연구자 상세 조회
    """
    try:
        conn = get_db_connection()
        cursor = conn.cursor()
        cursor.execute("SELECT * FROM researchers WHERE researcher_id = ?", (researcher_id,))
        row = cursor.fetchone()
        conn.close()

        if not row:
            return jsonify({
                'status': 'error',
                'message': f'Researcher {researcher_id} not found'
            }), 404

        return jsonify({
            'status': 'success',
            'data': dict(row)
        }), 200

    except Exception as e:
        return jsonify({'status': 'error', 'message': str(e)}), 500


@app.route('/api/experiments', methods=['GET'])
def get_experiments():
    """
    【 GET /api/experiments 】
    모든 실험 프로젝트 조회 (JOIN 사용)
    """
    try:
        conn = get_db_connection()
        cursor = conn.cursor()
        cursor.execute("""
            SELECT
                e.experiment_id,
                e.title,
                e.description,
                e.status,
                e.start_date,
                e.end_date,
                r.name as researcher_name,
                r.researcher_id
            FROM experiments e
            JOIN researchers r ON e.researcher_id = r.researcher_id
            ORDER BY e.experiment_id DESC
        """)
        experiments = [dict(row) for row in cursor.fetchall()]
        conn.close()

        return jsonify({
            'status': 'success',
            'count': len(experiments),
            'data': experiments
        }), 200

    except Exception as e:
        return jsonify({'status': 'error', 'message': str(e)}), 500


@app.route('/api/measurements', methods=['GET'])
def get_measurements():
    """
    【 GET /api/measurements 】
    모든 측정 결과 조회
    """
    try:
        conn = get_db_connection()
        cursor = conn.cursor()
        cursor.execute("""
            SELECT
                m.measurement_id,
                m.metric_name,
                m.value,
                m.unit,
                m.recorded_at,
                e.title as experiment_title
            FROM measurements m
            JOIN experiments e ON m.experiment_id = e.experiment_id
            ORDER BY m.recorded_at DESC
            LIMIT 20
        """)
        measurements = [dict(row) for row in cursor.fetchall()]
        conn.close()

        return jsonify({
            'status': 'success',
            'count': len(measurements),
            'data': measurements
        }), 200

    except Exception as e:
        return jsonify({'status': 'error', 'message': str(e)}), 500


# ==================== PHASE 2: POST 메서드 (CREATE) ====================

@app.route('/api/researchers', methods=['POST'])
def create_researcher():
    """
    【 POST /api/researchers 】
    새 연구자 추가

    요청:
        {
            "name": "박새로움",
            "department": "정보통신공학과",
            "email": "park.new@gogs.dev"
        }
    """
    try:
        data = request.get_json()

        # 입력 검증
        if not data or 'name' not in data:
            return jsonify({'status': 'error', 'message': 'Missing required field: name'}), 400

        if not data['name'].strip():
            return jsonify({'status': 'error', 'message': 'Name cannot be empty'}), 400

        conn = get_db_connection()
        cursor = conn.cursor()

        try:
            cursor.execute(
                "INSERT INTO researchers (name, department, email) VALUES (?, ?, ?)",
                (data['name'], data.get('department'), data.get('email'))
            )
            conn.commit()
            researcher_id = cursor.lastrowid
            conn.close()

            return jsonify({
                'status': 'success',
                'message': f'Researcher created with ID {researcher_id}',
                'researcher_id': researcher_id
            }), 201  # 201 Created

        except sqlite3.IntegrityError as e:
            conn.close()
            return jsonify({
                'status': 'error',
                'message': 'Duplicate name or constraint violation'
            }), 409  # 409 Conflict

    except Exception as e:
        return jsonify({'status': 'error', 'message': str(e)}), 500


@app.route('/api/measurements', methods=['POST'])
def create_measurement():
    """
    【 POST /api/measurements 】
    새 측정 결과 추가
    """
    try:
        data = request.get_json()

        # 입력 검증
        required = ['experiment_id', 'metric_name', 'value']
        if not all(field in data for field in required):
            return jsonify({'status': 'error', 'message': f'Missing fields: {required}'}), 400

        conn = get_db_connection()
        cursor = conn.cursor()

        cursor.execute(
            "INSERT INTO measurements (experiment_id, metric_name, value, unit) VALUES (?, ?, ?, ?)",
            (data['experiment_id'], data['metric_name'], data['value'], data.get('unit'))
        )
        conn.commit()
        measurement_id = cursor.lastrowid
        conn.close()

        return jsonify({
            'status': 'success',
            'message': f'Measurement created with ID {measurement_id}',
            'measurement_id': measurement_id
        }), 201

    except Exception as e:
        return jsonify({'status': 'error', 'message': str(e)}), 500


# ==================== PHASE 3: PUT 메서드 (UPDATE) ====================

@app.route('/api/experiments/<int:experiment_id>', methods=['PUT'])
def update_experiment(experiment_id):
    """
    【 PUT /api/experiments/{id} 】
    실험 상태 업데이트

    요청:
        {
            "status": "완료"
        }
    """
    try:
        data = request.get_json()

        if 'status' not in data:
            return jsonify({'status': 'error', 'message': 'Missing field: status'}), 400

        valid_statuses = ['진행중', '완료', '중단']
        if data['status'] not in valid_statuses:
            return jsonify({'status': 'error', 'message': f'Invalid status. Must be one of {valid_statuses}'}), 400

        conn = get_db_connection()
        cursor = conn.cursor()

        # 실험이 존재하는지 확인
        cursor.execute("SELECT * FROM experiments WHERE experiment_id = ?", (experiment_id,))
        if not cursor.fetchone():
            conn.close()
            return jsonify({'status': 'error', 'message': f'Experiment {experiment_id} not found'}), 404

        cursor.execute("UPDATE experiments SET status = ? WHERE experiment_id = ?", (data['status'], experiment_id))
        conn.commit()
        conn.close()

        return jsonify({
            'status': 'success',
            'message': f'Experiment {experiment_id} updated'
        }), 200

    except Exception as e:
        return jsonify({'status': 'error', 'message': str(e)}), 500


# ==================== PHASE 4: DELETE 메서드 ====================

@app.route('/api/measurements/<int:measurement_id>', methods=['DELETE'])
def delete_measurement(measurement_id):
    """
    【 DELETE /api/measurements/{id} 】
    측정 결과 삭제
    """
    try:
        conn = get_db_connection()
        cursor = conn.cursor()

        # 존재하는지 확인
        cursor.execute("SELECT * FROM measurements WHERE measurement_id = ?", (measurement_id,))
        if not cursor.fetchone():
            conn.close()
            return jsonify({'status': 'error', 'message': f'Measurement {measurement_id} not found'}), 404

        cursor.execute("DELETE FROM measurements WHERE measurement_id = ?", (measurement_id,))
        conn.commit()
        conn.close()

        return jsonify({
            'status': 'success',
            'message': f'Measurement {measurement_id} deleted'
        }), 200

    except Exception as e:
        return jsonify({'status': 'error', 'message': str(e)}), 500


# ==================== PHASE 5: 고급 API ====================

@app.route('/api/statistics', methods=['GET'])
def get_statistics():
    """
    【 GET /api/statistics 】
    데이터베이스 통계
    """
    try:
        conn = get_db_connection()
        cursor = conn.cursor()

        stats = {}

        # 연구자 수
        cursor.execute("SELECT COUNT(*) as count FROM researchers")
        stats['total_researchers'] = cursor.fetchone()['count']

        # 실험 수
        cursor.execute("SELECT COUNT(*) as count FROM experiments")
        stats['total_experiments'] = cursor.fetchone()['count']

        # 완료된 실험
        cursor.execute("SELECT COUNT(*) as count FROM experiments WHERE status = '완료'")
        stats['completed_experiments'] = cursor.fetchone()['count']

        # 측정 결과 수
        cursor.execute("SELECT COUNT(*) as count FROM measurements")
        stats['total_measurements'] = cursor.fetchone()['count']

        # 평균 측정값
        cursor.execute("SELECT AVG(value) as avg_value FROM measurements WHERE metric_name = 'throughput'")
        row = cursor.fetchone()
        stats['avg_throughput'] = row['avg_value'] if row['avg_value'] else 0

        conn.close()

        return jsonify({
            'status': 'success',
            'data': stats
        }), 200

    except Exception as e:
        return jsonify({'status': 'error', 'message': str(e)}), 500


@app.route('/api/researcher/<int:researcher_id>/experiments', methods=['GET'])
def get_researcher_experiments(researcher_id):
    """
    【 GET /api/researcher/{id}/experiments 】
    특정 연구자의 모든 실험 조회
    """
    try:
        conn = get_db_connection()
        cursor = conn.cursor()

        # 연구자 존재 확인
        cursor.execute("SELECT * FROM researchers WHERE researcher_id = ?", (researcher_id,))
        researcher = cursor.fetchone()
        if not researcher:
            conn.close()
            return jsonify({'status': 'error', 'message': 'Researcher not found'}), 404

        cursor.execute(
            "SELECT * FROM experiments WHERE researcher_id = ? ORDER BY experiment_id DESC",
            (researcher_id,)
        )
        experiments = [dict(row) for row in cursor.fetchall()]
        conn.close()

        return jsonify({
            'status': 'success',
            'researcher_name': researcher['name'],
            'experiment_count': len(experiments),
            'data': experiments
        }), 200

    except Exception as e:
        return jsonify({'status': 'error', 'message': str(e)}), 500


