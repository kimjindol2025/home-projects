// ============================================================================
// [1] 불변 바인딩 (Immutable Binding)
// ============================================================================
//
// let 키워드로 변수를 선언하면 기본적으로 불변입니다.
// 한 번 값을 할당하면, 이후 재할당할 수 없습니다.
// 이것은 안전성을 위한 설계 선택입니다.
//
fn immutable_bindings() {
    println!("[1] 불변 바인딩 (let)");
    println!("────────────────────────────────────────────────────────────");

    // 기본 불변 변수
    {
        let x = 5;
        println!("✓ 불변 변수: let x = 5; → x = {}", x);
    }

    // 명시적으로 불변임을 나타낼 수 있음 (강조)
    {
        let message = "Hello, World!";
        println!("✓ 문자열 불변: let message = \"...\" → {}", message);
    }

    // 여러 불변 변수
    {
        let a = 10;
        let b = 20;
        let c = a + b;
        println!("✓ 계산: let a = 10; let b = 20; let c = a + b = {}", c);
    }

    println!();
    // 다음 코드는 컴파일되지 않습니다:
    // let x = 5;
    // x = 10;  // ❌ 오류: cannot assign twice to immutable variable
}

// ============================================================================
// [2] 가변 바인딩 (Mutable Binding)
// ============================================================================
//
// let mut 키워드로 선언하면 변수를 가변으로 만듭니다.
// 이제 값을 재할당할 수 있지만, 타입은 여전히 고정입니다.
//
fn mutable_bindings() {
    println!("[2] 가변 바인딩 (let mut)");
    println!("────────────────────────────────────────────────────────────");

    // 기본 가변 변수
    {
        let mut x = 5;
        println!("✓ 가변 변수 초기: let mut x = 5; → x = {}", x);

        x = 10;
        println!("✓ 가변 변수 변경: x = 10; → x = {}", x);

        x = x + 5;
        println!("✓ 가변 변수 계산: x = x + 5; → x = {}", x);
    }

    // 카운터 패턴 (반복)
    {
        let mut count = 0;
        println!("✓ 카운터 (0): count = {}", count);

        count = count + 1;
        println!("✓ 카운터 (1): count = {}", count);

        count = count + 1;
        println!("✓ 카운터 (2): count = {}", count);

        count = count + 1;
        println!("✓ 카운터 (3): count = {}", count);
    }

    println!();
    // 다음 코드는 컴파일되지 않습니다:
    // let mut x = 5;
    // x = 3.14;  // ❌ 오류: cannot assign f64 to i32
}

// ============================================================================
// [3] 명시적 타입 선언 (Type Annotation)
// ============================================================================
//
// 변수명 뒤에 `: Type` 을 붙여 타입을 명시합니다.
// 코드의 의도를 명확히 하고, 컴파일러가 검증합니다.
//
fn explicit_types() {
    println!("[3] 명시적 타입 선언");
    println!("────────────────────────────────────────────────────────────");

    // 정수형
    {
        let age: i32 = 25;
        println!("✓ i32 타입: let age: i32 = 25; → {}", age);
    }

    // 큰 정수
    {
        let population: i64 = 1000000000i64;
        println!("✓ i64 타입: let population: i64 = {}; → {}", "1000000000i64", population);
    }

    // 부동소수점
    {
        let pi: f64 = 3.14159;
        println!("✓ f64 타입: let pi: f64 = 3.14159; → {}", pi);
    }

    // 32비트 부동소수점
    {
        let speed: f32 = 99.9f32;
        println!("✓ f32 타입: let speed: f32 = 99.9f32; → {}", speed);
    }

    // 문자열
    {
        let name: &str = "PulseAI";
        println!("✓ &str 타입: let name: &str = \"...\"; → {}", name);
    }

    // 불린
    {
        let is_active: bool = true;
        println!("✓ bool 타입: let is_active: bool = true; → {}", is_active);
    }

    println!();
}

// ============================================================================
// [4] 타입 추론 (Type Inference)
// ============================================================================
//
// Rust는 강력한 타입 추론 능력을 가지고 있습니다.
// 초기값으로부터 타입을 자동으로 결정합니다.
//
fn type_inference() {
    println!("[4] 타입 추론");
    println!("────────────────────────────────────────────────────────────");

    // 정수 추론 (i32)
    {
        let x = 42;  // → i32 추론
        println!("✓ 정수 추론: let x = 42; → i32로 추론, x = {}", x);
    }

    // 부동소수점 추론 (f64)
    {
        let y = 3.14;  // → f64 추론
        println!("✓ 실수 추론: let y = 3.14; → f64로 추론, y = {}", y);
    }

    // 문자열 추론 (&str)
    {
        let message = "Hello";  // → &str 추론
        println!("✓ 문자열 추론: let message = \"...\"; → &str로 추론");
    }

    // 불린 추론
    {
        let flag = true;  // → bool 추론
        println!("✓ 불린 추론: let flag = true; → bool로 추론, flag = {}", flag);
    }

    // 명시적 타입 vs 추론
    {
        let inferred = 100;  // 추론: i32
        let explicit: i32 = 100;  // 명시: i32
        println!("✓ 추론 vs 명시: 둘 다 같은 i32 타입입니다.");
        println!("  inferred = {}, explicit = {}", inferred, explicit);
    }

    println!();
}

// ============================================================================
// [5] 상수 (Constant)
// ============================================================================
//
// const 키워드로 상수를 정의합니다.
// - 반드시 타입을 명시해야 합니다.
// - 컴파일 타임에 값이 결정됩니다.
// - 프로그램 전체에서 사용 가능합니다.
//
fn constants() {
    println!("[5] 상수 (const)");
    println!("────────────────────────────────────────────────────────────");

    // 프로그램 수준의 상수들
    const SECONDS_IN_MINUTE: i32 = 60;
    const MINUTES_IN_HOUR: i32 = 60;
    const HOURS_IN_DAY: i32 = 24;
    const PI: f64 = 3.14159265;
    const GRAVITY: f64 = 9.81;

    // 상수 사용
    let seconds_in_hour = SECONDS_IN_MINUTE * MINUTES_IN_HOUR;
    println!("✓ 상수: SECONDS_IN_MINUTE * MINUTES_IN_HOUR = {}", seconds_in_hour);

    let seconds_in_day = seconds_in_hour * HOURS_IN_DAY;
    println!("✓ 상수: seconds_in_hour * HOURS_IN_DAY = {}", seconds_in_day);

    println!("✓ 상수: PI = {}", PI);
    println!("✓ 상수: GRAVITY = {}", GRAVITY);

    println!();
}

// ============================================================================
// [6] 재바인딩 (Shadowing)
// ============================================================================
//
// 같은 이름의 변수를 다시 선언할 수 있습니다.
// 이전 변수는 새 변수로 "가려집니다" (shadowed).
// 타입도 바뀔 수 있습니다!
//
fn shadowing() {
    println!("[6] 재바인딩 (Shadowing)");
    println!("────────────────────────────────────────────────────────────");

    // 기본 재바인딩
    {
        let x = 5;
        println!("✓ 첫 번째: let x = 5; → x = {}", x);

        let x = x + 1;
        println!("✓ 재바인딩: let x = x + 1; → x = {}", x);

        let x = x * 2;
        println!("✓ 재바인딩: let x = x * 2; → x = {}", x);
    }

    // 타입 변환을 통한 재바인딩
    {
        let spaces = "   ";  // &str
        println!("✓ 첫 번째: let spaces = \"   \"; → 문자열 = {}", spaces);

        let spaces = spaces.len();  // i32 (타입 변경!)
        println!("✓ 재바인딩: let spaces = spaces.len(); → 숫자 = {}", spaces);
    }

    println!();
}

// ============================================================================
// [7] 메모리 모델 (Memory Model)
// ============================================================================
//
// 변수는 메모리상의 특정 주소에 값을 저장합니다.
// Rust의 메모리 모델은 다음과 같습니다:
// - Stack: 컴파일 타임에 크기가 정해진 데이터 (정수, 부동소수점)
// - Heap: 런타임에 크기가 결정되는 데이터 (문자열)
//
fn memory_model() {
    println!("[7] 메모리 모델");
    println!("────────────────────────────────────────────────────────────");

    println!("✓ Stack에 저장되는 타입들:");
    {
        let a: i32 = 10;          // 4 bytes (Stack)
        let b: i64 = 20;          // 8 bytes (Stack)
        let c: f64 = 3.14;        // 8 bytes (Stack)
        let d: bool = true;       // 1 byte  (Stack)
        println!("  i32(a) = {}, i64(b) = {}, f64(c) = {}, bool(d) = {}", a, b, c, d);
    }

    println!("✓ 메모리 생명주기:");
    {
        let lifetime = 100;
        println!("  변수 생성: lifetime = {}", lifetime);
        // 이 블록을 벗어나면 lifetime이 메모리에서 해제됩니다.
    }
    // lifetime은 여기서 더 이상 존재하지 않습니다.
    println!("  변수 해제: lifetime이 범위를 벗어남");

    println!();
}

// ============================================================================
// v2.0 핵심 학습 요소
// ============================================================================
//
// 1. 불변성 (Immutability)
//    - let으로 선언한 변수는 기본적으로 불변입니다.
//    - 재할당하려면 컴파일 오류가 발생합니다.
//    - 안전성을 위한 설계 원칙입니다.
//
// 2. 가변성 (Mutability)
//    - let mut으로 선언하면 변수를 가변으로 만듭니다.
//    - 명시적으로 의도를 표현합니다.
//    - 성능 주의: 가변 상태는 복잡성을 증대합니다.
//
// 3. 타입 시스템
//    - i32: 32비트 부호 있는 정수 (기본 정수형)
//    - i64: 64비트 부호 있는 정수
//    - f32: 32비트 부동소수점
//    - f64: 64비트 부동소수점 (기본 실수형)
//    - &str: 불변 문자열 슬라이스
//    - bool: 참/거짓
//
// 4. 타입 안전성
//    - 컴파일 타임에 타입 오류를 감지합니다.
//    - let x: i32 = 5; x = 3.14; → 컴파일 오류!
//    - 런타임 오류를 사전에 방지합니다.
//
// 5. 타입 추론
//    - 초기값으로부터 타입을 자동 결정합니다.
//    - let x = 5; → i32로 추론
//    - let y = 3.14; → f64로 추론
//
// 6. 상수 (Constant)
//    - const로 선언합니다.
//    - 타입 명시 필수입니다.
//    - 프로그램 전체에서 사용 가능합니다.
//
// 7. 재바인딩 (Shadowing)
//    - 같은 이름으로 변수를 다시 선언 가능합니다.
//    - 이전 변수는 새 변수로 가려집니다.
//    - 타입도 바뀔 수 있습니다!
//
// ============================================================================
