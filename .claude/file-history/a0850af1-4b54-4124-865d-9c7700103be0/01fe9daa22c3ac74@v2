"""
Python Elementary v1.4 - 반복문(for) — 자동화의 첫걸음

탐구(초등학교): "귀찮은 일은 컴퓨터에게 (for 반복문)"

리스트라는 바구니에 데이터를 가득 담았으니,
이제 그 데이터들을 하나씩 꺼내어 자동으로 처리하는 방법을 배웁시다.
사람이 일일이 print(basket[0]), print(basket[1])이라고 쓰지 않아도
파이썬이 대신 반복해주는 마법입니다.

for 문은 리스트 같은 바구니 안에서 아이템을 하나씩 꺼내어
"이름표"를 붙이고, 지정된 일을 반복합니다.

1. for 문의 구조
   - 바구니: 데이터가 모여 있는 곳 (리스트 등)
   - 꺼낸 아이템의 이름: 임시 이름표
   - 들여쓰기(Indentation): 파이썬에서 가장 중요한 규칙!
     반복할 내용은 반드시 스페이스 4칸(또는 Tab)을 띄워야 합니다.

2. 숫자 범위로 반복하기 (range)
   - 특정 횟수만큼 반복하고 싶을 때는 range()를 사용합니다.
"""

print("=" * 70)
print("# Python Elementary v1.4 - 반복문(for) — 자동화의 첫걸음")
print("=" * 70)

# ============================================================================
# [1단계] 리스트를 순회하는 기본 for 반복문
# ============================================================================

print("\n[1단계] 리스트 순회 - 과일 상자 차례대로 열기")
print("-" * 70)

fruits = ["사과", "바나나", "포도", "딸기"]

print("과일 상자:", fruits)
print("\n--- for 반복문으로 차례대로 꺼내기 ---")

for fruit in fruits:
    print(f"상자에서 {fruit}를 꺼냈습니다.")

print("\n설명:")
print("  ✓ for fruit in fruits: → fruits 바구니에서")
print("  ✓ fruit: → 하나씩 꺼낸 것을 'fruit'이라고 부르고")
print("  ✓ print(f'...'): → 들여쓰기된 부분을 반복 실행")

# ============================================================================
# [2단계] 숫자 범위로 반복하기 (range 함수)
# ============================================================================

print("\n[2단계] range() 함수로 숫자 반복")
print("-" * 70)

print("range(5) - 0부터 4까지:")
for i in range(5):
    print(f"  i = {i}")

print("\nrange(1, 6) - 1부터 5까지:")
for i in range(1, 6):
    print(f"  현재 숫자는 {i}입니다.")

print("\nrange(0, 10, 2) - 0부터 10 전까지 2씩 증가:")
for i in range(0, 10, 2):
    print(f"  {i}", end=" ")
print()

print("\n설명:")
print("  ✓ range(5): 0, 1, 2, 3, 4")
print("  ✓ range(1, 6): 1, 2, 3, 4, 5")
print("  ✓ range(0, 10, 2): 0, 2, 4, 6, 8")

# ============================================================================
# [3단계] 인덱스를 사용한 반복
# ============================================================================

print("\n[3단계] 인덱스를 사용하여 반복 (위치 번호 필요할 때)")
print("-" * 70)

animals = ["고양이", "개", "새", "물고기"]

print("동물 목록:", animals)
print("\nfor i in range(len(animals)) 방식:")

for i in range(len(animals)):
    print(f"  위치 {i}번: {animals[i]}")

# ============================================================================
# [4단계] 응용: 리스트 안의 모든 숫자 더하기
# ============================================================================

print("\n[4단계] 응용: 리스트의 모든 숫자 합 구하기")
print("-" * 70)

numbers = [10, 20, 30, 40, 50]

print("숫자 목록:", numbers)

total = 0
print("\n계산 과정:")
for num in numbers:
    total = total + num
    print(f"  더하기: {total - num} + {num} = {total}")

print(f"\n최종 합계: {total}")

# ============================================================================
# [5단계] 들여쓰기가 중요한 이유
# ============================================================================

print("\n[5단계] 들여쓰기(Indentation)의 중요성")
print("-" * 70)

print("잘못된 예: 들여쓰기가 없으면 반복이 아니라 한 번만 실행")
print("  for x in [1, 2, 3]:")
print("  print(x)  ← 들여쓰기 없음! 마지막 x만 출력")

print("\n올바른 예: 들여쓰기가 있으면 반복 실행")
print("  for x in [1, 2, 3]:")
print("      print(x)  ← 들여쓰기 있음! 모두 출력")

print("\n실제 실행:")
for x in [1, 2, 3]:
    print(f"  {x}")

# ============================================================================
# [6단계] 문자열도 반복 가능
# ============================================================================

print("\n[6단계] 문자열 반복 - 한 글자씩 꺼내기")
print("-" * 70)

word = "파이썬"

print(f"단어: {word}")
print("한 글자씩 꺼내기:")

for letter in word:
    print(f"  글자: {letter}")

# ============================================================================
# [7단계] 중첩 반복 (반복문 안의 반복문)
# ============================================================================

print("\n[7단계] 중첩 반복 - 반복 안의 반복")
print("-" * 70)

colors = ["빨강", "파랑"]
items = ["공", "풍선"]

print("색상:", colors)
print("물건:", items)

print("\n모든 조합 만들기:")
for color in colors:
    for item in items:
        print(f"  {color}색 {item}")

# ============================================================================
# [8단계] 조건과 함께 사용하기 (if와 함께)
# ============================================================================

print("\n[8단계] 조건과 함께 사용 (미리 보기)")
print("-" * 70)

scores = [85, 92, 78, 95, 88]

print("점수 목록:", scores)
print("\n90점 이상만 표시:")

for score in scores:
    if score >= 90:
        print(f"  {score}점 ★ (좋음!)")
    else:
        print(f"  {score}점")

print("\n설명:")
print("  ✓ for 반복문 안에 if 조건문을 중첩할 수 있습니다.")
print("  ✓ 다음 수업에서 조건문을 자세히 배웁니다!")

# ============================================================================
# [9단계] 실용적인 예제: 구구단 출력
# ============================================================================

print("\n[9단계] 실용적인 예제: 구구단 (2단)")
print("-" * 70)

print("2 × 1 부터 2 × 9까지:")
for i in range(1, 10):
    result = 2 * i
    print(f"  2 × {i} = {result}")

# ============================================================================
# [최종 증명]
# ============================================================================

print("\n" + "=" * 70)
print("# [최종 증명] 반복문의 힘")
print("=" * 70)

print("""
✓ [for 문의 기본 구조]
  for 변수 in 바구니:
      반복할 코드 (들여쓰기!)

✓ [리스트 순회]
  for fruit in fruits:
      print(fruit)
  바구니에서 하나씩 꺼내 반복합니다.

✓ [range() 함수]
  for i in range(5): → 0부터 4까지 반복
  for i in range(1, 6): → 1부터 5까지 반복
  for i in range(0, 10, 2): → 0부터 10까지 2씩 증가

✓ [들여쓰기의 힘]
  파이썬에서 가장 중요한 규칙!
  들여쓰기가 반복 범위를 결정합니다.

✓ [응용 가능성]
  - 리스트 합 구하기
  - 문자열 한 글자씩 처리
  - 중첩 반복
  - 조건과 함께 사용

✓ [자동화의 시작]
  수만 개, 수백만 개의 데이터도
  for 반복문 몇 줄로 처리 가능합니다!

결론:
  반복문은 프로그래밍의 기초 중 기초입니다.
  "일이 많아도 컴퓨터가 대신 처리한다"
  이것이 프로그래밍의 진정한 힘입니다!

저장 필수 너는 기록이 증명이다 gogs
""")
