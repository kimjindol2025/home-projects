// ============================================================================
// [프로젝트 3] 물리 단위 시스템
// ============================================================================
struct Meter(f64);
struct Kilogram(f64);
struct Second(f64);
struct MeterPerSecond(f64);

impl fmt::Display for Meter {
    fn fmt(&self, f: &mut fmt::Formatter) -> fmt::Result {
        write!(f, "{}m", self.0)
    }
}

impl fmt::Display for Kilogram {
    fn fmt(&self, f: &mut fmt::Formatter) -> fmt::Result {
        write!(f, "{}kg", self.0)
    }
}

impl fmt::Display for Second {
    fn fmt(&self, f: &mut fmt::Formatter) -> fmt::Result {
        write!(f, "{}s", self.0)
    }
}

impl fmt::Display for MeterPerSecond {
    fn fmt(&self, f: &mut fmt::Formatter) -> fmt::Result {
        write!(f, "{}m/s", self.0)
    }
}

fn calculate_velocity(distance: Meter, time: Second) -> MeterPerSecond {
    MeterPerSecond(distance.0 / time.0)
}

fn calculate_momentum(mass: Kilogram, velocity: MeterPerSecond) -> f64 {
    mass.0 * velocity.0
}

fn project_unit_system() {
    println!("\n[프로젝트 3] 물리 단위 시스템");
    println!("═════════════════════════════════════════");

    println!("\n[자동차 속도 계산]");
    let distance = Meter(100.0);
    let time = Second(5.0);
    let velocity = calculate_velocity(distance, time);
    println!("  거리: {}", distance);
    println!("  시간: {}", time);
    println!("  속도: {}", velocity);

    println!("\n[운동량 계산]");
    let mass = Kilogram(1000.0);
    let momentum = calculate_momentum(mass, velocity);
    println!("  질량: {}", mass);
    println!("  속도: {}", velocity);
    println!("  운동량: {} kg⋅m/s", momentum);

    println!("\n✓ 설계: 각 물리량이 별개의 타입");
    println!("✓ 안전성: 거리에 시간을 더하는 것 불가능");
    println!("✓ 정확성: 함수 시그니처에서 단위 명시");
}

// ============================================================================
// [프로젝트 4] 타입 에일리어스
// ============================================================================
type UserDatabase = HashMap<u64, String>;
type EventLog = Vec<(String, u64)>;
type Result<T> = std::result::Result<T, String>;

fn get_user(id: u64, db: &UserDatabase) -> Result<String> {
    db.get(&id)
        .cloned()
        .ok_or_else(|| format!("사용자 {} 없음", id))
}

fn log_event(log: &mut EventLog, event: &str, timestamp: u64) {
    log.push((event.to_string(), timestamp));
}

fn project_type_aliases() {
    println!("\n[프로젝트 4] 타입 에일리어스");
    println!("═════════════════════════════════════════");

    println!("\n[사용자 데이터베이스]");
    let mut db: UserDatabase = HashMap::new();
    db.insert(1, "Alice".to_string());
    db.insert(2, "Bob".to_string());
    db.insert(3, "Charlie".to_string());

    match get_user(1, &db) {
        Ok(name) => println!("  사용자 1: {}", name),
        Err(e) => println!("  오류: {}", e),
    }

    match get_user(99, &db) {
        Ok(name) => println!("  사용자 99: {}", name),
        Err(e) => println!("  오류: {}", e),
    }

    println!("\n[이벤트 로그]");
    let mut log: EventLog = Vec::new();
    log_event(&mut log, "시스템 시작", 1000);
    log_event(&mut log, "사용자 로그인", 1001);
    log_event(&mut log, "데이터 저장", 1002);

    for (event, time) in &log {
        println!("  [{}] {}", time, event);
    }

    println!("\n✓ 설계: 복잡한 타입에 의미있는 이름 부여");
    println!("✓ 가독성: UserDatabase, EventLog, Result<T>");
    println!("✓ 유지보수: 나중에 타입 변경 시 한 곳만 수정");
}

// ============================================================================
// [프로젝트 5] 도메인 규칙을 타입으로 표현
// ============================================================================
struct Email(String);
struct PhoneNumber(String);
struct Age(u32);
struct Percentage(f64);

impl Email {
    fn new(value: &str) -> Result<Self> {
        if value.contains('@') && value.contains('.') {
            Ok(Email(value.to_string()))
        } else {
            Err("유효하지 않은 이메일".to_string())
        }
    }

    fn domain(&self) -> Option<&str> {
        self.0.split('@').nth(1)
    }
}

impl PhoneNumber {
    fn new(value: &str) -> Result<Self> {
        if value.len() >= 10 {
            Ok(PhoneNumber(value.to_string()))
        } else {
            Err("유효하지 않은 전화번호".to_string())
        }
    }
}

impl Age {
    fn new(value: u32) -> Result<Self> {
        if value > 0 && value < 150 {
            Ok(Age(value))
        } else {
            Err("유효하지 않은 나이".to_string())
        }
    }

    fn is_adult(&self) -> bool {
        self.0 >= 18
    }
}

impl Percentage {
    fn new(value: f64) -> Result<Self> {
        if value >= 0.0 && value <= 100.0 {
            Ok(Percentage(value))
        } else {
            Err("퍼센트는 0~100 사이여야 함".to_string())
        }
    }
}

impl fmt::Display for Email {
    fn fmt(&self, f: &mut fmt::Formatter) -> fmt::Result {
        write!(f, "{}", self.0)
    }
}

impl fmt::Display for Age {
    fn fmt(&self, f: &mut fmt::Formatter) -> fmt::Result {
        write!(f, "{}세", self.0)
    }
}

impl fmt::Display for Percentage {
    fn fmt(&self, f: &mut fmt::Formatter) -> fmt::Result {
        write!(f, "{:.1}%", self.0)
    }
}

fn project_domain_types() {
    println!("\n[프로젝트 5] 도메인 규칙을 타입으로 표현");
    println!("═════════════════════════════════════════");

    println!("\n[유효한 데이터]");
    match Email::new("alice@example.com") {
        Ok(email) => println!("  이메일: {} (도메인: {})", email, email.domain().unwrap_or("?")),
        Err(e) => println!("  오류: {}", e),
    }

    match Age::new(25) {
        Ok(age) => {
            println!("  나이: {} (성인? {})", age, age.is_adult());
        }
        Err(e) => println!("  오류: {}", e),
    }

    match Percentage::new(85.5) {
        Ok(pct) => println!("  성공률: {}", pct),
        Err(e) => println!("  오류: {}", e),
    }

    println!("\n[유효하지 않은 데이터]");
    match Email::new("invalid-email") {
        Ok(_) => println!("  이메일 OK"),
        Err(e) => println!("  이메일 오류: {}", e),
    }

    match Age::new(200) {
        Ok(_) => println!("  나이 OK"),
        Err(e) => println!("  나이 오류: {}", e),
    }

    match Percentage::new(150.0) {
        Ok(_) => println!("  퍼센트 OK"),
        Err(e) => println!("  퍼센트 오류: {}", e),
    }

    println!("\n✓ 설계: 생성 시 유효성 검사");
    println!("✓ 안전성: 유효하지 않은 값 생성 불가");
    println!("✓ 도메인: 비즈니스 규칙이 타입에 내재");
}

