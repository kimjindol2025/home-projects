// ============================================================================
// [프로젝트 1] 온도 단위 분리
// ============================================================================
struct Celsius(f64);
struct Fahrenheit(f64);

impl Celsius {
    fn new(value: f64) -> Self {
        Celsius(value)
    }

    fn to_fahrenheit(&self) -> f64 {
        self.0 * 9.0 / 5.0 + 32.0
    }

    fn to_kelvin(&self) -> f64 {
        self.0 + 273.15
    }
}

impl fmt::Display for Celsius {
    fn fmt(&self, f: &mut fmt::Formatter) -> fmt::Result {
        write!(f, "{}°C", self.0)
    }
}

impl Fahrenheit {
    fn new(value: f64) -> Self {
        Fahrenheit(value)
    }

    fn to_celsius(&self) -> f64 {
        (self.0 - 32.0) * 5.0 / 9.0
    }
}

impl fmt::Display for Fahrenheit {
    fn fmt(&self, f: &mut fmt::Formatter) -> fmt::Result {
        write!(f, "{}°F", self.0)
    }
}

fn project_temperature_system() {
    println!("\n[프로젝트 1] 온도 단위 분리");
    println!("═════════════════════════════════════════");

    println!("\n[섭씨 온도]");
    let water_boil = Celsius::new(100.0);
    println!("  물의 끓는점: {}", water_boil);
    println!("  화씨 변환: {}°F", water_boil.to_fahrenheit());
    println!("  켈빈 변환: {}K", water_boil.to_kelvin());

    println!("\n[화씨 온도]");
    let room_temp = Fahrenheit::new(72.0);
    println!("  실온: {}", room_temp);
    println!("  섭씨 변환: {}°C", room_temp.to_celsius());

    println!("\n✓ 설계: Celsius와 Fahrenheit는 서로 다른 타입");
    println!("✓ 안전성: 두 온도를 직접 더하는 것 불가능");
    println!("✓ 명확성: 각 타입의 메서드로 의도 명확화");
}

