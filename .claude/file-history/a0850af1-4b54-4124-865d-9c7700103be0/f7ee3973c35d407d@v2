struct UserId(u64);
struct PostId(u64);
struct CommentId(u64);

struct User {
    id: UserId,
    name: String,
}

struct Post {
    id: PostId,
    title: String,
    user_id: UserId,  // 명확: 이 게시물의 작성자
}

struct Comment {
    id: CommentId,
    content: String,
    post_id: PostId,
    user_id: UserId,
}

impl fmt::Display for UserId {
    fn fmt(&self, f: &mut fmt::Formatter) -> fmt::Result {
        write!(f, "User#{}", self.0)
    }
}

impl fmt::Display for PostId {
    fn fmt(&self, f: &mut fmt::Formatter) -> fmt::Result {
        write!(f, "Post#{}", self.0)
    }
}

impl fmt::Display for CommentId {
    fn fmt(&self, f: &mut fmt::Formatter) -> fmt::Result {
        write!(f, "Comment#{}", self.0)
    }
}

