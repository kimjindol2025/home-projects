## 📖 FFI 보안 체크리스트

```rust
// [1] 포인터 유효성 검증
if ptr.is_null() {
    return Err("Null pointer");
}

// [2] 메모리 소유권 명확화
/// # Safety
/// 호출자는 ptr이 유효한 메모리를 가리키고 있고,
/// C 함수가 메모리를 해제하지 않음을 보장해야 한다.
pub unsafe fn use_external_memory(ptr: *const u8) { }

// [3] Panic 방지
catch_unwind(AssertUnwindSafe(|| {
    // 잠재적 panic 코드
}))

// [4] 타입 호환성 확인
// use std::os::raw::{c_int, c_char, c_void};
// i32 ≠ c_int (모든 플랫폼에서)

// [5] 문서화: 호출자의 책임 명시
/// # Safety
/// 다음 조건이 만족되어야 한다:
/// 1. ptr은 유효한 메모리를 가리킨다
/// 2. ptr은 len 바이트 이상을 가리킨다
/// 3. ptr의 메모리는 초기화되어 있다
pub unsafe fn safe_slice(ptr: *const u8, len: usize) -> &'static [u8] { }
