## 📚 핵심 개념: FFI의 계층

### 1️⃣ ABI (Application Binary Interface)

```rust
// [정의] ABI는 함수 호출의 '약속'
// - 인수를 어느 레지스터에 놓을지
// - 반환값을 어디에 놓을지
// - 스택을 어떻게 정렬할지

// [주요 ABI]
extern "C" { }        // System V AMD64 (리눅스/유닉스 표준)
extern "stdcall" { }  // Windows 32-bit
extern "fastcall" { } // 최적화된 호출 규약

// [대부분의 경우 extern "C" 사용]
extern "C" {
    fn c_function(x: i32, y: i32) -> i32;
}
```

### 2️⃣ extern 블록과 함수 선언

```rust
// [형식]
extern "C" {
    // 함수 시그니처만 선언
    // 구현은 외부 라이브러리에 있음
    fn function_name(arg: Type) -> ReturnType;

    // 변수도 선언 가능
    static EXTERNAL_VAR: i32;
}

// [예제] 표준 수학 함수
extern "C" {
    fn abs(input: i32) -> i32;
    fn sqrt(x: f64) -> f64;
    fn pow(base: f64, exp: f64) -> f64;
    fn sin(x: f64) -> f64;
}

// [호출은 unsafe 영역에서만]
unsafe {
    let result = abs(-42);
    let root = sqrt(16.0);
}
```

### 3️⃣ 데이터 마샬링 (Marshalling)

```rust
// [정의] 타입 경계를 넘는 데이터 변환

// ===== 문자열 마샬링 =====
use std::ffi::{CString, CStr};
use std::os::raw::c_char;

extern "C" {
    fn strlen(s: *const c_char) -> usize;
    fn c_strcpy(dest: *mut c_char, src: *const c_char) -> *mut c_char;
}

fn example_string_marshalling() {
    unsafe {
        // Rust String → C String
        let rust_str = "Hello, C!";
        let c_str = CString::new(rust_str).unwrap();

        // C 함수에 전달
        let len = strlen(c_str.as_ptr());
        println!("Length: {}", len);

        // C String → Rust String
        let c_cstr = CStr::from_ptr(c_str.as_ptr());
        let rust_back = c_cstr.to_string_lossy();
        println!("Back to Rust: {}", rust_back);
    }
}

// ===== 배열/벡터 마샬링 =====
extern "C" {
    fn sum_array(arr: *const i32, len: usize) -> i32;
}

fn example_array_marshalling() {
    let vec = vec![1, 2, 3, 4, 5];

    unsafe {
        let result = sum_array(vec.as_ptr(), vec.len());
        println!("Sum: {}", result);
    }
}

// ===== 구조체 마샬링 =====
#[repr(C)]  // ⭐ 중요: C 호환 레이아웃
pub struct CPoint {
    x: i32,
    y: i32,
}

extern "C" {
    fn distance(p1: CPoint, p2: CPoint) -> f64;
}

fn example_struct_marshalling() {
    let p1 = CPoint { x: 0, y: 0 };
    let p2 = CPoint { x: 3, y: 4 };

    unsafe {
        let dist = distance(p1, p2);
        println!("Distance: {}", dist);
    }
}
```

### 4️⃣ 포인터 규칙

```rust
// [규칙 1] *const T: 읽기 전용 포인터
extern "C" {
    fn read_from_ptr(ptr: *const i32) -> i32;
}

// [규칙 2] *mut T: 쓰기 가능 포인터
extern "C" {
    fn write_to_ptr(ptr: *mut i32, value: i32);
}

// [규칙 3] null 체크는 필수
unsafe {
    let ptr: *const i32 = some_c_function();

    if !ptr.is_null() {
        let value = *ptr;
    }
}

// [규칙 4] 포인터 유효성은 호출자 책임
// C 함수가 "이 포인터는 유효하지 않습니다"라고 반환할 수 있음
// 러스트 컴파일러는 이를 검증할 수 없음
// → 문서화와 테스트가 중요!
```

### 5️⃣ Callback과 함수 포인터

```rust
// [정의] C 함수가 러스트 함수를 호출하는 경우

// C의 함수 포인터 타입
pub type CCallback = extern "C" fn(i32) -> i32;

extern "C" {
    fn register_callback(cb: CCallback);
    fn invoke_callback(value: i32);
}

// 러스트 함수를 콜백으로 제공
pub extern "C" fn my_callback(value: i32) -> i32 {
    println!("Callback called with: {}", value);
    value * 2
}

fn example_callback() {
    unsafe {
        register_callback(my_callback);
        invoke_callback(10);  // my_callback(10) 호출됨
    }
}
```

### 6️⃣ Panic 방지

```rust
// ⚠️ 위험: Panic이 C 경계를 넘으면 UB!

// ❌ 위험한 코드
pub extern "C" fn unsafe_callback(value: i32) -> i32 {
    // 이 함수 내에서 panic!이 발생하면
    // C 함수로 전파되어 Undefined Behavior 발생!
    if value < 0 {
        panic!("Negative value!");  // ❌ 위험!
    }
    value
}

// ✅ 안전한 코드
use std::panic::catch_unwind;

pub extern "C" fn safe_callback(value: i32) -> i32 {
    match catch_unwind(std::panic::AssertUnwindSafe(|| {
        if value < 0 {
            return Err("Negative value!");
        }
        Ok(value)
    })) {
        Ok(Ok(result)) => result,
        _ => -1,  // 에러 상태를 C가 이해하는 형태로 반환
    }
}
```

