// [구현 F] SatelliteSignal: 위성 신호 모니터링 (미래 확장 예시)
// ============================================================================
struct SatelliteSignal {
    frequency: f64,         // MHz
    signal_strength: u32,   // 0~100
    is_encrypted: bool,
    timestamp: String,
}

impl SatelliteSignal {
    fn new(frequency: f64, signal_strength: u32, is_encrypted: bool, timestamp: &str) -> Self {
        Self {
            frequency,
            signal_strength,
            is_encrypted,
            timestamp: String::from(timestamp),
        }
    }
}

impl Summary for SatelliteSignal {
    fn summarize(&self) -> String {
        let enc_status = if self.is_encrypted { "🔒 암호화됨" } else { "⚠️ 미암호화" };
        format!("📡 위성신호 {} MHz | 강도: {}% | {} | [{}]",
                self.frequency, self.signal_strength, enc_status, self.timestamp)
    }
}

impl Secure for SatelliteSignal {
    fn security_score(&self) -> u32 {
        let base = if !self.is_encrypted {
            80  // 암호화 안 됨 = 매우 위험
        } else if self.signal_strength < 30 {
            25
        } else {
            50
        };

        base.min(100)
    }
}

impl AuditItem for SatelliteSignal {}

