// ============================================================================
// [구현 B] IntrusionAlert: 침입 감지 알림
// ============================================================================
struct IntrusionAlert {
    ip: String,
    port: u16,
    severity: u32,      // 0~10
    timestamp: String,
    blocked: bool,
}

impl IntrusionAlert {
    fn new(ip: &str, port: u16, severity: u32, timestamp: &str, blocked: bool) -> Self {
        Self {
            ip: String::from(ip),
            port,
            severity,
            timestamp: String::from(timestamp),
            blocked,
        }
    }
}

impl Summary for IntrusionAlert {
    fn summarize(&self) -> String {
        let status = if self.blocked { "🛡️ 차단됨" } else { "⚠️ 감지됨" };
        format!("{} 침입시도: {}:{} [심각도: {}] [{}]",
                status, self.ip, self.port, self.severity, self.timestamp)
    }
}

impl Secure for IntrusionAlert {
    fn security_score(&self) -> u32 {
        let base = self.severity * 10;
        if self.blocked {
            (base / 2).min(100)  // 차단되면 위험도 50% 감소
        } else {
            base.min(100)
        }
    }
}

impl AuditItem for IntrusionAlert {}

// ============================================================================
// [구현 C] DatabaseAudit: 데이터베이스 감사
// ============================================================================
struct DatabaseAudit {
    query_type: String,      // SELECT, INSERT, UPDATE, DELETE
    table_name: String,
    rows_affected: u32,
    timestamp: String,
    user: String,
}

impl DatabaseAudit {
    fn new(query_type: &str, table_name: &str, rows_affected: u32,
           timestamp: &str, user: &str) -> Self {
        Self {
            query_type: String::from(query_type),
            table_name: String::from(table_name),
            rows_affected,
            timestamp: String::from(timestamp),
            user: String::from(user),
        }
    }
}

impl Summary for DatabaseAudit {
    fn summarize(&self) -> String {
        format!("[DB] {} 사용자가 {} 테이블에 {} ({}행 영향)",
                self.user, self.query_type, self.table_name, self.rows_affected)
    }
}

impl Secure for DatabaseAudit {
    fn security_score(&self) -> u32 {
        let base_score = match self.query_type.as_str() {
            "SELECT" => 20,
            "INSERT" => 40,
            "UPDATE" => 60,
            "DELETE" => 85,
            _ => 50,
        };

        // 많은 행에 영향 → 위험도 증가
        let row_penalty = if self.rows_affected > 10000 {
            15
        } else if self.rows_affected > 1000 {
            5
        } else {
            0
        };

        (base_score + row_penalty).min(100)
    }
}

impl AuditItem for DatabaseAudit {}

// ============================================================================
// [구현 D] AccessLog: 자원 접근 기록
// ============================================================================
struct AccessLog {
    user: String,
    resource: String,
    access_type: String,    // read, write, execute
    status: String,         // success, denied, timeout
    timestamp: String,
}

impl AccessLog {
    fn new(user: &str, resource: &str, access_type: &str,
           status: &str, timestamp: &str) -> Self {
        Self {
            user: String::from(user),
            resource: String::from(resource),
            access_type: String::from(access_type),
            status: String::from(status),
            timestamp: String::from(timestamp),
        }
    }
}

impl Summary for AccessLog {
    fn summarize(&self) -> String {
        format!("사용자 {}가 {}에 [{}] 시도 → {} [{}]",
                self.user, self.resource, self.access_type, self.status, self.timestamp)
    }
}

impl Secure for AccessLog {
    fn security_score(&self) -> u32 {
        // 기본 점수: 상태에 따라
        let base = match self.status.as_str() {
            "success" => 30,
            "denied" => 20,
            "timeout" => 50,
            _ => 40,
        };

        // 패널티: 접근 유형에 따라
        let penalty = match self.access_type.as_str() {
            "read" => 0,
            "write" => 15,
            "execute" => 25,
            _ => 10,
        };

        (base + penalty).min(100)
    }
}

impl AuditItem for AccessLog {}

