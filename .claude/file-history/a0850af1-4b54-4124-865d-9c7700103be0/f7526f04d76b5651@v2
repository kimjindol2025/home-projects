// ============================================================================
// [규약 1] Summary: 요약 기능 (모든 감시 항목이 자신을 한 줄로 설명)
// ============================================================================
trait Summary {
    /// 필수 구현: 항목을 한 문장으로 요약
    fn summarize(&self) -> String;
}

// ============================================================================
// [규약 2] Secure: 보안 평가 (모든 감시 항목이 자신의 위험도를 평가)
// ============================================================================
trait Secure {
    /// 필수 구현: 보안 점수 (0~100)
    fn security_score(&self) -> u32;

    /// 기본 구현: 위험도 등급 판정
    fn risk_level(&self) -> &'static str {
        match self.security_score() {
            0..=30 => "🟢 낮음",
            31..=60 => "🟡 중간",
            61..=85 => "🔴 높음",
            86..=100 => "🚨 극위험",
            _ => "❓ 미정의",
        }
    }

    /// 기본 구현: 즉각 대응 필요 여부
    fn requires_immediate_action(&self) -> bool {
        self.security_score() > 75
    }

    /// 기본 구현: 현황 리포트
    fn status_report(&self) -> String {
        format!(
            "위험도: {} ({}점)",
            self.risk_level(),
            self.security_score()
        )
    }
}

// ============================================================================
// [규약 3] AuditItem: Summary + Secure의 통합 규약 (다형성 처리용)
// ============================================================================
// Rust의 trait object 제한: dyn T + U (T, U가 non-auto trait)는 불가능
// 해결책: 새로운 trait로 두 규약을 합침
trait AuditItem: Summary + Secure {}

