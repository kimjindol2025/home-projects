// [핵심: 통합 처리기] — Step 8(where) + Step 6/7(Bounds) 결합
// ============================================================================
/// [최종 보스] 범용 보안 감사 함수
///
/// 이 함수의 위대함:
/// 1. Summary + Secure 구현 → 어떤 타입이든 처리 가능
/// 2. 기존 코드 수정 없이 새로운 타입 추가 가능
/// 3. 컴파일 타임에 안전성 보장
/// 4. 타입 안전 + 유연성의 완벽한 균형
fn audit_report<T: Summary + Secure + ?Sized>(item: &T) {
    println!("╔════════════════════════════════════════════════════╗");
    println!("║           🔍 보안 감사 보고서                     ║");
    println!("╚════════════════════════════════════════════════════╝");
    println!("📋 내용: {}", item.summarize());
    println!("🎯 위험도: {} ({}점)", item.risk_level(), item.security_score());

    if item.requires_immediate_action() {
        println!("🚨 [중요] 즉각 대응 필요!");
    } else {
        println!("✓ [정상] 모니터링 대기");
    }

    println!("📊 상세: {}", item.status_report());
    println!();
}

/// [다형성] 모든 감시 항목을 한 번에 처리
/// Step 4의 다형성과 Step 10의 통합이 만나는 지점
fn audit_all_items(items: &[&dyn AuditItem]) {
    println!("┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓");
    println!("┃       [실시간 통합 감시 시스템]                 ┃");
    println!("┃    모든 데이터 소스를 단일 규약으로 감시       ┃");
    println!("┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\n");

    for (idx, item) in items.iter().enumerate() {
        println!("【감시 항목 {}】", idx + 1);
        // audit_all_items 내에서 직접 처리
        println!("╔════════════════════════════════════════════════════╗");
        println!("║           🔍 보안 감사 보고서                     ║");
        println!("╚════════════════════════════════════════════════════╝");
        println!("📋 내용: {}", item.summarize());
        println!("🎯 위험도: {} ({}점)", item.risk_level(), item.security_score());

        if item.requires_immediate_action() {
            println!("🚨 [중요] 즉각 대응 필요!");
        } else {
            println!("✓ [정상] 모니터링 대기");
        }

        println!("📊 상세: {}", item.status_report());
        println!();
    }
}

/// [통합 분석] 위험도 순서대로 정렬해서 표시
fn show_risk_summary(items: &[(String, u32)]) {
    println!("╔════════════════════════════════════════════════════╗");
    println!("║        ⚠️  위험도 요약 (내림차순)               ║");
    println!("╚════════════════════════════════════════════════════╝\n");

    for (name, score) in items.iter() {
        let risk = match score {
            0..=30 => "🟢 낮음",
            31..=60 => "🟡 중간",
            61..=85 => "🔴 높음",
            86..=100 => "🚨 극위험",
            _ => "❓ 미정의",
        };

        let bar = "█".repeat((score / 10) as usize);
        println!("  {:<25} {} {} ({}/{}) ", name, bar, risk, score, 100);
    }
    println!();
}

