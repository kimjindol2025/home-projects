// [v9.4: 핵심 패턴 3] Upgrade 패턴 (안전한 접근)
// ============================================================================

fn demo_upgrade_pattern() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║    [Demo 4] Upgrade 패턴: 안전한 약한 참조 접근             ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    // [1] 트리 생성
    println!("[1] 트리 생성:");
    let root = TreeNode::new(1);
    let child = TreeNode::new(2);
    TreeNode::add_child(&root, Rc::clone(&child));

    println!("    root(1) → child(2)");

    // [2] upgrade() 성공 케이스
    println!("\n[2] root가 살아있을 때 upgrade():");
    {
        let child_ref = child.borrow();
        match child_ref.get_parent() {
            Some(parent) => {
                println!("    ✅ 부모 존재: {}", parent.borrow().get_value());
            }
            None => {
                println!("    ❌ 부모 없음");
            }
        }
    }

    // [3] upgrade() 실패 케이스 (시뮬레이션)
    println!("\n[3] 부모를 drop한 후 upgrade():");
    {
        // 약한 참조 저장
        let weak_parent = child.borrow().parent.borrow().clone();

        // root를 drop하지 않으면 테스트할 수 없으므로,
        // 약한 참조가 나중에 upgrade 실패하는 것을 설명
        println!("    만약 root가 삭제되었다면:");
        println!("    match weak_parent.upgrade() {{");
        println!("        Some(_) => /* 불가능 */,");
        println!("        None => /* parent는 이미 삭제됨 */,");
        println!("    }}");
    }

    println!("\n    ✅ upgrade()로 안전하게 Weak → Strong 변환\n");
}

