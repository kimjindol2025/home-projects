// [v9.4: 핵심 패턴 4] 순환 참조 방지 (v9.3 문제 해결)
// ============================================================================

fn demo_circular_ref_fixed() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║  [Demo 5] 순환 참조 방지: v9.3의 문제를 Weak로 해결         ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    println!("[1] v9.3의 순환 참조 문제:");
    println!("    A → B → A (순환)");
    println!("    A의 RefCount: 1 → 2 (B가 A를 가리킴)");
    println!("    B의 RefCount: 1 → 2 (A가 B를 가리킴)");
    println!("    A와 B 스코프 종료");
    println!("    A의 RefCount: 1 (B가 A를 가리키고 있음)");
    println!("    B의 RefCount: 1 (A가 B를 가리키고 있음)");
    println!("    ❌ 메모리 누수!");

    println!("\n[2] v9.4의 해결책 - Weak 사용:");
    {
        let node_a = TreeNode::new(1);
        let node_b = TreeNode::new(2);

        // node_a의 자식으로 node_b 추가
        TreeNode::add_child(&node_a, Rc::clone(&node_b));

        // node_b가 node_a를 약한 참조로 가리킴 (이미 add_child에서 자동 설정)
        println!("    A → B (강한 참조, A가 B를 소유)");
        println!("    B → A (약한 참조, B는 A를 소유하지 않음)");

        println!("\n    A의 StrongCount: {}", Rc::strong_count(&node_a));
        println!("    B의 StrongCount: {}", Rc::strong_count(&node_b));
    } // A와 B 스코프 종료
    // → 즉시 메모리 해제 (메모리 누수 없음!)

    println!("\n    ✅ Weak 참조로 순환 참조 방지 완료\n");
}

// ============================================================================
// [v9.4: 고급 패턴] 복잡한 계층 구조
// ============================================================================

type GogsSecurityNodeRef = Rc<RefCell<GogsSecurityNode>>;
type WeakGogsSecurityNodeRef = Weak<RefCell<GogsSecurityNode>>;

#[derive(Debug)]
struct GogsSecurityNode {
    node_id: usize,
    security_level: usize,
    parent: RefCell<WeakGogsSecurityNodeRef>,
    children: RefCell<Vec<GogsSecurityNodeRef>>,
}

impl GogsSecurityNode {
    fn new(node_id: usize, level: usize) -> GogsSecurityNodeRef {
        Rc::new(RefCell::new(Self {
            node_id,
            security_level: level,
            parent: RefCell::new(Weak::new()),
            children: RefCell::new(Vec::new()),
        }))
    }

    fn add_child(parent: &GogsSecurityNodeRef, child: GogsSecurityNodeRef) {
        parent.borrow_mut().children.borrow_mut().push(Rc::clone(&child));
        *child.borrow_mut().parent.borrow_mut() = Rc::downgrade(parent);
    }

    fn get_parent(&self) -> Option<GogsSecurityNodeRef> {
        self.parent.borrow().upgrade()
    }

    fn get_child_count(&self) -> usize {
        self.children.borrow().len()
    }

    fn get_info(&self) -> String {
        format!("Node {}: Level {}", self.node_id, self.security_level)
    }
}

fn demo_complex_hierarchy() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║  [Demo 6] 복잡한 계층: 보안 노드 계층 구조                  ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    // [1] 계층 구조 생성
    println!("[1] 3단계 계층 구조 생성:");
    let root = GogsSecurityNode::new(1, 5);
    let branch_a = GogsSecurityNode::new(2, 4);
    let branch_b = GogsSecurityNode::new(3, 4);
    let leaf_a1 = GogsSecurityNode::new(4, 3);
    let leaf_a2 = GogsSecurityNode::new(5, 3);
    let leaf_b1 = GogsSecurityNode::new(6, 3);

    println!("    노드 생성 완료");

    // [2] 계층 연결
    println!("\n[2] 계층 연결:");
    GogsSecurityNode::add_child(&root, Rc::clone(&branch_a));
    GogsSecurityNode::add_child(&root, Rc::clone(&branch_b));
    GogsSecurityNode::add_child(&branch_a, Rc::clone(&leaf_a1));
    GogsSecurityNode::add_child(&branch_a, Rc::clone(&leaf_a2));
    GogsSecurityNode::add_child(&branch_b, Rc::clone(&leaf_b1));

    println!("    root(1, L=5)");
    println!("    ├─ branch_a(2, L=4)");
    println!("    │  ├─ leaf_a1(4, L=3)");
    println!("    │  └─ leaf_a2(5, L=3)");
    println!("    └─ branch_b(3, L=4)");
    println!("       └─ leaf_b1(6, L=3)");

    // [3] 구조 검증
    println!("\n[3] 구조 검증:");
    println!("    root: {}, children: {}",
        root.borrow().get_info(),
        root.borrow().get_child_count());

    println!("    branch_a: {}, children: {}",
        branch_a.borrow().get_info(),
        branch_a.borrow().get_child_count());

    // [4] 역방향 참조 검증
    println!("\n[4] 역방향 참조 검증 (약한 참조):");
    {
        let leaf = leaf_a1.borrow();
        if let Some(parent) = leaf.get_parent() {
            println!("    leaf_a1의 부모: {}", parent.borrow().get_info());
            let grandparent_opt = parent.borrow().get_parent();
            if let Some(grandparent) = grandparent_opt {
                println!("    leaf_a1의 할아버지: {}", grandparent.borrow().get_info());
            }
        }
    }

    // [5] 참조 카운트 확인
    println!("\n[5] 참조 카운트 확인:");
    println!("    root - Strong: {}, Weak: {}",
        Rc::strong_count(&root),
        Rc::weak_count(&root));
    println!("    branch_a - Strong: {}, Weak: {}",
        Rc::strong_count(&branch_a),
        Rc::weak_count(&branch_a));

    println!("\n    ✅ 복잡한 계층도 Weak로 메모리 누수 없이 구현\n");
}

