// [v9.4: 핵심 패턴 2] 강한/약한 카운트 추적
// ============================================================================

fn demo_strong_vs_weak_counts() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║   [Demo 3] 카운트 추적: Strong vs Weak Reference             ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    // [1] 초기 상태
    println!("[1] 초기 상태:");
    let root = TreeNode::new(1);
    println!("    Strong: {}, Weak: {}",
        Rc::strong_count(&root),
        Rc::weak_count(&root));

    // [2] 첫 번째 자식 추가
    println!("\n[2] 첫 번째 자식 추가:");
    let child1 = TreeNode::new(2);
    TreeNode::add_child(&root, Rc::clone(&child1));

    println!("    root - Strong: {}, Weak: {}",
        Rc::strong_count(&root),
        Rc::weak_count(&root));
    println!("    child1 - Strong: {}, Weak: {}",
        Rc::strong_count(&child1),
        Rc::weak_count(&child1));

    // [3] 두 번째 자식 추가
    println!("\n[3] 두 번째 자식 추가:");
    let child2 = TreeNode::new(3);
    TreeNode::add_child(&root, Rc::clone(&child2));

    println!("    root - Strong: {}, Weak: {}",
        Rc::strong_count(&root),
        Rc::weak_count(&root));

    // [4] 손자 추가
    println!("\n[4] 손자 추가:");
    let grandchild = TreeNode::new(4);
    TreeNode::add_child(&child1, Rc::clone(&grandchild));

    println!("    root - Strong: {}, Weak: {}",
        Rc::strong_count(&root),
        Rc::weak_count(&root));
    println!("    child1 - Strong: {}, Weak: {}",
        Rc::strong_count(&child1),
        Rc::weak_count(&child1));

    println!("\n    핵심: WeakCount는 증가하지만 StrongCount는 변화 없음\n");
}

