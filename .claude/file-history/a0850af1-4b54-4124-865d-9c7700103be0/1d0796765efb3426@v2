// Phase 8 v9.4: 순환 참조의 고리 끊기 (Preventing Reference Cycles with Weak<T>)
// Weak<T>를 통한 메모리 누수 방지

use std::rc::{Rc, Weak};
use std::cell::RefCell;

// ============================================================================
// [v9.4: 기본 개념] Weak<T>의 기초
// ============================================================================

/// Weak<T>를 사용한 기본 약한 참조
fn demo_basic_weak() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║          [Demo 1] Weak<T>: 소유하지 않는 참조               ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    // [1] 강한 참조 (Rc<T>)
    println!("[1] 강한 참조 (Rc<T>):");
    {
        let strong = Rc::new(42);
        println!("    강한 참조 생성");
        println!("    Strong count: {}, Weak count: {}",
            Rc::strong_count(&strong),
            Rc::weak_count(&strong));
    }
    // strong이 스코프를 벗어나면 메모리에서 해제됨

    // [2] 약한 참조 (Weak<T>)
    println!("\n[2] 약한 참조 (Weak<T>):");
    {
        let strong = Rc::new(42);
        println!("    초기 상태:");
        println!("    Strong: {}, Weak: {}",
            Rc::strong_count(&strong),
            Rc::weak_count(&strong));

        let weak = Rc::downgrade(&strong);
        println!("\n    downgrade() 후 약한 참조 생성:");
        println!("    Strong: {} (변화 없음)",
            Rc::strong_count(&strong));
        println!("    Weak: {} (증가함)",
            Rc::weak_count(&strong));

        // [3] upgrade() 패턴
        println!("\n[3] upgrade()로 약한 참조를 강한 참조로:");
        match weak.upgrade() {
            Some(strong_ref) => {
                println!("    ✅ 데이터 존재: {}", strong_ref);
            }
            None => {
                println!("    ❌ 데이터 이미 삭제됨");
            }
        }
    } // strong 삭제

    println!("\n[4] strong 삭제 후 upgrade() 시도:");
    // 여기서 weak는 여전히 존재하지만 데이터는 삭제됨
    // (weak를 정의하려면 블록 외부에 있어야 하는데, 여기서는 생략)

    println!("    ✅ Weak<T>는 소유권이 없어 참조 카운트에 영향 없음\n");
}

// ============================================================================
// [v9.4: 핵심 패턴 1] 양방향 트리 (Weak로 부모 참조)
// ============================================================================

type TreeNodeRef = Rc<RefCell<TreeNode>>;
type WeakTreeNodeRef = Weak<RefCell<TreeNode>>;

#[derive(Debug)]
struct TreeNode {
    value: i32,
    parent: RefCell<WeakTreeNodeRef>,
    children: RefCell<Vec<TreeNodeRef>>,
}

impl TreeNode {
    fn new(value: i32) -> TreeNodeRef {
        Rc::new(RefCell::new(Self {
            value,
            parent: RefCell::new(Weak::new()),
            children: RefCell::new(Vec::new()),
        }))
    }

    /// 자식 노드를 추가합니다 (양방향 연결)
    fn add_child(parent: &TreeNodeRef, child: TreeNodeRef) {
        // 부모가 자식을 소유 (강한 참조)
        parent.borrow_mut().children.borrow_mut().push(Rc::clone(&child));
        // 자식이 부모를 참조 (약한 참조) - 순환 참조 방지!
        *child.borrow_mut().parent.borrow_mut() = Rc::downgrade(parent);
    }

    fn get_value(&self) -> i32 {
        self.value
    }

    fn get_parent(&self) -> Option<TreeNodeRef> {
        self.parent.borrow().upgrade()
    }

    fn get_child_count(&self) -> usize {
        self.children.borrow().len()
    }
}

fn demo_tree_with_weak() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║  [Demo 2] 양방향 트리: Weak로 순환 참조 방지                ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    // [1] 트리 구성
    println!("[1] 양방향 트리 구성:");
    let root = TreeNode::new(1);
    let child_a = TreeNode::new(2);
    let child_b = TreeNode::new(3);
    let grandchild = TreeNode::new(4);

    println!("    노드 생성: root(1), child_a(2), child_b(3), grandchild(4)");

    // [2] 부모-자식 관계 설정
    println!("\n[2] 부모-자식 관계 설정:");
    TreeNode::add_child(&root, Rc::clone(&child_a));
    TreeNode::add_child(&root, Rc::clone(&child_b));
    TreeNode::add_child(&child_a, Rc::clone(&grandchild));

    println!("    root → [child_a, child_b]");
    println!("    child_a → [grandchild]");

    // [3] 트리 구조 확인
    println!("\n[3] 트리 구조 확인:");
    println!("    root: value={}, children={}",
        root.borrow().get_value(),
        root.borrow().get_child_count());

    println!("    child_a: value={}, children={}",
        child_a.borrow().get_value(),
        child_a.borrow().get_child_count());

    // [4] 양방향 참조 확인
    println!("\n[4] 양방향 참조 확인:");
    {
        let child_ref = child_a.borrow();
        if let Some(parent) = child_ref.get_parent() {
            println!("    child_a의 부모: {}", parent.borrow().get_value());
        }
    }

    {
        let grandchild_ref = grandchild.borrow();
        if let Some(parent) = grandchild_ref.get_parent() {
            println!("    grandchild의 부모: {}", parent.borrow().get_value());
        }
    }

    println!("\n    ✅ Weak를 사용하여 순환 참조 없이 양방향 참조 구현\n");
}

