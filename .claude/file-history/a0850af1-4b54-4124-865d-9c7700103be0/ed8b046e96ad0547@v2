// 재현 가능한 빌드와 버전 관리
//
fn cargo_lock_importance() {
    println!("[6] Cargo.lock: 재현 가능한 빌드");
    println!("────────────────────────────────────────────────────────────");

    println!("✓ Cargo.lock의 역할");
    println!("  모든 의존성의 정확한 버전을 기록");
    println!("  팀의 모든 개발자가 같은 버전 사용 보장");
    println!("  프로덕션 배포 시 일관성 유지");

    println!();
    println!("✓ Cargo.lock 파일 예시");
    println!("  [[package]]");
    println!("  name = \"rand\"");
    println!("  version = \"0.8.5\"");
    println!("  source = \"registry+https://github.com/rust-lang/crates.io-index\"");

    println!();
    println!("✓ 버전 관리 전략");
    println!("  바이너리 프로젝트:");
    println!("    → Cargo.lock을 version control에 커밋");
    println!("    → 배포 시 정확히 같은 버전 사용");

    println!();
    println!("  라이브러리 프로젝트:");
    println!("    → Cargo.lock을 .gitignore에 추가");
    println!("    → 사용자가 자신의 버전 선택 가능");

    println!();
    println!("✓ 명령어");
    println!("  cargo update           # 최신 버전으로 업데이트");
    println!("  cargo update -p rand   # 특정 패키지만 업데이트");
    println!("  cargo tree             # 의존성 그래프 보기");
    println!();
}

