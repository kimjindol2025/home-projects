// [5] Rand 크레이트 예시 (Rand Crate Example)
// ============================================================================
//
// 난수 생성의 실제 사용 예시
//
fn rand_crate_example() {
    println!("[5] 외부 크레이트 활용: 난수 생성 (Rand)");
    println!("────────────────────────────────────────────────────────────");

    println!("✓ Cargo.toml 설정");
    println!("  [dependencies]");
    println!("  rand = \"0.8\"");

    println!();
    println!("✓ 코드 예시");
    println!("  use rand::Rng;");
    println!("  fn main() {{");
    println!("      let mut rng = rand::thread_rng();");
    println!("      let num: u32 = rng.gen_range(1..100);");
    println!("      println!(\"Random: {{}}\", num);");
    println!("  }}");

    println!();
    println!("✓ 시뮬레이션: 보안 코드 생성");
    simulate_random_generation();

    println!();
    println!("✓ 장점:");
    println!("  - 직접 구현할 필요 없음");
    println!("  - 검증된 알고리즘 (MT19937)");
    println!("  - 높은 성능과 품질");
    println!();
}

// 난수 생성 시뮬레이션
fn simulate_random_generation() {
    println!("  생성 중...");

    // 간단한 의사 난수 생성 (실제로는 rand 크레이트 사용)
    let seed = 2026;
    let security_codes = [
        (seed * 37) % 9000 + 1000,
        (seed * 73) % 9000 + 1000,
        (seed * 149) % 9000 + 1000,
    ];

    for (i, code) in security_codes.iter().enumerate() {
        println!("  보안 코드 {}: {}", i + 1, code);
    }

    analyze_security_strength(security_codes[0] as u32);
}

// 보안 강도 분석
fn analyze_security_strength(code: u32) {
    if code > 5000 {
        println!("  → 분석 결과: 고강도 보안 등급 ✓");
    } else {
        println!("  → 분석 결과: 표준 보안 등급");
    }
}

