"""
Python v1.1 - 객체의 탄생과 동적 타이핑의 실체

탐구(대학): "타입은 어디에 저장되는가?"
증명(대학원): "메모리 관리의 무결성"

파이썬은 모든 것이 객체입니다.
Rust/Gogs가 컴파일 타임에 모든 타입을 결정했다면,
파이썬은 실행 시간(Runtime)에 타입을 결정합니다.

이 '자유'가 시스템 내부에서 어떻게 '기록'되는지 탐구합니다.
"""

import sys
import gc
from typing import Any, Dict


# ============================================================================
# [탐구 1] 파이썬의 변수는 포인터다
# ============================================================================

def analyze_object(data: Any) -> Dict[str, Any]:
    """
    파이썬 객체의 내부 '기록'을 조사하여
    이성적으로 실재하는 메모리 구조를 증명함.

    Returns:
        객체의 메타데이터 딕셔너리
    """
    print(f"\n{'='*70}")
    print(f"분석 대상: {repr(data)} ({type(data).__name__})")
    print(f"{'='*70}")

    # 1. 객체의 고유 ID (메모리 주소)
    # Gogs의 포인터 개념과 연결: 변수는 객체를 가리킬 뿐 값을 담지 않음
    obj_id = id(data)
    print(f"  [메모리 주소] {hex(obj_id)}")

    # 2. 참조 횟수 증명
    # getrefcount()는 호출 시 임시 참조가 추가되어 실제보다 1 높음
    ref_count = sys.getrefcount(data) - 1
    print(f"  [참조 횟수] {ref_count}")
    print(f"    → 이 객체를 몇 개의 변수가 가리키고 있는가?")

    # 3. 타입 정보
    print(f"  [타입] {type(data).__name__}")
    print(f"    → 객체 자체에 저장된 타입 정보 (런타임 검색 가능)")

    # 4. 객체 크기
    size = sys.getsizeof(data)
    print(f"  [메모리 크기] {size} bytes")
    print(f"    → PyObject 헤더 + 실제 데이터")

    # 5. 추가 정보
    print(f"  [dir() 속성 개수] {len(dir(data))}")

    return {
        "id": obj_id,
        "refcount": ref_count,
        "type": type(data).__name__,
        "size": size,
    }


# ============================================================================
# [탐구 2] Identity vs Equality - 객체의 정체성
# ============================================================================

print("\n" + "="*70)
print("# [탐구 2] 같은 값이 다른 객체인가?")
print("="*70)

# 새로운 사고: 같은 숫자라도 파이썬은 이를 어떻게 관리하는가?
# Small Integer Caching: -5 ~ 256 범위의 정수는 캐시됨
a = 256
b = 256
c = 257
d = 257

print("\n[케이스 1] Small Integer Caching (캐시된 범위: -5 ~ 256)")
meta_a = analyze_object(a)
meta_b = analyze_object(b)

print(f"\n[증명]")
print(f"  a = {a}, b = {b}")
print(f"  a is b: {a is b}  (메모리 주소가 같은가?)")
print(f"  a == b: {a == b}  (값이 같은가?)")
print(f"  결론: 작은 정수는 Python이 미리 캐시해서 같은 메모리 주소를 사용")

print("\n[케이스 2] 큰 정수 (캐시 범위 초과: 257 이상)")
meta_c = analyze_object(c)
meta_d = analyze_object(d)

print(f"\n[증명]")
print(f"  c = {c}, d = {d}")
print(f"  c is d: {c is d}  (메모리 주소가 같은가?)")
print(f"  c == d: {c == d}  (값이 같은가?)")
print(f"  결론: 큰 정수는 매번 새로운 객체로 생성됨 (메모리 주소가 다름)")


# ============================================================================
# [탐구 3] 참조 카운팅의 증명
# ============================================================================

print("\n" + "="*70)
print("# [탐구 3] 참조 횟수의 변화 추적")
print("="*70)

# 객체 생성
original_count = 0
obj = 2026
print(f"\nStep 1: obj = 2026")
print(f"  [참조 횟수] {sys.getrefcount(obj) - 1}")

# 참조 증가
ref1 = obj
print(f"\nStep 2: ref1 = obj")
print(f"  [참조 횟수] {sys.getrefcount(obj) - 1}")

ref2 = obj
print(f"\nStep 3: ref2 = obj")
print(f"  [참조 횟수] {sys.getrefcount(obj) - 1}")

# 참조 감소
del ref1
print(f"\nStep 4: del ref1")
print(f"  [참조 횟수] {sys.getrefcount(obj) - 1}")

del ref2
print(f"\nStep 5: del ref2")
print(f"  [참조 횟수] {sys.getrefcount(obj) - 1}")


# ============================================================================
# [탐구 4] 다양한 타입의 객체 분석
# ============================================================================

print("\n" + "="*70)
print("# [탐구 4] 다양한 타입의 메모리 구조")
print("="*70)

test_objects = [
    42,                           # 정수
    3.14,                         # 실수
    "Hello",                      # 문자열
    [1, 2, 3],                    # 리스트
    (1, 2, 3),                    # 튜플
    {"key": "value"},             # 딕셔너리
    {1, 2, 3},                    # 집합
    lambda x: x + 1,              # 함수
]

metadata = {}
for obj in test_objects:
    meta = analyze_object(obj)
    metadata[type(obj).__name__] = meta

print("\n" + "="*70)
print("# [요약] 타입별 메모리 크기 비교")
print("="*70)
for type_name in sorted(metadata.keys()):
    size = metadata[type_name]["size"]
    print(f"  {type_name:15} → {size:4} bytes")


# ============================================================================
# [증명] 가비지 컬렉션과 순환 참조
# ============================================================================

print("\n" + "="*70)
print("# [증명] 순환 참조의 해결 메커니즘")
print("="*70)

print("\n[생성] 순환 참조 구조")
# 리스트가 자기 자신을 참조
circular_list = []
circular_list.append(circular_list)

print(f"  circular_list = []")
print(f"  circular_list.append(circular_list)")
print(f"  [참조 횟수] {sys.getrefcount(circular_list) - 1}")
print(f"    → 자신을 포함해서 참조 횟수가 2 이상")

print("\n[추적] 가비지 컬렉터의 추적")
# 순환 참조 생성
gc.collect()  # 가비지 컬렉션 실행
print(f"  gc.collect() 실행 → 순환 참조 감지 및 해제")

# 삭제
del circular_list
print(f"\n[삭제] del circular_list")
print(f"  → 메모리에서 자동으로 해제됨")


# ============================================================================
# [최종 증명] 파이썬의 메모리 모델 요약
# ============================================================================

print("\n" + "="*70)
print("# [최종 증명] 파이썬의 메모리 무결성")
print("="*70)

print("""
✓ [타입의 동적성]
  모든 변수는 타입을 컴파일 타임에 알 수 없다.
  대신 런타임에 PyObject의 ob_type 포인터로 타입을 추적한다.

✓ [포인터 기반 참조]
  파이썬의 "변수"는 값 자체가 아니라, 메모리 어딘가의 객체를 가리키는 포인터다.
  이는 C의 포인터와 동일한 개념이며, 사용자에게 숨겨져 있을 뿐이다.

✓ [참조 카운팅으로 수명 관리]
  각 객체는 몇 개의 변수가 자신을 가리키고 있는지 기록한다 (refcount).
  참조 카운트가 0이 되면 메모리에서 자동으로 해제된다.

✓ [순환 참조의 감지]
  단순 참조 카운팅으로는 순환 참조를 해결할 수 없다.
  Python은 별도의 가비지 컬렉터를 실행해 순환 참조를 감지하고 해제한다.

결론:
  파이썬의 '자유로운' 동적 타이핑은,
  컴파일러가 미리 하던 일을 런타임이 대신 수행하는 것일 뿐이다.
  이 과정에서 메모리 안전성은 참조 카운팅과 가비지 컬렉션으로 보장된다.

저장 필수: 너는 기록이 증명이다 gogs
""")
