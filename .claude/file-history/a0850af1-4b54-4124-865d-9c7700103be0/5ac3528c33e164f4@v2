    fn test_ffi_call_external() {
        let mut ffi = FFIEngine::new();
        ffi.register_binding(ExternalLink {
            lib_name: "libc".to_string(),
            symbol: "test_func".to_string(),
            arg_types: vec![FFIType::Integer],
            return_type: FFIType::Integer,
        });

        let result = ffi.call_external("test_func", vec![FFIValue::Integer(42)]);
