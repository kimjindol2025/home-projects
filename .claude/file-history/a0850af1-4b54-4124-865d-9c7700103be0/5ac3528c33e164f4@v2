// ============================================================================
// FFI (Foreign Function Interface) - 완성도 있는 구현
// ============================================================================

#[derive(Clone, Debug, PartialEq)]
pub enum FFIType {
    Integer,
    Float,
    String,
    Pointer,
    Void,
}

#[derive(Clone)]
pub struct ExternalLink {
    pub lib_name: String,
    pub symbol: String,
    pub arg_types: Vec<FFIType>,
    pub return_type: FFIType,
}

#[derive(Clone, Debug)]
pub enum FFIValue {
    Integer(i64),
    Float(f64),
    String(String),
    Pointer(usize),
    Void,
}

pub struct FFIEngine {
    pub loaded_libs: HashMap<String, String>,
    pub bindings: HashMap<String, ExternalLink>,
    pub call_count: HashMap<String, usize>,
}

impl FFIEngine {
    pub fn new() -> Self {
        Self {
            loaded_libs: HashMap::new(),
            bindings: HashMap::new(),
            call_count: HashMap::new(),
        }
    }

    pub fn register_binding(&mut self, binding: ExternalLink) {
        self.bindings.insert(binding.symbol.clone(), binding);
    }

    pub fn load_library(&mut self, name: &str, path: &str) -> Result<(), String> {
        // 라이브러리 로드 시뮬레이션
        self.loaded_libs.insert(name.to_string(), path.to_string());
        Ok(())
    }

    pub fn call_external(
        &mut self,
        symbol: &str,
        args: Vec<FFIValue>,
    ) -> Result<FFIValue, String> {
        if !self.bindings.contains_key(symbol) {
            return Err(format!("Symbol '{}' not found", symbol));
        }

        let binding = &self.bindings[symbol];

        // 타입 검증
        if args.len() != binding.arg_types.len() {
            return Err(format!(
                "Argument count mismatch: expected {}, got {}",
                binding.arg_types.len(),
                args.len()
            ));
        }

        // 호출 카운트 증가
        *self.call_count.entry(symbol.to_string()).or_insert(0) += 1;

        // 실제 호출은 시뮬레이션 (보안상 FFI는 런타임에서만 실행 가능)
        Ok(FFIValue::Integer(0))
    }

    pub fn get_call_stats(&self) -> Vec<(String, usize)> {
        let mut stats: Vec<_> = self
            .call_count
            .iter()
            .map(|(k, v)| (k.clone(), *v))
            .collect();
        stats.sort_by(|a, b| b.1.cmp(&a.1));
        stats
    }
}

