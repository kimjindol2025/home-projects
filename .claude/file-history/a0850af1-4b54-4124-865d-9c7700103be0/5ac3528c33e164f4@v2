#[derive(Clone, Debug, PartialEq)]
pub enum DiagnosticLevel {
    Info,
    Warning,
    Error,
}

pub struct Diagnostic {
    pub level: DiagnosticLevel,
    pub file: String,
    pub line: usize,
    pub col: usize,
    pub message: String,
    pub snippet: String,
    pub hint: Option<String>,
}

impl Diagnostic {
    pub fn new(
        level: DiagnosticLevel,
        file: &str,
        line: usize,
        col: usize,
        message: &str,
        snippet: &str,
    ) -> Self {
        Self {
            level,
            file: file.to_string(),
            line,
            col,
            message: message.to_string(),
            snippet: snippet.to_string(),
            hint: None,
        }
    }

    pub fn with_hint(mut self, hint: &str) -> Self {
        self.hint = Some(hint.to_string());
        self
    }

    pub fn report(&self) {
        let prefix = match self.level {
            DiagnosticLevel::Error => "❌ [ERROR]",
            DiagnosticLevel::Warning => "⚠️  [WARNING]",
            DiagnosticLevel::Info => "ℹ️  [INFO]",
        };

        println!("\n{} {}", prefix, self.message);
        println!("  --> {}:{}:{}", self.file, self.line, self.col);
        println!("   |");
        println!(" {:3} | {}", self.line, self.snippet);
        println!("   | {}^ 여기입니다", " ".repeat(self.col.saturating_sub(1)));

        if let Some(hint) = &self.hint {
            println!("   |");
            println!("   = 제안: {}", hint);
        }
    }
}

