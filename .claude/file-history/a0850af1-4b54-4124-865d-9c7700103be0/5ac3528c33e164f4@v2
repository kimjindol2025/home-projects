#[derive(Clone, Debug)]
pub enum RFCStatus {
    Proposed,
    UnderReview,
    Accepted,
    Rejected,
    Implemented,
}

pub struct RFC {
    pub id: String,
    pub title: String,
    pub author: String,
    pub status: RFCStatus,
    pub votes_for: usize,
    pub votes_against: usize,
    pub description: String,
}

impl RFC {
    pub fn new(id: &str, title: &str, author: &str) -> Self {
        Self {
            id: id.to_string(),
            title: title.to_string(),
            author: author.to_string(),
            status: RFCStatus::Proposed,
            votes_for: 0,
            votes_against: 0,
            description: String::new(),
        }
    }

    pub fn with_description(mut self, desc: &str) -> Self {
        self.description = desc.to_string();
        self
    }

    pub fn vote_for(&mut self) {
        self.votes_for += 1;
    }

    pub fn vote_against(&mut self) {
        self.votes_against += 1;
    }

    pub fn decide(&mut self) -> bool {
        if self.votes_for > self.votes_against {
            self.status = RFCStatus::Accepted;
            true
        } else {
            self.status = RFCStatus::Rejected;
            false
        }
    }

    pub fn report(&self) {
        println!("\n📋 RFC-{}: {}", self.id, self.title);
        println!("   Author: {}", self.author);
        println!("   Status: {:?}", self.status);
        println!("   Votes: {} for, {} against", self.votes_for, self.votes_against);
        println!("   Description: {}", self.description);
    }
}

pub struct RFCProcess {
    pub rfcs: HashMap<String, RFC>,
    pub next_id: usize,
}

impl RFCProcess {
    pub fn new() -> Self {
        Self {
            rfcs: HashMap::new(),
            next_id: 1,
        }
    }

    pub fn propose(&mut self, title: &str, author: &str, description: &str) -> String {
        let id = format!("{:03}", self.next_id);
        self.next_id += 1;

        let rfc = RFC::new(&id, title, author).with_description(description);
        self.rfcs.insert(id.clone(), rfc);

        id
    }

    pub fn vote(&mut self, id: &str, for_it: bool) -> Result<(), String> {
        if let Some(rfc) = self.rfcs.get_mut(id) {
            if for_it {
                rfc.vote_for();
            } else {
                rfc.vote_against();
            }
            Ok(())
        } else {
            Err(format!("RFC {} not found", id))
        }
    }

    pub fn finalize(&mut self, id: &str) -> Result<bool, String> {
        if let Some(rfc) = self.rfcs.get_mut(id) {
            Ok(rfc.decide())
        } else {
            Err(format!("RFC {} not found", id))
        }
    }
}

