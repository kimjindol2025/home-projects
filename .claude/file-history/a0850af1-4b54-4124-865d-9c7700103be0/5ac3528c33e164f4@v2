#[derive(Clone, Debug)]
pub enum Platform {
    MacOS,
    Linux,
    Windows,
}

impl Platform {
    pub fn current() -> Self {
        #[cfg(target_os = "macos")]
        {
            return Platform::MacOS;
        }
        #[cfg(target_os = "linux")]
        {
            return Platform::Linux;
        }
        #[cfg(target_os = "windows")]
        {
            return Platform::Windows;
        }
        #[cfg(not(any(target_os = "macos", target_os = "linux", target_os = "windows")))]
        {
            Platform::Linux // 기본값
        }
    }

    pub fn binary_name(&self) -> &str {
        match self {
            Platform::MacOS | Platform::Linux => "gogs",
            Platform::Windows => "gogs.exe",
        }
    }
}

pub struct ToolchainInstaller {
