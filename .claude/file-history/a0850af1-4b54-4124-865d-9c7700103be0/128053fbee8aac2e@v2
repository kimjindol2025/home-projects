{% extends "base.html" %}

{% block title %}대시보드 - 학생관리 시스템{% endblock %}

{% block content %}
<div class="dashboard">
    <h1 class="page-title">📊 대시보드</h1>

    <!-- 통계 카드 -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon">👥</div>
            <div class="stat-content">
                <h3>총 학생</h3>
                <p class="stat-number">{{ stats.total_students }}</p>
                <a href="/students" class="stat-link">→ 학생 목록</a>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon">🏢</div>
            <div class="stat-content">
                <h3>학과</h3>
                <p class="stat-number">{{ stats.departments }}</p>
                <a href="/statistics" class="stat-link">→ 학과 통계</a>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon">📚</div>
            <div class="stat-content">
                <h3>개설 과목</h3>
                <p class="stat-number">{{ stats.courses }}</p>
                <a href="/grades" class="stat-link">→ 성적 현황</a>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon">📋</div>
            <div class="stat-content">
                <h3>성적 기록</h3>
                <p class="stat-number">{{ stats.grades }}</p>
                <a href="/attendance" class="stat-link">→ 출석 현황</a>
            </div>
        </div>
    </div>

    <!-- 기능 안내 -->
    <div class="features-section">
        <h2>✨ 주요 기능</h2>

        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon">🔍</div>
                <h3>학생 정보 관리</h3>
                <p>학생 정보를 조회하고 상세 정보를 확인할 수 있습니다.</p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">📊</div>
                <h3>성적 관리</h3>
                <p>학생의 성적과 평점(GPA)을 조회합니다.</p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">✅</div>
                <h3>출석 관리</h3>
                <p>학생의 출석 현황을 한눈에 확인합니다.</p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">📈</div>
                <h3>통계 분석</h3>
                <p>학과별 통계 정보를 분석합니다.</p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">➕</div>
                <h3>데이터 입력</h3>
                <p>새로운 학생을 추가합니다.</p>
            </div>

            <div class="feature-card">
                <div class="feature-icon">🔗</div>
                <h3>REST API</h3>
                <p>JSON API로 외부 시스템과 통합합니다.</p>
            </div>
        </div>
    </div>

    <!-- 기술 정보 -->
    <div class="tech-info">
        <h2>🛠️ 기술 스택</h2>
        <div class="tech-grid">
            <div class="tech-item">
                <span class="tech-label">Backend:</span>
                <span class="tech-value">Python Flask</span>
            </div>
            <div class="tech-item">
                <span class="tech-label">Database:</span>
                <span class="tech-value">SQLite (v5.2)</span>
            </div>
            <div class="tech-item">
                <span class="tech-label">Frontend:</span>
                <span class="tech-value">HTML/CSS/JavaScript</span>
            </div>
            <div class="tech-item">
                <span class="tech-label">API:</span>
                <span class="tech-value">REST (v5.3)</span>
            </div>
        </div>
    </div>

    <!-- 빠른 액세스 -->
    <div class="quick-access">
        <h2>🚀 빠른 액세스</h2>
        <div class="button-group">
            <a href="/students" class="btn btn-primary">학생 목록 보기</a>
            <a href="/add-student" class="btn btn-success">새 학생 추가</a>
            <a href="/grades" class="btn btn-info">성적 조회</a>
            <a href="/statistics" class="btn btn-warning">통계 분석</a>
        </div>
    </div>
</div>
{% endblock %}
