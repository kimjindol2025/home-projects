// ============================================================================
// [1] 기본 통합 검증 (Basic Integration)
// ============================================================================
//
// 가장 단순한 형태의 통합: 상태 + 조건부 종료
//
fn basic_integration() {
    println!("[1] 기본 통합 검증");
    println!("────────────────────────────────────────────────────────────");

    #[derive(Debug, Clone, PartialEq)]
    enum State {
        Ready,
        Processing,
        Complete,
    }

    let mut state = State::Ready;
    let inputs = vec![1, 2, 3, 4, 5];
    let mut count = 0;

    println!("✓ 기본 루프 통합");
    'basic: loop {
        // v3.6 Guard: 조기 탈출 조건
        if count >= inputs.len() {
            println!("  → 모든 입력 처리 완료");
            break 'basic;
        }

        let input = inputs[count];

        // v3.7 상태 머신
        state = match state {
            State::Ready => {
                println!("  [{}] Ready → Processing", count + 1);
                State::Processing
            }
            State::Processing => {
                println!("  [{}] Processing (input={})", count + 1, input);
                if count == inputs.len() - 1 {
                    State::Complete
                } else {
                    State::Processing
                }
            }
            State::Complete => {
                println!("  [{}] Complete (finished)", count + 1);
                State::Complete
            }
        };

        count += 1;
    }

    println!("  최종 상태: {:?}", state);
    println!();
}

// ============================================================================
// [2] 상태 머신과 가드의 결합 (State Machine + Guards)
// ============================================================================
//
// v3.7 FSM + v3.6 Guard Clause 통합
//
fn state_machine_with_guards() {
    println!("[2] 상태 머신과 가드의 결합");
    println!("────────────────────────────────────────────────────────────");

    #[derive(Debug, Clone, PartialEq)]
    enum SystemStatus {
        Ready,
        Active,
        ShuttingDown,
        EmergencyStop(String),
    }

    let mut status = SystemStatus::Ready;
    let inputs = vec![10, 50, 120, 30, 0];
    let mut history = Vec::new();

    println!("✓ 통합 상태 머신 실행");
    'system: for (cycle, &input) in inputs.iter().enumerate() {
        println!("  Cycle {}: input={}", cycle + 1, input);

        // v3.6 Guard: 비상 정지 상태라면 즉시 종료
        if let SystemStatus::EmergencyStop(ref reason) = status {
            println!("    !! 비상 정지: {}", reason);
            break 'system;
        }

        // v3.7 + v3.4: 상태 머신 + 패턴 가드
        status = match (status.clone(), input) {
            (SystemStatus::Ready, x) if x > 0 => {
                println!("    → Ready → Active");
                SystemStatus::Active
            }
            (SystemStatus::Active, 0) => {
                println!("    → (유효하지 않은 입력, 상태 유지)");
                SystemStatus::Active
            }
            (SystemStatus::Active, x) if x >= 100 => {
                println!("    → Active → EmergencyStop (임계치 초과)");
                SystemStatus::EmergencyStop(format!("Limit exceeded: {}", x))
            }
            (SystemStatus::Active, x) => {
                println!("    → Active (정상 처리: {})", x);
                SystemStatus::Active
            }
            (s, _) => s,
        };

        history.push((cycle + 1, input, format!("{:?}", status)));
    }

    println!("  최종 상태: {:?}", status);
    println!("  이력:");
    for (cycle, input, state) in history {
        println!("    [{:2}] input={:3} → {}", cycle, input, state);
    }
    println!();
}

// ============================================================================
// [3] 반복자와 패턴 매칭 (Iterator + Patterns)
// ============================================================================
//
// v3.8 Iterator + v3.4 Pattern Matching
//
fn iterator_with_patterns() {
    println!("[3] 반복자와 패턴 매칭");
    println!("────────────────────────────────────────────────────────────");

    let signals = vec![10, 0, 85, 92, 120, 0, 45];

    println!("✓ 신호 분석 파이프라인");

    // v3.8 반복자로 필터링
    let valid_signals: Vec<i32> = signals.iter()
        .filter(|&&x| x > 0)
        .cloned()
        .collect();

    println!("  유효한 신호: {:?}", valid_signals);

    // v3.8 + v3.4: 반복자와 패턴 매칭 결합
    let analysis: Vec<String> = signals.iter()
        .enumerate()
        .filter(|(_, &x)| x > 0)
        .map(|(i, &x)| {
            // v3.4: 패턴 매칭으로 분류
            match x {
                0 => format!("[{}] 에러값", i),
                1..=49 => format!("[{}] 낮음({})", i, x),
                50..=99 => format!("[{}] 중간({})", i, x),
                100..=119 => format!("[{}] 높음({})", i, x),
                120.. => format!("[{}] 위험({})", i, x),
            }
        })
        .collect();

    println!("  분석 결과:");
    for result in analysis {
        println!("    {}", result);
    }
    println!();
}

// ============================================================================
// [4] 복합 상태 전이 (Complex State Transitions)
// ============================================================================
//
// 여러 조건이 복합적으로 작용하는 상황
//
fn complex_state_transitions() {
    println!("[4] 복합 상태 전이");
    println!("────────────────────────────────────────────────────────────");

    #[derive(Debug, Clone, PartialEq)]
    enum State {
        Idle,
        Running(u32),      // 전력 수치 포함
        Warning(String),   // 경고 메시지 포함
        Error(String),     // 에러 메시지 포함
    }

    let mut state = State::Idle;
    let commands = vec!["START", "INCREASE", "INCREASE", "WARNING", "ERROR", "RESET"];

    println!("✓ 상태 전이 시뮬레이션");

    for (i, cmd) in commands.iter().enumerate() {
        println!("  [{}] 명령: {}", i + 1, cmd);

        // v3.7: 상태 머신
        state = match (state.clone(), *cmd) {
            (State::Idle, "START") => {
                println!("      → Idle → Running(50)");
                State::Running(50)
            }
            (State::Running(power), "INCREASE") => {
                let new_power = power + 30;
                let next_state = if new_power > 100 {
                    println!("      → Running({}) → Warning", power);
                    State::Warning("High power detected".to_string())
                } else {
                    println!("      → Running({}) → Running({})", power, new_power);
                    State::Running(new_power)
                };
                next_state
            }
            (State::Warning(_), "ERROR") => {
                println!("      → Warning → Error");
                State::Error("System failure".to_string())
            }
            (State::Error(_), "RESET") => {
                println!("      → Error → Idle");
                State::Idle
            }
            (s, _) => {
                println!("      → {} (명령 무시)", format!("{:?}", s).split('(').next().unwrap_or("Unknown"));
                s
            }
        };
    }

    println!("  최종 상태: {:?}", state);
    println!();
}

// ============================================================================
// [5] 통합 에러 처리 (Unified Error Handling)
// ============================================================================
//
// v3.4 Match + v3.1 논리 연산자로 에러 처리
//
fn error_handling_unified() {
    println!("[5] 통합 에러 처리");
    println!("────────────────────────────────────────────────────────────");

    fn process_value(x: i32) -> Result<String, String> {
        // v3.1: 논리 연산자로 범위 검사
        if x < 0 || x > 100 {
            Err(format!("범위 초과: {}", x))
        } else if x == 0 {
            Err("0은 유효하지 않은 값".to_string())
        } else {
            Ok(format!("처리됨: {}", x))
        }
    }

    let values = vec![10, 0, 85, 120, -5, 50];

    println!("✓ 값 검증 및 처리");

    // v3.8: 반복자로 처리
    let results: Vec<String> = values.iter()
        .map(|&x| {
            // v3.4: 패턴 매칭으로 결과 처리
            match process_value(x) {
                Ok(msg) => format!("✓ {}", msg),
                Err(msg) => format!("✗ {}", msg),
            }
        })
        .collect();

    for result in results {
        println!("  {}", result);
    }
    println!();
}

// ============================================================================
// [6] 경계값 처리 (Boundary Conditions)
// ============================================================================
//
// 극단값과 특수 경우에 대한 완벽한 처리
//
fn boundary_conditions() {
    println!("[6] 경계값 처리");
    println!("────────────────────────────────────────────────────────────");

    let test_cases = vec![
        (0, "0 (하한 경계)"),
        (1, "1 (범위 최소)"),
        (50, "50 (중간)"),
        (99, "99 (범위 최대)"),
        (100, "100 (상한 초과 시작)"),
        (i32::MAX / 2, "매우 큰 값"),
    ];

    println!("✓ 경계값 검증");

    for (value, description) in test_cases {
        // v3.4: 패턴 매칭으로 범위 분류
        let classification = match value {
            0 => "에러(0)",
            1..=99 => "정상",
            100..=199 => "경고",
            200.. => "위험",
            _ => "미정의",
        };

        println!("  {:>12} → {}", description, classification);
    }

    println!();
}

// ============================================================================
// [7] 스트레스 테스트 (Stress Test)
// ============================================================================
//
// 다양한 시나리오를 동시에 처리
//
fn stress_test() {
    println!("[7] 스트레스 테스트");
    println!("────────────────────────────────────────────────────────────");

    // 정상 데이터 + 비정상 데이터 + 경계값 혼합
    let mixed_data = vec![
        10,    // 정상
        0,     // 비정상
        50,    // 정상
        -5,    // 비정상
        99,    // 경계값 (최대)
        100,   // 경계값 (초과 시작)
        120,   // 비정상 (극단값)
        75,    // 정상
    ];

    println!("✓ 혼합 데이터 처리 ({} 개)", mixed_data.len());

    let mut valid_count = 0;
    let mut error_count = 0;
    let mut total = 0;

    // v3.8: 반복자로 처리
    mixed_data.iter()
        .enumerate()
        .for_each(|(i, &value)| {
            // v3.1: 논리 연산자
            if value > 0 && value < 100 {
                println!("  [{}] {} → 유효 ✓", i + 1, value);
                valid_count += 1;
            } else {
                println!("  [{}] {} → 무효 ✗", i + 1, value);
                error_count += 1;
            }
            total += 1;
        });

    println!("  통계: 총 {}, 유효 {}, 무효 {}", total, valid_count, error_count);
    println!("  결론: Panic 없음, 모든 경로 안전");
    println!();
}

// ============================================================================
// [8] 최종 검증 (Final Verification)
// ============================================================================
//
// 모든 개념을 통합한 완전한 시뮬레이션 (사용자 예제 포함)
//
fn final_verification() {
    println!("[8] 최종 검증 - 통합 무결성 검사");
    println!("────────────────────────────────────────────────────────────");

    #[derive(Debug, Clone, PartialEq)]
    enum SystemStatus {
        Ready,
        Active,
        ShuttingDown,
        EmergencyStop(String),
    }

    let raw_inputs = vec![10, 85, 0, 120, 45, 99, 0, 200];
    let mut current_status = SystemStatus::Ready;
    let mut log_history = Vec::new();

    println!("✓ v3.9 통합 무결성 검사 시작...");
    println!("  입력: {:?}", raw_inputs);
    println!();

    // v3.2: 반복 루프
    'main_engine: for (cycle, &input) in raw_inputs.iter().enumerate() {
        println!("  [Cycle {}] 입력값: {}", cycle + 1, input);

        // v3.6 Guard: 이미 비상 정지 상태라면 즉시 종료
        if let SystemStatus::EmergencyStop(_) = current_status {
            println!("    → 비상 정지 상태: 루프 종료");
            break 'main_engine;
        }

        // v3.7 + v3.4: 상태 전이와 패턴 가드 매칭
        current_status = match (current_status.clone(), input) {
            // v3.1: 논리 연산자 포함
            (SystemStatus::Ready, _) if input > 0 => {
                println!("    → Ready → Active");
                SystemStatus::Active
            }
            (SystemStatus::Active, i) if i >= 100 => {
                println!("    → Active → EmergencyStop (임계 {}", i);
                SystemStatus::EmergencyStop(format!("Limit exceeded: {}", i))
            }
            (SystemStatus::Active, 0) => {
                println!("    → Active (0 무시, 상태 유지)");
                SystemStatus::Active
            }
            (SystemStatus::Active, i) => {
                println!("    → Active (정상 운영: {})", i);
                SystemStatus::Active
            }
            (status, _) => {
                println!("    → {:?} (상태 유지)", status);
                status
            }
        };

        // v3.8: 반복자로 로그 처리
        log_history.push(format!("  Cycle {}: {:?}", cycle + 1, current_status));
    }

    println!();
    println!("  최종 상태: {:?}", current_status);
    println!();
    println!("  실행 이력:");
    for entry in log_history.iter().take(8) {
        println!("{}", entry);
    }

    println!();
    println!("  ✅ 최종 검증 완료:");
    println!("     - Panic 없음 (모든 경로 안전)");
    println!("     - 상태 전이 명확 (exhaustive matching)");
    println!("     - 비상 종료 가능 (guard clause 작동)");
    println!("     - 완전 기록 (log history 유지)");

    println!();
}

