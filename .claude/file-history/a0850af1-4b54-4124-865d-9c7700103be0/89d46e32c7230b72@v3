// ==========================================
// Phase 6: 제네릭과 트레이트 (Generics & Traits)
// ==========================================

/// 기록할 수 있는 모든 것에 대한 약속(Trait)
///
/// 이 트레이트를 구현하는 타입은 `format_log()` 메서드를 반드시 제공해야 합니다.
/// 이를 통해 어떤 타입이든 GogsLogger에 기록될 수 있습니다.
pub trait Loggable {
    /// 자신의 정보를 기록 형식으로 변환합니다.
    fn format_log(&self) -> String;
}

/// 제네릭 로거: Loggable 트레이트를 구현한 어떤 타입이든 기록할 수 있습니다.
///
/// # 제네릭 파라미터
/// * `T` - Loggable 트레이트를 구현해야 함 (트레이트 바운드)
///
/// # 예제
/// ```
/// struct Task { name: String }
/// impl Loggable for Task {
///     fn format_log(&self) -> String {
///         format!("작업: {}", self.name)
///     }
/// }
///
/// let task = Task { name: "Learning".to_string() };
/// let logger = GogsLogger { entry: task };
/// logger.record();
/// ```
pub struct GogsLogger<T: Loggable> {
    /// 기록할 항목 (T는 반드시 Loggable을 구현해야 함)
    pub entry: T,
}

impl<T: Loggable> GogsLogger<T> {
    /// 제네릭 로거를 사용해 기록합니다.
    pub fn record(&self) {
        println!("[🔖 LOG]: {}", self.entry.format_log());
    }
}
