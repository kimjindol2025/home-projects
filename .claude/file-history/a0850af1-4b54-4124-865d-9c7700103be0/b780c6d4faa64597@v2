"""
Python Elementary v1.5 - 조건문(if) — 똑똑하게 판단하기

탐구(초등학교): "상황에 맞춰 다르게 행동하기"

이제 프로그램은 단순히 시키는 대로 반복하는 것을 넘어,
상황에 따라 스스로 결정을 내리기 시작합니다.
이것이 바로 우리가 나중에 대학 과정에서 다룰
'인공지능'과 '인지적 실행'의 아주 작은 씨앗입니다.

if 문은 "만약 ~라면"이라는 조건을 확인하고,
그 조건이 참(True)일 때만 정해진 코드를 실행합니다.

1. 조건문의 구조
   - if: 만약 이 조건이 맞으면 실행해!
   - elif (else if): 위 조건은 틀렸지만, 이 조건이 맞으면 실행해!
   - else: 위 조건들이 다 틀렸으면 무조건 이걸 실행해!

2. 비교하는 기호 (비교 연산자)
   - == : 같아요 (주의: =은 이름표 붙이기, ==은 비교하기!)
   - != : 달라요
   - > , < : 커요, 작아요
   - >= , <= : 크거나 같아요, 작거나 같아요
"""

print("=" * 70)
print("# Python Elementary v1.5 - 조건문(if) — 똑똑하게 판단하기")
print("=" * 70)

# ============================================================================
# [1단계] 기본 if 문 (한 가지 조건)
# ============================================================================

print("\n[1단계] 기본 if 문 - 한 가지 조건만 확인")
print("-" * 70)

age = 15

print(f"사용자 나이: {age}세")

if age >= 18:
    print("성인이신 것을 환영합니다!")
else:
    print("미성년자입니다. 보호자 동의가 필요합니다.")

print("\n설명:")
print("  ✓ if age >= 18:  → 나이가 18 이상인지 확인")
print("  ✓ 조건이 True이면 if 블록 실행")
print("  ✓ 조건이 False이면 else 블록 실행")

# ============================================================================
# [2단계] if, elif, else 구조 (여러 조건)
# ============================================================================

print("\n[2단계] if, elif, else - 여러 조건을 차례로 확인")
print("-" * 70)

current_temp = 28

print(f"현재 온도: {current_temp}도")
print("\n--- 온도에 따른 알림 ---")

if current_temp >= 30:
    print("🔴 경보: 날씨가 너무 덥습니다! 에어컨을 가동합니다.")
elif current_temp >= 20:
    print("🟢 알림: 활동하기 좋은 날씨입니다.")
elif current_temp >= 10:
    print("🔵 알림: 쌀쌀합니다. 가벼운 외투를 챙기세요.")
else:
    print("❄️  알림: 날씨가 매우 춥습니다. 두꺼운 외투를 입으세요.")

print("\n설명:")
print("  ✓ if first_condition: → 첫 번째 조건 확인")
print("  ✓ elif second_condition: → 첫 번째가 False면 두 번째 확인")
print("  ✓ elif third_condition: → 두 번째도 False면 세 번째 확인")
print("  ✓ else: → 모든 조건이 False면 무조건 실행")

# ============================================================================
# [3단계] 비교 연산자 모두 시험해보기
# ============================================================================

print("\n[3단계] 비교 연산자 - 모든 비교 기호 시험")
print("-" * 70)

score = 85

print(f"학생의 점수: {score}")
print("\n비교 연산자 테스트:")
print(f"  score == 85: {score == 85}   (같다)")
print(f"  score != 80: {score != 80}   (다르다)")
print(f"  score > 80: {score > 80}    (크다)")
print(f"  score < 90: {score < 90}    (작다)")
print(f"  score >= 85: {score >= 85}  (크거나 같다)")
print(f"  score <= 90: {score <= 90}  (작거나 같다)")

# ============================================================================
# [4단계] 주의사항: = 와 == 구분하기
# ============================================================================

print("\n[4단계] 중요한 구분: = (할당) vs == (비교)")
print("-" * 70)

print("잘못된 예:")
print("  x = 10")
print("  if x = 20:  ← 에러! = 는 비교하는 기호가 아니라 '이름표 붙이기'")

print("\n올바른 예:")
print("  x = 10")
print("  if x == 20:  ← 맞다! == 는 '비교하는' 기호")

x = 10
if x == 10:
    print(f"  x의 값이 10과 같습니다. (비교 성공)")

# ============================================================================
# [5단계] 리스트와 함께 사용하기
# ============================================================================

print("\n[5단계] 반복문 안의 조건문 - 리스트에서 특정 데이터 찾기")
print("-" * 70)

basket = ["포도", "딸기", "사과", "배"]

print(f"바구니 내용: {basket}")
print("\n--- 바구니 검사 시작 ---")

for fruit in basket:
    if fruit == "사과":
        print(f"💡 찾았다! {fruit}이 여기에 있습니다.")
    else:
        print(f"[ {fruit} ]는 사과가 아닙니다.")

# ============================================================================
# [6단계] 범위 확인 (and, or)
# ============================================================================

print("\n[6단계] 논리 연산자 - 여러 조건을 함께 확인")
print("-" * 70)

temperature = 25
humidity = 60

print(f"온도: {temperature}도, 습도: {humidity}%")

if temperature >= 20 and temperature <= 30:
    print("✓ 온도가 쾌적한 범위입니다 (20-30도)")

if humidity > 80 or humidity < 30:
    print("⚠️  습도가 불쾌한 범위입니다 (30% 이상 80% 이하 추천)")
else:
    print("✓ 습도가 쾌적한 범위입니다")

print("\n설명:")
print("  ✓ and: 둘 다 True여야 True (그리고)")
print("  ✓ or: 하나만 True여도 True (또는)")

# ============================================================================
# [7단계] 성적 평가 시스템
# ============================================================================

print("\n[7단계] 실용 예제: 성적 평가 시스템")
print("-" * 70)

score = 92

print(f"점수: {score}점")
print("\n평가 결과:")

if score >= 90:
    grade = "A"
    comment = "탁월한 성과! 🌟"
elif score >= 80:
    grade = "B"
    comment = "좋은 성과입니다. 👍"
elif score >= 70:
    grade = "C"
    comment = "평범한 수준입니다."
elif score >= 60:
    grade = "D"
    comment = "개선이 필요합니다. 📚"
else:
    grade = "F"
    comment = "재응시가 필요합니다."

print(f"  학점: {grade}")
print(f"  평가: {comment}")

# ============================================================================
# [8단계] 여러 조건 결합 (복잡한 판단)
# ============================================================================

print("\n[8단계] 복잡한 조건 - 여러 조건을 함께 판단")
print("-" * 70)

day = "토요일"
weather = "맑음"
time_of_day = "오후"

print(f"요일: {day}, 날씨: {weather}, 시간: {time_of_day}")

if day == "토요일" or day == "일요일":
    if weather == "맑음":
        if time_of_day == "오후":
            print("🎉 외출하기 완벽한 시간입니다!")
        else:
            print("📖 실내에서 독서하기 좋은 시간입니다.")
    else:
        print("🏠 집에서 쉬는 시간으로 보내세요.")
else:
    print("🎒 학교/일을 다녀와야 할 시간입니다.")

# ============================================================================
# [9단계] 문자열 비교
# ============================================================================

print("\n[9단계] 문자열 비교 - 글자끼리도 비교할 수 있어요")
print("-" * 70)

password = "1234"
user_input = "1234"

print(f"정답 비밀번호: {password}")
print(f"사용자 입력: {user_input}")

if user_input == password:
    print("✅ 비밀번호가 정확합니다! 접근이 허용됩니다.")
elif user_input == "":
    print("⚠️  비밀번호를 입력해주세요.")
else:
    print("❌ 비밀번호가 틀렸습니다. 다시 시도해주세요.")

# ============================================================================
# [최종 증명]
# ============================================================================

print("\n" + "=" * 70)
print("# [최종 증명] 조건문의 힘")
print("=" * 70)

print("""
✓ [if 문의 기본]
  if 조건:
      조건이 True일 때 실행할 코드

✓ [if-else 구조]
  if 조건:
      True일 때
  else:
      False일 때

✓ [if-elif-else 구조]
  여러 조건을 차례로 확인
  첫 번째부터 시작해서 참인 것을 찾으면 그것만 실행

✓ [비교 연산자]
  == (같다), != (다르다)
  > (크다), < (작다)
  >= (크거나 같다), <= (작거나 같다)

✓ [중요한 규칙]
  = 는 '이름표 붙이기' (할당)
  == 는 '비교하기' (비교)

✓ [논리 연산자]
  and: 둘 다 True여야 True
  or: 하나만 True여도 True

✓ [응용]
  - for 반복문 안에서 조건 확인
  - 성적 평가 시스템
  - 보안 검증 (비밀번호 확인)
  - 복잡한 논리 판단

결론:
  조건문은 프로그램이 '생각'하고 '판단'하게 해줍니다.
  이것이 '인공지능'의 아주 작은 씨앗입니다!
  컴퓨터가 상황을 이해하고 결정을 내릴 수 있게 되는 것,
  이것이 프로그래밍의 가장 흥미로운 부분입니다!

저장 필수 너는 기록이 증명이다 gogs
""")
