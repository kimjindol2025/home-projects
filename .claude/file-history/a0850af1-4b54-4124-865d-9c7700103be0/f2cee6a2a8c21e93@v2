// Phase 13 v14.0: Lexer — 텍스트의 질서화
// 소스 코드를 의미 있는 토큰으로 분해하는 어휘 분석기

use std::fmt;

/// 토큰의 종류를 나타냅니다.
#[derive(Debug, Clone, PartialEq)]
pub enum TokenKind {
    // 리터럴
    Int(i32),
    Float(f64),
    String(String),
    Ident(String),

    // 키워드
    Let,
    Const,
    Fn,
    If,
    Else,
    While,
    For,
    Return,
    Break,
    Continue,

    // 연산자
    Plus,
    Minus,
    Star,
    Slash,
    Percent,
    Equal,
    EqualEqual,
    NotEqual,
    Less,
    LessEqual,
    Greater,
    GreaterEqual,
    Bang,
    And,
    Or,

    // 구분자
    LeftParen,
    RightParen,
    LeftBrace,
    RightBrace,
    LeftBracket,
    RightBracket,
    Comma,
    Semicolon,
    Colon,
    Dot,
    Arrow,
    FatArrow,

    // 특수
    Newline,
    Eof,
    Error(String),
}

impl fmt::Display for TokenKind {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        match self {
            Self::Int(n) => write!(f, "Int({})", n),
            Self::Float(n) => write!(f, "Float({})", n),
            Self::String(s) => write!(f, "String({})", s),
            Self::Ident(s) => write!(f, "Ident({})", s),
            Self::Let => write!(f, "let"),
            Self::Const => write!(f, "const"),
            Self::Fn => write!(f, "fn"),
            Self::If => write!(f, "if"),
            Self::Else => write!(f, "else"),
            Self::While => write!(f, "while"),
            Self::For => write!(f, "for"),
            Self::Return => write!(f, "return"),
            Self::Break => write!(f, "break"),
            Self::Continue => write!(f, "continue"),
            Self::Plus => write!(f, "+"),
            Self::Minus => write!(f, "-"),
            Self::Star => write!(f, "*"),
            Self::Slash => write!(f, "/"),
            Self::Percent => write!(f, "%"),
            Self::Equal => write!(f, "="),
            Self::EqualEqual => write!(f, "=="),
            Self::NotEqual => write!(f, "!="),
            Self::Less => write!(f, "<"),
            Self::LessEqual => write!(f, "<="),
            Self::Greater => write!(f, ">"),
            Self::GreaterEqual => write!(f, ">="),
            Self::Bang => write!(f, "!"),
            Self::And => write!(f, "&&"),
            Self::Or => write!(f, "||"),
            Self::LeftParen => write!(f, "("),
            Self::RightParen => write!(f, ")"),
            Self::LeftBrace => write!(f, "{{"),
            Self::RightBrace => write!(f, "}}"),
            Self::LeftBracket => write!(f, "["),
            Self::RightBracket => write!(f, "]"),
            Self::Comma => write!(f, ","),
            Self::Semicolon => write!(f, ";"),
            Self::Colon => write!(f, ":"),
            Self::Dot => write!(f, "."),
            Self::Arrow => write!(f, "->"),
            Self::FatArrow => write!(f, "=>"),
            Self::Newline => write!(f, "\\n"),
            Self::Eof => write!(f, "EOF"),
            Self::Error(e) => write!(f, "Error({})", e),
        }
    }
}

/// 토큰 구조체: 토큰의 종류, 원본 텍스트, 위치 정보를 포함합니다.
#[derive(Debug, Clone, PartialEq)]
pub struct Token {
    pub kind: TokenKind,
    pub lexeme: String,
    pub line: usize,
    pub column: usize,
}

impl fmt::Display for Token {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        write!(f, "Token({}, \"{}\", {}:{})", self.kind, self.lexeme, self.line, self.column)
    }
}

/// Lexer: 입력 텍스트를 토큰으로 분석합니다.
pub struct Lexer {
    input: Vec<char>,
    position: usize,
    peek_position: usize,
    ch: char,
    line: usize,
    column: usize,
}

impl Lexer {
    /// Lexer를 초기화합니다.
    pub fn new(input: &str) -> Self {
        let chars: Vec<char> = input.chars().collect();
        let mut lexer = Lexer {
            input: chars,
            position: 0,
            peek_position: 1,
            ch: '\0',
            line: 1,
            column: 0,
        };
        lexer.read_char();
        lexer
    }

    /// 다음 문자를 읽습니다.
    fn read_char(&mut self) {
        self.ch = if self.position < self.input.len() {
            self.input[self.position]
        } else {
            '\0'
        };

        self.position = self.peek_position;
        self.peek_position = self.position + 1;

        if self.ch == '\n' {
            self.line += 1;
            self.column = 0;
        } else {
            self.column += 1;
        }
    }

    /// 다음 문자를 미리 봅니다 (읽지 않음).
    fn peek_char(&self) -> char {
        if self.position < self.input.len() {
            self.input[self.position]
        } else {
            '\0'
        }
    }

    /// 공백과 탭을 건너뜁니다.
    fn skip_whitespace(&mut self) {
        while self.ch == ' ' || self.ch == '\t' {
            self.read_char();
        }
    }

    /// 식별자나 키워드를 읽습니다.
    fn read_identifier(&mut self) -> String {
        let start = self.position - 1;
        while self.is_identifier_char(self.ch) {
            self.read_char();
        }
        self.input[start..self.position - 1].iter().collect()
    }

    /// 식별자 문자인지 확인합니다 (문자, 숫자, 언더스코어).
    fn is_identifier_char(&self, ch: char) -> bool {
        self.is_letter(ch) || self.is_digit(ch) || ch == '_'
    }

    /// 숫자를 읽습니다 (정수 또는 실수).
    fn read_number(&mut self) -> TokenKind {
        let start = self.position - 1;

        // 정수 부분
        while self.is_digit(self.ch) {
            self.read_char();
        }

        // 실수 부분 확인
        if self.ch == '.' && self.is_digit(self.peek_char()) {
            self.read_char(); // '.' 넘기기
            while self.is_digit(self.ch) {
                self.read_char();
            }
            let num_str: String = self.input[start..self.position - 1].iter().collect();
            TokenKind::Float(num_str.parse().unwrap_or(0.0))
        } else {
            let num_str: String = self.input[start..self.position - 1].iter().collect();
            TokenKind::Int(num_str.parse().unwrap_or(0))
        }
    }

    /// 문자인지 확인합니다.
    fn is_letter(&self, ch: char) -> bool {
        (ch >= 'a' && ch <= 'z') || (ch >= 'A' && ch <= 'Z')
    }

    /// 숫자인지 확인합니다.
    fn is_digit(&self, ch: char) -> bool {
        ch >= '0' && ch <= '9'
    }

    /// 키워드를 조회합니다.
    fn lookup_keyword(&self, ident: &str) -> TokenKind {
        match ident {
            "let" => TokenKind::Let,
            "const" => TokenKind::Const,
            "fn" => TokenKind::Fn,
            "if" => TokenKind::If,
            "else" => TokenKind::Else,
            "while" => TokenKind::While,
            "for" => TokenKind::For,
            "return" => TokenKind::Return,
            "break" => TokenKind::Break,
            "continue" => TokenKind::Continue,
            _ => TokenKind::Ident(ident.to_string()),
        }
    }

    /// 다음 토큰을 생성합니다 (FSM 기반).
    pub fn next_token(&mut self) -> Token {
        self.skip_whitespace();

        let line = self.line;
        let column = self.column;
        let start_pos = self.position - 1;

        let kind = match self.ch {
            // 식별자 또는 키워드
            c if self.is_letter(c) || c == '_' => {
                let ident = self.read_identifier();
                self.lookup_keyword(&ident)
            }

            // 숫자
            c if self.is_digit(c) => self.read_number(),

            // 연산자와 구분자
            '+' => {
                self.read_char();
                TokenKind::Plus
            }
            '-' => {
                if self.peek_char() == '>' {
                    self.read_char();
                    self.read_char();
                    TokenKind::FatArrow
                } else {
                    self.read_char();
                    TokenKind::Minus
                }
            }
            '*' => {
                self.read_char();
                TokenKind::Star
            }
            '/' => {
                self.read_char();
                TokenKind::Slash
            }
            '%' => {
                self.read_char();
                TokenKind::Percent
            }
            '=' => {
                if self.peek_char() == '=' {
                    self.read_char();
                    self.read_char();
                    TokenKind::EqualEqual
                } else if self.peek_char() == '>' {
                    self.read_char();
                    self.read_char();
                    TokenKind::FatArrow
                } else {
                    self.read_char();
                    TokenKind::Equal
                }
            }
            '!' => {
                if self.peek_char() == '=' {
                    self.read_char();
                    self.read_char();
                    TokenKind::NotEqual
                } else {
                    self.read_char();
                    TokenKind::Bang
                }
            }
            '<' => {
                if self.peek_char() == '=' {
                    self.read_char();
                    self.read_char();
                    TokenKind::LessEqual
                } else {
                    self.read_char();
                    TokenKind::Less
                }
            }
            '>' => {
                if self.peek_char() == '=' {
                    self.read_char();
                    self.read_char();
                    TokenKind::GreaterEqual
                } else {
                    self.read_char();
                    TokenKind::Greater
                }
            }
            '&' => {
                if self.peek_char() == '&' {
                    self.read_char();
                    self.read_char();
                    TokenKind::And
                } else {
                    self.read_char();
                    TokenKind::Error("unexpected character '&'".to_string())
                }
            }
            '|' => {
                if self.peek_char() == '|' {
                    self.read_char();
                    self.read_char();
                    TokenKind::Or
                } else {
                    self.read_char();
                    TokenKind::Error("unexpected character '|'".to_string())
                }
            }
            '(' => {
                self.read_char();
                TokenKind::LeftParen
            }
            ')' => {
                self.read_char();
                TokenKind::RightParen
            }
            '{' => {
                self.read_char();
                TokenKind::LeftBrace
            }
            '}' => {
                self.read_char();
                TokenKind::RightBrace
            }
            '[' => {
                self.read_char();
                TokenKind::LeftBracket
            }
            ']' => {
                self.read_char();
                TokenKind::RightBracket
            }
            ',' => {
                self.read_char();
                TokenKind::Comma
            }
            ';' => {
                self.read_char();
                TokenKind::Semicolon
            }
            ':' => {
                self.read_char();
                TokenKind::Colon
            }
            '.' => {
                self.read_char();
                TokenKind::Dot
            }
            '\n' => {
                self.read_char();
                TokenKind::Newline
            }
            '\0' => TokenKind::Eof,
            c => {
                self.read_char();
                TokenKind::Error(format!("unexpected character '{}'", c))
            }
        };

        let lexeme = match &kind {
            TokenKind::Eof => String::new(),
            TokenKind::Error(_) => String::new(),
            _ => {
                let end_pos = (self.position - 1).min(self.input.len());
                self.input[start_pos..end_pos].iter().collect()
            }
        };

        Token { kind, lexeme, line, column }
    }

    /// 모든 토큰을 수집합니다.
    pub fn tokenize(&mut self) -> Vec<Token> {
        let mut tokens = Vec::new();
        loop {
            let token = self.next_token();
            let is_eof = token.kind == TokenKind::Eof;
            tokens.push(token);
            if is_eof {
                break;
            }
        }
        tokens
    }
}

