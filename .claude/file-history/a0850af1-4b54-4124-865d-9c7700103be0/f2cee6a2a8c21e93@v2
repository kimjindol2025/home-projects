fn demo_basic_declaration() {
    println!("[데모 1] 기본 변수 선언");
    println!("─────────────────────");

    let code = "let x = 10;";
    println!("Input: {}", code);

    let mut lexer = Lexer::new(code);
    let tokens = lexer.tokenize();

    print!("Tokens: ");
    for (i, token) in tokens.iter().enumerate() {
        if i > 0 {
            print!(", ");
        }
        print!("{}", token.kind);
    }
    println!("\n");
}

fn demo_arithmetic_operations() {
    println!("[데모 2] 산술 연산");
    println!("─────────────────────");

    let code = "a + b - c * d / e";
    println!("Input: {}", code);

    let mut lexer = Lexer::new(code);
    let tokens = lexer.tokenize();

    println!("상세 토큰:");
    for token in &tokens {
        println!("  {}", token);
    }
    println!();
}

fn demo_comparison_operations() {
    println!("[데모 3] 비교 연산");
    println!("─────────────────────");

    let code = "x == y && z < 10 || w >= 5";
    println!("Input: {}", code);

    let mut lexer = Lexer::new(code);
    let tokens = lexer.tokenize();

    print!("Tokens: ");
    for (i, token) in tokens.iter().enumerate() {
        if i > 0 {
            print!(", ");
        }
        print!("{}", token.kind);
    }
    println!("\n");
}

fn demo_control_flow() {
    println!("[데모 4] 제어 구조");
    println!("─────────────────────");

    let code = "if (x > 0) {{ return x; }}";
    println!("Input: {}", code);

    let mut lexer = Lexer::new(code);
    let tokens = lexer.tokenize();

    println!("토큰 개수: {}", tokens.len() - 1); // EOF 제외
    println!("첫 3개 토큰:");
    for token in tokens.iter().take(3) {
        println!("  {}", token);
    }
    println!();
}

fn demo_function_definition() {
    println!("[데모 5] 함수 정의");
    println!("─────────────────────");

    let code = "fn add(a, b) -> i32 {{ a + b }}";
    println!("Input: {}", code);

    let mut lexer = Lexer::new(code);
    let tokens = lexer.tokenize();

    print!("Tokens: ");
    for (i, token) in tokens.iter().enumerate() {
        if i > 0 {
            print!(", ");
        }
        print!("{}", token.kind);
    }
    println!("\n");
}

fn demo_complex_identifiers() {
    println!("[데모 6] 복합 식별자");
    println!("─────────────────────");

    let code = "my_var_123 = count_x + _private_var";
    println!("Input: {}", code);

    let mut lexer = Lexer::new(code);
    let tokens = lexer.tokenize();

    println!("식별자 추출:");
    for token in &tokens {
        if let TokenKind::Ident(name) = &token.kind {
            println!("  - {}", name);
        }
    }
    println!();
}

fn demo_float_handling() {
    println!("[데모 7] 실수 처리");
    println!("─────────────────────");

    let code = "3.14 + 2.71 - 1.0";
    println!("Input: {}", code);

    let mut lexer = Lexer::new(code);
    let tokens = lexer.tokenize();

    println!("수치 토큰:");
    for token in &tokens {
        match &token.kind {
            TokenKind::Float(f) => println!("  Float: {}", f),
            TokenKind::Int(i) => println!("  Int: {}", i),
            _ => {}
        }
    }
    println!();
}

fn demo_error_detection() {
    println!("[데모 8] 에러 감지");
    println!("─────────────────────");

    let code = "x & y";
    println!("Input: {}", code);

    let mut lexer = Lexer::new(code);
    let tokens = lexer.tokenize();

    println!("토큰 분석:");
    for token in &tokens {
        match &token.kind {
            TokenKind::Error(e) => println!("  ❌ Error at {}:{} - {}", token.line, token.column, e),
            _ => println!("  ✓ {}", token.kind),
        }
    }
    println!();
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_basic_keywords() {
        let mut lexer = Lexer::new("let const fn");
        let tokens = lexer.tokenize();
        assert_eq!(tokens[0].kind, TokenKind::Let);
        assert_eq!(tokens[1].kind, TokenKind::Const);
        assert_eq!(tokens[2].kind, TokenKind::Fn);
    }

    #[test]
    fn test_integers() {
        let mut lexer = Lexer::new("42 100 0");
        let tokens = lexer.tokenize();
        assert_eq!(tokens[0].kind, TokenKind::Int(42));
        assert_eq!(tokens[1].kind, TokenKind::Int(100));
        assert_eq!(tokens[2].kind, TokenKind::Int(0));
    }

    #[test]
    fn test_floats() {
        let mut lexer = Lexer::new("3.14 2.71");
        let tokens = lexer.tokenize();
        assert_eq!(tokens[0].kind, TokenKind::Float(3.14));
        assert_eq!(tokens[1].kind, TokenKind::Float(2.71));
    }

    #[test]
    fn test_identifiers() {
        let mut lexer = Lexer::new("my_var count_123 _private");
        let tokens = lexer.tokenize();
        assert_eq!(tokens[0].kind, TokenKind::Ident("my_var".to_string()));
        assert_eq!(tokens[1].kind, TokenKind::Ident("count_123".to_string()));
        assert_eq!(tokens[2].kind, TokenKind::Ident("_private".to_string()));
    }

    #[test]
    fn test_operators() {
        let mut lexer = Lexer::new("+ - * / == != < > && ||");
        let tokens = lexer.tokenize();
        assert_eq!(tokens[0].kind, TokenKind::Plus);
        assert_eq!(tokens[1].kind, TokenKind::Minus);
        assert_eq!(tokens[2].kind, TokenKind::Star);
        assert_eq!(tokens[3].kind, TokenKind::Slash);
        assert_eq!(tokens[4].kind, TokenKind::EqualEqual);
        assert_eq!(tokens[5].kind, TokenKind::NotEqual);
        assert_eq!(tokens[6].kind, TokenKind::Less);
        assert_eq!(tokens[7].kind, TokenKind::Greater);
        assert_eq!(tokens[8].kind, TokenKind::And);
        assert_eq!(tokens[9].kind, TokenKind::Or);
    }

    #[test]
    fn test_delimiters() {
        let mut lexer = Lexer::new("( ) { } [ ] , ; : . -> =>");
        let tokens = lexer.tokenize();
        assert_eq!(tokens[0].kind, TokenKind::LeftParen);
        assert_eq!(tokens[1].kind, TokenKind::RightParen);
        assert_eq!(tokens[2].kind, TokenKind::LeftBrace);
        assert_eq!(tokens[3].kind, TokenKind::RightBrace);
        assert_eq!(tokens[4].kind, TokenKind::LeftBracket);
        assert_eq!(tokens[5].kind, TokenKind::RightBracket);
        assert_eq!(tokens[6].kind, TokenKind::Comma);
        assert_eq!(tokens[7].kind, TokenKind::Semicolon);
        assert_eq!(tokens[8].kind, TokenKind::Colon);
        assert_eq!(tokens[9].kind, TokenKind::Dot);
        assert_eq!(tokens[10].kind, TokenKind::FatArrow);
        assert_eq!(tokens[11].kind, TokenKind::FatArrow);
    }

    #[test]
    fn test_complex_expression() {
        let mut lexer = Lexer::new("let x = 10;");
        let tokens = lexer.tokenize();
        assert_eq!(tokens[0].kind, TokenKind::Let);
        assert_eq!(tokens[1].kind, TokenKind::Ident("x".to_string()));
        assert_eq!(tokens[2].kind, TokenKind::Equal);
        assert_eq!(tokens[3].kind, TokenKind::Int(10));
        assert_eq!(tokens[4].kind, TokenKind::Semicolon);
        assert_eq!(tokens[5].kind, TokenKind::Eof);
    }

    #[test]
    fn test_error_detection() {
        let mut lexer = Lexer::new("x & y");
        let tokens = lexer.tokenize();

        let has_error = tokens.iter().any(|t| matches!(t.kind, TokenKind::Error(_)));
        assert!(has_error);
    }
}
