// Phase 6 v7.1: 구조체 수명 명시 (Lifetime Annotations in Structs)
// ============================================================================
// 철학: "구조체가 소유하지 않은 데이터로 만든 도구는,
//       그 데이터가 살아있는 동안에만 의미가 있다."
//
// 지금까지: 함수의 참조자 관계를 정의했다면
// 이제: 구조체 필드의 참조자 관계를 정의합니다.
//
// [핵심 목표]:
// - 구조체가 참조자를 안전하게 보관
// - 메모리를 복사하지 않고 참조만 사용
// - 저지연(Low-Latency) 설계 완성
// ============================================================================

// ============================================================================
// [패턴 1] 단일 참조자를 가진 구조체
// ============================================================================

/// [기본 구조체] 하나의 텍스트 라인을 담음
struct Line<'a> {
    content: &'a str,
}

impl<'a> Line<'a> {
    /// 라인 생성
    fn new(content: &'a str) -> Self {
        Self { content }
    }

    /// 라인 출력
    fn print(&self) {
        println!("📄 {}", self.content);
    }

    /// 라인 길이
    fn length(&self) -> usize {
        self.content.len()
    }

    /// 라인이 특정 문자열을 포함하는가?
    fn contains(&self, pattern: &str) -> bool {
        self.content.contains(pattern)
    }
}

// ============================================================================
// [패턴 2] 여러 참조자를 가진 구조체 (같은 수명)
// ============================================================================

/// [다중 참조자] 텍스트의 여러 부분을 담음
struct TextFragment<'a> {
    prefix: &'a str,
    main: &'a str,
    suffix: &'a str,
}

impl<'a> TextFragment<'a> {
    /// 조각 생성
    fn new(prefix: &'a str, main: &'a str, suffix: &'a str) -> Self {
        Self {
            prefix,
            main,
            suffix,
        }
    }

    /// 전체 텍스트 조합
    fn full_text(&self) -> String {
        format!("{}{}{}", self.prefix, self.main, self.suffix)
    }

    /// 가장 긴 부분 찾기
    fn longest_part(&self) -> &'a str {
        let lengths = [self.prefix.len(), self.main.len(), self.suffix.len()];
        let max_idx = lengths.iter().position(|&len| len == lengths.iter().max().copied().unwrap()).unwrap();

        match max_idx {
            0 => self.prefix,
            1 => self.main,
            _ => self.suffix,
        }
    }

    /// 부분 출력
    fn display(&self) {
        println!("Prefix: '{}' | Main: '{}' | Suffix: '{}'",
                 self.prefix, self.main, self.suffix);
    }
}

// ============================================================================
// [패턴 3] 여러 참조자를 가진 구조체 (다른 수명)
// ============================================================================

/// [다중 수명] 서로 다른 수명을 가진 데이터들
struct TextComparator<'a, 'b> {
    first: &'a str,
    second: &'b str,
}

impl<'a, 'b> TextComparator<'a, 'b> {
    /// 비교기 생성
    fn new(first: &'a str, second: &'b str) -> Self {
        Self { first, second }
    }

    /// 길이 비교
    fn compare_length(&self) -> std::cmp::Ordering {
        self.first.len().cmp(&self.second.len())
    }

    /// 더 긴 텍스트 반환
    fn longer(&self) -> &str {
        if self.first.len() > self.second.len() {
            self.first
        } else {
            self.second
        }
    }

    /// 길이 합
    fn total_length(&self) -> usize {
        self.first.len() + self.second.len()
    }
}

// ============================================================================
// [패턴 4] 혼합 (소유권 + 참조)
// ============================================================================

/// [혼합형] 소유권과 참조를 함께 보유
struct Message<'a> {
    author: String,        // 소유권: 저자명 (구조체가 소유)
    content: &'a str,      // 참조: 메시지 내용 (빌려옴)
    timestamp: String,     // 소유권: 시간 (구조체가 소유)
}

impl<'a> Message<'a> {
    /// 메시지 생성
    fn new(author: &str, content: &'a str, timestamp: &str) -> Self {
        Self {
            author: author.to_string(),
            content,
            timestamp: timestamp.to_string(),
        }
    }

    /// 메시지 출력
    fn display(&self) {
        println!("[{}] {}: {}", self.timestamp, self.author, self.content);
    }

    /// 메시지 요약
    fn summary(&self) -> String {
        let truncated = if self.content.len() > 30 {
            format!("{}...", &self.content[0..30])
        } else {
            self.content.to_string()
        };
        format!("@{}: {}", self.author, truncated)
    }
}

// ============================================================================
// [실전 설계] 스마트 로그 파서
// ============================================================================

/// [로그 항목]
struct LogEntry<'a> {
    level: &'a str,      // "INFO", "ERROR" 등
    message: &'a str,    // 로그 메시지
    timestamp: &'a str,  // 시간
}

impl<'a> LogEntry<'a> {
    /// 로그 라인 파싱
    /// 형식: "LEVEL | MESSAGE | TIMESTAMP"
    fn parse(line: &'a str) -> Option<Self> {
        let parts: Vec<&'a str> = line.split('|').collect();
        if parts.len() >= 3 {
            Some(LogEntry {
                level: parts[0].trim(),
                message: parts[1].trim(),
                timestamp: parts[2].trim(),
            })
        } else {
            None
        }
    }

    /// 포맷된 출력
    fn display(&self) {
        let level_emoji = match self.level {
            "INFO" => "ℹ️",
            "WARN" => "⚠️",
            "ERROR" => "🔴",
            "DEBUG" => "🔧",
            _ => "❓",
        };
        println!("{} [{}] {}: {}", level_emoji, self.timestamp, self.level, self.message);
    }

    /// 심각도 판정
    fn is_critical(&self) -> bool {
        self.level == "ERROR"
    }

    /// 심각도 숫자 (0-10)
    fn severity_score(&self) -> u8 {
        match self.level {
            "DEBUG" => 1,
            "INFO" => 3,
            "WARN" => 6,
            "ERROR" => 9,
            _ => 5,
        }
    }
}

/// [로그 파서]
struct LogParser<'a> {
    source: &'a str,        // 원본 로그 전체
    lines: Vec<&'a str>,    // 각 줄의 참조
}

impl<'a> LogParser<'a> {
    /// 파서 생성
    fn new(source: &'a str) -> Self {
        let lines = source.lines().collect();
        Self { source, lines }
    }

    /// 모든 항목 파싱
    fn parse_all(&self) -> Vec<LogEntry<'a>> {
        self.lines
            .iter()
            .filter_map(|line| LogEntry::parse(line))
            .collect()
    }

    /// 특정 레벨만 필터링
    fn filter_by_level(&self, level: &str) -> Vec<LogEntry<'a>> {
        self.parse_all()
            .into_iter()
            .filter(|entry| entry.level == level)
            .collect()
    }

    /// 심각한 항목만 필터링
    fn critical_entries(&self) -> Vec<LogEntry<'a>> {
        self.parse_all()
            .into_iter()
            .filter(|entry| entry.is_critical())
            .collect()
    }

    /// 통계 정보
    fn statistics(&self) {
        let entries = self.parse_all();
        println!("📊 로그 통계:");
        println!("  총 항목: {}", entries.len());
        println!("  심각한 항목: {}", entries.iter().filter(|e| e.is_critical()).count());

        let avg_severity: f64 = entries.iter()
            .map(|e| e.severity_score() as f64)
            .sum::<f64>() / entries.len() as f64;
        println!("  평균 심각도: {:.1}/10", avg_severity);
    }
}

