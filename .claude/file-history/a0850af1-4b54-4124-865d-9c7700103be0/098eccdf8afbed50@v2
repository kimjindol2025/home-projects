### 2단계: Gogs로 작성된 컴파일러

```gogs
// src/compiler.gogs
// Gogs로 작성된 Gogs 컴파일러

fn compile(source: String) -> Array<u8> {
    // 1. 렉싱
    let tokens = lexer.tokenize(source);

    // 2. 파싱
    let ast = parser.parse(tokens);

    // 3. 타입 체크
    let checked_ast = type_checker.check(ast);

    // 4. 코드 생성
    let bytecode = code_generator.generate(checked_ast);

    // 5. 최적화 (선택)
    let optimized = optimizer.optimize(bytecode);

    return optimized;
}

fn main() {
    let source = read_file("src/compiler.gogs");
    let bytecode = compile(source);
    write_file("stage2_compiler", bytecode);
}
```

### 3단계: 검증 스크립트

```bash
#!/bin/bash
# bootstrap.sh

echo "[Stage 0] Rust 컴파일러 빌드..."
cargo build --release
STAGE0=./target/release/gogs_compiler

echo "[Stage 1] Stage 0으로 Gogs 컴파일러 컴파일..."
$STAGE0 compile src/compiler.gogs > stage1_compiler
chmod +x stage1_compiler

echo "[Stage 2] Stage 1로 다시 컴파일..."
./stage1_compiler compile src/compiler.gogs > stage2_compiler
chmod +x stage2_compiler

echo "[Verify] 바이너리 비교..."
if cmp stage1_compiler stage2_compiler; then
    echo "✓ 셀프 호스팅 성공!"
    echo "  Stage 1과 Stage 2가 일치합니다."
else
    echo "✗ 셀프 호스팅 실패"
    echo "  Stage 1과 Stage 2가 다릅니다."
    exit 1
fi
```

