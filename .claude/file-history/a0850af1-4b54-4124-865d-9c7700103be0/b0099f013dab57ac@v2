// [예제 8] 완전한 API 제공 (조회 + 수정 + 소비)
// ============================================================================
struct TodoItem {
    id: u32,
    title: String,
    completed: bool,
}

impl TodoItem {
    // 생성자
    fn new(id: u32, title: String) -> TodoItem {
        TodoItem { id, title, completed: false }
    }

    // &self 메서드: 조회
    fn get_id(&self) -> u32 {
        self.id
    }

    fn get_title(&self) -> &str {
        &self.title
    }

    fn is_completed(&self) -> bool {
        self.completed
    }

    fn display(&self) {
        let status = if self.completed { \"✓\" } else { \"○\" };
        println!(\"{} [{}] {}\", status, self.id, self.title);
    }

    // &mut self 메서드: 수정
    fn mark_completed(&mut self) {
        self.completed = true;
    }

    fn update_title(&mut self, new_title: String) {
        self.title = new_title;
    }

    // self 메서드: 소비
    fn into_string(self) -> String {
        format!(\"[{}] {} (완료: {})\", self.id, self.title, self.completed)
    }
}

struct TodoList {
    items: Vec<TodoItem>,
}

impl TodoList {
    fn new() -> TodoList {
        TodoList { items: Vec::new() }
    }

    fn add(&mut self, item: TodoItem) {
        self.items.push(item);
    }

    fn complete(&mut self, id: u32) -> bool {
        for item in &mut self.items {
            if item.get_id() == id {
                item.mark_completed();
                return true;
            }
        }
        false
    }

    fn list_all(&self) {
        println!(\"\\n할일 목록:\");
        for item in &self.items {
            item.display();
        }
    }

    fn clear_completed(self) -> Vec<String> {
        self.items
            .into_iter()
            .filter(|item| !item.is_completed())
            .map(|item| item.into_string())
            .collect()
    }
}

fn complete_api_example() {
    println!(\"\\n[예제 8] 완전한 API 제공\");
    println!(\"═════════════════════════════════════════\");

    let mut todo_list = TodoList::new();

    let task1 = TodoItem::new(1, \"러스트 배우기\".to_string());
    let task2 = TodoItem::new(2, \"프로젝트 만들기\".to_string());
    let task3 = TodoItem::new(3, \"배포하기\".to_string());

    todo_list.add(task1);
    todo_list.add(task2);
    todo_list.add(task3);

    todo_list.list_all();

    println!(\"\\n[완료 표시]\");
    todo_list.complete(1);
    todo_list.complete(3);
    todo_list.list_all();

    println!(\"\\n[남은 작업]\");
    let remaining = todo_list.clear_completed();
    for task in remaining {
        println!(\"  - {}\", task);
    }
}

