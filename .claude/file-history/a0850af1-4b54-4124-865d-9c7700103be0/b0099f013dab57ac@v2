// [예제 7] 자동 참조 역참조 (Deref Coercion)
// ============================================================================
struct Point {
    x: i32,
    y: i32,
}

impl Point {
    fn new(x: i32, y: i32) -> Point {
        Point { x, y }
    }

    fn distance_from_origin(&self) -> f64 {
        (((self.x.pow(2) + self.y.pow(2)) as f64).sqrt())
    }

    fn move_by(&mut self, dx: i32, dy: i32) {
        self.x += dx;
        self.y += dy;
    }

    fn display(&self) {
        println!(\"Point({}, {})\", self.x, self.y);
    }
}

fn auto_deref_methods() {
    println!(\"\\n[예제 7] 자동 참조 역참조 (Deref Coercion)\");
    println!(\"═════════════════════════════════════════\");

    let point = Point::new(3, 4);
    // 다음은 모두 동일함 (Rust가 자동으로 처리)
    println!(\"거리: {:.2}\", point.distance_from_origin());

    let mut point2 = Point::new(0, 0);
    point2.move_by(5, 5);
    point2.display();

    // Box로 감싼 Point도 동일하게 작동
    let mut boxed_point = std::boxed::Box::new(Point::new(1, 1));
    boxed_point.move_by(2, 2);
    boxed_point.display();
}

