// [예제 5] 생성자 패턴 (Constructor Pattern)
// ============================================================================
struct ServerConfig {
    host: String,
    port: u16,
    timeout: u32,
}

impl ServerConfig {
    // 생성자 1: 기본값
    fn new() -> ServerConfig {
        ServerConfig {
            host: \"localhost\".to_string(),
            port: 8080,
            timeout: 30,
        }
    }

    // 생성자 2: 매개변수 포함
    fn with_config(host: &str, port: u16, timeout: u32) -> ServerConfig {
        ServerConfig {
            host: host.to_string(),
            port,
            timeout,
        }
    }

    // 생성자 3: 개발용 기본값
    fn development() -> ServerConfig {
        ServerConfig {
            host: \"localhost\".to_string(),
            port: 3000,
            timeout: 10,
        }
    }

    // 생성자 4: 프로덕션용 기본값
    fn production() -> ServerConfig {
        ServerConfig {
            host: \"0.0.0.0\".to_string(),
            port: 80,
            timeout: 60,
        }
    }

    fn display(&self) {
        println!(\"Server Config: {}:{} (timeout: {}초)\", self.host, self.port, self.timeout);
    }
}

fn constructor_pattern() {
    println!(\"\\n[예제 5] 생성자 패턴\");
    println!(\"═════════════════════════════════════════\");

    let default_config = ServerConfig::new();
    default_config.display();

    let custom_config = ServerConfig::with_config(\"192.168.1.1\", 9000, 45);
    custom_config.display();

    let dev_config = ServerConfig::development();
    dev_config.display();

    let prod_config = ServerConfig::production();
    prod_config.display();
}

// ============================================================================
// [예제 6] 메서드 체이닝 (Method Chaining - Builder Pattern)
// ============================================================================
struct DatabaseConfig {
    host: String,
    port: u16,
    database: String,
    username: String,
    pool_size: u32,
}

impl DatabaseConfig {
    fn new() -> Self {
        DatabaseConfig {
            host: \"localhost\".to_string(),
            port: 5432,
            database: \"mydb\".to_string(),
            username: \"root\".to_string(),
            pool_size: 10,
        }
    }

    // 각 메서드가 self를 반환하여 체이닝 가능
    fn host(mut self, host: &str) -> Self {
        self.host = host.to_string();
        self
    }

    fn port(mut self, port: u16) -> Self {
        self.port = port;
        self
    }

    fn database(mut self, database: &str) -> Self {
        self.database = database.to_string();
        self
    }

    fn username(mut self, username: &str) -> Self {
        self.username = username.to_string();
        self
    }

    fn pool_size(mut self, pool_size: u32) -> Self {
        self.pool_size = pool_size;
        self
    }

    fn display(&self) {
        println!(
            \"DB Config: {}@{}:{}/{} (pool: {})\",
            self.username, self.host, self.port, self.database, self.pool_size
        );
    }
}

fn method_chaining() {
    println!(\"\\n[예제 6] 메서드 체이닝 (빌더 패턴)\");
    println!(\"═════════════════════════════════════════\");

    // 체이닝을 통한 자연스러운 구성
    let config = DatabaseConfig::new()
        .host(\"db.example.com\")
        .port(3306)
        .database(\"production\")
        .username(\"app_user\")
        .pool_size(50);

    config.display();
}

