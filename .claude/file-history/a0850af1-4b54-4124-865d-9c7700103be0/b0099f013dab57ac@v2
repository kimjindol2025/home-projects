// ============================================================================
// [예제 1] impl 블록의 기본 & &self 메서드
// ============================================================================
struct Rectangle {
    width: u32,
    height: u32,
}

impl Rectangle {
    // &self 메서드: 구조체를 읽기만 함
    fn area(&self) -> u32 {
        self.width * self.height
    }

    fn perimeter(&self) -> u32 {
        (self.width + self.height) * 2
    }

    fn is_square(&self) -> bool {
        self.width == self.height
    }

    fn display(&self) {
        println!(
            \"Rectangle: {}x{} (면적: {}, 둘레: {})\",
            self.width,
            self.height,
            self.area(),
            self.perimeter()
        );
    }
}

fn struct_with_impl_basics() {
    println!(\"\\n[예제 1] impl 블록의 기본 & &self 메서드\");
    println!(\"═══════════════════════════════════════════\");

    let rect1 = Rectangle { width: 30, height: 50 };
    println!(\"면적: {}\", rect1.area());           // 1500
    println!(\"둘레: {}\", rect1.perimeter());      // 160
    println!(\"정사각형?: {}\", rect1.is_square()); // false

    let rect2 = Rectangle { width: 20, height: 20 };
    rect2.display();

    // 메서드 호출 후에도 rect1, rect2 사용 가능 (&self이므로)
    println!(\"rect1 재사용 가능: {:?}\", rect1.width);
}

// ============================================================================
// [예제 2] &self 메서드: 데이터 조회 (Immutable Methods)
// ============================================================================
struct User {
    id: u64,
    name: String,
    email: String,
    age: u8,
}

impl User {
    // 생성자 (연관 함수 - self 없음)
    fn new(id: u64, name: String, email: String, age: u8) -> User {
        User { id, name, email, age }
    }

    // &self 메서드: 조회
    fn display_info(&self) {
        println!(\"ID: {}, Name: {}, Email: {}, Age: {}\", self.id, self.name, self.email, self.age);
    }

    fn is_adult(&self) -> bool {
        self.age >= 18
    }

    fn full_name(&self) -> String {
        format!(\"{}({} 세)\", self.name, self.age)
    }

    fn get_summary(&self) -> String {
        format!(\"사용자 {}는 {} ({}세)입니다\", self.id, self.name, self.age)
    }
}

fn immutable_methods() {
    println!(\"\\n[예제 2] &self 메서드: 데이터 조회\");
    println!(\"═════════════════════════════════════════\");

    let user = User::new(1001, \"Alice\".to_string(), \"alice@example.com\".to_string(), 28);

    // &self 메서드 호출
    user.display_info();
    println!(\"성인?: {}\", user.is_adult());
    println!(\"성명: {}\", user.full_name());
    println!(\"요약: {}\", user.get_summary());

    // 모든 &self 메서드 호출 후 user 재사용 가능
    println!(\"이름 재사용: {}\", user.name);
}

// ============================================================================
// [예제 3] &mut self 메서드: 데이터 수정 (Mutable Methods)
// ============================================================================
struct BankAccount {
    owner: String,
    balance: f64,
}

impl BankAccount {
    // 생성자
    fn new(owner: String, initial_balance: f64) -> BankAccount {
        BankAccount { owner, balance: initial_balance }
    }

    // &self 메서드: 조회
    fn get_balance(&self) -> f64 {
        self.balance
    }

    fn get_owner(&self) -> &str {
        &self.owner
    }

    // &mut self 메서드: 수정
    fn deposit(&mut self, amount: f64) {
        self.balance += amount;
        println!(\"{:.2}원 입금됨. 현재 잔액: {:.2}원\", amount, self.balance);
    }

    fn withdraw(&mut self, amount: f64) -> bool {
        if amount <= self.balance {
            self.balance -= amount;
            println!(\"{:.2}원 출금됨. 현재 잔액: {:.2}원\", amount, self.balance);
            true
        } else {
            println!(\"잔액 부족! (보유: {:.2}원, 요청: {:.2}원)\", self.balance, amount);
            false
        }
    }

    fn transfer(&mut self, amount: f64, target: &mut BankAccount) -> bool {
        if self.withdraw(amount) {
            target.balance += amount;
            println!(\"{}에게 {:.2}원 이체됨\", target.owner, amount);
            true
        } else {
            false
        }
    }
}

fn mutable_methods() {
    println!(\"\\n[예제 3] &mut self 메서드: 데이터 수정\");
    println!(\"═════════════════════════════════════════\");

    let mut alice = BankAccount::new(\"Alice\".to_string(), 10000.0);
    let mut bob = BankAccount::new(\"Bob\".to_string(), 5000.0);

    println!(\"\\n[초기 상태]\");
    println!(\"Alice 잔액: {:.2}원\", alice.get_balance());
    println!(\"Bob 잔액: {:.2}원\", bob.get_balance());

    println!(\"\\n[거래]\");
    alice.deposit(5000.0);
    alice.withdraw(3000.0);
    alice.transfer(4000.0, &mut bob);

    println!(\"\\n[최종 상태]\");
    println!(\"Alice 잔액: {:.2}원\", alice.get_balance());
    println!(\"Bob 잔액: {:.2}원\", bob.get_balance());
}

// ============================================================================
// [예제 4] self 메서드: 소유권 전달 (Consuming Methods)
// ============================================================================
struct Box {
    items: Vec<String>,
}

impl Box {
    // 생성자
    fn new() -> Box {
        Box { items: Vec::new() }
    }

    // &self: 내용물 확인
    fn list_items(&self) {
        if self.items.is_empty() {
            println!(\"상자가 비어있습니다\");
        } else {
            println!(\"상자 안에: {:?}\", self.items);
        }
    }

    // self: 소유권을 받아서 소비함
    fn into_vec(self) -> Vec<String> {
        self.items  // self의 소유권이 소비됨
    }

    fn destroy(self) {
        println!(\"상자가 폐기됨. 내용물: {:?}\", self.items);
        // 이 함수를 나가면 self는 자동으로 해제됨
    }

    fn transfer_contents(self, mut target: Box) -> Box {
        let mut new_items = self.items;
        new_items.extend(target.items);
        Box { items: new_items }
    }
}

fn consuming_methods() {
    println!(\"\\n[예제 4] self 메서드: 소유권 전달\");
    println!(\"═════════════════════════════════════════\");

    let mut box1 = Box::new();
    box1.items.push(\"사과\".to_string());
    box1.items.push(\"오렌지\".to_string());
    box1.list_items();

    // into_vec: box1의 소유권 이전
    println!(\"\\nbox1을 벡터로 변환\");
    let items = box1.into_vec();
    println!(\"벡터 내용: {:?}\", items);
    // box1은 이제 사용 불가능

    // destroy 예제
    let box2 = Box::new();
    let mut inner = box2;
    inner.items.push(\"바나나\".to_string());
    println!(\"\\nbox2 폐기\");
    inner.destroy();
    // box2는 이제 사용 불가능

    // transfer_contents 예제
    let mut box3 = Box::new();
    box3.items.push(\"포도\".to_string());
    let mut box4 = Box::new();
    box4.items.push(\"딸기\".to_string());

    println!(\"\\nbox3과 box4 통합\");
    let box5 = box3.transfer_contents(box4);
    box5.list_items();
    // box3, box4는 이제 사용 불가능
}

