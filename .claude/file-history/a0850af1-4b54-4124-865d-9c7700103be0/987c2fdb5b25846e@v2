### 패턴 2: 로그인 상태 관리

```rust
#[derive(Debug)]
enum AuthState {
    LoggedOut,
    LoggedIn { user_id: u32, email: String },
    SessionExpired,
}

fn handle_auth_command(state: AuthState, cmd: &str) -> AuthState {
    match state {
        AuthState::LoggedOut => {
            if cmd == "LOGIN" {
                AuthState::LoggedIn {
                    user_id: 1,
                    email: "user@example.com".to_string(),
                }
            } else {
                AuthState::LoggedOut
            }
        }
        AuthState::LoggedIn { .. } => {
            if cmd == "LOGOUT" {
                AuthState::LoggedOut
            } else {
                state
            }
        }
        AuthState::SessionExpired => {
            if cmd == "LOGIN" {
                AuthState::LoggedIn {
                    user_id: 1,
                    email: "user@example.com".to_string(),
                }
            } else {
                AuthState::LoggedOut
            }
        }
    }
}
```

### 패턴 3: 주문 처리

```rust
#[derive(Debug)]
enum OrderState {
    Draft { items: Vec<String> },
    Confirmed { items: Vec<String>, total: f64 },
    Shipped { tracking: String },
    Delivered,
}

fn process_order(state: OrderState, action: &str) -> OrderState {
    match (state, action) {
        (OrderState::Draft { items }, "CONFIRM") => {
            OrderState::Confirmed {
                items: items.clone(),
                total: 999.99,
            }
        }
        (OrderState::Confirmed { .. }, "SHIP") => {
            OrderState::Shipped {
                tracking: "TRACK123".to_string(),
            }
        }
        (OrderState::Shipped { .. }, "DELIVER") => {
            OrderState::Delivered
        }
        (state, _) => state,  // 부적절한 액션은 무시
    }
}
```

