## 🎓 실전 설계: 신호등 상태 머신

```rust
#[derive(Debug)]
enum TrafficLight {
    Red,     // 정지
    Yellow,  // 주의
    Green,   // 진행
}

fn cycle(light: TrafficLight) -> TrafficLight {
    match light {
        TrafficLight::Red => TrafficLight::Green,
        TrafficLight::Green => TrafficLight::Yellow,
        TrafficLight::Yellow => TrafficLight::Red,
    }
}

// 사용
let mut light = TrafficLight::Red;
println!("{:?}", light);  // Red

light = cycle(light);
println!("{:?}", light);  // Green

light = cycle(light);
println!("{:?}", light);  // Yellow

light = cycle(light);
println!("{:?}", light);  // Red (다시 돌아옴)
```

