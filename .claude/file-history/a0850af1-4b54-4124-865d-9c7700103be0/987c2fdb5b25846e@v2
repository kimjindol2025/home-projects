## 5️⃣ 명령 처리 (Command Handling)

### 5.1 상태에 따른 명령 처리

```rust
#[derive(Debug)]
enum SystemState {
    Idle,
    Running(u32),
    Error(String),
}

fn handle_command(state: SystemState, cmd: &str) -> SystemState {
    match state {
        SystemState::Idle => {
            println!("대기 상태 처리");
            if cmd == "START" {
                SystemState::Running(0)
            } else {
                SystemState::Idle
            }
        }
        SystemState::Running(level) => {
            println!("가동 상태 처리");
            match cmd {
                "POWER_UP" => SystemState::Running(level + 10),
                "STOP" => SystemState::Idle,
                "ERROR" => SystemState::Error("과부하".to_string()),
                _ => SystemState::Running(level),
            }
        }
        SystemState::Error(ref msg) => {
            println!("에러 상태 처리: {}", msg);
            if cmd == "RECOVER" {
                SystemState::Idle
            } else {
                state
            }
        }
    }
}
```

### 5.2 부적절한 명령은 무시

```rust
// 에러 상태에서 START 명령이 들어오면?
// → 명령이 무시되고 상태 유지
// → 에러 상태에서만 유효한 RECOVER 명령 대기

current_state = handle_command(current_state, "START");
// 에러 상태면 START는 무시됨
```

