// =============================================================================
// 데이터 구조 정의
// =============================================================================

#[derive(Debug, Clone, Copy, PartialEq)]
enum Protocol {
    TCP,
    UDP,
    ICMP,
}

#[derive(Debug, Clone)]
struct Packet {
    id: u32,
    protocol: Protocol,
    payload: Option<String>,
    source_ip: (u8, u8, u8, u8),
    dest_ip: (u8, u8, u8, u8),
    port: u16,
}

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
enum ThreatLevel {
    Critical,
    High,
    Medium,
    Low,
}

#[derive(Debug, Clone)]
enum Message {
    Status(u32),
    Error(String),
    Alert(String),
}

#[derive(Debug, Clone)]
struct SecurityLog {
    timestamp: u64,
    level: ThreatLevel,
    message: String,
}

// =============================================================================
// Demo 1: 기본 패턴 매칭 - Enum 분해
// =============================================================================

fn demo_basic_pattern_matching() {
    println!("\n=== Demo 1: 기본 패턴 매칭 - Enum 분해 ===");

    let protocols = vec![Protocol::TCP, Protocol::UDP, Protocol::ICMP];

    for protocol in protocols {
        match protocol {
            Protocol::TCP => println!("  [TCP] 신뢰할 수 있는 연결 기반 프로토콜"),
            Protocol::UDP => println!("  [UDP] 빠르지만 신뢰성 없는 프로토콜"),
            Protocol::ICMP => println!("  [ICMP] 제어 메시지 프로토콜"),
        }
    }

    // 여러 경우 합치기 (또는 패턴)
    let protocol = Protocol::TCP;
    match protocol {
        Protocol::TCP | Protocol::UDP => {
            println!("  [INFO] 전송계층 프로토콜: {:?}", protocol);
        }
        _ => println!("  [INFO] 기타 프로토콜"),
    }
}

// =============================================================================
// Demo 2: Destructuring - 구조체 분해
// =============================================================================

fn demo_destructuring() {
    println!("\n=== Demo 2: Destructuring - 구조체 분해 ===");

    let packet = Packet {
        id: 1024,
        protocol: Protocol::TCP,
        payload: Some("MALWARE ATTACK".to_string()),
        source_ip: (192, 168, 1, 50),
        dest_ip: (10, 0, 0, 1),
        port: 443,
    };

    // [설계 핵심] 구조체 필드를 한 번에 분해
    let Packet {
        id,
        protocol,
        ref payload,
        source_ip: (src_a, src_b, src_c, src_d),
        ..
    } = packet;

    println!("  ID: {}", id);
    println!("  Protocol: {:?}", protocol);
    println!("  Payload: {:?}", payload);
    println!("  Source IP: {}.{}.{}.{}", src_a, src_b, src_c, src_d);

    // 부분 분해 (..) - packet의 참조로 두 번째 매칭
    if let Packet {
        source_ip: (192, 168, _, _),
        payload: Some(msg),
        ..
    } = &packet
    {
        println!("  [경고] 내부 네트워크에서 의심 메시지: {}", msg);
    }
}

// =============================================================================
// Demo 3: Match Guards - 조건절 붙이기
// =============================================================================

fn demo_match_guards() {
    println!("\n=== Demo 3: Match Guards - 조건절 붙이기 ===");

    let packets = vec![
        Packet {
            id: 1,
            protocol: Protocol::TCP,
            payload: Some("ATTACK".to_string()),
            source_ip: (192, 168, 1, 1),
            dest_ip: (10, 0, 0, 1),
            port: 80,
        },
        Packet {
            id: 2,
            protocol: Protocol::UDP,
            payload: None,
            source_ip: (8, 8, 8, 8),
            dest_ip: (10, 0, 0, 1),
            port: 53,
        },
        Packet {
            id: 3,
            protocol: Protocol::TCP,
            payload: Some("NORMAL DATA".to_string()),
            source_ip: (172, 16, 0, 1),
            dest_ip: (10, 0, 0, 1),
            port: 443,
        },
    ];

    for packet in packets {
        match packet {
            // [설계 핵심] 패턴 + 추가 조건 (guard)
            Packet {
                protocol: Protocol::TCP,
                source_ip: (192, 168, _, _),
                payload: Some(content),
                ..
            } if content.contains("ATTACK") => {
                println!(
                    "  [🚨 CRITICAL] 내부 네트워크 침입 시도 (ID: {})",
                    packet.id
                );
            }

            Packet {
                protocol: Protocol::UDP,
                payload: None,
                ..
            } => {
                println!("  [ℹ️ INFO] 빈 UDP 패킷 (ID: {})", packet.id);
            }

            Packet {
                protocol: Protocol::TCP,
                port: 443,
                ..
            } if packet.port == 443 => {
                println!("  [✓ OK] HTTPS 연결 (ID: {})", packet.id);
            }

            _ => println!("  [PASS] 일반 패킷 스캔 완료 (ID: {})", packet.id),
        }
    }
}

