#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_basic_pattern_matching() {
        let p = Protocol::TCP;
        match p {
            Protocol::TCP => assert!(true),
            _ => assert!(false),
        }
    }

    #[test]
    fn test_destructuring() {
        let packet = Packet {
            id: 100,
            protocol: Protocol::UDP,
            payload: Some("data".to_string()),
            source_ip: (192, 168, 1, 1),
            dest_ip: (10, 0, 0, 1),
            port: 53,
        };

        let Packet {
            id,
            source_ip: (a, b, _, _),
            ..
        } = packet;

        assert_eq!(id, 100);
        assert_eq!(a, 192);
        assert_eq!(b, 168);
    }

    #[test]
    fn test_match_guards() {
        let packet = Packet {
            id: 1,
            protocol: Protocol::TCP,
            payload: Some("ATTACK".to_string()),
            source_ip: (192, 168, 1, 1),
            dest_ip: (10, 0, 0, 1),
            port: 80,
        };

        let is_attack = match packet {
            Packet {
                protocol: Protocol::TCP,
                source_ip: (192, 168, _, _),
                payload: Some(content),
                ..
            } if content.contains("ATTACK") => true,
            _ => false,
        };

        assert!(is_attack);
    }

    #[test]
    fn test_if_let() {
        let msg = Message::Status(200);

        let result = if let Message::Status(code) = msg {
            code
        } else {
            0
        };

        assert_eq!(result, 200);
    }

    #[test]
    fn test_pattern_binding() {
        let age = 25;

        let category = match age {
            a @ 0..=18 => "Minor",
            a @ 19..=64 => "Adult",
            _ => "Senior",
        };

        assert_eq!(category, "Adult");
    }

    #[test]
    fn test_analyze_threat_critical() {
        let packet = Packet {
            id: 1,
            protocol: Protocol::TCP,
            payload: Some("MALWARE ATTACK".to_string()),
            source_ip: (192, 168, 1, 1),
            dest_ip: (10, 0, 0, 1),
            port: 80,
        };

        let threat = analyze_threat(&packet);
        assert_eq!(threat, ThreatLevel::Critical);
    }

    #[test]
    fn test_parse_threat_message() {
        let result = parse_threat_message("CRITICAL");
        assert!(result.is_ok());
        assert_eq!(result.unwrap(), ThreatLevel::Critical);

        let error = parse_threat_message("INVALID");
        assert!(error.is_err());
    }
}
