fn demo_if_let_while_let() {
    println!("\n=== Demo 4: if let과 while let - 관용적 표현 ===");

    let packet = Packet {
        id: 2048,
        protocol: Protocol::TCP,
        payload: Some("IMPORTANT DATA".to_string()),
        source_ip: (192, 168, 1, 100),
        dest_ip: (10, 0, 0, 1),
        port: 8080,
    };

    // [관용구 1] if let: 특정 조건만 처리
    if let Some(payload) = &packet.payload {
        println!("  [페이로드] {}바이트 추출 성공", payload.len());
        println!("  [내용] {}", payload);
    }

    // [관용구 2] if let으로 구조체 분해
    if let Packet {
        protocol: Protocol::TCP,
        port: 8080,
        source_ip: (192, 168, _, _),
        ..
    } = packet
    {
        println!("  [패턴] 내부 TCP 8080 포트 접속 감지");
    }

    // [관용구 3] while let: 반복 처리
    let messages = vec![
        Message::Status(200),
        Message::Status(404),
        Message::Error("Connection timeout".to_string()),
        Message::Alert("System overload".to_string()),
    ];

    let mut iter = messages.into_iter();
    println!("  [메시지 처리 루프]");
    while let Some(msg) = iter.next() {
        match msg {
            Message::Status(code) => println!("    Status: {}", code),
            Message::Error(e) => println!("    Error: {}", e),
            Message::Alert(a) => println!("    Alert: {}", a),
        }
    }
}

// =============================================================================
// Demo 5: Pattern Binding (@) - 범위 + 값 추출
// =============================================================================

fn demo_pattern_binding() {
    println!("\n=== Demo 5: Pattern Binding (@) - 범위 + 값 추출 ===");

    let ages = vec![5, 15, 25, 50, 75];

    for age in ages {
        match age {
            // [설계 핵심] 범위 패턴 + 값 바인딩
            a @ 0..=12 => println!("  어린이 ({}살): 콘텐츠 필터 적용", a),
            a @ 13..=19 => println!("  청소년 ({}살): 중간 수준 필터 적용", a),
            a @ 20..=64 => println!("  성인 ({}살): 제한 없음", a),
            a @ 65.. => println!("  노인 ({}살): 건강 관련 팝업", a),
            _ => println!("  유효하지 않은 나이: {}", age),
        }
    }

    // 메시지 분석
    let messages = vec![
        Message::Status(200),
        Message::Status(404),
        Message::Status(500),
        Message::Status(100),
    ];

    println!("  [메시지 상태 코드 분류]");
    for msg in messages {
        match msg {
            Message::Status(code @ 200..=299) => {
                println!("    ✓ 성공 응답: {}", code);
            }
            Message::Status(code @ 300..=399) => {
                println!("    → 리다이렉션: {}", code);
            }
            Message::Status(code @ 400..=499) => {
                println!("    ✗ 클라이언트 에러: {}", code);
            }
            Message::Status(code @ 500..=599) => {
                println!("    ✗✗ 서버 에러: {}", code);
            }
            Message::Status(code) => println!("    ? 미분류: {}", code),
            _ => {}
        }
    }
}

// =============================================================================
// Demo 6: 보안 패킷 분석기 - 실무 통합
// =============================================================================

fn analyze_threat(packet: &Packet) -> ThreatLevel {
    match packet {
        // [설계 핵심] 중첩된 구조를 한 번에 분해하고 조건을 검사함
        Packet {
            protocol: Protocol::TCP,
            source_ip: (192, 168, _, _),
            payload: Some(content),
            ..
        } if content.contains("ATTACK") || content.contains("MALWARE") => {
            println!(
                "  🚨 [CRITICAL] 내부 네트워크 침입 시도 감지: ID {}",
                packet.id
            );
            ThreatLevel::Critical
        }

        Packet {
            protocol: Protocol::TCP,
            payload: Some(content),
            ..
        } if content.contains("EXPLOIT") => {
            println!("  ⚠️ [HIGH] Exploit 패턴 감지: ID {}", packet.id);
            ThreatLevel::High
        }

        Packet {
            protocol: Protocol::UDP,
            payload: None,
            port: p @ 53,
            ..
        } => {
            println!(
                "  ℹ️ [MEDIUM] DNS 요청 (포트: {}): ID {}",
                p, packet.id
            );
            ThreatLevel::Medium
        }

        Packet {
            protocol: Protocol::ICMP,
            ..
        } => {
            println!("  ℹ️ [LOW] ICMP 메시지: ID {}", packet.id);
            ThreatLevel::Low
        }

        Packet {
            protocol: Protocol::TCP,
            payload: Some(_),
            port: 443,
            ..
        } => {
            println!("  ✓ [LOW] 정상 HTTPS 통신: ID {}", packet.id);
            ThreatLevel::Low
        }

        Packet {
            payload: None, ..
        } => {
            println!("  ✓ [LOW] 페이로드 없는 패킷: ID {}", packet.id);
            ThreatLevel::Low
        }

        _ => {
            println!("  ? [UNKNOWN] 분류되지 않은 패킷: ID {}", packet.id);
            ThreatLevel::Medium
        }
    }
}

fn demo_security_packet_analyzer() {
    println!("\n=== Demo 6: 보안 패킷 분석기 - 실무 통합 ===");
    println!("  [다층 보안 패킷 분석 시스템]");

    let test_packets = vec![
        Packet {
            id: 1024,
            protocol: Protocol::TCP,
            payload: Some("MALWARE ATTACK PAYLOAD".to_string()),
            source_ip: (192, 168, 1, 50),
            dest_ip: (10, 0, 0, 1),
            port: 80,
        },
        Packet {
            id: 1025,
            protocol: Protocol::UDP,
            payload: None,
            source_ip: (8, 8, 8, 8),
            dest_ip: (192, 168, 1, 1),
            port: 53,
        },
        Packet {
            id: 1026,
            protocol: Protocol::TCP,
            payload: Some("HTTPS encrypted data".to_string()),
            source_ip: (192, 168, 1, 100),
            dest_ip: (93, 184, 216, 34),
            port: 443,
        },
        Packet {
            id: 1027,
            protocol: Protocol::ICMP,
            payload: None,
            source_ip: (8, 8, 8, 8),
            dest_ip: (192, 168, 1, 1),
            port: 0,
        },
        Packet {
            id: 1028,
            protocol: Protocol::TCP,
            payload: Some("EXPLOIT CVE-2024-1234".to_string()),
            source_ip: (10, 0, 0, 50),
            dest_ip: (192, 168, 1, 1),
            port: 22,
        },
    ];

    let mut threat_counts = [0; 4]; // Critical, High, Medium, Low

    for packet in &test_packets {
        let threat = analyze_threat(packet);
        match threat {
            ThreatLevel::Critical => threat_counts[0] += 1,
            ThreatLevel::High => threat_counts[1] += 1,
            ThreatLevel::Medium => threat_counts[2] += 1,
            ThreatLevel::Low => threat_counts[3] += 1,
        }
    }

    println!("\n  [분석 결과 요약]");
    println!("    Critical: {} 건", threat_counts[0]);
    println!("    High:     {} 건", threat_counts[1]);
    println!("    Medium:   {} 건", threat_counts[2]);
    println!("    Low:      {} 건", threat_counts[3]);

    // 위협 수준별로 특별한 처리
    if threat_counts[0] > 0 {
        println!("\n  [🚨 ALERT] Critical 위협 {} 건 감지! 즉시 조치 필요", threat_counts[0]);
    }

    if threat_counts[1] > 0 {
        println!("  [⚠️ WARNING] High 위협 {} 건 감지! 모니터링 강화", threat_counts[1]);
    }

    // [관용구] matches! 매크로 사용
    let has_malware = test_packets.iter().any(|p| {
        matches!(
            p,
            Packet {
                payload: Some(content),
                ..
            } if content.contains("MALWARE")
        )
    });

    if has_malware {
        println!("  [🛡️ ACTION] 말웨어 탐지됨 - 격리 모드 활성화");
    }
}

// =============================================================================
// 추가: 함수형 에러 처리 (? 연산자, and_then)
// =============================================================================

fn parse_threat_message(msg: &str) -> Result<ThreatLevel, String> {
    match msg {
        "CRITICAL" => Ok(ThreatLevel::Critical),
        "HIGH" => Ok(ThreatLevel::High),
        "MEDIUM" => Ok(ThreatLevel::Medium),
        "LOW" => Ok(ThreatLevel::Low),
        _ => Err("Unknown threat level".to_string()),
    }
}

fn validate_threat(level: ThreatLevel) -> Result<(), String> {
    if matches!(level, ThreatLevel::Critical) {
        Err("Critical threat detected!".to_string())
    } else {
        Ok(())
    }
}

fn process_threat_report(report: &str) -> Result<String, String> {
    let level = parse_threat_message(report)?; // ? 연산자로 에러 즉시 반환
    validate_threat(level)?; // 검증 (에러 시 반환)
    Ok(format!("Threat level: {:?}", level))
}

fn demo_functional_error_handling() {
    println!("\n=== Extra: 함수형 에러 처리 ===");

    let results = vec!["CRITICAL", "HIGH", "MEDIUM", "INVALID"];

    for report in results {
        match process_threat_report(report) {
            Ok(msg) => println!("  ✓ {}", msg),
            Err(e) => println!("  ✗ Error: {}", e),
        }
    }

    // and_then 사용 (체이닝)
    let result: Result<(), String> = parse_threat_message("HIGH")
        .and_then(|level| {
            println!("  [Step 1] Parsed: {:?}", level);
            Ok(level)
        })
        .and_then(|level| {
            if matches!(level, ThreatLevel::Low) {
                Ok(())
            } else {
                Err("Elevated threat".to_string())
            }
        })
        .or_else(|_| {
            println!("  [Fallback] Treated as elevated threat");
            Ok(())
        });

    match result {
        Ok(_) => println!("  [Result] Process completed"),
        Err(e) => println!("  [Result] Failed: {}", e),
    }
}

