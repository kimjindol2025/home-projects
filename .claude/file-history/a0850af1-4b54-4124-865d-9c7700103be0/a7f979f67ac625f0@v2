        }
    }

    #[test]
    fn test_multiple_optimization_passes() {
        let mut ir = IntermediateRepresentation::new();

        // 상수 연산 + 죽은 코드
        ir.instructions.push(IRInstruction::BinOp {
            op: BinaryOp::Add,
            left: Box::new(IRInstruction::Const(Value::Integer(5))),
            right: Box::new(IRInstruction::Const(Value::Integer(5))),
        });
        ir.instructions.push(IRInstruction::If {
            cond: Box::new(IRInstruction::Const(Value::Boolean(false))),
            then_branch: vec![],
            else_branch: None,
        });

        let engine = OptimizationEngine::new();
        let stats = engine.run(&mut ir);

        let total_folded: usize = stats.iter().map(|s| s.constants_folded).sum();
        let total_eliminated: usize = stats.iter().map(|s| s.dead_code_eliminated).sum();

        assert!(total_folded > 0);
        assert!(total_eliminated > 0);
    }
