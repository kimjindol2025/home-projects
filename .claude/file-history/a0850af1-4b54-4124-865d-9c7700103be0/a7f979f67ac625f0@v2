// ============================================================================
// 프로파일러
// ============================================================================

pub struct Profiler {
    pub samples: Vec<(String, std::time::Duration)>,
}

impl Profiler {
    pub fn new() -> Self {
        Self {
            samples: Vec::new(),
        }
    }

    pub fn profile<F>(&mut self, name: &str, f: F)
    where
        F: Fn(),
    {
        let start = Instant::now();
        f();
        let duration = start.elapsed();
        self.samples.push((name.to_string(), duration));
    }

    pub fn report(&self) {
        let mut sorted = self.samples.clone();
        sorted.sort_by(|a, b| b.1.cmp(&a.1));

        println!("\n  [PROFILING REPORT]");
        for (name, duration) in sorted.iter().take(10) {
            println!("    {}: {:.3}ms", name, duration.as_secs_f64() * 1000.0);
        }
    }
}

