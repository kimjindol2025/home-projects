## Phase 3: 타입 체커(Type Checker) — 의미론 분석

### 3.1 목표

```
입력: 타입 주석 없는 AST
  BinaryOp {
    op: Add,
    left: Literal(10),
    right: Literal(5)
  }

출력: 타입 주석 추가된 AST
  BinaryOp {
    op: Add,
    left: Literal(10): Integer,
    right: Literal(5): Integer,
    result_type: Integer
  }
```

### 3.2 타입 체커 구현

```rust
pub struct TypeChecker {
    scopes: Vec<HashMap<String, Type>>,
    errors: Vec<String>,
}

impl TypeChecker {
    pub fn new() -> Self {
        TypeChecker {
            scopes: vec![HashMap::new()],
            errors: Vec::new(),
        }
    }

    pub fn check(&mut self, statements: &[Statement]) -> Result<(), Vec<String>> {
        for stmt in statements {
            self.check_statement(stmt);
        }

        if self.errors.is_empty() {
            Ok(())
        } else {
            Err(self.errors.clone())
        }
    }

    fn check_statement(&mut self, stmt: &Statement) {
        match stmt {
            Statement::VariableDeclaration {
                name,
                type_annotation,
                initializer,
            } => {
                let init_type = initializer
                    .as_ref()
                    .map(|e| self.check_expression(e));

                let var_type = if let Some(annotation) = type_annotation {
                    annotation.clone()
                } else if let Some(init_type) = &init_type {
                    init_type.clone()
                } else {
                    self.errors.push("Variable must have type annotation or initializer".to_string());
                    Type::Unknown
                };

                // 타입 호환성 검사
                if let Some(init_type) = &init_type {
                    if !self.is_compatible(&var_type, init_type) {
                        self.errors.push(format!(
                            "Type mismatch: expected {:?}, found {:?}",
                            var_type, init_type
                        ));
                    }
                }

                self.define(name.clone(), var_type);
            }

            Statement::ExpressionStatement(expr) => {
                self.check_expression(expr);
            }

            Statement::If {
                condition,
                then_branch,
                else_branch,
            } => {
                let cond_type = self.check_expression(condition);
                if !self.is_compatible(&Type::Boolean, &cond_type) {
                    self.errors.push(format!(
                        "If condition must be boolean, found {:?}",
                        cond_type
                    ));
                }

                self.push_scope();
                for stmt in then_branch {
                    self.check_statement(stmt);
                }
                self.pop_scope();

                if let Some(else_stmts) = else_branch {
                    self.push_scope();
                    for stmt in else_stmts {
                        self.check_statement(stmt);
                    }
                    self.pop_scope();
                }
            }

            Statement::Loop { body } => {
                self.push_scope();
                for stmt in body {
                    self.check_statement(stmt);
                }
                self.pop_scope();
            }

            _ => {}
        }
    }

    fn check_expression(&mut self, expr: &Expression) -> Type {
        match expr {
            Expression::Literal(value) => {
                match value {
                    Value::Integer(_) => Type::Integer,
                    Value::Float(_) => Type::Float,
                    Value::String(_) => Type::String,
                    Value::Boolean(_) => Type::Boolean,
                    Value::Null => Type::Unknown,
                    _ => Type::Unknown,
                }
            }

            Expression::Variable(name) => {
                self.lookup(name).unwrap_or_else(|| {
                    self.errors.push(format!("Undefined variable: {}", name));
                    Type::Unknown
                })
            }

            Expression::Binary { op, left, right } => {
                let left_type = self.check_expression(left);
                let right_type = self.check_expression(right);

                match op {
                    BinaryOp::Add | BinaryOp::Sub | BinaryOp::Mul | BinaryOp::Div => {
                        if self.is_numeric(&left_type) && self.is_numeric(&right_type) {
                            if self.is_compatible(&left_type, &right_type) {
                                left_type
                            } else {
                                Type::Unknown
                            }
                        } else {
                            self.errors.push(format!(
                                "Operator {:?} requires numeric types",
                                op
                            ));
                            Type::Unknown
                        }
                    }

                    BinaryOp::Eq | BinaryOp::Ne | BinaryOp::Lt | BinaryOp::Gt
                    | BinaryOp::Le | BinaryOp::Ge => Type::Boolean,

                    BinaryOp::And | BinaryOp::Or => {
                        if !self.is_compatible(&Type::Boolean, &left_type) {
                            self.errors.push("Operand must be boolean".to_string());
                        }
                        if !self.is_compatible(&Type::Boolean, &right_type) {
                            self.errors.push("Operand must be boolean".to_string());
                        }
                        Type::Boolean
                    }
                }
            }

            Expression::Call { function, args } => {
                let func_type = self.check_expression(function);
                // 함수 타입 검증
                Type::Unknown // 또는 실제 반환 타입
            }

            Expression::Array(elements) => {
                if elements.is_empty() {
                    Type::Array(Box::new(Type::Unknown))
                } else {
                    let elem_type = self.check_expression(&elements[0]);
                    for elem in &elements[1..] {
                        let t = self.check_expression(elem);
                        if !self.is_compatible(&elem_type, &t) {
                            self.errors.push(
                                "Array elements must have same type".to_string()
                            );
                        }
                    }
                    Type::Array(Box::new(elem_type))
                }
            }

            _ => Type::Unknown,
        }
    }

    fn is_numeric(&self, t: &Type) -> bool {
        matches!(t, Type::Integer | Type::Float)
    }

    fn is_compatible(&self, t1: &Type, t2: &Type) -> bool {
        match (t1, t2) {
            (Type::Unknown, _) | (_, Type::Unknown) => true,
            (Type::Integer, Type::Integer) => true,
            (Type::Float, Type::Float) => true,
            (Type::String, Type::String) => true,
            (Type::Boolean, Type::Boolean) => true,
            // 숫자 호환성
            (Type::Integer, Type::Float) | (Type::Float, Type::Integer) => true,
            _ => false,
        }
    }

    fn define(&mut self, name: String, t: Type) {
        if let Some(scope) = self.scopes.last_mut() {
            scope.insert(name, t);
        }
    }

    fn lookup(&self, name: &str) -> Option<Type> {
        for scope in self.scopes.iter().rev() {
            if let Some(t) = scope.get(name) {
                return Some(t.clone());
            }
        }
        None
    }

    fn push_scope(&mut self) {
        self.scopes.push(HashMap::new());
    }

    fn pop_scope(&mut self) {
        self.scopes.pop();
    }
}
```

