### 2.3 파서 구현 (Recursive Descent)

```rust
pub struct Parser {
    tokens: Vec<Token>,
    current: usize,
}

impl Parser {
    pub fn new(tokens: Vec<Token>) -> Self {
        Parser { tokens, current: 0 }
    }

    pub fn parse(&mut self) -> Vec<Statement> {
        let mut statements = Vec::new();

        while !self.is_at_end() {
            if let Some(stmt) = self.parse_statement() {
                statements.push(stmt);
            }
        }

        statements
    }

    // 문장 파싱
    fn parse_statement(&mut self) -> Option<Statement> {
        match &self.peek().token_type {
            TokenType::Keyword(kw) => match kw.as_str() {
                "let" => Some(self.parse_variable_declaration()),
                "fn" => Some(self.parse_function_declaration()),
                "if" => Some(self.parse_if_statement()),
                "loop" => Some(self.parse_loop_statement()),
                "break" => {
                    self.advance();
                    Some(Statement::Break)
                }
                "return" => Some(self.parse_return_statement()),
                "{" => Some(self.parse_block_statement()),
                _ => Some(Statement::ExpressionStatement(self.parse_expression()?)),
            },
            _ => Some(Statement::ExpressionStatement(self.parse_expression()?)),
        }
    }

    fn parse_variable_declaration(&mut self) -> Statement {
        self.consume_keyword("let");

        let name = self.parse_identifier();

        let type_annotation = if self.check(&TokenType::Colon) {
            self.advance();
            Some(self.parse_type())
        } else {
            None
        };

        let initializer = if self.check(&TokenType::Equal) {
            self.advance();
            Some(self.parse_expression().unwrap())
        } else {
            None
        };

        self.consume_token(&TokenType::Semicolon);

        Statement::VariableDeclaration {
            name,
            type_annotation,
            initializer,
        }
    }

    fn parse_function_declaration(&mut self) -> Statement {
        self.consume_keyword("fn");

        let name = self.parse_identifier();

        self.consume_token(&TokenType::LeftParen);
        let mut params = Vec::new();
        while !self.check(&TokenType::RightParen) {
            let param_name = self.parse_identifier();
            self.consume_token(&TokenType::Colon);
            let param_type = self.parse_type();
            params.push((param_name, param_type));

            if !self.check(&TokenType::RightParen) {
                self.consume_token(&TokenType::Comma);
            }
        }
        self.consume_token(&TokenType::RightParen);

        let return_type = if self.check(&TokenType::Arrow) {
            self.advance();
            Some(self.parse_type())
        } else {
            None
        };

        self.consume_token(&TokenType::LeftBrace);
        let body = self.parse_block_contents();
        self.consume_token(&TokenType::RightBrace);

        Statement::FunctionDeclaration {
            name,
            params,
            return_type,
            body,
        }
    }

    // 식 파싱 (연산자 우선순위)
    fn parse_expression(&mut self) -> Option<Expression> {
        self.parse_or()
    }

    fn parse_or(&mut self) -> Option<Expression> {
        let mut left = self.parse_and()?;

        while self.check_op("||") {
            self.advance();
            let right = self.parse_and()?;
            left = Expression::Binary {
                op: BinaryOp::Or,
                left: Box::new(left),
                right: Box::new(right),
            };
        }

        Some(left)
    }

    fn parse_and(&mut self) -> Option<Expression> {
        let mut left = self.parse_equality()?;

        while self.check_op("&&") {
            self.advance();
            let right = self.parse_equality()?;
            left = Expression::Binary {
                op: BinaryOp::And,
                left: Box::new(left),
                right: Box::new(right),
            };
        }

        Some(left)
    }

    fn parse_equality(&mut self) -> Option<Expression> {
        let mut left = self.parse_relational()?;

        while let Some(op) = self.match_ops(&["==", "!="]) {
            let right = self.parse_relational()?;
            left = Expression::Binary {
                op: match op.as_str() {
                    "==" => BinaryOp::Eq,
                    "!=" => BinaryOp::Ne,
                    _ => unreachable!(),
                },
                left: Box::new(left),
                right: Box::new(right),
            };
        }

        Some(left)
    }

    fn parse_relational(&mut self) -> Option<Expression> {
        let mut left = self.parse_additive()?;

        while let Some(op) = self.match_ops(&["<", ">", "<=", ">="]) {
            let right = self.parse_additive()?;
            left = Expression::Binary {
                op: match op.as_str() {
                    "<" => BinaryOp::Lt,
                    ">" => BinaryOp::Gt,
                    "<=" => BinaryOp::Le,
                    ">=" => BinaryOp::Ge,
                    _ => unreachable!(),
                },
                left: Box::new(left),
                right: Box::new(right),
            };
        }

        Some(left)
    }

    fn parse_additive(&mut self) -> Option<Expression> {
        let mut left = self.parse_multiplicative()?;

        while let Some(op) = self.match_ops(&["+", "-"]) {
            let right = self.parse_multiplicative()?;
            left = Expression::Binary {
                op: match op.as_str() {
                    "+" => BinaryOp::Add,
                    "-" => BinaryOp::Sub,
                    _ => unreachable!(),
                },
                left: Box::new(left),
                right: Box::new(right),
            };
        }

        Some(left)
    }

    fn parse_multiplicative(&mut self) -> Option<Expression> {
        let mut left = self.parse_unary()?;

        while let Some(op) = self.match_ops(&["*", "/", "%"]) {
            let right = self.parse_unary()?;
            left = Expression::Binary {
                op: match op.as_str() {
                    "*" => BinaryOp::Mul,
                    "/" => BinaryOp::Div,
                    "%" => BinaryOp::Mod,
                    _ => unreachable!(),
                },
                left: Box::new(left),
                right: Box::new(right),
            };
        }

        Some(left)
    }

    fn parse_unary(&mut self) -> Option<Expression> {
        if let Some(op) = self.match_ops(&["!", "-"]) {
            let operand = self.parse_unary()?;
            return Some(Expression::Unary {
                op: match op.as_str() {
                    "!" => UnaryOp::Not,
                    "-" => UnaryOp::Neg,
                    _ => unreachable!(),
                },
                operand: Box::new(operand),
            });
        }

        self.parse_postfix()
    }

    fn parse_postfix(&mut self) -> Option<Expression> {
        let mut expr = self.parse_primary()?;

        loop {
            match &self.peek().token_type {
                TokenType::LeftParen => {
                    self.advance();
                    let mut args = Vec::new();
                    while !self.check(&TokenType::RightParen) {
                        args.push(self.parse_expression()?);
                        if !self.check(&TokenType::RightParen) {
                            self.consume_token(&TokenType::Comma);
                        }
                    }
                    self.consume_token(&TokenType::RightParen);
                    expr = Expression::Call {
                        function: Box::new(expr),
                        args,
                    };
                }
                TokenType::LeftBracket => {
                    self.advance();
                    let index = self.parse_expression()?;
                    self.consume_token(&TokenType::RightBracket);
                    expr = Expression::Index {
                        object: Box::new(expr),
                        index: Box::new(index),
                    };
                }
                TokenType::Dot => {
                    self.advance();
                    let field = self.parse_identifier();
                    expr = Expression::Field {
                        object: Box::new(expr),
                        field,
                    };
                }
                _ => break,
            }
        }

        Some(expr)
    }

    fn parse_primary(&mut self) -> Option<Expression> {
        match &self.peek().token_type {
            TokenType::Number(n) => {
                let value = *n;
                self.advance();
                Some(Expression::Literal(Value::Float(value)))
            }
            TokenType::String(s) => {
                let value = s.clone();
                self.advance();
                Some(Expression::Literal(Value::String(value)))
            }
            TokenType::Boolean(b) => {
                let value = *b;
                self.advance();
                Some(Expression::Literal(Value::Boolean(value)))
            }
            TokenType::Identifier(name) => {
                let name = name.clone();
                self.advance();
                Some(Expression::Variable(name))
            }
            TokenType::LeftParen => {
                self.advance();
                let expr = self.parse_expression()?;
                self.consume_token(&TokenType::RightParen);
                Some(expr)
            }
            TokenType::LeftBracket => {
                self.advance();
                let mut elements = Vec::new();
                while !self.check(&TokenType::RightBracket) {
                    elements.push(self.parse_expression()?);
                    if !self.check(&TokenType::RightBracket) {
                        self.consume_token(&TokenType::Comma);
                    }
                }
                self.consume_token(&TokenType::RightBracket);
                Some(Expression::Array(elements))
            }
            _ => {
                self.error(&format!("Unexpected token: {:?}", self.peek()));
                None
            }
        }
    }

    // 헬퍼 메서드
    fn parse_identifier(&mut self) -> String {
        if let TokenType::Identifier(name) = &self.peek().token_type {
            let name = name.clone();
            self.advance();
            name
        } else {
            self.error("Expected identifier");
            String::new()
        }
    }

    fn peek(&self) -> &Token {
        &self.tokens[self.current]
    }

    fn advance(&mut self) {
        if !self.is_at_end() {
            self.current += 1;
        }
    }

    fn check(&self, token_type: &TokenType) -> bool {
        std::mem::discriminant(&self.peek().token_type)
            == std::mem::discriminant(token_type)
    }

    fn is_at_end(&self) -> bool {
        matches!(self.peek().token_type, TokenType::EOF)
    }

    fn error(&self, msg: &str) {
        eprintln!("Parse error: {}", msg);
    }
}
