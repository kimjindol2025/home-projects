## Phase 1: 렉서(Lexer) — 텍스트를 토큰으로

### 1.1 목표

```
입력:  "let x = 10 + 5;"
출력:  [
         Token { type: KEYWORD("let"), ... },
         Token { type: IDENTIFIER("x"), ... },
         Token { type: OPERATOR("="), ... },
         Token { type: NUMBER(10), ... },
         Token { type: OPERATOR("+"), ... },
         Token { type: NUMBER(5), ... },
         Token { type: SEMICOLON, ... },
       ]
```

### 1.2 구현 단계

#### Step 1: 토큰 정의

```rust
#[derive(Debug, Clone, PartialEq)]
pub enum TokenType {
    // 키워드
    Keyword(String),  // "let", "fn", "if", etc.

    // 식별자
    Identifier(String),

    // 리터럴
    Number(f64),
    String(String),
    Boolean(bool),

    // 연산자
    Plus,
    Minus,
    Star,
    Slash,
    Percent,
    Equal,
    EqualEqual,
    NotEqual,
    Less,
    Greater,
    // ... 등

    // 구분자
    LeftParen,
    RightParen,
    LeftBrace,
    RightBrace,
    LeftBracket,
    RightBracket,
    Semicolon,
    Comma,
    Dot,
    Colon,

    // 특수
    EOF,
}

pub struct Token {
    pub token_type: TokenType,
    pub lexeme: String,
    pub line: usize,
    pub column: usize,
}
```

#### Step 2: 렉서 구조

```rust
pub struct Lexer {
    input: Vec<char>,
    current: usize,
    line: usize,
    column: usize,
}

impl Lexer {
    pub fn new(input: &str) -> Self {
        Lexer {
            input: input.chars().collect(),
            current: 0,
            line: 1,
            column: 1,
        }
    }

    pub fn tokenize(&mut self) -> Vec<Token> {
        let mut tokens = Vec::new();

        while !self.is_at_end() {
            self.skip_whitespace();

            if self.is_at_end() { break; }

            if let Some(token) = self.next_token() {
                tokens.push(token);
            }
        }

        tokens.push(Token {
            token_type: TokenType::EOF,
            lexeme: String::new(),
            line: self.line,
            column: self.column,
        });

        tokens
    }

    fn next_token(&mut self) -> Option<Token> {
        let ch = self.current_char();

        match ch {
            // 숫자
            '0'..='9' => Some(self.read_number()),

            // 식별자/키워드
            'a'..='z' | 'A'..='Z' | '_' => Some(self.read_identifier()),

            // 문자열
            '"' => Some(self.read_string()),

            // 연산자/구분자
            '+' => Some(self.make_token(TokenType::Plus)),
            '-' => Some(self.make_token(TokenType::Minus)),
            '*' => Some(self.make_token(TokenType::Star)),
            '/' => Some(self.make_token(TokenType::Slash)),
            '=' => {
                if self.peek() == Some('=') {
                    self.advance();
                    Some(self.make_token(TokenType::EqualEqual))
                } else {
                    Some(self.make_token(TokenType::Equal))
                }
            }
            '(' => Some(self.make_token(TokenType::LeftParen)),
            ')' => Some(self.make_token(TokenType::RightParen)),
            '{' => Some(self.make_token(TokenType::LeftBrace)),
            '}' => Some(self.make_token(TokenType::RightBrace)),
            '[' => Some(self.make_token(TokenType::LeftBracket)),
            ']' => Some(self.make_token(TokenType::RightBracket)),
            ';' => Some(self.make_token(TokenType::Semicolon)),
            ',' => Some(self.make_token(TokenType::Comma)),
            '.' => Some(self.make_token(TokenType::Dot)),
            ':' => Some(self.make_token(TokenType::Colon)),

            _ => {
                self.error(&format!("Unknown character: {}", ch));
                None
            }
        }
    }

    fn read_number(&mut self) -> Token {
        let start = self.current;
        let start_line = self.line;
        let start_col = self.column;

        while self.current_char().is_ascii_digit() {
            self.advance();
        }

        if self.peek() == Some('.') && self.peek_next().map_or(false, |c| c.is_ascii_digit()) {
            self.advance(); // consume '.'
            while self.current_char().is_ascii_digit() {
                self.advance();
            }
        }

        let lexeme: String = self.input[start..self.current].iter().collect();
        let value = lexeme.parse::<f64>().unwrap();

        Token {
            token_type: TokenType::Number(value),
            lexeme,
            line: start_line,
            column: start_col,
        }
    }

    fn read_identifier(&mut self) -> Token {
        let start = self.current;
        let start_line = self.line;
        let start_col = self.column;

        while matches!(self.current_char(), 'a'..='z' | 'A'..='Z' | '0'..='9' | '_') {
            self.advance();
        }

        let lexeme: String = self.input[start..self.current].iter().collect();

        let token_type = match lexeme.as_str() {
            "let" | "fn" | "if" | "else" | "loop" | "break" | "return"
            | "true" | "false" | "null" | "use" | "impl" | "for" | "while" => {
                TokenType::Keyword(lexeme.clone())
            }
            _ => TokenType::Identifier(lexeme.clone()),
        };

        Token {
            token_type,
            lexeme,
            line: start_line,
            column: start_col,
        }
    }

    fn read_string(&mut self) -> Token {
        let start_line = self.line;
        let start_col = self.column;
        self.advance(); // consume opening "

        let mut value = String::new();
        while self.current_char() != '"' && !self.is_at_end() {
            if self.current_char() == '\\' {
                self.advance();
                match self.current_char() {
                    'n' => value.push('\n'),
                    't' => value.push('\t'),
                    'r' => value.push('\r'),
                    '"' => value.push('"'),
                    _ => value.push(self.current_char()),
                }
            } else {
                value.push(self.current_char());
            }
            self.advance();
        }

        if self.is_at_end() {
            self.error("Unterminated string");
        } else {
            self.advance(); // consume closing "
        }

        Token {
            token_type: TokenType::String(value),
            lexeme: format!("\"{}\"", value),
            line: start_line,
            column: start_col,
        }
    }

    // 헬퍼 메서드들
    fn current_char(&self) -> char {
        if self.is_at_end() { '\0' } else { self.input[self.current] }
    }

    fn peek(&self) -> Option<char> {
        if self.current + 1 >= self.input.len() {
            None
        } else {
            Some(self.input[self.current + 1])
        }
    }

    fn peek_next(&self) -> Option<char> {
        if self.current + 2 >= self.input.len() {
            None
        } else {
            Some(self.input[self.current + 2])
        }
    }

    fn advance(&mut self) {
        if !self.is_at_end() {
            if self.current_char() == '\n' {
                self.line += 1;
                self.column = 1;
            } else {
                self.column += 1;
            }
            self.current += 1;
        }
    }

    fn is_at_end(&self) -> bool {
        self.current >= self.input.len()
    }

    fn skip_whitespace(&mut self) {
        while matches!(self.current_char(), ' ' | '\t' | '\n' | '\r') {
            self.advance();
        }
        // 주석 처리
        if self.current_char() == '/' && self.peek() == Some('/') {
            while !self.is_at_end() && self.current_char() != '\n' {
                self.advance();
            }
        }
    }

    fn make_token(&mut self, token_type: TokenType) -> Token {
        let line = self.line;
        let column = self.column;
        let lexeme = self.current_char().to_string();
        self.advance();
        Token { token_type, lexeme, line, column }
    }

    fn error(&self, msg: &str) {
        eprintln!("Error at line {}, column {}: {}", self.line, self.column, msg);
    }
}
```

#### Step 3: 테스트

```rust
#[test]
fn test_lexer_arithmetic() {
    let mut lexer = Lexer::new("let x = 10 + 5;");
    let tokens = lexer.tokenize();

    assert_eq!(tokens[0].token_type, TokenType::Keyword("let".to_string()));
    assert_eq!(tokens[1].token_type, TokenType::Identifier("x".to_string()));
    assert_eq!(tokens[2].token_type, TokenType::Equal);
    assert_eq!(tokens[3].token_type, TokenType::Number(10.0));
    assert_eq!(tokens[4].token_type, TokenType::Plus);
    assert_eq!(tokens[5].token_type, TokenType::Number(5.0));
    assert_eq!(tokens[6].token_type, TokenType::Semicolon);
    assert_eq!(tokens[7].token_type, TokenType::EOF);
}

#[test]
fn test_lexer_strings() {
    let mut lexer = Lexer::new(r#"let s = "hello world";"#);
    let tokens = lexer.tokenize();

    assert_eq!(tokens[0].token_type, TokenType::Keyword("let".to_string()));
    assert_eq!(tokens[3].token_type, TokenType::String("hello world".to_string()));
}

#[test]
fn test_lexer_keywords() {
    let mut lexer = Lexer::new("fn if else loop break return");
    let tokens = lexer.tokenize();

    assert!(matches!(tokens[0].token_type, TokenType::Keyword(_)));
    assert!(matches!(tokens[1].token_type, TokenType::Keyword(_)));
}
