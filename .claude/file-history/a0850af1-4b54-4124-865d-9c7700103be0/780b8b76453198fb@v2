#!/usr/bin/env python3
# -*- coding: utf-8 -*-

"""
🏛️ v6.1: 디자인 패턴 (Design Patterns)
거장들의 설계 규격 — 싱글톤과 팩토리 패턴

학생관리 시스템에 디자인 패턴을 적용한 아키텍처 개선
"""

from abc import ABC, abstractmethod
from datetime import datetime
from typing import Dict, List, Optional
import json


# ==================== 1. 싱글톤 패턴 ====================

class SystemLogger:
    """
    싱글톤 패턴: 시스템 전체에서 유일한 로거 인스턴스

    장점:
    - 메모리 효율성 (인스턴스 1개만 생성)
    - 전역 상태 관리 (모든 로그가 한 곳에 집중)

    단점:
    - 테스트 어려움 (전역 상태)
    - 멀티스레드 환경에서 동기화 필요
    """
    _instance = None
    _log_file = 'system.log'

    def __new__(cls):
        if cls._instance is None:
            print("🆕 [SYSTEM] 새로운 로거 인스턴스를 생성합니다.")
            cls._instance = super().__new__(cls)
            cls._instance._logs = []
        return cls._instance

    def log(self, level: str, message: str):
        """로그 기록"""
        timestamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
        log_entry = {
            'timestamp': timestamp,
            'level': level,
            'message': message
        }
        self._logs.append(log_entry)

        # 콘솔 출력
        level_emoji = {
            'INFO': 'ℹ️ ',
            'SUCCESS': '✅',
            'WARNING': '⚠️ ',
            'ERROR': '❌',
            'DEBUG': '🐛'
        }.get(level, '📝')

        print(f"{level_emoji} [{timestamp}] {level}: {message}")

    def get_logs(self) -> List[Dict]:
        """로그 조회"""
        return self._logs

    def export_logs(self) -> str:
        """로그 내보내기"""
        return json.dumps(self._logs, indent=2, ensure_ascii=False)


class ConfigManager:
    """
    싱글톤 패턴: 시스템 설정 관리자

    데이터베이스 연결, API 키 등을 중앙에서 관리
    """
    _instance = None

    def __new__(cls):
        if cls._instance is None:
            print("🆕 [CONFIG] 새로운 설정 관리자를 생성합니다.")
            cls._instance = super().__new__(cls)
            cls._instance._config = {
                'db_host': 'localhost',
                'db_port': 5432,
                'db_name': 'student_management',
                'api_timeout': 30,
                'max_connections': 10,
                'debug_mode': True,
            }
        return cls._instance

    def get(self, key: str, default=None):
        """설정값 조회"""
        return self._config.get(key, default)

    def set(self, key: str, value):
        """설정값 변경"""
        self._config[key] = value

    def get_all(self) -> Dict:
        """모든 설정 조회"""
        return self._config.copy()


# ==================== 2. 팩토리 패턴 ====================

class DataSource(ABC):
    """
    추상 기본 클래스: 데이터 소스

    팩토리 패턴의 기초
    """

    @abstractmethod
    def read(self) -> str:
        """데이터 읽기"""
        pass

    @abstractmethod
    def write(self, data: str):
        """데이터 쓰기"""
        pass

    @abstractmethod
    def get_type(self) -> str:
        """데이터 소스 타입 반환"""
        pass


class DatabaseSource(DataSource):
    """데이터베이스 소스"""

    def read(self) -> str:
        return "📊 데이터베이스에서 학생 데이터를 읽었습니다."

    def write(self, data: str):
        print(f"💾 데이터베이스에 저장: {data}")

    def get_type(self) -> str:
        return "Database (SQLite)"


class CSVSource(DataSource):
    """CSV 파일 소스"""

    def read(self) -> str:
        return "📄 CSV 파일에서 학생 데이터를 읽었습니다."

    def write(self, data: str):
        print(f"📝 CSV 파일에 저장: {data}")

    def get_type(self) -> str:
        return "CSV File"


class JSONSource(DataSource):
    """JSON 파일 소스"""

    def read(self) -> str:
        return "📋 JSON 파일에서 학생 데이터를 읽었습니다."

    def write(self, data: str):
        print(f"🔧 JSON 파일에 저장: {data}")

    def get_type(self) -> str:
        return "JSON File"


class APISource(DataSource):
    """API 소스"""

    def read(self) -> str:
        return "🌐 API에서 학생 데이터를 읽었습니다."

    def write(self, data: str):
        print(f"📡 API로 전송: {data}")

    def get_type(self) -> str:
        return "REST API"


class DataSourceFactory:
    """
    팩토리 패턴: 데이터 소스 공장

    클라이언트가 구체적인 클래스에 의존하지 않도록 함
    """

    _sources: Dict[str, type] = {
        'database': DatabaseSource,
        'csv': CSVSource,
        'json': JSONSource,
        'api': APISource,
    }

    @classmethod
    def create(cls, source_type: str) -> Optional[DataSource]:
        """데이터 소스 생성"""
        source_class = cls._sources.get(source_type.lower())
        if source_class:
            return source_class()
        return None

    @classmethod
    def register(cls, name: str, source_class: type):
        """새로운 데이터 소스 등록"""
        cls._sources[name.lower()] = source_class

    @classmethod
    def list_sources(cls) -> List[str]:
        """사용 가능한 소스 목록"""
        return list(cls._sources.keys())


# ==================== 3. 팩토리 패턴: 리포트 생성기 ====================

class Report(ABC):
    """리포트 추상 클래스"""

    @abstractmethod
    def generate(self, data: Dict) -> str:
        """리포트 생성"""
        pass

    @abstractmethod
    def get_format(self) -> str:
        """리포트 형식"""
        pass


class PDFReport(Report):
    """PDF 리포트"""

    def generate(self, data: Dict) -> str:
        return f"📄 PDF 리포트 생성: {json.dumps(data, ensure_ascii=False)}"

    def get_format(self) -> str:
        return "PDF"


class ExcelReport(Report):
    """Excel 리포트"""

    def generate(self, data: Dict) -> str:
        return f"📊 Excel 리포트 생성: {json.dumps(data, ensure_ascii=False)}"

    def get_format(self) -> str:
        return "Excel"


class HTMLReport(Report):
    """HTML 리포트"""

    def generate(self, data: Dict) -> str:
        return f"🌐 HTML 리포트 생성: {json.dumps(data, ensure_ascii=False)}"

    def get_format(self) -> str:
        return "HTML"


class ReportFactory:
    """리포트 생성 팩토리"""

    _reports: Dict[str, type] = {
        'pdf': PDFReport,
        'excel': ExcelReport,
        'html': HTMLReport,
    }

    @classmethod
    def create(cls, report_type: str) -> Optional[Report]:
        """리포트 생성"""
        report_class = cls._reports.get(report_type.lower())
        if report_class:
            return report_class()
        return None

    @classmethod
    def list_formats(cls) -> List[str]:
        """지원하는 리포트 형식"""
        return list(cls._reports.keys())


# ==================== 4. 애플리케이션 시작 ====================

def main():
    """메인 실행"""
    print("\n" + "🏛️ " * 20)
    print("v6.1: 디자인 패턴 - 거장들의 설계 규격")
    print("🏛️ " * 20 + "\n")

    # ==================== 싱글톤 패턴 데모 ====================
    print("="*80)
    print("【 1️⃣  싱글톤 패턴: SystemLogger 】")
    print("="*80 + "\n")

    # 첫 번째 로거 생성
    logger1 = SystemLogger()
    logger1.log('INFO', '시스템 부팅 중...')

    print()

    # 두 번째 로거 생성 (같은 인스턴스)
    logger2 = SystemLogger()
    logger2.log('SUCCESS', '시스템 부팅 완료!')

    print()

    # 같은 객체인지 확인
    print(f"❓ logger1 is logger2: {logger1 is logger2}")
    print(f"❓ id(logger1) == id(logger2): {id(logger1) == id(logger2)}")
    print(f"✅ 싱글톤 패턴 검증: 두 로거는 정확히 같은 인스턴스입니다!\n")

    # ==================== 설정 관리자 ====================
    print("="*80)
    print("【 2️⃣  싱글톤 패턴: ConfigManager 】")
    print("="*80 + "\n")

    config1 = ConfigManager()
    config2 = ConfigManager()

    print(f"설정 조회:")
    print(f"  DB Host: {config1.get('db_host')}")
    print(f"  DB Port: {config1.get('db_port')}")
    print(f"  Max Connections: {config1.get('max_connections')}")

    print(f"\n설정 변경:")
    config1.set('debug_mode', False)
    print(f"  Debug Mode: {config2.get('debug_mode')} (config1에서 변경했는데도 config2에서 보입니다!)")
    print(f"\n✅ 싱글톤 패턴 검증: 모든 설정이 동기화됩니다!\n")

    # ==================== 팩토리 패턴: 데이터 소스 ====================
    print("="*80)
    print("【 3️⃣  팩토리 패턴: DataSourceFactory 】")
    print("="*80 + "\n")

    factory = DataSourceFactory()

    print(f"지원하는 데이터 소스: {factory.list_sources()}\n")

    sources = ['database', 'csv', 'json', 'api']
    for source_type in sources:
        source = factory.create(source_type)
        if source:
            print(f"📌 {source_type.upper()}:")
            print(f"   타입: {source.get_type()}")
            print(f"   읽기: {source.read()}")
            source.write("학생 데이터 저장")
            print()

    print("✅ 팩토리 패턴 검증: 코드 수정 없이 새로운 소스 추가 가능!\n")

    # ==================== 팩토리 패턴: 리포트 ====================
    print("="*80)
    print("【 4️⃣  팩토리 패턴: ReportFactory 】")
    print("="*80 + "\n")

    report_factory = ReportFactory()

    print(f"지원하는 리포트 형식: {report_factory.list_formats()}\n")

    sample_data = {
        'total_students': 6,
        'total_grades': 7,
        'average_gpa': 89.5
    }

    for format_type in report_factory.list_formats():
        report = report_factory.create(format_type)
        if report:
            print(f"📊 {format_type.upper()} 리포트:")
            result = report.generate(sample_data)
            print(f"   {result}\n")

    print("✅ 팩토리 패턴 검증: 리포트 형식 추가도 간단합니다!\n")

    # ==================== 패턴의 이점 분석 ====================
    print("="*80)
    print("【 🎯 디자인 패턴의 이점 】")
    print("="*80 + "\n")

    benefits = {
        '싱글톤': [
            '메모리 효율성: 인스턴스 1개만 생성',
            '전역 상태 관리: 모든 모듈이 같은 상태 공유',
            '초기화 비용 절감: 시스템 시작 시 1회만 생성'
        ],
        '팩토리': [
            '느슨한 결합: 클라이언트가 구체적 클래스에 의존하지 않음',
            '확장성: 새로운 타입 추가 시 기존 코드 수정 불필요',
            '유지보수성: 객체 생성 로직이 한 곳에 집중'
        ]
    }

    for pattern, benefits_list in benefits.items():
        print(f"🎯 {pattern} 패턴:")
        for benefit in benefits_list:
            print(f"   ✓ {benefit}")
        print()

    # ==================== 로그 내보내기 ====================
    print("="*80)
    print("【 📝 시스템 로그 조회 】")
    print("="*80 + "\n")

    logs = logger1.get_logs()
    print(f"총 로그 수: {len(logs)}\n")

    for log in logs:
        print(f"{log['timestamp']} [{log['level']}] {log['message']}")

    # ==================== 최종 요약 ====================
    print("\n" + "="*80)
    print("✨ v6.1 디자인 패턴 완료!")
    print("="*80)

    print("\n【 핵심 개념 】\n")
    print("🏛️ 싱글톤 패턴:")
    print("   - 인스턴스를 1개만 생성하고 전역에서 접근")
    print("   - 사용: 로거, 설정 관리자, 데이터베이스 연결풀")
    print("   - 주의: 테스트 어려움, 전역 상태 관리")

    print("\n🏭 팩토리 패턴:")
    print("   - 객체 생성을 추상화하여 느슨한 결합 달성")
    print("   - 사용: 데이터 소스, 리포트 생성, 플러그인 시스템")
    print("   - 이점: 확장성, 유지보수성 증대")

    print("\n" + "="*80)
    print("기록이 증명이다 gogs 🎓")
    print("="*80 + "\n")


if __name__ == "__main__":
    main()
