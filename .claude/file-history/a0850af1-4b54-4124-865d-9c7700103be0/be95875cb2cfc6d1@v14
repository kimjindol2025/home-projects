    SecurityLog::new()
}

/// Creates a new empty configuration manager.
///
/// This is a convenience factory function that creates a new `ConfigManager` instance.
/// For more control, use `ConfigManager::new()` directly.
///
/// # Examples
///
/// ```
/// use pulseai_lang::create_config_manager;
///
/// let mut config = create_config_manager();
