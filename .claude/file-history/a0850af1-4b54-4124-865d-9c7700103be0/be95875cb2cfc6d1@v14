/// Audit severity levels for security events.
///
/// Represents the priority level of security audit events,
/// ranging from informational to critical incidents.
///
/// # Examples
///
/// ```
/// use pulseai_lang::AuditLevel;
///
/// let level = AuditLevel::Critical;
/// assert_eq!(level.severity_score(), 4);
/// assert_eq!(level.level_name(), "FATAL");
/// ```
#[derive(Clone, Copy, Debug, PartialEq, Eq, PartialOrd, Ord)]
pub enum AuditLevel {
    /// Low priority event (score: 1, name: "INFO")
    Low,
    /// Medium priority event (score: 2, name: "WARN")
    Medium,
    /// High priority event (score: 3, name: "ERROR")
    High,
    /// Critical event requiring immediate action (score: 4, name: "FATAL")
    Critical,
}

impl AuditLevel {
    /// Returns the human-readable name of the audit level.
    ///
    /// # Examples
    ///
    /// ```
    /// use pulseai_lang::AuditLevel;
    ///
    /// assert_eq!(AuditLevel::Low.level_name(), "INFO");
    /// assert_eq!(AuditLevel::Critical.level_name(), "FATAL");
    /// ```
    pub fn level_name(&self) -> &'static str {
        match self {
            AuditLevel::Low => "INFO",
            AuditLevel::Medium => "WARN",
            AuditLevel::High => "ERROR",
            AuditLevel::Critical => "FATAL",
        }
    }

    /// Returns the numeric severity score (1-4) for this audit level.
    ///
    /// Used for calculating cumulative severity and priority ranking.
    ///
    /// # Examples
    ///
    /// ```
    /// use pulseai_lang::AuditLevel;
    ///
    /// assert_eq!(AuditLevel::Low.severity_score(), 1);
    /// assert_eq!(AuditLevel::Medium.severity_score(), 2);
    /// assert_eq!(AuditLevel::High.severity_score(), 3);
    /// assert_eq!(AuditLevel::Critical.severity_score(), 4);
    /// ```
    pub fn severity_score(&self) -> u32 {
        match self {
            AuditLevel::Low => 1,
            AuditLevel::Medium => 2,
            AuditLevel::High => 3,
            AuditLevel::Critical => 4,
        }
    }
}

/// Security vault for managing and authenticating secret keys.
///
/// A `Vault` securely stores a secret key and provides authentication
/// through exact string comparison. Keys are case-sensitive.
///
/// # Examples
///
/// ```
/// use pulseai_lang::Vault;
///
/// // Create a new vault with a secret key
/// let vault = Vault::new("my_secret_key");
///
/// // Authenticate with the correct key
/// assert!(vault.authenticate("my_secret_key"));
///
/// // Failed authentication with wrong key
/// assert!(!vault.authenticate("wrong_key"));
/// ```
#[derive(Clone)]
pub struct Vault {
    secret_key: String,
}

impl Vault {
    /// Creates a new vault with the given secret key.
    ///
    /// # Arguments
    ///
    /// * `key` - The secret key to store in the vault (any valid string)
    ///
    /// # Examples
    ///
    /// ```
    /// use pulseai_lang::Vault;
    ///
    /// let vault = Vault::new("secret_key_xyz");
    /// assert_eq!(vault.key_length(), 14);
    /// ```
    pub fn new(key: &str) -> Self {
        Self {
            secret_key: key.to_string(),
        }
    }

    /// Authenticates a provided input against the stored secret key.
    ///
    /// Returns `true` if the input matches the secret key exactly,
    /// `false` otherwise. The comparison is case-sensitive.
    ///
    /// # Arguments
    ///
    /// * `input` - The key to verify against the stored secret
    ///
    /// # Examples
    ///
    /// ```
    /// use pulseai_lang::Vault;
    ///
    /// let vault = Vault::new("MyPassword");
    /// assert!(vault.authenticate("MyPassword"));
    /// assert!(!vault.authenticate("mypassword"));  // Case sensitive
    /// assert!(!vault.authenticate("wrong"));
    /// ```
    pub fn authenticate(&self, input: &str) -> bool {
        self.secret_key == input
    }

    /// Returns the length of the stored secret key.
    ///
    /// Useful for validating key strength or generating reports.
    ///
    /// # Examples
    ///
    /// ```
    /// use pulseai_lang::Vault;
    ///
    /// let vault = Vault::new("secret");
    /// assert_eq!(vault.key_length(), 6);
    ///
    /// let empty_vault = Vault::new("");
    /// assert_eq!(empty_vault.key_length(), 0);
    /// ```
    pub fn key_length(&self) -> usize {
        self.secret_key.len()
    }
}

/// Generic auditor for auditing and logging displayable data with severity levels.
///
/// `Auditor<'a, T>` provides a flexible way to audit any data that implements
/// `Display`. It maintains a reference to the data, a configuration identifier,
/// and a severity level. The auditor uses the builder pattern for configuration.
///
/// # Type Parameters
///
/// * `'a` - Lifetime of the target data reference
/// * `T` - Type of data to audit (must implement `Display`)
///
/// # Examples
///
/// ```
/// use pulseai_lang::{Auditor, AuditLevel};
///
/// let config_name = "database_access";
/// let user = "admin_user";
///
/// // Create auditor with default Medium severity
/// let auditor = Auditor::new(&user, config_name);
/// auditor.audit();
///
/// // Use builder pattern to set severity
/// let critical_audit = Auditor::new(&user, config_name)
///     .with_severity(AuditLevel::Critical);
/// assert!(critical_audit.is_critical());
/// ```
pub struct Auditor<'a, T>
where
    T: Display + 'a,
{
    target: &'a T,
    config: &'a str,
    severity: AuditLevel,
}

impl<'a, T> Auditor<'a, T>
where
    T: Display + 'a,
{
    /// Creates a new auditor for the given target with default Medium severity.
    ///
    /// # Arguments
    ///
    /// * `target` - Reference to data to be audited (must implement Display)
    /// * `config` - Configuration identifier or log name
    ///
    /// # Examples
    ///
    /// ```
    /// use pulseai_lang::Auditor;
    ///
    /// let data = "audit_target";
    /// let auditor = Auditor::new(&data, "SEC-001");
    /// assert_eq!(auditor.get_severity(), 2);  // Medium = 2
    /// ```
    pub fn new(target: &'a T, config: &'a str) -> Self {
        Auditor {
            target,
            config,
            severity: AuditLevel::Medium,
        }
    }

    /// Outputs the audit information to stdout in a structured format.
    ///
    /// Prints: `[{config}] {severity_name} -> {target}`
    ///
    /// # Examples
    ///
    /// ```
    /// use pulseai_lang::Auditor;
    ///
    /// let data = "test_data";
    /// let auditor = Auditor::new(&data, "AUDIT-1");
    /// // This prints: [AUDIT-1] WARN -> test_data
    /// auditor.audit();
    /// ```
    pub fn audit(&self) {
        println!(
            "[{}] {} -> {}",
            self.config,
            self.severity.level_name(),
            self.target
        );
    }

    /// Sets the severity level and returns self for builder pattern chaining.
    ///
    /// # Arguments
    ///
    /// * `level` - The new audit severity level
    ///
    /// # Examples
    ///
    /// ```
    /// use pulseai_lang::{Auditor, AuditLevel};
    ///
    /// let data = "critical_event";
    /// let auditor = Auditor::new(&data, "EVENT-001")
    ///     .with_severity(AuditLevel::High);
    /// assert_eq!(auditor.get_severity(), 3);  // High = 3
    /// ```
    pub fn with_severity(mut self, level: AuditLevel) -> Self {
        self.severity = level;
        self
    }

    /// Returns the numeric severity score (1-4) of the current audit level.
    ///
    /// # Examples
    ///
    /// ```
    /// use pulseai_lang::{Auditor, AuditLevel};
    ///
    /// let data = 42;
    /// let auditor = Auditor::new(&data, "NUM-AUDIT")
    ///     .with_severity(AuditLevel::Critical);
    /// assert_eq!(auditor.get_severity(), 4);
    /// ```
    pub fn get_severity(&self) -> u32 {
        self.severity.severity_score()
    }

    /// Checks if the current audit level is Critical.
    ///
    /// # Examples
    ///
    /// ```
    /// use pulseai_lang::{Auditor, AuditLevel};
    ///
    /// let data = "test";
    /// let normal = Auditor::new(&data, "TEST-1");
    /// assert!(!normal.is_critical());
    ///
    /// let critical = Auditor::new(&data, "TEST-2")
    ///     .with_severity(AuditLevel::Critical);
    /// assert!(critical.is_critical());
    /// ```
    pub fn is_critical(&self) -> bool {
        self.severity == AuditLevel::Critical
    }
}

/// A log entry recording a security audit event.
///
/// Represents a single timestamped event with a severity level.
///
/// # Examples
///
/// ```
/// use pulseai_lang::{LogEntry, AuditLevel};
///
/// let entry = LogEntry {
///     event: "Login attempt".to_string(),
///     timestamp: "2026-02-22T10:00:00Z".to_string(),
///     severity: AuditLevel::Low,
/// };
/// assert_eq!(entry.event, "Login attempt");
/// ```
#[derive(Clone, Debug)]
pub struct LogEntry {
    /// Description of the security event
    pub event: String,
    /// ISO 8601 timestamp of when the event occurred
    pub timestamp: String,
    /// Severity level of the event
    pub severity: AuditLevel,
}

/// A collection of security event logs with analysis capabilities.
///
/// `SecurityLog` accumulates audit events and provides methods to
/// query, filter, and analyze them by severity level.
///
/// # Examples
///
/// ```
/// use pulseai_lang::{SecurityLog, AuditLevel};
///
/// let mut log = SecurityLog::new();
///
/// // Log various events
/// log.log_event("System startup", "2026-02-22T10:00:00Z", AuditLevel::Low);
/// log.log_event("Breach detected", "2026-02-22T10:05:00Z", AuditLevel::Critical);
///
/// // Query the log
/// assert_eq!(log.get_events().len(), 2);
/// assert_eq!(log.critical_count(), 1);
/// assert!(log.total_severity() > 0);
/// ```
pub struct SecurityLog {
    events: Vec<LogEntry>,
}

impl SecurityLog {
    /// Creates a new empty security log.
    ///
    /// # Examples
    ///
    /// ```
    /// use pulseai_lang::SecurityLog;
    ///
    /// let log = SecurityLog::new();
    /// assert_eq!(log.get_events().len(), 0);
    /// ```
    pub fn new() -> Self {
        Self {
            events: Vec::new(),
        }
    }

    /// Adds a new event to the security log.
    ///
    /// # Arguments
    ///
    /// * `event` - Description of the security event
    /// * `timestamp` - ISO 8601 formatted timestamp
    /// * `severity` - The severity level of the event
    ///
    /// # Examples
    ///
    /// ```
    /// use pulseai_lang::{SecurityLog, AuditLevel};
    ///
    /// let mut log = SecurityLog::new();
    /// log.log_event("User login", "2026-02-22T10:00:00Z", AuditLevel::Low);
    /// assert_eq!(log.get_events().len(), 1);
    /// ```
    pub fn log_event(&mut self, event: &str, timestamp: &str, severity: AuditLevel) {
        self.events.push(LogEntry {
            event: event.to_string(),
            timestamp: timestamp.to_string(),
            severity,
        });
    }

    /// Returns a slice of all logged events.
    ///
    /// # Examples
    ///
    /// ```
    /// use pulseai_lang::{SecurityLog, AuditLevel};
    ///
    /// let mut log = SecurityLog::new();
    /// log.log_event("Event 1", "2026-02-22T10:00:00Z", AuditLevel::Low);
    /// log.log_event("Event 2", "2026-02-22T10:01:00Z", AuditLevel::High);
    ///
    /// let events = log.get_events();
    /// assert_eq!(events.len(), 2);
    /// assert_eq!(events[0].event, "Event 1");
    /// ```
    pub fn get_events(&self) -> &[LogEntry] {
        &self.events
    }

    /// Counts the number of critical severity events in the log.
    ///
    /// # Examples
    ///
    /// ```
    /// use pulseai_lang::{SecurityLog, AuditLevel};
    ///
    /// let mut log = SecurityLog::new();
    /// log.log_event("Normal event", "2026-02-22T10:00:00Z", AuditLevel::Low);
    /// log.log_event("Critical event", "2026-02-22T10:01:00Z", AuditLevel::Critical);
    /// log.log_event("Another critical", "2026-02-22T10:02:00Z", AuditLevel::Critical);
    ///
    /// assert_eq!(log.critical_count(), 2);
    /// ```
    pub fn critical_count(&self) -> usize {
        self.events
            .iter()
            .filter(|e| e.severity == AuditLevel::Critical)
            .count()
    }

    /// Calculates the total severity score of all logged events.
    ///
    /// Each event's severity contributes its score (Low=1, Medium=2, High=3, Critical=4)
    /// to the total.
    ///
    /// # Examples
    ///
    /// ```
    /// use pulseai_lang::{SecurityLog, AuditLevel};
    ///
    /// let mut log = SecurityLog::new();
    /// log.log_event("Low event", "2026-02-22T10:00:00Z", AuditLevel::Low);      // 1
    /// log.log_event("Medium event", "2026-02-22T10:01:00Z", AuditLevel::Medium); // 2
    ///
    /// assert_eq!(log.total_severity(), 3);
    /// ```
    pub fn total_severity(&self) -> u32 {
        self.events.iter().map(|e| e.severity.severity_score()).sum()
    }
}

impl Default for SecurityLog {
    fn default() -> Self {
        Self::new()
    }
}

/// A manager for storing and retrieving configuration settings.
///
/// `ConfigManager` provides a simple key-value store for application configuration.
/// Both keys and values are stored as strings, and keys are case-sensitive.
///
/// # Examples
///
/// ```
/// use pulseai_lang::ConfigManager;
///
/// let mut config = ConfigManager::new();
///
/// // Store configuration
/// config.set("database_url", "postgresql://localhost:5432");
/// config.set("log_level", "info");
///
/// // Retrieve configuration
/// assert_eq!(
///     config.get("database_url"),
///     Some(&"postgresql://localhost:5432".to_string())
/// );
///
/// // Count settings
/// assert_eq!(config.setting_count(), 2);
/// ```
pub struct ConfigManager {
    settings: std::collections::HashMap<String, String>,
}

impl ConfigManager {
    /// Creates a new empty configuration manager.
    ///
    /// # Examples
    ///
    /// ```
    /// use pulseai_lang::ConfigManager;
    ///
    /// let config = ConfigManager::new();
    /// assert_eq!(config.setting_count(), 0);
    /// ```
    pub fn new() -> Self {
        Self {
            settings: std::collections::HashMap::new(),
        }
    }

    /// Sets a configuration value, overwriting any existing value for the key.
    ///
    /// # Arguments
    ///
    /// * `key` - The configuration key (case-sensitive)
    /// * `value` - The configuration value
    ///
    /// # Examples
    ///
    /// ```
    /// use pulseai_lang::ConfigManager;
    ///
    /// let mut config = ConfigManager::new();
    /// config.set("app_name", "PulseAI");
    /// config.set("version", "1.0.0");
    ///
    /// assert_eq!(config.get("app_name"), Some(&"PulseAI".to_string()));
    ///
    /// // Overwriting existing value
    /// config.set("version", "1.1.0");
    /// assert_eq!(config.get("version"), Some(&"1.1.0".to_string()));
    /// ```
    pub fn set(&mut self, key: &str, value: &str) {
        self.settings.insert(key.to_string(), value.to_string());
    }

    /// Retrieves a configuration value by key.
    ///
    /// Returns `Some(&value)` if the key exists, `None` otherwise.
    /// Keys are case-sensitive.
    ///
    /// # Arguments
    ///
    /// * `key` - The configuration key to retrieve
    ///
    /// # Examples
    ///
    /// ```
    /// use pulseai_lang::ConfigManager;
    ///
    /// let mut config = ConfigManager::new();
    /// config.set("debug", "true");
    ///
    /// assert_eq!(config.get("debug"), Some(&"true".to_string()));
    /// assert_eq!(config.get("nonexistent"), None);
    /// assert_eq!(config.get("Debug"), None);  // Case sensitive
    /// ```
    pub fn get(&self, key: &str) -> Option<&String> {
        self.settings.get(key)
    }

    /// Returns a vector of all key-value pairs in the configuration.
    ///
    /// # Examples
    ///
    /// ```
    /// use pulseai_lang::ConfigManager;
    ///
    /// let mut config = ConfigManager::new();
    /// config.set("key1", "value1");
    /// config.set("key2", "value2");
    ///
    /// let all = config.all_settings();
    /// assert_eq!(all.len(), 2);
    /// ```
    pub fn all_settings(&self) -> Vec<(&String, &String)> {
        self.settings.iter().collect()
    }

    /// Returns the number of configuration settings currently stored.
    ///
    /// # Examples
    ///
    /// ```
    /// use pulseai_lang::ConfigManager;
    ///
    /// let mut config = ConfigManager::new();
    /// assert_eq!(config.setting_count(), 0);
    ///
    /// config.set("setting1", "value1");
    /// config.set("setting2", "value2");
    /// assert_eq!(config.setting_count(), 2);
    /// ```
    pub fn setting_count(&self) -> usize {
        self.settings.len()
    }
}

impl Default for ConfigManager {
    fn default() -> Self {
        Self::new()
    }
}

/// Creates a new security vault with the given secret key.
///
/// This is a convenience factory function that creates a new `Vault` instance.
/// For more control, use `Vault::new()` directly.
///
/// # Arguments
///
/// * `key` - The secret key to store in the vault
///
/// # Examples
///
/// ```
/// use pulseai_lang::create_vault;
///
/// let vault = create_vault("secure_key");
/// assert!(vault.authenticate("secure_key"));
/// assert!(!vault.authenticate("wrong_key"));
/// ```
pub fn create_vault(key: &str) -> Vault {
    Vault::new(key)
}

