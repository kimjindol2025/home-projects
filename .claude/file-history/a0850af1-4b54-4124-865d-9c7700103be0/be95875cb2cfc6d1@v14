/// Verifies that the provided input matches the vault's secret key.
///
/// This is a convenience function that delegates to `vault.authenticate()`.
///
/// # Arguments
///
/// * `vault` - Reference to the vault to verify against
/// * `input` - The key to verify
///
/// # Examples
///
/// ```
/// use pulseai_lang::{create_vault, verify_access};
///
/// let vault = create_vault("secret_123");
/// assert!(verify_access(&vault, "secret_123"));
/// assert!(!verify_access(&vault, "wrong"));
/// ```
pub fn verify_access(vault: &Vault, input: &str) -> bool {
    vault.authenticate(input)
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn vault_creation() {
        let vault = Vault::new("secret");
        assert_eq!(vault.key_length(), 6);
    }

    #[test]
    fn vault_authentication() {
        let vault = Vault::new("correct_key");
        assert!(vault.authenticate("correct_key"));
        assert!(!vault.authenticate("wrong_key"));
    }

    #[test]
    fn audit_severity_levels() {
        assert_eq!(AuditLevel::Low.severity_score(), 1);
        assert_eq!(AuditLevel::Critical.severity_score(), 4);
    }

    #[test]
    fn security_log_operations() {
        let mut log = SecurityLog::new();
        log.log_event("Login", "2026-02-22T10:00:00Z", AuditLevel::Low);
        log.log_event("Breach", "2026-02-22T10:01:00Z", AuditLevel::Critical);

        assert_eq!(log.get_events().len(), 2);
        assert_eq!(log.critical_count(), 1);
    }

    #[test]
    fn config_manager_operations() {
        let mut config = ConfigManager::new();
        config.set("database", "postgresql");
        config.set("port", "5432");

        assert_eq!(config.setting_count(), 2);
        assert_eq!(config.get("database"), Some(&"postgresql".to_string()));
    }
}
