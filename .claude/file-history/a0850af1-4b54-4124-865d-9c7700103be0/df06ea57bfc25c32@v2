// ============================================================================
// [1] 단순 가드 구문 (Simple Guard Clauses)
// ============================================================================
//
// 부적격 조건을 먼저 처리
//
fn simple_guard_clauses() {
    println!("[1] 단순 가드 구문");
    println!("────────────────────────────────────────────────────────────");

    // 가드 1: 기본 가드
    {
        println!("✓ 기본 Guard Clause");
        fn check_value(x: i32) {
            if x < 0 {
                println!("  [ERROR] 음수는 허용되지 않습니다");
                return;  // 조기 종료
            }

            if x > 100 {
                println!("  [ERROR] 100을 초과할 수 없습니다");
                return;  // 조기 종료
            }

            // 여기에 도달했다면 0 <= x <= 100 보장
            println!("  [OK] 값이 유효합니다: {}", x);
        }

        check_value(50);
        check_value(-10);
        check_value(150);
    }

    // 가드 2: 시스템 가동 테스트
    {
        println!("✓ 시스템 가동 테스트 (사용자 예제)");
        let system_power = true;
        let auth_level = 10;
        let component_status = "STABLE";

        // Guard 1: 전원 검사
        if !system_power {
            println!("  [STOP] 전원이 꺼져 있습니다");
            return;
        }

        // Guard 2: 권한 검사
        if auth_level < 5 {
            println!("  [STOP] 권한이 부족합니다");
            return;
        }

        // Guard 3: 부품 상태 검사
        if component_status != "STABLE" {
            println!("  [STOP] 부품이 불안정합니다");
            return;
        }

        // 핵심 로직 (청정 구역)
        println!("  [SUCCESS] 모든 가드를 통과했습니다");
        println!("  -> 메인 엔진 가동!");
    }

    println!();
}

// ============================================================================
// [2] 피라미드 제거 (Pyramid Elimination)
// ============================================================================
//
// 깊은 중첩을 가드로 평탄화
//
fn pyramid_elimination() {
    println!("[2] 피라미드 제거");
    println!("────────────────────────────────────────────────────────────");

    // 제거 1: 피라미드 vs 평탄화
    {
        println!("✓ 피라미드 코드 vs 평탄화 코드");

        // ❌ 피라미드 (들여쓰기 지옥)
        fn pyramid_style(a: bool, b: bool, c: bool) {
            if a {
                println!("  a OK");
                if b {
                    println!("    b OK");
                    if c {
                        println!("      c OK");
                        println!("        [핵심] 깊이 4");  // 4단계 깊이
                    }
                }
            }
        }

        // ✅ 평탄화 (Guard 사용)
        fn flatten_style(a: bool, b: bool, c: bool) {
            if !a {
                println!("  a FAIL");
                return;
            }
            if !b {
                println!("  b FAIL");
                return;
            }
            if !c {
                println!("  c FAIL");
                return;
            }

            println!("  [핵심] 깊이 1 ✅");  // 1단계 깊이
        }

        println!("  피라미드:");
        pyramid_style(true, true, true);

        println!("  평탄화:");
        flatten_style(true, true, true);
    }

    println!();
}

// ============================================================================
// [3] Early Return 패턴 (Early Return Patterns)
// ============================================================================
//
// 조건 불만족 시 즉시 종료
//
fn early_return_patterns() {
    println!("[3] Early Return 패턴");
    println!("────────────────────────────────────────────────────────────");

    // Early Return 1: 인증
    {
        println!("✓ 인증 검증");
        fn authenticate(username: &str, password: &str) -> bool {
            // Guard 1: 사용자명
            if username.is_empty() {
                eprintln!("  [ERROR] 사용자명 입력 필요");
                return false;
            }

            // Guard 2: 비밀번호
            if password.is_empty() {
                eprintln!("  [ERROR] 비밀번호 입력 필요");
                return false;
            }

            // Guard 3: 길이 검사
            if password.len() < 8 {
                eprintln!("  [ERROR] 비밀번호는 8자 이상");
                return false;
            }

            // 핵심: 비밀번호 확인
            println!("  [OK] 인증 성공");
            true
        }

        authenticate("user", "");
        authenticate("user", "short");
        authenticate("user", "securepass");
    }

    // Early Return 2: 파일 검증
    {
        println!("✓ 파일 검증");
        fn validate_file(name: &str, size: usize) -> Result<(), String> {
            // Guard 1: 파일명
            if name.is_empty() {
                return Err("파일명이 비어있습니다".to_string());
            }

            // Guard 2: 파일 크기
            if size == 0 {
                return Err("파일 크기가 0입니다".to_string());
            }

            // Guard 3: 최대 크기
            if size > 1024 * 1024 * 10 {  // 10MB
                return Err("파일이 너무 큽니다".to_string());
            }

            // 핵심: 파일 처리
            Ok(())
        }

        match validate_file("test.txt", 1000) {
            Ok(_) => println!("  [OK] 파일 검증 완료"),
            Err(e) => println!("  [ERROR] {}", e),
        }
    }

    println!();
}

// ============================================================================
// [4] 불변성 보장 (Invariant Protection)
// ============================================================================
//
// 본문 진입 = 모든 검증 완료의 의미
//
fn invariant_protection() {
    println!("[4] 불변성 보장");
    println!("────────────────────────────────────────────────────────────");

    // 불변성 1: 급여 계산
    {
        println!("✓ 급여 계산 (불변성 보장)");
        fn calculate_salary(base: f64, hours: i32) -> Result<f64, String> {
            // Guard: 기본급이 유효한가?
            if base < 0.0 {
                return Err("기본급이 음수입니다".to_string());
            }

            // Guard: 근무 시간이 유효한가?
            if hours < 0 {
                return Err("근무 시간이 음수입니다".to_string());
            }

            // Guard: 과도한 근무 시간은 아닌가?
            if hours > 168 {  // 일주일이 168시간
                return Err("근무 시간이 너무 많습니다".to_string());
            }

            // 불변성 보장: 여기서부터는 모든 값이 유효
            let regular_pay = base * (hours.min(40) as f64) / 40.0;
            let overtime_hours = (hours - 40).max(0);
            let overtime_pay = base * (overtime_hours as f64) / 40.0 * 1.5;

            Ok(regular_pay + overtime_pay)
        }

        match calculate_salary(40.0, 50) {
            Ok(salary) => println!("  급여: ${:.2}", salary),
            Err(e) => println!("  오류: {}", e),
        }
    }

    // 불변성 2: 사용자 처리
    {
        println!("✓ 사용자 처리");
        struct User {
            name: String,
            age: u32,
        }

        fn process_user(user: &User) -> Result<String, String> {
            // Guard: 이름이 비어있는가?
            if user.name.is_empty() {
                return Err("이름이 비어있습니다".to_string());
            }

            // Guard: 나이가 유효한가?
            if user.age < 0 || user.age > 150 {
                return Err("나이가 유효하지 않습니다".to_string());
            }

            // 불변성 보장: 유효한 사용자
            Ok(format!("{}: {} 세", user.name, user.age))
        }

        let user = User {
            name: "Alice".to_string(),
            age: 30,
        };

        match process_user(&user) {
            Ok(info) => println!("  {}", info),
            Err(e) => println!("  오류: {}", e),
        }
    }

    println!();
}

// ============================================================================
// [5] Option/Result와 가드 결합 (Guard with Options/Results)
// ============================================================================
//
// 선택적 값 처리에서의 가드
//
fn guard_with_options() {
    println!("[5] Option/Result와 가드 결합");
    println!("────────────────────────────────────────────────────────────");

    // 가드 1: Option 처리
    {
        println!("✓ Option 처리");
        fn process_optional(value: Option<i32>) -> String {
            // Guard: None인가?
            let val = match value {
                None => return "값이 없습니다".to_string(),
                Some(v) => v,
            };

            // Guard: 음수인가?
            if val < 0 {
                return "음수는 허용되지 않습니다".to_string();
            }

            // 핵심: 유효한 값 처리
            format!("값: {}", val)
        }

        println!("  {}", process_optional(Some(42)));
        println!("  {}", process_optional(None));
        println!("  {}", process_optional(Some(-10)));
    }

    // 가드 2: Result 처리
    {
        println!("✓ Result 처리");
        fn process_result(input: i32) -> Result<i32, String> {
            // Guard: 0인가?
            if input == 0 {
                return Err("0으로 나눌 수 없습니다".to_string());
            }

            // Guard: 음수인가?
            if input < 0 {
                return Err("음수는 허용되지 않습니다".to_string());
            }

            // 핵심: 유효한 계산
            Ok(100 / input)
        }

        match process_result(5) {
            Ok(result) => println!("  결과: {}", result),
            Err(e) => println!("  오류: {}", e),
        }
    }

    println!();
}

// ============================================================================
// [6] 함수 수준의 가드 (Function-Level Guards)
// ============================================================================
//
// 함수 진입 시 전체 조건 검사
//
fn function_guards() {
    println!("[6] 함수 수준의 가드");
    println!("────────────────────────────────────────────────────────────");

    // 함수 1: 주문 처리
    {
        println!("✓ 주문 처리");
        fn process_order(customer_id: u32, amount: f64) -> Result<String, String> {
            // Guard 1: 고객 ID
            if customer_id == 0 {
                return Err("고객 ID가 필요합니다".to_string());
            }

            // Guard 2: 금액
            if amount <= 0.0 {
                return Err("주문 금액이 유효하지 않습니다".to_string());
            }

            // Guard 3: 최대 금액
            if amount > 1_000_000.0 {
                return Err("주문 금액이 너무 큽니다".to_string());
            }

            // 핵심: 주문 생성
            Ok(format!("주문 생성: 고객 #{}, 금액 ${:.2}", customer_id, amount))
        }

        match process_order(123, 9999.99) {
            Ok(msg) => println!("  {}", msg),
            Err(e) => println!("  오류: {}", e),
        }
    }

    // 함수 2: 데이터 검증
    {
        println!("✓ 데이터 검증");
        fn validate_data(name: &str, email: &str, age: u32) -> Result<(), String> {
            // Guard 1: 이름
            if name.is_empty() || name.len() > 50 {
                return Err("이름이 유효하지 않습니다".to_string());
            }

            // Guard 2: 이메일
            if !email.contains('@') {
                return Err("이메일이 유효하지 않습니다".to_string());
            }

            // Guard 3: 나이
            if age < 18 || age > 120 {
                return Err("나이가 유효하지 않습니다".to_string());
            }

            Ok(())
        }

        match validate_data("Alice", "alice@example.com", 30) {
            Ok(_) => println!("  [OK] 모든 데이터가 유효합니다"),
            Err(e) => println!("  [ERROR] {}", e),
        }
    }

    println!();
}

// ============================================================================
// [7] 복잡한 가드 조합 (Complex Guard Combinations)
// ============================================================================
//
// 여러 가드의 조합으로 복잡한 검증
//
fn complex_guards() {
    println!("[7] 복잡한 가드 조합");
    println!("────────────────────────────────────────────────────────────");

    // 복잡 1: 시스템 시작
    {
        println!("✓ 복잡한 시스템 시작");
        fn start_system(
            power: bool,
            auth: u32,
            status: &str,
            memory: u64,
        ) -> Result<String, String> {
            // Guard 1: 전원
            if !power {
                return Err("전원이 꺼져 있습니다".to_string());
            }

            // Guard 2: 권한
            if auth < 5 {
                return Err("권한이 부족합니다".to_string());
            }

            // Guard 3: 상태
            if status != "STABLE" {
                return Err("시스템 상태가 불안정합니다".to_string());
            }

            // Guard 4: 메모리
            if memory < 512 {
                return Err("사용 가능한 메모리가 부족합니다".to_string());
            }

            // 핵심: 모든 가드 통과, 시스템 시작
            Ok("시스템이 정상적으로 시작되었습니다".to_string())
        }

        match start_system(true, 10, "STABLE", 1024) {
            Ok(msg) => println!("  ✓ {}", msg),
            Err(e) => println!("  ✗ {}", e),
        }
    }

    // 복잡 2: 다단계 검증
    {
        println!("✓ 다단계 검증");
        fn multi_stage_check(
            user_id: u32,
            action: &str,
            timestamp: u64,
        ) -> Result<String, String> {
            // Stage 1: 사용자 확인
            if user_id == 0 {
                return Err("사용자를 찾을 수 없습니다".to_string());
            }

            // Stage 2: 작업 확인
            if action.is_empty() {
                return Err("작업을 지정해야 합니다".to_string());
            }

            // Stage 3: 시간 확인
            if timestamp == 0 {
                return Err("타임스탬프가 유효하지 않습니다".to_string());
            }

            // 핵심: 모든 검증 통과
            Ok(format!(
                "사용자 {} - 작업: {} - 시간: {}",
                user_id, action, timestamp
            ))
        }

        match multi_stage_check(1, "READ", 1705929600) {
            Ok(msg) => println!("  {}", msg),
            Err(e) => println!("  오류: {}", e),
        }
    }

    println!();
}

// ============================================================================
// v3.6 핵심 학습 요소
// ============================================================================
//
// 1. Guard Clause 패턴
//    - 부적격 조건을 먼저 처리
//    - 조기 종료 (return, break, continue)
//    - 코드 깊이 감소
//
// 2. 피라미드 제거
//    - 들여쓰기 깊이 최소화
//    - 인지 부하 감소
//    - 버그 숨김 감소
//
// 3. 불변성 보장
//    - 함수 진입 = 모든 검증 완료
//    - 타입 안전성 강화
//    - 예측 가능한 실행
//
// 4. Early Return
//    - 실패 경로를 먼저 처리
//    - 핵심 로직을 최후에 배치
//    - 코드 흐름이 명확
//
// 5. 에러 처리
//    - 명확한 에러 메시지
//    - 모든 실패 경우 처리
//    - 디버깅 용이
//
// 6. 함수 설계
//    - Guard가 문지기 역할
//    - 핵심이 가시적
//    - 유지보수 간편
//
// ============================================================================

