#!/usr/bin/env python3
# -*- coding: utf-8 -*-

"""
🌐 학생관리 시스템 웹 서버 (Flask)

SQLite 데이터베이스를 웹 인터페이스로 제공
"""

from flask import Flask, render_template, request, jsonify, redirect, url_for
from student_management_system import StudentManagementSystem
import json
from datetime import datetime

app = Flask(__name__)
app.config['JSON_AS_ASCII'] = False

# 시스템 초기화
system = StudentManagementSystem()

# ==================== 라우트: 페이지 ====================

@app.route('/')
def index():
    """대시보드 홈페이지"""
    students = system.get_all_students()

    # 통계
    stats = {
        'total_students': len(students),
        'departments': 3,
        'courses': 5,
        'grades': 7
    }

    return render_template('index.html', stats=stats)


@app.route('/students')
def students():
    """학생 목록"""
    students_list = system.get_all_students()
    return render_template('students.html', students=students_list)


@app.route('/student/<int:student_id>')
def student_detail(student_id):
    """학생 상세 페이지"""
    student = system.get_student_detail(student_id)
    if not student:
        return "학생을 찾을 수 없습니다", 404

    grades = system.get_student_grades(student_id)
    attendance = system.get_student_attendance(student_id)
    gpa = system.get_student_gpa(student_id)

    return render_template(
        'student_detail.html',
        student=student[0],
        grades=grades,
        attendance=attendance,
        gpa=gpa
    )


@app.route('/grades')
def grades_page():
    """성적 조회"""
    # 모든 학생의 성적
    students_list = system.get_all_students()
    grades_data = []

    for student in students_list:
        grades = system.get_student_grades(student['student_id'])
        gpa = system.get_student_gpa(student['student_id'])
        grades_data.append({
            'student': student,
            'grades': grades,
            'gpa': gpa
        })

    return render_template('grades.html', grades_data=grades_data)


@app.route('/attendance')
def attendance_page():
    """출석 조회"""
    students_list = system.get_all_students()
    attendance_data = []

    for student in students_list:
        attendance = system.get_student_attendance(student['student_id'])
        attendance_data.append({
            'student': student,
            'records': attendance
        })

    return render_template('attendance.html', attendance_data=attendance_data)


@app.route('/statistics')
def statistics():
    """통계"""
    departments = [
        {'id': 1, 'name': '컴퓨터과학과'},
        {'id': 2, 'name': '데이터과학과'},
        {'id': 3, 'name': '소프트웨어공학과'}
    ]

    stats_data = []
    for dept in departments:
        stats = system.get_department_statistics(dept['id'])
        stats['dept_name'] = dept['name']
        stats_data.append(stats)

    return render_template('statistics.html', stats=stats_data)


@app.route('/add-student', methods=['GET', 'POST'])
def add_student():
    """학생 추가"""
    if request.method == 'POST':
        data = request.form
        result = system.add_student(
            student_no=data['student_no'],
            name=data['name'],
            dept_id=int(data['dept_id']),
            year=int(data['year']),
            email=data['email'],
            phone=data['phone']
        )

        if result['status'] == 'success':
            return redirect(url_for('students'))
        else:
            return render_template('add_student.html', error=result['message'])

    return render_template('add_student.html')


# ==================== API: JSON 엔드포인트 ====================

@app.route('/api/students')
def api_students():
    """API: 모든 학생"""
    students = system.get_all_students()
    return jsonify({'status': 'success', 'data': students})


@app.route('/api/student/<int:student_id>/grades')
def api_student_grades(student_id):
    """API: 학생 성적"""
    grades = system.get_student_grades(student_id)
    gpa = system.get_student_gpa(student_id)
    return jsonify({
        'status': 'success',
        'grades': grades,
        'gpa': gpa
    })


@app.route('/api/student/<int:student_id>/attendance')
def api_student_attendance(student_id):
    """API: 학생 출석"""
    attendance = system.get_student_attendance(student_id)
    return jsonify({'status': 'success', 'data': attendance})


@app.route('/api/statistics/<int:dept_id>')
def api_department_stats(dept_id):
    """API: 학과 통계"""
    stats = system.get_department_statistics(dept_id)
    return jsonify({'status': 'success', 'data': stats})


@app.route('/api/add-student', methods=['POST'])
def api_add_student():
    """API: 학생 추가"""
    data = request.get_json()
    result = system.add_student(
        student_no=data['student_no'],
        name=data['name'],
        dept_id=data['dept_id'],
        year=data['year'],
        email=data['email'],
        phone=data['phone']
    )
    return jsonify(result)


@app.route('/health')
def health():
    """헬스 체크"""
    return jsonify({'status': 'healthy', 'timestamp': datetime.now().isoformat()})


# ==================== 에러 핸들러 ====================

@app.errorhandler(404)
def not_found(error):
    """404 에러"""
    return render_template('404.html'), 404


@app.errorhandler(500)
def server_error(error):
    """500 에러"""
    return render_template('500.html'), 500


if __name__ == '__main__':
    print("\n" + "🌐 " * 20)
    print("학생관리 시스템 웹 서버 (Flask)")
    print("🌐 " * 20)
    print("\n🚀 서버 시작: http://localhost:5000\n")

    app.run(debug=True, host='0.0.0.0', port=5000)
