@measure_execution_time
def find_record_linear(records: List[int], target: int) -> int:
    """
    ✅ [v5.1 알고리즘 - 비교용] 선형 탐색 O(n)

    【 시간 복잡도 】
    - 최선: O(1) - 첫 번째 원소가 목표값
    - 평균: O(n/2)
    - 최악: O(n) - 마지막 원소 또는 없음

    【 공간 복잡도 】
    - O(1) - 추가 공간 사용 없음

    【 사용 시나리오 】
    - 작은 데이터셋 (n < 100)
    - 정렬되지 않은 데이터
    """
    for i, record in enumerate(records):
        if record == target:
            return i
    return -1


@measure_execution_time
def find_record_optimized(records: List[int], target: int) -> int:
    """
    ✅ [미구현 → 완성] 이진 탐색 O(log n)

    【 설계 과제 】
    records는 정렬되어 있다는 전제 조건 하에,
    O(n)이 아닌 O(log n)으로 작동하도록 이진 탐색을 구현하라.

    【 이진 탐색 알고리즘 】
    1. 정렬된 배열의 중간값과 비교
    2. target > mid: 오른쪽 절반 탐색
    3. target < mid: 왼쪽 절반 탐색
    4. target == mid: 찾음!

    【 시간 복잡도 분석 】
    - 1,000개: 선형 ~500번 비교 vs 이진 ~10번 비교 (50배)
    - 1,000,000개: 선형 ~500,000번 비교 vs 이진 ~20번 비교 (25,000배!)

    【 구현 전략 】
    low = 0, high = len(records) - 1
    while low <= high:
        mid = (low + high) // 2
        if records[mid] == target: return mid
        elif records[mid] < target: low = mid + 1
        else: high = mid - 1
    return -1
    """
    low = 0
    high = len(records) - 1
    comparisons = 0

    while low <= high:
        comparisons += 1
        mid = (low + high) // 2
        mid_value = records[mid]

        if mid_value == target:
            # 찾음!
            return mid
        elif mid_value < target:
            # 오른쪽 절반 탐색
            low = mid + 1
        else:
            # 왼쪽 절반 탐색
            high = mid - 1

    # 못 찾음
    return -1


