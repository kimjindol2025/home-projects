class GogsAnalyzer:
    """
    【 설계 목표 】
    - 비동기로 대량의 데이터를 수집
    - 손상된 데이터를 예외로 감지
    - 성공/실패 통계 수집

    【 구조 분석 】
    1. __init__: 상태 초기화 (registry, 통계)
    2. process_data: 개별 데이터 처리 (비동기)
    3. batch_process: 대량 데이터 동시 처리 (asyncio.gather)
    """

    def __init__(self):
        """
        설계자 분석:
        - registry: 성공한 데이터 ID 저장
        - errors: 발생한 예외 기록
        - timings: 개별 작업의 실행 시간
        """
        self.registry = []
        self.errors = []
        self.timings = []
        self.total_processed = 0

    async def process_data(self, data_id: int) -> bool:
        """
        ✅ [v4.1 비동기] 개별 데이터 처리

        【 로직 분석 】
        1. await asyncio.sleep(0.01): I/O 시뮬레이션
        2. data_id % 7 == 0: 특정 조건에서 오류 발생
        3. try-except: 예외 처리로 시스템 안정성 확보
        4. return: 성공/실패 여부 반환

        【 설계의 의도 】
        - 비동기 작업 중 일부가 실패해도 전체 시스템 계속 진행
        - 실패한 작업만 기록하고 다른 작업 진행
        - 분산 시스템에서의 부분 장애 대응 패턴
        """
        start = time.time()
        try:
            # I/O 작업 시뮬레이션 (실제: 네트워크, 파일 I/O)
            await asyncio.sleep(0.01)

            # 특정 조건에서 데이터 오염 시뮬레이션
            if data_id % 7 == 0:
                raise DataCorruptionError(f"Node-{data_id} 데이터 오염 감지")

            # 성공 시 registry에 추가
            self.registry.append(data_id)
            elapsed = time.time() - start
            self.timings.append(elapsed)
            return True

        except DataCorruptionError as e:
            # 예외 기록 (시스템 중단 아님)
            self.errors.append({
                "data_id": data_id,
                "error": str(e),
                "timestamp": time.time()
            })
            return False

    async def batch_process(self, count: int) -> dict:
        """
        ✅ [v4.1 비동기 - asyncio.gather] 대량 데이터 동시 처리

        【 설계 분석 】
        1. [self.process_data(i) for i in range(count)]: 태스크 생성
        2. asyncio.gather(*tasks): 모든 태스크를 동시에 실행
        3. 결과 수집 및 통계 계산

        【 성능 특성 】
        - 순차 처리: N * 0.01초 (N개 데이터)
        - 동시 처리: ~0.1초 (최대 동시 작업 수에 따라 달라짐)
        - 성능 향상: ~100배!
        """
        self.total_processed = count
        tasks = [self.process_data(i) for i in range(count)]
        results = await asyncio.gather(*tasks)

        success_count = results.count(True)
        failure_count = results.count(False)

        return {
            "total": count,
            "success": success_count,
            "failure": failure_count,
            "success_rate": (success_count / count * 100) if count > 0 else 0,
            "avg_time": statistics.mean(self.timings) if self.timings else 0,
            "total_time": sum(self.timings)
        }


