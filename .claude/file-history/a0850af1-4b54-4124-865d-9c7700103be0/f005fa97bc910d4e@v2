# 【 점검 대상 2 】 성능 측정 데코레이터 (v3.1 메타프로그래밍)
# ================================================================================

def measure_execution_time(func: Callable) -> Callable:
    """
    ✅ [미구현 → 완성] 실행 시간을 측정하는 데코레이터

    【 설계 분석 】
    1. 함수의 시작/종료 시간 기록
    2. 실행 시간을 계산하고 출력
    3. 원본 함수의 반환값을 유지

    【 v3.1 메타프로그래밍 적용 】
    - 함수의 실행을 투명하게 관찰
    - 원본 로직 수정 없이 기능 추가
    - @wraps로 메타데이터 보존
    """
    @wraps(func)
    def wrapper(*args, **kwargs):
        start_time = time.time()
        result = func(*args, **kwargs)
        end_time = time.time()
        elapsed = (end_time - start_time) * 1000  # 밀리초로 변환
        print(f"  ⏱️  {func.__name__}: {elapsed:.4f}ms")
        return result

    @wraps(func)
    async def async_wrapper(*args, **kwargs):
        start_time = time.time()
        result = await func(*args, **kwargs)
        end_time = time.time()
        elapsed = (end_time - start_time) * 1000  # 밀리초로 변환
        # 비동기 함수는 상세 로깅을 피함
        return result

    # 비동기 함수 판별
    if asyncio.iscoroutinefunction(func):
        return async_wrapper
    else:
        return wrapper


