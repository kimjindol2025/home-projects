class DataCorruptionError(Exception):
    """
    데이터가 손상되었을 때 발생하는 커스텀 예외

    설계 분석:
      - 예외 상속: 사용자 정의 예외의 정석적 설계
      - 메시지 전달: 오류의 원인을 명확히 기록
      - 복구 가능성: 시스템 중단 없이 로깅 후 계속 진행
    """
    pass


class InvalidAlgorithmError(Exception):
    """알고리즘 검증 실패 시 발생하는 예외"""
