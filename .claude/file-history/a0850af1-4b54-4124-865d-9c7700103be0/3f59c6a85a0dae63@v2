// ============================================================================
// [1] 구조체 정의 기초 (Struct Definition Basics)
// ============================================================================
//
// 구조체의 정의: 데이터의 설계도 작성
//
fn struct_definition_basics() {
    println!("[1] 구조체 정의: 데이터의 설계도");
    println!("────────────────────────────────────────────────────────────");

    // [구조체 정의 1: 사용자]
    struct User {
        id: u64,
        name: String,
        email: String,
        age: u8,
        is_active: bool,
    }

    // [구조체 정의 2: 블로그 글]
    struct BlogPost {
        id: u64,
        title: String,
        content: String,
        author: String,
        published: bool,
    }

    // [구조체 정의 3: 서버 설정]
    struct ServerConfig {
        hostname: String,
        port: u16,
        is_running: bool,
        max_connections: u32,
    }

    println!("✓ 구조체 정의 완료");
    println!("  struct User {{ id, name, email, age, is_active }}");
    println!("  struct BlogPost {{ id, title, content, author, published }}");
    println!("  struct ServerConfig {{ hostname, port, is_running, max_connections }}");

    println!();
    println!("✓ 특징:");
    println!("  - struct 키워드로 새로운 타입 정의");
    println!("  - 각 필드는 타입을 명시해야 함");
    println!("  - 메모리에 순차적으로 배치됨");
    println!();
}

// ============================================================================
// [2] 구조체 인스턴스 생성 (Instantiation)
// ============================================================================
//
// 설계도를 바탕으로 실제 데이터 객체 생성
//
fn struct_instantiation() {
    println!("[2] 인스턴스 생성: 설계도를 현실로");
    println!("────────────────────────────────────────────────────────────");

    struct User {
        id: u64,
        name: String,
        email: String,
        age: u8,
        is_active: bool,
    }

    println!("✓ 인스턴스 1: 기본 초기화");
    let user1 = User {
        id: 1001,
        name: String::from("Alice"),
        email: String::from("alice@example.com"),
        age: 28,
        is_active: true,
    };
    println!("  id: {}, name: {}, age: {}", user1.id, user1.name, user1.age);

    println!();
    println!("✓ 인스턴스 2: 간략한 초기화 (shorthand)");
    let id = 1002;
    let name = String::from("Bob");
    let email = String::from("bob@example.com");
    let age = 35;
    let is_active = true;

    let user2 = User {
        id,
        name,
        email,
        age,
        is_active,
    };
    println!("  id: {}, name: {}, age: {}", user2.id, user2.name, user2.age);

    println!();
    println!("✓ 특징:");
    println!("  - 모든 필드를 명시적으로 초기화해야 함");
    println!("  - 필드 이름과 값을 명시");
    println!("  - 초기화 순서는 정의 순서와 무관");
    println!();
}

// ============================================================================
// [3] 필드 접근과 수정 (Field Access and Modification)
// ============================================================================
//
// 점(.) 표기법으로 필드에 접근하고 수정
//
fn field_access_and_modification() {
    println!("[3] 필드 접근: 점(.) 표기법");
    println!("────────────────────────────────────────────────────────────");

    struct Product {
        id: u64,
        name: String,
        price: f64,
        in_stock: bool,
    }

    let product = Product {
        id: 2001,
        name: String::from("Laptop"),
        price: 1299.99,
        in_stock: true,
    };

    println!("✓ 필드 읽기");
    println!("  상품명: {}", product.name);
    println!("  가격: ${:.2}", product.price);
    println!("  재고: {}", if product.in_stock { "있음" } else { "없음" });

    println!();
    println!("✓ 필드 정보 활용");
    if product.price > 1000.0 {
        println!("  분류: 고가 상품");
    }

    if product.in_stock {
        println!("  상태: 주문 가능");
    }

    println!();
    println!("✓ Debug 트레이트로 전체 출력");
    println!("  {:?}", product);

    println!();
    println!("✓ 특징:");
    println!("  - 점(.) 표기법으로 필드 접근");
    println!("  - 타입 안전성 보장");
    println!("  - 명확한 필드 이름");
    println!();
}

// ============================================================================
// [4] 구조체 가변성 (Struct Mutability)
// ============================================================================
//
// mut 키워드로 구조체 필드 수정 가능
//
fn struct_mutability() {
    println!("[4] 가변성: mut으로 필드 수정");
    println!("────────────────────────────────────────────────────────────");

    struct Account {
        account_number: String,
        owner: String,
        balance: f64,
        is_frozen: bool,
    }

    println!("✓ 불변 구조체: 읽기만 가능");
    let account = Account {
        account_number: String::from("ACC001"),
        owner: String::from("Alice"),
        balance: 5000.0,
        is_frozen: false,
    };
    println!("  계좌: {}, 잔액: ${}", account.owner, account.balance);
    // account.balance = 6000.0;  // ❌ 컴파일 에러

    println!();
    println!("✓ 가변 구조체: 필드 수정 가능");
    let mut account2 = Account {
        account_number: String::from("ACC002"),
        owner: String::from("Bob"),
        balance: 3000.0,
        is_frozen: false,
    };

    println!("  초기 잔액: ${}", account2.balance);
    account2.balance = 3500.0;
    println!("  입금 후: ${}", account2.balance);

    account2.is_frozen = true;
    println!("  계좌 상태: {}", if account2.is_frozen { "동결" } else { "활성" });

    println!();
    println!("✓ 규칙:");
    println!("  - 구조체가 mut이면 모든 필드 수정 가능");
    println!("  - 구조체가 불변이면 모든 필드 읽기만 가능");
    println!("  - 선택적 가변성 불가능 (모든 필드가 함께)");
    println!();
}

// ============================================================================
// [5] 소유권 (Ownership in Structs)
// ============================================================================
//
// 구조체 내부의 String 필드와 소유권
//
fn ownership_in_structs() {
    println!("[5] 소유권: 구조체가 데이터 소유");
    println!("────────────────────────────────────────────────────────────");

    struct Document {
        title: String,
        content: String,
        author: String,
    }

    println!("✓ 소유권 이전");
    let doc = Document {
        title: String::from("Report 2026"),
        content: String::from("This is a comprehensive report..."),
        author: String::from("Alice"),
    };

    println!("  제목: {}", doc.title);
    println!("  저자: {}", doc.author);

    // doc이 스코프를 벗어나면 String들도 함께 해제됨
    println!("  문서가 스코프를 벗어나면 모든 String도 자동 해제");

    println!();
    println!("✓ 소유권 추적");
    {
        let _doc2 = Document {
            title: String::from("Report 2027"),
            content: String::from("..."),
            author: String::from("Bob"),
        };
        println!("  _doc2 스코프 내부");
    }  // _doc2가 소멸, String들도 해제됨
    println!("  _doc2 스코프 외부: 메모리 해제됨");

    println!();
    println!("✓ 중요한 점:");
    println!("  - 구조체가 String을 소유");
    println!("  - 구조체가 사라지면 String도 사라짐");
    println!("  - 메모리 자동 관리의 이점");
    println!();
}

// ============================================================================
// [6] 구조체 분해 (Destructuring)
// ============================================================================
//
// 구조체를 개별 변수로 분해
//
fn struct_destructuring() {
    println!("[6] 분해: 구조체를 변수로");
    println!("────────────────────────────────────────────────────────────");

    struct Point {
        x: i32,
        y: i32,
    }

    struct Color {
        red: u8,
        green: u8,
        blue: u8,
    }

    let point = Point { x: 10, y: 20 };

    println!("✓ 완전한 분해");
    let Point { x, y } = point;
    println!("  x: {}, y: {}", x, y);

    println!();
    println!("✓ 부분 분해");
    let Point { x, .. } = point;
    println!("  x만 추출: {}", x);

    println!();
    println!("✓ 새로운 이름으로 분해");
    let Point { x: px, y: py } = point;
    println!("  px: {}, py: {}", px, py);

    println!();
    println!("✓ 중첩된 분해");
    let color = Color { red: 255, green: 128, blue: 64 };
    let Color { red, green, blue } = color;
    println!("  RGB: ({}, {}, {})", red, green, blue);

    println!();
    println!("✓ 특징:");
    println!("  - 전체 또는 부분 분해 가능");
    println!("  - 패턴 매칭의 기초");
    println!("  - 여러 변수를 한 줄에 추출");
    println!();
}

// ============================================================================
// [7] 실무 패턴: 도메인 모델링 (Domain Modeling)
// ============================================================================
//
// 현실의 개념을 구조체로 정확히 옮기기
//
fn named_structs_patterns() {
    println!("[7] 도메인 모델링: 현실을 코드로");
    println!("────────────────────────────────────────────────────────────");

    // 패턴 1: 사용자 관리
    struct User {
        id: u64,
        username: String,
        email: String,
        created_at: String,
        is_premium: bool,
    }

    // 패턴 2: 상품 카탈로그
    struct Product {
        id: u64,
        name: String,
        price: f64,
        in_stock: bool,
        rating: f32,
    }

    // 패턴 3: 서버 상태
    struct ServerStatus {
        hostname: String,
        cpu_usage: f32,
        memory_usage: f32,
        uptime_days: u32,
        is_healthy: bool,
    }

    println!("✓ 패턴 1: 사용자");
    let user = User {
        id: 1001,
        username: String::from("alice_wonder"),
        email: String::from("alice@example.com"),
        created_at: String::from("2024-01-15"),
        is_premium: true,
    };
    println!("  사용자: {} ({} 구독)", user.username,
        if user.is_premium { "프리미엄" } else { "일반" });

    println!();
    println!("✓ 패턴 2: 상품");
    let product = Product {
        id: 5001,
        name: String::from("Wireless Headphones"),
        price: 149.99,
        in_stock: true,
        rating: 4.5,
    };
    println!("  상품: {} (${:.2}, 평점: {:.1})", product.name, product.price, product.rating);

    println!();
    println!("✓ 패턴 3: 서버");
    let server = ServerStatus {
        hostname: String::from("api.example.com"),
        cpu_usage: 45.2,
        memory_usage: 62.8,
        uptime_days: 127,
        is_healthy: true,
    };
    println!("  서버: {} (CPU: {:.1}%, 메모리: {:.1}%)",
        server.hostname, server.cpu_usage, server.memory_usage);

    println!();
    println!("✓ 설계 원칙:");
    println!("  - 현실의 개념을 정확히 반영");
    println!("  - 필요한 속성만 포함");
    println!("  - 의도가 드러나는 이름 사용");
    println!();
}

// ============================================================================
// [8] 구조체 설계 최선의 관행 (Best Practices)
// ============================================================================
//
// 실무에서의 구조체 설계 원칙
//
fn struct_best_practices() {
    println!("[8] 설계 최선의 관행");
    println!("────────────────────────────────────────────────────────────");

    // 최선의 관행 1: 필드 최소화
    struct GoodUser {
        id: u64,
        name: String,
        email: String,
        is_active: bool,
    }

    // 최선의 관행 2: 의도가 드러나는 이름
    struct GoodConfig {
        hostname: String,
        port: u16,
        is_ssl_enabled: bool,
        max_retries: u32,
    }

    // 최선의 관행 3: 소유권 신중히
    struct GoodRecord {
        id: u64,
        title: String,
        timestamp: String,
        is_verified: bool,
    }

    println!("✓ 황금률 1: 필드 최소화");
    println!("  이상적 필드 수: 5~9개");
    println!("  기준: 꼭 필요한 데이터만 포함");

    println!();
    println!("✓ 황금률 2: 이름의 구체성");
    println!("  ❌ data, val, info, result");
    println!("  ✅ username, email, is_active");

    println!();
    println!("✓ 황금률 3: 소유권 주의");
    println!("  String 필드: 구조체가 소유");
    println!("  구조체 소멸 = 데이터 소멸");
    println!("  라이프타임 고려 필요 (v5.x에서 다룸)");

    println!();
    let user = GoodUser {
        id: 1001,
        name: String::from("Alice"),
        email: String::from("alice@example.com"),
        is_active: true,
    };

    println!("✓ 완성된 구조체 예시:");
    println!("  ID: {}", user.id);
    println!("  이름: {}", user.name);
    println!("  활성: {}", user.is_active);

    println!();
    println!("✓ 메모리 효율:");
    use std::mem::size_of;
    println!("  GoodUser 크기: {} bytes", size_of::<GoodUser>());
    println!("  (시스템마다 다를 수 있음)");
    println!();
}

