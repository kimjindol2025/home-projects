{% extends "base.html" %}

{% block title %}{{ student.name }} - 학생관리 시스템{% endblock %}

{% block content %}
<div class="student-detail-page">
    <h1 class="page-title">📋 학생 상세 정보</h1>

    <div class="detail-container">
        <!-- 기본 정보 -->
        <div class="info-section">
            <h2>👤 기본 정보</h2>
            <div class="info-grid">
                <div class="info-item">
                    <label>학번</label>
                    <p>{{ student.student_no }}</p>
                </div>
                <div class="info-item">
                    <label>이름</label>
                    <p><strong>{{ student.name }}</strong></p>
                </div>
                <div class="info-item">
                    <label>학과</label>
                    <p>{{ student.dept_name }}</p>
                </div>
                <div class="info-item">
                    <label>학년</label>
                    <p>{{ student.year }}학년</p>
                </div>
                <div class="info-item">
                    <label>이메일</label>
                    <p>{{ student.email }}</p>
                </div>
                <div class="info-item">
                    <label>연락처</label>
                    <p>{{ student.phone }}</p>
                </div>
                <div class="info-item">
                    <label>입학일</label>
                    <p>{{ student.enrollment_date }}</p>
                </div>
            </div>
        </div>

        <!-- 성적 정보 -->
        <div class="info-section">
            <h2>📊 성적 정보</h2>
            {% if gpa %}
            <div class="gpa-display">
                <div class="gpa-card">
                    <p class="gpa-label">평점 (GPA)</p>
                    <p class="gpa-value">{{ gpa.gpa }}</p>
                    <p class="gpa-meta">{{ gpa.courses_taken }}개 과목</p>
                </div>
            </div>
            {% endif %}

            {% if grades %}
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>학기</th>
                            <th>과목명</th>
                            <th>학점</th>
                            <th>점수</th>
                            <th>등급</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for grade in grades %}
                        <tr>
                            <td>{{ grade.semester }}</td>
                            <td>{{ grade.course_name }}</td>
                            <td>{{ grade.credit }}</td>
                            <td class="score-cell">{{ grade.score|round(1) }}</td>
                            <td>
                                <span class="grade-badge grade-{{ grade.grade }}">{{ grade.grade }}</span>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% else %}
            <p class="empty-message">등록된 성적이 없습니다.</p>
            {% endif %}
        </div>

        <!-- 출석 정보 -->
        <div class="info-section">
            <h2>✅ 출석 현황</h2>
            {% if attendance %}
            <div class="attendance-stats">
                {% set total = attendance|length %}
                {% set present = attendance|selectattr('status', 'equalto', '출석')|list|length %}
                {% set late = attendance|selectattr('status', 'equalto', '지각')|list|length %}
                {% set absent = attendance|selectattr('status', 'equalto', '결석')|list|length %}

                <div class="attendance-card">
                    <p class="att-label">✅ 출석</p>
                    <p class="att-value">{{ present }}회</p>
                </div>
                <div class="attendance-card">
                    <p class="att-label">⏰ 지각</p>
                    <p class="att-value">{{ late }}회</p>
                </div>
                <div class="attendance-card">
                    <p class="att-label">❌ 결석</p>
                    <p class="att-value">{{ absent }}회</p>
                </div>
                <div class="attendance-card">
                    <p class="att-label">📊 합계</p>
                    <p class="att-value">{{ total }}회</p>
                </div>
            </div>

            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>날짜</th>
                            <th>과목</th>
                            <th>상태</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for att in attendance %}
                        <tr>
                            <td>{{ att.date }}</td>
                            <td>{{ att.course_name }}</td>
                            <td>
                                {% if att.status == '출석' %}
                                <span class="status-badge status-present">✅ {{ att.status }}</span>
                                {% elif att.status == '지각' %}
                                <span class="status-badge status-late">⏰ {{ att.status }}</span>
                                {% else %}
                                <span class="status-badge status-absent">❌ {{ att.status }}</span>
                                {% endif %}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% else %}
            <p class="empty-message">등록된 출석 기록이 없습니다.</p>
            {% endif %}
        </div>
    </div>

    <!-- 버튼 -->
    <div class="button-group">
        <a href="/students" class="btn btn-secondary">← 돌아가기</a>
        <a href="/grades" class="btn btn-info">전체 성적 보기</a>
    </div>
</div>
{% endblock %}
