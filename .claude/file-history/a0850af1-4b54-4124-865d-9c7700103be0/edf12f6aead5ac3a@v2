print("  # 작업들이 동시에 진행되며, CPU는 대기 시간을 다른 일에 사용")
print("  results = await asyncio.gather(")
print("      task_1(),  # 2초 시작")
print("      task_2(),  # 2초 시작")
print("      task_3()   # 2초 시작")
print("  )")
print("  # 총 2초만 소요! (가장 긴 작업 기준)")
print()

# 비동기 방식 시뮬레이션
async def async_demo():
    """비동기 방식으로 작업"""

    async def task(num):
        await asyncio.sleep(1)
        print(f"  [비동기] 작업{num} 완료")

    start = time.perf_counter()
    await asyncio.gather(task(1), task(2), task(3))
    elapsed = time.perf_counter() - start
    return elapsed

print("✓ 비동기 방식 실제 실행:")
elapsed_async = asyncio.run(async_demo())
print(f"  소요 시간: {elapsed_async:.2f}초")
print()

