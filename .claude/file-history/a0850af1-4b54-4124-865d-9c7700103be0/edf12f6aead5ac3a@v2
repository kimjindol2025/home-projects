# 예제: sleep의 차이
async def sleep_comparison():
    """asyncio.sleep()의 효과"""
    print("✓ 비동기 sleep 효과:")
    print()

    async def worker(num, delay):
        print(f"  [W{num}] 시작 (대기 {delay}초)")
        await asyncio.sleep(delay)
        print(f"  [W{num}] 완료")

    start = time.perf_counter()
    await asyncio.gather(
        worker(1, 1),
        worker(2, 2),
        worker(3, 0.5)
    )
    elapsed = time.perf_counter() - start
    print(f"  전체 소요: {elapsed:.2f}초 (2초가 아니라 가장 긴 작업 기준)")


asyncio.run(sleep_comparison())
print()

