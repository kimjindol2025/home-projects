# 패턴 2: 프로듀서-컨슈머
async def producer_consumer_demo():
    """비동기 프로듀서-컨슈머 패턴"""
    print("✓ 프로듀서-컨슈머 패턴:")
    print()

    queue = asyncio.Queue()

    async def producer():
        for i in range(3):
            await asyncio.sleep(0.1)
            await queue.put(f"Item {i}")
            print(f"  📤 생성: Item {i}")

    async def consumer():
        while True:
            item = await queue.get()
            print(f"  📥 소비: {item}")
            queue.task_done()
            if item == "Item 2":
                break

    # 프로듀서와 컨슈머 동시 실행
    await asyncio.gather(producer(), consumer())

    print()


asyncio.run(producer_consumer_demo())

# 패턴 3: 재시도 로직
async def retry_demo():
    """실패 시 재시도하는 비동기 작업"""
    print("✓ 재시도 로직:")
    print()

    async def unreliable_request():
        await asyncio.sleep(0.1)
        if random.random() < 0.5:
            raise ConnectionError("네트워크 오류")
        return "성공"

    async def request_with_retry(max_retries=3):
        for attempt in range(max_retries):
            try:
                result = await unreliable_request()
                print(f"  ✅ 성공: {result}")
                return result
            except ConnectionError as e:
                print(f"  ⚠️ 시도 {attempt+1} 실패: {e}")
                if attempt < max_retries - 1:
                    await asyncio.sleep(0.1)

    await request_with_retry()
    print()


asyncio.run(retry_demo())

print("💡 결론: 비동기 패턴으로 복잡한 시스템을 우아하게 설계합니다!\n")


