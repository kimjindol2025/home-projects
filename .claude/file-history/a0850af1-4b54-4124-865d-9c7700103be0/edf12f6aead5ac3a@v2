# 동기 방식 시뮬레이션
def sync_demo():
    """동기 방식으로 작업"""
    start = time.perf_counter()

    # 작업 시뮬레이션
    for i in range(3):
        time.sleep(1)  # 1초씩 대기
        print(f"  [동기] 작업{i+1} 완료")

    elapsed = time.perf_counter() - start
    return elapsed

