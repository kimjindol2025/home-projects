# 예제 1: 타임아웃
async def timeout_demo():
    """asyncio.wait_for()로 타임아웃 설정"""
    print("✓ 타임아웃 처리:")
    print()

    async def slow_task():
        await asyncio.sleep(5)
        return "완료"

    try:
        # 3초 안에 완료되지 않으면 timeout
        result = await asyncio.wait_for(slow_task(), timeout=3)
        print(f"  결과: {result}")
    except asyncio.TimeoutError:
        print(f"  ⏱️ 타임아웃: 작업이 3초를 초과했습니다")

    print()


asyncio.run(timeout_demo())

# 예제 2: 예외 처리
async def exception_demo():
    """비동기 작업에서의 예외 처리"""
    print("✓ 예외 처리:")
    print()

    async def risky_task(num):
        await asyncio.sleep(0.2)
        if num == 2:
            raise ValueError(f"작업 {num}에서 오류 발생!")
        return f"작업 {num} 성공"

    try:
        results = await asyncio.gather(
            risky_task(1),
            risky_task(2),
            risky_task(3),
            return_exceptions=True  # 예외를 반환값으로 처리
        )
        for result in results:
            if isinstance(result, Exception):
                print(f"  ❌ {result}")
            else:
                print(f"  ✅ {result}")
    except Exception as e:
        print(f"  예외: {e}")

    print()


asyncio.run(exception_demo())

print("💡 결론: 타임아웃과 예외 처리로 안전한 비동기 코드를 작성합니다!\n")


