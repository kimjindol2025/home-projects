        print(f"  {check}")
    print()

# 프로덕션급 비동기 엔진
async def production_async_engine():
    """프로덕션 환경에서 사용할 수 있는 비동기 엔진"""
    print("✓ 프로덕션급 비동기 엔진:")
    print()

    class DataCollector:
        def __init__(self, num_nodes):
            self.num_nodes = num_nodes
            self.results = {}
            self.start_time = time.perf_counter()

        async def collect_from_node(self, node_id):
            """노드에서 데이터 수집"""
            try:
                delay = random.uniform(0.1, 0.5)
                await asyncio.sleep(delay)
                return f"Data from Node-{node_id}"
            except Exception as e:
                return f"Error in Node-{node_id}: {e}"

        async def run(self):
            """모든 노드에서 데이터 수집"""
            print(f"  🚀 {self.num_nodes}개 노드에서 데이터 수집 시작")

            tasks = [self.collect_from_node(i) for i in range(self.num_nodes)]
            results = await asyncio.gather(*tasks)

            elapsed = time.perf_counter() - self.start_time
            print(f"  ✅ 수집 완료 ({elapsed:.2f}초)")
            return results

    # 엔진 실행
    collector = DataCollector(num_nodes=10)
    results = await collector.run()
    print(f"  수집된 데이터: {len(results)}개")
    print()


asyncio.run(production_async_engine())

