// std::thread를 통한 병렬 실행 구현

use std::thread;
use std::time::{Duration, Instant};

// ============================================================================
// [v10.0: 기본 개념] 스레드의 기초
// ============================================================================

/// 기본 스레드 생성 및 실행
fn demo_basic_thread() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║          [Demo 1] 기본 스레드: spawn과 join                ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    // [1] 스레드 생성
    println!("[1] 스레드 생성 (spawn):");
    let handle = thread::spawn(|| {
        for i in 1..5 {
            println!("    [서브 스레드] 단계 {}/4", i);
            thread::sleep(Duration::from_millis(200));
        }
    });

    // [2] 메인 스레드도 동시에 작업
    println!("\n[2] 메인 스레드 작업 (동시 실행):");
    for i in 1..3 {
        println!("    [메인 스레드] 실시간 감시 {}/2", i);
        thread::sleep(Duration::from_millis(300));
    }

    // [3] 스레드 완료 대기
    println!("\n[3] 스레드 완료 대기 (join):");
    handle.join().unwrap();
    println!("    ✅ 모든 작업 완료!\n");
}

// ============================================================================
// [v10.0: 핵심 패턴 1] Move 클로저로 데이터 이동
