/// 각 스레드가 독립적인 데이터를 가짐
fn demo_thread_data_isolation() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║   [Demo 4] 데이터 격리: 데이터 경합 방지               ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    // [1] 각 스레드가 자신만의 데이터 소유
    println!("[1] 각 스레드의 독립적인 데이터:");
    let mut handles = vec![];

    for id in 1..=3 {
        let handle = thread::spawn(move || {
            // 각 스레드가 자신만의 local_data를 가짐
            let mut local_data = id * 100;
            println!("    [스레드 {}] 초기 데이터: {}", id, local_data);

            // 자신의 데이터를 수정 (다른 스레드에 영향 없음)
            local_data += 50;
            println!("    [스레드 {}] 수정 후: {}", id, local_data);

            local_data
        });
        handles.push(handle);
    }

    // [2] 결과 수집
    println!("\n[2] 각 스레드의 최종 결과:");
    for (i, handle) in handles.into_iter().enumerate() {
        let result = handle.join().unwrap();
        println!("    [스레드 {}] 최종값: {}", i + 1, result);
    }

    println!("\n    ✅ 각 스레드가 독립적인 데이터를 처리 → 데이터 경합 없음\n");
}

