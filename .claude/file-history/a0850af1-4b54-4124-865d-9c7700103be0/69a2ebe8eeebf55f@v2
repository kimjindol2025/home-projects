/// Move 클로저를 사용한 데이터 이동
fn demo_thread_with_move() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║        [Demo 2] Move 클로저: 데이터를 스레드로 이동        ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    // [1] Move 클로저로 벡터 이동
    println!("[1] 벡터를 스레드로 이동:");
    let data = vec![1, 2, 3, 4, 5];
    println!("    메인: data = {:?}", data);

    let handle = thread::spawn(move || {
        // move로 인해 data의 소유권이 이 클로저로 이동됨
        let sum: i32 = data.iter().sum();
        println!("    [스레드] data = {:?}", data);
        println!("    [스레드] 합계 = {}", sum);
        sum
    });

    // [2] 스레드 실행
    println!("\n[2] 스레드 실행:");
    let result = handle.join().unwrap();
    println!("    [메인] 스레드로부터 받은 결과: {}", result);
    // println!("    data = {:?}");  // ❌ 에러: data는 스레드로 이동됨

    println!("    ✅ data의 소유권이 완벽하게 이동되어 데이터 경합 없음\n");
}

