// [v10.0: 핵심 패턴 4] 병렬 보안 분석 엔진
// ============================================================================

struct SecurityWorker {
    worker_id: usize,
}

impl SecurityWorker {
    fn new(id: usize) -> Self {
        Self { worker_id: id }
    }

    /// 보안 검사를 수행합니다
    fn run_security_checks(&self, num_checks: u32) -> String {
        for check in 1..=num_checks {
            println!("    [워커 {}] 보안 검사 {}/{} 중...",
                self.worker_id, check, num_checks);
            thread::sleep(Duration::from_millis(150));
        }

        format!("워커 {} 완료: {} 검사 실행",
            self.worker_id, num_checks)
    }
}

fn demo_parallel_security_analysis() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║  [Demo 5] 병렬 보안 분석: 실전 시뮬레이션                ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    // [1] 병렬 분석 시작
    println!("[1] 3개의 워커로 병렬 분석 시작:");
    let mut handles = vec![];

    for i in 1..=3 {
        let handle = thread::spawn(move || {
            let worker = SecurityWorker::new(i);
            worker.run_security_checks(3)
        });
        handles.push(handle);
    }

    // [2] 메인 스레드도 동시 작업
    println!("\n[2] 메인 스레드: 실시간 로그 감시");
    for i in 1..=2 {
        println!("    [메인] 로그 수집 {}/2", i);
        thread::sleep(Duration::from_millis(200));
    }

    // [3] 모든 워커 완료 대기
    println!("\n[3] 워커 완료 대기:");
    for handle in handles {
        let result = handle.join().unwrap();
        println!("    {}", result);
    }

    println!("    ✅ 병렬 보안 분석 완료\n");
}

// ============================================================================
// [v10.0: 고급 패턴] 성능 비교 (직렬 vs 병렬)
// ============================================================================

/// CPU 집약적인 작업 시뮬레이션
fn cpu_intensive_work(n: u32) -> u32 {
    let mut sum = 0u32;
    for i in 0..n {
        sum = sum.wrapping_add(i);
    }
    sum
}

fn demo_thread_performance() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║  [Demo 6] 성능 비교: 직렬 처리 vs 병렬 처리            ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    const WORK_SIZE: u32 = 100_000_000;

    // [1] 직렬 처리 (순차)
    println!("[1] 직렬 처리 (1개 스레드):");
    let start = Instant::now();
    let result1 = cpu_intensive_work(WORK_SIZE);
    let result2 = cpu_intensive_work(WORK_SIZE);
    let serial_duration = start.elapsed();
    println!("    결과: {}, {}", result1, result2);
    println!("    소요 시간: {}ms\n", serial_duration.as_millis());

    // [2] 병렬 처리
    println!("[2] 병렬 처리 (2개 스레드):");
    let start = Instant::now();
    let handle1 = thread::spawn(|| cpu_intensive_work(WORK_SIZE));
    let handle2 = thread::spawn(|| cpu_intensive_work(WORK_SIZE));
    let result1 = handle1.join().unwrap();
    let result2 = handle2.join().unwrap();
    let parallel_duration = start.elapsed();
    println!("    결과: {}, {}", result1, result2);
    println!("    소요 시간: {}ms\n", parallel_duration.as_millis());

    // [3] 성능 분석
    println!("[3] 성능 분석:");
    let speedup = serial_duration.as_millis() as f64
        / parallel_duration.as_millis() as f64;
    println!("    직렬 대비: {:.2}배 빨라짐", speedup);
    if speedup > 1.5 {
        println!("    ✅ 병렬 처리의 성능 이점 확인!");
    } else {
        println!("    (멀티코어 환경에서 더 큰 이득)");
    }
    println!();
}

