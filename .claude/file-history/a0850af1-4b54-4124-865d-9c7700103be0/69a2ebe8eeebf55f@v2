/// 여러 스레드를 생성하고 완료를 기다림
fn demo_join_handles() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║      [Demo 3] 여러 스레드 관리: 병렬 처리 조율            ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    // [1] 여러 스레드 생성
    println!("[1] 3개의 스레드 생성:");
    let mut handles = vec![];

    for i in 1..=3 {
        let handle = thread::spawn(move || {
            for step in 1..=3 {
                println!("    [스레드 {}] 단계 {}/3", i, step);
                thread::sleep(Duration::from_millis(100 * i as u64));
            }
            i * 10  // 스레드에서 결과 반환
        });
        handles.push(handle);
    }

    // [2] 모든 스레드 완료 대기
    println!("\n[2] 모든 스레드 완료 대기:");
    let mut results = vec![];
    for (i, handle) in handles.into_iter().enumerate() {
        let result = handle.join().unwrap();
        results.push(result);
        println!("    [메인] 스레드 {} 완료, 결과: {}", i + 1, result);
    }

    println!("\n[3] 수집된 결과:");
    println!("    결과들: {:?}", results);
    println!("    ✅ 모든 스레드의 결과 수집 완료\n");
}

