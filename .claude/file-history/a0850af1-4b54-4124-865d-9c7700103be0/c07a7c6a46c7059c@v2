/// 메시지를 전송하는 트레이트
pub trait Messenger {
    fn send(&self, msg: &str);
}

/// 실제 메신저 (이메일 전송)
struct EmailMessenger;

impl Messenger for EmailMessenger {
    fn send(&self, msg: &str) {
        println!("  📧 이메일 전송: {}", msg);
    }
}

/// Mock 메신저: 호출을 추적하는 테스트용 구현
struct MockMessenger {
    sent_messages: RefCell<Vec<String>>,
}

impl MockMessenger {
    fn new() -> Self {
        Self {
            sent_messages: RefCell::new(Vec::new()),
        }
    }

    /// 전송된 메시지 개수를 반환합니다.
    fn sent_count(&self) -> usize {
        self.sent_messages.borrow().len()
    }

    /// 특정 인덱스의 메시지를 반환합니다.
    fn get_message(&self, index: usize) -> Option<String> {
        self.sent_messages.borrow()
            .get(index)
            .map(|s| s.clone())
    }
}

impl Messenger for MockMessenger {
    fn send(&self, msg: &str) {
        // &self는 불변이지만, RefCell을 통해 내부 수정 가능!
        self.sent_messages.borrow_mut().push(String::from(msg));
    }
}

/// 메신저를 사용하는 통지 함수
fn notify(messenger: &impl Messenger, msg: &str) {
    messenger.send(msg);
}

fn demo_mock_messenger() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║      [Demo 2] Mock 객체: RefCell로 테스트 지원                ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    // [1] 실제 메신저 (프로덕션)
    println!("[1] 실제 메신저 (이메일 전송):");
    let real = EmailMessenger;
    notify(&real, "배포 완료");

    // [2] Mock 메신저 (테스트)
    println!("\n[2] Mock 메신저 (테스트):");
    let mock = MockMessenger::new();
    println!("    초기 메시지 개수: {}", mock.sent_count());

    notify(&mock, "테스트 메시지 1");
    println!("    notify() 호출 후: {}", mock.sent_count());

    notify(&mock, "테스트 메시지 2");
    println!("    두 번째 호출 후: {}", mock.sent_count());

    notify(&mock, "테스트 메시지 3");
    println!("    세 번째 호출 후: {}", mock.sent_count());

    // [3] 메시지 검증
    println!("\n[3] 전송된 메시지 검증:");
    for i in 0..mock.sent_count() {
        if let Some(msg) = mock.get_message(i) {
            println!("    Message {}: {}", i, msg);
        }
    }

    println!("\n    ✅ Mock 객체는 &self 불변 참조로도 호출 기록 가능\n");
}

