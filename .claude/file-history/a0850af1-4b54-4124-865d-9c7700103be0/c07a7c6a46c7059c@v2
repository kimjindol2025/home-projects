/// 값을 캐싱하고 캐시 히트율을 추적하는 구조체
struct CachedValue<T: Clone> {
    value: T,
    cache: RefCell<Option<T>>,
    cache_hits: RefCell<usize>,
}

impl<T: Clone> CachedValue<T> {
    fn new(value: T) -> Self {
        Self {
            value,
            cache: RefCell::new(None),
            cache_hits: RefCell::new(0),
        }
    }

    /// 값을 얻습니다 (캐시가 있으면 캐시 사용).
    fn get(&self) -> T {
        // 불변 메서드이지만 내부 상태 변경
        if let Some(cached) = self.cache.borrow().as_ref() {
            *self.cache_hits.borrow_mut() += 1;
            return cached.clone();
        }

        let result = self.value.clone();
        *self.cache.borrow_mut() = Some(result.clone());
        result
    }

    /// 캐시 히트 횟수를 반환합니다.
    fn cache_hits(&self) -> usize {
        *self.cache_hits.borrow()
    }
}

fn demo_cached_value() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║        [Demo 3] 캐시 시스템: 내부 상태 추적                   ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    let cached = CachedValue::new(vec![1, 2, 3, 4, 5]);
    println!("CachedValue 생성: {:?}", cached.get());

    println!("\n[1] 첫 번째 get() - 캐시 미스:");
    let _result = cached.get();
    println!("    캐시 히트: {}", cached.cache_hits());

    println!("\n[2] 두 번째 get() - 캐시 히트:");
    let _result = cached.get();
    println!("    캐시 히트: {}", cached.cache_hits());

    println!("\n[3] 세 번째 get() - 캐시 히트:");
    let _result = cached.get();
    println!("    캐시 히트: {}", cached.cache_hits());

    println!("\n    ✅ RefCell<Option<T>>로 캐시 상태 관리");
    println!("    ✅ RefCell<usize>로 히트 통계 추적\n");
}

