// [v9.2: 안전 패턴] Panic 방지 (try_borrow 사용)
// ============================================================================

fn demo_panic_prevention() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║    [Demo 6] Panic 방지: try_borrow 안전한 사용                ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    let cell = RefCell::new(5);

    println!("[1] 불변 참조 유지:");
    {
        let borrow1 = cell.borrow();
        println!("    borrow1 획득: {}", *borrow1);

        println!("\n[2] try_borrow_mut() 시도 (안전):");
        match cell.try_borrow_mut() {
            Ok(mut b) => {
                *b = 10;
                println!("    수정 성공: {}", b);
            }
            Err(e) => {
                println!("    ✅ 안전하게 실패 감지: {}", e);
            }
        }

        // borrow1이 여기서 drop
    }

    println!("\n[3] borrow1 drop 후 try_borrow_mut() 성공:");
    {
        match cell.try_borrow_mut() {
            Ok(mut b) => {
                *b = 20;
                println!("    수정 성공: {}", b);
            }
            Err(e) => {
                println!("    에러: {}", e);
            }
        }
    }

    println!("\n    ✅ try_borrow와 try_borrow_mut로 panic 방지\n");
}

