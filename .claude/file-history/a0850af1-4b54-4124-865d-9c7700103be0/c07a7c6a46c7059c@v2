fn demo_rc_refcell() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║    [Demo 7] Rc + RefCell: 다중 소유권 + 내부 가변성           ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    println!("[1] Rc<RefCell<T>> 구조: 다중 소유 + 수정 가능");
    {
        let shared = Rc::new(RefCell::new(vec![]));
        println!("    초기 상태: {:?}", shared.borrow());

        // 여러 소유자 생성
        let shared1 = Rc::clone(&shared);
        let shared2 = Rc::clone(&shared);

        println!("\n[2] 각 소유자에서 수정:");
        shared.borrow_mut().push(1);
        println!("    shared.borrow_mut().push(1) → {:?}", shared.borrow());

        shared1.borrow_mut().push(2);
        println!("    shared1.borrow_mut().push(2) → {:?}", shared1.borrow());

        shared2.borrow_mut().push(3);
        println!("    shared2.borrow_mut().push(3) → {:?}", shared2.borrow());

        println!("\n[3] 모두 같은 데이터를 공유:");
        println!("    shared:  {:?}", shared.borrow());
        println!("    shared1: {:?}", shared1.borrow());
        println!("    shared2: {:?}", shared2.borrow());
    }

    println!("\n    ✅ Rc<T>로 다중 소유권");
    println!("    ✅ RefCell<T>로 내부 가변성");
    println!("    ✅ 조합으로 최대 유연성 제공\n");
}

