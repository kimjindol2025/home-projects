/// Gogs 보안 메신저: 불변 참조로도 메시지 기록
struct GogsTracker {
    sent_messages: RefCell<Vec<String>>,
}

impl GogsTracker {
    fn new() -> Self {
        Self {
            sent_messages: RefCell::new(Vec::new()),
        }
    }

    /// 불변 메서드이지만 내부 상태 변경
    fn send(&self, msg: &str) {
        self.sent_messages.borrow_mut().push(String::from(msg));
        println!("  [전송]: {}", msg);
    }

    /// 전송 기록 조회
    fn get_sent_count(&self) -> usize {
        self.sent_messages.borrow().len()
    }

    /// 특정 메시지 조회
    fn get_message(&self, index: usize) -> Option<String> {
        self.sent_messages.borrow()
            .get(index)
            .map(|s| s.clone())
    }

    /// 모든 메시지 출력
    fn print_all_messages(&self) {
        let messages = self.sent_messages.borrow();
        for (i, msg) in messages.iter().enumerate() {
            println!("    [{}] {}", i + 1, msg);
        }
    }
}

impl Messenger for GogsTracker {
    fn send(&self, msg: &str) {
        self.sent_messages.borrow_mut().push(String::from(msg));
    }
}

fn demo_gogs_tracker() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║     [Demo 5] GogsTracker: 보안 메신저 설계                    ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    let tracker = GogsTracker::new();
    println!("[1] 초기 상태:");
    println!("    전송 기록: {}", tracker.get_sent_count());

    println!("\n[2] 메시지 전송:");
    tracker.send("보안 암호화 메시지 1");
    tracker.send("보안 암호화 메시지 2");
    tracker.send("보안 암호화 메시지 3");
    println!("    총 전송: {}", tracker.get_sent_count());

    println!("\n[3] 전송 기록 조회:");
    tracker.print_all_messages();

    println!("\n[4] 특정 메시지 검증:");
    if let Some(msg) = tracker.get_message(0) {
        println!("    첫 번째 메시지: {}", msg);
    }
    if let Some(msg) = tracker.get_message(2) {
        println!("    세 번째 메시지: {}", msg);
    }

    println!("\n    ✅ GogsTracker는 불변 참조만으로 메시지 기록 가능\n");
}

