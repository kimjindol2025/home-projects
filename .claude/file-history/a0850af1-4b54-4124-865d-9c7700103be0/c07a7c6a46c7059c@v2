/// RefCell<T>를 사용한 기본 내부 가변성
fn demo_basic_refcell() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║         [Demo 1] RefCell<T>: 기본 내부 가변성                 ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    // [1] Rc<T>의 한계: 불변 공유만 가능
    println!("❌ Rc<T>의 한계: 불변 공유만 가능");
    {
        let _value: Rc<Vec<i32>> = Rc::new(vec![]);
        // let shared = Rc::clone(&_value);
        // shared.push(1);  // ❌ 컴파일 에러: Rc<Vec>에서 push 불가능
        println!("   Rc<T>는 공유하면서 수정 불가능\n");
    }

    // [2] RefCell<T>의 해답: 불변 참조로도 내부 수정 가능
    println!("✅ RefCell<T>의 해답: 불변 참조로도 내부 수정");
    {
        let value = RefCell::new(vec![]);
        println!("   초기 상태: {:?}", value.borrow());

        // &value는 불변이지만 내부는 수정 가능!
        value.borrow_mut().push(1);
        println!("   push(1) 후: {:?}", value.borrow());

        value.borrow_mut().push(2);
        println!("   push(2) 후: {:?}", value.borrow());

        value.borrow_mut().push(3);
        println!("   push(3) 후: {:?}", value.borrow());
    }

    println!("   RefCell은 런타임에 대여 규칙을 검사합니다\n");
}

