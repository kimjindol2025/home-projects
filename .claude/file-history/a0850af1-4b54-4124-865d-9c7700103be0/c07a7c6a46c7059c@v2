/// 요청을 추적하고 통계를 수집하는 구조체
struct RequestTracker {
    count: RefCell<usize>,
    errors: RefCell<usize>,
}

impl RequestTracker {
    fn new() -> Self {
        Self {
            count: RefCell::new(0),
            errors: RefCell::new(0),
        }
    }

    /// 요청을 기록합니다 (성공).
    fn record_request(&self) {
        *self.count.borrow_mut() += 1;
    }

    /// 에러를 기록합니다.
    fn record_error(&self) {
        *self.errors.borrow_mut() += 1;
    }

    /// 현재 통계를 반환합니다: (총 요청, 에러 개수).
    fn get_stats(&self) -> (usize, usize) {
        (*self.count.borrow(), *self.errors.borrow())
    }

    /// 성공률을 계산합니다 (백분율).
    fn success_rate(&self) -> f64 {
        let (count, errors) = self.get_stats();
        if count == 0 {
            0.0
        } else {
            ((count - errors) as f64 / count as f64) * 100.0
        }
    }
}

fn demo_request_tracker() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║      [Demo 4] 통계 수집: 실시간 메트릭 추적                   ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    let tracker = RequestTracker::new();
    println!("[1] 초기 상태:");
    let (count, errors) = tracker.get_stats();
    println!("    요청: {}, 에러: {}", count, errors);

    // 10개 요청 처리
    for i in 1..=10 {
        tracker.record_request();
        println!("    [{}] 요청 기록 → 누계: {}", i, tracker.get_stats().0);
    }

    println!("\n[2] 3개 에러 발생:");
    for i in 1..=3 {
        tracker.record_error();
        let (count, errors) = tracker.get_stats();
        println!("    [{}] 에러 기록 → 요청: {}, 에러: {}", i, count, errors);
    }

    println!("\n[3] 최종 통계:");
    let (count, errors) = tracker.get_stats();
    println!("    총 요청: {}", count);
    println!("    총 에러: {}", errors);
    println!("    성공률: {:.1}%", tracker.success_rate());

    println!("\n    ✅ RefCell<usize>로 변경 가능한 통계 추적\n");
}

