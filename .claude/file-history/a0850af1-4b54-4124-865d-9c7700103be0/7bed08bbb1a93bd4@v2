// ============================================================================
// [예제 1] 기본 패턴 매칭
// ============================================================================
enum TrafficSignal {
    Stop,
    Caution(u32),  // 황색 신호의 시간(초)
    Go,
}

fn pattern_matching_basics() {
    println!(\"\\n[예제 1] 기본 패턴 매칭\");
    println!(\"═════════════════════════════════════════\");

    let signals = vec![
        TrafficSignal::Stop,
        TrafficSignal::Caution(5),
        TrafficSignal::Go,
    ];

    println!(\"\\n[신호 처리]\");
    for signal in signals {
        match signal {
            TrafficSignal::Stop => println!(\"🔴 정지 신호\"),
            TrafficSignal::Caution(secs) => {
                println!(\"🟡 주의 신호 ({}초)\", secs);
            }
            TrafficSignal::Go => println!(\"🟢 진행 신호\"),
        }
    }
}

// ============================================================================
// [예제 2] 구조체와 튜플 분해
// ============================================================================
struct Point {
    x: i32,
    y: i32,
}

struct Rectangle {
    top_left: Point,
    bottom_right: Point,
}

enum Color {
    RGB(u8, u8, u8),
    HSL { hue: f64, saturation: f64, lightness: f64 },
    Black,
}

fn destructuring_patterns() {
    println!(\"\\n[예제 2] 구조체와 튜플 분해\");
    println!(\"═════════════════════════════════════════\");

    println!(\"\\n[Point 분해]\");
    let point = Point { x: 10, y: 20 };
    match point {
        Point { x, y } => println!(\"좌표: ({}, {})\", x, y),
    }

    println!(\"\\n[Rectangle 분해]\");
    let rect = Rectangle {
        top_left: Point { x: 0, y: 100 },
        bottom_right: Point { x: 100, y: 0 },
    };
    match rect {
        Rectangle {
            top_left: Point { x: x1, y: y1 },
            bottom_right: Point { x: x2, y: y2 },
        } => {
            println!(
                \"직사각형: ({},{}) ~ ({},{})\",
                x1, y1, x2, y2
            );
        }
    }

    println!(\"\\n[Color 분해]\");
    let colors = vec![
        Color::RGB(255, 0, 0),
        Color::HSL { hue: 120.0, saturation: 100.0, lightness: 50.0 },
        Color::Black,
    ];

    for color in colors {
        match color {
            Color::RGB(r, g, b) => println!(\"RGB({}, {}, {})\", r, g, b),
            Color::HSL { hue, saturation, lightness } => {
                println!(\"HSL({}, {}, {})\", hue, saturation, lightness);
            }
            Color::Black => println!(\"검정\"),
        }
    }
}

// ============================================================================
// [예제 3] match Guard (조건부 패턴)
// ============================================================================
enum Status {
    Processing(u32),  // 진행률(%)
    Completed,
    Failed(String),
}

fn guard_clauses() {
    println!(\"\\n[예제 3] match Guard\");
    println!(\"═════════════════════════════════════════\");

    println!(\"\\n[진행률 판정]\");
    let statuses = vec![
        Status::Processing(25),
        Status::Processing(50),
        Status::Processing(99),
        Status::Completed,
        Status::Failed(\"네트워크 오류\".to_string()),
    ];

    for status in statuses {
        match status {
            Status::Processing(percent) if percent < 50 => {
                println!(\"처리 중 ({}%) - 초기 단계\", percent);
            }
            Status::Processing(percent) if percent < 100 => {
                println!(\"처리 중 ({}%) - 최종 단계\", percent);
            }
            Status::Processing(percent) => {
                println!(\"처리 중 ({}%) - 완료 직전\", percent);
            }
            Status::Completed => println!(\"완료!\"),
            Status::Failed(msg) => println!(\"실패: {}\", msg),
        }
    }

    println!(\"\\n[범위 기반 판정]\");
    let age = 25;
    match age {
        0..=12 => println!(\"어린이\"),
        13..=19 => println!(\"청소년\"),
        20..=64 => println!(\"성인\"),
        _ => println!(\"노인\"),
    }
}

// ============================================================================
// [예제 4] if let 패턴
// ============================================================================
enum Permission {
    Read,
    Write,
    Execute,
    Admin,
}

fn if_let_patterns() {
    println!(\"\\n[예제 4] if let 패턴\");
    println!(\"═════════════════════════════════════════\");

    let permissions = vec![
        Permission::Read,
        Permission::Write,
        Permission::Admin,
    ];

    println!(\"\\n[if let 기본]\");
    for perm in permissions {
        if let Permission::Admin = perm {
            println!(\"🔐 관리자 권한 감지!\");
        } else {
            println!(\"일반 권한\");
        }
    }

    println!(\"\\n[if let else]\");
    let opt = Some(42);
    if let Some(value) = opt {
        println!(\"값 있음: {}\", value);
    } else {
        println!(\"값 없음\");
    }

    println!(\"\\n[while let]\");
    let mut values = vec![1, 2, 3];
    while let Some(v) = values.pop() {
        println!(\"꺼낸 값: {}\", v);
    }
}

// ============================================================================
// [예제 5] 와일드카드와 범위 패턴
// ============================================================================
fn wildcard_and_ranges() {
    println!(\"\\n[예제 5] 와일드카드와 범위 패턴\");
    println!(\"═════════════════════════════════════════\");

    println!(\"\\n[| 연산자로 여러 패턴]\");
    let num = 2;
    match num {
        0 => println!(\"0\"),
        1 | 2 | 3 => println!(\"1, 2, 또는 3\"),
        4..=6 => println!(\"4~6\"),
        _ => println!(\"그 외\"),
    }

    println!(\"\\n[범위 패턴]\");
    for score in 50..100 {
        match score {
            90..=100 => println!(\"{}점: A\", score),
            80..=89 => println!(\"{}점: B\", score),
            70..=79 => println!(\"{}점: C\", score),
            _ => println!(\"{}점: F\", score),
        }
        if score >= 95 { break; }  // 루프 종료
    }

    println!(\"\\n[as 바인딩]\");
    let value = 15;
    match value {
        0..=10 => println!(\"작음\"),
        range @ 11..=20 => println!(\"중간: {}\", range),
        range @ _ => println!(\"큼: {}\", range),
    }
}

// ============================================================================
// [예제 6] 중첩된 패턴
// ============================================================================
enum Message {
    User {
        id: u32,
        name: String,
        status: UserStatus,
    },
    Command {
        action: String,
        args: Vec<String>,
    },
}

enum UserStatus {
    Active,
    Inactive { reason: String },
}

fn nested_patterns() {
    println!(\"\\n[예제 6] 중첩된 패턴\");
    println!(\"═════════════════════════════════════════\");

    let messages = vec![
        Message::User {
            id: 1,
            name: \"Alice\".to_string(),
            status: UserStatus::Active,
        },
        Message::User {
            id: 2,
            name: \"Bob\".to_string(),
            status: UserStatus::Inactive {
                reason: \"휴가 중\".to_string(),
            },
        },
        Message::Command {
            action: \"start\".to_string(),
            args: vec![\"server\".to_string()],
        },
    ];

    println!(\"\\n[중첩된 패턴 매칭]\");
    for msg in messages {
        match msg {
            Message::User {
                id,
                name,
                status: UserStatus::Active,
            } => {
                println!(\"활성 사용자: {} (ID: {})\", name, id);
            }
            Message::User {
                id,
                name,
                status: UserStatus::Inactive { reason },
            } => {
                println!(\"비활성 사용자: {} - {}\", name, reason);
            }
            Message::Command { action, args } => {
                println!(
                    \"명령: {} (인자: {})\",
                    action,
                    args.join(\", \")
                );
            }
        }
    }
}

// ============================================================================
// [예제 7] 완전성 검증
// ============================================================================
enum HttpStatus {
    Success(u16),
    Redirect(u16),
    ClientError(u16),
    ServerError(u16),
}

fn exhaustiveness_checking() {
    println!(\"\\n[예제 7] 완전성 검증\");
    println!(\"═════════════════════════════════════════\");

    let statuses = vec![
        HttpStatus::Success(200),
        HttpStatus::Redirect(301),
        HttpStatus::ClientError(404),
        HttpStatus::ServerError(500),
    ];

    println!(\"\\n[모든 경우 처리]\");
    for status in statuses {
        match status {
            HttpStatus::Success(code) => println!(\"성공: {}\", code),
            HttpStatus::Redirect(code) => println!(\"리다이렉트: {}\", code),
            HttpStatus::ClientError(code) => println!(\"클라이언트 에러: {}\", code),
            HttpStatus::ServerError(code) => println!(\"서버 에러: {}\", code),
            // 모든 경우를 처리하지 않으면 컴파일 에러!
        }
    }

    println!(\"\\n[와일드카드 사용]\");
    let status = HttpStatus::Success(200);
    match status {
        HttpStatus::Success(_) => println!(\"성공\"),
        _ => println!(\"실패\"),
    }
}

// ============================================================================
// [예제 8] 실제 복합 패턴
// ============================================================================
#[derive(Clone)]
struct Transaction {
    from: String,
    to: String,
    amount: f64,
    status: TransactionStatus,
}

#[derive(Clone)]
enum TransactionStatus {
    Pending,
    Approved { approved_by: String },
    Rejected { reason: String },
    Completed { timestamp: String },
}

fn validate_transaction(tx: &Transaction) -> Result<String, String> {
    match tx {
        Transaction {
            amount,
            status: TransactionStatus::Approved { approved_by },
            ..
        } if *amount > 0.0 && *amount <= 10000.0 => {
            Ok(format!(
                \"거래 승인됨 (승인자: {}, 금액: {}\",
                approved_by, amount
            ))
        }
        Transaction {
            amount,
            status: TransactionStatus::Approved { .. },
            ..
        } if *amount > 10000.0 => {
            Err(\"금액이 한도를 초과했습니다\".to_string())
        }
        Transaction {
            status: TransactionStatus::Rejected { reason },
            ..
        } => Err(format!(\"거래 거부: {}\", reason)),
        Transaction {
            status: TransactionStatus::Pending,
            ..
        } => Err(\"아직 승인 대기 중\".to_string()),
        Transaction {
            status: TransactionStatus::Completed { timestamp },
            ..
        } => Ok(format!(\"완료됨 ({})\", timestamp)),
    }
}

fn real_world_patterns() {
    println!(\"\\n[예제 8] 실제 복합 패턴\");
    println!(\"═════════════════════════════════════════\");

    let transactions = vec![
        Transaction {
            from: \"Alice\".to_string(),
            to: \"Bob\".to_string(),
            amount: 1000.0,
            status: TransactionStatus::Approved {
                approved_by: \"Admin\".to_string(),
            },
        },
        Transaction {
            from: \"Charlie\".to_string(),
            to: \"David\".to_string(),
            amount: 50000.0,
            status: TransactionStatus::Approved {
                approved_by: \"Manager\".to_string(),
            },
        },
        Transaction {
            from: \"Eve\".to_string(),
            to: \"Frank\".to_string(),
            amount: 500.0,
            status: TransactionStatus::Rejected {
                reason: \"본인 확인 실패\".to_string(),
            },
        },
        Transaction {
            from: \"George\".to_string(),
            to: \"Hannah\".to_string(),
            amount: 750.0,
            status: TransactionStatus::Completed {
                timestamp: \"2026-02-22 14:30\".to_string(),
            },
        },
    ];

    println!(\"\\n[거래 검증]\");
    for (idx, tx) in transactions.iter().enumerate() {
        match validate_transaction(tx) {
            Ok(msg) => println!(\"거래 {}: ✓ {}\", idx + 1, msg),
            Err(err) => println!(\"거래 {}: ✗ {}\", idx + 1, err),
        }
    }
}

