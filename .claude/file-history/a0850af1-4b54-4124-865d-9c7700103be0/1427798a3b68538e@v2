# 예제: 가장 간단한 컨텍스트 매니저
class SimpleManager:
    def __init__(self, name):
        self.name = name
        print(f"  [{self.name}] 객체 생성됨")

    def __enter__(self):
        print(f"  [{self.name}] __enter__() 실행됨")
        return self

    def __exit__(self, exc_type, exc_val, exc_tb):
        print(f"  [{self.name}] __exit__() 실행됨")
        if exc_type:
            print(f"  [{self.name}] 예외 발생: {exc_type.__name__}")
        return False

print("✓ 가장 간단한 컨텍스트 매니저:")
print()
