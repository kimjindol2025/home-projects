# 패턴 3: 임시 설정 변경
class TemporarySettings:
    """임시로 설정을 변경했다가 복원하는 컨텍스트 매니저"""

    def __init__(self, settings: dict):
        self.settings = settings
        self.original_settings = {}

    def __enter__(self):
        print(f"  ⚙️ 설정 변경:")
        for key, value in self.settings.items():
            self.original_settings[key] = f"original_{key}"
            print(f"      - {key}: {self.original_settings[key]} → {value}")
        return self

    def __exit__(self, exc_type, exc_val, exc_tb):
        print(f"  ⚙️ 설정 복원:")
        for key, value in self.original_settings.items():
            print(f"      - {key}: {self.settings[key]} → {value}")
        return False

print("✓ 임시 설정 변경:")
print()
with TemporarySettings({"debug": True, "timeout": 30}):
    print(f"  [임시 설정 활성화] 디버그 모드, 타임아웃 30초")
