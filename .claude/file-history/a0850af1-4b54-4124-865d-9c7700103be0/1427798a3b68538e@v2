# 예제 1: 데이터베이스 연결 시뮬레이션
class DatabaseConnection:
    """데이터베이스 연결을 관리하는 컨텍스트 매니저"""

    def __init__(self, db_name):
        self.db_name = db_name
        self.connection = None
        print(f"  📊 [{self.db_name}] 데이터베이스 매니저 생성")

    def __enter__(self):
        print(f"  🔗 [{self.db_name}] 데이터베이스 연결 중...")
        time.sleep(0.1)  # 연결 시뮬레이션
        self.connection = f"Connection to {self.db_name}"
        print(f"  ✅ [{self.db_name}] 연결 완료: {self.connection}")
        return self.connection

    def __exit__(self, exc_type, exc_val, exc_tb):
        print(f"  🔌 [{self.db_name}] 데이터베이스 연결 해제 중...")
        self.connection = None
        print(f"  ✅ [{self.db_name}] 연결 해제 완료")
        return False

print("✓ 데이터베이스 연결 관리:")
print()
with DatabaseConnection("gogs_db") as conn:
    print(f"  [사용 중] {conn}")
print()

# 예제 2: 타이머 매니저
class Timer:
    """코드 블록의 실행 시간을 측정하는 컨텍스트 매니저"""

    def __init__(self, label="작업"):
        self.label = label
        self.start_time = None

    def __enter__(self):
        self.start_time = time.time()
        print(f"  ⏱️ [{self.label}] 시작")
        return self

    def __exit__(self, exc_type, exc_val, exc_tb):
        elapsed = time.time() - self.start_time
        print(f"  ⏱️ [{self.label}] 완료 ({elapsed:.4f}초)")
        return False

print("✓ 코드 실행 시간 측정:")
print()
with Timer("데이터 처리"):
    time.sleep(0.2)
    print(f"    작업 수행 중...")
print()

