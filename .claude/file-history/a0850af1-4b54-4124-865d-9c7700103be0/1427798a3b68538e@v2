# 예제 1: 간단한 함수형 컨텍스트 매니저
@contextmanager
def timer(label: str):
    """함수형 타이머"""
    start = time.time()
    print(f"  ⏱️ [{label}] 시작")
    try:
        yield
    finally:
        elapsed = time.time() - start
        print(f"  ⏱️ [{label}] 완료 ({elapsed:.4f}초)")

print("✓ 함수형 타이머:")
print()
with timer("계산"):
    time.sleep(0.1)
    print(f"    계산 실행 중...")
print()

# 예제 2: 자원 할당/해제
@contextmanager
def open_database(db_name: str):
    """데이터베이스 연결 관리"""
    print(f"  🔗 [{db_name}] 연결 중...")
    db_conn = f"Connection({db_name})"
    try:
        yield db_conn
    finally:
        print(f"  🔌 [{db_name}] 연결 해제")

print("✓ 함수형 데이터베이스 관리:")
print()
with open_database("users_db") as conn:
    print(f"    데이터베이스 사용 중: {conn}")
print()

# 예제 3: 예외 처리
@contextmanager
def safe_operation(op_name: str):
    """안전한 작업 실행"""
    print(f"  🔄 [{op_name}] 시작")
    try:
        yield
    except Exception as e:
        print(f"  ❌ [{op_name}] 에러 발생: {e}")
        raise  # 에러를 위로 던짐
    else:
        print(f"  ✅ [{op_name}] 성공")
    finally:
        print(f"  🧹 [{op_name}] 정리 완료")

print("✓ 예외 처리가 있는 함수형 컨텍스트 매니저:")
print()
