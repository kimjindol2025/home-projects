# 예제 2: ExitStack으로 더 깔끔하게
from contextlib import ExitStack

print("✓ ExitStack을 사용한 동적 자원 관리:")
print()

@contextmanager
def open_file_verbose(filename):
    """파일 열기를 알리는 매니저"""
    print(f"  📂 {filename} 열기")
    f = open(filename, "w")
    try:
        yield f
    finally:
        print(f"  📂 {filename} 닫기")
        f.close()

print("  파일들을 동적으로 열기:")
with ExitStack() as stack:
    files = [
        stack.enter_context(open_file_verbose(f"/tmp/dynamic_{i}.txt"))
        for i in range(3)
    ]
    for i, f in enumerate(files):
        f.write(f"Content {i}\n")
    print(f"    3개 파일에 동시에 쓰기 완료")
print()

# 예제 3: 복합 자원 관리
class ComplexResource:
    """여러 단계의 초기화와 정리가 필요한 복잡한 자원"""

    def __init__(self, name):
        self.name = name
        self.steps = []

    def __enter__(self):
        print(f"  🔧 [{self.name}] 복합 초기화 시작")
        self.steps.append("Step 1: 메모리 할당")
        print(f"      {self.steps[-1]}")
        self.steps.append("Step 2: 연결 설정")
        print(f"      {self.steps[-1]}")
        self.steps.append("Step 3: 동기화")
        print(f"      {self.steps[-1]}")
        return self

    def __exit__(self, exc_type, exc_val, exc_tb):
        print(f"  🧹 [{self.name}] 복합 정리 시작 (역순)")
        while self.steps:
            step = self.steps.pop()
            print(f"      {step} 취소됨")
        return False

print("✓ 복합 자원의 역순 정리:")
print()
with ComplexResource("데이터 처리 파이프라인"):
    print(f"    리소스 사용 중...")
print()

print("💡 결론: ExitStack으로 동적이고 복잡한 자원 관리도 가능합니다!\n")


