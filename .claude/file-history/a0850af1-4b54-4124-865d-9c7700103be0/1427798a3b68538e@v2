# 프로덕션급 컨텍스트 매니저
class ProductionTransaction:
    """
    프로덕션 환경에서 사용할 수 있는 트랜잭션 관리자
    - ACID 속성 보장
    - 자동 커밋/롤백
    - 상세한 로깅
    """

    def __init__(self, transaction_name: str):
        self.name = transaction_name
        self.start_time = None
        self.status = "PENDING"

    def __enter__(self):
        self.start_time = time.time()
        self.status = "ACTIVE"
        print(f"\n  💳 [{self.name}] 트랜잭션 시작")
        print(f"     시간: {datetime.now().strftime('%H:%M:%S')}")
        print(f"     상태: {self.status}")
        return self

    def commit(self):
        """변경사항 커밋"""
        print(f"  ✅ [{self.name}] COMMIT 실행")
        self.status = "COMMITTED"

    def rollback(self):
        """변경사항 롤백"""
        print(f"  ↩️ [{self.name}] ROLLBACK 실행")
        self.status = "ROLLED_BACK"

    def __exit__(self, exc_type, exc_val, exc_tb):
        elapsed = time.time() - self.start_time

        if exc_type is None:
            print(f"  ✅ [{self.name}] 트랜잭션 성공")
            self.commit()
        else:
            print(f"  ❌ [{self.name}] 트랜잭션 실패 ({exc_type.__name__})")
            self.rollback()

        print(f"  📊 트랜잭션 통계:")
        print(f"     - 최종 상태: {self.status}")
        print(f"     - 소요 시간: {elapsed:.4f}초")
        print(f"     - 종료 시간: {datetime.now().strftime('%H:%M:%S')}\n")

        # False를 반환하여 예외는 위로 전파
        return False

print("✓ 프로덕션급 트랜잭션 관리자:")
