# 패턴 1: 연결 풀 관리
class ConnectionPool:
    """연결 풀을 관리하는 컨텍스트 매니저"""

    def __init__(self, pool_name, size=3):
        self.pool_name = pool_name
        self.size = size
        self.connections = []

    def __enter__(self):
        print(f"  🏊 [{self.pool_name}] 연결 풀 생성 (크기: {self.size})")
        self.connections = [f"conn-{i}" for i in range(self.size)]
        for conn in self.connections:
            print(f"      - {conn} 준비됨")
        return self

    def __exit__(self, exc_type, exc_val, exc_tb):
        print(f"  🏊 [{self.pool_name}] 연결 풀 정리")
        for conn in self.connections:
            print(f"      - {conn} 해제됨")
        self.connections.clear()
        return False

    def get_connection(self):
        return self.connections.pop() if self.connections else None

print("✓ 연결 풀 관리:")
print()
with ConnectionPool("API_POOL") as pool:
    conn1 = pool.get_connection()
    conn2 = pool.get_connection()
    print(f"  [사용 중] {conn1}, {conn2}")
print()

