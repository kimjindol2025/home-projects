## 6️⃣ 실전 패턴

### 패턴 1: 사용자 입력 검증

```rust
fn process_user_input(input: String) -> Result<(), Error> {
    // Guard 1: 빈 문자열
    if input.trim().is_empty() {
        return Err(Error::EmptyInput);
    }

    // Guard 2: 길이 검사
    if input.len() > 100 {
        return Err(Error::TooLong);
    }

    // Guard 3: 특수문자 검사
    if input.chars().any(|c| !c.is_alphanumeric() && c != ' ') {
        return Err(Error::InvalidCharacters);
    }

    // 핵심: 검증된 입력 처리
    store_input(&input)?;
    Ok(())
}
```

### 패턴 2: 파일 작업

```rust
fn read_config_file(path: &str) -> Result<Config, Error> {
    // Guard 1: 파일 경로 검사
    if path.is_empty() {
        return Err(Error::EmptyPath);
    }

    // Guard 2: 파일 존재 검사
    if !std::path::Path::new(path).exists() {
        return Err(Error::FileNotFound);
    }

    // Guard 3: 파일 읽기
    let contents = std::fs::read_to_string(path)
        .map_err(|_| Error::ReadFailed)?;

    // Guard 4: 파싱
    let config = serde_json::from_str(&contents)
        .map_err(|_| Error::ParseFailed)?;

    // 핵심: 유효한 설정 처리
    Ok(config)
}
```

### 패턴 3: 시스템 상태 검사

```rust
fn start_system(config: SystemConfig) -> Result<(), Error> {
    // Guard: 전원 확인
    if !config.power_enabled {
        return Err(Error::PowerOff);
    }

    // Guard: 권한 확인
    if config.permission_level < 5 {
        return Err(Error::InsufficientPermission);
    }

    // Guard: 부품 상태 확인
    if config.component_status != Status::Stable {
        return Err(Error::ComponentUnstable);
    }

    // Guard: 메모리 확인
    if config.available_memory < 1024 {
        return Err(Error::InsufficientMemory);
    }

    // 핵심: 모든 검증 통과, 시스템 시작
    println!("모든 가드 통과. 시스템 시작!");
    initialize_system(&config);
    Ok(())
}
```

