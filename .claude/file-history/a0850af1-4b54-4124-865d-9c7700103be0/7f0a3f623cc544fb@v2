## 🎓 실전 리팩토링 예제

### Before: 피라미드 (35줄)

```rust
fn process_order(order: Order) -> Result<OrderResult, Error> {
    if order.customer_id != 0 {
        if order.items.len() > 0 {
            if order.total_price > 0.0 {
                if order.payment_method != "" {
                    if order.shipping_address != "" {
                        // 핵심 로직 (5단계 깊이)
                        let result = calculate_tax(&order)?;
                        let total = order.total_price + result;
                        create_order_in_db(&order, total)?;
                        send_confirmation_email(&order)?;
                        return Ok(OrderResult { success: true });
                    }
                }
            }
        }
    }
    Err(Error::InvalidOrder)
}
```

### After: Guard (25줄, 더 명확함)

```rust
fn process_order(order: Order) -> Result<OrderResult, Error> {
    // Guard: 고객 ID
    if order.customer_id == 0 {
        return Err(Error::NoCustomerId);
    }

    // Guard: 주문 항목
    if order.items.is_empty() {
        return Err(Error::NoItems);
    }

    // Guard: 가격
    if order.total_price <= 0.0 {
        return Err(Error::InvalidPrice);
    }

    // Guard: 결제 방법
    if order.payment_method.is_empty() {
        return Err(Error::NoPaymentMethod);
    }

    // Guard: 배송 주소
    if order.shipping_address.is_empty() {
        return Err(Error::NoShippingAddress);
    }

    // 핵심 로직 (1단계 깊이) ✅
    let result = calculate_tax(&order)?;
    let total = order.total_price + result;
    create_order_in_db(&order, total)?;
    send_confirmation_email(&order)?;

    Ok(OrderResult { success: true })
}
```

