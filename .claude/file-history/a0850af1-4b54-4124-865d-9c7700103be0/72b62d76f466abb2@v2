// Phase 9 v10.4: Deadlock Prevention - Defensive Design
// "순환 대기의 고리 끊기" - Breaking the Circular Wait
// 자원 계층화를 통한 데드락 방어 설계

use std::sync::{Arc, Mutex};
use std::thread;
use std::time::Duration;

// ============================================================================
// Foundation: Secure Resource with Priority ID
// ============================================================================

/// 우선순위 ID를 가진 보안 자원
/// 모든 자원은 ID(우선순위)를 통해 계층화됨
#[derive(Debug)]
struct SecureResource {
    id: u32,                    // 자원 식별자 (잠금 순서 결정용)
    label: String,              // 자원 이름
    data: Mutex<String>,        // 보호되는 데이터
}

impl SecureResource {
    fn new(id: u32, label: &str, initial_data: &str) -> Self {
        SecureResource {
            id,
            label: label.to_string(),
            data: Mutex::new(initial_data.to_string()),
        }
    }
}

// ============================================================================
// Demo 1: Basic Deadlock Problem (Problem Demonstration)
// ============================================================================
// 데드락의 위험성을 직접 경험하기 - sleep으로 경합 상황 시뮬레이션

fn demo_basic_deadlock_problem() {
    println!("\n=== Demo 1: Basic Deadlock Problem ===");
    println!("⚠️  경합 상황 시뮬레이션 (데드락 회피 설계로 안전하게 진행)");

    let database = Arc::new(SecureResource::new(
        1,
        "Database",
        "DB_INITIAL",
    ));
    let cache = Arc::new(SecureResource::new(
        2,
        "Cache",
        "CACHE_INITIAL",
    ));

    // Thread 1: Database → Cache 순서 (올바른 순서)
    let db1 = Arc::clone(&database);
    let cache1 = Arc::clone(&cache);

    let h1 = thread::spawn(move || {
        println!("✓ [Thread 1] {} (ID:{}) 획득 시도", db1.label, db1.id);
        let _lock_db = db1.data.lock().unwrap();
        println!("✓ [Thread 1] {} (ID:{}) 획득 성공", db1.label, db1.id);

        thread::sleep(Duration::from_millis(50)); // 문맥 교환 기회 제공

        println!("✓ [Thread 1] {} (ID:{}) 획득 시도", cache1.label, cache1.id);
        let _lock_cache = cache1.data.lock().unwrap();
        println!("✓ [Thread 1] 모든 자원 안전하게 획득");
    });

    // Thread 2: 동일한 순서 (ID 기반 - 데드락 방지)
    let db2 = Arc::clone(&database);
    let cache2 = Arc::clone(&cache);

    let h2 = thread::spawn(move || {
        thread::sleep(Duration::from_millis(10)); // 약간 지연

        // 중요: Thread 1과 다른 순서로 시도하고 싶지만,
        // "항상 낮은 ID부터" 규칙 때문에 같은 순서로 강제됨
        println!("✓ [Thread 2] {} (ID:{}) 획득 시도", db2.label, db2.id);
        let _lock_db = db2.data.lock().unwrap();
        println!("✓ [Thread 2] {} (ID:{}) 획득 성공", db2.label, db2.id);

        println!("✓ [Thread 2] {} (ID:{}) 획득 시도", cache2.label, cache2.id);
        let _lock_cache = cache2.data.lock().unwrap();
        println!("✓ [Thread 2] 모든 자원 안전하게 획득");
    });

    h1.join().unwrap();
    h2.join().unwrap();

    println!("✓ Demo 1 완료: 설계된 순서로 데드락 방지됨");
}

// ============================================================================
// Demo 2: Resource Hierarchy (Core Defense Pattern)
// ============================================================================
// 자원 계층화 - 핵심 방어 패턴

fn demo_resource_hierarchy() {
    println!("\n=== Demo 2: Resource Hierarchy (Core Pattern) ===");
    println!("📋 자원 계층화 원칙:");
    println!("  ├─ 모든 자원에 고유 ID 부여");
    println!("  ├─ 항상 낮은 ID의 자원을 먼저 획득");
    println!("  └─ 이로써 순환 대기 구조 불가능하게 함");

    // 4개 자원 생성 (ID 명시적 부여)
    let auth = Arc::new(SecureResource::new(1, "AuthServer", "AUTH_INIT"));
    let db = Arc::new(SecureResource::new(2, "Database", "DB_INIT"));
    let cache = Arc::new(SecureResource::new(3, "Cache", "CACHE_INIT"));
    let logger = Arc::new(SecureResource::new(4, "Logger", "LOG_INIT"));

    println!("\n자원 ID 순서:");
    println!("  1. {} (ID: 1) - 가장 먼저 잠금", auth.label);
    println!("  2. {} (ID: 2)", db.label);
    println!("  3. {} (ID: 3)", cache.label);
    println!("  4. {} (ID: 4) - 가장 나중에 잠금", logger.label);

    // 3개 스레드가 모두 같은 순서 (ID 오름차순)로 접근
    let mut handles = vec![];

    for thread_id in 1..=3 {
        let a = Arc::clone(&auth);
        let d = Arc::clone(&db);
        let c = Arc::clone(&cache);
        let l = Arc::clone(&logger);

        let handle = thread::spawn(move || {
            println!("\n[Thread {}] 자원 획득 시작...", thread_id);

            // ID 순서대로만 획득 (절대 역순 아님!)
            let _lock1 = a.data.lock().unwrap();
            println!("  [Thread {}] ✓ {} 획득", thread_id, a.label);

            let _lock2 = d.data.lock().unwrap();
            println!("  [Thread {}] ✓ {} 획득", thread_id, d.label);

            thread::sleep(Duration::from_millis(5)); // 다른 스레드 개입 기회

            let _lock3 = c.data.lock().unwrap();
            println!("  [Thread {}] ✓ {} 획득", thread_id, c.label);

            let _lock4 = l.data.lock().unwrap();
            println!("  [Thread {}] ✓ {} 획득", thread_id, l.label);

            println!("  [Thread {}] ✅ 모든 자원 완벽하게 획득", thread_id);
        });

        handles.push(handle);
    }

    for handle in handles {
        handle.join().unwrap();
    }

    println!("\n✓ Demo 2 완료: 3개 스레드 모두 데드락 없이 성공");
    println!("  → 자원 계층화 = 논리적 멈춤의 완벽한 방어");
}

// ============================================================================
// Demo 3: Minimal Lock Scope (Performance Optimization)
// ============================================================================
// 잠금 범위 최소화 - 성능 최적화 패턴

fn demo_minimal_lock_scope() {
    println!("\n=== Demo 3: Minimal Lock Scope ===");
    println!("⚡ 성능 최적화: MutexGuard 범위를 극도로 제한");

    let data = Arc::new(Mutex::new(0));

    println!("\n❌ 나쁜 패턴: 긴 잠금 범위");
    println!("let _guard = data.lock().unwrap();");
    println!("// 1000줄의 작업 (I/O, 계산 등)");
    println!("// → 다른 스레드 대기 시간 길어짐");

    println!("\n✅ 좋은 패턴: 명시적 블록으로 범위 제한");
    println!("{{");
    println!("    let _guard = data.lock().unwrap();");
    println!("    // 정말 필요한 1-2줄만 실행");
    println!("}} // ← 여기서 자동 해제");
    println!("// 나머지는 락 없이 수행");

    println!("\n🔬 성능 비교 실험:");

    // 비효율적 잠금 (전체 작업 동안 잠금)
    let data1 = Arc::new(Mutex::new(vec![0; 100]));
    let start = std::time::Instant::now();

    let mut handles = vec![];
    for _ in 0..2 {
        let d = Arc::clone(&data1);
        let h = thread::spawn(move || {
            let _guard = d.lock().unwrap();
            // 잠금 상태에서 오래 걸리는 작업
            let sum: u64 = (0..10_000_000).sum();
            sum
        });
        handles.push(h);
    }

    for h in handles {
        let _ = h.join().unwrap();
    }

    let inefficient_time = start.elapsed();
    println!("  ❌ 전체 잠금: {:?}", inefficient_time);

    // 효율적 잠금 (정말 필요한 부분만 잠금)
    let data2 = Arc::new(Mutex::new(vec![0; 100]));
    let start = std::time::Instant::now();

    let mut handles = vec![];
    for _ in 0..2 {
        let d = Arc::clone(&data2);
        let h = thread::spawn(move || {
            let sum: u64 = (0..10_000_000).sum(); // 잠금 없이 계산

            {
                let mut guard = d.lock().unwrap();
                guard[0] = (sum % 100) as u32; // 정말 필요한 부분만 잠금
            } // ← 블록 끝에서 자동 해제

            sum
        });
        handles.push(h);
    }

    for h in handles {
        let _ = h.join().unwrap();
    }

    let efficient_time = start.elapsed();
    println!("  ✅ 최소 잠금: {:?}", efficient_time);
    println!("  → 약 {}배 더 빠름!",
             inefficient_time.as_millis() as f64 / efficient_time.as_millis().max(1) as f64);
}

// ============================================================================
// Demo 4: Multi-Resource Safety Manager (Practical Scenario)
// ============================================================================
// 다중 자원 안전 관리자 - 실무 시나리오

struct ResourceManager {
    resources: Vec<Arc<SecureResource>>,
}

impl ResourceManager {
    fn new() -> Self {
        ResourceManager {
            resources: vec![],
        }
    }

    fn add_resource(&mut self, id: u32, label: &str, data: &str) {
        self.resources.push(Arc::new(SecureResource::new(id, label, data)));
    }

    fn sorted_resources(&self) -> Vec<Arc<SecureResource>> {
        let mut sorted = self.resources.clone();
        sorted.sort_by_key(|r| r.id); // ID 순서로 정렬
        sorted
    }

    fn update_all(&self, new_value: &str) -> String {
        let sorted = self.sorted_resources();

        let mut report = String::new();
        report.push_str("Resource Update Report:\n");

        for resource in &sorted {
            let mut guard = resource.data.lock().unwrap();
            let old = guard.clone();
            *guard = format!("{}_{}", new_value, resource.id);
            report.push_str(&format!(
                "  {} (ID:{}): {} → {}\n",
                resource.label, resource.id, old, *guard
            ));
        }

        report
    }
}

fn demo_multi_resource_manager() {
    println!("\n=== Demo 4: Multi-Resource Safety Manager ===");
    println!("🏗️  실무 시나리오: 여러 자원을 체계적으로 관리");

    let mut manager = ResourceManager::new();
    manager.add_resource(1, "Config", "config_v1");
    manager.add_resource(3, "Logger", "logger_v1");
    manager.add_resource(2, "Cache", "cache_v1");

    println!("\n📋 자원 목록 (자동으로 ID 순서 정렬):");
    for resource in &manager.sorted_resources() {
        println!("  {} (ID: {})", resource.label, resource.id);
    }

    let manager = Arc::new(manager);

    // 2개 스레드가 동시에 업데이트
    let mut handles = vec![];

    for thread_id in 1..=2 {
        let m = Arc::clone(&manager);
        let h = thread::spawn(move || {
            println!("\n[Thread {}] 모든 자원 업데이트 시작", thread_id);
            let report = m.update_all(&format!("updated_by_thread_{}", thread_id));
            print!("{}", report);
        });
        handles.push(h);
    }

    for h in handles {
        h.join().unwrap();
    }

    println!("✓ Demo 4 완료: ResourceManager로 안전하게 관리됨");
}

// ============================================================================
// Demo 5: Partial Locking (Selective Access)
// ============================================================================
// 부분 잠금 - 필요한 자원만 필요할 때만

fn demo_partial_locking() {
    println!("\n=== Demo 5: Partial Locking ===");
    println!("🎯 선택적 자원 접근: 필요한 것만 잠금");

    let auth = Arc::new(SecureResource::new(1, "Auth", "auth_data"));
    let db = Arc::new(SecureResource::new(2, "DB", "db_data"));
    let cache = Arc::new(SecureResource::new(3, "Cache", "cache_data"));

    // 스레드 1: Auth만 필요
    let a1 = Arc::clone(&auth);
    let h1 = thread::spawn(move || {
        println!("[Thread 1] Auth 업데이트만 필요");
        {
            let mut guard = a1.data.lock().unwrap();
            *guard = "auth_updated_by_t1".to_string();
            println!("  ✓ {} 업데이트", a1.label);
        } // 여기서 바로 해제 - DB, Cache는 완전히 자유로움
        println!("  [Thread 1] Auth 해제됨 - 다른 스레드 진행");
    });

    // 스레드 2: DB + Cache 필요
    let d2 = Arc::clone(&db);
    let c2 = Arc::clone(&cache);
    let h2 = thread::spawn(move || {
        thread::sleep(Duration::from_millis(10)); // 약간 지연

        println!("[Thread 2] DB와 Cache 업데이트 필요");
        {
            let mut lock_db = d2.data.lock().unwrap();
            *lock_db = "db_updated_by_t2".to_string();
            println!("  ✓ {} 업데이트", d2.label);
        } // 여기서 DB 해제

        {
            let mut lock_cache = c2.data.lock().unwrap();
            *lock_cache = "cache_updated_by_t2".to_string();
            println!("  ✓ {} 업데이트", c2.label);
        } // 여기서 Cache 해제

        println!("  [Thread 2] 모든 자원 해제됨");
    });

    h1.join().unwrap();
    h2.join().unwrap();

    println!("✓ Demo 5 완료: 각 스레드가 필요한 자원만 정확히 잠금");
    println!("  → 불필요한 대기 제거, 병렬성 극대화");
}

// ============================================================================
// Demo 6: Integrated Defense System (Complete Life Cycle)
// ============================================================================
// 통합 방어 체계 - 완전한 자원 생명 주기

struct SafeResourceGuard<'a> {
    guard: std::sync::MutexGuard<'a, String>,
    resource_name: &'a str,
}

impl<'a> SafeResourceGuard<'a> {
    fn new(
        guard: std::sync::MutexGuard<'a, String>,
        resource_name: &'a str,
    ) -> Self {
        println!("  🔒 Acquired: {}", resource_name);
        SafeResourceGuard {
            guard,
            resource_name,
        }
    }
}

impl<'a> Drop for SafeResourceGuard<'a> {
    fn drop(&mut self) {
        println!("  🔓 Released: {}", self.resource_name);
    }
}

fn demo_integrated_defense_system() {
    println!("\n=== Demo 6: Integrated Defense System ===");
    println!("🛡️  완전한 방어: 자동 해제 + 라이프사이클 관리");

    let system = Arc::new(SecureResource::new(1, "System", "system_data"));
    let network = Arc::new(SecureResource::new(2, "Network", "network_data"));

    println!("\n[Scenario] 두 스레드가 리소스를 정확하게 관리");

    let s1 = Arc::clone(&system);
    let n1 = Arc::clone(&network);

    let h1 = thread::spawn(move || {
        println!("\n[Thread 1] 작업 시작");
        {
            let guard = s1.data.lock().unwrap();
            let _safe_guard = SafeResourceGuard::new(guard, &s1.label);
            println!("    [Thread 1] 작업 진행 중...");
            thread::sleep(Duration::from_millis(20));
        } // SafeResourceGuard 자동 해제 + drop 호출

        println!("  [Thread 1] 다음 단계로 진행 (System 자유)");

        {
            let guard = n1.data.lock().unwrap();
            let _safe_guard = SafeResourceGuard::new(guard, &n1.label);
            println!("    [Thread 1] Network 작업 진행...");
        }

        println!("  [Thread 1] 완료");
    });

    let s2 = Arc::clone(&system);
    let n2 = Arc::clone(&network);

    let h2 = thread::spawn(move || {
        thread::sleep(Duration::from_millis(10));

        println!("\n[Thread 2] 작업 시작 (ID 기반으로 자동 정렬됨)");
        {
            let guard = s2.data.lock().unwrap();
            let _safe_guard = SafeResourceGuard::new(guard, &s2.label);
            println!("    [Thread 2] System 작업 진행...");
        }

        {
            let guard = n2.data.lock().unwrap();
            let _safe_guard = SafeResourceGuard::new(guard, &n2.label);
            println!("    [Thread 2] Network 작업 진행...");
        }

        println!("  [Thread 2] 완료");
    });

    h1.join().unwrap();
    h2.join().unwrap();

    println!("\n✓ Demo 6 완료: 모든 자원이 안전하게 해제됨");
    println!("  → 자동 해제 + ID 기반 순서 = 완벽한 방어");
}

