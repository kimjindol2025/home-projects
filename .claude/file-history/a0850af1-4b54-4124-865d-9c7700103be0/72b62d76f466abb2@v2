        manager.add_resource(1, "A", "a");
        manager.add_resource(2, "B", "b");

        let sorted = manager.sorted_resources();
        assert_eq!(sorted[0].id, 1);
        assert_eq!(sorted[1].id, 2);
        assert_eq!(sorted[2].id, 3);
    }

    #[test]
    fn test_minimal_lock_scope_performance() {
        let data = Arc::new(Mutex::new(0));
        let mut handles = vec![];

        for _ in 0..4 {
            let d = Arc::clone(&data);
            let h = thread::spawn(move || {
                {
                    let mut guard = d.lock().unwrap();
                    *guard += 1;
                } // 명시적 해제
            });
            handles.push(h);
        }

        for h in handles {
            h.join().unwrap();
        }

        assert_eq!(*data.lock().unwrap(), 4);
    }

