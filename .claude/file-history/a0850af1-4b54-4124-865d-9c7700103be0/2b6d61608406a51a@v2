#[test]
fn test_production_configuration() {
    let mut config = create_config_manager();

    // Configure production environment
    config.set("environment", "production");
    config.set("log_level", "error");
    config.set("encryption", "aes-256");
    config.set("backup_enabled", "true");

    assert_eq!(config.setting_count(), 4);
    assert_eq!(config.get("encryption"), Some(&"aes-256".to_string()));
}

#[test]
fn test_audit_severity_levels() {
    let mut log = create_security_log();

    let severities = vec![
        (AuditLevel::Low, "Low priority"),
        (AuditLevel::Medium, "Medium priority"),
        (AuditLevel::High, "High priority"),
        (AuditLevel::Critical, "Critical priority"),
    ];

    for (severity, description) in severities {
        log.log_event(description, "2026-02-22T10:00:00Z", severity);
    }

    assert_eq!(log.get_events().len(), 4);
    // 1 + 2 + 3 + 4 = 10
    assert_eq!(log.total_severity(), 10);
}

