// Phase 7 v8.1: Integration Tests for PulseAI Library
// Test public API from external perspective

use pulseai_lang::{
    create_vault, create_security_log, create_config_manager,
    verify_access, Vault, SecurityLog, ConfigManager, AuditLevel,
};

// ============================================================================
// [Test 1] Vault Integration
// ============================================================================

#[test]
fn test_vault_creation_and_authentication() {
    // Step 1: Create vault
    let vault = create_vault("secure_password_123");

    // Step 2: Verify authentication success
    assert!(vault.authenticate("secure_password_123"));

    // Step 3: Verify authentication failure
    assert!(!vault.authenticate("wrong_password"));
}

#[test]
fn test_vault_key_length() {
    let vault = create_vault("short");
    assert_eq!(vault.key_length(), 5);

    let vault_long = create_vault("very_long_password");
    assert_eq!(vault_long.key_length(), 18);
}

#[test]
fn test_vault_verification_helper() {
    let vault = create_vault("test_key");
    assert!(verify_access(&vault, "test_key"));
    assert!(!verify_access(&vault, "incorrect"));
}

// ============================================================================
// [Test 2] Security Log Integration
// ============================================================================

#[test]
fn test_security_log_creation() {
    let log = create_security_log();
    assert_eq!(log.get_events().len(), 0);
}

#[test]
fn test_security_log_event_logging() {
    let mut log = create_security_log();

    log.log_event("Login attempt", "2026-02-22T10:00:00Z", AuditLevel::Low);
    log.log_event("Failed auth", "2026-02-22T10:01:00Z", AuditLevel::High);
    log.log_event("Intrusion detected", "2026-02-22T10:02:00Z", AuditLevel::Critical);

    assert_eq!(log.get_events().len(), 3);
    assert_eq!(log.critical_count(), 1);
}

#[test]
fn test_security_log_severity_calculation() {
    let mut log = create_security_log();

    log.log_event("Event 1", "2026-02-22T10:00:00Z", AuditLevel::Low);      // 1
    log.log_event("Event 2", "2026-02-22T10:01:00Z", AuditLevel::Medium);   // 2
    log.log_event("Event 3", "2026-02-22T10:02:00Z", AuditLevel::High);     // 3
    log.log_event("Event 4", "2026-02-22T10:03:00Z", AuditLevel::Critical); // 4

    // Total: 1 + 2 + 3 + 4 = 10
    assert_eq!(log.total_severity(), 10);
}

#[test]
fn test_security_log_filtering() {
    let mut log = create_security_log();

    // Log mixed severity events
    for i in 0..3 {
        log.log_event(
            &format!("Event {}", i),
            &format!("2026-02-22T10:{:02}:00Z", i),
            AuditLevel::Low,
        );
    }

    log.log_event("Critical event", "2026-02-22T10:10:00Z", AuditLevel::Critical);
    log.log_event("Critical event", "2026-02-22T10:11:00Z", AuditLevel::Critical);

    assert_eq!(log.critical_count(), 2);
    assert_eq!(log.get_events().len(), 5);
}

