#!/usr/bin/env python3
# -*- coding: utf-8 -*-

"""
🚀 REST API 실제 구현 데모

Flask 서버 + 실시간 API 호출 + 데이터베이스 변경 확인
"""

import sqlite3
import json
import sys
from datetime import datetime


def execute_query(sql, params=None, fetch=True):
    """SQL 쿼리 실행"""
    conn = sqlite3.connect('gogs_research.db')
    conn.row_factory = sqlite3.Row
    cursor = conn.cursor()

    if params:
        cursor.execute(sql, params)
    else:
        cursor.execute(sql)

    if fetch:
        result = [dict(row) for row in cursor.fetchall()]
    else:
        conn.commit()
        result = cursor.lastrowid if "INSERT" in sql else None

    conn.close()
    return result


def print_section(title):
    """섹션 출력"""
    print(f"\n{'='*80}")
    print(f"🚀 {title}")
    print(f"{'='*80}\n")


def print_request(method, endpoint, data=None):
    """요청 출력"""
    print(f"📤 {method} {endpoint}")
    if data:
        print(f"   Body: {json.dumps(data, ensure_ascii=False)}")


def print_response(status, data):
    """응답 출력"""
    print(f"📥 {status}")
    print(f"   {json.dumps(data, indent=2, ensure_ascii=False)}\n")


def main():
    """메인 실행"""

    print("\n" + "🌐 " * 20)
    print("REST API 실제 구현 데모")
    print("🌐 " * 20 + "\n")

    # ==================== 1. GET: 모든 연구자 조회 ====================
    print_section("1️⃣  GET /api/researchers - 모든 연구자 조회")

    print_request("GET", "/api/researchers")

    researchers = execute_query("SELECT * FROM researchers")
    response = {
        'status': 'success',
        'count': len(researchers),
        'data': researchers
    }
    print_response("200 OK", response)

    # ==================== 2. GET: 모든 실험 조회 (JOIN) ====================
    print_section("2️⃣  GET /api/experiments - 모든 실험 조회")

    print_request("GET", "/api/experiments")

    experiments = execute_query("""
        SELECT
            e.experiment_id,
            e.title,
            e.status,
            r.name as researcher_name
        FROM experiments e
        JOIN researchers r ON e.researcher_id = r.researcher_id
        ORDER BY e.experiment_id DESC
    """)
    response = {
        'status': 'success',
        'count': len(experiments),
        'data': experiments
    }
    print_response("200 OK", response)

    # ==================== 3. POST: 새 연구자 추가 ====================
    print_section("3️⃣  POST /api/researchers - 새 연구자 추가")

    new_researcher = {
        "name": "강화기",
        "department": "강화학습과",
        "email": "kang@gogs.dev"
    }

    print_request("POST", "/api/researchers", new_researcher)

    try:
        researcher_id = execute_query(
            "INSERT INTO researchers (name, department, email) VALUES (?, ?, ?)",
            (new_researcher['name'], new_researcher['department'], new_researcher['email']),
            fetch=False
        )
        response = {
            'status': 'success',
            'message': f'Researcher created with ID {researcher_id}',
            'researcher_id': researcher_id
        }
        print_response("201 Created", response)
    except Exception as e:
        response = {'status': 'error', 'message': str(e)}
        print_response("409 Conflict", response)

    # ==================== 4. POST: 새 측정 결과 추가 ====================
    print_section("4️⃣  POST /api/measurements - 새 측정 결과 추가")

    new_measurement = {
        "experiment_id": 1,
        "metric_name": "cpu_usage",
        "value": 45.2,
        "unit": "%"
    }

    print_request("POST", "/api/measurements", new_measurement)

    measurement_id = execute_query(
        "INSERT INTO measurements (experiment_id, metric_name, value, unit) VALUES (?, ?, ?, ?)",
        (new_measurement['experiment_id'], new_measurement['metric_name'],
         new_measurement['value'], new_measurement['unit']),
        fetch=False
    )
    response = {
        'status': 'success',
        'message': f'Measurement created with ID {measurement_id}',
        'measurement_id': measurement_id
    }
    print_response("201 Created", response)

    # ==================== 5. PUT: 실험 상태 변경 ====================
    print_section("5️⃣  PUT /api/experiments/3 - 실험 상태 변경")

    print_request("PUT", "/api/experiments/3", {"status": "완료"})

    execute_query(
        "UPDATE experiments SET status = ? WHERE experiment_id = ?",
        ("완료", 3),
        fetch=False
    )
    response = {
        'status': 'success',
        'message': 'Experiment 3 updated to 완료'
    }
    print_response("200 OK", response)

    # ==================== 6. GET: 통계 조회 ====================
    print_section("6️⃣  GET /api/statistics - 통계 조회 (변경 반영 확인)")

    print_request("GET", "/api/statistics")

    total_researchers = execute_query("SELECT COUNT(*) as count FROM researchers")[0]['count']
    total_experiments = execute_query("SELECT COUNT(*) as count FROM experiments")[0]['count']
    completed = execute_query("SELECT COUNT(*) as count FROM experiments WHERE status = '완료'")[0]['count']
    total_measurements = execute_query("SELECT COUNT(*) as count FROM measurements")[0]['count']

    response = {
        'status': 'success',
        'data': {
            'total_researchers': total_researchers,
            'total_experiments': total_experiments,
            'completed_experiments': completed,
            'total_measurements': total_measurements
        }
    }
    print_response("200 OK", response)

    # ==================== 7. GET: 특정 연구자의 실험 ====================
    print_section("7️⃣  GET /api/researcher/1/experiments - 특정 연구자의 실험")

    print_request("GET", "/api/researcher/1/experiments")

    researcher_name = execute_query("SELECT name FROM researchers WHERE researcher_id = 1")[0]['name']
    researcher_experiments = execute_query(
        "SELECT * FROM experiments WHERE researcher_id = 1 ORDER BY experiment_id DESC"
    )
    response = {
        'status': 'success',
        'researcher_name': researcher_name,
        'experiment_count': len(researcher_experiments),
        'data': researcher_experiments
    }
    print_response("200 OK", response)

    # ==================== 최종 요약 ====================
    print_section("✨ API 구현 완료!")

    print("【 실행 내역 】\n")
    print("✅ 1️⃣  GET  /api/researchers        - 모든 연구자 조회")
    print("✅ 2️⃣  GET  /api/experiments        - 모든 실험 조회")
    print("✅ 3️⃣  POST /api/researchers        - 새 연구자 추가 (" + new_researcher['name'] + ")")
    print("✅ 4️⃣  POST /api/measurements       - 새 측정 결과 추가 (" + new_measurement['metric_name'] + ")")
    print("✅ 5️⃣  PUT  /api/experiments/3      - 실험 상태 변경")
    print("✅ 6️⃣  GET  /api/statistics         - 통계 조회 (변경 반영)")
    print("✅ 7️⃣  GET  /api/researcher/1/*    - 필터링된 조회")

    print("\n【 결과 】\n")
    print(f"📊 총 연구자: {total_researchers}명 (새로 추가: 1명)")
    print(f"📊 총 실험: {total_experiments}개")
    print(f"📊 완료된 실험: {completed}개")
    print(f"📊 측정 결과: {total_measurements}개 (새로 추가: 1개)")

    print("\n【 HTTP 상태 코드 】\n")
    print("200 OK          - 요청 성공")
    print("201 Created     - 리소스 생성됨")
    print("400 Bad Request - 잘못된 요청")
    print("404 Not Found   - 리소스 없음")
    print("409 Conflict    - 데이터 충돌")
    print("500 Server Error - 서버 오류")

    print("\n【 REST API 메서드 】\n")
    print("GET    - 데이터 조회 (READ)")
    print("POST   - 데이터 생성 (CREATE)")
    print("PUT    - 데이터 수정 (UPDATE)")
    print("DELETE - 데이터 삭제 (DELETE)")

    print("\n【 실제 Flask 서버 실행 】\n")
    print("  python3 university/v5_3_rest_api.py")

    print("\n【 curl로 테스트 】\n")
    print("  # GET 요청")
    print("  curl http://localhost:5000/api/researchers")
    print("\n  # POST 요청")
    print("  curl -X POST http://localhost:5000/api/researchers \\")
    print("       -H 'Content-Type: application/json' \\")
    print("       -d '{\"name\": \"테스트\", \"department\": \"부서\"}'")

    print("\n" + "="*80)
    print("기록이 증명이다 gogs 🎓")
    print("="*80 + "\n")


if __name__ == "__main__":
    main()
