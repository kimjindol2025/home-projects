#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_stage0_compilation() {
        let mut verifier = BootstrapVerifier::new();
        let source = "fn main() { return 42; }";

        let result = verifier.compile_stage0(source);

        assert_eq!(result.stage, BootstrapStage::Stage0);
        assert!(result.bytecode_size > 0);
        assert_eq!(result.source_length, source.len());
    }

    #[test]
    fn test_stage1_compilation() {
        let mut verifier = BootstrapVerifier::new();
        let source = "fn main() { return 42; }";

        verifier.compile_stage0(source);
        let result = verifier.compile_stage1(source);

        assert_eq!(result.stage, BootstrapStage::Stage1);
        assert!(result.bytecode_size > 0);
    }

    #[test]
    fn test_stage2_compilation() {
        let mut verifier = BootstrapVerifier::new();
        let source = "fn main() { return 42; }";

        verifier.compile_stage0(source);
        verifier.compile_stage1(source);
        let result = verifier.compile_stage2(source);

        assert_eq!(result.stage, BootstrapStage::Stage2);
        assert!(result.bytecode_size > 0);
    }

    #[test]
    fn test_fixpoint_verification() {
        let mut verifier = BootstrapVerifier::new();
        let source = "fn main() { return 42; }";

        verifier.compile_stage0(source);
        verifier.compile_stage1(source);
        verifier.compile_stage2(source);

        let fixpoint = verifier.verify_fixpoint();
        assert!(fixpoint.success);
        assert_eq!(fixpoint.stage1_hash, fixpoint.stage2_hash);
    }

    #[test]
    fn test_hash_calculation() {
        let bytecode1 = simulate_compile("test", "rust");
        let bytecode2 = simulate_compile("test", "rust");

        let hash1 = calculate_hash(&bytecode1);
        let hash2 = calculate_hash(&bytecode2);

        assert_eq!(hash1, hash2);
    }

    #[test]
    fn test_different_source_different_hash() {
        let bytecode1 = simulate_compile("source1", "rust");
        let bytecode2 = simulate_compile("source2", "rust");

        let hash1 = calculate_hash(&bytecode1);
        let hash2 = calculate_hash(&bytecode2);

        assert_ne!(hash1, hash2);
    }

    #[test]
    fn test_bootstrap_report_generation() {
        let mut verifier = BootstrapVerifier::new();
        let source = "fn main() {}";

        verifier.compile_stage0(source);
        verifier.compile_stage1(source);
        verifier.compile_stage2(source);

        let report = verifier.generate_report();

        assert!(report.stage0.is_some());
        assert!(report.stage1.is_some());
        assert!(report.stage2.is_some());
        assert!(report.fixpoint.success);
    }

    #[test]
    fn test_compilation_time_simulation() {
        let time1 = simulate_compilation_time(100);
        let time2 = simulate_compilation_time(1000);

        assert!(time2 > time1);
    }

    #[test]
    fn test_stage_display() {
        assert_eq!(format!("{}", BootstrapStage::Stage0), "Stage 0 (Rust)");
        assert_eq!(format!("{}", BootstrapStage::Stage1), "Stage 1 (Gogs via Rust)");
        assert_eq!(format!("{}", BootstrapStage::Stage2), "Stage 2 (Gogs via Gogs)");
    }

    #[test]
    fn test_fnv_hash_consistency() {
        let input = "test_string";
        let hash1 = fnv_hash(input);
        let hash2 = fnv_hash(input);

        assert_eq!(hash1, hash2);
    }
}
