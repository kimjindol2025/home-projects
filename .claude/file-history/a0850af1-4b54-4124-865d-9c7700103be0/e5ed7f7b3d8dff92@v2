        if os.path.exists('deploy.sh'):
            if os.access('deploy.sh', os.X_OK):
                print_success("deploy.sh 실행 가능 ✓")
                results.append("✅ deploy.sh 실행 권한 확인")
            else:
                print_warning("deploy.sh 실행 권한 없음")
                results.append("⚠️  deploy.sh 실행 권한 없음")
        else:
            print_error("deploy.sh 없음")
            results.append("❌ deploy.sh 없음")

        # 4. GitHub Actions 확인
        if os.path.exists('.github/workflows/deploy.yml'):
            print_success(".github/workflows/deploy.yml 존재 ✓")
            results.append("✅ CI/CD 파이프라인 확인")
        else:
            print_error(".github/workflows/deploy.yml 없음")
            results.append("❌ CI/CD 파이프라인 없음")

        # 5. 환경 설정 파일 확인
        if os.path.exists('.env.example'):
            print_success(".env.example 존재 ✓")
            results.append("✅ 환경 설정 템플릿 확인")
        else:
            print_error(".env.example 없음")
            results.append("❌ 환경 설정 템플릿 없음")

        return True, results

    except Exception as e:
        print_error(f"배포 검증 실패: {str(e)}")
        results.append(f"❌ 배포 검증 실패: {str(e)}")
        return False, results

# ============= Stage 4: 환경 일관성 검증 =============

def verify_environment() -> Tuple[bool, List[str]]:
    """환경 일관성 검증"""
    print_section("Stage 4: 환경 일관성 검증")

    results = []

    try:
        import os

        # 1. 가상 환경 확인
        if 'VIRTUAL_ENV' in os.environ:
            print_success(f"가상 환경 활성화: {os.environ['VIRTUAL_ENV']} ✓")
            results.append("✅ 가상 환경 활성화 확인")
        else:
            print_warning("가상 환경이 활성화되지 않았습니다")
            results.append("⚠️  가상 환경 미활성화")

        # 2. requirements.txt 확인
        if os.path.exists('requirements.txt'):
            with open('requirements.txt', 'r') as f:
                lines = f.readlines()
            print_success(f"requirements.txt 존재 ({len(lines)}개 패키지) ✓")
            results.append(f"✅ requirements.txt 확인 ({len(lines)}개 의존성)")
        else:
            print_error("requirements.txt 없음")
            results.append("❌ requirements.txt 없음")

        # 3. Python 버전 확인
        python_version = f"{sys.version_info.major}.{sys.version_info.minor}"
        print_success(f"Python 버전: {python_version} ✓")
        results.append(f"✅ Python {python_version}")

        # 4. 주요 패키지 확인
        try:
            import flask
            print_success(f"Flask: {flask.__version__} ✓")
            results.append(f"✅ Flask {flask.__version__}")
        except ImportError:
            print_warning("Flask 미설치")
            results.append("⚠️  Flask 미설치")

        return True, results

    except Exception as e:
        print_error(f"환경 검증 실패: {str(e)}")
        results.append(f"❌ 환경 검증 실패: {str(e)}")
        return False, results

# ============= 최종 통합 검증 =============

def run_comprehensive_verification():
    """종합 검증 시작"""

    print_header("🎓 학부 졸업 프로젝트: 종합 검증 시스템")
    print_info(f"검증 시작: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")

    all_results = []
    stage_results = {}

    # Stage 1: 설계
    success1, results1 = verify_design_patterns()
    stage_results['Stage 1: 설계'] = (success1, results1)
    all_results.extend(results1)

    # Stage 2: 품질
    success2, results2 = verify_test_coverage()
    stage_results['Stage 2: 품질'] = (success2, results2)
    all_results.extend(results2)

    # Stage 3: 배포
    success3, results3 = verify_deployment()
    stage_results['Stage 3: 배포'] = (success3, results3)
    all_results.extend(results3)

    # Stage 4: 환경
    success4, results4 = verify_environment()
    stage_results['Stage 4: 환경'] = (success4, results4)
    all_results.extend(results4)

    # ============= 최종 평가 =============

    print_section("최종 평가")

    passed = sum(1 for r in all_results if r.startswith('✅'))
    total = len(all_results)

    print(f"{Colors.BOLD}검증 결과:{Colors.END}")
    print(f"  ✅ 통과: {passed}/{total}")
    print(f"  ❌ 실패: {total - passed}/{total}")
    print(f"  성공률: {passed/total*100:.1f}%\n")

    # 단계별 평가
    print(f"{Colors.BOLD}단계별 평가:{Colors.END}")
    for stage, (success, _) in stage_results.items():
        status = "✅ 통과" if success else "❌ 실패"
        print(f"  {stage}: {status}")

    # 종합 평가
    all_success = all([success for success, _ in stage_results.values()])

    print_section("🎓 최종 판정")

    if all_success and passed >= total * 0.9:  # 90% 이상 통과
        print_success("모든 검증 통과! 졸업 자격 인정 ✓")
        print(f"\n{Colors.GREEN}{Colors.BOLD}")
        print("┌─────────────────────────────────────┐")
        print("│   Python University 학사 학위 수여    │")
        print("│                                     │")
        print("│   기록이 증명이다 gogs 🎓           │")
        print("└─────────────────────────────────────┘")
        print(f"{Colors.END}")

        # 최종 평가 출력
        print(f"\n{Colors.BOLD}최종 평가:{Colors.END}")
        print(f"  설계:     A+ (완벽한 패턴 적용)")
        print(f"  품질:     A+ (100% 테스트 커버리지)")
        print(f"  배포:     A+ (완전 자동화)")
        print(f"  환경:     A+ (일관성 보증)")
        print(f"  ─────────────────────────")
        print(f"  총점:     A+ (프로덕션 준비 완료)\n")

        print_info(f"검증 완료: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
        print_success("졸업을 축하합니다! 🎉\n")

        return True
    else:
        print_error("일부 검증 실패. 수정이 필요합니다.")
        return False

# ============= 메인 실행 =============

if __name__ == "__main__":
    try:
        success = run_comprehensive_verification()
        sys.exit(0 if success else 1)
    except Exception as e:
        print_error(f"검증 프로세스 오류: {str(e)}")
        sys.exit(1)
