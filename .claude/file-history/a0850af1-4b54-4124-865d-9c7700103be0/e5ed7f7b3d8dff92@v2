    results = []

    try:
        import os

        # 1. Dockerfile 확인
        if os.path.exists('Dockerfile.optimized'):
            print_success("Dockerfile.optimized 존재 ✓")
            results.append("✅ Dockerfile.optimized 확인")
        else:
            print_error("Dockerfile.optimized 없음")
            results.append("❌ Dockerfile.optimized 없음")

        # 2. docker-compose 확인
        if os.path.exists('docker-compose.optimized.yml'):
            print_success("docker-compose.optimized.yml 존재 ✓")
            results.append("✅ docker-compose.optimized.yml 확인")
        else:
            print_error("docker-compose.optimized.yml 없음")
            results.append("❌ docker-compose.optimized.yml 없음")

