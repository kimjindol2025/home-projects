import math
import random
import json
from datetime import datetime, timedelta

# 센서 데이터 수집
sensors = []
for i in range(3):
    sensor_data = {
        "id": f"SENSOR_{i+1}",
        "timestamp": datetime.now().isoformat(),
        "temperature": round(20 + random.gauss(0, 2), 2),  # 평균 20°C, 표준편차 2
        "humidity": round(50 + random.gauss(0, 5), 2),     # 평균 50%, 표준편차 5
    }
    sensors.append(sensor_data)

print("📊 센서 데이터 수집:")
print("-" * 80)
for sensor in sensors:
    print(f"ID: {sensor['id']}")
    print(f"  온도: {sensor['temperature']}°C")
    print(f"  습도: {sensor['humidity']}%")
    print()

# 데이터 분석
temps = [s["temperature"] for s in sensors]
avg_temp = sum(temps) / len(temps)
max_temp = max(temps)
min_temp = min(temps)
temp_variance = math.sqrt(sum((t - avg_temp)**2 for t in temps) / len(temps))

print("📈 데이터 분석:")
print("-" * 80)
print(f"평균 온도: {avg_temp:.2f}°C")
print(f"최고 온도: {max_temp:.2f}°C")
print(f"최저 온도: {min_temp:.2f}°C")
print(f"표준편차: {temp_variance:.2f}°C")

# 데이터 저장
report = {
    "report_time": datetime.now().isoformat(),
    "sensors": sensors,
    "analysis": {
        "avg_temperature": round(avg_temp, 2),
        "max_temperature": max_temp,
        "min_temperature": min_temp,
        "std_deviation": round(temp_variance, 2)
    }
}

print()
print("💾 JSON 형식으로 저장할 리포트:")
print("-" * 80)
print(json.dumps(report, indent=2, ensure_ascii=False)[:300] + "...")

