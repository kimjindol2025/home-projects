// ============================================================================
// [1] 단순 함수 (Simple Functions)
// ============================================================================
//
// 함수의 기본: 입력을 받아 처리한 후 결과를 반환합니다.
//
fn simple_functions() {
    println!("[1] 단순 함수");
    println!("────────────────────────────────────────────────────────────");

    // 함수 1: 상수 반환
    {
        fn get_pi() -> f64 {
            3.14159
        }

        let pi = get_pi();
        println!("✓ get_pi(): {}", pi);
    }

    // 함수 2: 단순 계산
    {
        fn add_one(x: i32) -> i32 {
            x + 1
        }

        let result = add_one(10);
