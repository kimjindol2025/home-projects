}

// ============================================================================
// [2] 함수 서명 (Function Signature)
// ============================================================================
//
// fn name(param: Type) -> ReturnType { body }
//
fn function_signatures() {
    println!("[2] 함수 서명");
    println!("────────────────────────────────────────────────────────────");

    // 서명 1: 단일 매개변수
    {
        fn square(x: i32) -> i32 {
            x * x
        }

        println!("✓ square(5): {}", square(5));
    }

    // 서명 2: 복수 매개변수
    {
        fn add(a: i32, b: i32) -> i32 {
            a + b
        }

        println!("✓ add(3, 4): {}", add(3, 4));
    }

    // 서명 3: 매개변수 없음
    {
        fn get_answer() -> i32 {
            42
        }

        println!("✓ get_answer(): {}", get_answer());
    }

    // 서명 4: 반환값 없음 (Unit type)
    {
        fn print_info() {
            println!("✓ print_info(): 반환값 없음");
        }

        print_info();
    }

    println!();
}

// ============================================================================
// [3] 반환값 (Return Types)
// ============================================================================
//
// 마지막 표현식이 자동으로 반환됩니다 (세미콜론 없을 때).
//
fn return_types() {
    println!("[3] 반환값");
    println!("────────────────────────────────────────────────────────────");

    // 반환 1: 암묵적 반환 (권장)
    {
        fn double(x: i32) -> i32 {
            x * 2  // 세미콜론 없음 → 반환
        }

        println!("✓ 암묵적 반환: double(5) = {}", double(5));
    }

    // 반환 2: 명시적 반환 (return 키워드)
    {
        fn triple(x: i32) -> i32 {
            return x * 3;  // return 키워드 + 세미콜론
        }

        println!("✓ 명시적 반환: triple(5) = {}", triple(5));
    }

    // 반환 3: if 표현식으로 반환
    {
        fn abs_value(x: i32) -> i32 {
            if x < 0 {
                -x
            } else {
                x
            }
        }

        println!("✓ if 표현식: abs_value(-10) = {}", abs_value(-10));
    }

    println!();
}

// ============================================================================
// [4] 복수 매개변수 (Multiple Parameters)
// ============================================================================
//
// 모든 매개변수의 타입을 명시해야 합니다.
//
fn multiple_parameters() {
    println!("[4] 복수 매개변수");
    println!("────────────────────────────────────────────────────────────");

    // 매개변수 1: 두 개
    {
        fn max(a: i32, b: i32) -> i32 {
            if a > b {
                a
            } else {
                b
            }
        }

        println!("✓ max(10, 20): {}", max(10, 20));
    }

    // 매개변수 2: 세 개
    {
        fn sum_three(a: i32, b: i32, c: i32) -> i32 {
            a + b + c
        }

        println!("✓ sum_three(1, 2, 3): {}", sum_three(1, 2, 3));
    }

    // 매개변수 3: 혼합 타입
    {
        fn multiply_and_add(x: i32, y: i32, z: f64) -> f64 {
            (x * y) as f64 + z
        }

        println!("✓ multiply_and_add(3, 4, 0.5): {}", multiply_and_add(3, 4, 0.5));
    }

    println!();
}

// ============================================================================
// [5] 재귀 함수 (Recursive Functions)
// ============================================================================
//
// 함수가 자신을 호출합니다.
// 반드시 기저 사례(Base Case)가 있어야 합니다.
//
fn recursive_functions() {
    println!("[5] 재귀 함수");
    println!("────────────────────────────────────────────────────────────");

    // 재귀 1: 카운트다운
    {
        fn countdown(n: i32) {
            if n <= 0 {
                println!("✓ 카운트다운 완료!");
                return;
            }
            println!("  {}", n);
            countdown(n - 1);
        }

        countdown(3);
    }

    // 재귀 2: 팩토리얼
    {
        fn factorial(n: i32) -> i32 {
            if n <= 1 {
                1  // 기저 사례
            } else {
                n * factorial(n - 1)  // 재귀
            }
        }

        println!("✓ factorial(5): {}", factorial(5));
    }

    // 재귀 3: 피보나치
    {
        fn fibonacci(n: i32) -> i32 {
            if n <= 1 {
                n  // 기저 사례
            } else {
                fibonacci(n - 1) + fibonacci(n - 2)  // 재귀
            }
        }

        println!("✓ fibonacci(6): {}", fibonacci(6));
    }

    println!();
}

// ============================================================================
// [6] 함수 조합 (Function Composition)
// ============================================================================
//
// 여러 함수를 조합하여 복잡한 로직을 만듭니다.
//
fn function_composition() {
    println!("[6] 함수 조합");
    println!("────────────────────────────────────────────────────────────");

    // 조합 1: 순차적 호출
    {
        fn increment(x: i32) -> i32 {
            x + 1
        }

        fn double(x: i32) -> i32 {
            x * 2
        }

        let result = double(increment(5));  // (5+1)*2 = 12
        println!("✓ double(increment(5)): {}", result);
    }

    // 조합 2: 함수 체인
    {
        fn is_even(n: i32) -> bool {
            n % 2 == 0
        }

        fn count_even_to(limit: i32) -> i32 {
            let mut count = 0;
            for i in 1..=limit {
                if is_even(i) {
                    count += 1;
                }
            }
            count
        }

        println!("✓ count_even_to(10): {}", count_even_to(10));
    }

    // 조합 3: 헬퍼 함수
    {
        fn is_prime(n: i32) -> bool {
            if n < 2 {
                return false;
            }
            for i in 2..n {
                if n % i == 0 {
                    return false;
                }
            }
            true
        }

        fn count_primes_to(limit: i32) -> i32 {
            let mut count = 0;
            for i in 2..=limit {
                if is_prime(i) {
                    count += 1;
                }
            }
            count
        }

        println!("✓ count_primes_to(20): {}", count_primes_to(20));
    }

    println!();
}

// ============================================================================
// [7] 순수 함수 vs 부작용 함수 (Pure vs Impure)
// ============================================================================
//
// 순수 함수: 같은 입력 → 항상 같은 결과 (부작용 없음)
// 부작용 함수: 외부 상태 변경 (출력, 파일 작성 등)
//
fn pure_vs_impure() {
    println!("[7] 순수 함수 vs 부작용 함수");
    println!("────────────────────────────────────────────────────────────");

    // 순수 함수 1: 계산만 수행
    {
        fn add(a: i32, b: i32) -> i32 {
            a + b
        }

        println!("✓ 순수: add(3, 4) = {} (항상 7)", add(3, 4));
    }

    // 부작용 함수 1: 출력
    {
        fn print_sum(a: i32, b: i32) {
            println!("✓ 부작용: sum = {}", a + b);
        }

        print_sum(3, 4);
    }

    // 혼합: 순수 함수로 계산, 부작용 함수로 출력
    {
        fn calculate(a: i32, b: i32) -> i32 {
            a * b  // 순수: 계산만
        }

        fn report_result(label: &str, result: i32) {
            println!("✓ 혼합: {} = {}", label, result);  // 부작용: 출력
        }

        let result = calculate(5, 3);
        report_result("5 * 3", result);
    }

    println!();
}

// ============================================================================
// [8] 함수 설계 원칙 (Function Design Principles)
// ============================================================================
//
// 1. 단일 책임 (Single Responsibility)
// 2. 명확한 이름 (Clear Naming)
// 3. 작은 크기 (Small Size)
// 4. 테스트 가능성 (Testability)
//
fn function_design_principles() {
    println!("[8] 함수 설계 원칙");
    println!("────────────────────────────────────────────────────────────");

    // 원칙 1: 단일 책임
    {
        fn validate_age(age: i32) -> bool {
            age >= 18
        }

        fn validate_name(name: &str) -> bool {
            !name.is_empty()
        }

        println!("✓ 원칙 1: 각 함수는 하나의 책임");
        println!("  validate_age(25): {}", validate_age(25));
        println!("  validate_name(\"Alice\"): {}", validate_name("Alice"));
    }

    // 원칙 2: 명확한 이름
    {
        fn calculate_circle_area(radius: i32) -> f64 {
            3.14159 * (radius as f64) * (radius as f64)
        }

        println!("✓ 원칙 2: 의도가 명확한 함수명");
        println!("  calculate_circle_area(5): {:.2}", calculate_circle_area(5));
    }

    // 원칙 3: 작은 크기
    {
        fn is_valid_password(password: &str) -> bool {
            // 길이 확인
            if password.len() < 8 {
                return false;
            }

            // 숫자 포함 확인
            password.chars().any(|c| c.is_numeric())
        }

        println!("✓ 원칙 3: 함수는 한 화면에 보일 정도로 작음");
        println!("  is_valid_password(\"secure123\"): {}", is_valid_password("secure123"));
    }

    // 원칙 4: 테스트 가능성
    {
        fn absolute_value(x: i32) -> i32 {
            if x < 0 {
                -x
            } else {
                x
            }
        }

        println!("✓ 원칙 4: 테스트 가능한 순수 함수");
        assert_eq!(absolute_value(-5), 5);
        assert_eq!(absolute_value(5), 5);
        println!("  absolute_value() 테스트 통과");
    }

    println!();
}

