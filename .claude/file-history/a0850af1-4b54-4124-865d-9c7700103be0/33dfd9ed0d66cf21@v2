def print_tree(d, indent=0):
    for key, value in d.items():
        print("  " * indent + f"📁 {key}")
        if isinstance(value, dict):
            print_tree(value, indent + 1)
        elif isinstance(value, list):
            for item in value:
                print("  " * (indent + 1) + f"📄 {item}")

