@dataclass
class Document:
    """검색 문서"""
    id: int
    title: str
    content: str
    ranking_score: float = 0.0


class SearchEngine:
    """프로덕션 검색 엔진"""

    def __init__(self):
        self.documents: Dict[int, Document] = {}
        self.inverted_index: Dict[str, Set[int]] = defaultdict(set)

    def add_document(self, doc: Document) -> None:
        """O(n) - 단어별 인덱싱"""
        self.documents[doc.id] = doc

        # 역 인덱스 구성
        words = set((doc.title + " " + doc.content).lower().split())
        for word in words:
            self.inverted_index[word].add(doc.id)

    def search(self, query: str, top_k: int = 5) -> List[Document]:
        """O(log n) - 해시 테이블 + 역 인덱스"""
        query_words = query.lower().split()

        # 모든 단어를 포함하는 문서 찾기
        result_ids = None
        for word in query_words:
            word_docs = self.inverted_index.get(word, set())
            if result_ids is None:
                result_ids = word_docs
            else:
                result_ids &= word_docs  # 교집합

        if not result_ids:
            return []

        # 점수 계산 및 정렬
        results = []
        for doc_id in result_ids:
            doc = self.documents[doc_id]
            # 단순 점수: 쿼리 단어 개수
            score = sum(1 for word in query_words if word in doc.title.lower())
            doc.ranking_score = score
            results.append(doc)

        # 상위 k개 반환
        return sorted(results, key=lambda x: x.ranking_score, reverse=True)[:top_k]


class RecommendationSystem:
    """협필터링 기반 추천 시스템"""

    def __init__(self):
        self.user_preferences: Dict[int, Dict[str, float]] = defaultdict(dict)

    def record_interaction(self, user_id: int, item_name: str, score: float) -> None:
        """사용자의 아이템 평점 기록: O(1)"""
        self.user_preferences[user_id][item_name] = score

    def recommend_items(self, user_id: int, top_k: int = 5) -> List[Tuple[str, float]]:
        """협필터링 기반 추천: O(n*m)"""
        if user_id not in self.user_preferences:
            return []

        # 모든 사용자의 선호도 평균 계산
        all_items: Dict[str, List[float]] = defaultdict(list)

        for uid, preferences in self.user_preferences.items():
            for item, score in preferences.items():
                all_items[item].append(score)

        # 사용자가 평가하지 않은 아이템 추천
        user_items = set(self.user_preferences[user_id].keys())
        recommendations = []

        for item, scores in all_items.items():
            if item not in user_items:
                avg_score = sum(scores) / len(scores)
                recommendations.append((item, avg_score))

        # 상위 k개 반환
        return sorted(recommendations, key=lambda x: x[1], reverse=True)[:top_k]


