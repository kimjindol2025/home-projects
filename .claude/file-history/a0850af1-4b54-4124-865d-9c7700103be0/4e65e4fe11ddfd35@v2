    scheduler = TaskScheduler()
    tasks = [
        (3, "이메일 백그라운드 작업"),
        (1, "시스템 critical 패치"),
        (4, "로그 정리"),
        (2, "데이터베이스 백업"),
        (0, "사용자 인터랙션"),
    ]

    print("\n📋 작업 큐:")
    for priority, task in tasks:
        scheduler.add_task(priority, task)
        print(f"   - [Priority {priority}] {task}")

    print("\n⚙️ 실행 순서 (우선순위 높은 것부터):")
    task_order = 1
    while True:
        task = scheduler.execute_next_task()
        if not task:
            break
        print(f"   {task_order}. {task}")
        task_order += 1


