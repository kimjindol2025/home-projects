def linear_search(data: List[int], target: int) -> int:
    """선형 탐색: O(n)"""
    for i in range(len(data)):
        if data[i] == target:
            return i
    return -1


def binary_search(data: List[int], target: int) -> int:
    """이진 탐색: O(log n) - 정렬된 데이터 전제"""
    low, high = 0, len(data) - 1

    while low <= high:
        mid = (low + high) // 2
        if data[mid] == target:
            return mid
        elif data[mid] < target:
            low = mid + 1
        else:
            high = mid - 1

    return -1


