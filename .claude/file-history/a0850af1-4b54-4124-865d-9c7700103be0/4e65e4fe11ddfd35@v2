    print("\n📊 피보나치 수열 성능 비교:")
    print(f"\n{'n':<5} | {'Naive O(2^n)':<20} | {'DP O(n)':<20} | 속도향상")
    print("-" * 55)

    test_values = [10, 20, 30, 35]

    for n in test_values:
        # Naive 방식
        start = time.perf_counter()
        result_naive = fibonacci_naive(n)
        naive_time = time.perf_counter() - start

        # DP 방식
        start = time.perf_counter()
        result_dp = fibonacci_dp(n)
        dp_time = time.perf_counter() - start

        speedup = naive_time / (dp_time + 1e-8)

        print(f"{n:<5} | {naive_time*1000:>15.3f}ms | {dp_time*1000:>15.6f}ms | {speedup:>8.0f}x")

    print("\n📊 배낭 문제 (Knapsack): 가치 최대화")
    weights = [2, 3, 4, 5]
    values = [3, 4, 5, 6]
    capacity = 8

    max_value = knapsack_dp(weights, values, capacity)
    print(f"   배낭 용량: {capacity}")
    print(f"   아이템 무게: {weights}")
    print(f"   아이템 가치: {values}")
    print(f"   → 최대 가치: {max_value}")
    print("   💡 동적계획법은 과거의 계산을 기억해서 미래를 빠르게 계산!")


