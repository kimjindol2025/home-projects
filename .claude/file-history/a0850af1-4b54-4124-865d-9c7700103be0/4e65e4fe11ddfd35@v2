class TaskScheduler:
    """CPU 스케줄링: Priority Queue 활용 예제"""

    def __init__(self):
        self.tasks: List[Tuple[int, str]] = []  # (priority, task_name)

    def add_task(self, priority: int, task_name: str) -> None:
        """O(log n) - Heap 삽입"""
        heapq.heappush(self.tasks, (priority, task_name))

    def execute_next_task(self) -> Optional[str]:
        """O(log n) - Heap 추출"""
        if self.tasks:
            _, task = heapq.heappop(self.tasks)
            return task
        return None

    def get_high_priority_tasks(self, k: int) -> List[str]:
        """O(k log n) - 우선순위 높은 k개 작업"""
        temp = []
        result = []

        for _ in range(min(k, len(self.tasks))):
            if self.tasks:
                priority, task = heapq.heappop(self.tasks)
                result.append(task)
                temp.append((priority, task))

        # 원래 상태로 복구
        for item in temp:
            heapq.heappush(self.tasks, item)

        return result


def demonstrate_priority_queue():
    """Priority Queue의 실무 예제"""
    print("\n" + "="*80)
    print("STAGE 6: Heap과 Priority Queue")
    print("="*80)

