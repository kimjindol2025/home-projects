class ComplexityType(Enum):
    """Big-O 표기법의 분류"""
    CONSTANT = "O(1)"           # Hash Table 접근
    LOGARITHMIC = "O(log n)"    # Binary Search
    LINEAR = "O(n)"             # Linear Scan
    LINEARITHMIC = "O(n log n)" # Merge Sort
    QUADRATIC = "O(n^2)"        # Bubble Sort (위험)
    CUBIC = "O(n^3)"            # 3중 반복문 (매우 위험)
    EXPONENTIAL = "O(2^n)"      # 모든 부분집합 탐색 (불가능)
    FACTORIAL = "O(n!)"         # 모든 순열 탐색 (완전히 불가능)


@dataclass
class AlgorithmAnalysis:
    """알고리즘의 시간/공간 복잡도 분석"""
    name: str
    time_complexity: ComplexityType
    space_complexity: ComplexityType
    best_case: str
    worst_case: str
    real_world_example: str


