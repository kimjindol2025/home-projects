def fibonacci_naive(n: int) -> int:
    """피보나치 수열: O(2^n) - 매우 비효율적"""
    if n <= 1:
        return n
    return fibonacci_naive(n - 1) + fibonacci_naive(n - 2)


def fibonacci_dp(n: int) -> int:
    """피보나치 수열 (Memoization): O(n) - 효율적"""
    memo = {}

    def fib_helper(n: int) -> int:
        if n in memo:
            return memo[n]

        if n <= 1:
            return n

        result = fib_helper(n - 1) + fib_helper(n - 2)
        memo[n] = result
        return result

    return fib_helper(n)


def knapsack_dp(weights: List[int], values: List[int], capacity: int) -> int:
    """배낭 문제: Dynamic Programming O(n*W)"""
    n = len(weights)
    dp = [[0] * (capacity + 1) for _ in range(n + 1)]

    for i in range(1, n + 1):
        for w in range(capacity + 1):
            if weights[i - 1] <= w:
                dp[i][w] = max(
                    values[i - 1] + dp[i - 1][w - weights[i - 1]],
                    dp[i - 1][w]
                )
            else:
                dp[i][w] = dp[i - 1][w]

    return dp[n][capacity]


