#!/usr/bin/env python3
# -*- coding: utf-8 -*-

"""
calculator.py - 부품 모듈 (계산기)

이 모듈은 수학 계산 기능을 담당합니다.
"""

import math

class Calculator:
    """고급 계산기 클래스"""
    def __init__(self):
        self.last_result = 0
        print("🧮 계산기 준비 완료")

    def add(self, a, b):
        """덧셈"""
        self.last_result = a + b
        return self.last_result

    def subtract(self, a, b):
        """뺄셈"""
        self.last_result = a - b
        return self.last_result

    def multiply(self, a, b):
        """곱셈"""
        self.last_result = a * b
        return self.last_result

    def divide(self, a, b):
        """나눗셈"""
        if b == 0:
            return "❌ 0으로 나눌 수 없습니다!"
        self.last_result = a / b
        return self.last_result

    def power(self, base, exp):
        """거듭제곱"""
        self.last_result = base ** exp
        return self.last_result

    def square_root(self, n):
        """제곱근"""
        if n < 0:
            return "❌ 음수의 제곱근은 계산할 수 없습니다!"
        self.last_result = math.sqrt(n)
        return self.last_result

    def get_last_result(self):
        """마지막 계산 결과"""
        return self.last_result


def fibonacci(n):
    """피보나치 수열 계산"""
    if n <= 0:
        return []
    elif n == 1:
        return [0]
    elif n == 2:
        return [0, 1]

    fib = [0, 1]
    for i in range(2, n):
        fib.append(fib[i-1] + fib[i-2])
    return fib


def factorial(n):
    """팩토리얼 계산"""
    if n < 0:
        return "❌ 음수의 팩토리얼은 계산할 수 없습니다!"
    if n == 0 or n == 1:
        return 1
    return n * factorial(n - 1)


if __name__ == "__main__":
    print("\n=== calculator.py 테스트 ===\n")

    print("✅ 계산기 생성")
    calc = Calculator()

    print("\n✅ 기본 연산")
    print(f"  5 + 3 = {calc.add(5, 3)}")
    print(f"  10 - 4 = {calc.subtract(10, 4)}")
    print(f"  6 * 7 = {calc.multiply(6, 7)}")
    print(f"  20 / 4 = {calc.divide(20, 4)}")

    print("\n✅ 고급 연산")
    print(f"  2 ^ 10 = {calc.power(2, 10)}")
    print(f"  √144 = {calc.square_root(144)}")

    print("\n✅ 피보나치 수열")
    print(f"  처음 10개: {fibonacci(10)}")

    print("\n✅ 팩토리얼")
    print(f"  5! = {factorial(5)}")
    print(f"  10! = {factorial(10)}")
