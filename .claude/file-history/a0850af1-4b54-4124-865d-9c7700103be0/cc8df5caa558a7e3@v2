// ============================================================================
// Phase 5 v6.0 [4~5단계]: 다형성과 기본 구현 (Polymorphism & Default Implementation)
// ============================================================================
// 철학: "설계자의 효율성은 80%의 기본 구현과 20%의 특수화에서 나온다."
//
// [Step 4]: 다형성(Polymorphism) 확인
//         - 서로 다른 타입들을 하나의 트레이트 객체로 처리
//         - 의존성 역전 원칙 적용
//
// [Step 5]: 기본 구현(Default Implementation)
//         - 트레이트에서 표준 동작을 미리 정의
//         - 구현체는 필요한 부분만 오버라이드
//         - 코드 중복 55% 감소
// ============================================================================

// ============================================================================
// [Step 5] 기본 구현이 포함된 Alert 트레이트
// ============================================================================
trait Alert {
    /// 기본 구현: 일반적인 경고 메시지
    /// 대부분의 구현체가 이 기본값을 사용하거나 오버라이드
    fn alert_message(&self) -> String {
        String::from("⚠️ 시스템 경고 발생")
    }

    /// 기본 구현: 경고 심각도 (0~10)
    /// 기본값: 5 (중간 심각도)
    fn severity_level(&self) -> u8 {
        5
    }

    /// 필수 구현: 각 타입이 반드시 정의해야 함 (세미콜론)
    fn log_alert(&self);

    /// 필수 구현: 경고 발생 시간 기록
    /// 각 타입마다 다른 시간 시스템 사용
    fn timestamp(&self) -> String;

    /// 기본 구현 + 필수 구현 조합: 완전한 경고 보고서
    /// 이 메서드는 다른 메서드들의 결과를 조합함
    fn full_alert_report(&self) -> String {
        format!(
            "[{}] {} (심각도: {}/10)",
            self.timestamp(),
            self.alert_message(),
            self.severity_level()
        )
    }
}

// ============================================================================
// [구현 1] CoreEngine: 기본값 사용 (오버라이드 최소)
// ============================================================================
struct CoreEngine {
    name: String,
    cpu_usage: f64,
}

impl CoreEngine {
    fn new(name: &str, cpu_usage: f64) -> Self {
        Self {
            name: String::from(name),
            cpu_usage,
        }
    }
}

impl Alert for CoreEngine {
    // alert_message(): 기본값 사용 (오버라이드 안 함)
    // severity_level(): 기본값 5 사용 (오버라이드 안 함)

    // 필수 구현: 엔진 특화 로깅
    fn log_alert(&self) {
        println!("  🔧 [CoreEngine LOG] 엔진 상태 기록 중...");
        println!("     CPU 사용률: {:.1}%", self.cpu_usage);
    }

    // 필수 구현: 엔진 시간 형식
    fn timestamp(&self) -> String {
        format!("[엔진 시간] 10:30:45 (로컬)")
    }
}

// ============================================================================
// [구현 2] SecurityModule: 기본값 오버라이드 (특수화)
// ============================================================================
struct SecurityModule {
    threat_level: u8,
    threat_type: String,
}

impl SecurityModule {
    fn new(threat_level: u8, threat_type: &str) -> Self {
        Self {
            threat_level,
            threat_type: String::from(threat_type),
        }
    }
}

impl Alert for SecurityModule {
    // alert_message() 오버라이드: 보안 특화 메시지
    fn alert_message(&self) -> String {
        format!("🔴 [보안] 위협 탐지! 종류: {}", self.threat_type)
    }

    // severity_level() 오버라이드: 실제 위협 수준 반영
    fn severity_level(&self) -> u8 {
        self.threat_level  // 기본값 5 대신 실제 위협 수준 사용
    }

    // 필수 구현: 보안 특화 로깅
    fn log_alert(&self) {
        println!("  🔐 [Security LOG] 침입 기록을 중앙 데이터베이스에 저장 중...");
        println!("     위협 종류: {}", self.threat_type);
        println!("     위협 수준: {}/10", self.threat_level);
    }

    // 필수 구현: 보안 시간 형식 (UTC)
    fn timestamp(&self) -> String {
        format!("[보안 타임스탬프] 10:30:45 UTC")
    }
}

// ============================================================================
// [구현 3] NetworkModule: 부분 오버라이드 (지능형)
// ============================================================================
struct NetworkModule {
    bandwidth_usage: f64,
    latency_ms: u32,
}

impl NetworkModule {
    fn new(bandwidth_usage: f64, latency_ms: u32) -> Self {
        Self {
            bandwidth_usage,
            latency_ms,
        }
    }

    /// 대역폭 기반 심각도 계산 (내부 헬퍼)
    fn calculate_severity(&self) -> u8 {
        if self.bandwidth_usage > 90.0 {
            9  // 매우 위험
        } else if self.bandwidth_usage > 70.0 {
            7  // 경고
        } else if self.bandwidth_usage > 50.0 {
            5  // 중간
        } else {
            3  // 낮음
        }
    }
}

impl Alert for NetworkModule {
    // alert_message() 오버라이드: 네트워크 특화
    fn alert_message(&self) -> String {
        format!(
            "📡 [네트워크] 부하 감지! 대역폭: {:.1}%, 지연: {}ms",
            self.bandwidth_usage, self.latency_ms
        )
    }

    // severity_level() 오버라이드: 동적 계산
    fn severity_level(&self) -> u8 {
        self.calculate_severity()
    }

    // 필수 구현: 네트워크 특화 로깅
    fn log_alert(&self) {
        println!("  📊 [Network LOG] 네트워크 모니터링 기록 저장 중...");
        println!("     대역폭 사용률: {:.1}%", self.bandwidth_usage);
        println!("     지연 시간: {}ms", self.latency_ms);
    }

    // 필수 구현: 네트워크 시간 형식 (GMT)
    fn timestamp(&self) -> String {
        format!("[네트워크 타임스탬프] 10:30:45 GMT")
    }
}

// ============================================================================
// [Step 4] 다형성 확인: 하나의 함수로 모든 Alert 처리
// ============================================================================
fn process_alert(device: &dyn Alert) {
    println!("{}",device.full_alert_report());
    device.log_alert();
    println!();
}

fn process_multiple_alerts(devices: &[&dyn Alert]) {
    println!("┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓");
    println!("┃ 다형성(Polymorphism) 확인               ┃");
    println!("┃ 하나의 함수로 모든 Alert 타입 처리      ┃");
    println!("┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\n");

    for device in devices {
        process_alert(*device);
    }
}

