## 🔧 v9.2 설계: 세 가지 패턴

### 패턴 1️⃣: Mock 객체 테스트

```rust
pub trait Messenger {
    fn send(&self, msg: &str);
}

// 실제 메신저
struct EmailMessenger;
impl Messenger for EmailMessenger {
    fn send(&self, msg: &str) {
        println!("이메일 전송: {}", msg);
    }
}

// Mock 메신저: 호출 추적
struct MockMessenger {
    sent_messages: RefCell<Vec<String>>,
}

impl MockMessenger {
    fn new() -> Self {
        Self {
            sent_messages: RefCell::new(Vec::new()),
        }
    }
}

impl Messenger for MockMessenger {
    fn send(&self, msg: &str) {
        // &self는 불변이지만 내부는 수정 가능!
        self.sent_messages.borrow_mut().push(String::from(msg));
    }
}

// 테스트
fn notify(messenger: &impl Messenger, msg: &str) {
    messenger.send(msg);
}

let mock = MockMessenger::new();
notify(&mock, "테스트");
assert_eq!(mock.sent_messages.borrow().len(), 1);
```

### 패턴 2️⃣: 캐시 시스템

```rust
struct CachedValue<T: Clone> {
    value: T,
    cache: RefCell<Option<T>>,
    cache_hits: RefCell<usize>,
}

impl<T: Clone> CachedValue<T> {
    fn new(value: T) -> Self {
        Self {
            value,
            cache: RefCell::new(None),
            cache_hits: RefCell::new(0),
        }
    }

    fn get(&self) -> T {
        // 불변 메서드이지만 내부 캐시 상태 변경
        if let Some(cached) = self.cache.borrow().as_ref() {
            *self.cache_hits.borrow_mut() += 1;
            return cached.clone();
        }

        let result = self.value.clone();
        *self.cache.borrow_mut() = Some(result.clone());
        result
    }

    fn cache_hits(&self) -> usize {
        *self.cache_hits.borrow()
    }
}
```

### 패턴 3️⃣: 통계 수집

```rust
struct RequestTracker {
    count: RefCell<usize>,
    errors: RefCell<usize>,
}

impl RequestTracker {
    fn new() -> Self {
        Self {
            count: RefCell::new(0),
            errors: RefCell::new(0),
        }
    }

    fn record_request(&self) {
        *self.count.borrow_mut() += 1;
    }

    fn record_error(&self) {
        *self.errors.borrow_mut() += 1;
    }

    fn get_stats(&self) -> (usize, usize) {
        (*self.count.borrow(), *self.errors.borrow())
    }
}
```

