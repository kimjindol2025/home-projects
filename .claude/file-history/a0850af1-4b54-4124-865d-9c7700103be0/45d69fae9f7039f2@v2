print("="*70)

def fibonacci_infinite() -> Generator[int, None, None]:
    """
    무한 피보나치 수열: 0, 1, 1, 2, 3, 5, 8, 13, ...

    수학적으로 정의된 무한 수열을 코드로 표현합니다.
    """
    a, b = 0, 1
    while True:
        yield a
        a, b = b, a + b


print(f"\n[생성] 무한 피보나치 제너레이터")
fib = fibonacci_infinite()

print(f"  메모리: {sys.getsizeof(fib)} bytes")

print(f"\n[처음 20개의 피보나치 수]")
fib_20 = [next(fibonacci_infinite()) for _ in range(20)]
print(f"  {fib_20}")

print(f"\n[특정 인덱스의 값 추출]")
def get_fib_at(index: int) -> int:
    """index번째 피보나치 수를 구합니다."""
    fib_gen = fibonacci_infinite()
    for _ in range(index + 1):
        value = next(fib_gen)
    return value

