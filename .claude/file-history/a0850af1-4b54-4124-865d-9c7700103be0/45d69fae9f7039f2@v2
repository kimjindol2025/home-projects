def infinite_primes() -> Generator[int, None, None]:
    """
    무한 소수 생성기: 2, 3, 5, 7, 11, 13, ...

    에라토스테네스의 체(Sieve of Eratosthenes)를 사용하여
    효율적으로 소수를 생성합니다.
    """
    def is_prime(n: int) -> bool:
        if n < 2:
            return False
        if n == 2:
            return True
        if n % 2 == 0:
            return False
        for i in range(3, int(n**0.5) + 1, 2):
            if n % i == 0:
                return False
        return True

    n = 2
    while True:
        if is_prime(n):
            yield n
        n += 1


print(f"\n[생성] 무한 소수 제너레이터")
