small_fib = filter_gen(fib, lambda x: x < 100)
print(f"  {list(small_fib)}")

print(f"\n[조합 3] 소수 중 10번째부터 20번째까지")
primes = infinite_primes()
skip(primes, 10)  # 처음 10개 건너뛰기
print(f"  {take(primes, 10)}")


