print("="*70)

def infinite_naturals() -> Generator[int, None, None]:
    """
    무한 자연수: 0, 1, 2, 3, ...

    이 제너레이터는 절대 종료되지 않습니다.
    while True는 무한 루프를 만들지만,
    yield를 사용하므로 각 호출마다 하나씩 값을 반환합니다.
    """
    n = 0
    while True:
        yield n
        n += 1


print(f"\n[생성] 무한 자연수 제너레이터")
