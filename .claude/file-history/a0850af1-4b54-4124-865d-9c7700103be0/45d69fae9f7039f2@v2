def take(gen: Generator, n: int) -> list:
    """제너레이터에서 처음 n개를 추출합니다."""
    return [next(gen) for _ in range(n)]

def skip(gen: Generator, n: int) -> Generator:
    """제너레이터의 처음 n개를 건너뜁니다."""
    for _ in range(n):
        next(gen)
    return gen

def filter_gen(gen: Generator, predicate) -> Generator:
    """조건을 만족하는 값만 필터링합니다."""
    for item in gen:
        if predicate(item):
            yield item

print(f"\n[조합 1] 처음 100개의 자연수 중 짝수만")
