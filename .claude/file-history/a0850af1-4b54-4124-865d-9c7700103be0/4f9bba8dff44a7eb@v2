#!/usr/bin/env python3
# -*- coding: utf-8 -*-

"""
engine.py - 부품 모듈 (엔진 시스템)

이 모듈은 시스템의 핵심 엔진을 담당합니다.
다른 모듈에서 import해서 사용할 수 있습니다.
"""

class PowerCore:
    """전원 코어를 관리하는 클래스"""
    def __init__(self, power=100):
        self.power = power
        self.status = "Stable"
        print(f"⚡ PowerCore 초기화 (전력: {self.power}%)")

    def check_status(self):
        """상태 확인"""
        return f"상태: {self.status}, 전력: {self.power}%"

    def decrease_power(self, amount):
        """전력 소비"""
        self.power -= amount
        if self.power < 20:
            self.status = "Warning"
        elif self.power < 0:
            self.status = "Critical"
        return f"전력 감소: {amount}% → 남은 전력: {self.power}%"


def start_engine():
    """엔진 시작"""
    return "🚀 엔진이 가동되었습니다."


def stop_engine():
    """엔진 정지"""
    return "🛑 엔진이 정지되었습니다."


def run_diagnostic():
    """진단 실행"""
    return {
        "CPU": "정상",
        "Memory": "256MB",
        "Storage": "1GB",
        "Network": "연결됨"
    }


# if __name__ == "__main__": 패턴
# 이 블록은 이 파일을 직접 실행할 때만 동작합니다.
# 다른 파일에서 import할 때는 실행되지 않습니다.
if __name__ == "__main__":
    print("\n=== engine.py 테스트 ===\n")

    print("✅ 엔진 시작")
    print(start_engine())

    print("\n✅ PowerCore 생성")
    core = PowerCore(100)
    print(core.check_status())

    print("\n✅ 진단 실행")
    diag = run_diagnostic()
    for key, value in diag.items():
        print(f"  - {key}: {value}")

    print("\n✅ 엔진 정지")
    print(stop_engine())
