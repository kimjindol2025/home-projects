// Phase 6 v7.3: Static Lifetime - Programs eternal data
// Philosophy: All things perish. Yet during a program's lifetime,
//             some data exists forever.
// Goal: Understand and safely manage static data in programs

use std::sync::{OnceLock, Mutex};

// ============================================================================
// [Category 1] String Literals - Automatically 'static
// ============================================================================

fn get_welcome_message() -> &'static str {
    "Welcome to Rust Static Lifetime World!"
}

const KEYWORDS: &[&'static str] = &[
    "if", "else", "while", "for", "fn", "let", "mut",
];

const VERSION: &str = "v7.3.0";
const API_ENDPOINT: &str = "https://api.example.com";

const ERROR_MESSAGES: &[&'static str] = &[
    "Connection failed: timeout",
    "Database error: cannot connect",
    "Authentication failed: invalid credentials",
    "Permission denied: insufficient privileges",
    "Server error: internal server error",
];

// ============================================================================
// [Category 2] Static Variables - Global program state
// ============================================================================

static MAX_CONNECTIONS: u32 = 1000;
static DEFAULT_TIMEOUT_SECS: u32 = 30;
static DATABASE_URL: &'static str = "postgresql://localhost:5432/db";

struct ServerConfig {
    host: &'static str,
    port: u16,
    max_connections: u32,
    debug: bool,
}

static SERVER_CONFIG: ServerConfig = ServerConfig {
    host: "127.0.0.1",
    port: 8080,
    max_connections: 100,
    debug: false,
};

static mut REQUEST_COUNTER: u64 = 0;

static LOGGER_NAME: OnceLock<String> = OnceLock::new();
static MAX_RETRIES: OnceLock<u32> = OnceLock::new();

fn init_logger_name() -> &'static str {
    LOGGER_NAME
        .get_or_init(|| "DefaultLogger".to_string())
        .as_str()
}

fn init_max_retries() -> u32 {
    *MAX_RETRIES.get_or_init(|| 3)
}

// ============================================================================
// [Category 3] Dynamic to Static Conversion (Box::leak)
// ============================================================================

fn init_app_name(name: String) -> &'static str {
    Box::leak(name.into_boxed_str())
}

fn init_database_url(host: &str, port: u16, db: &str) -> &'static str {
    let url = format!("postgresql://{}:{}/{}", host, port, db);
    Box::leak(url.into_boxed_str())
}

fn create_config_string(env: &str, version: &str) -> &'static str {
    let config = format!("Environment: {}, Version: {}", env, version);
    Box::leak(config.into_boxed_str())
}

fn create_error_message(error_code: u32, details: &str) -> &'static str {
    let msg = format!("Error {}: {}", error_code, details);
    Box::leak(msg.into_boxed_str())
}

fn load_config_from_dynamic(config: String) -> &'static str {
    let processed = format!("Loaded: {}", config);
    Box::leak(processed.into_boxed_str())
}

// ============================================================================
// [Integration Design] Multitenant Server Engine
// ============================================================================

struct TenantConfig {
    tenant_id: u32,
    name: &'static str,
    api_url: &'static str,
    max_users: u32,
}

struct ServerEngine {
    version: &'static str,
    tenants: Vec<TenantConfig>,
}

impl ServerEngine {
    fn new() -> Self {
        ServerEngine {
            version: VERSION,
            tenants: Vec::new(),
        }
    }

    fn add_tenant(&mut self, id: u32, name: String, url: String, max_users: u32) {
        let tenant = TenantConfig {
            tenant_id: id,
            name: Box::leak(name.into_boxed_str()),
            api_url: Box::leak(url.into_boxed_str()),
            max_users,
        };
        self.tenants.push(tenant);
    }

    fn get_version(&self) -> &'static str {
        self.version
    }

    fn get_server_config() -> &'static ServerConfig {
        &SERVER_CONFIG
    }

    fn max_connections() -> u32 {
        MAX_CONNECTIONS
    }

    fn increment_request_count() {
        unsafe {
            REQUEST_COUNTER += 1;
        }
    }

    fn get_request_count() -> u64 {
        unsafe { REQUEST_COUNTER }
    }

    fn get_tenant_info(&self) -> Vec<(&'static str, &'static str)> {
        self.tenants
            .iter()
            .map(|t| (t.name, t.api_url))
            .collect()
    }
}

// ============================================================================
// [Practical Pattern] Singleton with Static Lifetime
// ============================================================================

struct ApplicationState {
    initialized: bool,
    config_path: &'static str,
}

static APP_STATE: OnceLock<Mutex<ApplicationState>> = OnceLock::new();

fn init_app_state(config_path: String) -> &'static Mutex<ApplicationState> {
    APP_STATE.get_or_init(|| {
        Mutex::new(ApplicationState {
            initialized: true,
            config_path: Box::leak(config_path.into_boxed_str()),
        })
    })
}

fn get_app_config_path() -> &'static str {
    if let Ok(guard) = APP_STATE
        .get_or_init(|| {
            Mutex::new(ApplicationState {
                initialized: false,
                config_path: "default_config.json",
            })
        })
        .lock()
    {
        guard.config_path
    } else {
        "error_config.json"
    }
}

