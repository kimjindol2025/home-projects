#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn string_literals_are_static() {
        let s = "Hello";
        assert_eq!(s, "Hello");
    }

    #[test]
    fn static_constants() {
        assert_eq!(VERSION, "v7.3.0");
        assert_eq!(MAX_CONNECTIONS, 1000);
    }

    #[test]
    fn static_config() {
        assert_eq!(SERVER_CONFIG.host, "127.0.0.1");
        assert_eq!(SERVER_CONFIG.port, 8080);
        assert_eq!(SERVER_CONFIG.max_connections, 100);
    }

    #[test]
    fn box_leak_dynamic() {
        let app_name = init_app_name("TestApp".to_string());
        assert_eq!(app_name, "TestApp");
    }

    #[test]
    fn dynamic_config() {
        let url = init_database_url("db.example.com", 5432, "testdb");
        assert!(url.contains("db.example.com"));
        assert!(url.contains("5432"));
    }

    #[test]
    fn tenant_config() {
        let mut engine = ServerEngine::new();
        engine.add_tenant(1, "Tenant1".to_string(), "https://t1.api.com".to_string(), 100);

        let tenants = engine.get_tenant_info();
        assert_eq!(tenants.len(), 1);
        assert_eq!(tenants[0].0, "Tenant1");
    }
}

