      tasks = [system.analyze_node(n) for n in nodes_list]

      방법 2) 직접 제너레이터 호출
      tasks = [system.analyze_node(n) for n in data_generator(5)]

      방법 3) 미리 변환
      nodes_data = [i for i in data_generator(5)]
    """
    print("\n【 완벽하게 수정된 시스템 】\n")

    # ✅ 방법 1: list()로 변환 (명확함)
    nodes_list = list(data_generator(5))
    print(f"생성된 노드: {nodes_list}")

    system = GogsDataSystem(nodes_list)

    print(f"\n📊 {len(nodes_list)}개 노드 비동기 분석 중...\n")

    # 각 노드를 비동기로 처리
    tasks = [system.analyze_node(n) for n in nodes_list]
    results = await asyncio.gather(*tasks)

    print(f"\n📈 분석 결과:")
    for result in results:
        print(f"  {result}")

    print(f"\n✅ 처리된 노드 수: {system.processed_count}")


