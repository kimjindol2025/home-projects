# ✅ 수정 1: 비동기 함수 지원 데코레이터
def gogs_timer_fixed(func):
    """
    ✅ [수정 1] 비동기와 동기 함수를 모두 지원하는 데코레이터

    【 핵심 개선 】
    1. wrapper를 async def로 선언
    2. func가 코루틴이면 await로 실행
    3. functools.wraps로 메타데이터 보존
    """
    @wraps(func)
    async def async_wrapper(*args, **kwargs):
        start = time.time()
        result = await func(*args, **kwargs)  # 🔧 await 추가!
        elapsed = time.time() - start
        print(f"  ⏱️  {func.__name__}: {elapsed:.4f}s")
        return result

    @wraps(func)
    def sync_wrapper(*args, **kwargs):
        start = time.time()
        result = func(*args, **kwargs)
        elapsed = time.time() - start
        print(f"  ⏱️  {func.__name__}: {elapsed:.4f}s")
        return result

    # 비동기 함수 판별
    if asyncio.iscoroutinefunction(func):
        return async_wrapper
    else:
        return sync_wrapper


# ✅ 수정 2: 제너레이터 안전 처리
def data_generator(limit: int) -> Generator[int, None, None]:
    """
    ✅ [수정 2] 표준 제너레이터 (v3.2)

    【 핵심 이해 】
    1. yield: 값을 하나씩 반환하고 상태 유지
    2. 제너레이터는 한 번만 순회 가능
    3. 다시 순회하려면 새로 생성해야 함

    【 yield의 작동 원리 】
    - yield i를 만나면 i를 호출자에게 반환
    - 함수 실행이 일시 중단됨 (상태 유지)
    - 다시 next()가 호출되면 다음 줄부터 재개
    - for 루프가 끝나면 StopIteration 발생
    """
    for i in range(limit):
        yield i
        # yield 이후에 i += 1을 명시하지 않아도
        # for 루프가 자동으로 다음 값으로 진행됨


class GogsDataSystem:
    """실험 데이터 스트리밍 시스템"""

    def __init__(self, data_stream):
        self.data_stream = data_stream
        self.processed_count = 0
        self.results = []

    @gogs_timer_fixed  # ✅ 수정된 데코레이터 사용
    async def analyze_node(self, node_id: int) -> str:
        """
        ✅ [수정 1] 비동기 함수에 @gogs_timer_fixed 적용

        원본의 문제:
          @gogs_timer (async 미지원)
          async def analyze_node(...)
          → 데코레이터가 코루틴을 받지만 실행 못 함

        수정:
          @gogs_timer_fixed (async 지원)
          async def analyze_node(...)
          → 데코레이터가 async wrapper로 변환하여 await 가능
        """
        await asyncio.sleep(0.1)  # 분석 시뮬레이션
        self.processed_count += 1
        return f"Node-{node_id} Complete"


