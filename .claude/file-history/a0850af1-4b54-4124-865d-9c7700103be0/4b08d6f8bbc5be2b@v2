// Phase 7 v8.1: CLI for PulseAI Auditing System

use pulseai_lang::{
    create_vault, create_security_log, create_config_manager,
    AuditLevel,
};

fn main() {
    println!("╔══════════════════════════════════════════════════════════════════╗");
    println!("║     Phase 7 v8.1: Integration Testing and Library Design        ║");
    println!("╚══════════════════════════════════════════════════════════════════╝\n");

    // ========================================================================
    // [Demo 1] Vault System
    // ========================================================================
    println!("[Demo 1] Security Vault System");
    println!("─────────────────────────────────────────────\n");

    let vault = create_vault("master_key_2026");
    println!("Vault created with key length: {}", vault.key_length());
    println!("Authentication test: {}\n", vault.authenticate("master_key_2026"));

    // ========================================================================
    // [Demo 2] Security Log
    // ========================================================================
    println!("[Demo 2] Security Event Log");
    println!("─────────────────────────────────────────────\n");

    let mut log = create_security_log();
    log.log_event("System startup", "2026-02-22T10:00:00Z", AuditLevel::Low);
    log.log_event("User login", "2026-02-22T10:01:00Z", AuditLevel::Low);
    log.log_event("Data access", "2026-02-22T10:02:00Z", AuditLevel::Medium);
    log.log_event("Suspicious activity", "2026-02-22T10:03:00Z", AuditLevel::High);

    println!("Logged {} events", log.get_events().len());
    println!("Critical events: {}", log.critical_count());
    println!("Total severity: {}\n", log.total_severity());

    // ========================================================================
    // [Demo 3] Configuration Manager
    // ========================================================================
    println!("[Demo 3] Configuration Manager");
    println!("─────────────────────────────────────────────\n");

    let mut config = create_config_manager();
    config.set("environment", "production");
    config.set("version", "v8.1");
    config.set("encryption", "AES-256");

    println!("Configuration settings:");
    for (key, value) in config.all_settings() {
        println!("  {} = {}", key, value);
    }
    println!();

    // ========================================================================
    // [Summary]
    // ========================================================================
    println!("╔══════════════════════════════════════════════════════════════════╗");
    println!("║                 [v8.1 Library Summary]                          ║");
    println!("╠══════════════════════════════════════════════════════════════════╣");
    println!("║                                                                  ║");
    println!("║  ✅ Library Structure: Modular design with pub interfaces        ║");
    println!("║                                                                  ║");
    println!("║  ✅ Public API:                                                  ║");
    println!("║     - create_vault() → Vault                                     ║");
    println!("║     - create_security_log() → SecurityLog                        ║");
    println!("║     - create_config_manager() → ConfigManager                    ║");
    println!("║                                                                  ║");
    println!("║  ✅ Integration Tests:                                           ║");
    println!("║     - tests/integration_test.rs (6 test groups, 20+ tests)      ║");
    println!("║     - tests/workflow_test.rs (8 real-world workflows)           ║");
    println!("║                                                                  ║");
    println!("║  ✅ External Perspective:                                        ║");
    println!("║     Tests only use public API                                    ║");
    println!("║     No internal implementation dependencies                      ║");
    println!("║                                                                  ║");
    println!("╚══════════════════════════════════════════════════════════════════╝");

    println!("\nTo run integration tests:");
    println!("  cargo test --test integration_test");
    println!("  cargo test --test workflow_test");
    println!("  cargo test   # Run all tests");
    println!("\nNote: Library is now ready for external use!");
}
