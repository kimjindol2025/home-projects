#[derive(Debug)]
struct GraphNode {
    id: usize,
    neighbors: Vec<Rc<RefCell<GraphNode>>>,
}

impl GraphNode {
    fn new(id: usize) -> Rc<RefCell<Self>> {
        Rc::new(RefCell::new(Self {
            id,
            neighbors: Vec::new(),
        }))
    }

    /// 다른 노드에 연결합니다
    fn connect(from: &Rc<RefCell<GraphNode>>,
               to: Rc<RefCell<GraphNode>>) {
        from.borrow_mut().neighbors.push(to);
    }

    fn get_id(&self) -> usize {
        self.id
    }

    fn get_neighbor_count(&self) -> usize {
        self.neighbors.len()
    }
}

fn demo_graph_structure() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║     [Demo 4] 그래프: 복잡한 네트워크 구조                    ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    // [1] 노드 생성
    println!("[1] 5개 노드 생성:");
    let node1 = GraphNode::new(1);
    let node2 = GraphNode::new(2);
    let node3 = GraphNode::new(3);
    let node4 = GraphNode::new(4);
    let node5 = GraphNode::new(5);
    println!("    노드 1, 2, 3, 4, 5");

    // [2] 연결 구성
    println!("\n[2] 복잡한 네트워크 구성:");
    GraphNode::connect(&node1, Rc::clone(&node2));
    GraphNode::connect(&node1, Rc::clone(&node3));
    GraphNode::connect(&node2, Rc::clone(&node4));
    GraphNode::connect(&node3, Rc::clone(&node4));
    GraphNode::connect(&node4, Rc::clone(&node5));

    println!("    1 → [2, 3]");
    println!("    2 → [4]");
    println!("    3 → [4]");
    println!("    4 → [5]");
    println!("    5 → []");

    // [3] 그래프 상태 확인
    println!("\n[3] 각 노드의 이웃 개수:");
    println!("    Node 1: {} neighbors", node1.borrow().get_neighbor_count());
    println!("    Node 2: {} neighbors", node2.borrow().get_neighbor_count());
    println!("    Node 3: {} neighbors", node3.borrow().get_neighbor_count());
    println!("    Node 4: {} neighbors", node4.borrow().get_neighbor_count());
    println!("    Node 5: {} neighbors", node5.borrow().get_neighbor_count());

    println!("\n    ✅ Rc<RefCell<T>>로 복잡한 그래프 구조 표현 가능\n");
}

