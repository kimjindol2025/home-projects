// Phase 8 v9.3: 다중 소유 가변성 (Multiple Ownership with Mutability)
// Rc<RefCell<T>>를 통한 공유와 수정의 공존

use std::rc::Rc;
use std::cell::RefCell;

// ============================================================================
// [v9.3: 기본 개념] Rc<RefCell<T>>의 기초
// ============================================================================

/// Rc<RefCell<T>>를 사용한 기본 공유 가변성
fn demo_basic_rc_refcell() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║      [Demo 1] Rc<RefCell<T>>: 공유와 수정의 공존            ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    // [1] Rc<T>의 한계: 공유는 하지만 수정 불가능
    println!("[1] Rc<T>의 한계:");
    {
        let data = Rc::new(vec![1, 2, 3]);
        let shared = Rc::clone(&data);
        // shared.push(4);  // ❌ 컴파일 에러!
        println!("    Rc<Vec>은 공유하면서 수정 불가능");
        println!("    data = {:?}, shared = {:?}\n", *data, *shared);
    }

    // [2] RefCell<T> 단독: 공유 불가능, 수정만 가능
    println!("[2] RefCell<T> 단독의 한계:");
    {
        let data = RefCell::new(vec![1, 2, 3]);
        // let shared = Rc::clone(&data);  // ❌ RefCell은 Rc가 아님
        data.borrow_mut().push(4);
        println!("    RefCell은 수정은 가능하지만 공유 불가능\n");
    }

    // [3] Rc<RefCell<T>>의 해답: 공유하면서 동시에 수정!
    println!("✅ [3] Rc<RefCell<T>>: 공유하면서 수정!");
    {
        let data = Rc::new(RefCell::new(vec![1, 2, 3]));
        println!("    초기 상태: {:?}", data.borrow());

        let shared1 = Rc::clone(&data);
        let shared2 = Rc::clone(&data);

        // shared1을 통해 수정
        shared1.borrow_mut().push(4);
        println!("    shared1.push(4) 후: {:?}", data.borrow());

        // shared2를 통해 읽기
        println!("    shared2로 읽기: {:?}", shared2.borrow());

        // data를 통해 다시 수정
        data.borrow_mut().push(5);
        println!("    data.push(5) 후: {:?}", shared1.borrow());

        println!("    ✅ 모두 같은 데이터를 소유하면서 수정 가능!");
    }

    println!("    참조 카운트: Rc로 추적되고, 대여는 RefCell로 검사됨\n");
}

