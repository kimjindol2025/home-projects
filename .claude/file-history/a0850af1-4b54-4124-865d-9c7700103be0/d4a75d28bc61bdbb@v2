fn demo_circular_reference_warning() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║   [Demo 5] 순환 참조: 메모리 누수의 위험                    ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    println!("[1] 순환 참조의 위험:");
    println!("    A → B → A (순환)");
    println!("    A의 RefCount: 1 (초기)");
    println!("    B의 RefCount: 1 (초기)");
    println!("    A가 B를 참조 → B의 RefCount: 2");
    println!("    B가 A를 참조 → A의 RefCount: 2");
    println!("    A와 B 스코프 종료");
    println!("    A의 RefCount: 1 (B가 A를 가리키므로)");
    println!("    B의 RefCount: 1 (A가 B를 가리키므로)");
    println!("    ❌ 양쪽 모두 RefCount가 1로 유지");
    println!("    ❌ 메모리가 영원히 해제되지 않음 → 메모리 누수!");

    println!("\n[2] 순환 참조 예시 (실제 코드):");
    {
        #[derive(Debug)]
        struct Node {
            id: usize,
            next: Option<Rc<RefCell<Node>>>,
        }

        println!("    let a = Rc::new(RefCell::new(Node {{ id: 1, next: None }}));");
        println!("    let b = Rc::new(RefCell::new(Node {{ id: 2, next: None }}));");
        println!("    a.borrow_mut().next = Some(Rc::clone(&b));");
        println!("    b.borrow_mut().next = Some(Rc::clone(&a));  // ❌ 순환!");
    }

    println!("\n[3] 해결책:");
    println!("    ✅ 다음 단계: Weak<T>를 사용하여 약한 참조 생성");
    println!("    ✅ 약한 참조는 RefCount를 증가시키지 않음");
    println!("    ✅ 순환 참조를 자동으로 방지");

    println!("\n    💡 설계 원칙:");
    println!("    - 부모 → 자식: 강한 참조 (Rc<RefCell<T>>)");
    println!("    - 자식 → 부모: 약한 참조 (Weak<RefCell<T>>)\n");
}

