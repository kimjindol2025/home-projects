#[derive(Debug, Clone)]
struct SecurityConfig2 {
    protocol: String,
    level: u32,
}

impl SecurityConfig2 {
    fn new(protocol: &str, level: u32) -> Self {
        Self {
            protocol: String::from(protocol),
            level,
        }
    }
}

#[derive(Debug)]
struct SecurityNode {
    node_id: usize,
    config: Rc<RefCell<SecurityConfig2>>,
    neighbors: Vec<Rc<RefCell<SecurityNode>>>,
}

impl SecurityNode {
    fn new(node_id: usize,
           config: Rc<RefCell<SecurityConfig2>>) -> Rc<RefCell<Self>> {
        Rc::new(RefCell::new(Self {
            node_id,
            config,
            neighbors: Vec::new(),
        }))
    }

    fn connect_to(from: &Rc<RefCell<SecurityNode>>,
                  to: Rc<RefCell<SecurityNode>>) {
        from.borrow_mut().neighbors.push(to);
    }

    fn read_config(&self) -> String {
        let cfg = self.config.borrow();
        format!("Protocol: {}, Level: {}", cfg.protocol, cfg.level)
    }

    fn update_config(&self, protocol: &str, level: u32) {
        let mut cfg = self.config.borrow_mut();
        cfg.protocol = String::from(protocol);
        cfg.level = level;
    }

    fn get_node_id(&self) -> usize {
        self.node_id
    }

    fn get_neighbor_count(&self) -> usize {
        self.neighbors.len()
    }
}

fn demo_complex_network() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║  [Demo 6] 복잡한 보안 노드 네트워크: 실전 시뮬레이션        ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    // [1] 공유 보안 설정 생성
    println!("[1] 공유 보안 설정 생성:");
    let shared_config = Rc::new(RefCell::new(SecurityConfig2::new("TLS_1.3", 256)));
    println!("    초기: {:?}", shared_config.borrow());

    // [2] 보안 노드 네트워크 구성
    println!("\n[2] 5개의 보안 노드 생성 (모두 같은 설정 공유):");
    let node1 = SecurityNode::new(1, Rc::clone(&shared_config));
    let node2 = SecurityNode::new(2, Rc::clone(&shared_config));
    let node3 = SecurityNode::new(3, Rc::clone(&shared_config));
    let node4 = SecurityNode::new(4, Rc::clone(&shared_config));
    let node5 = SecurityNode::new(5, Rc::clone(&shared_config));

    // [3] 네트워크 연결
    println!("\n[3] 네트워크 연결:");
    SecurityNode::connect_to(&node1, Rc::clone(&node2));
    SecurityNode::connect_to(&node1, Rc::clone(&node3));
    SecurityNode::connect_to(&node2, Rc::clone(&node4));
    SecurityNode::connect_to(&node3, Rc::clone(&node5));

    println!("    Node 1 → [2, 3]");
    println!("    Node 2 → [4]");
    println!("    Node 3 → [5]");

    // [4] 초기 설정 확인
    println!("\n[4] 초기 설정 확인 (모두 동일):");
    for i in 1..=5 {
        match i {
            1 => println!("    Node 1: {}", node1.borrow().read_config()),
            2 => println!("    Node 2: {}", node2.borrow().read_config()),
            3 => println!("    Node 3: {}", node3.borrow().read_config()),
            4 => println!("    Node 4: {}", node4.borrow().read_config()),
            5 => println!("    Node 5: {}", node5.borrow().read_config()),
            _ => {}
        }
    }

    // [5] Node 2에서 설정 변경
    println!("\n[5] Node 2에서 보안 정책 변경 (TLS_1.3/256 → TLS_1.2/128):");
    node2.borrow_mut().update_config("TLS_1.2", 128);

    // [6] 모든 노드에서 즉시 반영됨
    println!("\n[6] 변경 후 모든 노드의 설정 (즉시 반영됨):");
    for i in 1..=5 {
        match i {
            1 => println!("    Node 1: {}", node1.borrow().read_config()),
            2 => println!("    Node 2: {}", node2.borrow().read_config()),
            3 => println!("    Node 3: {}", node3.borrow().read_config()),
            4 => println!("    Node 4: {}", node4.borrow().read_config()),
            5 => println!("    Node 5: {}", node5.borrow().read_config()),
            _ => {}
        }
    }

    // [7] 참조 카운트와 네트워크 상태
    println!("\n[7] 네트워크 상태:");
    println!("    공유 설정의 RefCount: {}", Rc::strong_count(&shared_config));
    println!("    Node 1의 이웃: {}", node1.borrow().get_neighbor_count());
    println!("    Node 2의 이웃: {}", node2.borrow().get_neighbor_count());
    println!("    Node 3의 이웃: {}", node3.borrow().get_neighbor_count());

    println!("\n    ✅ 복잡한 분산 시스템도 Rc<RefCell<T>>로 우아하게 설계 가능\n");
}

