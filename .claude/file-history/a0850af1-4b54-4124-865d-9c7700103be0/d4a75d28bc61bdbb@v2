#[derive(Debug, Clone)]
struct SecurityConfig {
    active_protocol: String,
    max_connections: usize,
}

impl SecurityConfig {
    fn new(protocol: &str, max_conn: usize) -> Self {
        Self {
            active_protocol: String::from(protocol),
            max_connections: max_conn,
        }
    }
}

struct AdminPanel {
    name: String,
    config: Rc<RefCell<SecurityConfig>>,
}

impl AdminPanel {
    fn new(name: &str, config: Rc<RefCell<SecurityConfig>>) -> Self {
        Self {
            name: String::from(name),
            config,
        }
    }

    fn get_name(&self) -> &str {
        &self.name
    }

    /// 현재 설정을 읽습니다 (불변 접근)
    fn read_config(&self) -> String {
        let cfg = self.config.borrow();
        format!("Protocol: {}, Max Connections: {}",
            cfg.active_protocol, cfg.max_connections)
    }

    /// 프로토콜을 변경합니다 (가변 접근)
    fn update_protocol(&self, protocol: &str) {
        self.config.borrow_mut().active_protocol = String::from(protocol);
    }

    /// 최대 연결 수를 변경합니다
    fn set_max_connections(&self, count: usize) {
        self.config.borrow_mut().max_connections = count;
    }
}

fn demo_shared_config() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║   [Demo 2] 공유 설정: AdminPanel 분산 제어 시스템            ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    // [1] 공유 설정 생성
    let shared_config = Rc::new(RefCell::new(SecurityConfig::new("TLS_1.3", 100)));
    println!("[1] 초기 공유 설정:");
    println!("    {:?}\n", shared_config.borrow());

    // [2] 여러 관리 패널이 동일한 설정을 소유
    println!("[2] 세 개의 관리 패널 생성 (모두 같은 설정을 소유):");
    let panel_a = AdminPanel::new("Panel A", Rc::clone(&shared_config));
    let panel_b = AdminPanel::new("Panel B", Rc::clone(&shared_config));
    let panel_c = AdminPanel::new("Panel C", Rc::clone(&shared_config));

    println!("    Panel A: {}", panel_a.read_config());
    println!("    Panel B: {}", panel_b.read_config());
    println!("    Panel C: {}", panel_c.read_config());

    // [3] Panel B가 프로토콜을 변경
    println!("\n[3] Panel B에서 프로토콜 변경 (TLS_1.3 → TLS_1.2):");
    panel_b.update_protocol("TLS_1.2");

    // [4] 모든 패널에서 즉시 반영됨
    println!("    Panel A: {}", panel_a.read_config());
    println!("    Panel B: {}", panel_b.read_config());
    println!("    Panel C: {}", panel_c.read_config());

    // [5] Panel C가 최대 연결 수를 변경
    println!("\n[4] Panel C에서 최대 연결 수 변경 (100 → 200):");
    panel_c.set_max_connections(200);

    println!("    Panel A: {}", panel_a.read_config());
    println!("    Panel B: {}", panel_b.read_config());
    println!("    Panel C: {}", panel_c.read_config());

    // [6] 참조 카운트 확인
    println!("\n[5] 참조 카운트:");
    println!("    Rc::strong_count = {}", Rc::strong_count(&shared_config));
    println!("    (초기 1 + Panel A + Panel B + Panel C = 4)\n");

    println!("    ✅ 중앙 통제 없이도 모든 패널이 설정을 공유하고 수정합니다\n");
}

