#[derive(Debug)]
struct TreeNode {
    value: i32,
    parent: Option<Rc<RefCell<TreeNode>>>,
    children: Vec<Rc<RefCell<TreeNode>>>,
}

impl TreeNode {
    fn new(value: i32) -> Rc<RefCell<Self>> {
        Rc::new(RefCell::new(Self {
            value,
            parent: None,
            children: Vec::new(),
        }))
    }

    /// 자식 노드를 추가합니다 (양방향 연결)
    fn add_child(parent: &Rc<RefCell<TreeNode>>,
                 child: Rc<RefCell<TreeNode>>) {
        parent.borrow_mut().children.push(Rc::clone(&child));
        child.borrow_mut().parent = Some(Rc::clone(parent));
    }

    fn get_value(&self) -> i32 {
        self.value
    }

    fn get_child_count(&self) -> usize {
        self.children.len()
    }

    fn has_parent(&self) -> bool {
        self.parent.is_some()
    }
}

fn demo_tree_structure() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║    [Demo 3] 양방향 트리: 부모-자식 양방향 연결               ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    // [1] 트리 구성
    println!("[1] 양방향 트리 구성:");
    let root = TreeNode::new(1);
    let child_a = TreeNode::new(2);
    let child_b = TreeNode::new(3);
    let grandchild = TreeNode::new(4);

    println!("    노드 생성: root(1), child_a(2), child_b(3), grandchild(4)");

    // [2] 부모-자식 관계 설정
    println!("\n[2] 부모-자식 관계 설정:");
    TreeNode::add_child(&root, Rc::clone(&child_a));
    TreeNode::add_child(&root, Rc::clone(&child_b));
    TreeNode::add_child(&child_a, Rc::clone(&grandchild));

    println!("    root → [child_a, child_b]");
    println!("    child_a → [grandchild]");

    // [3] 노드 정보 확인
    println!("\n[3] 노드 정보:");
    println!("    root: value={}, children={}, has_parent={}",
        root.borrow().get_value(),
        root.borrow().get_child_count(),
        root.borrow().has_parent());

    println!("    child_a: value={}, children={}, has_parent={}",
        child_a.borrow().get_value(),
        child_a.borrow().get_child_count(),
        child_a.borrow().has_parent());

    println!("    grandchild: value={}, children={}, has_parent={}",
        grandchild.borrow().get_value(),
        grandchild.borrow().get_child_count(),
        grandchild.borrow().has_parent());

    // [4] 양방향 연결 확인
    println!("\n[4] 양방향 연결 검증:");
    {
        let child_ref = &child_a.borrow();
        println!("    child_a는 부모를 알고 있습니다: {}",
            if child_ref.has_parent() { "Yes" } else { "No" });
    }

    println!("\n    ✅ Rc<RefCell<T>>로 양방향 참조 구현 완료\n");
}

