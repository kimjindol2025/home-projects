// Phase 10 v11.4: Trait-Based Plugin Architecture & Anti-Pattern Defense
// 플러그인 기반 확장 가능한 시스템 설계

use std::collections::HashMap;
use std::fmt;

// =============================================================================
// Core: 플러그인 인터페이스 정의 (계약)
// =============================================================================

/// [Core Interface] 모든 보안 플러그인이 구현해야 할 인터페이스
trait SecurityPlugin: fmt::Debug {
    fn name(&self) -> &str;
    fn scan(&self, data: &str) -> bool;

    // 기본 구현 제공 - 플러그인이 필요한 것만 오버라이드
    fn priority(&self) -> u32 {
        100
    }

    fn description(&self) -> &str {
        "Generic security plugin"
    }
}

// =============================================================================
// Demo 1: 기본 플러그인 시스템
// =============================================================================

#[derive(Debug)]
struct VirusScanner;

impl SecurityPlugin for VirusScanner {
    fn name(&self) -> &str {
        "VirusScanner v1.0"
    }

    fn scan(&self, data: &str) -> bool {
        !data.contains("VIRUS")
    }

    fn priority(&self) -> u32 {
        90
    }

    fn description(&self) -> &str {
        "Detects malicious virus patterns"
    }
}

#[derive(Debug)]
struct SqlInjectionDefender;

impl SecurityPlugin for SqlInjectionDefender {
    fn name(&self) -> &str {
        "SQL-Guard v2.1"
    }

    fn scan(&self, data: &str) -> bool {
        !data.contains("SELECT *") && !data.contains("DROP TABLE")
    }

    fn priority(&self) -> u32 {
        95
    }

    fn description(&self) -> &str {
        "Prevents SQL injection attacks"
    }
}

#[derive(Debug)]
struct XssDefender;

impl SecurityPlugin for XssDefender {
    fn name(&self) -> &str {
        "XSS-Guard"
    }

    fn scan(&self, data: &str) -> bool {
        !data.contains("<script>") && !data.contains("javascript:")
    }

    fn priority(&self) -> u32 {
        85
    }

    fn description(&self) -> &str {
        "Protects against XSS attacks"
    }
}

fn demo_basic_plugin_system() {
    println!("\n=== Demo 1: 기본 플러그인 시스템 ===");

    let plugins: Vec<Box<dyn SecurityPlugin>> = vec![
        Box::new(VirusScanner),
        Box::new(SqlInjectionDefender),
        Box::new(XssDefender),
    ];

    println!("  [플러그인 목록]");
    for plugin in &plugins {
        println!(
            "    • {} (Priority: {})",
            plugin.name(),
            plugin.priority()
        );
        println!("      └─ {}",plugin.description());
    }

    let test_data = "NORMAL DATA";
    println!("\n  [테스트 데이터: '{}']", test_data);

    for plugin in &plugins {
        let result = plugin.scan(test_data);
        let status = if result { "✓ Safe" } else { "✗ Threat" };
        println!("    {} - {}", plugin.name(), status);
    }
}

// =============================================================================
// Demo 2: Trait 상속 (Advanced Plugin)
// =============================================================================

/// [확장된 인터페이스] SecurityPlugin을 기반으로 더 정교한 기능
trait AdvancedSecurityPlugin: SecurityPlugin {
    fn scan_advanced(&self, data: &str) -> (bool, AdvancedResult);
    fn get_threat_score(&self) -> u32;
}

#[derive(Debug, Clone)]
struct AdvancedResult {
    safe: bool,
    threat_level: String,
    details: String,
}

#[derive(Debug)]
struct AdvancedMalwareDetector;

impl SecurityPlugin for AdvancedMalwareDetector {
    fn name(&self) -> &str {
        "Advanced Malware Detector"
    }

    fn scan(&self, data: &str) -> bool {
        // 기본 스캔
        !data.contains("MALWARE")
    }

    fn priority(&self) -> u32 {
        110
    }
}

impl AdvancedSecurityPlugin for AdvancedMalwareDetector {
    fn scan_advanced(&self, data: &str) -> (bool, AdvancedResult) {
        let safe = self.scan(data);
        let threat_level = if safe {
            "LOW".to_string()
        } else {
            "CRITICAL".to_string()
        };

        (
            safe,
            AdvancedResult {
                safe,
                threat_level,
                details: if safe {
                    "No malware signatures detected".to_string()
                } else {
                    "Suspicious patterns found".to_string()
                },
            },
        )
    }

    fn get_threat_score(&self) -> u32 {
        85
    }
}

fn demo_trait_inheritance() {
    println!("\n=== Demo 2: Trait 상속 (Advanced Plugin) ===");

    let detector: Box<dyn AdvancedSecurityPlugin> =
        Box::new(AdvancedMalwareDetector);

    println!("  [고급 플러그인: {}]", detector.name());
    println!("  기본 스캔 (SecurityPlugin): {}", detector.scan("SAFE DATA"));
    println!("  위협 점수: {}", detector.get_threat_score());

    let (safe, result) = detector.scan_advanced("SUSPICIOUS MALWARE CODE");
    println!("\n  [고급 분석 결과]");
    println!("    안전성: {}", if safe { "Safe" } else { "Threat" });
    println!("    위협 수준: {}", result.threat_level);
    println!("    세부정보: {}", result.details);
}

// =============================================================================
// Demo 3: Blanket Implementation (자동 구현)
// =============================================================================

/// [마법] 모든 SecurityPlugin에 자동으로 로깅 기능 부여
trait Loggable {
    fn log_scan(&self, data: &str, result: bool);
}

// Blanket Implementation: SecurityPlugin을 구현한 모든 타입은 자동으로 Loggable도 구현
impl<T: SecurityPlugin> Loggable for T {
    fn log_scan(&self, data: &str, result: bool) {
        println!(
            "    [LOG] {} | Scanning '{}...' | Result: {}",
            self.name(),
            &data[..data.len().min(30)],
            if result { "PASS" } else { "FAIL" }
        );
    }
}

fn demo_blanket_implementation() {
    println!("\n=== Demo 3: Blanket Implementation ===");

    let scanner = VirusScanner;
    let defender = SqlInjectionDefender;

    println!("  [자동 로깅 기능 (Blanket Implementation)]");
    println!("  각 플러그인은 Loggable을 구현하지 않았지만,");
    println!("  SecurityPlugin을 구현했으므로 자동으로 로깅 가능:");

    // Blanket Implementation: SecurityPlugin → Loggable
    println!("\n  [로깅 시작]");
    scanner.log_scan("SAFE DATA", scanner.scan("SAFE DATA"));
    defender.log_scan("SELECT * ATTACK", defender.scan("SELECT * ATTACK"));

    println!("\n  [Blanket Implementation의 마법]");
    println!("    • VirusScanner는 Loggable을 구현하지 않음");
    println!("    • 하지만 SecurityPlugin을 구현함");
    println!("    • impl<T: SecurityPlugin> Loggable for T 덕분에");
    println!("    • 모든 SecurityPlugin 구현체는 자동으로 Loggable!");
}

