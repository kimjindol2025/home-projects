    // Test Case 1: 안전한 데이터
    println!("\n  [테스트 1: 안전한 데이터]");
    engine.run_all_scans("GET /api/users HTTP/1.1");

    // Test Case 2: 공격 패턴 포함
    println!("\n  [테스트 2: SQL 주입 시도]");
