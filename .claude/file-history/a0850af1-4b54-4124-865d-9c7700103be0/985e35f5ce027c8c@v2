#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_basic_plugin() {
        let scanner = VirusScanner;
        assert!(scanner.scan("SAFE DATA"));
        assert!(!scanner.scan("VIRUS CODE"));
    }

    #[test]
    fn test_multiple_plugins() {
        let plugins: Vec<Box<dyn SecurityPlugin>> = vec![
            Box::new(VirusScanner),
            Box::new(SqlInjectionDefender),
        ];

        assert_eq!(plugins.len(), 2);
        assert_eq!(plugins[0].name(), "VirusScanner v1.0");
        assert_eq!(plugins[1].name(), "SQL-Guard v2.1");
    }

    #[test]
    fn test_plugin_priority() {
        let v1 = VirusScanner;
        let v2 = SqlInjectionDefender;
        assert!(v2.priority() > v1.priority());
    }

    #[test]
    fn test_sql_defender() {
        let defender = SqlInjectionDefender;
        assert!(!defender.scan("SELECT * FROM users"));
        assert!(defender.scan("GET /users"));
    }

    #[test]
    fn test_xss_defender() {
        let defender = XssDefender;
        assert!(!defender.scan("<script>alert('xss')</script>"));
        assert!(defender.scan("Hello World"));
    }

    #[test]
    fn test_engine_plugin_management() {
        let mut engine = SecurityEngine::new();
        engine.add_plugin(Box::new(VirusScanner));
        engine.add_plugin(Box::new(SqlInjectionDefender));

        assert_eq!(engine.get_plugin_count(), 2);
    }

    #[test]
    fn test_trait_inheritance() {
        let detector: Box<dyn AdvancedSecurityPlugin> =
            Box::new(AdvancedMalwareDetector);

        assert_eq!(detector.name(), "Advanced Malware Detector");
        assert_eq!(detector.get_threat_score(), 85);

        let (safe, _) = detector.scan_advanced("MALWARE");
        assert!(!safe);
    }
}
