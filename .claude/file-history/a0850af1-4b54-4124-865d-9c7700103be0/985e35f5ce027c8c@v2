fn demo_dependency_injection() {
    println!("\n=== Demo 5: 의존성 주입 (Dependency Injection) ===");

    println!("  [패턴 1: 하드코딩된 의존성 (나쁜 방식)]");
    println!("    엔진이 구체적인 플러그인을 알아야 함");
    println!("    → 새 플러그인 추가 시 엔진 코드 수정 필요");

    println!("\n  [패턴 2: 의존성 주입 (좋은 방식)]");
    println!("    엔진은 Trait만 알면 됨");
    println!("    → 새 플러그인도 자동으로 수용");

    // 의존성 주입의 장점 시연
    let mut engine = SecurityEngine::new();

    // 런타임에 플러그인 선택
    let plugins_config = vec![
        Box::new(VirusScanner) as Box<dyn SecurityPlugin>,
        Box::new(SqlInjectionDefender),
        Box::new(XssDefender),
    ];

    println!("\n  [실행]");
    for plugin in plugins_config {
        engine.add_plugin(plugin);
    }

    engine.run_all_scans("SELECT * FROM USERS WHERE ID=1 OR 1=1");
}

