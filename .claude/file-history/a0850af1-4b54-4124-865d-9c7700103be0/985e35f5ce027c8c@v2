fn demo_production_plugin_system() {
    println!("\n=== Demo 6: 실무 플러그인 시스템 ===");
    println!("  [프로덕션 레벨 멀티 플러그인 시스템]");

    let mut engine = SecurityEngine::new();

    // 6개의 플러그인 장착
    engine.add_plugin(Box::new(CryptoValidator));
    engine.add_plugin(Box::new(VirusScanner));
    engine.add_plugin(Box::new(RateLimitDefender));
    engine.add_plugin(Box::new(SqlInjectionDefender));
