/// [올바른 방식] 계층적 기능을 조합으로 표현
trait RealTimeCapable {
    fn is_real_time(&self) -> bool;
}

trait CloudIntegration {
    fn sync_to_cloud(&self) -> bool;
}

trait CachingCapable {
    fn supports_caching(&self) -> bool;
}

#[derive(Debug)]
struct ModernSecurityScanner;

impl SecurityPlugin for ModernSecurityScanner {
    fn name(&self) -> &str {
        "ModernScanner"
    }

    fn scan(&self, data: &str) -> bool {
        !data.contains("THREAT")
    }
}

// 필요한 기능만 조합해서 구현 (Deep Hierarchy 회피)
impl RealTimeCapable for ModernSecurityScanner {
    fn is_real_time(&self) -> bool {
        true
    }
}

impl CloudIntegration for ModernSecurityScanner {
    fn sync_to_cloud(&self) -> bool {
        true
    }
}

impl CachingCapable for ModernSecurityScanner {
    fn supports_caching(&self) -> bool {
        true
    }
}

fn demo_anti_pattern_defense() {
    println!("\n=== Demo 4: 안티 패턴 방어 (Deep Hierarchy 회피) ===");

    let scanner = ModernSecurityScanner;

    println!("  [조합을 통한 기능 확장]");
    println!("    SecurityPlugin:     O (기본 기능)");
    println!("    RealTimeCapable:    {} (실시간 지원)", if scanner.is_real_time() { "O" } else { "X" });
    println!("    CloudIntegration:   {} (클라우드 동기화)", if scanner.sync_to_cloud() { "O" } else { "X" });
    println!("    CachingCapable:     {} (캐싱 지원)", if scanner.supports_caching() { "O" } else { "X" });

    println!("\n  [장점]");
    println!("    ✓ Deep Hierarchy 없음 (최대 1단계)");
    println!("    ✓ 필요한 기능만 조합");
    println!("    ✓ 새 기능 추가가 쉬움");
}

// =============================================================================
// Core Engine: SecurityEngine (플러그인 관리자)
// =============================================================================

struct SecurityEngine {
    plugins: Vec<Box<dyn SecurityPlugin>>,
    scan_results: HashMap<String, bool>,
}

impl SecurityEngine {
    fn new() -> Self {
        SecurityEngine {
            plugins: Vec::new(),
            scan_results: HashMap::new(),
        }
    }

    fn add_plugin(&mut self, plugin: Box<dyn SecurityPlugin>) {
        println!(
            "  [시스템] '{}' 플러그인 장착 완료. (우선순위: {})",
            plugin.name(),
            plugin.priority()
        );
        self.plugins.push(plugin);

        // 우선순위순으로 정렬 (높을수록 먼저 실행)
        self.plugins.sort_by(|a, b| b.priority().cmp(&a.priority()));
    }

    fn run_all_scans(&mut self, data: &str) {
        println!("\n  [통합 보안 스캔 시작]");
        let mut threat_count = 0;

        for plugin in &self.plugins {
            let result = plugin.scan(data);
            let status = if result { "✓ SAFE" } else { "✗ THREAT" };

            println!(
                "    {} - {} | Priority: {}",
                plugin.name(),
                status,
                plugin.priority()
            );

            self.scan_results.insert(plugin.name().to_string(), result);

            if !result {
                threat_count += 1;
            }
        }

        println!("\n  [스캔 결과]");
        println!("    총 플러그인: {}", self.plugins.len());
        println!("    위협 감지: {}", threat_count);
        if threat_count == 0 {
            println!("    상태: 모두 안전 ✓");
        } else {
            println!("    상태: 위협 감지됨 ✗");
        }
    }

    fn get_plugin_count(&self) -> usize {
        self.plugins.len()
    }
}

