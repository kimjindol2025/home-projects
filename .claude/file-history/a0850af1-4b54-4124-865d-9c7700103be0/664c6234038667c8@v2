#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_missile_system_states() {
        let system = MissileSystem::new();
        let loaded = system.load();
        let aimed = loaded.aim(100);
        let armed = aimed.arm();
        // fire() consumes armed, so we can't test it directly
        // but the compilation itself is the test
    }

    #[test]
    fn test_zst_sizes() {
        assert_eq!(size_of::<Idle>(), 0);
        assert_eq!(size_of::<Loaded>(), 4);  // u32
        assert_eq!(size_of::<Aimed>(), 4);   // u32
        assert_eq!(size_of::<Armed>(), 0);

        assert_eq!(size_of::<MissileSystem<Idle>>(), 4);  // only u32
    }

    #[test]
    fn test_security_document_workflow() {
        let doc = SecurityDocument::new("Test")
            .add_content("Content");
        let reviewed = doc.submit_for_review("reviewer");
        let approved = reviewed.approve();
        let signed = approved.sign("signer");
        // archive() consumes signed
    }

    #[test]
    fn test_task_success_path() {
        let task = Task::new("test");
        let processing = task.execute().unwrap();
        let success = processing.complete_success();
        assert!(success.get_result().contains("성공"));
    }

    #[test]
    fn test_task_retry_path() {
        let task = Task::new("test");
        let processing = task.execute().unwrap();
        let failed = processing.complete_failed("error");
        let ready = failed.retry();
        let processing2 = ready.execute().unwrap();
        let success = processing2.complete_success();
        assert!(success.get_result().contains("성공"));
    }

    #[test]
    fn test_document_rejection() {
        let doc = SecurityDocument::new("Test")
            .add_content("Content");
        let reviewed = doc.submit_for_review("reviewer");
        let draft = reviewed.reject();
        // draft is back in Draft state - can be modified or resubmitted
    }
}
