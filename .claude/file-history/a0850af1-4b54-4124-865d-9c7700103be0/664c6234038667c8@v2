// Phase 10 v11.2: Type State Pattern - Compile-Time State Machines
// "불가능한 상태를 표현 불가능하게 만들기"
// Zero-Cost Abstraction through Type-Level State Transitions

use std::mem::size_of;

// ============================================================================
// Foundation: State Type Markers (Zero-Sized Types)
// ============================================================================

/// 상태 1: 유휴 상태 (메모리 0 바이트)
#[derive(Debug, Clone, Copy)]
struct Idle;

/// 상태 2: 장전 완료 상태
#[derive(Debug, Clone, Copy)]
struct Loaded {
    ammo_count: u32,
}

/// 상태 3: 조준 완료 상태
#[derive(Debug, Clone, Copy)]
struct Aimed {
    target_coords: u32,
}

/// 상태 4: 무장 완료 상태
#[derive(Debug, Clone, Copy)]
struct Armed;

// ============================================================================
// Demo 1: Basic Type State - Missile System
// ============================================================================

/// 타입 매개변수 S로 현재 상태를 표현
#[derive(Debug)]
struct MissileSystem<S> {
    power: u32,
    state: S,
}

// Idle 상태에서만 가능한 메서드들
impl MissileSystem<Idle> {
    fn new() -> Self {
        MissileSystem {
            power: 100,
            state: Idle,
        }
    }

    fn load(self) -> MissileSystem<Loaded> {
        println!("  🔄 [System] 미사일 장전 완료");
        MissileSystem {
            power: self.power,
            state: Loaded { ammo_count: 1 },
        }
    }
}

// Loaded 상태에서만 가능한 메서드
impl MissileSystem<Loaded> {
    fn aim(self, target: u32) -> MissileSystem<Aimed> {
        println!("  🎯 [System] 좌표 {} 조준 완료", target);
        MissileSystem {
            power: self.power,
            state: Aimed {
                target_coords: target,
            },
        }
    }
}

// Aimed 상태에서만 가능한 메서드
impl MissileSystem<Aimed> {
    fn arm(self) -> MissileSystem<Armed> {
        println!("  ⚠️  [System] 무기 무장 완료. 발사 대기 중");
        MissileSystem {
            power: self.power,
            state: Armed,
        }
    }
}

// Armed 상태에서만 가능한 메서드
impl MissileSystem<Armed> {
    fn fire(self) {
        println!("  🚀 [System] 미사일 발사! 타겟 추적 중...");
        println!("  💥 [System] 명중!");
    }
}

fn demo_basic_type_state() {
    println!("\n=== Demo 1: Basic Type State - Missile System ===");
    println!("📋 타입 상태 패턴으로 상태 전이 강제하기:");

    println!("\n정상 흐름 (컴파일 가능):");
    let system = MissileSystem::new();
    println!("✓ 상태 1: Idle (새로운 시스템)");

    let loaded = system.load();
    println!("✓ 상태 2: Loaded (장전 완료)");

    let aimed = loaded.aim(37 * 1000 + 500);  // 37.5N
    println!("✓ 상태 3: Aimed (조준 완료)");

    let armed = aimed.arm();
    println!("✓ 상태 4: Armed (무장 완료)");

    armed.fire();
    println!("✓ 발사 완료");

    println!("\n❌ 불가능한 흐름 (컴파일 불가):");
    println!("  let system = MissileSystem::new();");
    println!("  system.fire();  // error! Idle에는 fire() 메서드 없음");
    println!("\n  let system = MissileSystem::new();");
    println!("  let aimed = system.aim(100);  // error! Loaded 상태 필요");
}

// ============================================================================
// Demo 2: State Transition Chain (Builder-like Pattern)
// ============================================================================

fn demo_state_transition_chain() {
    println!("\n=== Demo 2: State Transition Chain ===");
    println!("⛓️  메서드 체이닝으로 우아한 상태 전이:");

    println!("\n한 줄로 표현되는 완전한 상태 머신:");
    MissileSystem::new()
        .load()
        .aim(127 * 1000)  // 127.0E
        .arm()
        .fire();

    println!("\n✨ 특징:");
    println!("  ├─ 각 메서드가 self를 소비하고 새로운 상태 반환");
    println!("  ├─ Builder 패턴과 유사한 우아한 인터페이스");
    println!("  ├─ 런타임 순서 검증 필요 없음 (컴파일 타임에 강제)");
    println!("  └─ 메모리 오버헤드: 0 바이트 (모든 상태는 ZST)");
}

