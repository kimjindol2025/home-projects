fn demo_zst_memory_verification() {
    println!("\n=== Demo 3: ZST Memory Verification ===");
    println!("📐 타입 상태가 메모리를 차지하지 않음을 검증:");

    println!("\n상태 구조체들의 크기:");
    println!("  Idle:      {} 바이트", size_of::<Idle>());
    println!("  Loaded:    {} 바이트", size_of::<Loaded>());
    println!("  Aimed:     {} 바이트", size_of::<Aimed>());
    println!("  Armed:     {} 바이트", size_of::<Armed>());

    println!("\n미사일 시스템의 크기:");
    println!("  MissileSystem<Idle>:   {} 바이트 (u32만 저장)",
             size_of::<MissileSystem<Idle>>());
    println!("  MissileSystem<Loaded>: {} 바이트",
             size_of::<MissileSystem<Loaded>>());
    println!("  MissileSystem<Aimed>:  {} 바이트",
             size_of::<MissileSystem<Aimed>>());
    println!("  MissileSystem<Armed>:  {} 바이트",
             size_of::<MissileSystem<Armed>>());

    println!("\n✅ Zero-Cost Abstraction 증명:");
    println!("  모든 상태 정보는 컴파일 타임에만 존재");
    println!("  런타임에는 상태 데이터가 메모리를 차지하지 않음");
    println!("  성능 오버헤드: 0 (정적 디스패치와 동일)");
}

// ============================================================================
// Demo 4: Type Safety Verification (Compiler-Enforced)
// ============================================================================

fn demo_type_safety_verification() {
    println!("\n=== Demo 4: Type Safety Verification ===");
    println!("🛡️  컴파일러가 거부하는 불가능한 상태 조합:");

    println!("\n❌ 불가능한 시나리오 1: 장전 없이 조준");
    println!("  let system = MissileSystem::new();  // Idle");
    println!("  let aimed = system.aim(100);  // ERROR!");
    println!("  reason: Idle 상태에는 aim() 메서드가 없음\n");

    println!("❌ 불가능한 시나리오 2: 장전 후 바로 발사");
    println!("  let system = MissileSystem::new();");
    println!("  let loaded = system.load();  // Loaded");
    println!("  loaded.fire();  // ERROR!");
    println!("  reason: Loaded 상태에는 fire() 메서드가 없음\n");

    println!("❌ 불가능한 시나리오 3: 역순 상태 전이");
    println!("  let system = MissileSystem::new();");
    println!("  let loaded = system.load();  // Loaded");
    println!("  let idle = loaded.unload();  // ERROR!");
    println!("  reason: Loaded에는 unload() 메서드가 없음\n");

    println!("✅ 이 모든 에러는 런타임이 아닌 컴파일 타임에 감지됩니다!");
    println!("✅ 설계자의 의도 위반 = 컴파일 불가능");
}

// ============================================================================
// Demo 5: Real-World Example - Security Document Processing
// ============================================================================

#[derive(Debug)]
struct Draft;

#[derive(Debug)]
struct UnderReview {
    reviewer: String,
}

#[derive(Debug)]
struct Approved;

#[derive(Debug)]
struct Signed;

#[derive(Debug)]
struct SecurityDocument<Status> {
    title: String,
    content: String,
    status: Status,
}

// Draft 상태
impl SecurityDocument<Draft> {
    fn new(title: &str) -> Self {
        SecurityDocument {
            title: title.to_string(),
            content: String::new(),
            status: Draft,
        }
    }

    fn add_content(mut self, content: &str) -> Self {
        self.content = content.to_string();
        self
    }

    fn submit_for_review(self, reviewer: &str) -> SecurityDocument<UnderReview> {
        println!("  📤 [Document] 검토 요청: {}", reviewer);
        SecurityDocument {
            title: self.title,
            content: self.content,
            status: UnderReview {
                reviewer: reviewer.to_string(),
            },
        }
    }
}

// UnderReview 상태
impl SecurityDocument<UnderReview> {
    fn approve(self) -> SecurityDocument<Approved> {
        println!("  ✓ [Document] {} 승인됨", self.status.reviewer);
        SecurityDocument {
            title: self.title,
            content: self.content,
            status: Approved,
        }
    }

    fn reject(self) -> SecurityDocument<Draft> {
        println!("  ✗ [Document] 반려됨. 초안으로 돌아감");
        SecurityDocument {
            title: self.title,
            content: self.content,
            status: Draft,
        }
    }
}

// Approved 상태
impl SecurityDocument<Approved> {
    fn sign(self, signer: &str) -> SecurityDocument<Signed> {
        println!("  🔏 [Document] {} 서명됨", signer);
        SecurityDocument {
            title: self.title,
            content: self.content,
            status: Signed,
        }
    }
}

// Signed 상태 (최종)
impl SecurityDocument<Signed> {
    fn archive(self) {
        println!("  📦 [Document] 보안 보관 완료");
        println!("  ✓ 문서 '{}' 처리 완료", self.title);
    }
}

fn demo_security_document() {
    println!("\n=== Demo 5: Real-World Example - Security Document ===");
    println!("📄 보안 문서의 워크플로우 (상태 머신):");

    let doc = SecurityDocument::new("기밀 문서")
        .add_content("이것은 매우 비밀스러운 내용입니다")
        .submit_for_review("security_officer");

    println!("✓ Draft → UnderReview");

    let doc = doc.approve();
    println!("✓ UnderReview → Approved");

    let doc = doc.sign("CISO Kim");
    println!("✓ Approved → Signed");

    doc.archive();
    println!("✓ Signed → Archived");

    println!("\n💡 설계 이점:");
    println!("  ├─ 각 단계에서만 가능한 작업이 명확");
    println!("  ├─ 승인되지 않은 문서는 서명 불가능 (컴파일 에러)");
    println!("  ├─ 잘못된 순서는 아예 표현 불가능");
    println!("  └─ 런타임 검증 코드 필요 없음 (성능 ↑, 버그 ↓)");
}

// ============================================================================
// Demo 6: Conditional State Transitions
// ============================================================================

#[derive(Debug)]
struct Ready;

#[derive(Debug)]
struct Processing;

#[derive(Debug)]
struct Success;

#[derive(Debug)]
struct Failed;

#[derive(Debug)]
struct Task<State> {
    name: String,
    state: State,
}

impl Task<Ready> {
    fn new(name: &str) -> Self {
        Task {
            name: name.to_string(),
            state: Ready,
        }
    }

    fn execute(self) -> Result<Task<Processing>, String> {
        println!("  ⚙️  [Task] {} 실행 시작", self.name);
        Ok(Task {
            name: self.name,
            state: Processing,
        })
    }
}

impl Task<Processing> {
    fn complete_success(self) -> Task<Success> {
        println!("  ✓ [Task] {} 성공 완료", self.name);
        Task {
            name: self.name,
            state: Success,
        }
    }

    fn complete_failed(self, reason: &str) -> Task<Failed> {
        println!("  ✗ [Task] {} 실패: {}", self.name, reason);
        Task {
            name: self.name,
            state: Failed,
        }
    }
}

impl Task<Success> {
    fn get_result(&self) -> String {
        format!("✓ {} 성공 완료!", self.name)
    }
}

impl Task<Failed> {
    fn retry(self) -> Task<Ready> {
        println!("  🔄 [Task] {} 재시도 준비", self.name);
        Task {
            name: self.name,
            state: Ready,
        }
    }
}

fn demo_conditional_transitions() {
    println!("\n=== Demo 6: Conditional State Transitions ===");
    println!("🔀 여러 경로가 가능한 복잡한 상태 머신:");

    println!("\n경로 1: 성공 케이스");
    let task = Task::new("데이터 처리");
    let processing = task.execute().unwrap();
    let success = processing.complete_success();
    println!("  결과: {}", success.get_result());

    println!("\n경로 2: 실패 후 재시도");
    let task = Task::new("네트워크 요청");
    let processing = task.execute().unwrap();
    let failed = processing.complete_failed("타임아웃");
    let ready = failed.retry();
    let processing2 = ready.execute().unwrap();
    let success2 = processing2.complete_success();
    println!("  결과: {}", success2.get_result());

    println!("\n✨ 특징:");
    println!("  ├─ Ready → Processing (필수)");
    println!("  ├─ Processing → Success 또는 Failed (선택)");
    println!("  ├─ Failed → Ready (재시도 가능)");
    println!("  ├─ 잘못된 전이는 컴파일 불가능");
    println!("  └─ 모든 경로가 타입 시스템으로 관리됨");
}

