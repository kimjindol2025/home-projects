// [프로젝트 2] 전자상거래 주문 관리 시스템
// ============================================================================
#[derive(Debug, Clone)]
enum OrderStatus {
    Created { created_at: String },
    Confirmed { confirmation_code: String },
    Shipped { tracking_number: String },
    Delivered { delivered_at: String },
    Cancelled { reason: String },
}

#[derive(Debug, Clone)]
struct Order {
    id: u32,
    customer: String,
    items: Vec<String>,
    status: OrderStatus,
}

struct OrderSystem {
    orders: HashMap<u32, Order>,
    notifications: Vec<String>,
}

impl OrderSystem {
    fn new() -> Self {
        Self {
            orders: HashMap::new(),
            notifications: Vec::new(),
        }
    }

    fn create_order(&mut self, id: u32, customer: &str, items: Vec<&str>) -> Result<(), String> {
        if self.orders.contains_key(&id) {
            return Err(format!("주문 {}는 이미 존재", id));
        }

        let order = Order {
            id,
            customer: String::from(customer),
            items: items.iter().map(|s| s.to_string()).collect(),
            status: OrderStatus::Created {
                created_at: "2026-02-22".to_string(),
            },
        };

        self.orders.insert(id, order);
        self.notifications.push(format!("주문 #{} 생성", id));
        Ok(())
    }

    fn confirm_order(&mut self, id: u32, code: &str) -> Result<(), String> {
        let order = self.orders.get_mut(&id)
            .ok_or(format!("주문 {}를 찾을 수 없음", id))?;

        // 현재 상태가 Created인지 확인
        match &order.status {
            OrderStatus::Created { .. } => {
                order.status = OrderStatus::Confirmed {
                    confirmation_code: String::from(code),
                };
                self.notifications.push(format!("주문 #{} 확정", id));
                Ok(())
            }
            _ => Err("이미 확정된 주문".to_string()),
        }
    }

    fn ship_order(&mut self, id: u32, tracking: &str) -> Result<(), String> {
        let order = self.orders.get_mut(&id)
            .ok_or(format!("주문 {}를 찾을 수 없음", id))?;

        match &order.status {
            OrderStatus::Confirmed { .. } => {
                order.status = OrderStatus::Shipped {
                    tracking_number: String::from(tracking),
                };
                self.notifications.push(format!("주문 #{} 배송 시작", id));
                Ok(())
            }
            _ => Err("확정 상태에서만 배송 가능".to_string()),
        }
    }

    fn report(&self) {
        println!("\n>>> 주문 관리 시스템 현황 <<<");
        for (id, order) in &self.orders {
            let status_text = match &order.status {
                OrderStatus::Created { .. } => "생성됨".to_string(),
                OrderStatus::Confirmed { code } => format!("확정 ({})", code),
                OrderStatus::Shipped { tracking_number } => format!("배송 ({})", tracking_number),
                OrderStatus::Delivered { delivered_at } => format!("배송완료 ({})", delivered_at),
                OrderStatus::Cancelled { reason } => format!("취소 ({})", reason),
            };
            println!("  [#{}] {} → {} 항목: {:?}",
                id, order.customer, status_text, order.items);
        }
    }
}

fn project_order_system() {
    println!("\n[프로젝트 2] 전자상거래 주문 관리 시스템");
    println!("═════════════════════════════════════════");

    let mut system = OrderSystem::new();

    // 주문 생성
    let _ = system.create_order(1001, "Alice", vec!["노트북", "마우스"]);
    let _ = system.create_order(1002, "Bob", vec!["키보드"]);

    // 주문 진행
    let _ = system.confirm_order(1001, "CONF-001");
    let _ = system.ship_order(1001, "TRACK-12345");

    system.report();

    println!("\n✓ 설계: 각 상태가 필요한 데이터를 포함 (Created, Confirmed, Shipped)");
    println!("✓ 패턴: 상태 전이를 메서드로 명시 (create → confirm → ship)");
    println!("✓ 안전성: 불가능한 상태 전이 방지");
}

