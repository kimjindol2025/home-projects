#[derive(Debug, Clone)]
enum DocumentStatus {
    Draft,
    UnderReview { reviewer_id: u32 },
    Approved { approver_id: u32 },
    Published { published_date: String },
    Archived,
}

#[derive(Debug)]
struct Document {
    id: u32,
    title: String,
    status: DocumentStatus,
}

struct DocumentSystem {
    documents: HashMap<u32, Document>,
    workflow_log: Vec<String>,
}

impl DocumentSystem {
    fn new() -> Self {
        Self {
            documents: HashMap::new(),
            workflow_log: Vec::new(),
        }
    }

    fn create_document(&mut self, id: u32, title: &str) -> Result<(), String> {
        if self.documents.contains_key(&id) {
            return Err(format!("문서 {}는 이미 존재", id));
        }

        let doc = Document {
            id,
            title: String::from(title),
            status: DocumentStatus::Draft,
        };

        self.documents.insert(id, doc);
        self.workflow_log.push(format!("[문서] '{}' 작성 시작", title));
        Ok(())
    }

    fn submit_for_review(&mut self, id: u32, reviewer_id: u32) -> Result<(), String> {
        let doc = self.documents.get_mut(&id)
            .ok_or(format!("문서 {}를 찾을 수 없음", id))?;

        match &doc.status {
            DocumentStatus::Draft => {
                doc.status = DocumentStatus::UnderReview { reviewer_id };
                self.workflow_log.push(format!("[리뷰] 문서 {} 검토 대기 (검토자: {})", id, reviewer_id));
                Ok(())
            }
            _ => Err("Draft 상태에서만 리뷰 요청 가능".to_string()),
        }
    }

    fn approve(&mut self, id: u32, approver_id: u32) -> Result<(), String> {
        let doc = self.documents.get_mut(&id)
            .ok_or(format!("문서 {}를 찾을 수 없음", id))?;

        match &doc.status {
            DocumentStatus::UnderReview { .. } => {
                doc.status = DocumentStatus::Approved { approver_id };
                self.workflow_log.push(format!("[승인] 문서 {} 승인 (승인자: {})", id, approver_id));
                Ok(())
            }
            _ => Err("UnderReview 상태에서만 승인 가능".to_string()),
        }
    }

    fn publish(&mut self, id: u32) -> Result<(), String> {
        let doc = self.documents.get_mut(&id)
            .ok_or(format!("문서 {}를 찾을 수 없음", id))?;

        match &doc.status {
            DocumentStatus::Approved { .. } => {
                doc.status = DocumentStatus::Published {
                    published_date: "2026-02-22".to_string(),
                };
                self.workflow_log.push(format!("[발행] 문서 {} 공개", id));
                Ok(())
            }
            _ => Err("Approved 상태에서만 발행 가능".to_string()),
        }
    }

    fn report(&self) {
        println!("\n>>> 문서 워크플로우 현황 <<<");
        for (id, doc) in &self.documents {
            let status_text = match &doc.status {
                DocumentStatus::Draft => "작성중".to_string(),
                DocumentStatus::UnderReview { reviewer_id } => format!("검토중 (검토자: {})", reviewer_id),
                DocumentStatus::Approved { approver_id } => format!("승인됨 (승인자: {})", approver_id),
                DocumentStatus::Published { published_date } => format!("발행됨 ({})", published_date),
                DocumentStatus::Archived => "보관됨".to_string(),
            };
            println!("  [#{}] {} → {}", id, doc.title, status_text);
        }
    }
}

fn project_document_workflow() {
    println!("\n[프로젝트 4] 문서 워크플로우 시스템");
    println!("═════════════════════════════════════════");

    let mut system = DocumentSystem::new();

    // 문서 작성
    let _ = system.create_document(201, "보안 정책");
    let _ = system.create_document(202, "구현 가이드");

    // 워크플로우 진행
    let _ = system.submit_for_review(201, 1);
    let _ = system.approve(201, 2);
    let _ = system.publish(201);

    system.report();

    println!("\n✓ 설계: 상태 전이를 명시적으로 구현 (Draft → Review → Approved → Published)");
    println!("✓ 패턴: 각 상태가 추가 정보 포함 (reviewer_id, approver_id, published_date)");
    println!("✓ 안전성: 잘못된 상태 전이 방지");
}

