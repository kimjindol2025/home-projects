// [프로젝트 3] 권한 관리 시스템
// ============================================================================
#[derive(Debug, Clone, Eq, PartialEq, Hash)]
enum Permission {
    Read,
    Write,
    Delete,
    Admin,
}

#[derive(Debug)]
struct User {
    id: u32,
    name: String,
    permissions: Vec<Permission>,
}

struct UserManager {
    users: HashMap<u32, User>,
    action_logs: Vec<String>,
}

impl UserManager {
    fn new() -> Self {
        Self {
            users: HashMap::new(),
            action_logs: Vec::new(),
        }
    }

    fn add_user(&mut self, id: u32, name: &str, perms: Vec<Permission>) -> Result<(), String> {
        if self.users.contains_key(&id) {
            return Err(format!("사용자 {}는 이미 존재", id));
        }

        let user = User {
            id,
            name: String::from(name),
            permissions: perms,
        };

        self.users.insert(id, user);
        self.action_logs.push(format!("[사용자] {} 추가", name));
        Ok(())
    }

    fn has_permission(&self, user_id: u32, perm: Permission) -> bool {
        self.users
            .get(&user_id)
            .map(|u| u.permissions.contains(&perm))
            .unwrap_or(false)
    }

    fn grant_permission(&mut self, user_id: u32, perm: Permission) -> Result<(), String> {
        match self.users.get_mut(&user_id) {
            Some(user) => {
                if !user.permissions.contains(&perm) {
                    user.permissions.push(perm.clone());
                    self.action_logs.push(format!("[권한] 사용자 {} 권한 부여: {:?}", user_id, perm));
                }
                Ok(())
            }
            None => Err(format!("사용자 {}를 찾을 수 없음", user_id)),
        }
    }

    fn check_action(&self, user_id: u32, action: &str, perm: Permission) -> bool {
        if self.has_permission(user_id, perm) {
            println!("  ✓ 사용자 {}의 [{}] 행동 승인", user_id, action);
            true
        } else {
            println!("  ✗ 사용자 {}의 [{}] 행동 거부", user_id, action);
            false
        }
    }

    fn report(&self) {
        println!("\n>>> 권한 관리 리포트 <<<");
        for (id, user) in &self.users {
            println!("  [{}] {} → 권한: {:?}", id, user.name, user.permissions);
        }
    }
}

fn project_user_permissions() {
    println!("\n[프로젝트 3] 권한 관리 시스템");
    println!("═════════════════════════════════════════");

    let mut manager = UserManager::new();

    // 사용자 추가
    let _ = manager.add_user(1, "Alice", vec![Permission::Read, Permission::Write]);
    let _ = manager.add_user(2, "Bob", vec![Permission::Read]);
    let _ = manager.add_user(3, "Charlie", vec![Permission::Admin]);

    // 권한 검사
    println!("\n[권한 검사]");
    manager.check_action(1, "쓰기", Permission::Write);
    manager.check_action(2, "삭제", Permission::Delete);
    manager.check_action(3, "관리", Permission::Admin);

    // 권한 부여
    println!("\n[권한 부여]");
    let _ = manager.grant_permission(2, Permission::Delete);
    manager.check_action(2, "삭제", Permission::Delete);

    manager.report();

    println!("\n✓ 설계: HashMap<사용자ID, 권한목록>으로 빠른 검색");
    println!("✓ 패턴: Permission을 공통 타입으로 사용하여 확장성 확보");
    println!("✓ 안전성: Option과 contains로 존재성 확인");
}

