// [프로젝트 1] 보안 관제 시스템
// ============================================================================
#[derive(Debug, Clone)]
enum NodeStatus {
    Active,
    Warning(String),
    Critical,
}

#[derive(Debug, Clone)]
struct SecurityNode {
    id: u32,
    location: String,
    status: NodeStatus,
}

struct ControlCenter {
    center_name: String,
    nodes: HashMap<u32, SecurityNode>,
    logs: Vec<String>,
}

impl ControlCenter {
    fn new(name: &str) -> Self {
        Self {
            center_name: String::from(name),
            nodes: HashMap::new(),
            logs: Vec::new(),
        }
    }

    fn register_node(&mut self, id: u32, location: &str) -> Result<(), String> {
        if self.nodes.contains_key(&id) {
            return Err(format!("노드 {}는 이미 등록됨", id));
        }

        let node = SecurityNode {
            id,
            location: String::from(location),
            status: NodeStatus::Active,
        };

        self.nodes.insert(id, node);
        self.logs.push(format!("[등록] 노드 {} 추가 ({})", id, location));
        Ok(())
    }

    fn update_status(&mut self, id: u32, status: NodeStatus) -> Result<(), String> {
        match self.nodes.get_mut(&id) {
            Some(node) => {
                node.status = status;
                self.logs.push(format!("[상태] 노드 {} 상태 변경", id));
                Ok(())
            }
            None => Err(format!("노드 {}를 찾을 수 없음", id)),
        }
    }

    fn audit(&self) {
        println!("\n>>> [{}] 보안 관제 리포트 <<<", self.center_name);
        for (id, node) in &self.nodes {
            let status_text = match &node.status {
                NodeStatus::Active => "✓ 정상".to_string(),
                NodeStatus::Warning(msg) => format!("⚠ 주의: {}", msg),
                NodeStatus::Critical => "✗ 치명적".to_string(),
            };
            println!("  [#{}] {} → {}", id, node.location, status_text);
        }
        println!("  기록: {} 건", self.logs.len());
    }
}

fn project_security_center() {
    println!("\n[프로젝트 1] 보안 관제 시스템");
    println!("═════════════════════════════════════════");

    let mut center = ControlCenter::new("GOGS-HQ");

    // 노드 등록
    let _ = center.register_node(101, "메인 게이트");
    let _ = center.register_node(202, "서버실");
    let _ = center.register_node(303, "통신실");

    // 상태 업데이트
    let _ = center.update_status(202, NodeStatus::Warning("비정상 접근 감지".to_string()));

    center.audit();

    println!("\n✓ 설계: ControlCenter가 모든 노드 데이터의 주인");
    println!("✓ 패턴: register_node와 update_status로 접근 제어");
    println!("✓ 안전성: Result로 오류 처리");
}

