print("\n[9단계] 딕셔너리 데이터를 파일로 저장")
print("-" * 70)

student_data = {
    "Alice": {"수학": 95, "영어": 88, "과학": 92},
    "Bob": {"수학": 87, "영어": 91, "과학": 85},
}

data_file = "student_data.txt"

print("코드: 딕셔너리를 파일로 저장")
with open(data_file, "w", encoding="utf-8") as file:
    for name, scores in student_data.items():
        file.write(f"{name}|{scores['수학']}|{scores['영어']}|{scores['과학']}\n")

print(f"✓ 딕셔너리 데이터를 '{data_file}'로 저장했습니다.")

print("\n저장된 파일 내용:")
with open(data_file, "r", encoding="utf-8") as file:
    for line in file:
        print(f"  {line.rstrip()}")

# ============================================================================
# [10단계] 리스트 데이터 저장 및 로드
