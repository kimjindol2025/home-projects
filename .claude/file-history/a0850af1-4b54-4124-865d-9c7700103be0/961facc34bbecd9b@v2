print("-" * 70)

log_file = "learning_log.txt"

print("Step 1: 학습 기록 추가")
def add_learning_record(task, status):
    with open(log_file, "a", encoding="utf-8") as file:
        timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        file.write(f"[{timestamp}] {task}: {status}\n")

add_learning_record("v1.1 변수", "완료")
add_learning_record("v1.2 연산자", "완료")
add_learning_record("v1.3 리스트", "완료")
add_learning_record("v1.4 반복문", "완료")
add_learning_record("v1.5 조건문", "완료")
add_learning_record("v1.6 함수", "완료")
add_learning_record("v1.7 딕셔너리", "완료")
add_learning_record("v1.8 튜플과 집합", "완료")
add_learning_record("v1.9 리스트 컴프리헨션", "완료")
add_learning_record("v2.0 파일 입출력", "진행 중")

print("  ✓ 학습 기록이 저장되었습니다.")

print("\nStep 2: 학습 기록 조회")
print("  저장된 학습 기록:")
with open(log_file, "r", encoding="utf-8") as file:
    for line in file:
        print(f"    {line.rstrip()}")

print("\nStep 3: 통계")
with open(log_file, "r", encoding="utf-8") as file:
    records = file.readlines()
    completed = sum(1 for line in records if "완료" in line)
    in_progress = sum(1 for line in records if "진행 중" in line)

print(f"  완료: {completed}개")
print(f"  진행 중: {in_progress}개")
print(f"  전체: {completed + in_progress}개")

