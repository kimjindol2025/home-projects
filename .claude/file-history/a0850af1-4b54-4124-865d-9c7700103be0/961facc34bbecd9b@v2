print("\n[10단계] 리스트 데이터 저장 및 로드")
print("-" * 70)

numbers = [1, 2, 3, 4, 5, 10, 20, 30, 40, 50]
list_file = "numbers.txt"

print("Step 1: 리스트를 파일로 저장")
with open(list_file, "w", encoding="utf-8") as file:
    for num in numbers:
        file.write(f"{num}\n")

print(f"  ✓ {len(numbers)}개의 숫자를 저장했습니다.")

print("\nStep 2: 파일에서 리스트 로드")
loaded_numbers = []
with open(list_file, "r", encoding="utf-8") as file:
    for line in file:
        loaded_numbers.append(int(line.rstrip()))

print(f"  원본 리스트:  {numbers}")
print(f"  로드된 리스트: {loaded_numbers}")
print(f"  같은가? {numbers == loaded_numbers}")

# ============================================================================
# [11단계] 실전: 학습 기록 시스템
