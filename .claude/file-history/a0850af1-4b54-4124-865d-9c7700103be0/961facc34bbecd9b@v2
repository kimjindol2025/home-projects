"""
Python Middle School v2.0 - 파일 입출력(File I/O) — 영원히 남는 기록

탐구(중학교 졸업): "메모리를 넘어 하드디스크에 기록하기"

프로그램을 종료하면 메모리에 있던 변수와 리스트는 모두 사라집니다.
하지만 '기록이 증명'되려면 데이터를 물리적인 파일로 저장해야 합니다.
이것이 나중에 고등학교 과정에서 배울 '데이터베이스'와 '지속성'의 기초입니다.

파이썬은 파일을 다루는 매우 안전하고 우아한 방법인 'with 문'을 제공합니다.

1. 파일 열기 모드
   - 'w' (Write): 새로 쓰기 (기존 내용이 사라짐)
   - 'a' (Append): 이어 쓰기 (기존 기록 뒤에 덧붙임)
   - 'r' (Read): 읽기 (저장된 기록을 불러옴)

2. with 문의 마법
   - 파일을 열면 반드시 닫아야(close) 컴퓨터 자원이 낭비되지 않습니다.
   - with 문을 사용하면 파이썬이 알아서 파일을 열고, 작업이 끝나면 자동으로 닫아줍니다.
   - 이것이 '중등 과정의 안전장치'입니다.

3. encoding="utf-8"
   - 한글을 저장할 때 깨지지 않도록 해주는 표준 약속입니다.
   - 기록의 무결성을 위해 항상 사용하는 습관을 들여야 합니다.
"""

import os
from datetime import datetime

print("=" * 70)
print("# Python Middle School v2.0 - 파일 입출력(File I/O)")
print("=" * 70)

# ============================================================================
# [1단계] 파일에 텍스트 쓰기 (Write Mode)
# ============================================================================

print("\n[1단계] 파일에 텍스트 쓰기 (Write Mode 'w')")
print("-" * 70)

file_name = "gogs_record.txt"

print("코드:")
print('  with open("gogs_record.txt", "w", encoding="utf-8") as file:')
print('      file.write("내용")')
print()

print("실행: 파일에 기록 저장 중...")
with open(file_name, "w", encoding="utf-8") as file:
    file.write("파이썬 중학교 학습 기록\n")
    file.write("=" * 40 + "\n")
    file.write(f"날짜: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n")
    file.write("상태: 중학교 과정 진행 중\n")
    file.write("철학: 저장 필수 너는 기록이 증명이다 gogs\n")

print(f"✓ 파일 '{file_name}'이 생성되었습니다.")

print("\n설명:")
print("  ✓ 'w' 모드는 새로운 파일을 만들거나 기존 파일을 덮어씁니다.")
print("  ✓ encoding='utf-8'은 한글이 깨지지 않도록 보장합니다.")
print("  ✓ with 블록이 끝나면 파이썬이 자동으로 파일을 닫습니다.")

# ============================================================================
# [2단계] 파일에서 텍스트 읽기 (Read Mode)
# ============================================================================

print("\n[2단계] 파일에서 텍스트 읽기 (Read Mode 'r')")
print("-" * 70)

print("코드:")
print('  with open("gogs_record.txt", "r", encoding="utf-8") as file:')
print('      content = file.read()')
print()

print("실행: 저장된 기록 불러오기...")
with open(file_name, "r", encoding="utf-8") as file:
    content = file.read()
    print(content)

print("설명:")
print("  ✓ 'r' 모드는 기존 파일을 읽기만 합니다.")
print("  ✓ .read()는 파일 전체 내용을 문자열로 반환합니다.")

# ============================================================================
# [3단계] 파일에 내용 추가하기 (Append Mode)
# ============================================================================

print("\n[3단계] 파일에 내용 추가하기 (Append Mode 'a')")
print("-" * 70)

print("코드:")
print('  with open("gogs_record.txt", "a", encoding="utf-8") as file:')
print('      file.write("새로운 내용")')
print()

print("실행: 새로운 기록 추가 중...")
with open(file_name, "a", encoding="utf-8") as file:
    file.write("\n추가 기록\n")
    file.write("=" * 40 + "\n")
    file.write("v2.0: 파일 입출력 학습 완료\n")
    file.write("다음 단계: 고등학교 과정 진급\n")

print(f"✓ 파일 '{file_name}'에 내용이 추가되었습니다.")

print("\n설명:")
print("  ✓ 'a' 모드는 기존 내용 뒤에 새로운 내용을 추가합니다.")
print("  ✓ 'w' 모드와 달리 기존 내용을 보존합니다.")

# ============================================================================
# [4단계] with 문의 중요성
# ============================================================================

print("\n[4단계] with 문의 중요성 - 자동 close")
print("-" * 70)

print("❌ 나쁜 예제: 파일을 명시적으로 닫지 않음")
print("  file = open('test.txt', 'w')")
print("  file.write('내용')")
print("  # file.close() ← 이것을 빼먹으면 파일이 닫히지 않음")

print("\n✓ 좋은 예제: with 문으로 자동 close")
print("  with open('test.txt', 'w') as file:")
print("      file.write('내용')")
print("      # with 블록 끝나면 자동으로 close")

print("\n설명:")
print("  ✓ with 문을 사용하면 파일을 명시적으로 닫을 필요가 없습니다.")
print("  ✓ 파이썬이 자동으로 cleanup 처리를 해줍니다.")
print("  ✓ 프로그래머는 더 깨끗한 코드를 작성할 수 있습니다.")
print("  ✓ 이것이 파이썬의 '우아함'입니다.")

# ============================================================================
# [5단계] 여러 줄 읽기 - readline() vs readlines()
# ============================================================================

print("\n[5단계] 여러 줄 읽기 - readline() vs readlines()")
print("-" * 70)

print("방법 1: readlines() - 모든 줄을 리스트로 반환")
with open(file_name, "r", encoding="utf-8") as file:
    lines = file.readlines()
    print(f"  전체 줄 개수: {len(lines)}")
    print("  첫 3줄:")
    for i, line in enumerate(lines[:3]):
        print(f"    [{i}] {line.rstrip()}")

print("\n방법 2: 반복문으로 라인 단위 처리")
with open(file_name, "r", encoding="utf-8") as file:
    print("  각 줄의 길이:")
    for i, line in enumerate(file):
        print(f"    Line {i}: {len(line)} 문자")

print("\n설명:")
print("  ✓ .readlines(): 모든 줄을 리스트로 반환")
print("  ✓ for line in file: 각 줄을 순회 (메모리 효율적)")

# ============================================================================
# [6단계] CSV 파일 만들기
# ============================================================================

print("\n[6단계] CSV 파일 만들기 (comma-separated values)")
print("-" * 70)

csv_file = "grades.csv"

print("코드: CSV 파일 생성")
with open(csv_file, "w", encoding="utf-8") as file:
    file.write("학생,수학,영어,과학\n")
    file.write("Alice,95,88,92\n")
    file.write("Bob,87,91,85\n")
    file.write("Charlie,92,89,94\n")

print(f"✓ '{csv_file}' 파일이 생성되었습니다.")

print("\n생성된 CSV 파일 내용:")
with open(csv_file, "r", encoding="utf-8") as file:
    print(file.read())

print("설명:")
print("  ✓ CSV는 데이터를 쉼표로 구분하는 텍스트 포맷입니다.")
print("  ✓ 스프레드시트 프로그램(Excel 등)에서 열 수 있습니다.")

# ============================================================================
# [7단계] 라인 단위 처리 및 분석
# ============================================================================

print("\n[7단계] 라인 단위 처리 및 분석")
print("-" * 70)

print("코드: CSV 파일 읽고 분석하기")
with open(csv_file, "r", encoding="utf-8") as file:
    header = file.readline().rstrip()
    print(f"헤더: {header}")

    print("\n학생별 성적 분석:")
    for line in file:
        data = line.rstrip().split(",")
        name, math, english, science = data
        average = (int(math) + int(english) + int(science)) / 3
        print(f"  {name}: 평균 = {average:.1f}")

# ============================================================================
# [8단계] 파일 존재 확인 및 기본 에러 처리
# ============================================================================

print("\n[8단계] 파일 존재 확인 및 에러 처리")
print("-" * 70)

print("방법 1: os.path.exists()로 파일 존재 확인")
if os.path.exists(file_name):
    print(f"  ✓ '{file_name}' 파일이 존재합니다.")
    file_size = os.path.getsize(file_name)
    print(f"  파일 크기: {file_size} 바이트")
else:
    print(f"  ✗ '{file_name}' 파일을 찾을 수 없습니다.")

print("\n방법 2: try-except로 에러 처리")
try:
    with open("없는_파일.txt", "r", encoding="utf-8") as file:
        content = file.read()
except FileNotFoundError:
    print("  ✗ 파일을 찾을 수 없습니다. (에러 처리됨)")

print("\n설명:")
print("  ✓ os.path.exists(): 파일이 존재하는지 확인")
print("  ✓ os.path.getsize(): 파일 크기 확인")
print("  ✓ try-except: 파일이 없을 때의 에러 처리")

