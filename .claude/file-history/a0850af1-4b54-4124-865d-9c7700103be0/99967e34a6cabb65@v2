@dataclass
class Server:
    """서버 인스턴스"""
    id: str = field(default_factory=lambda: str(uuid.uuid4())[:8])
    capacity: int = 100  # 최대 동시 요청
    current_load: int = 0
    is_healthy: bool = True
    processed_requests: int = 0

    def can_accept_request(self) -> bool:
        """요청을 받을 수 있는가"""
        return self.is_healthy and self.current_load < self.capacity

    def process_request(self, request_id: str) -> bool:
        """요청 처리"""
        if not self.can_accept_request():
            return False

        self.current_load += 1
        self.processed_requests += 1
        return True

    def complete_request(self):
        """요청 완료"""
        self.current_load = max(0, self.current_load - 1)


class LoadBalancingStrategy(ABC):
    """로드 밸런싱 전략 (v5.4 Strategy 패턴 활용)"""

    @abstractmethod
    def select_server(self, servers: List[Server]) -> Optional[Server]:
        pass


class RoundRobinStrategy(LoadBalancingStrategy):
    """라운드 로빈: 순서대로 분배"""

    def __init__(self):
        self.current_index = 0

    def select_server(self, servers: List[Server]) -> Optional[Server]:
        """순서대로 선택"""
        healthy_servers = [s for s in servers if s.is_healthy]
        if not healthy_servers:
            return None

        server = healthy_servers[self.current_index % len(healthy_servers)]
        self.current_index += 1
        return server


class LeastConnectionStrategy(LoadBalancingStrategy):
    """최소 연결: 가장 적은 요청을 받는 서버 선택"""

    def select_server(self, servers: List[Server]) -> Optional[Server]:
        """부하가 가장 적은 서버 선택"""
        healthy_servers = [s for s in servers if s.is_healthy]
        if not healthy_servers:
            return None

        return min(healthy_servers, key=lambda s: s.current_load)


class WeightedLoadBalanceStrategy(LoadBalancingStrategy):
    """가중 로드 밸런싱: 성능에 따라 가중치 부여"""

    def __init__(self, weights: Dict[str, float]):
        self.weights = weights

    def select_server(self, servers: List[Server]) -> Optional[Server]:
        """가중치를 고려하여 선택"""
        healthy_servers = [s for s in servers if s.is_healthy]
        if not healthy_servers:
            return None

        # 점수 계산: (용량 - 현재부하) * 가중치
        scored_servers = []
        for server in healthy_servers:
            weight = self.weights.get(server.id, 1.0)
            score = (server.capacity - server.current_load) * weight
            scored_servers.append((score, server))

        return max(scored_servers, key=lambda x: x[0])[1]


class LoadBalancer:
    """로드 밸런서 (v5.4 Facade 패턴 활용)"""

    def __init__(self, strategy: LoadBalancingStrategy):
        self.servers: List[Server] = []
        self.strategy = strategy
        self.request_log: List[Dict] = []

    def add_server(self, server: Server) -> None:
        """서버 추가"""
        self.servers.append(server)

    def route_request(self, request_id: str) -> bool:
        """요청을 서버로 라우팅"""
        server = self.strategy.select_server(self.servers)

        if server is None:
            self.request_log.append({
                "request_id": request_id,
                "status": "REJECTED",
                "timestamp": datetime.now().isoformat()
            })
            return False

        success = server.process_request(request_id)
        self.request_log.append({
            "request_id": request_id,
            "server_id": server.id,
            "status": "ACCEPTED",
            "timestamp": datetime.now().isoformat()
        })
        return success

    def get_stats(self) -> Dict:
        """통계 조회"""
        return {
            "total_servers": len(self.servers),
            "healthy_servers": sum(1 for s in self.servers if s.is_healthy),
            "total_capacity": sum(s.capacity for s in self.servers),
            "current_load": sum(s.current_load for s in self.servers),
            "total_requests_processed": sum(s.processed_requests for s in self.servers),
        }


