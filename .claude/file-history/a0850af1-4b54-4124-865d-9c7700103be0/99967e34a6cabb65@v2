@dataclass
class Task:
    """작업"""
    id: str = field(default_factory=lambda: str(uuid.uuid4())[:8])
    data: str = ""
    status: str = "PENDING"
    result: Optional[str] = None
    created_at: str = field(default_factory=lambda: datetime.now().isoformat())
    completed_at: Optional[str] = None
    worker_id: Optional[str] = None


class WorkerNode:
    """작업 노드 (v4.2 멀티프로세싱 개념 활용)"""

    def __init__(self, node_id: str):
        self.node_id = node_id
        self.current_task: Optional[Task] = None
        self.completed_tasks: List[Task] = []
        self.is_available = True

    def process_task(self, task: Task) -> Task:
        """작업 처리"""
        if not self.is_available:
            return task

        self.current_task = task
        task.status = "PROCESSING"
        task.worker_id = self.node_id

        # 시뮬레이션: 작업 처리
        time.sleep(0.01)
        task.result = f"Processed by {self.node_id}: {task.data}"
        task.status = "COMPLETED"
        task.completed_at = datetime.now().isoformat()

        self.completed_tasks.append(task)
        self.current_task = None

        return task

    def get_status(self) -> Dict:
        """노드 상태"""
        return {
            "node_id": self.node_id,
            "is_available": self.is_available,
            "completed_tasks": len(self.completed_tasks),
        }


class DistributedTaskEngine:
    """분산 작업 처리 엔진 (v5.1 마이크로서비스 개념 활용)"""

    def __init__(self, num_workers: int = 3):
        self.workers = [WorkerNode(f"worker_{i}") for i in range(num_workers)]
        self.task_queue: List[Task] = []
        self.completed_tasks: List[Task] = []
        self.load_balancer = LoadBalancer(LeastConnectionStrategy())

    def submit_task(self, data: str) -> Task:
        """작업 제출"""
        task = Task(data=data)
        self.task_queue.append(task)
        return task

    def process_tasks(self) -> int:
        """큐에 있는 작업 처리"""
        processed_count = 0

        for task in self.task_queue:
            if task.status == "PENDING":
                # 가용 워커 찾기
                available_workers = [w for w in self.workers if w.is_available]
                if not available_workers:
                    break

                # 부하가 가장 적은 워커 선택
                worker = min(available_workers, key=lambda w: len(w.completed_tasks))

                # 작업 처리
                completed_task = worker.process_task(task)
                self.completed_tasks.append(completed_task)
                self.task_queue.remove(task)
                processed_count += 1

        return processed_count

    def get_system_status(self) -> Dict:
        """시스템 상태"""
        return {
            "pending_tasks": len([t for t in self.task_queue if t.status == "PENDING"]),
            "completed_tasks": len(self.completed_tasks),
            "workers": [w.get_status() for w in self.workers],
        }


def demonstrate_distributed_engine():
    """분산 작업 처리 엔진 시연"""
    print("\n" + "="*80)
    print("STAGE 5: 분산 작업 처리 엔진")
    print("="*80)

    engine = DistributedTaskEngine(num_workers=3)

    print("\n📊 대량 작업 처리:")
    print("   100개 작업 제출 중...")

    for i in range(100):
        engine.submit_task(f"Task_{i}_Data")

    print(f"   → 제출 완료: {len(engine.task_queue)}개")

    # 작업 처리
    total_processed = 0
    while len(engine.task_queue) > 0:
        processed = engine.process_tasks()
        total_processed += processed
        if processed == 0:
            break

    status = engine.get_system_status()
    print(f"\n   처리 완료: {total_processed}개 작업")
    print(f"   남은 작업: {status['pending_tasks']}개")
    print(f"   총 완료: {status['completed_tasks']}개")

    print("\n   워커별 상태:")
    for worker_status in status['workers']:
        print(f"   - {worker_status['node_id']}: {worker_status['completed_tasks']}개 처리")


