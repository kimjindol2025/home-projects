class Metrics:
    """메트릭 수집 (v5.4 Observer 패턴 활용)"""

    def __init__(self):
        self.cpu_usage: List[float] = []
        self.memory_usage: List[float] = []
        self.request_latency: List[float] = []
        self.error_rate: List[float] = []

    def record_cpu(self, usage: float) -> None:
        """CPU 사용률 기록"""
        self.cpu_usage.append(usage)

    def record_latency(self, latency: float) -> None:
        """요청 지연 시간 기록"""
        self.request_latency.append(latency)

    def get_average_latency(self) -> float:
        """평균 지연 시간"""
        if not self.request_latency:
            return 0
        return sum(self.request_latency) / len(self.request_latency)

    def get_p99_latency(self) -> float:
        """99 percentile 지연 시간 (상위 1%)"""
        if not self.request_latency:
            return 0
        sorted_latencies = sorted(self.request_latency)
        index = int(len(sorted_latencies) * 0.99)
        return sorted_latencies[index] if index < len(sorted_latencies) else 0

    def get_summary(self) -> Dict:
        """메트릭 요약"""
        return {
            "requests_recorded": len(self.request_latency),
            "average_latency_ms": f"{self.get_average_latency():.2f}",
            "p99_latency_ms": f"{self.get_p99_latency():.2f}",
