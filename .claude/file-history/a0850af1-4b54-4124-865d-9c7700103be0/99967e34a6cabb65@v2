class AutoScaler:
    """오토 스케일러: 부하에 따라 서버 자동 추가/제거"""

    def __init__(self, min_servers: int = 2, max_servers: int = 10):
        self.min_servers = min_servers
        self.max_servers = max_servers
        self.servers: List[Server] = []
        self.load_history: List[float] = []

    def add_server(self) -> Optional[Server]:
        """서버 추가"""
        if len(self.servers) >= self.max_servers:
            return None

        server = Server()
        self.servers.append(server)
        return server

    def remove_server(self) -> Optional[Server]:
        """서버 제거"""
        if len(self.servers) <= self.min_servers:
            return None

        # 부하가 없는 서버 제거
        idle_servers = [s for s in self.servers if s.current_load == 0]
        if idle_servers:
            server = idle_servers[0]
            self.servers.remove(server)
            return server

        return None

    def check_and_scale(self) -> str:
        """부하 확인 및 스케일링 결정"""
        if not self.servers:
            return "NO_SERVERS"

        # 평균 부하 계산
        avg_load = sum(s.current_load for s in self.servers) / len(self.servers)
        load_ratio = avg_load / 100  # 정규화

        self.load_history.append(load_ratio)

        if load_ratio > 0.8 and len(self.servers) < self.max_servers:
            self.add_server()
            return "SCALED_UP"
        elif load_ratio < 0.3 and len(self.servers) > self.min_servers:
            self.remove_server()
            return "SCALED_DOWN"
        else:
            return "NO_ACTION"

    def get_status(self) -> Dict:
        """스케일러 상태"""
        return {
            "server_count": len(self.servers),
            "min_servers": self.min_servers,
            "max_servers": self.max_servers,
            "avg_load": sum(s.current_load for s in self.servers) / len(self.servers) if self.servers else 0,
        }


