class HealthCheck:
    """헬스 체크: 서버의 상태 모니터링"""

    def __init__(self, check_interval: int = 5):
        self.check_interval = check_interval
        self.last_check = {}

    def check_server(self, server: Server) -> bool:
        """서버 상태 확인"""
        # 실제로는 HTTP 요청, 데이터베이스 연결 등을 확인
        # 시뮬레이션: 5% 확률로 실패
        is_healthy = random.random() > 0.05

        if not is_healthy:
            print(f"   ⚠️ [HealthCheck] 서버 {server.id} 장애 감지!")

        return is_healthy


class FailoverManager:
    """장애 복구 관리자: 서버 장애 시 자동 조치"""

    def __init__(self, load_balancer: LoadBalancer):
        self.load_balancer = load_balancer
        self.health_check = HealthCheck()
        self.failover_log: List[Dict] = []

    def monitor_and_recover(self) -> int:
        """서버 모니터링 및 장애 복구"""
        recovered_count = 0

        for server in self.load_balancer.servers:
            is_healthy = self.health_check.check_server(server)

            if not is_healthy and server.is_healthy:
                # 서버 장애 감지
                self._failover(server)
                recovered_count += 1
            elif is_healthy and not server.is_healthy:
                # 서버 복구
                server.is_healthy = True
                print(f"   ✅ 서버 {server.id} 복구됨!")

        return recovered_count

    def _failover(self, failed_server: Server) -> None:
        """장애 복구 실행"""
        failed_server.is_healthy = False

        # 해당 서버의 요청을 다른 서버로 이관
        self.failover_log.append({
            "failed_server": failed_server.id,
            "timestamp": datetime.now().isoformat(),
            "requests_rerouted": failed_server.current_load,
        })

        print(f"   🔄 서버 {failed_server.id} 장애 → {failed_server.current_load}개 요청 재라우팅")


