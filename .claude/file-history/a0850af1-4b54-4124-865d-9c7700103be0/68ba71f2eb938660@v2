class SchoolClass:
    """학급을 관리하는 클래스"""

    def __init__(self, class_name, teacher):
        self.class_name = class_name
        self.teacher = teacher
        self.students = []
        print(f"📚 학급 [{self.class_name}] 개설 (담임: {self.teacher})")

    def add_student(self, student):
        """학생 추가"""
        self.students.append(student)
        print(f"  ✓ {student.name} 학생 추가")

    def show_class_info(self):
        """학급 정보 출력"""
        print(f"\n--- {self.class_name} 정보 ---")
        print(f"담임: {self.teacher}")
        print(f"학생 수: {len(self.students)}")
        print("학생 목록:")
        for i, student in enumerate(self.students, 1):
            avg = student.get_average() if student.scores else 0
            print(f"  {i}. {student.name} - 평균: {avg:.1f}점")
        print("-" * 25)

