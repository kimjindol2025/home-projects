class BankAccount:
    """은행 계좌를 나타내는 클래스"""

    def __init__(self, account_owner, initial_balance):
        self.owner = account_owner
        self.balance = initial_balance
        print(f"✓ 계좌 생성: {self.owner} (초기 잔액: {self.balance:,}원)")

    def deposit(self, amount):
        """입금"""
        self.balance += amount
        print(f"  입금: {amount:,}원 → 잔액: {self.balance:,}원")

    def withdraw(self, amount):
        """출금"""
        if self.balance >= amount:
            self.balance -= amount
            print(f"  출금: {amount:,}원 → 잔액: {self.balance:,}원")
        else:
            print(f"  [ERROR] 잔액 부족! 현재 잔액: {self.balance:,}원")

account = BankAccount("김철수", 100000)
account.deposit(50000)
account.withdraw(30000)
account.withdraw(150000)

