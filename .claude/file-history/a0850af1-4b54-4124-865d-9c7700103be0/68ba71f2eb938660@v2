class Student:
    """학생 정보를 관리하는 클래스"""

    def __init__(self, name, student_id, grade):
        """학생 정보 초기화"""
        self.name = name
        self.student_id = student_id
        self.grade = grade
        self.scores = []
        print(f"✓ 학생 [{self.name}] (학번: {self.student_id}) 등록됨")

    def add_score(self, subject, score):
        """시험 성적 추가"""
        self.scores.append({"subject": subject, "score": score})
        print(f"  성적 기록: {subject} = {score}점")

    def get_average(self):
        """평균 점수 계산"""
        if not self.scores:
            return 0
        total = sum(s["score"] for s in self.scores)
        return total / len(self.scores)

    def display_info(self):
        """학생 정보 출력"""
        print(f"\n--- 학생 정보 ---")
        print(f"이름: {self.name}")
        print(f"학번: {self.student_id}")
        print(f"학년: {self.grade}학년")
        print(f"평균 점수: {self.get_average():.1f}점")
        print("-" * 20)

print("학생 관리 시스템:")
student1 = Student("Alice", "2024001", 1)
student1.add_score("수학", 95)
student1.add_score("영어", 88)
student1.add_score("과학", 92)
student1.display_info()

