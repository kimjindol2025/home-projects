class Person:
    """사람을 나타내는 클래스"""

    def __init__(self, name, age):
        self.name = name
        self.age = age

    def __str__(self):
        """객체를 문자열로 표현하는 특수 메서드"""
        return f"{self.name}({self.age}세)"

    def __repr__(self):
        """개발자용 표현"""
        return f"Person(name='{self.name}', age={self.age})"

print("__str__ 메서드의 역할:")
person1 = Person("Charlie", 25)
print(f"print(person1) = {person1}")
print(f"str(person1) = {str(person1)}")
print(f"repr(person1) = {repr(person1)}")

print("\n설명:")
print("  ✓ __str__: 사용자가 보기 좋은 형태")
print("  ✓ __repr__: 개발자가 보기 좋은 형태")

