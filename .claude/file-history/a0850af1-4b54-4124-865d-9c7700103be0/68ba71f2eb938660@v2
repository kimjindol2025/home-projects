class Temperature:
    """온도 변환을 담당하는 클래스"""

    def __init__(self, celsius):
        self.celsius = celsius

    def to_fahrenheit(self):
        """인스턴스 메서드: 자신의 속성을 사용"""
        return (self.celsius * 9/5) + 32

    @staticmethod
    def celsius_to_fahrenheit(c):
        """정적 메서드: 객체 생성 없이도 호출 가능"""
        return (c * 9/5) + 32

    @classmethod
    def from_fahrenheit(cls, fahrenheit):
        """클래스 메서드: 클래스 정보를 사용"""
        celsius = (fahrenheit - 32) * 5/9
        return cls(celsius)

print("온도 변환 예제:")
temp = Temperature(25)
print(f"25°C = {temp.to_fahrenheit():.1f}°F")
print(f"정적 메서드: {Temperature.celsius_to_fahrenheit(30):.1f}°F")
temp2 = Temperature.from_fahrenheit(77)
print(f"클래스 메서드로 생성: {temp2.celsius:.1f}°C")

