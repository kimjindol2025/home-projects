class GogsRobot:
    """실험 데이터를 수집하고 기록하는 로봇 설계도"""

    def __init__(self, name, model_id):
        """객체가 생성될 때 자동으로 호출되는 초기화 메서드"""
        self.name = name              # 속성 1: 이름
        self.model_id = model_id      # 속성 2: 모델 ID
        self.data_count = 0           # 속성 3: 데이터 개수 (초기값 0)
        print(f"🤖 로봇 [{self.name}] (ID: {self.model_id}) 가동 시작.")

    def collect_data(self):
        """데이터를 수집하는 행동(메서드)"""
        self.data_count += 1
        print(f"  [ACTION] {self.name}: 데이터 1건 수집 완료. (총 {self.data_count}건)")

    def report_status(self):
        """현재 상태를 보고하는 행동"""
        print(f"--- 로봇 상태 보고 ---")
        print(f"이름: {self.name} | 모델: {self.model_id} | 누적 데이터: {self.data_count}")
        print("---------------------")

