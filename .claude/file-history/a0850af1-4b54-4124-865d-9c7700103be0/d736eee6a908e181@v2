## 🎯 Evaluator 구조

```rust
pub struct Evaluator;

impl Evaluator {
    // AST 노드 평가 (엔트리 포인트)
    pub fn eval(&self, expr: &Expression, env: &mut Environment) -> Object {
        match expr {
            Expression::Literal(val) => Object::Integer(*val),
            Expression::FloatLiteral(f) => { /* 나중에 */ }
            Expression::Prefix { operator, operand } => {
                let operand_val = self.eval(operand, env);
                self.eval_prefix(operator, operand_val)
            }
            Expression::Infix { left, operator, right } => {
                let left_val = self.eval(left, env);
                let right_val = self.eval(right, env);
                self.eval_infix(left_val, operator, right_val)
            }
            _ => Object::Null,
        }
    }

    // 전위 연산자 평가
    fn eval_prefix(&self, op: &PrefixOp, operand: Object) -> Object {
        match op {
            PrefixOp::Minus => {
                match operand {
                    Object::Integer(val) => Object::Integer(-val),
                    _ => Object::Error(format!("unknown operator: -{:?}", operand)),
                }
            }
            PrefixOp::Bang => {
                match operand {
                    Object::Boolean(b) => Object::Boolean(!b),
                    Object::Null => Object::Boolean(true),
                    _ => Object::Boolean(false),
                }
            }
        }
    }

    // 중위 연산자 평가
    fn eval_infix(&self, left: Object, op: &InfixOp, right: Object) -> Object {
        match (left, right) {
            (Object::Integer(l), Object::Integer(r)) => {
                self.eval_integer_infix(l, op, r)
            }
            (Object::Boolean(l), Object::Boolean(r)) => {
                self.eval_boolean_infix(l, op, r)
            }
            _ => Object::Error("type mismatch".to_string()),
        }
    }

    // 정수 연산
    fn eval_integer_infix(&self, left: i32, op: &InfixOp, right: i32) -> Object {
        match op {
            InfixOp::Plus => Object::Integer(left + right),
            InfixOp::Minus => Object::Integer(left - right),
            InfixOp::Multiply => Object::Integer(left * right),
            InfixOp::Divide => {
                if right == 0 {
                    Object::Error("division by zero".to_string())
                } else {
                    Object::Integer(left / right)
                }
            }
            InfixOp::Equal => Object::Boolean(left == right),
            InfixOp::NotEqual => Object::Boolean(left != right),
            InfixOp::Less => Object::Boolean(left < right),
            InfixOp::LessEqual => Object::Boolean(left <= right),
            InfixOp::Greater => Object::Boolean(left > right),
            InfixOp::GreaterEqual => Object::Boolean(left >= right),
            _ => Object::Error(format!("unknown operator: {:?}", op)),
        }
    }

    // 불리언 연산
    fn eval_boolean_infix(&self, left: bool, op: &InfixOp, right: bool) -> Object {
        match op {
            InfixOp::Equal => Object::Boolean(left == right),
            InfixOp::NotEqual => Object::Boolean(left != right),
            _ => Object::Error(format!("unknown operator for booleans: {:?}", op)),
        }
    }
}
```

