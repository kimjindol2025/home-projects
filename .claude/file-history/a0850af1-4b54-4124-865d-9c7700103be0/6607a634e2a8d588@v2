// [예제 2] 구조체 제네릭
// ============================================================================
fn generic_structs() {
    println!("\n[예제 2] 구조체 제네릭");
    println!("═════════════════════════════════════════");

    #[derive(Debug)]
    struct Point<T> {
        x: T,
        y: T,
    }

    println!("\n[Point<i32>]");
    let integer_point = Point { x: 5, y: 10 };
    println!("Point {{ x: 5, y: 10 }} = {:?}", integer_point);

    println!("\n[Point<f64>]");
    let float_point = Point { x: 1.5, y: 4.5 };
    println!("Point {{ x: 1.5, y: 4.5 }} = {:?}", float_point);

    println!("\n[Point<&str>]");
    let string_point = Point { x: "hello", y: "world" };
    println!("Point {{ x: \"hello\", y: \"world\" }} = {:?}", string_point);

    println!("\n[구조체는 타입 추론]");
    let auto_point = Point { x: 100, y: 200 };
    println!("타입 명시 없이도 Point<i32> 자동 추론");

    println!("\n[여러 타입 파라미터]");
    struct Pair<T, U> {
        first: T,
        second: U,
    }

    let pair = Pair {
        first: 42,
        second: "answer",
    };
    println!("Pair<i32, &str> {{ first: 42, second: \"answer\" }} ✓");
}

