// [예제 4] 트레이트 바운드 - 조건 추가하기
// ============================================================================
fn trait_bounds_basics() {
    println!("\n[예제 4] 트레이트 바운드");
    println!("═════════════════════════════════════════");

    println!("\n[Display 바운드]");
    fn print_item<T: std::fmt::Display>(item: T) {
        println!("  [출력] {}", item);
    }

    print_item(42);
    print_item("hello");
    print_item(3.14);

    println!("\n[PartialOrd 바운드]");
    fn is_positive<T: PartialOrd + Default>(val: T) -> bool {
        val > T::default()
    }

    println!("is_positive(5) = {}", is_positive(5));
    println!("is_positive(-3) = {}", is_positive(-3));
    println!("is_positive(0.0) = {}", is_positive(0.0));

    println!("\n[Clone 바운드]");
    fn duplicate<T: Clone>(item: T) -> (T, T) {
        (item.clone(), item.clone())
    }

    let (a, b) = duplicate(42);
    println!("duplicate(42) = ({}, {})", a, b);

    let (s1, s2) = duplicate("hello");
    println!("duplicate(\"hello\") = (\"{}\", \"{}\")", s1, s2);

    println!("\n[여러 바운드]");
    fn clone_and_print<T: Clone + Debug>(item: T) {
        let cloned = item.clone();
        println!("원본: {:?}", item);
        println!("복제: {:?}", cloned);
    }

    clone_and_print(vec![1, 2, 3]);
}

// ============================================================================
// [예제 5] 여러 타입 파라미터
// ============================================================================
fn multiple_generic_types() {
    println!("\n[예제 5] 여러 타입 파라미터");
    println!("═════════════════════════════════════════");

    #[derive(Debug)]
    struct Pair<T, U> {
        first: T,
        second: U,
    }

    println!("\n[Pair<i32, &str>]");
    let pair1 = Pair {
        first: 5,
        second: "five",
    };
    println!("{:?}", pair1);

    println!("\n[Pair<String, f64>]");
    let pair2 = Pair {
        first: "pi".to_string(),
        second: 3.14,
    };
    println!("{:?}", pair2);

    println!("\n[제네릭 함수로 Pair 다루기]");
    fn get_first<T, U>(pair: &Pair<T, U>) -> &T {
        &pair.first
    }

    fn get_second<T, U>(pair: &Pair<T, U>) -> &U {
        &pair.second
    }

    println!("first: {}, second: {}", get_first(&pair1), get_second(&pair1));
    println!("first: {}, second: {}", get_first(&pair2), get_second(&pair2));

    println!("\n[특정 타입 조합에만 메서드]");
    impl<T: Clone, U: Clone> Pair<T, U> {
        fn clone_pair(&self) -> Pair<T, U> {
            Pair {
                first: self.first.clone(),
                second: self.second.clone(),
            }
        }
    }

    let cloned_pair = pair1.clone_pair();
    println!("복제된 Pair: {:?}", cloned_pair);
}

