// [예제 6] impl 블록의 제네릭
// ============================================================================
fn generic_impl_blocks() {
    println!("\n[예제 6] impl 블록의 제네릭");
    println!("═════════════════════════════════════════");

    struct Container<T> {
        items: Vec<T>,
    }

    println!("\n[모든 T에 대한 메서드]");
    impl<T> Container<T> {
        fn new() -> Self {
            Container {
                items: Vec::new(),
            }
        }

        fn add(&mut self, item: T) {
            self.items.push(item);
        }

        fn len(&self) -> usize {
            self.items.len()
        }
    }

    let mut container: Container<i32> = Container::new();
    container.add(1);
    container.add(2);
    container.add(3);
    println!("Container::len() = {}", container.len());

    println!("\n[Clone이 가능한 T에만 메서드]");
    impl<T: Clone> Container<T> {
        fn get_first(&self) -> Option<T> {
            self.items.first().cloned()
        }
    }

    let first = container.get_first();
    println!("Container::get_first() = {:?}", first);

    println!("\n[Display가 가능한 T에만 메서드]");
    impl<T: std::fmt::Display> Container<T> {
        fn print_all(&self) {
            for item in &self.items {
                println!("  - {}", item);
            }
        }
    }

    let mut str_container: Container<&str> = Container::new();
    str_container.add("hello");
    str_container.add("world");
    println!("Container<&str>::print_all():");
    str_container.print_all();

    println!("\n[i32에만 특별한 메서드]");
    impl Container<i32> {
        fn sum(&self) -> i32 {
            self.items.iter().sum()
        }
    }

    println!("Container<i32>::sum() = {}", container.sum());
}

