// [예제 1] 함수 제네릭 - 타입을 변수처럼 다루기
// ============================================================================
fn generic_functions() {
    println!("\n[예제 1] 함수 제네릭 - 타입 매개변수");
    println!("═════════════════════════════════════════");

    println!("\n[기본 함수 제네릭]");
    fn largest<T: PartialOrd>(list: &[T]) -> &T {
        let mut result = &list[0];
        for item in list {
            if item > result {
                result = item;
            }
        }
        result
    }

    let numbers = vec![34, 50, 25, 100, 65];
    println!("정수 목록: {:?}", numbers);
    println!("가장 큰 수: {}", largest(&numbers));

    let floats = vec![1.5, 3.2, 2.8, 5.1];
    println!("실수 목록: {:?}", floats);
    println!("가장 큰 수: {}", largest(&floats));

    let chars = vec!['y', 'm', 'a', 'q'];
    println!("문자 목록: {:?}", chars);
    println!("가장 큰 문자: {}", largest(&chars));

    println!("\n[제네릭의 힘]");
    println!("같은 함수로 모든 비교 가능한 타입을 처리 ✓");
    println!("코드 중복 없음 ✓");
    println!("타입 안전성 유지 ✓");
}

