// [예제 8] 실제 사용 패턴
// ============================================================================
fn real_world_generics() {
    println!("\n[예제 8] 실제 사용 패턴");
    println!("═════════════════════════════════════════");

    println!("\n[패턴 1: Stack (LIFO)]");
    struct Stack<T> {
        items: Vec<T>,
    }

    impl<T> Stack<T> {
        fn new() -> Self {
            Stack {
                items: Vec::new(),
            }
        }

        fn push(&mut self, item: T) {
            self.items.push(item);
        }

        fn pop(&mut self) -> Option<T> {
            self.items.pop()
        }

        fn peek(&self) -> Option<&T> {
            self.items.last()
        }
    }

    let mut stack: Stack<i32> = Stack::new();
    stack.push(1);
    stack.push(2);
    stack.push(3);
    println!("Stack: push(1), push(2), push(3)");
    println!("peek() = {:?}", stack.peek());
    println!("pop() = {:?}", stack.pop());
    println!("pop() = {:?}", stack.pop());

    println!("\n[패턴 2: find (제네릭 검색)]");
    fn find<T: PartialEq>(list: &[T], target: &T) -> Option<usize> {
        for (i, item) in list.iter().enumerate() {
            if item == target {
                return Some(i);
            }
        }
        None
    }

    let numbers = vec![10, 20, 30, 40, 50];
    println!("목록: {:?}", numbers);
    println!("find(&numbers, &30) = {:?}", find(&numbers, &30));
    println!("find(&numbers, &99) = {:?}", find(&numbers, &99));

    println!("\n[패턴 3: Cache (키-값 저장)");
    struct Cache<K, V> {
        data: HashMap<K, V>,
    }

    impl<K: std::hash::Hash + Eq, V> Cache<K, V> {
        fn new() -> Self {
            Cache {
                data: HashMap::new(),
            }
        }

        fn get(&self, key: &K) -> Option<&V> {
            self.data.get(key)
        }

        fn set(&mut self, key: K, value: V) {
            self.data.insert(key, value);
        }
    }

    let mut cache: Cache<String, i32> = Cache::new();
    cache.set("age".to_string(), 30);
    cache.set("score".to_string(), 100);

    println!("Cache::get(\"age\") = {:?}", cache.get(&"age".to_string()));
    println!("Cache::get(\"score\") = {:?}", cache.get(&"score".to_string()));

    println!("\n[패턴 4: 변환 함수]");
    fn transform<T: Clone + std::fmt::Display>(original: T) -> (T, T) {
        (original.clone(), original)
    }

    let (a, b) = transform("hello");
    println!("transform(\"hello\") = (\"{}\", \"{}\")", a, b);

    println!("\n[제네릭의 성능]");
    println!("✓ 런타임 오버헤드 없음 (컴파일 타임 단형화)");
    println!("✓ 각 타입별로 최적화된 코드 생성");
    println!("✓ 코드 크기는 약간 증가 (바이너리)");
}

