// [예제 3] 열거형 제네릭
// ============================================================================
fn generic_enums() {
    println!("\n[예제 3] 열거형 제네릭");
    println!("═════════════════════════════════════════");

    println!("\n[커스텀 제네릭 열거형]");
    #[derive(Debug)]
    enum Container<T> {
        Empty,
        Single(T),
        Multiple(Vec<T>),
    }

    println!("\n[Container<i32>]");
    let single: Container<i32> = Container::Single(42);
    println!("Single(42) = {:?}", single);

    let multiple: Container<i32> = Container::Multiple(vec![1, 2, 3]);
    println!("Multiple(vec![1, 2, 3]) = {:?}", multiple);

    println!("\n[Container<String>]");
    let text: Container<String> = Container::Single("Hello".to_string());
    println!("Single(\"Hello\") = {:?}", text);

    let texts: Container<String> = Container::Multiple(vec![
        "a".to_string(),
        "b".to_string(),
        "c".to_string(),
    ]);
    println!("Multiple([...]) = {:?}", texts);

    println!("\n[표준 라이브러리의 제네릭 열거형]");
    let opt: Option<i32> = Some(42);
    println!("Option<i32> = {:?}", opt);

    let result: Result<i32, String> = Ok(100);
    println!("Result<i32, String> = {:?}", result);
}

