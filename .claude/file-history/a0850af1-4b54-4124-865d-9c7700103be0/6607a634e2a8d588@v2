// [예제 7] 복합 트레이트 바운드
// ============================================================================
fn trait_bounds_complex() {
    println!("\n[예제 7] 복합 트레이트 바운드");
    println!("═════════════════════════════════════════");

    println!("\n[여러 트레이트 조합]");
    fn process<T: Clone + Debug + PartialOrd>(item: T) {
        let cloned = item.clone();
        println!("원본: {:?}", item);
        println!("복제: {:?}", cloned);

        if item > cloned {
            println!("원본이 더 큼");
        }
    }

    process(42);
    process(vec![1, 2, 3]);

    println!("\n[where 절로 복잡성 관리]");
    fn complex_function<T, U>(t: T, u: U)
    where
        T: Clone + Debug,
        U: Clone + std::fmt::Display,
    {
        let t_cloned = t.clone();
        let u_cloned = u.clone();
        println!("T: {:?}, U: {}", t_cloned, u_cloned);
    }

    complex_function(vec![1, 2], "hello");

    println!("\n[트레이트 객체]");
    fn use_displayable(items: Vec<&dyn std::fmt::Display>) {
        for item in items {
            println!("  {}", item);
        }
    }

    let int: i32 = 42;
    let str_val: &str = "hello";
    let float: f64 = 3.14;

    println!("서로 다른 타입을 같은 벡터에:");
    use_displayable(vec![&int, &str_val, &float]);
}

