"""
Python v1.2 - 제너레이터와 게으른 계산 (Generators and Lazy Evaluation)

탐구(대학): "모든 데이터를 메모리에 올릴 필요가 있는가?"
증명(대학원): "메모리 점유율의 극적 차이"

새로운 사고:
  1억 개의 숫자가 필요할 때, 1억 개의 방을 미리 만드는 것은 낭비입니다.
  대신, "다음 숫자가 뭐야?"라고 물을 때마다 하나씩 대답해주는
  '공장'을 만들 수 있습니다.

파이썬의 yield 키워드는 함수의 상태를 정지(Suspend)시켰다가
다시 시작하는 코루틴(Coroutine)의 기초가 됩니다.
"""

import sys
import time
from typing import Generator, Iterator


# ============================================================================
# [탐구 1] Eager vs Lazy - 메모리의 극적 차이
# ============================================================================

print("\n" + "="*70)
print("# [탐구 1] Eager Evaluation vs Lazy Evaluation")
print("="*70)

# 1. Eager Evaluation (기존 사고: 모든 데이터를 메모리에 할당)
print(f"\n[EAGER] 100만 개의 숫자를 모두 생성하여 리스트에 저장")
start_eager = time.time()
eager_list = [i for i in range(1000000)]
eager_time = time.time() - start_eager

print(f"  생성 시간: {eager_time:.4f}초")
print(f"  메모리: {sys.getsizeof(eager_list):,} bytes")
print(f"  요소 개수: {len(eager_list)}")

# 2. Lazy Evaluation (새로운 사고: 필요할 때만 생성하는 제너레이터)
print(f"\n[LAZY] 제너레이터 표현식으로 필요할 때만 생성")
start_lazy = time.time()
lazy_gen = (i for i in range(1000000))
lazy_time = time.time() - start_lazy

print(f"  생성 시간: {lazy_time:.6f}초")
print(f"  메모리: {sys.getsizeof(lazy_gen)} bytes")
print(f"  설명: 제너레이터 객체 자체의 크기만 계산됨")

# 메모리 비교
print(f"\n[증명]")
memory_diff = sys.getsizeof(eager_list) - sys.getsizeof(lazy_gen)
memory_ratio = sys.getsizeof(eager_list) / sys.getsizeof(lazy_gen)
print(f"  메모리 차이: {memory_diff:,} bytes")
print(f"  메모리 배율: {memory_ratio:.0f}배")
print(f"  시간 차이: {eager_time - lazy_time:.4f}초")
print(f"  결론: Lazy는 즉시 생성, Eager는 모든 데이터 준비 필요")


# ============================================================================
# [탐구 2] yield의 마법: 함수의 상태 정지와 재개
# ============================================================================

print("\n" + "="*70)
print("# [탐구 2] yield - 함수의 상태 정지와 재개")
print("="*70)

print(f"\n[개념] 함수가 중간에 멈추고 나중에 다시 시작할 수 있습니다.")

def simple_generator():
    """
    yield를 사용한 간단한 제너레이터

    함수를 실행할 때마다 yield에서 멈추고,
    다음 호출 시 멈춘 지점 다음부터 실행을 재개합니다.
    """
    print("  [Step 1] 함수 시작")
    yield 1

    print("  [Step 2] 첫 번째 yield 후 재개")
    yield 2

    print("  [Step 3] 두 번째 yield 후 재개")
    yield 3

    print("  [Step 4] 함수 종료")


print(f"\n[실행] 제너레이터 생성 및 값 추출")
gen = simple_generator()

print(f"\nfirst = next(gen)")
first = next(gen)
print(f"  반환값: {first}")

print(f"\nsecond = next(gen)")
second = next(gen)
print(f"  반환값: {second}")

print(f"\nthird = next(gen)")
third = next(gen)
print(f"  반환값: {third}")

print(f"\nfourth = next(gen)  # 더 이상 yield가 없음")
try:
    fourth = next(gen)
except StopIteration:
    print(f"  [StopIteration 발생] 제너레이터 종료")


# ============================================================================
# [탐구 3] 제너레이터 함수의 상태 보존
# ============================================================================

print("\n" + "="*70)
print("# [탐구 3] 제너레이터의 상태 보존")
print("="*70)

def counter_generator(start: int, end: int) -> Generator[int, None, None]:
    """
    시작부터 끝까지의 숫자를 하나씩 생성합니다.
    각 호출 사이에 상태(현재 값)를 보존합니다.
    """
    current = start
    while current < end:
        yield current
        current += 1


print(f"\n[예제] counter_generator(5, 10)")
gen = counter_generator(5, 10)

print(f"  값 1: {next(gen)}")
print(f"  값 2: {next(gen)}")
print(f"  값 3: {next(gen)}")

# for 루프는 자동으로 next()를 호출
print(f"\n[for 루프] 남은 값들 출력")
for value in gen:
    print(f"  값: {value}")


# ============================================================================
# [증명] 범위별 메모리 측정
# ============================================================================

print("\n" + "="*70)
print("# [증명] 다양한 범위에서의 메모리 비교")
print("="*70)

ranges = [1000, 10000, 100000, 1000000, 10000000]

print(f"\n{'범위':>10} | {'List 메모리':>15} | {'Gen 메모리':>12} | {'배율':>8}")
print("-" * 60)

for r in ranges:
    lst = [i for i in range(r)]
    gen = (i for i in range(r))

    lst_size = sys.getsizeof(lst)
    gen_size = sys.getsizeof(gen)
    ratio = lst_size / gen_size

    print(f"{r:>10,} | {lst_size:>15,} | {gen_size:>12} | {ratio:>8.0f}배")


# ============================================================================
# [탐구 4] 리스트 컴프리헨션 vs 제너레이터 표현식
# ============================================================================

print("\n" + "="*70)
print("# [탐구 4] 리스트 컴프리헨션 vs 제너레이터 표현식")
print("="*70)

print(f"\n[문법 비교]")
print(f"  리스트 컴프리헨션:  [x*2 for x in range(1000000)]  # []")
print(f"  제너레이터 표현식:  (x*2 for x in range(1000000))  # ()")

print(f"\n[실행 및 측정]")

# 리스트 컴프리헨션 (Eager)
list_comp = [x*2 for x in range(1000000)]
list_comp_size = sys.getsizeof(list_comp)

# 제너레이터 표현식 (Lazy)
gen_expr = (x*2 for x in range(1000000))
gen_expr_size = sys.getsizeof(gen_expr)

print(f"  리스트 컴프리헨션:  {list_comp_size:,} bytes")
print(f"  제너레이터 표현식:  {gen_expr_size:,} bytes")
print(f"  메모리 절감:        {list_comp_size - gen_expr_size:,} bytes")
print(f"  절감률:             {(1 - gen_expr_size/list_comp_size)*100:.1f}%")

print(f"\n[접근 방식 차이]")
print(f"  리스트 - 모든 값이 이미 메모리에 있음")
print(f"    처음부터 끝까지 시간 O(n), 메모리 O(n)")
print(f"  제너레이터 - 값을 필요할 때만 계산")
print(f"    특정 값까지 시간 O(k), 메모리 O(1)")


# ============================================================================
# [탐구 5] 제너레이터 함수 vs 제너레이터 표현식
# ============================================================================

print("\n" + "="*70)
print("# [탐구 5] 제너레이터 함수 vs 제너레이터 표현식")
print("="*70)

# 제너레이터 함수
def gen_func():
    for i in range(5):
        yield i * 2

# 제너레이터 표현식
gen_expr = (i * 2 for i in range(5))

print(f"\n[제너레이터 함수]")
print(f"  gen_func = def gen_func(): ...")
print(f"  호출: gen_func()")
print(f"  값: {list(gen_func())}")

print(f"\n[제너레이터 표현식]")
print(f"  gen_expr = (i * 2 for i in range(5))")
print(f"  값: {list(gen_expr)}")

print(f"\n[차이]")
print(f"  함수: 복잡한 로직, 상태 관리 가능")
print(f"  표현식: 간단한 변환, 한 줄 표현")


# ============================================================================
# [증명] yield의 컨텍스트: 함수는 제너레이터가 된다
# ============================================================================

print("\n" + "="*70)
print("# [증명] yield가 있으면 함수는 제너레이터 팩토리")
print("="*70)

def counting_gen(n: int):
    """
    yield가 포함된 함수는 호출되어도 실행되지 않습니다.
    대신 제너레이터 객체를 반환합니다.
    """
    for i in range(n):
        print(f"    [실행] i={i}")
        yield i


print(f"\n[함수 호출]")
print(f"  gen = counting_gen(3)")
gen = counting_gen(3)
print(f"  타입: {type(gen)}")
print(f"  메모리: {sys.getsizeof(gen)} bytes")

print(f"\n[첫 번째 next() - 함수 실행 시작]")
print(f"  next(gen)")
val1 = next(gen)
print(f"  반환: {val1}")

print(f"\n[두 번째 next() - 함수 재개]")
print(f"  next(gen)")
val2 = next(gen)
print(f"  반환: {val2}")

print(f"\n[for 루프 - 남은 값]")
print(f"  for val in gen: print(val)")
for val in gen:
    print(f"    {val}")


