// ============================================================================
// [1] 단순 if let 패턴 (Simple if let)
// ============================================================================
//
// 한 가지 패턴에만 관심이 있을 때, 나머지 _ => () 코드를 제거
//
fn simple_if_let() {
    println!("[1] 단순 if let 패턴");
    println!("────────────────────────────────────────────────────────────");

    // if let 1: 기본 사용
    {
        println!("✓ if let 기본");
        let x = Some(5);
        if let Some(n) = x {
            println!("  값: {}", n);
        }
    }

    // if let 2: else 분기
    {
        println!("✓ if let else");
        let device_status = Some("ACTIVE");
        if let Some(status) = device_status {
            println!("  상태: {}", status);
        } else {
            println!("  장치 없음");
        }
    }

    // if let 3: 선택적 신호 처리
    {
        println!("✓ 시스템 신호 처리");
        let system_signal = Some("EMERGENCY_STOP");

        // v3.4 방식 (모든 경우 명시)
        // match system_signal {
        //     Some(msg) => println!("v3.4: {}", msg),
        //     None => (),  // 번거로움
        // }

        // v3.5 방식 (핵심만 처리)
        if let Some(msg) = system_signal {
            println!("  v3.5 Optimized: 신호 감지 -> {}", msg);
        }
    }

    println!();
}

// ============================================================================
// [2] if let vs match 비교 (Comparison)
// ============================================================================
//
// 어느 것을 사용할지 명확한 기준
//
fn if_let_vs_match() {
    println!("[2] if let vs match 비교");
    println!("────────────────────────────────────────────────────────────");

    // 비교 1: 모든 경로가 필요한 경우
    {
        println!("✓ match: 모든 경로를 명시");
        let result = Some(42);
        match result {
            Some(n) => println!("  값: {}", n),
            None => println!("  없음"),
        }
    }

    // 비교 2: 한 경로만 관심인 경우
    {
        println!("✓ if let: 핵심만 처리");
        let result = Some(42);
        if let Some(n) = result {
            println!("  값: {}", n);
        }
    }

    // 비교 3: 여러 패턴 비교
    {
        println!("✓ match: 여러 패턴 처리");
        let code = 404;
        match code {
            200 => println!("  성공"),
            404 => println!("  찾을 수 없음"),
            500 => println!("  서버 오류"),
            _ => println!("  기타"),
        }
    }

    // 비교 4: 구조적 분해와 결합
    {
        println!("✓ if let: 복잡한 구조 분해");
        let person = Some(("Alice", 30));
        if let Some((name, age)) = person {
            println!("  {}님, {} 세", name, age);
        }
    }

    println!();
}

// ============================================================================
// [3] while let 패턴 (while let)
// ============================================================================
//
// 조건이 맞는 동안만 데이터를 추출하고 반복
//
fn while_let_patterns() {
    println!("[3] while let 패턴");
    println!("────────────────────────────────────────────────────────────");

    // while let 1: 벡터 큐 처리
    {
        println!("✓ 작업 큐 처리");
        let mut task_queue = vec!["냉각수 주입", "압력 조절", "시스템 체크"];
        println!("  자동화 엔진 가동:");

        while let Some(task) = task_queue.pop() {
            println!("    [실행] {} ... 완료", task);
        }
    }

    // while let 2: 카운터 감소
    {
        println!("✓ 카운터 감소");
        let mut count = 3;
        while count > 0 {
            println!("  카운트다운: {}", count);
            count -= 1;
        }
    }

    // while let 3: 반복 생성기
    {
        println!("✓ 반복 생성기");
        let mut items = vec![10, 20, 30].into_iter();
        while let Some(item) = items.next() {
            println!("  처리: {}", item);
        }
    }

    // while let 4: 데이터 수집
    {
        println!("✓ 데이터 수집");
        let mut data = vec![
            Some("signal_1"),
            Some("signal_2"),
            None,
            Some("signal_3"),
        ];

        let mut signals = Vec::new();
        while let Some(Some(signal)) = data.pop() {
            signals.push(signal);
        }
        println!("  수집된 신호: {:?}", signals);
    }

    println!();
}

// ============================================================================
// [4] 불변성 바인딩 (Immutability Binding)
// ============================================================================
//
// 조건부 바인딩에서 불변성 유지
//
fn immutability_binding() {
    println!("[4] 불변성 바인딩");
    println!("────────────────────────────────────────────────────────────");

    // 불변성 1: 기본적으로 불변
    {
        println!("✓ if let에서 기본 불변");
        if let Some(value) = Some(10) {
            println!("  값: {}", value);
            // value = 20;  // ❌ 불가능
        }
    }

    // 불변성 2: 필요할 때만 mut
    {
        println!("✓ mut를 명시해서 가변");
        let data = Some(vec![1, 2, 3]);
        if let Some(mut vec) = data {
            vec.push(4);
            println!("  수정된 벡터: {:?}", vec);
        }
    }

    // 불변성 3: Scope 벗어남
    {
        println!("✓ scope 벗어남으로 안전성 보장");
        let account = Some(1000.0);

        if let Some(mut balance) = account {
            balance -= 100.0;
            println!("  임시 잔액: {}", balance);
        }
        // balance는 scope 밖에서 접근 불가
        println!("  원본 잔액 유지됨");
    }

    // 불변성 4: 튜플 분해에서
    {
        println!("✓ 튜플 분해에서 불변성");
        if let Some((a, mut b)) = Some((5, 10)) {
            // a는 불변, b는 가변
            println!("  a: {}, b: {}", a, b);
            b += 10;
            println!("  수정 후: a: {}, b: {}", a, b);
        }
    }

    println!();
}

// ============================================================================
// [5] 선택적 처리 (Optional Handling)
// ============================================================================
//
// Option<T>와 if let의 완벽한 조합
//
fn optional_handling() {
    println!("[5] 선택적 처리");
    println!("────────────────────────────────────────────────────────────");

    // 선택적 1: 사용자 정보 조회
    {
        println!("✓ 사용자 정보 처리");
        fn get_user_name(id: u32) -> Option<String> {
            if id == 1 {
                Some("Alice".to_string())
            } else {
                None
            }
        }

        if let Some(name) = get_user_name(1) {
            println!("  사용자: {}", name);
        } else {
            println!("  사용자 없음");
        }
    }

    // 선택적 2: 다중 선택적 값
    {
        println!("✓ 다중 선택적 값 처리");
        let first_name = Some("Alice");
        let last_name = Some("Smith");

        if let (Some(f), Some(l)) = (first_name, last_name) {
            println!("  이름: {} {}", f, l);
        }
    }

    // 선택적 3: 중첩된 선택적 값
    {
        println!("✓ 중첩 선택적 값");
        let user = Some(("Bob", Some(25)));
        if let Some((name, Some(age))) = user {
            println!("  {}님, {} 세", name, age);
        }
    }

    // 선택적 4: 체인 처리
    {
        println!("✓ 체인 처리");
        let config = Some(true);
        if let Some(true) = config {
            println!("  설정 활성화");
        }
    }

    println!();
}

// ============================================================================
// [6] 오류 처리 (Result Handling)
// ============================================================================
//
// Result<T, E>와 if let의 조합
//
fn result_handling() {
    println!("[6] 오류 처리");
    println!("────────────────────────────────────────────────────────────");

    // 결과 1: 성공 처리
    {
        println!("✓ 성공 케이스 처리");
        fn parse_number(s: &str) -> Result<i32, String> {
            Ok(42)
        }

        if let Ok(n) = parse_number("42") {
            println!("  파싱 성공: {}", n);
        }
    }

    // 결과 2: 오류 처리
    {
        println!("✓ 오류 케이스 처리");
        fn validate_age(age: i32) -> Result<(), String> {
            if age < 0 {
                Err("나이는 음수일 수 없습니다".to_string())
            } else {
                Ok(())
            }
        }

        if let Err(e) = validate_age(-5) {
            println!("  검증 실패: {}", e);
        }
    }

    // 결과 3: 성공과 실패 모두
    {
        println!("✓ 성공/실패 구분");
        fn divide(a: i32, b: i32) -> Result<i32, String> {
            if b == 0 {
                Err("0으로 나눌 수 없습니다".to_string())
            } else {
                Ok(a / b)
            }
        }

        if let Ok(result) = divide(10, 2) {
            println!("  나눗셈 결과: {}", result);
        } else if let Err(e) = divide(10, 0) {
            println!("  나눗셈 오류: {}", e);
        }
    }

    // 결과 4: while let으로 오류 복구
    {
        println!("✓ 결과 시퀀스 처리");
        let operations = vec![Ok(10), Ok(20), Err("error".to_string()), Ok(30)];

        let mut successes = Vec::new();
        for op in operations {
            if let Ok(value) = op {
                successes.push(value);
            }
        }
        println!("  성공한 작업: {:?}", successes);
    }

    println!();
}

// ============================================================================
// [7] 복잡한 정제 (Complex Refinement)
// ============================================================================
//
// 여러 도구의 결합으로 우아한 코드 구성
//
fn complex_refinement() {
    println!("[7] 복잡한 정제");
    println!("────────────────────────────────────────────────────────────");

    // 복잡 1: 구조체 분해
    {
        println!("✓ 구조체 필드 추출");
        struct SystemStatus {
            core_id: u32,
            state: Option<String>,
        }

        let system = Some(SystemStatus {
            core_id: 5,
            state: Some("RUNNING".to_string()),
        });

        if let Some(SystemStatus { core_id, state }) = system {
            if let Some(s) = state {
                println!("  Core {} 상태: {}", core_id, s);
            }
        }
    }

    // 복잡 2: 설정 로드
    {
        println!("✓ 설정 로드 및 처리");
        fn load_config() -> Option<(String, u16)> {
            Some(("localhost".to_string(), 8080))
        }

        if let Some((host, port)) = load_config() {
            println!("  서버: {}:{}", host, port);
        }
    }

    // 복잡 3: 데이터 파이프라인
    {
        println!("✓ 데이터 파이프라인");
        let mut pipeline = vec![
            Some(10),
            Some(20),
            None,
            Some(30),
        ];

        let mut total = 0;
        while let Some(value_opt) = pipeline.pop() {
            if let Some(value) = value_opt {
                total += value;
            }
        }
        println!("  합계: {}", total);
    }

    // 복잡 4: 상태 머신 정제
    {
        println!("✓ 상태 머신 정제");
        enum State {
            Ready(String),
            Processing,
            Done(Option<String>),
        }

        let states = vec![
            State::Ready("task1".to_string()),
            State::Processing,
            State::Done(Some("완료".to_string())),
        ];

        for state in states {
            if let State::Ready(task) = state {
                println!("  준비됨: {}", task);
            } else if let State::Done(Some(msg)) = state {
                println!("  완료: {}", msg);
            }
        }
    }

    println!();
}

