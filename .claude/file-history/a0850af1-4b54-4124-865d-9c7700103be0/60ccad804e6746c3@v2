/// 잠금을 짧게 유지하는 효율적인 패턴
fn demo_lock_scope_minimization() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║    [Demo 3] 잠금 범위 최소화: 성능 최적화                 ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    let counter = Arc::new(Mutex::new(0u32));
    let mut handles = vec![];

    println!("[1] 나쁜 패턴: 잠금을 너무 오래 유지");
    println!("    (잠금 중에 오래 걸리는 작업 수행)\n");

    for i in 0..3 {
        let counter = Arc::clone(&counter);
        let handle = thread::spawn(move || {
            // 명시적 스코프로 잠금 범위 제한
            {
                let mut num = counter.lock().unwrap();
                println!("    [스레드 {}] lock 획득, counter = {}", i, *num);
                *num += 1;
                println!("    [스레드 {}] counter 업데이트: {}", i, *num);
            } // 여기서 lock 자동 해제!

            println!("    [스레드 {}] lock 해제 후 무거운 작업 시작", i);
            thread::sleep(Duration::from_millis(200));
            println!("    [스레드 {}] 무거운 작업 완료", i);
        });
        handles.push(handle);
    }

    for handle in handles {
        handle.join().unwrap();
    }

    println!("\n[2] 효과:");
    println!("    각 스레드의 잠금 시간: ~1ms");
    println!("    각 스레드의 무거운 작업: 200ms (lock 없이)");
    println!("    결과: 다른 스레드들이 대기하지 않음!\n");
    println!("    최종 카운터: {}", *counter.lock().unwrap());
    println!("    ✅ 잠금 범위 최소화로 병렬성 극대화!\n");
}

