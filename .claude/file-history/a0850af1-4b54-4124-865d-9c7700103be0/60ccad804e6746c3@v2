// [v10.2: 패턴 6] 여러 Mutex와 안전한 제어
// ============================================================================

/// 구조체로 관련 Mutex를 함께 관리
#[derive(Debug)]
struct SecuritySystem {
    threat_counter: Mutex<u32>,
    response_time: Mutex<f64>,
}

impl SecuritySystem {
    fn new() -> Self {
        Self {
            threat_counter: Mutex::new(0),
            response_time: Mutex::new(0.0),
        }
    }

    fn report_threat(&self, response_ms: f64) {
        // 항상 같은 순서: threat_counter → response_time
        let mut counter = self.threat_counter.lock().unwrap();
        let mut time = self.response_time.lock().unwrap();

        *counter += 1;
        *time += response_ms;
    }

    fn get_stats(&self) -> (u32, f64) {
        let counter = self.threat_counter.lock().unwrap();
        let time = self.response_time.lock().unwrap();
        (*counter, *time)
    }
}

fn demo_advanced_multiple_mutex() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║  [Demo 6] 고급: 여러 Mutex의 안전한 제어                 ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    println!("[1] 구조체로 Mutex 그룹화:");
    let system = Arc::new(SecuritySystem::new());
    let mut handles = vec![];

    println!("[2] 여러 팀의 위협 보고:\n");

    for team_id in 0..5 {
        let system = Arc::clone(&system);
        let handle = thread::spawn(move || {
            let response_time = (team_id as f64 * 10.0) + 15.0;
            println!(
                "    [팀 {}] 위협 감지! (응답: {}ms)",
                team_id, response_time
            );
            system.report_threat(response_time);
            println!("    [팀 {}] 데이터 기록 완료", team_id);
            thread::sleep(Duration::from_millis(50));
        });
        handles.push(handle);
    }

    for handle in handles {
        handle.join().unwrap();
    }

    println!("\n[3] 최종 통계:");
    let (total_threats, total_time) = system.get_stats();
    println!("    총 위협 건수: {}", total_threats);
    println!("    누적 응답 시간: {:.1}ms", total_time);
    println!(
        "    평균 응답 시간: {:.1}ms",
        total_time / total_threats as f64
    );
    println!("    ✅ 여러 Mutex를 안전하게 관리!\n");
}

