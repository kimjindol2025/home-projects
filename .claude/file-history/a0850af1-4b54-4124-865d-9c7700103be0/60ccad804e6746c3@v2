/// 여러 Mutex를 안전하게 다루는 순서 규정
fn demo_deadlock_avoidance() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║   [Demo 5] 데드락 회피: 안전한 순서 규정                ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    println!("[1] 데드락의 원인: 순환 대기");
    println!("    스레드 A: mutex1 lock → mutex2 lock 대기");
    println!("    스레드 B: mutex2 lock → mutex1 lock 대기");
    println!("    결과: 무한 대기!\n");

    println!("[2] 데드락 회피: 항상 같은 순서로 잠금");

    let mutex1 = Arc::new(Mutex::new(0u32));
    let mutex2 = Arc::new(Mutex::new(0u32));
    let mut handles = vec![];

    for i in 0..2 {
        let m1 = Arc::clone(&mutex1);
        let m2 = Arc::clone(&mutex2);

        let handle = thread::spawn(move || {
            println!("    [스레드 {}] mutex1 lock 시도...", i);
            let mut num1 = m1.lock().unwrap();
            println!("    [스레드 {}] mutex1 lock 획득!", i);

            thread::sleep(Duration::from_millis(100));

            println!("    [스레드 {}] mutex2 lock 시도...", i);
            let mut num2 = m2.lock().unwrap();
            println!("    [스레드 {}] mutex2 lock 획득!", i);

            *num1 += 1;
            *num2 += 1;
            println!("    [스레드 {}] 작업 완료", i);
        });
        handles.push(handle);
    }

    for handle in handles {
        handle.join().unwrap();
    }

    println!("\n[3] 결과:");
    println!(
        "    mutex1: {}",
        *mutex1.lock().unwrap()
    );
    println!(
        "    mutex2: {}",
        *mutex2.lock().unwrap()
    );
    println!("    ✅ 모든 스레드가 완료됨 (데드락 없음!)\n");
}

