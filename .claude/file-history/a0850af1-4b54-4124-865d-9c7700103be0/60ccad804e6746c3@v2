/// 10개 스레드가 동시에 하나의 카운터를 증가시킴
fn demo_basic_shared_counter() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║   [Demo 1] 기본 공유 카운터: 10개 스레드의 동시 접근      ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    println!("[1] Arc<Mutex<T>> 생성:");
    let counter = Arc::new(Mutex::new(0u32));
    println!("    ✅ 공유되는 보호된 카운터 생성\n");

    println!("[2] 10개 스레드 생성 (각각 카운터 +1):");
    let mut handles = vec![];

    for i in 0..10 {
        let counter = Arc::clone(&counter);
        let handle = thread::spawn(move || {
            // 잠금 획득
            let mut num = counter.lock().unwrap();
            let prev = *num;
            *num += 1;
            let new = *num;

            println!(
                "    [스레드 {}] lock 획득 → {} + 1 = {} → lock 해제",
                i, prev, new
            );
            thread::sleep(Duration::from_millis(50));
        });
        handles.push(handle);
    }

    println!("\n[3] 모든 스레드 완료 대기:");
    for handle in handles {
        handle.join().unwrap();
    }

    println!("\n[4] 최종 결과:");
    let final_count = *counter.lock().unwrap();
    println!("    최종 카운터 값: {}", final_count);
    if final_count == 10 {
        println!("    ✅ 모든 스레드의 업데이트가 안전하게 누적됨!\n");
    }
}

