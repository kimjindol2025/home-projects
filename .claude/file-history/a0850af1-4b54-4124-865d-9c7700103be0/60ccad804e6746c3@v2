/// Arc와 Mutex 각각의 역할을 명확히 이해
fn demo_arc_and_mutex_separation() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║   [Demo 2] Arc와 Mutex: 역할 분리와 조합               ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    println!("[1] Arc의 역할: 스레드 간 소유권 공유");
    println!("    let data = Arc::new(value);");
    println!("    Arc::clone() → 모든 스레드가 동일한 메모리를 가리킴\n");

    println!("[2] Mutex의 역할: 한 번에 하나의 스레드만 접근");
    println!("    let data = Mutex::new(value);");
    println!("    lock() → 잠금 획득 → 데이터 수정 → 자동 해제\n");

    println!("[3] Arc<Mutex<T>>의 조합:");
    let data = Arc::new(Mutex::new("안전한 공유 상태".to_string()));

    let mut handles = vec![];

    for i in 0..3 {
        let data = Arc::clone(&data);
        let handle = thread::spawn(move || {
            let mut state = data.lock().unwrap();
            println!("    [스레드 {}] lock 획득!", i);
            println!(
                "    [스레드 {}] 현재 상태: {}",
                i, *state
            );
            *state = format!("[스레드 {}에 의해 수정됨]", i);
            println!("    [스레드 {}] 상태 변경 완료 → lock 해제", i);
            thread::sleep(Duration::from_millis(100));
        });
        handles.push(handle);
    }

    for handle in handles {
        handle.join().unwrap();
    }

    println!("\n    최종 상태: {}", *data.lock().unwrap());
    println!("    ✅ Arc로 공유, Mutex로 보호!\n");
}

