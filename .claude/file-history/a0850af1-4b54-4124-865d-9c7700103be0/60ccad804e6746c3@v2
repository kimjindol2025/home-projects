/// 논블로킹 잠금 시도로 타임아웃 구현
fn demo_try_lock_non_blocking() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║  [Demo 4] try_lock(): 논블로킹 잠금 시도                ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    let counter = Arc::new(Mutex::new(0u32));
    let mut handles = vec![];

    println!("[1] try_lock() vs lock():");
    println!("    lock()     : 잠금 획득할 때까지 무한 대기");
    println!("    try_lock() : 즉시 반환 (성공/실패)\n");

    for i in 0..2 {
        let counter = Arc::clone(&counter);
        let handle = thread::spawn(move || {
            let mut attempts = 0;

            loop {
                attempts += 1;
                match counter.try_lock() {
                    Ok(mut num) => {
                        println!(
                            "    [스레드 {}] lock 획득! ({}번째 시도)",
                            i, attempts
                        );
                        *num += 1;
                        println!("    [스레드 {}] counter = {}", i, *num);
                        break;
                    }
                    Err(_) => {
                        if attempts <= 3 {
                            println!(
                                "    [스레드 {}] lock 실패, 재시도 중... ({}번째)",
                                i, attempts
                            );
                            thread::sleep(Duration::from_millis(50));
                        }
                    }
                }

                if attempts > 5 {
                    println!("    [스레드 {}] 5회 이상 실패, 포기!", i);
                    break;
                }
            }
        });
        handles.push(handle);
    }

    for handle in handles {
        handle.join().unwrap();
    }

    println!("\n[2] try_lock() 장점:");
    println!("    ✅ 무한 대기 방지");
    println!("    ✅ 타임아웃 구현 가능");
    println!("    ✅ 중단 가능한 작업에 적합\n");
}

