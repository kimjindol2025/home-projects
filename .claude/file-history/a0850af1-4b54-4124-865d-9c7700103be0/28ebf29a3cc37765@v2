#[test]
fn test_pinning_overhead_acceptable() {
    let start = Instant::now();
    for _ in 0..100000 {
        let buffer = vec![1, 2, 3];
        // 기본 연산
        let _ = buffer.iter().sum::<i32>();
    }
    let baseline = start.elapsed();

    let start_ffi = Instant::now();
    for _ in 0..100000 {
        // FFI 호출 (Pinning 포함)
        unsafe {
            external_noop_ffi();
        }
    }
    let with_ffi = start_ffi.elapsed();

    let overhead = (with_ffi.as_nanos() as f64 / baseline.as_nanos() as f64 - 1.0) * 100.0;
    assert!(overhead < 15.0, "Pinning 오버헤드 < 15%, 실제: {:.2}%", overhead);

    println!("✅ Test 5: Pinning 오버헤드 {:.2}% (허용범위)", overhead);
}
