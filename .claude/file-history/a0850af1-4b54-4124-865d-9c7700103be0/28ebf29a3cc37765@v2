## 해결책: 다층 방어 (Multi-Layer Defense)

### Tier 1: 컴파일러 FFI Pinning 분석 (v18.1 IR)

```rust
/// [v18.1] IR 최적화 패스: FFI 호출 전 Pinning 삽입
pub struct FFIPinningPass {
    ffi_functions: HashSet<String>,
    pinned_objects: HashSet<ObjectId>,
}

impl FFIPinningPass {
    pub fn transform(&mut self, ir: &mut Vec<IRInstruction>) -> Vec<IRInstruction> {
        let mut result = Vec::new();

        for (idx, instr) in ir.iter().enumerate() {
            match instr {
                IRInstruction::Call(func_name, args) if self.is_ffi_function(func_name) => {
                    // FFI 호출 감지
                    // 1. Pinning 명령 삽입 (호출 전)
                    for arg in args {
                        if self.is_reference(arg) {
                            result.push(IRInstruction::Pin(arg.id()));
                            self.pinned_objects.insert(arg.id());
                        }
                    }

                    // 2. FFI 호출 자체
                    result.push(instr.clone());

                    // 3. Unpinning 명령 삽입 (호출 후)
                    for arg in args {
                        if self.is_reference(arg) {
                            result.push(IRInstruction::Unpin(arg.id()));
                            self.pinned_objects.remove(&arg.id());
                        }
                    }
                }
                _ => result.push(instr.clone()),
            }
        }

        result
    }

    fn is_ffi_function(&self, name: &str) -> bool {
        self.ffi_functions.contains(name)
    }

    fn is_reference(&self, value: &IRValue) -> bool {
        matches!(value, IRValue::Reference(_) | IRValue::Array(_) | IRValue::String(_))
    }
}
```

### Tier 2: 런타임 Safe Handle 추적 (v15.0 GC)

```rust
/// [v15.0] 안전한 핸들 기반 메모리 추적
#[repr(C)]
pub struct SafeHandle {
    id: u64,              // 객체의 불변 ID
    version: u32,         // GC Generation (메모리 이동 감지)
}

pub struct HandleTable {
    handles: HashMap<u64, HandleEntry>,
    generation: u32,
}

pub struct HandleEntry {
    object_id: u64,
    current_ptr: *mut u8,  // GC 이동 후에도 항상 최신
    generation: u32,
    pinned: bool,
    access_count: u64,     // 통계
}

impl HandleTable {
    /// C 코드에 안전한 핸들 생성
    pub fn create_safe_handle(&mut self, object: &Value) -> SafeHandle {
        let handle = SafeHandle {
            id: object.id(),
            version: self.generation,
        };

        self.handles.insert(handle.id, HandleEntry {
            object_id: object.id(),
            current_ptr: object.as_ptr() as *mut u8,
            generation: self.generation,
            pinned: false,
            access_count: 0,
        });

        handle
    }

    /// GC가 메모리 이동 시 호출
    pub fn on_gc_moved(&mut self, old_ptr: *mut u8, new_ptr: *mut u8) {
        for (_, entry) in self.handles.iter_mut() {
            if entry.current_ptr == old_ptr {
                // 포인터 업데이트 + 버전 증가
                entry.current_ptr = new_ptr;
                entry.generation = self.generation;
            }
        }
        self.generation += 1;
    }

    /// C 코드가 핸들을 통해 데이터 접근
    pub fn dereference_safe(&mut self, handle: SafeHandle) -> Result<*mut u8, FFIError> {
        let entry = self.handles.get_mut(&handle.id)
            .ok_or(FFIError::InvalidHandle)?;

        // 버전 검증: Handle이 outdated되지 않았는지
        if entry.version != handle.version {
            return Err(FFIError::HandleOutdated);
        }

        // Pinning 검증: 이 핸들의 객체가 Pinned인지
        if !entry.pinned {
            return Err(FFIError::ObjectNotPinned);
        }

        entry.access_count += 1;
        Ok(entry.current_ptr)
    }

    pub fn pin_object(&mut self, id: u64) {
        if let Some(entry) = self.handles.get_mut(&id) {
            entry.pinned = true;
        }
    }

    pub fn unpin_object(&mut self, id: u64) {
        if let Some(entry) = self.handles.get_mut(&id) {
            entry.pinned = false;
        }
    }
}
```

### Tier 3: GC 통합 - Pinned 객체 보호

```rust
/// [v15.3] Mark-and-Sweep GC with Pinning Support
pub struct GarbageCollector {
    heap: HashMap<u64, HeapObject>,
    marked: HashSet<u64>,
    pinned: HashSet<u64>,        // ← Pinned 객체들
    handle_table: Arc<Mutex<HandleTable>>,
}

impl GarbageCollector {
    pub fn mark_and_sweep(&mut self, roots: &[StackFrame]) {
        // Phase 1: Mark
        self.mark_phase(roots);

        // Phase 2: Sweep (Pinned 객체는 건너뜀)
        let mut to_remove = Vec::new();
        for (id, _obj) in &self.heap {
            if !self.marked.contains(id) && !self.pinned.contains(id) {
                // Pinned이 아니고 도달 불가능 → 제거
                to_remove.push(*id);
            } else if self.pinned.contains(id) && !self.marked.contains(id) {
                // [경고] Pinned이지만 도달 불가능 → 버그!
                eprintln!("⚠️  WARNING: Pinned object is unreachable (memory leak)");
            }
        }

        // Phase 3: Remove
        for id in to_remove {
            self.heap.remove(&id);
        }

        self.marked.clear();
    }

    pub fn mark_phase(&mut self, roots: &[StackFrame]) {
        for root in roots {
            self.mark_recursive(root);
        }
    }

    fn mark_recursive(&mut self, value: &Value) {
        let id = value.id();
        if !self.marked.insert(id) {
            return;  // 이미 마크됨
        }

        // 참조하는 다른 객체들도 마크
        for child in value.children() {
            self.mark_recursive(&child);
        }
    }
}
```

### Tier 4: Async 런타임 동기화

```rust
/// [v18.2] Async with FFI-Safe Execution
pub struct AsyncExecutor {
    gc: Arc<Mutex<GarbageCollector>>,
    handle_table: Arc<Mutex<HandleTable>>,
    ffi_in_progress: Arc<AtomicBool>,  // FFI 호출 중 플래그
}

impl AsyncExecutor {
    /// FFI 호출이 포함된 안전한 async 블록
    pub async fn execute_with_ffi<F>(&self, f: F) -> Result<()>
    where
        F: Fn(&mut HandleTable) -> Result<()>,
    {
        // Step 1: FFI 호출 시작 표시
        self.ffi_in_progress.store(true, Ordering::SeqCst);

        // Step 2: GC 잠금 (FFI 중 GC 방지)
        let mut gc = self.gc.lock().await;
        let mut handle_table = self.handle_table.lock().await;

        // Step 3: 안전한 FFI 호출
        let result = f(&mut handle_table);

        // Step 4: 잠금 해제 (GC 다시 시작 가능)
        drop(gc);
        drop(handle_table);
        self.ffi_in_progress.store(false, Ordering::SeqCst);

        result
    }

    /// Yield 포인트 - FFI 중이 아닐 때만 GC 실행
    pub async fn safe_yield(&self) {
        while self.ffi_in_progress.load(Ordering::SeqCst) {
            // FFI 완료 대기
            tokio::task::yield_now().await;
        }

        // 이제 GC 실행 가능
        tokio::task::yield_now().await;
    }
}
```

### Tier 5: 타입 시스템 강제

```rust
/// [Type System] FFI-Safe 마커 트레이트
pub trait FFISafe: Sized {
    /// FFI 경계를 넘을 때 반드시 Pin되어야 함
    const REQUIRES_PINNING: bool = true;

    fn as_ffi_safe_ptr(&self) -> *const u8;
}

impl FFISafe for Vec<i64> {
    const REQUIRES_PINNING: bool = true;
    fn as_ffi_safe_ptr(&self) -> *const u8 {
        self.as_ptr() as *const u8
    }
}

impl FFISafe for String {
    const REQUIRES_PINNING: bool = true;
    fn as_ffi_safe_ptr(&self) -> *const u8 {
        self.as_ptr() as *const u8
    }
}

// 컴파일러가 이 트레이트 요구
pub fn safe_ffi_call<T: FFISafe>(obj: &T) {
    // FFI 호출 전 자동 Pinning
    unsafe {
        external_c_function(obj.as_ffi_safe_ptr());
    }
    // 호출 후 자동 Unpinning
}
