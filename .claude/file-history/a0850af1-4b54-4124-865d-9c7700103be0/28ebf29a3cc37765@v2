#[test]
fn test_ffi_pinning_prevents_dangling_pointer() {
    let mut compiler = Compiler::new();
    let code = r#"
        async fn test() {
            let buffer = vec![1, 2, 3];
            external_ffi(&buffer);      // Pinning 자동 삽입
            await some_task();          // GC 발동 가능
            // buffer는 여전히 유효
        }
    "#;

    let ir = compiler.compile_to_ir(code);

    // 검증: Pin/Unpin 명령이 삽입되었는가?
    let pin_count = ir.instructions
        .iter()
        .filter(|i| matches!(i, IRInstruction::Pin(_)))
        .count();

    let unpin_count = ir.instructions
        .iter()
        .filter(|i| matches!(i, IRInstruction::Unpin(_)))
        .count();

    assert_eq!(pin_count, 1, "FFI 전 Pin 명령 삽입");
    assert_eq!(unpin_count, 1, "FFI 후 Unpin 명령 삽입");
    println!("✅ Test 1: Pinning 명령이 올바르게 삽입됨");
}
