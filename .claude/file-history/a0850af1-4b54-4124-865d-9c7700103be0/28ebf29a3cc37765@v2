### 테스트 4: Use-After-Free 방지

```rust
#[test]
fn test_prevents_use_after_free() {
    let mut handle_table = HandleTable::new();
    let obj = Value::Array(vec![1, 2, 3]);
    let handle = handle_table.create_safe_handle(&obj);

    // Pinned 상태: 접근 성공
    handle_table.pin_object(obj.id());
    assert!(handle_table.dereference_safe(handle).is_ok());

    // Unpinned 상태: 접근 실패
    handle_table.unpin_object(obj.id());
    let result = handle_table.dereference_safe(handle);
    assert!(result.is_err());
    assert_eq!(result.unwrap_err(), FFIError::ObjectNotPinned);

    println!("✅ Test 4: Unpinned 객체는 FFI 접근 불가");
}
```

