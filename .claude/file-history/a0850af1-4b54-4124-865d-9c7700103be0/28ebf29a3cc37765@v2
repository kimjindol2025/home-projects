### 테스트 2: Handle 메모리 추적

```rust
#[test]
fn test_safe_handle_survives_gc_compaction() {
    let mut handle_table = HandleTable::new();
    let obj = Value::Array(vec![10, 20, 30]);
    let original_ptr = obj.as_ptr();

    // Handle 생성
    let handle = handle_table.create_safe_handle(&obj);

    // GC 전 Dereference
    let deref_before = handle_table.dereference_safe(handle)
        .expect("GC 전 dereference 성공");
    assert_eq!(deref_before as *const _, original_ptr);

    // GC 시뮬레이션 (메모리 이동)
    let new_ptr = (original_ptr as u64 + 1000) as *mut u8;
    handle_table.on_gc_moved(original_ptr as *mut u8, new_ptr);

    // Handle 업데이트 확인
    let deref_after = handle_table.dereference_safe(handle)
        .expect("GC 후 dereference 성공");
    assert_eq!(deref_after, new_ptr, "Handle이 새 주소로 업데이트됨");
    println!("✅ Test 2: Handle이 GC Compaction을 추적");
}
```

