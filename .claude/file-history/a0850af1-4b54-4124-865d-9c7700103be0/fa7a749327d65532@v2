### 패턴 3️⃣: 데이터 공유 뱅크 (Data Bank)

```rust
#[derive(Clone)]
struct DataBank {
    inventory: Rc<Vec<String>>,
}

impl DataBank {
    fn new(items: Vec<String>) -> Self {
        Self {
            inventory: Rc::new(items),
        }
    }

    fn checkout(&self) -> Rc<Vec<String>> {
        Rc::clone(&self.inventory)
    }
}

// 여러 모듈이 같은 inventory를 참고
let bank = DataBank::new(vec!["A", "B", "C"]);
let inventory1 = bank.checkout();  // 카운트: 2
let inventory2 = bank.checkout();  // 카운트: 3

// 모두 같은 데이터를 가리킴
```

