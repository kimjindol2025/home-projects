"""
어휘 분석기 테스트
"""

import pytest
from freelang.lexer import Lexer, TokenType
from freelang.errors import LexerError


class TestLexer:
    """Lexer 클래스 테스트"""

    def test_empty_source(self):
        """빈 소스 코드"""
        lexer = Lexer("")
        tokens = lexer.tokenize()
        assert len(tokens) == 1
        assert tokens[0].type == TokenType.EOF

    def test_simple_integer(self):
        """간단한 정수"""
        lexer = Lexer("42")
        tokens = lexer.tokenize()
        assert len(tokens) == 2
        assert tokens[0].type == TokenType.INTEGER
        assert tokens[0].value == 42

    def test_simple_float(self):
        """간단한 실수"""
        lexer = Lexer("3.14")
        tokens = lexer.tokenize()
        assert tokens[0].type == TokenType.FLOAT
        assert tokens[0].value == 3.14

    def test_string_literal(self):
        """문자열 리터럴"""
        lexer = Lexer('"Hello, World!"')
        tokens = lexer.tokenize()
        assert tokens[0].type == TokenType.STRING
        assert tokens[0].value == "Hello, World!"

    def test_keywords(self):
        """키워드 인식"""
        lexer = Lexer("let fn if else for in loop")
        tokens = lexer.tokenize()
        assert tokens[0].type == TokenType.LET
        assert tokens[1].type == TokenType.FN
        assert tokens[2].type == TokenType.IF
        assert tokens[3].type == TokenType.ELSE
        assert tokens[4].type == TokenType.FOR
        assert tokens[5].type == TokenType.IN
        assert tokens[6].type == TokenType.LOOP

    def test_identifier(self):
        """식별자"""
        lexer = Lexer("x my_var variable123")
        tokens = lexer.tokenize()
        assert tokens[0].type == TokenType.IDENTIFIER
        assert tokens[0].value == "x"
        assert tokens[1].type == TokenType.IDENTIFIER
        assert tokens[1].value == "my_var"
        assert tokens[2].type == TokenType.IDENTIFIER
        assert tokens[2].value == "variable123"

    def test_operators(self):
        """연산자"""
        lexer = Lexer("+ - * / % == != < <= > >= && || !")
        tokens = lexer.tokenize()
        assert tokens[0].type == TokenType.PLUS
        assert tokens[1].type == TokenType.MINUS
        assert tokens[2].type == TokenType.STAR
        assert tokens[3].type == TokenType.SLASH
        assert tokens[4].type == TokenType.PERCENT
        assert tokens[5].type == TokenType.EQEQ
        assert tokens[6].type == TokenType.NE
        assert tokens[7].type == TokenType.LT
        assert tokens[8].type == TokenType.LE
        assert tokens[9].type == TokenType.GT
        assert tokens[10].type == TokenType.GE
        assert tokens[11].type == TokenType.AND
        assert tokens[12].type == TokenType.OR
        assert tokens[13].type == TokenType.NOT

    def test_arrow_operator(self):
        """화살표 연산자"""
        lexer = Lexer("-> =>")
        tokens = lexer.tokenize()
        assert tokens[0].type == TokenType.ARROW
        assert tokens[1].type == TokenType.FAT_ARROW

    def test_range_operator(self):
        """범위 연산자"""
        lexer = Lexer("..")
        tokens = lexer.tokenize()
        assert tokens[0].type == TokenType.RANGE

    def test_delimiters(self):
        """구분자"""
        lexer = Lexer("( ) { } [ ] ; : , .")
        tokens = lexer.tokenize()
        assert tokens[0].type == TokenType.LPAREN
        assert tokens[1].type == TokenType.RPAREN
        assert tokens[2].type == TokenType.LBRACE
        assert tokens[3].type == TokenType.RBRACE
        assert tokens[4].type == TokenType.LBRACKET
        assert tokens[5].type == TokenType.RBRACKET
        assert tokens[6].type == TokenType.SEMICOLON
        assert tokens[7].type == TokenType.COLON
        assert tokens[8].type == TokenType.COMMA
        assert tokens[9].type == TokenType.DOT

    def test_comment(self):
        """주석"""
        lexer = Lexer("let x = 5; // 주석입니다")
        tokens = lexer.tokenize()
        assert tokens[0].type == TokenType.LET
        assert tokens[1].type == TokenType.IDENTIFIER
        assert tokens[2].type == TokenType.EQ
        assert tokens[3].type == TokenType.INTEGER
        assert tokens[4].type == TokenType.SEMICOLON
        assert tokens[5].type == TokenType.EOF

    def test_whitespace_handling(self):
        """공백 처리"""
        lexer = Lexer("  let   x  =  42  ;  ")
        tokens = lexer.tokenize()
        assert tokens[0].type == TokenType.LET
        assert tokens[1].type == TokenType.IDENTIFIER
        assert tokens[2].type == TokenType.EQ
        assert tokens[3].type == TokenType.INTEGER
        assert tokens[4].type == TokenType.SEMICOLON
        assert tokens[5].type == TokenType.EOF

    def test_line_and_column_tracking(self):
        """줄과 열 추적"""
        lexer = Lexer("let\nx = 42;")
        tokens = lexer.tokenize()
        assert tokens[0].line == 1
        assert tokens[0].column == 1
        assert tokens[1].line == 2

    def test_string_escape_sequences(self):
        """문자열 이스케이프 시퀀스"""
        lexer = Lexer('"Hello\\nWorld"')
        tokens = lexer.tokenize()
        assert tokens[0].type == TokenType.STRING
        assert tokens[0].value == "Hello\nWorld"

    def test_unterminated_string(self):
        """종료되지 않은 문자열"""
        lexer = Lexer('"Hello')
        with pytest.raises(LexerError):
            lexer.tokenize()

    def test_complex_program(self):
        """복잡한 프로그램"""
        code = """
        fn add(a: i32, b: i32) -> i32 {
            a + b
        }

        let result = add(10, 20);
        """
        lexer = Lexer(code)
        tokens = lexer.tokenize()

        # 기본적으로 토큰화되는지 확인
        assert len(tokens) > 0
        assert tokens[-1].type == TokenType.EOF


if __name__ == "__main__":
    pytest.main([__file__, "-v"])
