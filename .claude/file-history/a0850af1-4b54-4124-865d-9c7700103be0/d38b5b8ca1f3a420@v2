// ============================================================================
// [1] 무한 루프 방지 (Infinite Loop Prevention)
// ============================================================================
//
// 모든 루프가 반드시 끝나야 합니다.
//
fn infinite_loop_prevention() {
    println!("[1] 무한 루프 방지");
    println!("────────────────────────────────────────────────────────────");

    // 방지 1: for 루프의 물리적 한계
    {
        println!("✓ for 루프: 범위가 명확하므로 무한 루프 불가능");
        for i in 1..=5 {
            println!("  i = {}", i);
        }
    }

    // 방지 2: while 루프의 논리적 수렴
    {
        println!("✓ while 루프: 변수가 조건에 수렴");
        let mut n = 100;
        println!("  n의 변환: 100", );
        while n > 0 {
            println!(" → {}", n);
            n /= 2;  // n은 반드시 0에 수렴
        }
        println!();
    }

    // 방지 3: loop의 명시적 탈출
    {
        println!("✓ loop: 반드시 break 조건 확인");
        let mut attempts = 0;
        loop {
            attempts += 1;
            if attempts >= 3 {
                break;  // 반드시 탈출 가능
            }
        }
        println!("  3회 시도 후 탈출");
    }

    // 방지 4: 위험한 패턴 감지
    {
        println!("✓ 위험한 패턴 감지");
        let x = 10;
        // while x < 100 { } ← 위험! x가 증가하지 않음

        // ✅ 올바른 패턴
        let mut counter = 0;
        while counter < 100 {
            counter += 1;
        }
        println!("  counter가 증가하므로 반드시 끝남");
    }

    println!();
}

// ============================================================================
// [2] 데드 코드 제거 (Dead Code Elimination)
// ============================================================================
//
// 실행되지 않는 코드가 없는가?
//
fn dead_code_elimination() {
    println!("[2] 데드 코드 제거");
    println!("────────────────────────────────────────────────────────────");

    // 제거 1: if/else의 완전성
    {
        println!("✓ if/else: 모든 경로 처리");
        let x = 5;
        if x > 0 {
            println!("  양수");
        } else if x < 0 {
            println!("  음수");
        } else {
            println!("  0");
        }
        // 모든 x 값에 대해 처리됨
    }

    // 제거 2: match의 완전성
    {
        println!("✓ match: 와일드카드로 모든 경우 처리");
        let status = 2;
        match status {
            1 => println!("  상태: 1"),
            2 => println!("  상태: 2"),
            3 => println!("  상태: 3"),
            _ => println!("  상태: 기타"),  // 모든 다른 값 처리
        }
    }

    // 제거 3: 도달 불가능한 코드 방지
    {
        println!("✓ 명확한 반환 경로");
        fn get_status(code: i32) -> &'static str {
            if code == 0 {
                return "성공";
            }
            "실패"  // 명확한 탈출
        }
        println!("  status = {}", get_status(0));
    }

    // 제거 4: loop의 도달 불가능 검사
    {
        println!("✓ loop의 탈출 보장");
        let mut i = 0;
        loop {
            i += 1;
            if i >= 5 {
                break;  // 반드시 실행되는 코드
            }
            // 여기 코드는 실행됨
        }
    }

    println!();
}

// ============================================================================
// [3] 완전성 검사 (Exhaustiveness Check)
// ============================================================================
//
// 모든 조건이 처리되는가?
//
fn exhaustiveness_check() {
    println!("[3] 완전성 검사");
    println!("────────────────────────────────────────────────────────────");

    // 검사 1: 이진 조건
    {
        println!("✓ 이진 조건: true/false 모두 처리");
        let is_valid = true;
        if is_valid {
            println!("  유효함");
        } else {
            println!("  유효하지 않음");
        }
    }

    // 검사 2: 세 가지 경우
    {
        println!("✓ 비교 연산: 3가지 경우 모두 처리");
        let x = 10;
        let y = 5;
        if x > y {
            println!("  x > y");
        } else if x < y {
            println!("  x < y");
        } else {
            println!("  x == y");
        }
    }

    // 검사 3: 범위 검사
    {
        println!("✓ 범위 검사: 모든 값 영역 처리");
        let score = 85;
        let grade = if score >= 90 {
            'A'
        } else if score >= 80 {
            'B'
        } else if score >= 70 {
            'C'
        } else {
            'F'
        };
        println!("  학점 = {}", grade);
    }

    // 검사 4: 복합 조건
    {
        println!("✓ 복합 조건: 모든 조합 고려");
        let x = 10;
        let y = 20;
        if x > 0 && y > 0 {
            println!("  둘 다 양수");
        } else if x > 0 || y > 0 {
            println!("  하나는 양수");
        } else {
            println!("  둘 다 음수");
        }
    }

    println!();
}

// ============================================================================
// [4] 중첩 루프 제어 (Nested Loop Control)
// ============================================================================
//
// 깊은 중첩도 명확하게 제어할 수 있는가?
//
fn nested_loop_control() {
    println!("[4] 중첩 루프 제어");
    println!("────────────────────────────────────────────────────────────");

    // 제어 1: 이중 루프
    {
        println!("✓ 이중 루프: 곱셈표");
        for i in 1..=3 {
            for j in 1..=3 {
                print!("{} ", i * j);
            }
            println!();
        }
    }

    // 제어 2: 삼중 루프의 깊이
    {
        println!("✓ 삼중 루프 (경고: 재설계 검토 필요)");
        let mut count = 0;
        for i in 1..=2 {
            for j in 1..=2 {
                for k in 1..=2 {
                    count += 1;
                }
            }
        }
        println!("  총 {} 회 반복", count);
    }

    // 제어 3: 조건부 루프 탈출
    {
        println!("✓ 조건에 따른 루프 탈출");
        for i in 1..=10 {
            for j in 1..=10 {
                if i * j == 20 {
                    println!("  {}×{} = 20 발견", i, j);
                }
            }
        }
    }

    println!();
}

// ============================================================================
// [5] 루프 라벨 (Loop Labels)
// ============================================================================
//
// 복잡한 중첩을 라벨로 명확하게 제어합니다.
//
fn loop_labels_advanced() {
    println!("[5] 루프 라벨");
    println!("────────────────────────────────────────────────────────────");

    // 라벨 1: 외부 루프 탈출
    {
        println!("✓ 라벨로 외부 루프 탈출");
        'search: for i in 1..=5 {
            for j in 1..=5 {
                if i * j == 12 {
                    println!("  {}×{} = 12 발견, 탈출", i, j);
                    break 'search;  // 외부 루프 탈출
                }
            }
        }
    }

    // 라벨 2: continue로 진행
    {
        println!("✓ 라벨로 외부 루프 계속");
        'outer: for i in 1..=3 {
            for j in 1..=3 {
                if j == 2 {
                    continue 'outer;  // 외부 루프의 다음 반복으로
                }
                print!("({},{})", i, j);
            }
        }
        println!();
    }

    // 라벨 3: 값 반환
    {
        println!("✓ 라벨 블록에서 값 반환");
        let result = 'find: {
            for i in 1..=10 {
                if i == 5 {
                    break 'find i * 2;
                }
            }
            0
        };
        println!("  결과 = {}", result);
    }

    // 라벨 4: 여러 라벨
    {
        println!("✓ 여러 라벨 사용");
        let mut found = false;
        'outer: for i in 1..=3 {
            'inner: for j in 1..=3 {
                if i == 2 && j == 2 {
                    println!("  위치 ({}, {}) 발견", i, j);
                    found = true;
                    break 'outer;
                }
            }
        }
    }

    println!();
}

// ============================================================================
// [6] 데이터 흐름 추적 (Data Flow Tracing)
// ============================================================================
//
// 루프 후 변수의 최종 값을 예측할 수 있는가?
//
fn data_flow_tracing() {
    println!("[6] 데이터 흐름 추적");
    println!("────────────────────────────────────────────────────────────");

    // 추적 1: 단순 누적
    {
        println!("✓ 누적 연산의 흐름");
        let mut sum = 0;
        for i in 1..=5 {
            sum += i;  // 1+2+3+4+5 = 15
        }
        println!("  sum = {} (= 1+2+3+4+5)", sum);
    }

    // 추적 2: 조건부 누적
    {
        println!("✓ 조건부 누적의 흐름");
        let mut even_sum = 0;
        for i in 1..=10 {
            if i % 2 == 0 {
                even_sum += i;  // 2+4+6+8+10 = 30
            }
        }
        println!("  even_sum = {}", even_sum);
    }

    // 추적 3: 여러 변수 추적
    {
        println!("✓ 여러 변수의 동시 추적");
        let mut count = 0;
        let mut total = 0;
        for i in 1..=5 {
            count += 1;
            total += i;
        }
        println!("  count = {}, total = {}, average = {}", count, total, total / count);
    }

    // 추적 4: 복잡한 흐름
    {
        println!("✓ 복잡한 흐름의 예측");
        let mut state = 0;
        for i in 1..=5 {
            if state < 10 {
                state += i;
            } else {
                state -= i;
            }
        }
        // i=1: state=1, i=2: state=3, i=3: state=6, i=4: state=10, i=5: state=5
        println!("  최종 state = {} (예측 가능)", state);
    }

    println!();
}

// ============================================================================
// [7] 복잡한 논리 검증 (Complex Logic Verification)
// ============================================================================
//
// 모든 조건과 루프의 조합이 명확한가?
//
fn complex_logic_verification() {
    println!("[7] 복잡한 논리 검증");
    println!("────────────────────────────────────────────────────────────");

    // 검증 1: if + for 조합
    {
        println!("✓ 조건문 + 루프 조합");
        let threshold = 5;
        for i in 1..=10 {
            if i > threshold {
                println!("  {} > {} (임계값 초과)", i, threshold);
                break;
            }
        }
    }

    // 검증 2: if + while + match 조합
    {
        println!("✓ 다중 제어 구조 조합");
        let mut value = 10;
        while value > 0 {
            let status = if value > 7 {
                "높음"
            } else if value > 3 {
                "중간"
            } else {
                "낮음"
            };
            println!("  value={}, status={}", value, status);
            value -= 3;
        }
    }

    // 검증 3: 중첩 조건 + 루프
    {
        println!("✓ 중첩 조건 + 루프");
        for x in 1..=3 {
            for y in 1..=3 {
                if x > 1 {
                    if y > 1 {
                        println!("  ({},{}) 조건 만족", x, y);
                    }
                }
            }
        }
    }

    // 검증 4: 안전성 검증
    {
        println!("✓ 모든 경로의 안전성 검증");
        let mut valid = false;
        for i in 1..=5 {
            if i == 3 {
                valid = true;
                break;
            }
        }

        // valid는 반드시 정의됨 (초기값 = false, 또는 true)
        if valid {
            println!("  유효한 상태 발견");
        } else {
            println!("  유효한 상태 없음");
        }
    }

    println!();
}

