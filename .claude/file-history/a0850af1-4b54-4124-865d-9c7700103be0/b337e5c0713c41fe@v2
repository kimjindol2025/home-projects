print("="*70)

def timer_decorator(func):
    """
    함수의 실행 시간을 측정하는 데코레이터
    """
    @wraps(func)
    def wrapper(*args, **kwargs):
        start_time = time.time()

        result = func(*args, **kwargs)

        end_time = time.time()
        elapsed = end_time - start_time

        print(f"  [TIMER] '{func.__name__}' 실행시간: {elapsed:.6f}초")

        return result

    return wrapper


@timer_decorator
def slow_function(n):
    """느린 계산"""
    return sum(i*i for i in range(n))


@timer_decorator
def fast_function(n):
    """빠른 계산"""
    return n * (n + 1) * (2*n + 1) // 6


print(f"\n[실행]")
print(f"slow_function(100000):")
slow_function(100000)

print(f"\nfast_function(100000):")
fast_function(100000)


