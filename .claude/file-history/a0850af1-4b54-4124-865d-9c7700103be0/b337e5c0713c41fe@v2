print("="*70)

def validate_positive(*arg_names):
    """
    지정된 인자들이 양수인지 검증하는 데코레이터
    (Gogs v30.2의 '샌드박싱' 개념을 파이썬식으로 구현)
    """
    def decorator(func):
        @wraps(func)
        def wrapper(*args, **kwargs):
            # 위치 인자 검증
            func_args = func.__code__.co_varnames[:func.__code__.co_argcount]

            for arg_name in arg_names:
                if arg_name in func_args:
                    idx = func_args.index(arg_name)
                    if idx < len(args):
                        value = args[idx]
                        if not isinstance(value, (int, float)) or value <= 0:
                            raise ValueError(
                                f"'{arg_name}'는 양수여야 합니다. 받은 값: {value}"
                            )

            # 키워드 인자 검증
            for arg_name in arg_names:
                if arg_name in kwargs:
                    value = kwargs[arg_name]
                    if not isinstance(value, (int, float)) or value <= 0:
                        raise ValueError(
                            f"'{arg_name}'는 양수여야 합니다. 받은 값: {value}"
                        )

            return func(*args, **kwargs)

        return wrapper

    return decorator


@validate_positive('radius')
def circle_area(radius):
    """원의 넓이를 계산합니다"""
    pi = 3.14159
    return pi * radius * radius


print(f"\n[올바른 인자]")
print(f"  circle_area(5): {circle_area(5):.2f}")

print(f"\n[잘못된 인자 - 함수 실행 전에 차단됨]")
try:
    print(f"  circle_area(-5)...")
    circle_area(-5)
except ValueError as e:
    print(f"  [ERROR] {e}")

print(f"\n[키워드 인자]")
try:
    print(f"  circle_area(radius=0)...")
    circle_area(radius=0)
except ValueError as e:
    print(f"  [ERROR] {e}")


