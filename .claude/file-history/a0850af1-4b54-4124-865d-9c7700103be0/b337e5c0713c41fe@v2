print("="*70)

def uppercase_decorator(func):
    """결과를 대문자로 변환"""
    @wraps(func)
    def wrapper(*args, **kwargs):
        result = func(*args, **kwargs)
        if isinstance(result, str):
            return result.upper()
        return result
    return wrapper


def reverse_decorator(func):
    """결과를 역순으로 변환"""
    @wraps(func)
    def wrapper(*args, **kwargs):
        result = func(*args, **kwargs)
        if isinstance(result, str):
            return result[::-1]
        return result
    return wrapper


# 데코레이터는 아래부터 위로 적용됨
@uppercase_decorator
@reverse_decorator
def message(text):
    """메시지"""
    return text


print(f"\n[적용 순서]")
print(f"  @uppercase_decorator")
print(f"  @reverse_decorator")
print(f"  def message(text):")
print(f"\n  message('hello world'):")
print(f"    1. reverse_decorator 적용: '{message.__wrapped__('hello world')[::-1]}'")
print(f"    2. uppercase_decorator 적용: '{message('hello world')}'")

print(f"\n실제 결과: {message('hello world')}")

print(f"\n[역순으로 적용한 경우]")

@reverse_decorator
@uppercase_decorator
def message2(text):
    """메시지"""
    return text


print(f"  @reverse_decorator")
print(f"  @uppercase_decorator")
print(f"  message2('hello world'):")
print(f"  결과: {message2('hello world')}")


