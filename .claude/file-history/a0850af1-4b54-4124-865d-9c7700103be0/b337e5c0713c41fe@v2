print("="*70)

def logging_decorator(func):
    """
    함수 실행 전후를 기록하는 데코레이터
    """
    @wraps(func)  # 원본 함수의 메타데이터를 유지
    def wrapper(*args, **kwargs):
        print(f"  [LOG] '{func.__name__}' 실행 시작")
        print(f"        인자: args={args}, kwargs={kwargs}")

        result = func(*args, **kwargs)

        print(f"  [LOG] '{func.__name__}' 실행 완료")
        print(f"        반환값: {result}")

        return result

    return wrapper


@logging_decorator
def add(a, b):
    """두 수를 더합니다"""
    return a + b


@logging_decorator
def greet(name, greeting="Hello"):
    """인사합니다"""
    return f"{greeting}, {name}!"


print(f"\n[실행]")
print(f"add(3, 5):")
add(3, 5)

print(f"\ngreet('Alice', greeting='Hi'):")
greet("Alice", greeting="Hi")

print(f"\n[원본 함수의 메타데이터]")
print(f"  add.__name__: {add.__name__}")
print(f"  add.__doc__: {add.__doc__}")


