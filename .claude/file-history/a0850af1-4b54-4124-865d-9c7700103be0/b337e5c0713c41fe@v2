print("\n" + "="*70)
print("# [증명] 개방-폐쇄 원칙 (Open/Closed Principle)")
print("="*70)

def original_function(x):
    """원본 함수 - 절대 수정하지 않습니다"""
    return x * 2


# 데코레이터 1: 로깅 추가
@logging_decorator
def decorated_v1(x):
    """로깅 기능 추가"""
    return x * 2


# 데코레이터 2: 타이밍 추가
@timer_decorator
def decorated_v2(x):
    """타이밍 기능 추가"""
    return x * 2


# 데코레이터 3: 둘 다 추가
@logging_decorator
@timer_decorator
def decorated_v3(x):
    """로깅 + 타이밍"""
    return x * 2


print(f"\n[원본 함수]")
print(f"  original_function(10): {original_function(10)}")

print(f"\n[데코레이터 1 - 로깅 추가]")
print(f"  decorated_v1(10):")
decorated_v1(10)

print(f"\n[데코레이터 2 - 타이밍 추가]")
print(f"  decorated_v2(10):")
decorated_v2(10)

print(f"\n[데코레이터 3 - 로깅 + 타이밍]")
print(f"  decorated_v3(10):")
decorated_v3(10)

print(f"\n[결론]")
print(f"  원본 함수는 절대 수정되지 않습니다")
print(f"  기능 추가는 데코레이터를 통해서만 합니다")
print(f"  이것이 OCP(Open/Closed Principle)입니다")


