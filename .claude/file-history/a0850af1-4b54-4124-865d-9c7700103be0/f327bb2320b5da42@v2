#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn trinity_auditor() {
        let data = "CONFIDENTIAL_ACCESS_77".to_string();
        let config = "SEC-LOG";

        let auditor = GogsAuditor::new(&data, config);
        assert_eq!(auditor.get_severity(), 2);
    }

    #[test]
    fn dual_processor() {
        let primary = vec![1, 2, 3];
        let secondary = "configuration".to_string();

        let processor = DualProcessor::new(&primary, &secondary);
        let extracted = processor.extract_primary();
        assert_eq!(extracted, vec![1, 2, 3]);
    }

    #[test]
    fn security_log() {
        let event = "Unauthorized access attempt".to_string();
        let timestamp = "2026-02-22T10:30:45Z";

        let log = SecurityLog::new(&event, timestamp, AuditLevel::High);
        assert!(log.format_log().contains("ERROR"));
        assert!(!log.is_critical());
    }

    #[test]
    fn config_manager() {
        let settings = "database=localhost,port=5432".to_string();
        let environment = "production";
        let version = "v7.4.0";

        let manager = ConfigManager::new(&settings, environment, version);
        let description = manager.describe();
        assert!(description.contains("production"));
    }
}

