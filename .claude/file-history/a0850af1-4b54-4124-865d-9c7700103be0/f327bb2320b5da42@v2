use std::fmt::Display;

// ============================================================================
// [Foundation] Audit Level - Pure enum, no lifetime
// ============================================================================

#[derive(Clone, Copy, Debug)]
enum AuditLevel {
    Low,
    Medium,
    High,
    Critical,
}

impl AuditLevel {
    fn level(&self) -> &'static str {
        match self {
            AuditLevel::Low => "INFO",
            AuditLevel::Medium => "WARN",
            AuditLevel::High => "ERROR",
            AuditLevel::Critical => "FATAL",
        }
    }

    fn severity_score(&self) -> u32 {
        match self {
            AuditLevel::Low => 1,
            AuditLevel::Medium => 2,
            AuditLevel::High => 3,
            AuditLevel::Critical => 4,
        }
    }
}

// ============================================================================
// [Trinity: Generic + Trait Bound + Lifetime]
// ============================================================================

/// [Core Auditor - The Trinity]
/// 'a: lifetime of reference data
/// T: generic type being analyzed
/// T: 'a -> T's internal references must live at least 'a
struct GogsAuditor<'a, T>
where
    T: Display + 'a,
{
    target: &'a T,
    config: &'a str,
    severity: AuditLevel,
}

impl<'a, T> GogsAuditor<'a, T>
where
    T: Display + 'a,
{
    fn new(target: &'a T, config: &'a str) -> Self {
        GogsAuditor {
            target,
            config,
            severity: AuditLevel::Medium,
        }
    }

    fn audit(&self) {
        println!(
            "[{}] {} -> {}",
            self.config,
            self.severity.level(),
            self.target
        );
    }

    fn with_severity(mut self, level: AuditLevel) -> Self {
        self.severity = level;
        self
    }

    fn get_severity(&self) -> u32 {
        self.severity.severity_score()
    }
}

// ============================================================================
// [Advanced: Multiple Generics + Multiple Lifetimes]
// ============================================================================

/// [Multi-Generic Processor]
/// 'a, 'b: different lifetimes
/// T, U: different types with different constraints
/// T: 'a -> T's references live at least 'a
/// U: Display + 'b -> U's references live at least 'b
struct DualProcessor<'a, 'b, T, U>
where
    T: Clone + 'a,
    U: Display + 'b,
    'b: 'a,  // 'b lives longer than 'a
{
    primary: &'a T,
    secondary: &'b U,
}

impl<'a, 'b, T, U> DualProcessor<'a, 'b, T, U>
where
    T: Clone + Display + 'a,
    U: Display + 'b,
    'b: 'a,
{
    fn new(primary: &'a T, secondary: &'b U) -> Self {
        DualProcessor { primary, secondary }
    }

    fn process(&self) {
        println!(
            "Primary ({}): {} | Secondary ({}): {}",
            std::any::type_name::<T>(),
            self.primary,
            std::any::type_name::<U>(),
            self.secondary
        );
    }

    fn extract_primary(&self) -> T {
        self.primary.clone()
    }
}

// ============================================================================
// [Pattern: Trait Object with Lifetime Bound]
// ============================================================================

/// [Trait with Lifetime]
trait Analyzer<'a> {
    fn analyze(&self, data: &'a str) -> String;
}

/// [Implementation 1]
struct SimpleAnalyzer;

impl<'a> Analyzer<'a> for SimpleAnalyzer {
    fn analyze(&self, data: &'a str) -> String {
        format!("Analyzed: {}", data)
    }
}

/// [Implementation 2]
struct DetailedAnalyzer {
    prefix: String,
}

impl<'a> Analyzer<'a> for DetailedAnalyzer {
    fn analyze(&self, data: &'a str) -> String {
        format!("{} - Analyzed: {}", self.prefix, data)
    }
}

// ============================================================================
// [Advanced Pattern: Conditional Trait Bound]
// ============================================================================

struct ConditionalProcessor<'a, T>
where
    T: 'a,
{
    data: &'a T,
    _phantom: std::marker::PhantomData<&'a T>,
}

impl<'a, T> ConditionalProcessor<'a, T>
where
    T: Display + 'a,
{
    fn display(&self) {
        println!("Data: {}", self.data);
    }
}

impl<'a, T> ConditionalProcessor<'a, T>
where
    T: Clone + 'a,
{
    fn clone_data(&self) -> T {
        self.data.clone()
    }
}

// ============================================================================
// [Real-World: Security Log System]
// ============================================================================

struct SecurityLog<'a, T>
where
    T: Display + 'a,
{
    event: &'a T,
    timestamp: &'a str,
    severity: AuditLevel,
}

impl<'a, T> SecurityLog<'a, T>
where
    T: Display + 'a,
{
    fn new(event: &'a T, timestamp: &'a str, severity: AuditLevel) -> Self {
        SecurityLog {
            event,
            timestamp,
            severity,
        }
    }

    fn format_log(&self) -> String {
        format!(
            "[{}] {} | {} | {}",
            self.timestamp,
            self.severity.level(),
            self.severity.severity_score(),
            self.event
        )
    }

    fn is_critical(&self) -> bool {
        matches!(self.severity, AuditLevel::Critical)
    }
}

// ============================================================================
// [Real-World: Configuration Manager]
// ============================================================================

struct ConfigManager<'a, T>
where
    T: Display + 'a,
{
    settings: &'a T,
    environment: &'a str,
    version: &'a str,
}

impl<'a, T> ConfigManager<'a, T>
where
    T: Display + 'a,
{
    fn new(settings: &'a T, environment: &'a str, version: &'a str) -> Self {
        ConfigManager {
            settings,
            environment,
            version,
        }
    }

    fn describe(&self) -> String {
        format!(
            "Env: {}, Version: {}, Settings: {}",
            self.environment, self.version, self.settings
        )
    }
}

