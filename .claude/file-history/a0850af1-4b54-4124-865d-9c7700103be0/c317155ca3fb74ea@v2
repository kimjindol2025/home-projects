// ============================================================================
// [1] 구조체 기초 (Struct Basics)
// ============================================================================
//
// 구조체 정의와 인스턴스 생성
//
fn struct_basics() {
    println!("[1] 구조체 기초: 정의와 인스턴스 생성");
    println!("────────────────────────────────────────────────────────────");

    // 구조체 정의
    struct Rectangle {
        width: u32,
        height: u32,
    }

    println!("✓ 구조체 인스턴스 생성");
    let rect1 = Rectangle {
        width: 30,
        height: 50,
    };
    println!("  rect1: {}x{}", rect1.width, rect1.height);

    // 다른 변수로 필드값 초기화
    println!("✓ 필드 값 초기화");
    let width = 40;
    let height = 60;
    let rect2 = Rectangle {
        width: width,
        height: height,
    };
    println!("  rect2: {}x{}", rect2.width, rect2.height);

    // 간략한 필드 초기화 (shorthand)
    println!("✓ 간략한 필드 초기화");
    let rect3 = Rectangle { width, height };
    println!("  rect3: {}x{}", rect3.width, rect3.height);

    println!("✓ 특징: 필드는 정의 순서대로 메모리에 배치됨");
    println!();
}

// ============================================================================
// [2] 구조체와 소유권 (Struct Ownership)
// ============================================================================
//
// Copy 타입 필드 vs Move 타입 필드
//
fn struct_ownership() {
    println!("[2] 구조체와 소유권");
    println!("────────────────────────────────────────────────────────────");

    struct Person {
        name: String,
        age: u32,
    }

    println!("✓ Move 타입 필드 (String)");
    {
        let person = Person {
            name: String::from("Alice"),
            age: 30,
        };
        println!("  person: {} ({}세)", person.name, person.age);

        let p_name = person.name;  // String → move
        println!("  person.name을 p_name으로 이동 (소유권 이전)");
        // println!("{}", person.name);  // ❌ 컴파일 에러

        let p_age = person.age;  // u32 → copy
        println!("  person.age를 p_age로 복사 (자동 복사)");
        println!("  person.age 여전히 유효: {}", person.age);
    }

    println!("✓ 특징 분석");
    println!("  - String (Move 타입): 소유권이 이전되면 원본 사용 불가");
    println!("  - u32 (Copy 타입): 자동으로 복사되므로 원본도 사용 가능");
    println!();
}

// ============================================================================
// [3] 참조를 통한 구조체 접근 (References)
// ============================================================================
//
// &Struct으로 읽기 전용 접근
//
fn struct_references() {
    println!("[3] 참조를 통한 구조체 접근");
    println!("────────────────────────────────────────────────────────────");

    struct Point {
        x: f64,
        y: f64,
    }

    fn calculate_distance(p: &Point) {
        let dist = (p.x * p.x + p.y * p.y).sqrt();
        println!("✓ 원점으로부터 거리: {:.2}", dist);
    }

    fn print_point(p: &Point) {
        println!("  좌표: ({}, {})", p.x, p.y);
    }

    println!("✓ 참조를 매개변수로 사용");
    let point = Point { x: 3.0, y: 4.0 };

    calculate_distance(&point);
    print_point(&point);
    println!("  point는 여전히 유효: ({}, {})", point.x, point.y);

    println!("✓ 특징: 참조로 전달하면 소유권 유지");
    println!();
}

// ============================================================================
// [4] 가변 구조체 (Mutable Struct)
// ============================================================================
//
// &mut Struct으로 수정 권한 빌려주기
//
fn mutable_struct() {
    println!("[4] 가변 구조체");
    println!("────────────────────────────────────────────────────────────");

    struct Rectangle {
        width: u32,
        height: u32,
    }

    fn scale(r: &mut Rectangle, factor: u32) {
        r.width *= factor;
        r.height *= factor;
        println!("✓ 크기 조정: {}x{}", r.width, r.height);
    }

    fn double_width(r: &mut Rectangle) {
        r.width *= 2;
    }

    println!("✓ 가변 구조체 수정");
    let mut rect = Rectangle {
        width: 30,
        height: 50,
    };

    println!("  초기: {}x{}", rect.width, rect.height);
    scale(&mut rect, 2);

    println!("✓ 추가 수정");
    double_width(&mut rect);
    println!("  최종: {}x{}", rect.width, rect.height);

    println!("✓ 특징: &mut로 수정 권한을 빌려주기");
    println!();
}

// ============================================================================
// [5] 메모리 레이아웃 (Memory Layout)
// ============================================================================
//
// 구조체가 메모리에 배치되는 방식
//
fn memory_layout() {
    println!("[5] 메모리 레이아웃");
    println!("────────────────────────────────────────────────────────────");

    struct Employee {
        id: u32,        // 4 bytes
        age: u32,       // 4 bytes
        active: bool,   // 1 byte
    }

    struct Color {
        r: u8,          // 1 byte
        g: u8,          // 1 byte
        b: u8,          // 1 byte
    }

    println!("✓ Employee 구조체");
    let emp = Employee { id: 1001, age: 30, active: true };
    let emp_size = std::mem::size_of::<Employee>();
    println!("  크기: {} bytes", emp_size);
    println!("  필드: id (4) + age (4) + active (1) + padding");

    println!("✓ Color 구조체");
    let color = Color { r: 255, g: 128, b: 64 };
    let color_size = std::mem::size_of::<Color>();
    println!("  크기: {} bytes", color_size);
    println!("  필드: r (1) + g (1) + b (1) = {} bytes", 3);

    println!("✓ 특징:");
    println!("  - 필드는 정의 순서대로 메모리에 배치");
    println!("  - 정렬(Alignment) 때문에 패딩 추가 가능");
    println!("  - 아키텍처에 따라 크기가 다를 수 있음");
    println!();
}

// ============================================================================
// [6] 구조체 메서드 (Methods)
// ============================================================================
//
// impl 블록으로 메서드 정의
//
fn struct_methods() {
    println!("[6] 구조체 메서드");
    println!("────────────────────────────────────────────────────────────");

    struct Circle {
        radius: f64,
    }

    impl Circle {
        // 불변 메서드 (&self)
        fn area(&self) -> f64 {
            3.14159 * self.radius * self.radius
        }

        // 불변 메서드 (&self)
        fn circumference(&self) -> f64 {
            2.0 * 3.14159 * self.radius
        }

        // 가변 메서드 (&mut self)
        fn resize(&mut self, new_radius: f64) {
            self.radius = new_radius;
        }

        // 소비 메서드 (self)
        fn into_area(self) -> f64 {
            3.14159 * self.radius * self.radius
        }
    }

    println!("✓ 불변 메서드 호출");
    let circle = Circle { radius: 5.0 };
    println!("  반지름: {}", circle.radius);
    println!("  넓이: {:.2}", circle.area());
    println!("  둘레: {:.2}", circle.circumference());

    println!("✓ 가변 메서드 호출");
    let mut circle2 = Circle { radius: 3.0 };
    println!("  수정 전: {:.2}", circle2.area());
    circle2.resize(6.0);
    println!("  수정 후: {:.2}", circle2.area());

    println!("✓ 특징:");
    println!("  - &self: 읽기 전용 메서드");
    println!("  - &mut self: 수정 메서드");
    println!("  - self: 소유권을 받는 메서드");
    println!();
}

// ============================================================================
// [7] 복합 구조체 (Complex Structs)
// ============================================================================
//
// 실무 패턴: 계좌, 날짜, 좌표 등
//
fn complex_structs() {
    println!("[7] 복합 구조체와 메서드");
    println!("────────────────────────────────────────────────────────────");

    struct BankAccount {
        account_number: String,
        owner: String,
        balance: f64,
    }

    impl BankAccount {
        fn new(account_number: &str, owner: &str, initial: f64) -> Self {
            BankAccount {
                account_number: String::from(account_number),
                owner: String::from(owner),
                balance: initial,
            }
        }

        fn deposit(&mut self, amount: f64) {
            self.balance += amount;
            println!("  입금: {} → 잔액: {}", amount, self.balance);
        }

        fn withdraw(&mut self, amount: f64) -> bool {
            if self.balance >= amount {
                self.balance -= amount;
                println!("  출금: {} → 잔액: {}", amount, self.balance);
                true
            } else {
                println!("  출금 실패: 잔액 부족 (필요: {}, 보유: {})", amount, self.balance);
                false
            }
        }

        fn get_balance(&self) -> f64 {
            self.balance
        }
    }

    println!("✓ 은행 계좌 관리");
    let mut account = BankAccount::new("1234567890", "Kim", 1000.0);
    println!("  계좌: {}", account.account_number);
    println!("  소유자: {}", account.owner);
    println!("  초기 잔액: {}", account.get_balance());

    println!("✓ 입출금 기능");
    account.deposit(500.0);
    account.withdraw(300.0);
    account.withdraw(2000.0);

    println!("✓ 최종 잔액: {}", account.get_balance());
    println!();
}

// ============================================================================
// [8] 구조체 설계 패턴 (Best Practices)
// ============================================================================
//
// 실무에서 구조체를 잘 설계하는 방법
//
fn struct_best_practices() {
    println!("[8] 구조체 설계 패턴");
    println!("────────────────────────────────────────────────────────────");

    // 패턴 1: 생성자 메서드 (Constructor)
    struct Date {
        year: u32,
        month: u32,
        day: u32,
    }

    impl Date {
        fn new(year: u32, month: u32, day: u32) -> Self {
            Date { year, month, day }
        }

        fn format(&self) -> String {
            format!("{:04}-{:02}-{:02}", self.year, self.month, self.day)
        }

        fn is_valid(&self) -> bool {
            self.month >= 1 && self.month <= 12 &&
            self.day >= 1 && self.day <= 31
        }
    }

    // 패턴 2: 기하학적 연산
    struct Vector2D {
        x: f64,
        y: f64,
    }

    impl Vector2D {
        fn new(x: f64, y: f64) -> Self {
            Vector2D { x, y }
        }

        fn magnitude(&self) -> f64 {
            (self.x * self.x + self.y * self.y).sqrt()
        }

        fn dot_product(&self, other: &Vector2D) -> f64 {
            self.x * other.x + self.y * other.y
        }

        fn add(&self, other: &Vector2D) -> Vector2D {
            Vector2D::new(self.x + other.x, self.y + other.y)
        }
    }

    println!("✓ 패턴 1: 생성자 메서드");
    let date = Date::new(2026, 2, 22);
    println!("  날짜: {}", date.format());
    println!("  유효성: {}", date.is_valid());

    println!("✓ 패턴 2: 벡터 연산");
    let v1 = Vector2D::new(3.0, 4.0);
    let v2 = Vector2D::new(2.0, 1.0);
    println!("  v1 크기: {:.2}", v1.magnitude());
    println!("  v1·v2 (내적): {:.2}", v1.dot_product(&v2));

    let v3 = v1.add(&v2);
    println!("  v1 + v2: ({:.1}, {:.1})", v3.x, v3.y);

    println!("✓ 설계 원칙:");
    println!("  - 관련된 데이터를 하나의 구조체로");
    println!("  - 생성자(new)를 통한 인스턴스 생성");
    println!("  - 메서드로 행동 정의");
    println!();
}

