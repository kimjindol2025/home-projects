"""
FreeLang 에러 정의
"""

class FreeLangError(Exception):
    """모든 FreeLang 에러의 기본 클래스"""
    def __init__(self, message: str, line: int = 0, column: int = 0):
        self.message = message
        self.line = line
        self.column = column
        super().__init__(self._format_error())

    def _format_error(self) -> str:
        if self.line > 0:
            return f"Error at line {self.line}, column {self.column}: {self.message}"
        return f"Error: {self.message}"


class LexerError(FreeLangError):
    """어휘 분석 에러"""
    pass


class ParserError(FreeLangError):
    """구문 분석 에러"""
    pass


class TypeCheckerError(FreeLangError):
    """타입 검사 에러"""
    pass


class RuntimeError(FreeLangError):
    """런타임 에러"""
    pass


class CompilerError(FreeLangError):
    """컴파일러 에러"""
    pass
