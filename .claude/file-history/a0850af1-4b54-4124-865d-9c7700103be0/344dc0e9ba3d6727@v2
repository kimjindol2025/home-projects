def query_all_data(conn, cursor):
    """모든 데이터 조회"""

    print("\n" + "=" * 80)
    print("🔍 데이터 조회")
    print("=" * 80)

    # 1. 모든 연구자
    print("\n【 연구자 목록 】")
    print("-" * 80)
    cursor.execute("SELECT * FROM researchers")
    print(f"{'ID':<5} {'이름':<15} {'부서':<20} {'이메일':<25}")
    print("-" * 80)
    for row in cursor.fetchall():
        print(f"{row[0]:<5} {row[1]:<15} {row[2]:<20} {row[3]:<25}")

    # 2. 모든 실험
    print("\n【 실험 프로젝트 목록 】")
    print("-" * 80)
    cursor.execute("""
        SELECT e.experiment_id, e.title, r.name, e.status, e.start_date
        FROM experiments e
        JOIN researchers r ON e.researcher_id = r.researcher_id
        ORDER BY e.experiment_id
    """)
    print(f"{'ID':<5} {'프로젝트명':<30} {'담당자':<15} {'상태':<10} {'시작일':<12}")
    print("-" * 80)
    for row in cursor.fetchall():
        print(f"{row[0]:<5} {row[1]:<30} {row[2]:<15} {row[3]:<10} {row[4]:<12}")

    # 3. 측정 결과
    print("\n【 측정 결과 (상위 10개) 】")
    print("-" * 80)
    cursor.execute("""
        SELECT m.metric_name, m.value, m.unit, e.title, m.recorded_at
        FROM measurements m
        JOIN experiments e ON m.experiment_id = e.experiment_id
        ORDER BY m.recorded_at DESC
        LIMIT 10
    """)
    print(f"{'항목':<20} {'값':<15} {'단위':<10} {'실험명':<25} {'기록 시간':<20}")
    print("-" * 80)
    for row in cursor.fetchall():
        print(f"{row[0]:<20} {row[1]:<15.2f} {row[2]:<10} {row[3]:<25} {row[4]:<20}")


def advanced_queries(conn, cursor):
    """고급 쿼리"""

    print("\n" + "=" * 80)
    print("⚡ 고급 쿼리")
    print("=" * 80)

    # 1. 연구자별 실험 개수
    print("\n【 연구자별 실험 개수 】")
    print("-" * 80)
    cursor.execute("""
        SELECT r.name, COUNT(e.experiment_id) as count,
               SUM(CASE WHEN e.status = '완료' THEN 1 ELSE 0 END) as completed
        FROM researchers r
        LEFT JOIN experiments e ON r.researcher_id = e.researcher_id
        GROUP BY r.researcher_id
        ORDER BY count DESC
    """)
    print(f"{'연구자':<15} {'전체 실험':<15} {'완료':<10}")
    print("-" * 80)
    for row in cursor.fetchall():
        print(f"{row[0]:<15} {row[1]:<15} {row[2]:<10}")

    # 2. 실험별 측정 항목 수
    print("\n【 실험별 측정 항목 수 】")
    print("-" * 80)
    cursor.execute("""
        SELECT e.title, COUNT(m.measurement_id) as measurement_count,
               MAX(m.value) as max_value, MIN(m.value) as min_value
        FROM experiments e
        LEFT JOIN measurements m ON e.experiment_id = m.experiment_id
        GROUP BY e.experiment_id
        ORDER BY measurement_count DESC
    """)
    print(f"{'프로젝트명':<30} {'측정 항목':<15} {'최대값':<15} {'최소값':<15}")
    print("-" * 80)
    for row in cursor.fetchall():
        count = row[1] if row[1] else 0
        max_val = f"{row[2]:.2f}" if row[2] else "N/A"
        min_val = f"{row[3]:.2f}" if row[3] else "N/A"
        print(f"{row[0]:<30} {count:<15} {max_val:<15} {min_val:<15}")

    # 3. 완료된 실험 통계
    print("\n【 완료된 실험 통계 】")
    print("-" * 80)
    cursor.execute("""
        SELECT
            COUNT(*) as total_completed,
            AVG(julianday(end_date) - julianday(start_date)) as avg_duration_days
        FROM experiments
        WHERE status = '완료'
    """)
    row = cursor.fetchone()
    print(f"완료된 실험: {row[0]}개")
    print(f"평균 소요 기간: {row[1]:.1f}일")


def statistics(conn, cursor):
    """데이터베이스 통계"""

    print("\n" + "=" * 80)
    print("📊 데이터베이스 통계")
    print("=" * 80)

    cursor.execute("SELECT COUNT(*) FROM researchers")
    researcher_count = cursor.fetchone()[0]

    cursor.execute("SELECT COUNT(*) FROM experiments")
    experiment_count = cursor.fetchone()[0]

    cursor.execute("SELECT COUNT(*) FROM measurements")
    measurement_count = cursor.fetchone()[0]

    cursor.execute("SELECT COUNT(*) FROM experiments WHERE status = '완료'")
    completed = cursor.fetchone()[0]

    cursor.execute("SELECT COUNT(*) FROM experiments WHERE status = '진행중'")
    ongoing = cursor.fetchone()[0]

    print(f"\n【 현황 】")
    print(f"  연구자: {researcher_count}명")
    print(f"  전체 실험: {experiment_count}개")
    print(f"    - 완료: {completed}개 ✅")
    print(f"    - 진행중: {ongoing}개 ⏳")
    print(f"  측정 결과: {measurement_count}개")

    # 파일 크기
    file_size = os.path.getsize(DB_FILE)
    print(f"\n【 파일 】")
    print(f"  경로: {os.path.abspath(DB_FILE)}")
    print(f"  크기: {file_size:,} bytes ({file_size/1024:.1f} KB)")


def main():
    """메인 실행"""

    try:
        # 1. 데이터베이스 생성
        conn, cursor = init_database()

        # 2. 샘플 데이터 삽입
        insert_sample_data(conn, cursor)

        # 3. 데이터 조회
        query_all_data(conn, cursor)

        # 4. 고급 쿼리
        advanced_queries(conn, cursor)

        # 5. 통계
        statistics(conn, cursor)

        # 6. 최종 메시지
        print("\n" + "=" * 80)
        print("✨ 완료!")
        print("=" * 80)
        print(f"\n✅ SQLite 데이터베이스가 성공적으로 생성되었습니다!")
        print(f"\n파일 위치: {os.path.abspath(DB_FILE)}")
        print(f"\n기록이 증명이다 gogs 🎓")

        conn.close()

    except Exception as e:
        print(f"\n❌ 오류 발생: {e}")
        import traceback
        traceback.print_exc()


if __name__ == "__main__":
    main()
