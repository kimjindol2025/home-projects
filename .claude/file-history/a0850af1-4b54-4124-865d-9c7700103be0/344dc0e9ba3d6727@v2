#!/usr/bin/env python3
# -*- coding: utf-8 -*-

"""
🗄️ SQLite 데이터베이스 직접 만들기

실제 파일 기반 데이터베이스 생성 및 운영
"""

import sqlite3
import os
from datetime import datetime, timedelta

# 데이터베이스 파일 경로
DB_FILE = 'gogs_research.db'

def init_database():
    """데이터베이스 초기화 및 테이블 생성"""

    print("=" * 80)
    print("🗄️  SQLite 데이터베이스 생성")
    print("=" * 80)

    # 기존 DB 파일 제거 (깨끗한 시작)
    if os.path.exists(DB_FILE):
        os.remove(DB_FILE)
        print(f"\n⚠️  기존 데이터베이스 삭제: {DB_FILE}")

    # 연결 (파일이 없으면 자동 생성)
    conn = sqlite3.connect(DB_FILE)
    cursor = conn.cursor()

    print(f"\n✅ 새 데이터베이스 생성: {DB_FILE}")

    # 테이블 1: 연구자 정보
    print("\n[테이블 1] 연구자 정보")
    cursor.execute('''
        CREATE TABLE researchers (
            researcher_id INTEGER PRIMARY KEY AUTOINCREMENT,
            name TEXT NOT NULL UNIQUE,
            department TEXT,
            email TEXT,
            join_date DATE DEFAULT CURRENT_DATE
        )
    ''')
    print("  ✓ researchers 테이블 생성")

    # 테이블 2: 실험 프로젝트
    print("\n[테이블 2] 실험 프로젝트")
    cursor.execute('''
        CREATE TABLE experiments (
            experiment_id INTEGER PRIMARY KEY AUTOINCREMENT,
            researcher_id INTEGER NOT NULL,
            title TEXT NOT NULL,
            description TEXT,
            start_date DATE,
            end_date DATE,
            status TEXT CHECK(status IN ('진행중', '완료', '중단')) DEFAULT '진행중',
            FOREIGN KEY(researcher_id) REFERENCES researchers(researcher_id)
        )
    ''')
    print("  ✓ experiments 테이블 생성")

    # 테이블 3: 측정 결과
    print("\n[테이블 3] 측정 결과")
    cursor.execute('''
        CREATE TABLE measurements (
            measurement_id INTEGER PRIMARY KEY AUTOINCREMENT,
            experiment_id INTEGER NOT NULL,
            metric_name TEXT NOT NULL,
            value REAL NOT NULL,
            unit TEXT,
            recorded_at DATETIME DEFAULT CURRENT_TIMESTAMP,
            FOREIGN KEY(experiment_id) REFERENCES experiments(experiment_id)
        )
    ''')
    print("  ✓ measurements 테이블 생성")

    # 인덱스 생성 (성능 최적화)
    print("\n[인덱스 생성]")
    cursor.execute("CREATE INDEX idx_researcher ON experiments(researcher_id)")
    cursor.execute("CREATE INDEX idx_experiment ON measurements(experiment_id)")
    cursor.execute("CREATE INDEX idx_metric ON measurements(metric_name)")
    print("  ✓ 인덱스 생성 완료")

    conn.commit()

    return conn, cursor


