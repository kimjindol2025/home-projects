# 예제 1: 카운팅 제너레이터
def count_up(n):
    """n까지 세는 제너레이터"""
    i = 1
    while i <= n:
        yield i
        i += 1

print("✓ 카운팅 제너레이터:")
print("  for i in count_up(5):")
for i in count_up(5):
    print(f"    {i}")
print()

# 예제 2: 범위 제너레이터 (range처럼)
def my_range(start, stop, step=1):
    """Python의 range()를 제너레이터로 구현"""
    current = start
    while current < stop:
        yield current
        current += step

print("✓ 범위 제너레이터:")
print("  for i in my_range(0, 10, 2):")
for i in my_range(0, 10, 2):
    print(f"    {i}", end=" ")
print("\n")

# 예제 3: 피보나치 수열
def fibonacci(n):
    """n개의 피보나치 수를 생성하는 제너레이터"""
    a, b = 0, 1
    count = 0
    while count < n:
        yield a
        a, b = b, a + b
        count += 1

print("✓ 피보나치 수열 제너레이터:")
print("  처음 10개의 피보나치 수:")
