# 예제 1: 상태를 가진 제너레이터
def stateful_counter():
    """상태를 유지하면서 카운팅하는 제너레이터"""
    value = 0
    while True:
        value += 1
        print(f"  (내부 상태 value={value})")
        yield value

print("✓ 상태를 유지하는 제너레이터:")
print()
counter = stateful_counter()
print(f"  next(counter) = {next(counter)}")
print(f"  next(counter) = {next(counter)}")
print(f"  next(counter) = {next(counter)}")
print()

# 예제 2: 시퀀스 추적 제너레이터
def sequence_tracker(data):
    """데이터를 읽으면서 인덱스와 값을 추적"""
    index = 0
    while index < len(data):
        yield (index, data[index])
        index += 1

print("✓ 데이터의 인덱스와 값을 함께 반환:")
data = ["A", "B", "C", "D"]
for idx, value in sequence_tracker(data):
    print(f"  [{idx}] = {value}")
print()

# 예제 3: 윈도우 제너레이터 (슬라이딩 윈도우)
def sliding_window(data, window_size):
    """슬라이딩 윈도우로 데이터 분석"""
    for i in range(len(data) - window_size + 1):
        yield data[i:i+window_size]

print("✓ 슬라이딩 윈도우 (크기 3):")
data = [1, 2, 3, 4, 5, 6, 7]
for window in sliding_window(data, 3):
    print(f"  윈도우: {window}")
print()

# 예제 4: 스트림 필터 제너레이터
def filter_stream(generator, predicate):
    """제너레이터에서 조건을 만족하는 값만 선택"""
    for value in generator:
        if predicate(value):
            print(f"  ✓ {value} (조건 만족)")
            yield value
        else:
            print(f"  ✗ {value} (조건 미충족)")

print("✓ 제너레이터 필터링 (5보다 큰 수만):")
source = (x for x in range(3, 8))
filtered = filter_stream(source, lambda x: x > 5)
results = list(filtered)
print(f"  결과: {results}")
print()

print("💡 결론: 제너레이터는 로컬 변수로 복잡한 상태 관리를 우아하게 표현합니다!\n")


