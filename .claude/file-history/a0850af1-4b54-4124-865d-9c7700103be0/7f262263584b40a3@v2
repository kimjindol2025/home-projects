# 실전 예제: 프로덕션급 제너레이터
def production_data_pipeline(data_size=1_000_000):
    """
    프로덕션 환경에서 사용할 수 있는 데이터 파이프라인
    - 대용량 데이터 처리
    - 에러 처리
    - 상태 모니터링
    """
    processed = 0
    errors = 0

    # 1단계: 데이터 생성
    def data_generator():
        import random
        for i in range(data_size):
            if random.random() < 0.01:  # 1% 오류율
                yield None
            else:
                yield random.randint(1, 100)

    # 2단계: 데이터 필터링 및 정제
    def clean_data(source):
        nonlocal errors
        for value in source:
            if value is None:
                errors += 1
                continue
            yield value

    # 3단계: 데이터 변환 및 통계
    def aggregate_stats(source, batch_size=1000):
        nonlocal processed
        batch = []
        for value in source:
            batch.append(value)
            processed += 1

            if len(batch) >= batch_size:
                avg = sum(batch) / len(batch)
                min_val = min(batch)
                max_val = max(batch)
                yield {
                    "batch": processed // batch_size,
                    "avg": f"{avg:.2f}",
                    "min": min_val,
                    "max": max_val,
                    "count": len(batch)
                }
                batch = []

    # 파이프라인 구성
    source = data_generator()
    cleaned = clean_data(source)
    stats = aggregate_stats(cleaned, batch_size=10000)

    # 결과 처리
    print("✓ 프로덕션급 데이터 파이프라인:")
    print(f"  데이터 크기: {data_size:,}")
    print()

    batch_count = 0
    for stat in stats:
        batch_count += 1
        if batch_count <= 3:  # 처음 3개 배치만 출력
            print(f"  [{stat['batch']}] 평균: {stat['avg']}, "
                  f"범위: {stat['min']}~{stat['max']}, "
                  f"개수: {stat['count']}")

    print(f"  ...")
    print(f"  처리된 데이터: {processed:,}")
    print(f"  오류: {errors:,}")
    print(f"  메모리 사용: ~0.1 MB (리스트라면 ~40 MB)")
    print()

production_data_pipeline(100_000)

