# 예제 3: 데이터 파이프라인
def data_source():
    """데이터 소스: 센서 값을 시뮬레이션"""
    import random
    for i in range(10):
        yield random.randint(10, 100)

def filter_anomalies(source, threshold=50):
    """이상치 필터링: threshold보다 큰 값만"""
    for value in source:
        if value > threshold:
            yield value

def transform_data(source, transform_fn):
    """데이터 변환"""
    for value in source:
        yield transform_fn(value)

print("✓ 데이터 파이프라인 구성:")
print("  소스 → 필터 → 변환 → 결과")
