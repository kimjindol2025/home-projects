source = data_source()
filtered = filter_anomalies(source, 60)
transformed = transform_data(filtered, lambda x: x * 2)

print("  결과 (원본값 > 60인 값들의 2배):")
results = list(transformed)
print(f"  {results}")
print()

# 예제 4: 무한 피보나치
def infinite_fibonacci():
    """무한 피보나치 수열"""
    a, b = 0, 1
    while True:
        yield a
        a, b = b, a + b

