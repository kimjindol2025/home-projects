/// Box<T>를 사용한 기본 힙 할당
fn demo_basic_box() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║              [Demo 1] Box<T>: 기본 힙 할당                   ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    // [1] 스택에서: 고정 크기 i32
    let stack_value: i32 = 42;
    println!("스택 변수: value = {}", stack_value);
    println!("  위치: 스택 (빠르지만 엄격)");
    println!("  크기: 4 바이트 (컴파일 타임 결정)");

    // [2] 힙에서: Box를 사용한 동적 할당
    let heap_value: Box<i32> = Box::new(42);
    println!("\n힙 변수: Box::new({}) = {:?}", 42, heap_value);
    println!("  스택에 저장된 것: 포인터 주소 (8 바이트)");
    println!("  힙에 저장된 것: 실제 데이터 (4 바이트)");
    println!("  역참조: *heap_value = {}", *heap_value);

    // [3] 자동 역참조 (Deref 트레이트)
    struct Point {
        x: i32,
        y: i32,
    }

    let boxed_point = Box::new(Point { x: 10, y: 20 });
    println!("\n자동 역참조:");
    println!("  boxed_point.x = {} (수동 *boxed_point.x 불필요)", boxed_point.x);
    println!("  boxed_point.y = {}", boxed_point.y);

    // [4] 스코프를 벗어나면 자동 해제
    println!("\n메모리 안전성:");
    {
        let temporary = Box::new(vec![1, 2, 3, 4, 5]);
        println!("  임시 벡터 생성: 힙에 할당됨");
    }  // 여기서 자동으로 힙 메모리 해제
    println!("  스코프 벗어남: 자동 해제 (메모리 누수 불가능)");
}

