// [v9.0: 메모리 안전성] RAII 패턴
// ============================================================================

struct Resource {
    id: usize,
}

impl Resource {
    fn new(id: usize) -> Self {
        println!("  리소스 {} 생성 (힙에 할당)", id);
        Self { id }
    }
}

impl Drop for Resource {
    fn drop(&mut self) {
        println!("  리소스 {} 해제 (힙 메모리 정리)", self.id);
    }
}

fn demo_raii_pattern() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║     [Demo 5] 메모리 안전성: RAII 패턴 (자동 정리)            ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    println!("RAII (Resource Acquisition Is Initialization):");
    println!("리소스는 객체 생성 시 획득하고, 스코프를 벗어날 때 자동 정리됩니다.\n");

    println!("실행 순서:");
    {
        let r1 = Box::new(Resource::new(1));
        println!("  r1 생성 완료\n");

        {
            let r2 = Box::new(Resource::new(2));
            println!("  r2 생성 완료\n");
        }  // r2 스코프 벗어남 → 자동 해제
        println!("  r2 스코프 벗어남\n");

        let r3 = Box::new(Resource::new(3));
        println!("  r3 생성 완료\n");
    }  // r1, r3 스코프 벗어남 → 자동 해제
    println!("  모든 스코프 벗어남");

    println!("\n✅ 메모리 누수 불가능 - 완벽한 안전성!");
}

