// [v9.0: 성능 최적화] 거대한 데이터의 효율적 이동
// ============================================================================

struct HugeDataset {
    samples: Vec<f64>,
    metadata: String,
}

impl HugeDataset {
    fn new(size: usize) -> Self {
        Self {
            samples: vec![0.0; size],
            metadata: format!("Dataset with {} samples", size),
        }
    }

    fn average(&self) -> f64 {
        if self.samples.is_empty() {
            0.0
        } else {
            self.samples.iter().sum::<f64>() / self.samples.len() as f64
        }
    }

    fn size_in_bytes(&self) -> usize {
        self.samples.len() * 8 + self.metadata.len()
    }
}

/// Box를 사용하지 않은 비효율적 함수
fn process_dataset_inefficient(dataset: HugeDataset) -> f64 {
    // 수백만 바이트가 스택에 복사됨!
    dataset.average()
}

/// Box를 사용한 효율적 함수
fn process_dataset_efficient(dataset: Box<HugeDataset>) -> f64 {
    // 8바이트 포인터만 이동!
    dataset.average()
}

fn demo_performance_optimization() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║        [Demo 4] 성능 최적화: 거대 데이터의 효율적 이동       ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    let dataset = HugeDataset::new(1_000_000);
    println!("생성된 데이터셋:");
    println!("  크기: {} 바이트 ({:.1} MB)",
        dataset.size_in_bytes(),
        dataset.size_in_bytes() as f64 / 1_000_000.0);
    println!("  평균값: {:.2}", dataset.average());

    // [1] Box 없이: 복사 (비효율적)
    println!("\n❌ Box 없이 함수 호출:");
    println!("  process_dataset_inefficient(dataset)");
    println!("  → {} MB 데이터가 스택에 복사됨!", dataset.size_in_bytes() / 1_000_000);

    // [2] Box 사용: 포인터만 이동 (효율적)
    println!("\n✅ Box 사용하여 함수 호출:");
    let boxed = Box::new(HugeDataset::new(1_000_000));
    println!("  process_dataset_efficient(boxed)");
    println!("  → 8 바이트 포인터만 이동!");
    println!("  결과: {:.2}", process_dataset_efficient(boxed));
}

