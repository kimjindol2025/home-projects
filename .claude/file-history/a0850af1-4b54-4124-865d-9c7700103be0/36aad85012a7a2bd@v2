#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_box_basic() {
        let boxed = Box::new(42);
        assert_eq!(*boxed, 42);
    }

    #[test]
    fn test_gogs_node_list() {
        let list = GogsNode::Data(1, Box::new(GogsNode::Data(2, Box::new(GogsNode::Nil))));
        assert_eq!(list.head(), Some(1));
        assert_eq!(list.len(), 2);
        assert_eq!(list.sum(), 3);
    }

    #[test]
    fn test_tree_node() {
        let tree = TreeNode::new(10).add_left(TreeNode::new(5)).add_right(TreeNode::new(15));
        assert_eq!(tree.height(), 2);
        assert_eq!(tree.node_count(), 3);
    }

    #[test]
    fn test_stack() {
        let mut stack: Stack<i32> = Stack::new();
        stack.push(1);
        stack.push(2);
        assert_eq!(stack.size(), 2);
        assert_eq!(stack.pop(), Some(2));
        assert_eq!(stack.size(), 1);
    }
}
