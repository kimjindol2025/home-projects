// ============================================================================

/// 제네릭 스택 구조
struct Stack<T> {
    items: Vec<Box<T>>,
}

impl<T> Stack<T> {
    fn new() -> Self {
        Self { items: Vec::new() }
    }

    fn push(&mut self, item: T) {
        self.items.push(Box::new(item));
    }

    fn pop(&mut self) -> Option<T> {
        self.items.pop().map(|boxed| *boxed)
    }

    fn peek(&self) -> Option<&T> {
        self.items.last().map(|boxed| &**boxed)
    }

    fn size(&self) -> usize {
        self.items.len()
    }
}

fn demo_generic_with_box() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║          [Demo 6] 제네릭 + Box: 범용 스택 구조               ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    // [1] 정수 스택
    let mut int_stack: Stack<i32> = Stack::new();
    int_stack.push(10);
    int_stack.push(20);
    int_stack.push(30);

    println!("정수 스택:");
    println!("  크기: {}", int_stack.size());
    println!("  peek: {:?}", int_stack.peek());
    println!("  pop: {:?}", int_stack.pop());
    println!("  새 크기: {}", int_stack.size());

    // [2] 문자열 스택
    let mut string_stack: Stack<String> = Stack::new();
    string_stack.push("hello".to_string());
    string_stack.push("world".to_string());

    println!("\n문자열 스택:");
    println!("  크기: {}", string_stack.size());
    println!("  peek: {:?}", string_stack.peek());
    println!("  pop: {:?}", string_stack.pop());
}

