/// Gogs Node: 크기가 미정인 재귀적 연결 리스트
///
/// Box가 없다면 컴파일러는 GogsNode의 크기를 계산할 수 없어 에러를 냅니다.
/// Box를 사용하여 다음 노드의 주소(고정 크기)만 가짐으로써 문제를 해결합니다.
#[derive(Debug)]
enum GogsNode {
    /// 데이터와 다음 노드를 가진 노드
    /// 다음 노드는 Box<T>로 감싸져 고정 크기(8바이트)
    Data(i32, Box<GogsNode>),
    /// 리스트의 끝
    Nil,
}

impl GogsNode {
    /// 새로운 리스트를 생성합니다.
    fn new(value: i32, next: GogsNode) -> Self {
        GogsNode::Data(value, Box::new(next))
    }

    /// 리스트의 맨 처음 값을 반환합니다.
    fn head(&self) -> Option<i32> {
        match self {
            GogsNode::Data(val, _) => Some(*val),
            GogsNode::Nil => None,
        }
    }

    /// 리스트의 나머지 부분을 반환합니다.
    fn tail(&self) -> Option<&GogsNode> {
        match self {
            GogsNode::Data(_, next) => Some(next),
            GogsNode::Nil => None,
        }
    }

    /// 리스트의 길이를 계산합니다.
    fn len(&self) -> usize {
        match self {
            GogsNode::Data(_, next) => 1 + next.len(),
            GogsNode::Nil => 0,
        }
    }

    /// 리스트의 합을 계산합니다.
    fn sum(&self) -> i32 {
        match self {
            GogsNode::Data(val, next) => val + next.sum(),
            GogsNode::Nil => 0,
        }
    }

    /// 리스트의 모든 값을 보기 좋게 출력합니다.
    fn print_values(&self) {
        match self {
            GogsNode::Data(val, next) => {
                print!("{}", val);
                match **next {
                    GogsNode::Nil => println!(),
                    _ => {
                        print!(" -> ");
                        next.print_values();
                    }
                }
            }
            GogsNode::Nil => println!("(끝)"),
        }
    }
}

fn demo_recursive_list() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║      [Demo 2] 재귀적 연결 리스트 (Recursive Cons List)       ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    // [1] Box 없이는 불가능 - 컴파일 에러!
    println!("❌ Box 없이 재귀적 enum 시도");
    println!("   enum GogsNode {{");
    println!("       Data(i32, GogsNode),  // 무한 크기!");
    println!("   }}");
    println!("   에러: cannot contain itself\n");

    // [2] Box로 해결
    println!("✅ Box로 해결");
    println!("   enum GogsNode {{");
    println!("       Data(i32, Box<GogsNode>),  // 고정 8바이트!");
    println!("   }}\n");

    // [3] 연결 리스트 생성
    let list = GogsNode::Data(
        1,
        Box::new(GogsNode::Data(
            2,
            Box::new(GogsNode::Data(
                3,
                Box::new(GogsNode::Data(
                    4,
                    Box::new(GogsNode::Nil),
                )),
            )),
        )),
    );

    println!("생성된 리스트: 1 -> 2 -> 3 -> 4 -> (끝)");
    println!("구조: {:?}", list);

    // [4] 메서드 활용
    println!("\n리스트 분석:");
    println!("  head(): {:?}", list.head());
    println!("  length: {}", list.len());
    println!("  sum: {}", list.sum());
    println!("  values: ");
    print!("    ");
    list.print_values();

    // [5] tail() 활용
    println!("\n리스트 순회:");
    println!("  첫 번째: {:?}", list.head());
    if let Some(tail1) = list.tail() {
        println!("  두 번째: {:?}", tail1.head());
        if let Some(tail2) = tail1.tail() {
            println!("  세 번째: {:?}", tail2.head());
        }
    }
}

