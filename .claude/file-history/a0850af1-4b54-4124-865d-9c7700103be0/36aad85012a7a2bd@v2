/// 이진 트리 노드
#[derive(Debug)]
struct TreeNode<T> {
    value: T,
    left: Option<Box<TreeNode<T>>>,
    right: Option<Box<TreeNode<T>>>,
}

impl<T: fmt::Display> TreeNode<T> {
    fn new(value: T) -> Self {
        Self {
            value,
            left: None,
            right: None,
        }
    }

    fn add_left(mut self, node: TreeNode<T>) -> Self {
        self.left = Some(Box::new(node));
        self
    }

    fn add_right(mut self, node: TreeNode<T>) -> Self {
        self.right = Some(Box::new(node));
        self
    }

    /// 트리를 중위 순회(Inorder)로 출력
    fn inorder(&self) {
        if let Some(left) = &self.left {
            left.inorder();
        }
        print!("{} ", self.value);
        if let Some(right) = &self.right {
            right.inorder();
        }
    }

    /// 트리의 높이를 계산
    fn height(&self) -> usize {
        let left_height = self.left.as_ref().map(|n| n.height()).unwrap_or(0);
        let right_height = self.right.as_ref().map(|n| n.height()).unwrap_or(0);
        1 + left_height.max(right_height)
    }

    /// 트리의 모든 노드 수를 계산
    fn node_count(&self) -> usize {
        let left_count = self.left.as_ref().map(|n| n.node_count()).unwrap_or(0);
        let right_count = self.right.as_ref().map(|n| n.node_count()).unwrap_or(0);
        1 + left_count + right_count
    }
}

fn demo_binary_tree() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║              [Demo 3] 이진 트리 (Binary Tree)                 ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    // [1] 트리 구조 생성
    //         10
    //        /  \
    //       5    15
    //      / \
    //     3   7

    let tree = TreeNode::new(10)
        .add_left(
            TreeNode::new(5)
                .add_left(TreeNode::new(3))
                .add_right(TreeNode::new(7)),
        )
        .add_right(TreeNode::new(15));

    println!("트리 구조:");
    println!("         10");
    println!("        /  \\");
    println!("       5    15");
    println!("      / \\");
    println!("     3   7\n");

    // [2] 트리 분석
    println!("트리 분석:");
    println!("  높이(height): {}", tree.height());
    println!("  노드 수: {}", tree.node_count());
    print!("  중위 순회(inorder): ");
    tree.inorder();
    println!();

    // [3] 트리 자체가 Box로 감싸지지 않아도 가능한 이유
    println!("\n메모리 구조:");
    println!("  TreeNode = value(4) + left(8) + right(8) = 20 바이트");
    println!("  left/right: Option<Box<TreeNode>> = 8 바이트 (포인터)");
    println!("  따라서 크기가 고정되어 컴파일 가능!");
}

