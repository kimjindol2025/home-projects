def divide_lbyl(a, b):
    """LBYL: 먼저 확인"""
    if not isinstance(a, (int, float)):
        print("  ❌ a는 숫자여야 합니다")
        return None

    if not isinstance(b, (int, float)):
        print("  ❌ b는 숫자여야 합니다")
        return None

    if b == 0:
        print("  ❌ 0으로 나눌 수 없습니다")
        return None

    result = a / b
    print(f"  ✅ 결과: {result}")
    return result

divide_lbyl(10, 2)
divide_lbyl(10, 0)

print()
print("✅ EAFP 방식:")
print()

def divide_eafp(a, b):
    """EAFP: 먼저 시도"""
    try:
        result = a / b
        print(f"  ✅ 결과: {result}")
        return result
    except TypeError:
        print("  ❌ 숫자가 아닙니다")
        return None
    except ZeroDivisionError:
        print("  ❌ 0으로 나눌 수 없습니다")
        return None

