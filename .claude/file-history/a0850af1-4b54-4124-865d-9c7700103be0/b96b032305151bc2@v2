// [제1장: 존재의 시작] v1.0 - 출력과 연산
// ============================================================================
// 철학: 언어의 첫 울음소리는 세상과의 대화입니다.
//       이 단계에서 우리는 표준 출력(stdout)에 메시지를 전달하고,
//       CPU의 계산 능력을 인간이 읽을 수 있는 형태로 번역합니다.
// ============================================================================

fn main() {
    // 1단계: 존재 알리기 - 시스템이 활성화되었음을 선언
    println!("════════════════════════════════════════════════════════════");
    println!("v1.0: System Online - 언어가 존재를 알린다");
    println!("════════════════════════════════════════════════════════════");
    println!();

    // 2단계: 기초 산술 연산 (덧셈)
    {
        let sum = 10 + 20;
        println!("✓ 덧셈 연산: 10 + 20 = {}", sum);
    }

    // 3단계: 기초 산술 연산 (뺄셈)
    {
        let diff = 100 - 35;
        println!("✓ 뺄셈 연산: 100 - 35 = {}", diff);
    }

    // 4단계: 기초 산술 연산 (곱셈)
    {
        let product = 7 * 8;
        println!("✓ 곱셈 연산: 7 * 8 = {}", product);
    }

    // 5단계: 기초 산술 연산 (나눗셈)
    {
        let quotient = 144 / 12;
        println!("✓ 나눗셈 연산: 144 / 12 = {}", quotient);
    }

    // 6단계: 복합 연산
    {
        let complex = (5 + 3) * (10 - 2);
        println!("✓ 복합 연산: (5 + 3) * (10 - 2) = {}", complex);
    }

    println!();
    println!("════════════════════════════════════════════════════════════");
    println!("v1.0 검증 완료: 출력과 연산의 기초 공사가 마쳐졌습니다.");
    println!("════════════════════════════════════════════════════════════");
}
