"""
Python v1.1 - 리스트의 메모리 할당 전략

증명 과제: "파이썬의 리스트는 연결 리스트가 아니라 가변 배열이다.
데이터가 늘어날 때 메모리 할당이 어떻게 일어나는지 sys.getsizeof()로 증명한다."

동적 배열의 성능 특성:
- O(1) 접근 (배열 기반)
- O(n) 삽입/삭제 (데이터 이동 필요)
- O(1) 평균 추가 (amortized)
- 메모리 오버헤드 (미리 할당된 용량)
"""

import sys
from typing import List, Tuple


# ============================================================================
# [탐구] 리스트 용량(Capacity)의 성장 패턴
# ============================================================================

def analyze_list_growth() -> Tuple[List[int], List[int], List[int]]:
    """
    빈 리스트에서 시작해 요소를 하나씩 추가하면서
    메모리 할당이 어떻게 변하는지 추적합니다.

    Returns:
        (요소 개수, 메모리 크기, 용량)의 리스트 3개
    """

    print("\n" + "="*70)
    print("# [탐구] 리스트 메모리 할당 패턴")
    print("="*70)

    sizes = []      # sys.getsizeof() 값
    counts = []     # 요소 개수
    capacities = [] # 추정 용량

    lst = []

    # 100개 요소 추가 시 메모리 변화 기록
    print(f"\n{'요소 개수':>6} | {'메모리(bytes)':>12} | {'추정 용량':>10} | 변화")
    print("-" * 70)

    prev_size = sys.getsizeof(lst)
    for i in range(100):
        lst.append(i)
        current_size = sys.getsizeof(lst)

        # 메모리 할당이 일어났는지 확인
        change = "🔴 할당" if current_size > prev_size else ""

        # 용량 추정 (PyObject 헤더 크기 제외)
        # 리스트 크기 = 56(헤더) + 8(포인터) * 용량
        estimated_capacity = max(0, (current_size - 56) // 8)

        if i < 20 or i % 10 == 0:  # 처음 20개와 10의 배수만 출력
            print(
                f"{i+1:6d} | {current_size:12d} | {estimated_capacity:10d} | {change}"
            )

        counts.append(i + 1)
        sizes.append(current_size)
        capacities.append(estimated_capacity)

        prev_size = current_size

    return counts, sizes, capacities


# ============================================================================
# [분석] 과할당(Over-allocation) 전략
# ============================================================================

def analyze_overallocation(counts: List[int], sizes: List[int]) -> None:
    """
    파이썬의 과할당 전략을 분석합니다.
    """

    print("\n" + "="*70)
    print("# [분석] 과할당 패턴 (Over-allocation)")
    print("="*70)

    # 메모리 할당이 일어난 지점 찾기
    allocation_points = []
    prev_size = sizes[0]

    for i, size in enumerate(sizes):
        if size > prev_size:
            allocation_points.append(i + 1)
            prev_size = size

    print(f"\n메모리 재할당이 일어난 위치:")
    print(f"  요소 개수: {allocation_points[:20]}")  # 처음 20개만 출력
    print(f"  패턴 분석:")

    # 할당 간격 분석
    if len(allocation_points) > 1:
        intervals = []
        for i in range(1, min(len(allocation_points), 10)):
            interval = allocation_points[i] - allocation_points[i-1]
            intervals.append(interval)
            print(f"    {allocation_points[i-1]} → {allocation_points[i]}: +{interval}개")

        # 성장 비율 추정
        if intervals:
            avg_growth = sum(intervals) / len(intervals)
            print(f"\n  평균 성장률: 약 {avg_growth:.1f}배")


# ============================================================================
# [증명] 리스트 vs 튜플의 메모리 차이
# ============================================================================

def compare_list_vs_tuple() -> None:
    """
    리스트(변경 가능)와 튜플(불변)의 메모리 구조 비교
    """

    print("\n" + "="*70)
    print("# [증명] 리스트 vs 튜플 - 메모리 구조")
    print("="*70)

    data = list(range(10))
    tuple_data = tuple(range(10))

    print(f"\n리스트:  {data}")
    print(f"  메모리: {sys.getsizeof(data)} bytes")
    print(f"  용도:   변경 가능, 동적 크기")

    print(f"\n튜플:   {tuple_data}")
    print(f"  메모리: {sys.getsizeof(tuple_data)} bytes")
    print(f"  용도:   불변, 고정 크기")

    print(f"\n[차이 분석]")
    print(f"  리스트는 미래의 확장을 위해 용량을 미리 할당한다.")
    print(f"  튜플은 고정 크기이므로 정확한 메모리만 할당한다.")
    print(f"  리스트가 튜플보다 {sys.getsizeof(data) - sys.getsizeof(tuple_data)} bytes 더 크다.")


# ============================================================================
# [탐구] 복합 객체의 메모리 계산
# ============================================================================

def analyze_nested_structures() -> None:
    """
    리스트 안의 객체들이 어떻게 메모리를 차지하는지 분석
    """

    print("\n" + "="*70)
    print("# [탐구] 중첩 구조의 메모리")
    print("="*70)

    # 빈 리스트
    empty_list = []
    print(f"\n빈 리스트: []")
    print(f"  메모리: {sys.getsizeof(empty_list)} bytes")

    # 정수 리스트
    int_list = [1, 2, 3, 4, 5]
    print(f"\n정수 리스트: {int_list}")
    print(f"  리스트 자체: {sys.getsizeof(int_list)} bytes")
    print(f"  각 정수 크기:")
    for num in int_list:
        print(f"    {num}: {sys.getsizeof(num)} bytes")

    # 문자열 리스트
    str_list = ["apple", "banana", "cherry"]
    print(f"\n문자열 리스트: {str_list}")
    print(f"  리스트 자체: {sys.getsizeof(str_list)} bytes")
    print(f"  각 문자열 크기:")
    for s in str_list:
        print(f"    '{s}': {sys.getsizeof(s)} bytes")

    # 중첩 리스트
    nested = [[1, 2], [3, 4], [5, 6]]
    print(f"\n중첩 리스트: {nested}")
    print(f"  외부 리스트: {sys.getsizeof(nested)} bytes")
    print(f"  내부 리스트들:")
    for sublist in nested:
        print(f"    {sublist}: {sys.getsizeof(sublist)} bytes")

    print(f"\n[결론]")
    print(f"  리스트의 메모리 = 리스트 구조 + 포인터 배열")
    print(f"  객체 자체의 메모리는 따로 계산된다.")
    print(f"  sys.getsizeof()는 객체 자신만 계산하고,")
    print(f"  참조하는 객체의 메모리는 포함하지 않는다.")


# ============================================================================
# [증명] 리스트의 참조 구조
# ============================================================================

def analyze_reference_structure() -> None:
    """
    리스트와 그 요소들의 참조 관계를 시각화
    """

    print("\n" + "="*70)
    print("# [증명] 리스트의 참조 구조")
    print("="*70)

    obj = 42
    lst = [obj, obj, obj]  # 같은 객체를 3번 참조

    print(f"\nobj = {obj}")
    print(f"lst = [obj, obj, obj]")
    print(f"\n참조 관계:")
    print(f"  obj의 메모리 주소: {hex(id(obj))}")
    print(f"  lst[0] 메모리 주소: {hex(id(lst[0]))}")
    print(f"  lst[1] 메모리 주소: {hex(id(lst[1]))}")
    print(f"  lst[2] 메모리 주소: {hex(id(lst[2]))}")

    print(f"\n[증명]")
    print(f"  lst[0] is obj: {lst[0] is obj}")
    print(f"  lst[1] is obj: {lst[1] is obj}")
    print(f"  lst[2] is obj: {lst[2] is obj}")

    print(f"\n[결론]")
    print(f"  리스트의 각 요소는 실제 객체를 가리키는 포인터다.")
    print(f"  같은 객체를 여러 번 참조할 수 있다.")
    print(f"  따라서 obj의 참조 카운트가 증가한다.")
    print(f"  obj의 참조 카운트: {sys.getrefcount(obj) - 1}")


# ============================================================================
# 메인 실행
# ============================================================================

if __name__ == "__main__":
    # 1. 리스트 성장 패턴 분석
    counts, sizes, capacities = analyze_list_growth()

    # 2. 과할당 패턴 분석
    analyze_overallocation(counts, sizes)

    # 3. 리스트 vs 튜플
    compare_list_vs_tuple()

    # 4. 중첩 구조 분석
    analyze_nested_structures()

    # 5. 참조 구조 분석
    analyze_reference_structure()

    # 최종 결론
    print("\n" + "="*70)
    print("# [최종 증명] 동적 배열의 메모리 무결성")
    print("="*70)

    print("""
✓ [동적 배열의 구조]
  파이썬의 리스트는 고정 크기 배열 기반이다.
