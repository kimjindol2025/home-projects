#!/usr/bin/env python3
# -*- coding: utf-8 -*-

"""
🏛️ v6.1: 학생관리 시스템 리팩토링 (Design Patterns 적용)

기존 시스템을 디자인 패턴으로 개선:
- 싱글톤: SystemLogger, ConfigManager
- 팩토리: StudentRepository, ReportGenerator
- 느슨한 결합: 의존성 역전
"""

from abc import ABC, abstractmethod
from datetime import datetime
from typing import Dict, List, Optional
import json
from v6_1_design_patterns import (
    SystemLogger, ConfigManager, DataSourceFactory,
    ReportFactory, DataSource
)


# ==================== 저장소 패턴 ====================

class StudentRepository(ABC):
    """학생 데이터 저장소 추상 클래스"""

    @abstractmethod
    def add_student(self, data: Dict) -> bool:
        pass

    @abstractmethod
    def get_all_students(self) -> List[Dict]:
        pass

    @abstractmethod
    def get_student(self, student_id: int) -> Optional[Dict]:
        pass

    @abstractmethod
    def update_student(self, student_id: int, data: Dict) -> bool:
        pass


class DatabaseStudentRepository(StudentRepository):
    """데이터베이스 기반 학생 저장소"""

    def __init__(self, data_source: DataSource):
        self.data_source = data_source
        self.logger = SystemLogger()
        self.config = ConfigManager()

    def add_student(self, data: Dict) -> bool:
        try:
            self.logger.log('INFO', f"학생 추가: {data['name']}")
            self.data_source.write(json.dumps(data))
            return True
        except Exception as e:
            self.logger.log('ERROR', f"학생 추가 실패: {str(e)}")
            return False

    def get_all_students(self) -> List[Dict]:
        self.logger.log('INFO', "모든 학생 조회")
        return [
            {'id': 1, 'name': '김학생', 'dept': '컴퓨터과학과'},
            {'id': 2, 'name': '이학생', 'dept': '데이터과학과'},
            {'id': 3, 'name': '박학생', 'dept': '소프트웨어공학과'},
        ]

    def get_student(self, student_id: int) -> Optional[Dict]:
        students = self.get_all_students()
        for student in students:
            if student['id'] == student_id:
                self.logger.log('INFO', f"학생 조회: ID {student_id}")
                return student
        self.logger.log('WARNING', f"학생을 찾을 수 없음: ID {student_id}")
        return None

    def update_student(self, student_id: int, data: Dict) -> bool:
        try:
            self.logger.log('INFO', f"학생 수정: ID {student_id}")
            self.data_source.write(json.dumps(data))
            return True
        except Exception as e:
            self.logger.log('ERROR', f"학생 수정 실패: {str(e)}")
            return False


class CSVStudentRepository(StudentRepository):
    """CSV 기반 학생 저장소"""

    def __init__(self, data_source: DataSource):
        self.data_source = data_source
        self.logger = SystemLogger()

    def add_student(self, data: Dict) -> bool:
        try:
            self.logger.log('INFO', f"[CSV] 학생 추가: {data['name']}")
            self.data_source.write(json.dumps(data))
            return True
        except Exception as e:
            self.logger.log('ERROR', f"[CSV] 학생 추가 실패: {str(e)}")
            return False

    def get_all_students(self) -> List[Dict]:
        self.logger.log('INFO', "[CSV] 모든 학생 조회")
        return []

    def get_student(self, student_id: int) -> Optional[Dict]:
        self.logger.log('INFO', f"[CSV] 학생 조회: ID {student_id}")
        return None

    def update_student(self, student_id: int, data: Dict) -> bool:
        try:
            self.logger.log('INFO', f"[CSV] 학생 수정: ID {student_id}")
            return True
        except Exception as e:
            self.logger.log('ERROR', f"[CSV] 학생 수정 실패: {str(e)}")
            return False


class RepositoryFactory:
    """저장소 생성 팩토리"""

    _repositories: Dict[str, type] = {
        'database': DatabaseStudentRepository,
        'csv': CSVStudentRepository,
    }

    @classmethod
    def create(cls, repo_type: str, data_source: DataSource) -> Optional[StudentRepository]:
        """저장소 생성"""
        repo_class = cls._repositories.get(repo_type.lower())
        if repo_class:
            return repo_class(data_source)
        return None

    @classmethod
    def list_types(cls) -> List[str]:
        """지원하는 저장소 타입"""
        return list(cls._repositories.keys())


# ==================== 비즈니스 로직 ====================

class StudentManagementService:
    """
    학생 관리 서비스

    싱글톤 로거와 설정, 팩토리 패턴의 저장소를 사용
    """

    def __init__(self, repository: StudentRepository):
        self.repository = repository
        self.logger = SystemLogger()
        self.config = ConfigManager()

    def register_student(self, name: str, dept: str, email: str) -> bool:
        """학생 등록"""
        student_data = {
            'name': name,
            'dept': dept,
            'email': email,
            'timestamp': datetime.now().isoformat()
        }

        if self.repository.add_student(student_data):
            self.logger.log('SUCCESS', f"학생 등록 성공: {name}")
            return True
        else:
            self.logger.log('ERROR', f"학생 등록 실패: {name}")
            return False

    def get_student_info(self, student_id: int) -> Optional[Dict]:
        """학생 정보 조회"""
        return self.repository.get_student(student_id)

    def list_all_students(self) -> List[Dict]:
        """모든 학생 조회"""
        return self.repository.get_all_students()

    def generate_report(self, format_type: str) -> str:
        """리포트 생성"""
        students = self.list_all_students()
        data = {
            'total_students': len(students),
            'timestamp': datetime.now().isoformat(),
            'students': students
        }

        report_factory = ReportFactory()
        report = report_factory.create(format_type)

        if report:
            self.logger.log('SUCCESS', f"{format_type.upper()} 리포트 생성")
            return report.generate(data)
        else:
            self.logger.log('ERROR', f"알 수 없는 리포트 형식: {format_type}")
            return ""


