### 패턴 3️⃣: Rc<T> vs Arc<T> 비교

```rust
use std::rc::Rc;
use std::sync::Arc;
use std::thread;

// Rc<T>: 비원자적 참조 카운트
// ├─ !Send: 스레드로 이동 불가능
// └─ !Sync: 스레드에서 공유 불가능

// Arc<T>: 원자적 참조 카운트
// ├─ Send: 스레드로 이동 가능
// └─ Sync: 스레드에서 공유 가능

fn compare_rc_and_arc() {
    // Rc 사용 (단일 스레드)
    let rc_single = Rc::new(vec![1, 2, 3]);
    let rc_clone = Rc::clone(&rc_single);  // ✅ 안전

    // Arc 사용 (멀티 스레드)
    let arc_multi = Arc::new(vec![1, 2, 3]);
    let arc_clone = Arc::clone(&arc_multi);
    thread::spawn(move || {
        println!("{:?}", arc_clone);  // ✅ 안전
    }).join().unwrap();
}
```

---

### 패턴 4️⃣: Mutex<T>의 Send/Sync 특성

```rust
use std::sync::Mutex;
use std::thread;

// Mutex<T>: T가 Send라면
// ├─ Mutex<T>는 Send + Sync
// └─ 여러 스레드에서 안전하게 공유 가능

fn demo_mutex_send_sync() {
    let counter = Mutex::new(0);

    thread::spawn(|| {
        let mut num = counter.lock().unwrap();
        *num += 1;
        println!("스레드 1: {}", *num);
    });

    thread::spawn(|| {
        let mut num = counter.lock().unwrap();
        *num += 1;
        println!("스레드 2: {}", *num);
    });
}
```

