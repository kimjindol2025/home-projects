// [2] 복합 패턴 작성 시
// 단순한 것부터 시작해서 복잡한 것으로 진행
macro_rules! foo {
    () => { /* ... */ };           // 1. 빈 경우
    ($a:expr) => { /* ... */ };    // 2. 단일
    ($a:expr, $b:expr) => { /* */ }; // 3. 쌍
    ($($a:expr),*) => { /* ... */ }; // 4. 가변
}

// [3] 에러 메시지 커스터마이징
