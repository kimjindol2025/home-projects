{% extends "base.html" %}

{% block title %}학생 목록 - 학생관리 시스템{% endblock %}

{% block content %}
<div class="students-page">
    <h1 class="page-title">👥 학생 목록</h1>

    <div class="page-header">
        <div class="info-text">
            총 <strong>{{ students|length }}</strong>명의 학생
        </div>
        <a href="/add-student" class="btn btn-primary">+ 새 학생 추가</a>
    </div>

    {% if students %}
    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th>학번</th>
                    <th>이름</th>
                    <th>학과</th>
                    <th>학년</th>
                    <th>이메일</th>
                    <th>작업</th>
                </tr>
            </thead>
            <tbody>
                {% for student in students %}
                <tr class="table-row">
                    <td class="cell-no">{{ student.student_no }}</td>
                    <td class="cell-name"><strong>{{ student.name }}</strong></td>
                    <td class="cell-dept">{{ student.dept_name }}</td>
                    <td class="cell-year">{{ student.year }}학년</td>
                    <td class="cell-email">{{ student.email }}</td>
                    <td class="cell-action">
                        <a href="/student/{{ student.student_id }}" class="btn-small btn-info">상세보기</a>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <!-- 학과별 그룹 -->
    <div class="department-stats">
        <h2>🏢 학과별 학생 수</h2>
        <div class="dept-grid">
            <div class="dept-card">
                <h3>컴퓨터과학과</h3>
                <p class="dept-count">
                    {% set cs_count = students|selectattr('dept_name', 'equalto', '컴퓨터과학과')|list|length %}
                    {{ cs_count }}명
                </p>
            </div>
            <div class="dept-card">
                <h3>데이터과학과</h3>
                <p class="dept-count">
                    {% set ds_count = students|selectattr('dept_name', 'equalto', '데이터과학과')|list|length %}
                    {{ ds_count }}명
                </p>
            </div>
            <div class="dept-card">
                <h3>소프트웨어공학과</h3>
                <p class="dept-count">
                    {% set se_count = students|selectattr('dept_name', 'equalto', '소프트웨어공학과')|list|length %}
                    {{ se_count }}명
                </p>
            </div>
        </div>
    </div>

    {% else %}
    <div class="empty-state">
        <p>등록된 학생이 없습니다.</p>
        <a href="/add-student" class="btn btn-primary">첫 번째 학생 추가하기</a>
    </div>
    {% endif %}
</div>
{% endblock %}
