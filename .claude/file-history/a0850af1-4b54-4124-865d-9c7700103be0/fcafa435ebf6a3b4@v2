#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_allocate_basic() {
        let mut gc = GarbageCollector::new(1000);
        let idx = gc.allocate(ObjectType::Integer);

        assert_eq!(gc.heap.object_count(), 1);
        assert_eq!(gc.heap.allocated_bytes, 8);
        assert_eq!(idx, 0);
    }

    #[test]
    fn test_mark_from_stack() {
        let mut gc = GarbageCollector::new(1000);

        let obj = gc.allocate(ObjectType::Integer);
        gc.push_stack(obj);

        let roots = gc.roots.clone();
        gc.mark(&roots);

        assert!(gc.heap.objects[obj].header.is_marked);
    }

    #[test]
    fn test_mark_array_references() {
        let mut gc = GarbageCollector::new(1000);

        let obj_a = gc.allocate(ObjectType::Integer);
        let obj_b = gc.allocate(ObjectType::Integer);
        let obj_array = gc.allocate(ObjectType::Array(vec![obj_a, obj_b]));

        gc.push_stack(obj_array);

        let roots = gc.roots.clone();
        gc.mark(&roots);

        assert!(gc.heap.objects[obj_array].header.is_marked);
        assert!(gc.heap.objects[obj_a].header.is_marked);
        assert!(gc.heap.objects[obj_b].header.is_marked);
    }

    #[test]
    fn test_sweep_removes_unmarked() {
        let mut gc = GarbageCollector::new(1000);

        let obj0 = gc.allocate(ObjectType::Integer);
        let obj1 = gc.allocate(ObjectType::Integer);
        let obj2 = gc.allocate(ObjectType::Integer);

        gc.push_stack(obj0);

        let roots = gc.roots.clone();
        gc.mark(&roots);
        let stats = gc.sweep();

        assert_eq!(stats.freed_count, 2);
        assert_eq!(gc.heap.object_count(), 1);
    }

    #[test]
    fn test_gc_threshold_trigger() {
        let mut gc = GarbageCollector::new(10);  // 10 bytes 임계값

        let obj0 = gc.allocate(ObjectType::Integer);  // 8 bytes
        gc.push_stack(obj0);

        assert!(!gc.should_collect_garbage());  // 아직 미달

        let obj1 = gc.allocate(ObjectType::Integer);  // 8+8 = 16 bytes
        assert!(gc.should_collect_garbage());  // 이제 초과!
    }

    #[test]
    fn test_circular_reference() {
        let mut gc = GarbageCollector::new(1000);

        let obj_a = gc.allocate(ObjectType::Integer);
        let obj_b = gc.allocate(ObjectType::Array(vec![obj_a]));

        // 실제로는 obj_a도 obj_b를 참조하지만, 여기서는 한 방향만 테스트
        gc.push_stack(obj_b);

        let roots = gc.roots.clone();
        gc.mark(&roots);

        // 무한 루프가 없어야 함
        assert!(gc.heap.objects[obj_b].header.is_marked);
    }

    #[test]
    fn test_global_and_stack() {
        let mut gc = GarbageCollector::new(1000);

        let global_obj = gc.allocate(ObjectType::Integer);
        let local_obj = gc.allocate(ObjectType::Integer);
        let garbage_obj = gc.allocate(ObjectType::Integer);

        gc.register_global(global_obj);
        gc.push_stack(local_obj);

        let roots = gc.roots.clone();
        gc.mark(&roots);
        gc.sweep();

        // 전역과 로컬은 유지, 쓰레기만 제거
        assert_eq!(gc.heap.object_count(), 2);
    }

    #[test]
    fn test_memory_tracking() {
        let mut gc = GarbageCollector::new(1000);

        let before = gc.heap.allocated_bytes;

        gc.allocate(ObjectType::Integer);
        gc.allocate(ObjectType::Boolean);

        let after = gc.heap.allocated_bytes;
        assert!(after > before);
    }

    #[test]
    fn test_gc_stats() {
        let mut gc = GarbageCollector::new(1000);

        let obj0 = gc.allocate(ObjectType::Integer);
        let obj1 = gc.allocate(ObjectType::Integer);

        gc.push_stack(obj0);

        let roots = gc.roots.clone();
        gc.mark(&roots);
        let stats = gc.sweep();

        assert_eq!(stats.freed_count, 1);
        assert_eq!(stats.kept_count, 1);
        assert!(stats.remaining_bytes > 0);
    }

    #[test]
    fn test_array_size_calculation() {
        let mut gc = GarbageCollector::new(1000);

        let arr = gc.allocate(ObjectType::Array(vec![0, 1, 2]));
        let obj = &gc.heap.objects[arr];

        // 배열 크기 = 8(헤더) + 3*8(요소)
        assert!(obj.header.size > 8);
    }

    #[test]
    fn test_empty_roots() {
        let mut gc = GarbageCollector::new(1000);

        gc.allocate(ObjectType::Integer);
        gc.allocate(ObjectType::Integer);

        // 루트가 없으면 모든 객체 제거
        let roots = gc.roots.clone();
        gc.mark(&roots);
        gc.sweep();

        assert_eq!(gc.heap.object_count(), 0);
    }
