// 메인 데모
// ============================================================================

pub fn main() {
    println!("=== Phase 14 v15.3: Garbage Collection (Mark-and-Sweep) ===\n");

    // Demo 1: 기본 할당
    println!("【Demo 1】기본 객체 할당");
    {
        let mut gc = GarbageCollector::new(100);

        let obj0 = gc.allocate(ObjectType::Integer);
        let obj1 = gc.allocate(ObjectType::Boolean);
        let obj2 = gc.allocate(ObjectType::Null);

        gc.push_stack(obj0);

        println!("  할당: {} 객체", gc.heap.object_count());
        println!("  메모리: {}", gc.heap_summary());
        println!();
    }

    // Demo 2: 참조 관계
    println!("【Demo 2】배열로 참조 관계 표현");
    {
        let mut gc = GarbageCollector::new(200);

        let obj_a = gc.allocate(ObjectType::Integer);
        let obj_b = gc.allocate(ObjectType::Integer);
        let obj_c = gc.allocate(ObjectType::Array(vec![obj_a, obj_b]));

        gc.push_stack(obj_c); // 스택: [배열] → 내부: [정수, 정수]

        println!("  배열 생성 (2개 요소 포함)");
        println!("  스택 루트: [{}]", obj_c);
        println!("  메모리: {}", gc.heap_summary());
        println!();
    }

    // Demo 3: 순환 참조
    println!("【Demo 3】순환 참조 처리 (무한 루프 방지)");
    {
        let mut gc = GarbageCollector::new(300);

        // 객체 A
        let obj_a = gc.allocate(ObjectType::Integer);
        // 객체 B (A 참조)
        let obj_b = gc.allocate(ObjectType::Array(vec![obj_a]));
        // 객체 A 업데이트 (B 참조) - 실제로는 스택에서 수정
        // → 순환: A → B → A

        gc.push_stack(obj_b);

        println!("  순환 참조: B → A → B (실제 구현에서)");
        println!("  Mark 단계: is_marked 체크로 무한 재귀 방지");
        println!("  메모리: {}", gc.heap_summary());
        println!();
    }

    // Demo 4: GC 실행 (메모리 임계값)
    println!("【Demo 4】메모리 임계값으로 GC 자동 실행");
    {
        let mut gc = GarbageCollector::new(50); // 작은 임계값

        println!("  임계값: {} bytes", gc.heap.gc_threshold);

        // 여러 객체 할당
        let obj0 = gc.allocate(ObjectType::Integer);
        let obj1 = gc.allocate(ObjectType::Integer);
        let obj2 = gc.allocate(ObjectType::Integer);

        gc.push_stack(obj0); // obj0만 참조
        // obj1, obj2는 참조 안 함

        println!("  할당 전: {} bytes", gc.heap.allocated_bytes);
        println!("  메모리 사용률: {:.1}%", gc.heap.memory_usage_percent());

        // obj2를 할당할 때 임계값 도달 시 GC 자동 실행
        let obj3 = gc.allocate(ObjectType::Integer);

        println!("  할당 후: {} bytes (GC 실행됨)", gc.heap.allocated_bytes);
        println!("  메모리: {}", gc.heap_summary());
        println!();
    }

    // Demo 5: Mark-Sweep 상세 추적
    println!("【Demo 5】Mark-Sweep 상세 과정");
    {
        let mut gc = GarbageCollector::new(1000);

        // 객체 생성
        let obj0 = gc.allocate(ObjectType::Integer); // 살아있음
        let obj1 = gc.allocate(ObjectType::Integer); // 쓰레기
        let obj2 = gc.allocate(ObjectType::Integer); // 쓰레기
        let obj3 = gc.allocate(ObjectType::Array(vec![obj0])); // 살아있음

        // 루트 설정
        gc.push_stack(obj3); // obj3만 스택에서 참조

        println!("  생성 후:");
        println!("    총 객체: {}", gc.heap.object_count());
        println!("    메모리: {} bytes", gc.heap.allocated_bytes);

        // Mark 단계
        let roots = gc.roots.clone();
        gc.mark(&roots);

        println!();
        println!("  Mark 후 (마킹된 객체):");
        for i in 0..gc.heap.object_count() {
            if gc.heap.objects[i].header.is_marked {
                println!("    객체 {}: marked ✓", i);
            }
        }

        // Sweep 단계
        let stats = gc.sweep();

        println!();
        println!("  Sweep 결과:");
        println!("    {}", stats);
        println!();
    }

    // Demo 6: 전역 변수 추적
    println!("【Demo 6】전역 변수와 로컬 변수 구분");
    {
        let mut gc = GarbageCollector::new(500);

        let global_obj = gc.allocate(ObjectType::Integer);
        let local_obj = gc.allocate(ObjectType::Integer);

        gc.register_global(global_obj);
        gc.push_stack(local_obj);

        println!("  전역: 객체 {} (영구 보존)", global_obj);
        println!("  로컬: 객체 {} (스택 기반)", local_obj);
        println!("  메모리: {}", gc.heap_summary());
        println!();
    }

    // Demo 7: 복잡한 그래프
    println!("【Demo 7】복잡한 객체 그래프");
    {
        let mut gc = GarbageCollector::new(1000);

        // 트리 구조 생성
        //     root
        //     /  \
        //    a    b
        //   / \
        //  c   d

        let obj_c = gc.allocate(ObjectType::Integer);
        let obj_d = gc.allocate(ObjectType::Integer);
        let obj_a = gc.allocate(ObjectType::Array(vec![obj_c, obj_d]));
        let obj_b = gc.allocate(ObjectType::Integer);
        let obj_root = gc.allocate(ObjectType::Array(vec![obj_a, obj_b]));

        gc.push_stack(obj_root);

        println!("  트리 구조:");
        println!("       root");
        println!("       /  \\");
        println!("      a    b");
        println!("     / \\");
        println!("    c   d");
        println!();
        println!("  메모리: {}", gc.heap_summary());
        println!();
    }

    // Demo 8: GC 통계
    println!("【Demo 8】GC 통계 및 모니터링");
    {
        let mut gc = GarbageCollector::new(100);

        println!("  초기: {}", gc.heap_summary());

        for i in 0..5 {
            let obj = gc.allocate(ObjectType::Integer);
            gc.push_stack(obj);
            println!("    할당 {}: {}", i + 1, gc.heap_summary());
        }

        println!();
    }

    println!("=== v15.3 핵심 개념 ===\n");
    println!("1. Mark-Sweep GC:");
    println!("   - Mark: 루트에서 도달 가능한 객체 표시");
    println!("   - Sweep: 미마킹 객체 제거");
    println!();
    println!("2. Root 정의:");
    println!("   - 스택의 객체 참조");
    println!("   - 전역 변수");
    println!("   - 현재 실행 프레임");
    println!();
    println!("3. 안전성:");
    println!("   - 순환 참조: is_marked로 방지");
    println!("   - 메모리 누수: 없음 (모든 객체 추적)");
    println!("   - 사용 중 해제: 없음 (루트 체크)");
    println!();
    println!("4. GC 시점:");
    println!("   - 할당 임계값 도달 시 자동 실행");
    println!("   - Stop-the-World (실행 중단)");
    println!("   - 비결정적 성능 (GC 시간)");
}

