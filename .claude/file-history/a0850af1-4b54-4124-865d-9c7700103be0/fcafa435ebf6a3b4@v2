/// Phase 14 v15.3: Garbage Collection (Mark-and-Sweep)
///
/// VM 내부에서 생성된 객체들의 생명주기를 자동으로 관리합니다.
/// Mark-and-Sweep 알고리즘으로 도달 불가능한 객체를 식별하고 해제합니다.

use std::fmt;

// ============================================================================
// 객체 타입 정의
// ============================================================================

#[derive(Debug, Clone, PartialEq, Eq)]
pub enum ObjectType {
    Integer,
    Float,
    Boolean,
    Null,
    Array(Vec<usize>),     // 다른 객체의 인덱스 목록
    String(String),
}

impl fmt::Display for ObjectType {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        match self {
            ObjectType::Integer => write!(f, "Integer"),
            ObjectType::Float => write!(f, "Float"),
            ObjectType::Boolean => write!(f, "Boolean"),
            ObjectType::Null => write!(f, "Null"),
            ObjectType::Array(indices) => write!(f, "Array(len={})", indices.len()),
            ObjectType::String(s) => write!(f, "String(\"{}\")", s),
        }
    }
}

// ============================================================================
// 객체 헤더 (메타데이터)
// ============================================================================

#[derive(Debug, Clone)]
pub struct ObjectHeader {
    pub is_marked: bool,        // GC 마킹 플래그
    pub size: usize,            // 객체 크기 (바이트 추정)
    pub obj_type: ObjectType,   // 객체 타입
    pub allocation_id: usize,   // 할당 순서 (추적용)
}

impl ObjectHeader {
    fn new(obj_type: ObjectType, size: usize, allocation_id: usize) -> Self {
        ObjectHeader {
            is_marked: false,
            size,
            obj_type,
            allocation_id,
        }
    }
}

// ============================================================================
// Heap 객체
// ============================================================================

#[derive(Debug, Clone)]
pub struct HeapObject {
    pub header: ObjectHeader,
}

// ============================================================================
// Root 정의
// ============================================================================

#[derive(Debug, Clone, Default)]
pub struct GCRoots {
    pub stack: Vec<usize>,              // 스택의 객체 인덱스
    pub globals: Vec<usize>,            // 전역 변수 인덱스
    pub current_frame: Option<usize>,   // 현재 실행 프레임
}

impl GCRoots {
    pub fn new() -> Self {
        GCRoots::default()
    }

    /// 모든 루트 객체 인덱스 반환
    pub fn all_roots(&self) -> Vec<usize> {
        let mut roots = self.stack.clone();
        roots.extend(&self.globals);
        if let Some(frame) = self.current_frame {
            roots.push(frame);
        }
        roots
    }
}

// ============================================================================
// Heap 관리자
// ============================================================================

#[derive(Debug, Clone)]
pub struct Heap {
    pub objects: Vec<HeapObject>,
    pub allocated_bytes: usize,
    pub gc_threshold: usize,         // GC 시작 임계값
    pub total_allocations: usize,    // 총 할당 횟수
    pub gc_runs: usize,              // GC 실행 횟수
}

impl Heap {
    pub fn new(gc_threshold: usize) -> Self {
        Heap {
            objects: Vec::new(),
            allocated_bytes: 0,
            gc_threshold,
            total_allocations: 0,
            gc_runs: 0,
        }
    }

    pub fn object_count(&self) -> usize {
        self.objects.len()
    }

    pub fn memory_usage_percent(&self) -> f64 {
        (self.allocated_bytes as f64 / self.gc_threshold as f64) * 100.0
    }
}

// ============================================================================
// GC 통계
// ============================================================================

#[derive(Debug, Clone)]
pub struct GCStats {
    pub before_mark: usize,
    pub after_mark: usize,
    pub freed_count: usize,
    pub freed_bytes: usize,
    pub kept_count: usize,
    pub remaining_bytes: usize,
}

impl fmt::Display for GCStats {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        write!(
            f,
            "[GC] 해제: {} 객체 ({} bytes) | 유지: {} 객체 | 메모리: {} bytes",
            self.freed_count, self.freed_bytes, self.kept_count, self.remaining_bytes
        )
    }
}

// ============================================================================
// 가비지 컬렉터
// ============================================================================

pub struct GarbageCollector {
    pub heap: Heap,
    pub roots: GCRoots,
}

impl GarbageCollector {
    pub fn new(gc_threshold: usize) -> Self {
        GarbageCollector {
            heap: Heap::new(gc_threshold),
            roots: GCRoots::new(),
        }
    }

    // ========================================================================
    // 할당
    // ========================================================================

    /// 새 객체를 Heap에 할당
    pub fn allocate(&mut self, obj_type: ObjectType) -> usize {
        // GC 필요 여부 확인
        if self.should_collect_garbage() {
            self.collect_garbage();
        }

        // 크기 추정
        let size = self.estimate_size(&obj_type);

        // 객체 생성
        let obj = HeapObject {
            header: ObjectHeader::new(obj_type.clone(), size, self.heap.total_allocations),
        };

        // Heap에 추가
        let idx = self.heap.objects.len();
        self.heap.objects.push(obj);
        self.heap.allocated_bytes += size;
        self.heap.total_allocations += 1;

        idx
    }

    /// 스택에 객체 참조 추가
    pub fn push_stack(&mut self, obj_idx: usize) {
        if obj_idx < self.heap.objects.len() {
            self.roots.stack.push(obj_idx);
        }
    }

    /// 스택에서 객체 참조 제거
    pub fn pop_stack(&mut self) -> Option<usize> {
        self.roots.stack.pop()
    }

    /// 전역 변수 등록
    pub fn register_global(&mut self, obj_idx: usize) {
        if obj_idx < self.heap.objects.len() {
            self.roots.globals.push(obj_idx);
        }
    }

    // ========================================================================
    // Mark (마킹) - DFS 기반
    // ========================================================================

    /// Mark 단계: 루트에서 도달 가능한 객체 표시
    pub fn mark(&mut self, roots: &GCRoots) {
        // 모든 루트 객체부터 시작
        for &obj_idx in &roots.all_roots() {
            self.mark_object(obj_idx);
        }
    }

    /// 객체와 그 참조된 객체를 재귀적으로 표시
    fn mark_object(&mut self, obj_idx: usize) {
        // 범위 체크
        if obj_idx >= self.heap.objects.len() {
            return;
        }

        let obj = &mut self.heap.objects[obj_idx];

        // 이미 마킹된 경우 무한 재귀 방지
        if obj.header.is_marked {
            return;
        }

        // 마킹
        obj.header.is_marked = true;

        // 배열인 경우 참조된 객체도 마킹
        if let ObjectType::Array(indices) = &obj.header.obj_type {
            let indices = indices.clone(); // 소유권 이동 방지
            for &idx in &indices {
                self.mark_object(idx);
            }
        }
    }

    // ========================================================================
    // Sweep (청소)
    // ========================================================================

    /// Sweep 단계: 마킹되지 않은 객체 제거
    pub fn sweep(&mut self) -> GCStats {
        let before_count = self.heap.objects.len();

        let mut freed_count = 0;
        let mut freed_bytes = 0;
        let mut kept_count = 0;

        // 표시되지 않은 객체 제거
        let mut i = 0;
        while i < self.heap.objects.len() {
            if !self.heap.objects[i].header.is_marked {
                // 쓰레기 객체
                let obj = &self.heap.objects[i];
                freed_bytes += obj.header.size;
                freed_count += 1;

                // 제거
                self.heap.objects.remove(i);
                // i를 증가시키지 않음 (다음 요소가 현재 위치로 이동)
            } else {
                // 마킹된 객체 유지, 마킹 해제
                self.heap.objects[i].header.is_marked = false;
                kept_count += 1;
                i += 1;
            }
        }

        self.heap.allocated_bytes -= freed_bytes;

        GCStats {
            before_mark: before_count,
            after_mark: self.heap.objects.len(),
            freed_count,
            freed_bytes,
            kept_count,
            remaining_bytes: self.heap.allocated_bytes,
        }
    }

    // ========================================================================
    // GC 실행
    // ========================================================================

    pub fn should_collect_garbage(&self) -> bool {
        self.heap.allocated_bytes >= self.heap.gc_threshold
    }

    pub fn collect_garbage(&mut self) -> GCStats {
        let roots = self.roots.clone();

        // Mark 단계
        self.mark(&roots);

        // Sweep 단계
        let stats = self.sweep();

        self.heap.gc_runs += 1;

        stats
    }

    // ========================================================================
    // 유틸리티
    // ========================================================================

    fn estimate_size(&self, obj_type: &ObjectType) -> usize {
        match obj_type {
            ObjectType::Integer => 8,
            ObjectType::Float => 8,
            ObjectType::Boolean => 1,
            ObjectType::Null => 0,
            ObjectType::Array(indices) => 8 + indices.len() * 8,
            ObjectType::String(s) => s.len() + 8,
        }
    }

    pub fn get_object_info(&self, obj_idx: usize) -> Option<String> {
        if obj_idx < self.heap.objects.len() {
            let obj = &self.heap.objects[obj_idx];
            Some(format!(
                "객체 {}: {} ({} bytes, id={})",
                obj_idx,
                obj.header.obj_type,
                obj.header.size,
                obj.header.allocation_id
            ))
        } else {
            None
        }
    }

    pub fn heap_summary(&self) -> String {
        format!(
            "Heap: {} 객체, {} bytes ({:.1}%), {} 번 할당, {} 번 GC",
            self.heap.object_count(),
            self.heap.allocated_bytes,
            self.heap.memory_usage_percent(),
            self.heap.total_allocations,
            self.heap.gc_runs
        )
    }
}

