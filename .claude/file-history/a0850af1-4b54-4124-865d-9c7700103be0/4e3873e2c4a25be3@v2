<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}학생관리 시스템{% endblock %}</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
</head>
<body>
    <!-- 네비게이션 바 -->
    <nav class="navbar">
        <div class="container">
            <div class="navbar-brand">
                <a href="/" class="navbar-title">🎓 학생관리 시스템</a>
            </div>
            <div class="navbar-menu">
                <a href="/" class="nav-link">대시보드</a>
                <a href="/students" class="nav-link">학생</a>
                <a href="/grades" class="nav-link">성적</a>
                <a href="/attendance" class="nav-link">출석</a>
                <a href="/statistics" class="nav-link">통계</a>
                <a href="/add-student" class="nav-link nav-button">+ 학생 추가</a>
            </div>
        </div>
    </nav>

    <!-- 메인 컨텐츠 -->
    <main class="main-content">
        <div class="container">
            {% block content %}{% endblock %}
        </div>
    </main>

    <!-- 푸터 -->
    <footer class="footer">
        <p>기록이 증명이다 gogs 🎓 | v5.2 SQLite + v5.3 REST API</p>
    </footer>

    <script>
        // 페이지 로드 시 활성 네비게이션 강조
        document.addEventListener('DOMContentLoaded', function() {
            const links = document.querySelectorAll('.nav-link');
            const currentPath = window.location.pathname;

            links.forEach(link => {
                if (link.getAttribute('href') === currentPath) {
                    link.classList.add('active');
                }
            });
        });
    </script>

    {% block scripts %}{% endblock %}
</body>
</html>
