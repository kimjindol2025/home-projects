class MenuItem:
    """음식점 메뉴의 기본 항목"""

    def __init__(self, name, price):
        self.name = name
        self.price = price

    def describe(self):
        print(f"음식: {self.name}, 가격: {self.price}원")

    def get_calories(self):
        return 0

class Main(MenuItem):
    """메인 음식 (밥/면)"""

    def __init__(self, name, price, calories):
        super().__init__(name, price)
        self.calories = calories

    def describe(self):
        super().describe()
        print(f"칼로리: {self.calories}kcal")

    def get_calories(self):
        return self.calories

class Side(MenuItem):
    """반찬"""

    def __init__(self, name, price, spice_level):
        super().__init__(name, price)
        self.spice_level = spice_level

    def describe(self):
        super().describe()
        print(f"맵기: {'🌶️' * self.spice_level}")

class Drink(MenuItem):
    """음료"""

    def __init__(self, name, price, temperature):
        super().__init__(name, price)
        self.temperature = temperature

    def describe(self):
        super().describe()
        print(f"온도: {self.temperature}°C")

# 주문 테스트
items = [
    Main("카레라이스", 8000, 450),
    Side("된장찌개", 4000, 2),
    Drink("아메리카노", 3500, 5),
]

print("📋 주문 내용:")
print("-" * 80)

total_price = 0
total_calories = 0

for item in items:
    item.describe()
    total_price += item.price
    total_calories += item.get_calories()
    print()

print("=" * 80)
print(f"총 가격: {total_price}원")
print(f"총 칼로리: {total_calories}kcal")
print()

