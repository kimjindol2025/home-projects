# MRO: 메서드를 찾는 순서 (깊이 우선 탐색)
class GrandParent:
    def action(self):
        print("할아버지가 합니다.")

class Parent1(GrandParent):
    def action(self):
        print("아버지(1)가 합니다.")

class Parent2(GrandParent):
    def action(self):
        print("아버지(2)가 합니다.")

class Child(Parent1, Parent2):
    pass

child = Child()
child.action()  # Parent1의 action() 호출됨 (왼쪽부터 탐색)

print()
print("MRO 순서:", Child.__mro__)
print()
print("💡 메서드는 왼쪽부터 오른쪽 순서로 탐색합니다.")
print()

