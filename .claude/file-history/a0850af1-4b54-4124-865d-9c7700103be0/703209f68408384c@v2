# 실제 예제
class Robot:
    def __init__(self, name):
        self.name = name

    def work(self):
        print(f"{self.name}가 일 중입니다.")

# 좋은 설계: IS-A 관계가 명확함
class IndustrialRobot(Robot):
    def work(self):
        super().work()
        print(f"{self.name}가 공장에서 물건을 조립합니다.")

# 구성 예제
class RobotArm:
    def grab(self):
        print("팔로 집었습니다.")

class AdvancedRobot:
    def __init__(self, name):
        self.name = name
        self.arm = RobotArm()  # 상속 대신 구성

    def pick_item(self):
        print(f"{self.name}가 물건을 집으려고 합니다.")
        self.arm.grab()

robot1 = IndustrialRobot("산업용 로봇")
robot1.work()

print()

robot2 = AdvancedRobot("고급 로봇")
robot2.pick_item()

print()
print("💡 상속과 구성을 적절히 선택하는 것이 좋은 설계입니다.")
print()

