# 자식 클래스에서 부모의 메서드를 다시 정의 (기능을 특화시킴)
class Bus(Vehicle):
    def move(self):
        # 부모의 move() 대신 버스만의 move() 실행
        print(f"{self.brand}는 여러 사람을 태우고 도로를 따라 이동합니다.")

bus = Bus("현대", "노란색")
bus.info()
bus.move()  # 부모의 move()가 아닌 Bus의 move() 실행

print()
print("💡 메서드 오버라이딩: 자식이 부모의 메서드를 '다시 정의'하는 것")
