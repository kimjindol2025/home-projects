# Mixin 클래스들 (여러 클래스로부터 기능을 가져옴)
class Swimmer:
    def swim(self):
        print("수영 중입니다. 🏊")

class Flyer:
    def fly(self):
        print("날아다니는 중입니다. ✈️")

class Walker:
    def walk(self):
        print("걸어다니는 중입니다. 🚶")

# 오리: 걷고, 헤엄치고, 날 수 있음
class Duck(Walker, Swimmer, Flyer):
    def __init__(self, name):
        self.name = name

    def quack(self):
        print(f"{self.name}는 꽥꽥 웁니다. 🦆")

duck = Duck("도널드")
duck.walk()
duck.swim()
duck.fly()
duck.quack()

print()
print("💡 다중 상속: 여러 부모 클래스로부터 기능을 상속받을 수 있습니다.")
