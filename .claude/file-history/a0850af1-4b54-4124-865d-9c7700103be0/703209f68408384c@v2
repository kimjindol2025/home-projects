# 자식 클래스가 __init__을 정의할 때, 부모의 __init__을 호출해야 함
class Airplane(Vehicle):
    def __init__(self, brand, color, altitude):
        super().__init__(brand, color)  # 부모의 __init__ 호출
        self.altitude = altitude

    def info(self):
        super().info()  # 부모의 info() 호출
        print(f"고도: {self.altitude}m")

airplane = Airplane("보잉", "흰색", 10000)
airplane.info()
airplane.move()

print()
print("💡 super()는 '부모 클래스의 메서드를 호출하라'는 의미입니다.")
print()

