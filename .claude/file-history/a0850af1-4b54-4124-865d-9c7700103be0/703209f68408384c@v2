# 부모 클래스
class Animal:
    def __init__(self, name):
        self.name = name

    def sound(self):
        print(f"{self.name}가 소리를 냅니다.")

# 첫 번째 자식 클래스
class Dog(Animal):
    def sound(self):
        print(f"{self.name}는 멍멍 짖습니다. 🐕")

# 두 번째 자식 클래스
class Cat(Animal):
    def sound(self):
        print(f"{self.name}는 야옹 웁니다. 🐱")

# 세 번째 자식 클래스
class Parrot(Animal):
    def sound(self):
        print(f"{self.name}는 앵앵 울립니다. 🦜")

    def mimic(self, text):
        print(f"{self.name}가 말합니다: '{text}'")

# 각 동물 테스트
dog = Dog("뽀삐")
dog.sound()

cat = Cat("나비")
cat.sound()

parrot = Parrot("쩜쩜")
parrot.sound()
parrot.mimic("안녕하세요!")

print()
print("💡 부모 클래스 하나에서 여러 자식 클래스가 각각의 특화된 기능을 구현합니다.")
