// Phase 10 v11.0: Trait Objects and Dynamic Dispatch
// "타입의 경계를 허무는 기술" - Polymorphism Without Inheritance
// Fat Pointers, Vtables, and Dynamic Dispatch Mechanisms

use std::mem::size_of;

// ============================================================================
// Foundation: Security Log Trait
// ============================================================================

/// 모든 보안 로그가 구현해야 할 공통 규약
trait SecurityLog {
    /// 이벤트의 심각도 (0-10 범위)
    fn severity(&self) -> u8;

    /// 이벤트의 세부 메시지
    fn message(&self) -> String;

    /// 로그 타입 식별자
    fn log_type(&self) -> &'static str;
}

// ============================================================================
// Demo 1: Basic Trait Definition and Implementations
// ============================================================================

#[derive(Clone)]
struct NetworkLog {
    ip: String,
    attack_type: String,
    port: u16,
}

impl SecurityLog for NetworkLog {
    fn severity(&self) -> u8 {
        match self.attack_type.as_str() {
            "DDoS" => 9,
            "PortScan" => 7,
            "Intrusion" => 10,
            _ => 5,
        }
    }

    fn message(&self) -> String {
        format!("🌐 네트워크 침입: {} 공격 감지 (IP: {}, Port: {})",
                self.attack_type, self.ip, self.port)
    }

    fn log_type(&self) -> &'static str {
        "NetworkLog"
    }
}

#[derive(Clone)]
struct AuthLog {
    user: String,
    action: String,
    timestamp: String,
}

impl SecurityLog for AuthLog {
    fn severity(&self) -> u8 {
        match self.action.as_str() {
            "root_access" => 8,
            "password_change" => 4,
            "login_failure" => 3,
            "logout" => 1,
            _ => 2,
        }
    }

    fn message(&self) -> String {
        format!("🔐 권한 이벤트: {} by {} ({})",
                self.action, self.user, self.timestamp)
    }

    fn log_type(&self) -> &'static str {
        "AuthLog"
    }
}

#[derive(Clone)]
struct FileLog {
    path: String,
    operation: String,
    user: String,
}

impl SecurityLog for FileLog {
    fn severity(&self) -> u8 {
        match self.operation.as_str() {
            "delete" => 9,
            "chmod" => 7,
            "read" => 2,
            "write" => 5,
            _ => 3,
        }
    }

    fn message(&self) -> String {
        format!("📁 파일 접근: {} 작업 수행 (경로: {}, 사용자: {})",
                self.operation, self.path, self.user)
    }

    fn log_type(&self) -> &'static str {
        "FileLog"
    }
}

fn demo_basic_trait_definition() {
    println!("\n=== Demo 1: Basic Trait Definition and Implementations ===");
    println!("📋 SecurityLog 트레이트를 여러 구현체가 공통으로 구현");

