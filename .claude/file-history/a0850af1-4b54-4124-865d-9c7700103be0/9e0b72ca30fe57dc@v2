fn demo_dynamic_dispatch_reference() {
    println!("\n=== Demo 3: Dynamic Dispatch with &dyn ===");
    println!("🎭 트레이트 객체 참조 (&dyn SecurityLog):");

    let network = NetworkLog {
        ip: "203.0.113.5".to_string(),
        attack_type: "PortScan".to_string(),
        port: 8080,
    };

    let auth = AuthLog {
        user: "root".to_string(),
        action: "password_change".to_string(),
        timestamp: "2026-02-23 11:00:00".to_string(),
    };

    let file = FileLog {
        path: "/var/log/auth.log".to_string(),
        operation: "delete".to_string(),
        user: "attacker".to_string(),
    };

    println!("\n런타임에 vtable을 참조하여 메서드 호출:");

