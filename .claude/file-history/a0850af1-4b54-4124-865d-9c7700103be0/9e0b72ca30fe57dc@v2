fn demo_boxed_trait_collection() {
    println!("\n=== Demo 4: Box<dyn Trait> Collections ===");
    println!("📦 힙 기반 이질 컬렉션: Vec<Box<dyn SecurityLog>>");

    let logs: Vec<Box<dyn SecurityLog>> = vec![
        Box::new(NetworkLog {
            ip: "172.16.0.1".to_string(),
            attack_type: "DDoS".to_string(),
            port: 443,
        }),
        Box::new(AuthLog {
            user: "admin".to_string(),
            action: "root_access".to_string(),
            timestamp: "2026-02-23 12:30:00".to_string(),
        }),
        Box::new(FileLog {
            path: "/etc/shadow".to_string(),
            operation: "chmod".to_string(),
            user: "attacker".to_string(),
        }),
        Box::new(NetworkLog {
            ip: "198.51.100.2".to_string(),
            attack_type: "Intrusion".to_string(),
            port: 22,
        }),
    ];

    println!("\n🔍 통합 보안 분석 (다형성 엔진):");

    let mut total_severity = 0u32;
    let mut critical_count = 0;

    for (idx, log) in logs.iter().enumerate() {
        let severity = log.severity();
        total_severity += severity as u32;

        if severity >= 8 {
            critical_count += 1;
            println!("  [🔴 CRITICAL] {}", log.message());
        } else if severity >= 5 {
            println!("  [🟠 WARNING] {}", log.message());
        } else {
            println!("  [🟡 INFO] {}", log.message());
        }
    }

    println!("\n📊 분석 결과:");
    println!("  총 이벤트: {} 건", logs.len());
    println!("  평균 심각도: {:.1}", total_severity as f64 / logs.len() as f64);
    println!("  위험 이벤트: {} 건", critical_count);

    println!("\n💡 설계 패턴 - 플러그인 시스템의 기초:");
    println!("  새 로그 타입 추가 = SecurityLog 구현체 작성");
    println!("  기존 분석 엔진 = 수정 없이 자동 지원");
    println!("  → 런타임 확장성 극대화");
}

