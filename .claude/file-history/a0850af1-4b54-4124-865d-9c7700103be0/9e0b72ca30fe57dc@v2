fn demo_fat_pointer_structure() {
    println!("\n=== Demo 5: Fat Pointer Structure Verification ===");
    println!("🔬 트레이트 객체의 메모리 구조:");

    // 일반 포인터
    let ptr_size = size_of::<*const NetworkLog>();
    println!("\n일반 포인터 (*const NetworkLog):");
    println!("  크기: {} 바이트", ptr_size);

    // 참조
    let ref_size = size_of::<&NetworkLog>();
    println!("\n참조 (&NetworkLog):");
    println!("  크기: {} 바이트", ref_size);

    // 트레이트 객체 참조 (Fat Pointer)
    let dyn_ref_size = size_of::<&dyn SecurityLog>();
    println!("\n트레이트 객체 참조 (&dyn SecurityLog):");
    println!("  크기: {} 바이트 ← Fat Pointer!", dyn_ref_size);
    println!("  구성: 데이터 포인터 (8바이트) + Vtable 포인터 (8바이트)");

    // Box
    let box_size = size_of::<Box<NetworkLog>>();
    println!("\nBox<NetworkLog>:");
    println!("  크기: {} 바이트", box_size);

    // Box of dyn Trait (Fat Pointer)
    let dyn_box_size = size_of::<Box<dyn SecurityLog>>();
    println!("\nBox<dyn SecurityLog>:");
    println!("  크기: {} 바이트 ← Fat Pointer!", dyn_box_size);
    println!("  구성: 데이터 포인터 (8바이트) + Vtable 포인터 (8바이트)");

    println!("\n📐 Fat Pointer 구조 다이어그램:");
    println!("┌───────────────────────────────────────┐");
    println!("│ Fat Pointer: &dyn SecurityLog         │");
    println!("├───────────────────────────────────────┤");
    println!("│ 데이터 포인터 → 실제 NetworkLog 인스턴스");
    println!("│                (힙 또는 스택의 어디든)  │");
    println!("├───────────────────────────────────────┤");
    println!("│ Vtable 포인터 → |severity()           │");
    println!("│                 |message()            │");
    println!("│                 |log_type()           │");
    println!("│                 |drop()               │");
    println!("└───────────────────────────────────────┘");

    println!("\n✓ 런타임 타입 정보:");
    let network: Box<dyn SecurityLog> = Box::new(NetworkLog {
        ip: "0.0.0.0".to_string(),
        attack_type: "Test".to_string(),
        port: 0,
    });

    println!("  타입 이름: {}", network.log_type());
    println!("  심각도: {}", network.severity());
    println!("  메시지 길이: {} 바이트", network.message().len());
}

// ============================================================================
// Demo 6: Multi-Protocol Security Analyzer (Practical Polymorphism)
// ============================================================================

struct SecurityAnalyzer {
    logs: Vec<Box<dyn SecurityLog>>,
    analysis_timestamp: String,
}

impl SecurityAnalyzer {
    fn new(timestamp: &str) -> Self {
        SecurityAnalyzer {
            logs: vec![],
            analysis_timestamp: timestamp.to_string(),
        }
    }

    fn add_log(&mut self, log: Box<dyn SecurityLog>) {
        self.logs.push(log);
    }

    fn analyze(&self) -> String {
        if self.logs.is_empty() {
            return "분석 대상 없음".to_string();
        }

        let mut report = format!("📋 보안 분석 리포트 ({})\n", self.analysis_timestamp);
        report.push_str("═════════════════════════════════════\n");

        let mut severity_dist = [0; 11];
        let mut type_count: std::collections::HashMap<&str, usize> = std::collections::HashMap::new();

        for log in &self.logs {
            let severity = log.severity() as usize;
            severity_dist[severity] += 1;
            *type_count.entry(log.log_type()).or_insert(0) += 1;
        }

        // 심각도별 분포
        report.push_str("심각도 분포:\n");
        for (level, count) in severity_dist.iter().enumerate() {
            if *count > 0 {
                let bar = "█".repeat(*count);
                report.push_str(&format!("  [{:2}] {} ({}건)\n", level, bar, count));
            }
        }

        // 로그 타입별 분석
        report.push_str("\n로그 타입 분류:\n");
        for (log_type, count) in type_count.iter() {
            report.push_str(&format!("  {} : {}건\n", log_type, count));
        }

        // 최고 심각도
        let max_severity = self.logs.iter().map(|l| l.severity()).max().unwrap_or(0);
        report.push_str(&format!("\n최고 심각도: {}/10\n", max_severity));

        report
    }

    fn critical_events(&self) -> Vec<String> {
        self.logs
            .iter()
            .filter(|log| log.severity() >= 8)
            .map(|log| format!("[{}] {}", log.log_type(), log.message()))
            .collect()
    }
}

fn demo_multi_protocol_analyzer() {
    println!("\n=== Demo 6: Multi-Protocol Security Analyzer ===");
    println!("🛡️  실무 다형성 엔진: 멀티 프로토콜 보안 분석");

