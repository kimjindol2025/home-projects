            Box::new(NetworkLog {
                ip: "192.168.1.1".to_string(),
                attack_type: "Test".to_string(),
                port: 443,
            }),
            Box::new(AuthLog {
                user: "test".to_string(),
                action: "test_action".to_string(),
                timestamp: "test_time".to_string(),
            }),
        ];

        assert_eq!(logs.len(), 2);
        assert!(logs[0].severity() > 0);
        assert!(logs[1].severity() > 0);
    }

    #[test]
    fn test_security_analyzer() {
        let mut analyzer = SecurityAnalyzer::new("test_time");

        analyzer.add_log(Box::new(NetworkLog {
            ip: "1.1.1.1".to_string(),
            attack_type: "DDoS".to_string(),
            port: 80,
        }));

        analyzer.add_log(Box::new(AuthLog {
            user: "admin".to_string(),
            action: "root_access".to_string(),
            timestamp: "now".to_string(),
        }));

        assert_eq!(analyzer.logs.len(), 2);
        assert_eq!(analyzer.critical_events().len(), 2);
    }
}
