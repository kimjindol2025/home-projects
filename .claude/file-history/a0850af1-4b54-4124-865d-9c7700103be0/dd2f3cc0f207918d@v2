// Demo 1: 기본 속성 매크로의 개념 (로깅 주입)
// =============================================================================

/// 속성 매크로가 할 수 있는 일: 함수를 완전히 변조하기
///
/// 사용:
/// ```ignore
/// #[log_calls]
/// fn important_function(x: i32) -> i32 {
///     x * 2
/// }
/// ```
///
/// 생성되는 코드:
struct LoggingDemo;

impl LoggingDemo {
    fn original_function(x: i32) -> i32 {
        x * 2
    }

    // 매크로가 생성하는 버전
    fn wrapped_function(x: i32) -> i32 {
        println!("[LOG] 함수 호출: wrapped_function({})", x);
        let result = (|| LoggingDemo::original_function(x))();
        println!("[LOG] 함수 반환: {}", result);
        result
    }
}

fn demo_attribute_macro_concept() {
    println!("\n=== Demo 1: 속성 매크로의 개념 (로깅 주입) ===");

    println!("  [속성 매크로의 구조]");
    println!("    #[log_calls]");
    println!("    fn important_function(x: i32) → i32 {{");
    println!("        x * 2");
    println!("    }}");
    println!("");
    println!("    ↓ 매크로 처리 ↓");
    println!("");
    println!("    fn important_function(x: i32) → i32 {{");
    println!("        println!(\"[LOG] 함수 호출\");");
    println!("        let result = (|| {{ x * 2 }})();");
    println!("        println!(\"[LOG] 함수 반환\");");
    println!("        result");
    println!("    }}");

    println!("\n  [입출력 형태]");
    println!("    입력:");
    println!("      attr: (로깅 레벨 등 옵션)");
    println!("      item: 함수 코드 전체");
    println!("    ");
    println!("    출력:");
    println!("      로깅이 주입된 새로운 함수 코드");

    println!("\n  [실제 동작 시뮬레이션]");
    LoggingDemo::wrapped_function(5);

    println!("\n  [특징]");
    println!("    • 함수의 본체를 완전히 감쌀 수 있음");
    println!("    • 입출력 타입을 알 필요 없음 (어떤 함수든 가능)");
    println!("    • 원본 코드 구조는 유지됨");
}

// =============================================================================
// Demo 2: 성능 측정 속성 매크로
// =============================================================================

/// 성능 측정 매크로 시뮬레이션
struct PerformanceDemo;

impl PerformanceDemo {
    // 원본 함수
    fn expensive_operation() -> u64 {
        let mut sum = 0u64;
        for i in 0..1_000_000 {
            sum = sum.wrapping_add(i);
        }
        sum
    }

    // 매크로가 생성하는 버전
    fn measured_operation() -> u64 {
        let start = Instant::now();
        let result = (|| PerformanceDemo::expensive_operation())();
        let elapsed = start.elapsed();
        println!("[PERF] measured_operation 실행 시간: {:?}", elapsed);
        result
    }
}

fn demo_performance_measurement() {
    println!("\n=== Demo 2: 성능 측정 속성 매크로 ===");

    println!("  [사용 방법]");
    println!("    #[measure_time]");
    println!("    fn expensive_operation() → u64 {{");
    println!("        // ... 무거운 계산 ...");
    println!("    }}");

    println!("\n  [생성되는 코드]");
    println!("    fn expensive_operation() → u64 {{");
    println!("        let start = Instant::now();");
    println!("        let result = (|| {{ /* 원본 */ }})();");
    println!("        println!(\"실행 시간: {{:?}}\", start.elapsed());");
    println!("        result");
    println!("    }}");

    println!("\n  [실제 동작]");
    PerformanceDemo::measured_operation();

    println!("\n  [용도]");
    println!("    • 프로파일링");
    println!("    • 성능 병목 지점 파악");
    println!("    • 자동 최적화 제안");
}

