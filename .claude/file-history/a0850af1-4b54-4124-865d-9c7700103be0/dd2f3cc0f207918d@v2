// Demo 3: 권한 검사 속성 매크로
// =============================================================================

/// 권한 검사 매크로 시뮬레이션
struct AuthDemo;

impl AuthDemo {
    fn check_permission(required_role: &str) -> bool {
        // 현재 사용자가 admin이라고 가정
        let current_user_role = "admin";
        current_user_role == required_role
    }

    fn delete_user_unguarded() {
        println!("  [위험] 사용자 삭제 수행!");
    }

    fn delete_user_guarded() {
        if !AuthDemo::check_permission("admin") {
            println!("  [DENIED] 권한 부족: admin 필요");
            return;
        }
        println!("  [OK] 권한 확인 완료");
        AuthDemo::delete_user_unguarded();
    }
}

fn demo_auth_check() {
    println!("\n=== Demo 3: 권한 검사 속성 매크로 ===");

    println!("  [사용 방법]");
    println!("    #[require_auth(\"admin\")]");
    println!("    fn delete_user(id: u32) {{");
    println!("        // ... 삭제 로직 ...");
    println!("    }}");

    println!("\n  [생성되는 코드]");
    println!("    fn delete_user(id: u32) {{");
    println!("        if !check_permission(\"admin\") {{");
    println!("            panic!(\"권한 부족\");");
    println!("        }}");
    println!("        // ... 원본 로직 ...");
    println!("    }}");

    println!("\n  [실제 동작]");
    println!("    권한 있는 경우:");
    AuthDemo::delete_user_guarded();

    println!("\n  [특징]");
    println!("    • 함수 시작에 검사 코드 자동 주입");
    println!("    • 권한이 없으면 실행 중단");
    println!("    • 원본 함수는 권한 체크를 걱정 안 함");
}

