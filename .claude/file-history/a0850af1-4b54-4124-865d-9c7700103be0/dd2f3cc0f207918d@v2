// Demo 6: 커스텀 문법 함수형 매크로 (SQL)
// =============================================================================

/// 커스텀 SQL 문법 매크로 시뮬레이션
struct SqlDemo;

impl SqlDemo {
    fn explain() {
        println!("\n=== Demo 6: 커스텀 문법 함수형 매크로 (SQL) ===");

        println!("  [함수형 매크로가 가능한 것]");
        println!("    ❌ 표준 Rust 문법만 가능:");
        println!("       let query = \"SELECT * FROM users\";");
        println!("       // 컴파일 타임에 검증 불가! 런타임 에러 위험");
        println!("");
        println!("    ✅ 함수형 매크로로 해결:");
        println!("       let query = sql!(SELECT * FROM users);");
        println!("       // 컴파일 타임에 SQL 문법 검증!");

        println!("\n  [SQL 매크로가 하는 일]");
        println!("    1. 입력 파싱:");
        println!("       sql!(SELECT id, name FROM users WHERE age > 18)");
        println!("");
        println!("    2. 문법 검증 (컴파일 타임):");
        println!("       ✓ SELECT 키워드 확인");
        println!("       ✓ FROM 키워드 확인");
        println!("       ✓ 필드명과 테이블명 검증");
        println!("");
        println!("    3. 구조 생성:");
        println!("       Query {{");
        println!("           operation: QueryOp::Select,");
        println!("           fields: vec![\"id\", \"name\"],");
        println!("           from: \"users\",");
        println!("           where_clause: Some(\"age > 18\"),");
        println!("       }}");

        println!("\n  [다른 커스텀 문법 예시]");
        println!("    html!(<div class=\"container\">");
        println!("        <h1>Title</h1>");
        println!("    </div>)");
        println!("    → HTML 구조 검증");
        println!("");
        println!("    regex!(r\"[0-9]{{3}}-[0-9]{{4}}\")");
        println!("    → 정규표현식 검증");
        println!("");
        println!("    json!({{\"key\": \"value\"}})");
        println!("    → JSON 구조 검증");

        println!("\n  [장점]");
        println!("    • 컴파일 타임 검증");
        println!("    • 타입 안전");
        println!("    • 런타임 오버헤드 없음");
        println!("    • 새로운 언어처럼 사용 가능");
    }
}

