// Demo 5: 보안 감시 속성 매크로 (GOGS)
// =============================================================================

/// GOGS 감시 속성 매크로 시뮬레이션
struct GogsAuditDemo;

impl GogsAuditDemo {
    // 원본 함수
    fn sensitive_operation(username: &str) {
        println!("  [ACTION] 민감한 작업 수행 중...");
    }

    // 매크로가 생성하는 버전 (감시 추가)
    fn audited_sensitive_operation(username: &str) {
        println!("  ╔════════════════════════════════════╗");
        println!("  ║  [GOGS AUDIT] 명령 실행 감지       ║");
        println!("  ║  함수: audited_sensitive_operation ║");
        println!("  ║  사용자: {}                       ║", username);
        println!("  ║  시각: 2026-02-23 (컴파일 타임)    ║");
        println!("  ║  상태: 기록이 증명이다 gogs        ║");
        println!("  ╚════════════════════════════════════╝");
        GogsAuditDemo::sensitive_operation(username);
        println!("  [GOGS AUDIT] 명령 종료.");
    }
}

fn demo_gogs_audit() {
    println!("\n=== Demo 5: 보안 감시 속성 매크로 (GOGS) ===");

    println!("  [사용 방법]");
    println!("    #[gogs_audit]");
    println!("    fn delete_database() {{");
    println!("        // ... 위험한 작업 ...");
    println!("    }}");

    println!("\n  [생성되는 코드]");
    println!("    fn delete_database() {{");
    println!("        println!(\"[GOGS AUDIT] 명령 실행 감지: 'delete_database'\");");
    println!("        println!(\"[GOGS AUDIT] 기록이 증명이다 gogs\");");
    println!("        // ... 원본 로직 ...");
    println!("        println!(\"[GOGS AUDIT] 명령 종료.\");");
    println!("    }}");

    println!("\n  [실제 동작]");
    GogsAuditDemo::audited_sensitive_operation("admin_user");

    println!("\n  [특징]");
    println!("    • 모든 호출이 자동으로 기록됨");
    println!("    • 누가, 언제, 무엇을 했는지 추적");
    println!("    • 감시 코드는 원본 함수와 분리");
}

