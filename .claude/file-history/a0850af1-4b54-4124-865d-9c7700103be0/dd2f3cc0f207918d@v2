/// 매크로의 힘과 책임
struct MacroPowerDemo;

impl MacroPowerDemo {
    fn explain() {
        println!("\n=== 보충: 매크로의 강력함과 책임 ===");

        println!("  [매크로가 할 수 있는 것 (위험도순)]");
        println!("    1️⃣  Low: 메서드 추가 (derive)");
        println!("       → 원본은 안전하게 유지");
        println!("");
        println!("    2️⃣  Medium: 함수 감싸기 (속성)");
        println!("       → 원본 함수는 유지되지만 래퍼됨");
        println!("");
        println!("    3️⃣  High: 완전한 함수 재작성");
        println!("       → 함수의 서명 자체를 변경 가능");
        println!("");
        println!("    4️⃣  Very High: 새로운 문법 창조 (함수형)");
        println!("       → Rust 문법이 아닌 코드 처리");
        println!("       → 컴파일 타임 검증");

        println!("\n  [사용 원칙]");
        println!("    • 꼭 필요할 때만 사용");
        println!("    • 함수 99% → 제네릭 → 매크로 순서로 고려");
        println!("    • 문서를 충실하게 작성");
        println!("    • 에러 메시지를 친절하게");
        println!("    • cargo expand로 확인하는 습관");

        println!("\n  [compile_error!로 친절한 에러]");
        println!("    ✅ compile_error!(\"sql! macro requires SELECT or INSERT\");");
        println!("    → 사용자가 명확하게 이해 가능");
        println!("");
        println!("    ❌ panic!(\"Invalid input\");");
        println!("    → 어디가 틀렸는지 불명확");
    }
}

