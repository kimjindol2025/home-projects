// Demo 4: 함수형 매크로의 개념
// =============================================================================

/// 함수형 매크로의 개념 설명
struct FunctionMacroDemo;

impl FunctionMacroDemo {
    fn explain() {
        println!("\n=== Demo 4: 함수형 매크로의 개념 ===");

        println!("  [함수형 매크로 vs 속성 매크로]");
        println!("");
        println!("    속성 매크로:");
        println!("      #[my_attr]");
        println!("      fn my_func() {{ }}");
        println!("      → 기존 코드를 변조");
        println!("");
        println!("    함수형 매크로:");
        println!("      my_macro!(arg1, arg2)");
        println!("      → 새로운 코드를 생성");

        println!("\n  [함수형 매크로의 형태]");
        println!("    macro_name!(content)");
        println!("    macro_name![content]");
        println!("    macro_name! {{ content }}");
        println!("    괄호 형태 선택 가능");

        println!("\n  [사용 예시]");
        println!("    sql!(\"SELECT * FROM users\")");
        println!("    html!(<div>...</div>)");
        println!("    json!({{ \"key\": \"value\" }})");
        println!("    query!(SELECT id FROM table)");

        println!("\n  [특징]");
        println!("    • 어디서나 사용 가능");
        println!("    • 임의의 토큰 처리");
        println!("    • 새로운 문법 창조 가능");
        println!("    • 커스텀 DSL 구현 가능");
    }
}

