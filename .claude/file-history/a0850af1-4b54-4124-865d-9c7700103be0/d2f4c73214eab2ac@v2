/// 동기 채널로 송신자의 속도 제어
fn demo_backpressure_sync_channel() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║    [Demo 5] 백프레셔: 속도 조절과 버퍼 관리           ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    println!("[1] 동기 채널 생성 (버퍼 크기: 2):");
    let (tx, rx) = mpsc::sync_channel(2);
    println!("    sync_channel(2): 최대 2개 메시지만 버퍼링\n");

    println!("[2] 빠른 송신자 (5개 메시지 송신 시도):");
    thread::spawn(move || {
        for i in 1..=5 {
            println!(
                "    [송신자] 메시지 {} 송신 시도... (버퍼 대기)",
                i
            );
            tx.send(i).unwrap();
            println!("    [송신자] 메시지 {} 송신 완료!", i);
            thread::sleep(Duration::from_millis(50));
        }
    });

    thread::sleep(Duration::from_millis(100));

    println!("\n[3] 느린 수신자 (한 번에 하나씩 처리):");
    for msg in rx {
        println!("    [수신자] 메시지 {} 수신", msg);
        println!("    [수신자] 처리 중...");
        thread::sleep(Duration::from_millis(300));
    }

    println!("\n    ✅ 백프레셔: 송신자의 속도가 수신자에 맞춰짐\n");
}

