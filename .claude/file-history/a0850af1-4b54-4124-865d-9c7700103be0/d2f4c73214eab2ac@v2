// [v10.1: 패턴 6] 파이프라인 아키텍처 (생산자 → 처리기 → 로거)
// ============================================================================

/// 3단계 파이프라인: Producer → Processor → Logger
fn demo_pipeline_architecture() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║   [Demo 6] 파이프라인: 3단계 순차 처리 및 흐름 제어     ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    println!("[1] 파이프라인 아키텍처:");
    println!("    Producer (생성) → Processor (처리) → Logger (기록)\n");

    // Stage 1: Producer
    let (tx1, rx1) = mpsc::channel();
    thread::spawn(move || {
        for i in 1..=3 {
            let event = SecurityEvent::new(
                "이벤트_생산자",
                SecurityLevel::Info,
                &format!("원본 이벤트 {}", i),
            );
            println!("    [Stage 1] Producer: {} 생성", i);
            tx1.send(event).unwrap();
            thread::sleep(Duration::from_millis(150));
        }
    });

    // Stage 2: Processor
    let (tx2, rx2) = mpsc::channel();
    thread::spawn(move || {
        for (idx, mut event) in rx1.into_iter().enumerate() {
            println!("    [Stage 2] Processor: 이벤트 {} 처리 중...", idx + 1);
            // 데이터 변환
            event.message = format!("처리됨: {}", event.message);
            event.severity = SecurityLevel::Warning;
            thread::sleep(Duration::from_millis(100));
            println!("    [Stage 2] Processor: 이벤트 {} 처리 완료", idx + 1);
            tx2.send(event).unwrap();
        }
    });

    // Stage 3: Logger
    println!("\n[2] 파이프라인 실행:");
    thread::spawn(move || {
        for (idx, event) in rx2.into_iter().enumerate() {
            println!(
                "    [Stage 3] Logger: [{:?}] {}",
                event.severity, event.message
            );
            thread::sleep(Duration::from_millis(50));
            println!("    [Stage 3] Logger: 이벤트 {} 기록 완료", idx + 1);
        }
    });

    println!("\n[3] 파이프라인 특징:");
    println!("    ✅ 각 단계가 독립적인 스레드");
    println!("    ✅ 데이터가 일방향으로만 흐름");
    println!("    ✅ 각 단계의 속도를 독립적으로 제어");
    println!("    ✅ 새로운 단계 추가 용이\n");

    thread::sleep(Duration::from_millis(2000));
}

