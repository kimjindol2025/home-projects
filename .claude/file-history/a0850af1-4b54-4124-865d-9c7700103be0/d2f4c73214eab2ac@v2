// Phase 9 v10.1: 채널과 메시지 패싱 (Channels and Message Passing)
// mpsc (Multiple Producer, Single Consumer) 구현

use std::sync::mpsc;
use std::thread;
use std::time::{Duration, SystemTime};

// ============================================================================
// [v10.1: 기본 개념] 보안 이벤트 타입 정의
// ============================================================================

#[derive(Clone, Debug)]
enum SecurityLevel {
    Info,
    Warning,
    Critical,
}

impl SecurityLevel {
    fn as_str(&self) -> &'static str {
        match self {
            SecurityLevel::Info => "ℹ️  정보",
            SecurityLevel::Warning => "⚠️  경고",
            SecurityLevel::Critical => "🚨 심각",
        }
    }
}

#[derive(Clone, Debug)]
struct SecurityEvent {
    team: String,
    severity: SecurityLevel,
    message: String,
}

impl SecurityEvent {
    fn new(team: &str, severity: SecurityLevel, message: &str) -> Self {
        Self {
            team: team.to_string(),
            severity,
            message: message.to_string(),
        }
    }
}

// ============================================================================
// [v10.1: 패턴 1] 기본 채널 (단일 송신자)
// ============================================================================

/// 기본 채널: 하나의 송신자가 데이터를 보냄
fn demo_basic_channel() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║          [Demo 1] 기본 채널: spawn과 message passing       ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    println!("[1] 채널 생성:");
    let (tx, rx) = mpsc::channel();
    println!("    ✅ 송신자(tx)와 수신자(rx) 생성 완료\n");

    println!("[2] 데이터 송신:");
    thread::spawn(move || {
        let msg = "침입 시도 감지!";
        println!("    [워커 스레드] 메시지 송신: {}", msg);
        tx.send(SecurityEvent::new("감시팀", SecurityLevel::Critical, msg))
            .unwrap();
    });

    println!("[3] 데이터 수신:");
    match rx.recv() {
        Ok(event) => {
            println!("    [메인 스레드] 수신 완료: {:?}", event);
            println!("    📩 팀: {}, 심각도: {}", event.team, event.severity.as_str());
        }
        Err(_) => println!("    ❌ 채널 닫힘"),
    }
    println!("    ✅ 기본 메시지 패싱 완료\n");
}

// ============================================================================
// [v10.1: 패턴 2] 여러 송신자 (tx.clone())
// ============================================================================

/// 여러 송신자가 동일한 채널로 데이터를 보냄
fn demo_multiple_senders() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║    [Demo 2] 여러 송신자: tx.clone()으로 분산 송신         ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    println!("[1] 채널 생성 및 송신자 복제:");
    let (tx, rx) = mpsc::channel();
    let tx1 = tx.clone();
    let tx2 = tx.clone();
    println!("    원본 tx와 2개 복제본(tx1, tx2) 생성\n");

    println!("[2] 여러 송신자 스레드 생성:");

    // 송신자 1
    thread::spawn(move || {
        thread::sleep(Duration::from_millis(100));
        println!("    [송신자 1] 메시지 1 송신 중...");
        tx1.send(SecurityEvent::new("감시팀", SecurityLevel::Warning, "포트 스캔 감지"))
            .unwrap();
    });

    // 송신자 2
    thread::spawn(move || {
        thread::sleep(Duration::from_millis(50));
        println!("    [송신자 2] 메시지 2 송신 중...");
        tx2.send(SecurityEvent::new(
            "인증팀",
            SecurityLevel::Info,
            "로그인 시도",
        ))
        .unwrap();
    });

    // 송신자 3 (원본 tx 사용)
    thread::spawn(move || {
        println!("    [송신자 3] 메시지 3 송신 중...");
        tx.send(SecurityEvent::new("감사팀", SecurityLevel::Info, "정책 검토 완료"))
            .unwrap();
    });

    println!("\n[3] 메시지 수신 (순서대로):");
    let mut count = 0;
    for event in rx {
        count += 1;
        println!(
            "    📩 수신 {}: [{}] {} - {}",
            count, event.team, event.severity.as_str(), event.message
        );
    }
    println!("    ✅ 모든 메시지 수신 완료\n");
}

// ============================================================================
// [v10.1: 패턴 3] 다중 소스 로그 수집 (중앙 제어소)
// ============================================================================

/// 3개의 독립적인 보안팀에서 동시에 로그를 전송
fn demo_central_log_collector() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║   [Demo 3] 중앙 제어소: 3개 팀의 로그를 동시 수집       ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    println!("[1] 채널 생성 및 3개 팀 배치:");
    let (tx, rx) = mpsc::channel();

    // 감시팀
    let tx_monitor = tx.clone();
    thread::spawn(move || {
        let logs = vec![
            ("침입 시도 감지", SecurityLevel::Critical),
            ("방화벽 작동", SecurityLevel::Warning),
            ("네트워크 정상", SecurityLevel::Info),
        ];
        for (msg, severity) in logs {
            println!("    [감시팀] 로그 생성: {}", msg);
            tx_monitor
                .send(SecurityEvent::new("감시팀", severity, msg))
                .unwrap();
            thread::sleep(Duration::from_millis(300));
        }
    });

    // 인증팀
    let tx_auth = tx.clone();
    thread::spawn(move || {
        let logs = vec![
            ("관리자 로그인", SecurityLevel::Info),
            ("비정상 접근 시도", SecurityLevel::Warning),
            ("세션 만료", SecurityLevel::Info),
        ];
        for (msg, severity) in logs {
            println!("    [인증팀] 로그 생성: {}", msg);
            tx_auth
                .send(SecurityEvent::new("인증팀", severity, msg))
                .unwrap();
            thread::sleep(Duration::from_millis(250));
        }
    });

    // 감사팀
    let tx_audit = tx;
    thread::spawn(move || {
        let logs = vec![
            ("접근 권한 변경", SecurityLevel::Warning),
            ("정책 위반 감지", SecurityLevel::Critical),
            ("감사 완료", SecurityLevel::Info),
        ];
        for (msg, severity) in logs {
            println!("    [감사팀] 로그 생성: {}", msg);
            tx_audit
                .send(SecurityEvent::new("감사팀", severity, msg))
                .unwrap();
            thread::sleep(Duration::from_millis(350));
        }
    });

    println!("\n[2] 중앙 제어소: 로그 수집 및 처리");
    println!("    [중앙] 로그 수집 시작...\n");

    let mut count = 0;
    for event in rx {
        count += 1;
        println!(
            "    📊 로그 {}: [{}] {} - {}",
            count, event.team, event.severity.as_str(), event.message
        );
    }

    println!("\n    ✅ 중앙 제어소: 모든 로그 수집 완료 (총 {}건)\n", count);
}

// ============================================================================
// [v10.1: 패턴 4] 채널 닫힘 신호와 드롭
// ============================================================================

/// 채널의 명시적 닫힘과 에러 처리
fn demo_channel_closure() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║      [Demo 4] 채널 닫힘: drop과 신호 전파              ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    println!("[1] 채널 생성 및 송신 시작:");
    let (tx, rx) = mpsc::channel();

    thread::spawn(move || {
        for i in 1..=3 {
            let msg = format!("메시지 {}", i);
            println!("    [워커] {} 송신", msg);
            tx.send(msg).unwrap();
            thread::sleep(Duration::from_millis(100));
        }
        println!("    [워커] 모든 메시지 송신 완료");
        // tx가 여기서 drop됨 → 채널 닫힘 신호
    });

    println!("\n[2] 수신자: 채널이 닫힐 때까지 대기");
    let mut received_count = 0;
    for msg in rx {
        received_count += 1;
        println!("    [메인] 수신: {}", msg);
    }

    println!("\n[3] 채널 상태:");
    println!("    모든 송신자(tx)가 drop됨 → 채널 자동 닫힘");
    println!("    수신자의 반복문이 자동 종료됨");
    println!("    ✅ 안전한 채널 종료 (총 {}건 수신)\n", received_count);
}

