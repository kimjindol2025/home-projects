// ============================================================================
// Phase 6 v7.2: 수명 생략 법칙 (Lifetime Elision)
// ============================================================================
// 철학: \"뻔한 것은 숨기고, 복잡한 것만 드러낸다\"
// 목표: 명시와 생략의 조화로운 균형잡힌 설계를 배운다

// ============================================================================
// [규칙 1] 입력이 1개의 참조자만 있을 때 - 그 수명이 출력에 적용
// ============================================================================

/// [명시적 설계] 모든 수명을 명확히 표현
fn first_word_explicit<'a>(s: &'a str) -> &'a str {
    let bytes = s.as_bytes();
    for (i, &item) in bytes.iter().enumerate() {
        if item == b' ' {
            return &s[0..i];
        }
    }
    &s[..]
}

/// [생략된 설계] 규칙 1 적용 - 입력이 1개이므로 생략 가능
/// 컴파일러가 자동으로: fn first_word<'a>(s: &'a str) -> &'a str으로 해석
fn first_word_elided(s: &str) -> &str {
    let bytes = s.as_bytes();
    for (i, &item) in bytes.iter().enumerate() {
        if item == b' ' {
            return &s[0..i];
        }
    }
    &s[..]
}

/// [규칙 1 예제 2] 마지막 단어 추출 (반환값이 입력 참조 - 단일 입력!)
fn extract_last<'a>(text: &'a str) -> Option<&'a str> {
    text.split_whitespace().last()
}

fn extract_last_elided(text: &str) -> Option<&str> {
    text.split_whitespace().last()
}

/// [규칙 1 예제 3] 첫 라인 추출 (반환값이 입력 참조)
fn first_line_explicit<'a>(text: &'a str) -> Option<&'a str> {
    text.lines().next()
}

fn first_line_elided(text: &str) -> Option<&str> {
    text.lines().next()
}

/// [규칙 3] 두 개 입력 - 명시 필수!
fn longer_in_text<'a>(text: &'a str, marker: &str) -> &'a str {
    text.split(marker).next().unwrap_or(text)
}

// ============================================================================
// [규칙 2] 메서드의 &self가 있을 때 - &self의 수명이 출력에 적용
// ============================================================================

struct Message<'a> {
    content: &'a str,
}

/// [명시적 메서드]
impl<'a> Message<'a> {
    fn new_explicit(content: &'a str) -> Self {
        Message { content }
    }

    fn get_content_explicit(&'a self) -> &'a str {
        self.content
    }

    fn len_explicit(&'a self) -> usize {
        self.content.len()
    }
}

/// [생략된 메서드] - 규칙 2 적용
impl<'a> Message<'a> {
    fn new(content: &'a str) -> Self {
        Message { content }
    }

    /// 컴파일러가 자동으로: fn get_content<'b>(&'b self) -> &'a str으로 해석
    /// (struct의 'a가 &self에 전파되므로)
    fn get_content(&self) -> &'a str {
        self.content
    }

    /// 반환값이 참조가 아니므로 생명주기 무관
    fn len(&self) -> usize {
        self.content.len()
    }

    fn words(&self) -> Vec<&str> {
        self.content.split_whitespace().collect()
    }
}

// ============================================================================
// [규칙 3] 입력이 2개 이상일 때 - 명시 필수!
// ============================================================================

/// [필수 명시] 두 개의 입력 - 어느 것의 수명을 따를지 명확히 해야 함
fn longer<'a>(x: &'a str, y: &'a str) -> &'a str {
    if x.len() > y.len() {
        x
    } else {
        y
    }
}

/// [필수 명시] 메서드 내 다중 매개변수
struct TextMerger;

impl TextMerger {
    /// self와 other 두 개의 참조가 있지만,
    /// 반환값이 String이므로 생명주기 무관
    fn merge_to_string(self_text: &str, other_text: &str) -> String {
        format!("{} {}", self_text, other_text)
    }

    /// [필수 명시] 출력이 참조라면 명시 필수
    fn longer_text<'a>(a: &'a str, b: &'a str) -> &'a str {
        if a.len() > b.len() { a } else { b }
    }
}

// ============================================================================
// [전개된 설계] 텍스트 분석 엔진
// ============================================================================

struct TextAnalyzer<'a> {
    text: &'a str,
}

impl<'a> TextAnalyzer<'a> {
    /// [규칙 2] 메서드 - &self 사용, 생략 가능
    fn new(text: &'a str) -> Self {
        TextAnalyzer { text }
    }

    /// [생략] &self만 있으므로 &'a str로 자동 추론
    fn get_text(&self) -> &'a str {
        self.text
    }

    /// [생략] 반환값이 참조가 아니면 수명 무관
    fn word_count(&self) -> usize {
        self.text.split_whitespace().count()
    }

    /// [생략] Option<&str>은 안전하게 추론됨
    fn first_word(&self) -> Option<&str> {
        self.text.split_whitespace().next()
    }

    /// [생략] Vec은 소유권이므로 생명주기 무관
    fn all_words(&self) -> Vec<&str> {
        self.text.split_whitespace().collect()
    }

    /// [명시 필수] 다른 TextAnalyzer와 비교
    /// 어느 것의 수명을 따를지 명확히 해야 함
    fn longer<'b>(&'a self, other: &'b TextAnalyzer<'b>) -> &'a str
    where
        'b: 'a,
    {
        if self.text.len() > other.text.len() {
            self.text
        } else {
            other.text
        }
    }
}

// ============================================================================
// [고급 예제] 혼합된 시나리오들
// ============================================================================

/// [규칙 1] 단순한 필터링
fn filter_short_lines(text: &str, max_len: usize) -> Option<&str> {
    text.lines().find(|line| line.len() <= max_len)
}

/// [규칙 1] 마지막 단어 추출
fn last_word(text: &str) -> Option<&str> {
    text.split_whitespace().next_back()
}

/// [규칙 2 + 메서드] 로그 항목 파서
struct LogEntry<'a> {
    level: &'a str,
    message: &'a str,
}

impl<'a> LogEntry<'a> {
    /// [생략] 새 항목 생성
    fn parse(line: &'a str) -> Option<Self> {
        let parts: Vec<&str> = line.split('|').collect();
        if parts.len() >= 2 {
            Some(LogEntry {
                level: parts[0].trim(),
                message: parts[1].trim(),
            })
        } else {
            None
        }
    }

    /// [생략] 참조 반환
    fn get_level(&self) -> &str {
        self.level
    }

    /// [생략] 메시지 반환
    fn get_message(&self) -> &str {
        self.message
    }

    /// [명시 필수] 두 항목 비교
    fn is_more_critical<'b>(&'a self, other: &'b LogEntry<'b>) -> bool
    where
        'b: 'a,
    {
        let level_priority = |s: &str| match s {
            "FATAL" => 3,
            "ERROR" => 2,
            "WARN" => 1,
            _ => 0,
        };
        level_priority(self.level) > level_priority(other.level)
    }
}

// ============================================================================
// [검증] 명시적과 생략적이 동일함을 증명
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn rule1_equivalence() {
        let text = "Hello World";

        // 명시적 버전과 생략 버전이 같은 결과를 내는가?
        let result1 = first_word_explicit(text);
        let result2 = first_word_elided(text);

        assert_eq!(result1, result2);
        assert_eq!(result1, "Hello");
    }

    #[test]
    fn rule2_method_equivalence() {
        let my_string = String::from("Welcome to GOGS");

        // 메서드도 동일하게 작동하는가?
        let msg = Message::new(&my_string);
        assert_eq!(msg.get_content(), "Welcome to GOGS");
        assert_eq!(msg.len(), 15);
    }

    #[test]
    fn rule3_multiple_params() {
        let a = "short";
        let b = "much longer";

        let result = longer(a, b);
        assert_eq!(result, "much longer");
    }

    #[test]
    fn analyzer_basic() {
        let text = "The quick brown fox jumps";
        let analyzer = TextAnalyzer::new(text);

        assert_eq!(analyzer.word_count(), 5);
        assert_eq!(analyzer.first_word(), Some("The"));
        assert_eq!(analyzer.get_text(), text);
    }

    #[test]
    fn log_parsing() {
        let line = "ERROR | Database connection failed";
        let entry = LogEntry::parse(line).expect("Failed to parse");

        assert_eq!(entry.get_level(), "ERROR");
        assert_eq!(entry.get_message(), "Database connection failed");
    }
}

