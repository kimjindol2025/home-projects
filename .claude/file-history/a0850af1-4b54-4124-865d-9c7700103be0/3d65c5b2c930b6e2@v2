    use super::*;

    #[test]
    fn test_cognitive_function_creation() {
        let bytecode = vec![
            Instruction::Load { reg: 0 },
            Instruction::Load { reg: 1 },
            Instruction::Add,
            Instruction::Return,
        ];

        let func = CognitiveFunction::new(1, "test_add".to_string(), bytecode);
        assert_eq!(func.paths.len(), 1); // 기본 경로 1개
        println!("✅ Cognitive function creation test passed");
    }

    #[test]
    fn test_path_prediction() {
        let bytecode = vec![Instruction::Add, Instruction::Return];
        let func = CognitiveFunction::new(1, "test_predict".to_string(), bytecode);

        let optimal = func.predict_optimal_path();
        assert_eq!(optimal, PathID(0));
        println!("✅ Path prediction test passed");
    }

    #[test]
    fn test_neural_learning() {
        let bytecode = vec![Instruction::Add, Instruction::Return];
        let mut func = CognitiveFunction::new(1, "test_learning".to_string(), bytecode);
        let context = SystemContext::new();

        // 반복 실행으로 학습
        for _ in 0..5 {
            func.execute_with_inference(&context);
        }

        let score = func.calculate_cognitive_score();
        assert!(score > 0.0);
        println!("✅ Neural learning test passed (Score: {:.2}%)", score);
    }

    #[test]
    fn test_cognitive_scheduler() {
        let bytecode = vec![Instruction::Add, Instruction::Return];
        let func = CognitiveFunction::new(1, "scheduled_func".to_string(), bytecode);

        let mut scheduler = CognitiveScheduler::new();
        scheduler.register_function(func);

        let mut context = SystemContext::new();
        scheduler.execute_all_cognitive(&context);

        let health = scheduler.global_cognitive_health();
        assert!(health > 0.0);
        println!("✅ Cognitive scheduler test passed (Health: {:.2}%)", health);
    }

    #[test]
    fn test_safety_validator() {
        let bytecode = vec![
            Instruction::Load { reg: 0 },
            Instruction::Add,
            Instruction::Return,
        ];

        let result = SafetyValidator::validate_neural_inference(
            PathID(0),
            75.0,
            &bytecode,
        );

        assert!(result.is_ok());
        println!("✅ Safety validator test passed");
    }

    #[test]
    fn test_system_context_thermal() {
        let mut context = SystemContext::new();
        let initial_temp = context.temperature;

        // 부하 증가
        context.simulate_load_change(50.0);
        assert!(context.temperature > initial_temp);
        assert!(context.thermal_throttling);

        println!("✅ System thermal simulation test passed");
        println!("   Temp: {:.1}°C, Load: {:.1}%, Throttling: {}",
                 context.temperature, context.cpu_load, context.thermal_throttling);
    }

    #[test]
    fn test_adaptive_execution() {
        let bytecode = vec![Instruction::Add, Instruction::Return];
        let mut func = CognitiveFunction::new(1, "adaptive".to_string(), bytecode);
        let mut context = SystemContext::new();

        println!("\n  [ADAPTIVE TEST] Simulating workload changes...");

        // Normal load
        for _ in 0..3 {
            func.execute_with_inference(&context);
        }

        // Increasing load
        context.simulate_load_change(30.0);
        for _ in 0..3 {
            func.execute_with_inference(&context);
        }

        // High load
        context.simulate_load_change(25.0);
        for _ in 0..3 {
            func.execute_with_inference(&context);
        }

        let final_score = func.calculate_cognitive_score();
        println!("  Final cognitive score: {:.2}%", final_score);
        println!("✅ Adaptive execution test passed");
    }
}

