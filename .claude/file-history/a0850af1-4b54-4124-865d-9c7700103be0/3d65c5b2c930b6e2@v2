use std::collections::HashMap;
use std::fmt;

/// ============================================================
/// [PART 1] 실행 경로의 신경망 표현
/// ============================================================

/// 실행 경로 ID
#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
pub struct PathID(usize);

impl fmt::Display for PathID {
    fn fmt(&self, f: &mut fmt::Formatter) -> fmt::Result {
        write!(f, "Path#{}", self.0)
    }
}

/// 신경망 노드로서의 명령어
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum Instruction {
    Load { reg: u8 },
    Store { reg: u8 },
    Add,
    Sub,
    Mul,
    Div,
    Branch { path_count: usize },
    Return,
}

/// 경로 실행의 성능 메트릭
#[derive(Debug, Clone)]
pub struct PathProfile {
    pub id: PathID,
    pub execution_count: u64,
    pub success_count: u64,
    pub total_cycles: u64,
    pub avg_latency: f64,
    pub confidence: f64, // 0.0 ~ 1.0
}

impl PathProfile {
    pub fn new(id: PathID) -> Self {
        PathProfile {
            id,
            execution_count: 0,
            success_count: 0,
            total_cycles: 0,
            avg_latency: 0.0,
            confidence: 0.5, // 초기값: 중립
        }
    }

    pub fn success_rate(&self) -> f64 {
        if self.execution_count == 0 {
            0.0
        } else {
            self.success_count as f64 / self.execution_count as f64
        }
    }

    pub fn record_execution(&mut self, cycles: u64, success: bool) {
        self.execution_count += 1;
        if success {
            self.success_count += 1;
        }
        self.total_cycles += cycles;
        self.avg_latency = self.total_cycles as f64 / self.execution_count as f64;

        // 신경망 학습: 성공하면 신뢰도 증가, 실패하면 감소
        if success {
            self.confidence = (self.confidence + 0.05).min(1.0);
        } else {
            self.confidence = (self.confidence - 0.1).max(0.0);
        }
    }
}

/// ============================================================
/// [PART 2] 인지적 함수 (Cognitive Function)
/// ============================================================

pub struct CognitiveFunction {
    id: u64,
    name: String,
    bytecode: Vec<Instruction>,
    paths: HashMap<PathID, PathProfile>,
    weights: HashMap<PathID, f32>, // 신경망 가중치
    execution_history: Vec<(PathID, bool, u64)>, // (경로, 성공, 사이클)
    learning_rate: f32,
    generation: u32, // 학습 세대
}

impl CognitiveFunction {
    pub fn new(id: u64, name: String, bytecode: Vec<Instruction>) -> Self {
        let path_count = bytecode
            .iter()
            .filter(|instr| matches!(instr, Instruction::Branch { .. }))
            .count()
            + 1; // 기본 경로

        let mut paths = HashMap::new();
        let mut weights = HashMap::new();

        for i in 0..path_count {
            let path_id = PathID(i);
            paths.insert(path_id, PathProfile::new(path_id));
            weights.insert(path_id, 1.0 / path_count as f32); // 균등 초기화
        }

        CognitiveFunction {
            id,
            name,
            bytecode,
            paths,
            weights,
            execution_history: Vec::new(),
            learning_rate: 0.1,
            generation: 0,
        }
    }

    /// 신경망 추론을 통한 최적 경로 선택
    pub fn predict_optimal_path(&self) -> PathID {
        self.weights
            .iter()
            .max_by(|a, b| a.1.partial_cmp(b.1).unwrap())
            .map(|(id, _)| *id)
            .unwrap_or(PathID(0))
    }

    /// 인지적 실행: 가중치 기반 경로 선택
    pub fn execute_with_inference(&mut self, context: &SystemContext) -> ExecutionResult {
        let optimal_path = self.predict_optimal_path();

        println!(
            "  [NEURAL] Function '{}' analyzing execution context...",
            self.name
        );
        println!("           System temp: {}°C, Load: {:.1}%", context.temperature, context.cpu_load);
        println!("           Predicted optimal path: {} (weight: {:.3})",
                 optimal_path,
                 self.weights[&optimal_path]);

        // 경로 실행 시뮬레이션
        let cycles = ((self.weights[&optimal_path] * 100.0) as u64).max(10);
        let success = context.cpu_load < 80.0; // CPU 부하가 낮으면 성공 가능성 높음

        // 실행 결과 기록
        self.execution_history
            .push((optimal_path, success, cycles));

        // 경로 프로필 업데이트
        if let Some(profile) = self.paths.get_mut(&optimal_path) {
            profile.record_execution(cycles, success);
            println!(
                "           Path {} executed: {} (latency: {:.2}ns, success_rate: {:.1}%)",
                optimal_path,
                if success { "✅" } else { "❌" },
                profile.avg_latency,
                profile.success_rate() * 100.0
            );
        }

        // Backpropagation: 가중치 학습
        self.update_weights_backprop(optimal_path, success);

        ExecutionResult {
            path: optimal_path,
            success,
            cycles,
            cognitive_score: self.calculate_cognitive_score(),
        }
    }

    /// Backpropagation을 통한 가중치 학습
    fn update_weights_backprop(&mut self, executed_path: PathID, success: bool) {
        let adjustment = if success {
            self.learning_rate * 0.05 // 성공 시 작은 증가
        } else {
            -self.learning_rate * 0.1 // 실패 시 더 큰 감소
        };

        // 실행된 경로의 가중치 조정
        if let Some(weight) = self.weights.get_mut(&executed_path) {
            *weight += adjustment;
        }

        // 정규화: 모든 가중치 합 = 1.0
        self.normalize_weights();

        self.generation += 1;
    }

    /// 가중치 정규화
    fn normalize_weights(&mut self) {
        let sum: f32 = self.weights.values().sum();
        if sum > 0.0 {
            for weight in self.weights.values_mut() {
                *weight /= sum;
            }
        }
    }

    /// 인지적 점수 계산 (전체 신경망 건강도)
    pub fn calculate_cognitive_score(&self) -> f64 {
        if self.paths.is_empty() {
            return 0.0;
        }

        let avg_confidence: f64 = self.paths
            .values()
            .map(|p| p.confidence)
            .sum::<f64>()
            / self.paths.len() as f64;

        let avg_success_rate: f64 = self.paths
            .values()
            .map(|p| p.success_rate())
            .sum::<f64>()
            / self.paths.len() as f64;

        (avg_confidence * 0.4 + avg_success_rate * 0.6) * 100.0
    }

    /// 신경망 상태 리포트
    pub fn report(&self) -> String {
        let mut report = format!(
            "CognitiveFunction '{}' (Gen: {})\n",
            self.name, self.generation
        );
        report.push_str(&format!("  Cognitive Score: {:.2}%\n", self.calculate_cognitive_score()));
        report.push_str(&format!("  Paths: {}\n", self.paths.len()));

        for (path_id, profile) in &self.paths {
            let weight = self.weights[path_id];
            report.push_str(&format!(
                "    {} - Weight: {:.3}, Executions: {}, Success Rate: {:.1}%, Avg Latency: {:.2}ns\n",
                path_id,
                weight,
                profile.execution_count,
                profile.success_rate() * 100.0,
                profile.avg_latency
            ));
        }

        report
    }
}

/// 실행 결과
#[derive(Debug, Clone)]
pub struct ExecutionResult {
    pub path: PathID,
    pub success: bool,
    pub cycles: u64,
    pub cognitive_score: f64,
}

/// ============================================================
/// [PART 3] 시스템 컨텍스트 (열역학적 상태)
/// ============================================================

pub struct SystemContext {
    pub temperature: f32,      // CPU 온도
    pub cpu_load: f32,         // CPU 부하 %
    pub memory_pressure: f32,  // 메모리 압력 %
    pub thermal_throttling: bool,
}

impl SystemContext {
    pub fn new() -> Self {
        SystemContext {
            temperature: 35.0,
            cpu_load: 45.0,
            memory_pressure: 30.0,
            thermal_throttling: false,
        }
    }

    /// 시스템 상태 동적 변화
    pub fn simulate_load_change(&mut self, delta: f32) {
        self.cpu_load = (self.cpu_load + delta).max(0.0).min(100.0);
        self.temperature = 25.0 + (self.cpu_load / 100.0) * 50.0; // 25~75°C
        self.thermal_throttling = self.temperature > 70.0;
    }
}

/// ============================================================
/// [PART 4] 인지적 스케줄러 (Cognitive Scheduler)
/// ============================================================

pub struct CognitiveScheduler {
    functions: HashMap<u64, CognitiveFunction>,
    global_cognitive_state: Vec<f64>, // 전역 신경망 상태
    execution_log: Vec<String>,
}

impl CognitiveScheduler {
    pub fn new() -> Self {
        CognitiveScheduler {
            functions: HashMap::new(),
            global_cognitive_state: vec![0.5; 10], // 10개 신경망 뉴런
            execution_log: Vec::new(),
        }
    }

    pub fn register_function(&mut self, func: CognitiveFunction) {
        self.functions.insert(func.id, func);
    }

    /// 모든 함수를 인지적으로 실행
    pub fn execute_all_cognitive(&mut self, context: &SystemContext) {
        println!("\n[COGNITIVE SCHEDULER] Starting intelligent execution cycle...");

        for (_id, func) in self.functions.iter_mut() {
            let result = func.execute_with_inference(context);

            // 전역 신경망 상태 업데이트
            let score = result.cognitive_score / 100.0;
            self.global_cognitive_state[result.path.0 % 10] = score;

            self.execution_log.push(format!(
                "Function '{}': {} - Score: {:.2}%",
                func.name, if result.success { "SUCCESS" } else { "FAILED" }, result.cognitive_score
            ));
        }

        println!("[COGNITIVE SCHEDULER] Execution cycle complete");
    }

    /// 전역 신경망 상태
    pub fn global_cognitive_health(&self) -> f64 {
        let sum: f64 = self.global_cognitive_state.iter().sum();
        (sum / self.global_cognitive_state.len() as f64) * 100.0
    }

    pub fn report(&self) -> String {
        let mut report = format!(
            "Cognitive Scheduler Report\n  Global Health: {:.2}%\n",
            self.global_cognitive_health()
        );

        for func in self.functions.values() {
            report.push_str(&func.report());
        }

        report.push_str("\nExecution Log:\n");
        for log in &self.execution_log {
            report.push_str(&format!("  {}\n", log));
        }

        report
    }
}

/// ============================================================
/// [PART 5] 안전성 검증기 (Safety Validator)
/// ============================================================

/// 인지적 실행의 안전성을 보증
pub struct SafetyValidator;

impl SafetyValidator {
    /// 신경망 추론 결과가 Rust 안전성을 위배하지 않는지 검증
    pub fn validate_neural_inference(
        path: PathID,
        cognitive_score: f64,
        bytecode: &[Instruction],
    ) -> Result<(), String> {
        // 인지 점수가 너무 낮으면 안전하지 않음
        if cognitive_score < 40.0 {
            return Err(format!(
                "Neural inference confidence too low: {:.2}%",
                cognitive_score
            ));
        }

        // 바이트코드 유효성 검사
        for (i, instr) in bytecode.iter().enumerate() {
            match instr {
                Instruction::Load { reg } | Instruction::Store { reg } => {
                    if *reg >= 16 {
                        return Err(format!("Invalid register at instruction {}: {}", i, reg));
                    }
                }
                Instruction::Div => {
                    // Division by zero 검사는 컴파일 타임에 필요
                }
                _ => {}
            }
        }

        println!(
            "  [SAFETY] Neural inference for {} validated ✅ (Score: {:.2}%)",
            path, cognitive_score
        );
        Ok(())
    }
}

