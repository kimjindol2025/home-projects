"""
Python Middle School v1.8 - 튜플(Tuple)과 집합(Set) — 데이터의 안전성과 고유성

탐구(중학교): "데이터에 성격 부여하기"

딕셔너리가 '이름표'로 데이터를 관리했다면,
이번에는 "절대 변하지 않는 기록"과 "중복을 허용하지 않는 엄격한 모음"에 대해 배웁니다.

1. 튜플 (Tuple): "수정할 수 없는 리스트"
   - 기호: 소괄호 ( )
   - 특징: 한 번 만들면 내용을 바꿀 수 없음 (Immutable)
   - 용도: 절대로 변해서는 안 되는 중요한 값 보호
   - 예: 좌표, 설정값, 색상코드

2. 집합 (Set): "중복은 허용하지 않는다"
   - 기호: 중괄호 { } (딕셔너리와 같지만 키-값 쌍 아님)
   - 특징: 중복된 데이터를 하나만 유지, 순서 없음
   - 용도: 중복 제거, 합집합/교집합 같은 수학적 계산
"""

print("=" * 70)
print("# Python Middle School v1.8 - 튜플과 집합")
print("=" * 70)

# ============================================================================
# [1단계] 튜플 기본 - 순서쌍 데이터
# ============================================================================

print("\n[1단계] 튜플 기본 - 불변의 데이터")
print("-" * 70)

# 소괄호 ()로 생성
location = (37.5665, 126.9780)  # 서울의 위도, 경도
color = (255, 128, 0)            # RGB 색상
date = (2024, 2, 24)             # 년, 월, 일

print("튜플 생성:")
print(f"  위치 정보: {location}")
print(f"  색상 코드: {color}")
print(f"  날짜: {date}")

print("\n튜플 접근:")
print(f"  latitude: {location[0]}")
print(f"  longitude: {location[1]}")
print(f"  R값: {color[0]}, G값: {color[1]}, B값: {color[2]}")

# ============================================================================
# [2단계] 튜플의 특징 - 변경 불가 (Immutable)
# ============================================================================

print("\n[2단계] 튜플의 가장 중요한 특징 - 변경할 수 없음")
print("-" * 70)

print("리스트는 변경 가능:")
my_list = [1, 2, 3]
print(f"  원본: {my_list}")
my_list[0] = 999
print(f"  변경 후: {my_list} ✓ 성공!")

print("\n튜플은 변경 불가능 (시도):")
my_tuple = (1, 2, 3)
print(f"  원본: {my_tuple}")
try:
    my_tuple[0] = 999
except TypeError as e:
    print(f"  변경 시도 → 에러 발생! ✗")
    print(f"  오류 메시지: {e}")

print("\n설명:")
print("  ✓ 튜플의 값은 절대로 변경할 수 없습니다 (Immutable)")
print("  ✓ 이것이 중요한 데이터를 보호하는 방법입니다.")

# ============================================================================
# [3단계] 튜플 압축 해제 (Unpacking)
# ============================================================================

print("\n[3단계] 튜플 압축 해제 - 여러 변수에 동시 할당")
print("-" * 70)

# 튜플의 값들을 각각의 변수에 할당
x, y = (10, 20)
print(f"x, y = (10, 20)")
print(f"  x = {x}")
print(f"  y = {y}")

r, g, b = (255, 128, 0)
print(f"\nr, g, b = (255, 128, 0)")
print(f"  빨강: {r}, 초록: {g}, 파랑: {b}")

print("\n설명:")
print("  ✓ 튜플의 원소를 한 번에 여러 변수에 할당할 수 있습니다.")
print("  ✓ 이를 '언팩킹(Unpacking)'이라고 합니다.")

# ============================================================================
# [4단계] 집합 기본 - 중복 제거
# ============================================================================

print("\n[4단계] 집합 기본 - 중복 제거의 마법")
print("-" * 70)

# 리스트에 중복된 데이터
raw_samples = ["철", "구리", "철", "금", "구리", "은"]
print(f"원래 수집된 샘플: {raw_samples}")
print(f"  개수: {len(raw_samples)}")

# set()으로 집합 변환 → 중복 제거!
unique_samples = set(raw_samples)
print(f"\n중복 제거 후 (set 변환):")
print(f"  종류: {unique_samples}")
print(f"  개수: {len(unique_samples)}")

print("\n설명:")
print("  ✓ set()으로 변환하면 자동으로 중복이 제거됩니다.")
print("  ✓ 집합은 순서가 없습니다 (순서 보장 안 됨).")

# ============================================================================
# [5단계] 집합 생성 방법
# ============================================================================

print("\n[5단계] 집합 생성 방법")
print("-" * 70)

# 직접 생성
set1 = {"python", "javascript", "java"}
print(f"직접 생성: {set1}")

# set() 함수 사용
set2 = set([1, 2, 2, 3, 3, 3])
print(f"set() 함수: {set2}")

# 리스트에서 변환
my_list = ["apple", "banana", "apple", "cherry"]
set3 = set(my_list)
print(f"리스트 → 집합: {set3}")

# ============================================================================
# [6단계] 집합 연산 - 교집합 (교점)
# ============================================================================

print("\n[6단계] 집합 연산 - 교집합 (공통 원소)")
print("-" * 70)

science_club = {"Alice", "Bob", "Charlie"}
art_club = {"Bob", "Charlie", "David"}

print(f"과학 동아리: {science_club}")
print(f"미술 동아리: {art_club}")

intersection = science_club & art_club  # & 기호로 교집합
print(f"\n두 동아리 모두 가입한 학생 (교집합):")
print(f"  science_club & art_club = {intersection}")

print("\n설명:")
print("  ✓ & 기호로 교집합을 구합니다.")
print("  ✓ 두 집합에 모두 포함된 원소만 남습니다.")

# ============================================================================
# [7단계] 집합 연산 - 합집합
# ============================================================================

print("\n[7단계] 집합 연산 - 합집합 (모든 원소)")
print("-" * 70)

union = science_club | art_club  # | 기호로 합집합
print(f"동아리 전체 가입자 (합집합):")
print(f"  science_club | art_club = {union}")

print("\n설명:")
print("  ✓ | 기호로 합집합을 구합니다.")
print("  ✓ 두 집합의 모든 원소를 포함합니다 (중복 제거됨).")

# ============================================================================
# [8단계] 집합 연산 - 차집합
# ============================================================================

print("\n[8단계] 집합 연산 - 차집합 (한쪽에만 있는 것)")
print("-" * 70)

science_only = science_club - art_club
art_only = art_club - science_club

print(f"과학 동아리에만 가입한 학생:")
print(f"  science_club - art_club = {science_only}")

print(f"\n미술 동아리에만 가입한 학생:")
print(f"  art_club - science_club = {art_only}")

print("\n설명:")
print("  ✓ - 기호로 차집합을 구합니다.")
print("  ✓ 첫 번째 집합에서 두 번째 집합에 있는 원소를 뺍니다.")

# ============================================================================
# [9단계] 집합 연산 - 대칭차집합
# ============================================================================

print("\n[9단계] 집합 연산 - 대칭차집합 (한쪽에만 있는 모든 것)")
print("-" * 70)

symmetric_diff = science_club ^ art_club  # ^ 기호로 대칭차집합
print(f"정확히 한 동아리에만 가입한 학생:")
print(f"  science_club ^ art_club = {symmetric_diff}")

print("\n설명:")
print("  ✓ ^ 기호로 대칭차집합을 구합니다.")
print("  ✓ 한쪽 집합에만 있고 다른 쪽에는 없는 원소들입니다.")

# ============================================================================
# [10단계] 집합 메서드 - 추가와 제거
# ============================================================================

print("\n[10단계] 집합 메서드 - 원소 추가 및 제거")
print("-" * 70)

my_set = {"python", "java"}
print(f"원본 집합: {my_set}")

# 추가
my_set.add("javascript")
print(f"add('javascript') 후: {my_set}")

# 제거
my_set.remove("java")
print(f"remove('java') 후: {my_set}")

print("\n설명:")
print("  ✓ .add(): 집합에 원소 추가")
print("  ✓ .remove(): 집합에서 원소 제거")

# ============================================================================
# [11단계] 튜플 vs 리스트
# ============================================================================

print("\n[11단계] 튜플 vs 리스트 비교")
print("-" * 70)

print("리스트 (List):")
list_data = [1, 2, 3]
print(f"  생성: [1, 2, 3]")
print(f"  수정 가능: list_data[0] = 999 ✓")
print(f"  용도: 자주 변하는 데이터")

print("\n튜플 (Tuple):")
tuple_data = (1, 2, 3)
print(f"  생성: (1, 2, 3)")
print(f"  수정 불가능: tuple_data[0] = 999 ✗")
print(f"  용도: 절대 변하면 안 되는 데이터")

# ============================================================================
# [12단계] 실용 예제 - 학생 정보 보호
# ============================================================================

print("\n[12단계] 실용 예제: 학생 정보 보호 시스템")
print("-" * 70)

# 학번은 절대 변해서는 안 됨 (튜플)
student_id = (2024, 1, 15)  # 년도, 학년, 학번
print(f"학번 (튜플): {student_id}")

# 수강 과목 (중복 제거 필요하므로 집합)
enrolled_courses = ["수학", "영어", "과학", "수학", "영어", "사회"]
unique_courses = set(enrolled_courses)
print(f"수강 과목 (중복 제거): {unique_courses}")

print("\n설명:")
print("  ✓ 학번 같은 고정값은 튜플로 보호")
print("  ✓ 과목 목록 같은 중복 가능한 데이터는 집합으로 관리")

# ============================================================================
# [최종 증명]
# ============================================================================

print("\n" + "=" * 70)
print("# [최종 증명] 튜플과 집합의 역할")
print("=" * 70)

print("""
✓ [튜플의 역할]
  형태: (원소1, 원소2, 원소3)
  특징: 불변(Immutable) - 절대 변경 불가
  장점: 안전성, 속도, 메모리 효율
  용도:
    - 고정 좌표 (위도, 경도)
    - 고정 색상 (R, G, B)
    - 고정 설정값

