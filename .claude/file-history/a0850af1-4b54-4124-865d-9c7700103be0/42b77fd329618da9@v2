// Demo 5: quote! 매크로로 코드 생성 (개념)
// =============================================================================

/// quote! 매크로의 개념 설명
struct QuoteExplained;

impl QuoteExplained {
    fn explain() {
        println!("\n=== Demo 5: quote! 매크로 (코드 생성) ===");

        println!("  [quote!의 역할]");
        println!("    새로운 Rust 코드를 문자열처럼 작성");
        println!("    변수를 #{{}} 형태로 삽입");
        println!("    결과는 TokenStream으로 반환");

        println!("\n  [기본 사용법]");
        println!("    let name = syn::Ident::new(\"MyStruct\", Span::call_site());");
        println!("    ");
        println!("    let expanded = quote! {{");
        println!("        impl MyTrait for #name {{");
        println!("            fn method(&self) {{");
        println!("                println!(\"Hello from {{}}\", stringify!(#name));");
        println!("            }}");
        println!("        }}");
        println!("    }};");
        println!("");
        println!("    // expanded는 TokenStream으로 변환됨");

        println!("\n  [반복 처리]");
        println!("    let fields: Vec<_> = /* 필드 목록 */;");
        println!("    ");
        println!("    let expanded = quote! {{");
        println!("        impl MyTrait for MyStruct {{");
        println!("            fn print_all(&self) {{");
        println!("                #(");
        println!("                    println!(\"{{}} = {{}}\", stringify!(#fields), self.#fields);");
        println!("                )*");
        println!("            }}");
        println!("        }}");
        println!("    }};");
        println!("");
        println!("    // #(...)*는 for 루프처럼 각 필드 반복");

        println!("\n  [생성되는 코드 (예시)]");
        println!("    impl MyTrait for MyStruct {{");
        println!("        fn print_all(&self) {{");
        println!("            println!(\"id = {{}}\", self.id);");
        println!("            println!(\"name = {{}}\", self.name);");
        println!("            println!(\"email = {{}}\", self.email);");
        println!("        }}");
        println!("    }}");
    }
}

