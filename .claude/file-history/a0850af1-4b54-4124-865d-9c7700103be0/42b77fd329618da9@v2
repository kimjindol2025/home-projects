// Demo 1: Derive 매크로의 개념 (실제 구현 예시)
// =============================================================================

// 이것이 절차적 매크로라면 어떤 코드를 생성할까?
// 아래는 '매크로가 생성할 코드'를 수동으로 작성한 것입니다.

/// 절차적 매크로 #[derive(GogsInfo)]가 생성하는 코드
///
/// 사용:
/// ```ignore
/// #[derive(GogsInfo)]
/// struct User {
///     id: u32,
///     name: String,
/// }
/// ```
///
/// 생성되는 코드:
trait GogsInfoTemplate {
    fn print_gogs_info(&self);
    fn get_metadata(&self) -> (String, String);
}

struct TemplateUser {
    id: u32,
    name: String,
}

impl GogsInfoTemplate for TemplateUser {
    fn print_gogs_info(&self) {
        println!("\n╔════════════════════════════════════════╗");
        println!("║  Struct: TemplateUser                  ║");
        println!("║  메타 정보 자동 주입됨 (매크로)       ║");
        println!("╚════════════════════════════════════════╝");
        println!("  필드명: 'id'     | 값: {}", self.id);
        println!("  필드명: 'name'   | 값: {}", self.name);
        println!("  생성일: 2026-02-23");
        println!("  저장 필수 너는 기록이 증명이다 gogs");
    }

    fn get_metadata(&self) -> (String, String) {
        (
            format!("TemplateUser"),
            format!("fields: id, name")
        )
    }
}

fn demo_derive_macro_concept() {
    println!("\n=== Demo 1: Derive 매크로 개념 ===");

    println!("  [절차적 매크로의 역할]");
    println!("    입력: #[derive(GogsInfo)]");
    println!("         struct User {{ id: u32, name: String }}");
    println!("      ↓");
    println!("    처리 (컴파일 시점):");
    println!("      • syn으로 구조체 정보 파싱");
    println!("      • 구조체명, 필드명, 필드타입 추출");
    println!("      • quote!로 메서드 생성");
    println!("      ↓");
    println!("    출력: impl GogsInfo for User {{ ... }}");

    println!("\n  [실제 동작]");
    let user = TemplateUser {
        id: 42,
        name: "Kim".to_string(),
    };
    user.print_gogs_info();

    let (struct_name, fields_info) = user.get_metadata();
    println!("\n  [메타데이터 추출]");
    println!("    구조체: {}", struct_name);
    println!("    필드 정보: {}", fields_info);
}

