// Demo 4: syn 라이브러리로 AST 파싱 (개념)
// =============================================================================

/// syn 라이브러리의 핵심 개념
struct SynExplained;

impl SynExplained {
    fn explain() {
        println!("\n=== Demo 4: syn 라이브러리 (구문 분석) ===");

        println!("  [syn의 역할]");
        println!("    TokenStream → 구조화된 데이터(AST)");
        println!("    복잡한 토큰 스트림을 이해 가능한 형태로 변환");

        println!("\n  [주요 타입]");
        println!("    syn::DeriveInput");
        println!("      ├─ ident: 구조체/열거형 이름");
        println!("      ├─ generics: 제네릭 파라미터");
        println!("      └─ data: 필드/변수 정보");
        println!("");
        println!("    syn::ItemFn");
        println!("      ├─ sig: 함수 서명 (이름, 파라미터, 반환타입)");
        println!("      └─ block: 함수 본문");
        println!("");
        println!("    syn::Field");
        println!("      ├─ ident: 필드명");
        println!("      └─ ty: 필드 타입");

        println!("\n  [파싱 과정]");
        println!("    1. let ast = syn::parse::<syn::DeriveInput>(input)?;");
        println!("       → TokenStream을 DeriveInput으로 파싱");
        println!("");
        println!("    2. let name = &ast.ident;");
        println!("       → 구조체 이름 추출: 'User'");
        println!("");
        println!("    3. if let syn::Data::Struct(data) = &ast.data {{");
        println!("         for field in &data.fields {{");
        println!("           println!(\"필드: {{}}\", field.ident);");
        println!("         }}");
        println!("       }}");
        println!("       → 모든 필드 순회");

        println!("\n  [실제 추출 예시]");
        println!("    입력 구조체:");
        println!("      struct User {{");
        println!("        id: u32,");
        println!("        name: String,");
        println!("        email: String,");
        println!("      }}");
        println!("");
        println!("    syn이 추출하는 정보:");
        println!("      struct_name = \"User\"");
        println!("      fields = [");
        println!("        Field {{ ident: \"id\", ty: \"u32\" }},");
        println!("        Field {{ ident: \"name\", ty: \"String\" }},");
        println!("        Field {{ ident: \"email\", ty: \"String\" }},");
        println!("      ]");
    }
}

