/// 절차적 매크로 프로젝트 구조 설명
struct ProjectStructureDemo;

impl ProjectStructureDemo {
    fn show_structure() {
        println!("\n=== Demo 6: 절차적 매크로 프로젝트 구조 ===");

        println!("  [디렉토리 구조]");
        println!("    my_project/");
        println!("    ├── Cargo.toml");
        println!("    ├── src/");
        println!("    │   └── lib.rs              (메인 크레이트)");
        println!("    └── my_project_macros/     (절차적 매크로 크레이트)");
        println!("        ├── Cargo.toml");
        println!("        └── src/");
        println!("            └── lib.rs          (매크로 정의)");

        println!("\n  [메인 Cargo.toml]");
        println!("    [package]");
        println!("    name = \"my_project\"");
        println!("    ");
        println!("    [dependencies]");
        println!("    my_project_macros = {{ path = \"my_project_macros\" }}");

        println!("\n  [매크로 Cargo.toml (중요!)]");
        println!("    [package]");
        println!("    name = \"my_project_macros\"");
        println!("    ");
        println!("    [lib]");
        println!("    proc-macro = true    ← 핵심: 절차적 매크로 크레이트 선언");
        println!("    ");
        println!("    [dependencies]");
        println!("    proc-macro2 = \"1.0\"");
        println!("    quote = \"1.0\"");
        println!("    syn = {{ version = \"2.0\", features = [\"full\"] }}");

        println!("\n  [메인 크레이트 사용]");
        println!("    // src/lib.rs");
        println!("    use my_project_macros::*;");
        println!("    ");
        println!("    #[derive(MyTrait)]");
        println!("    struct User {{");
        println!("        id: u32,");
        println!("        name: String,");
        println!("    }}");

        println!("\n  [컴파일 순서]");
        println!("    1. my_project_macros 크레이트 컴파일");
        println!("       (절차적 매크로 함수들이 별도 프로그램으로 컴파일)");
        println!("    ");
        println!("    2. my_project 크레이트 분석");
        println!("       (#[derive(MyTrait)] 등 발견)");
        println!("    ");
        println!("    3. my_project_macros 프로그램 실행");
        println!("       (TokenStream 입력 → 새 코드 생성)");
        println!("    ");
        println!("    4. 생성된 코드 주입 + 컴파일");

        println!("\n  [중요 포인트]");
        println!("    • proc-macro = true가 핵심");
        println!("    • 별도 크레이트 필수");
        println!("    • 컴파일 시간에 매크로 함수 실행");
        println!("    • syn, quote, proc-macro2 모두 필수 의존성");
    }
}

