/// 절차적 매크로 파이프라인 시뮬레이션
struct MacroPipeline;

impl MacroPipeline {
    fn explain_pipeline() {
        println!("\n=== Demo 2: 절차적 매크로 파이프라인 ===");

        println!("  [단계 1: 입력 (TokenStream)]");
        println!("    #[derive(GogsInfo)]");
        println!("    struct Product {{");
        println!("        id: u32,");
        println!("        title: String,");
        println!("        price: f64,");
        println!("    }}");

        println!("\n  [단계 2: 파싱 (syn 라이브러리)]");
        println!("    TokenStream을 구조화된 데이터(AST)로 변환");
        println!("    추출 정보:");
        println!("      • 구조체명: Product");
        println!("      • 필드 1: id (타입: u32)");
        println!("      • 필드 2: title (타입: String)");
        println!("      • 필드 3: price (타입: f64)");

        println!("\n  [단계 3: 분석 및 변환 (Rust 함수)]");
        println!("    각 필드에 대해 코드 생성:");
        println!("      • println!(\"id: {{}}\", self.id);");
        println!("      • println!(\"title: {{}}\", self.title);");
        println!("      • println!(\"price: {{}}\", self.price);");

        println!("\n  [단계 4: 코드 생성 (quote! 매크로)]");
        println!("    새로운 Rust 코드 작성");
        println!("    impl GogsInfo for Product {{");
        println!("        fn print_info(&self) {{");
        println!("            println!(\"...\");");
        println!("            // 필드별로 반복되는 코드");
        println!("        }}");
        println!("    }}");

        println!("\n  [단계 5: 출력 (TokenStream)]");
        println!("    생성된 코드가 메인 크레이트에 주입됨");
        println!("    컴파일러는 전체 코드를 일반 Rust 코드로 컴파일");

        println!("\n  [핵심]");
        println!("    • 입력과 출력 모두 TokenStream");
        println!("    • 중간에는 Rust 함수로 원하는 대로 처리");
        println!("    • 마치 컴파일러 내부 파이프라인과 동일");
    }
}

