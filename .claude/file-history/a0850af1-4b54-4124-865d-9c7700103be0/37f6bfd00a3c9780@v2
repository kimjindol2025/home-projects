    def generate_security_report(self):
        """보안 보고서 생성"""
        print("\n" + "="*80)
        print("【 🛡️  보안 종합 평가 】")
        print("="*80 + "\n")

        print("현재 보안 수준: ⭐⭐⭐⭐☆ (4/5) - 양호")
        print("\n✅ 강점:")
        print("   • SQL 인젝션 방지 (매개변수화)")
        print("   • 기본 데이터 검증")
        print("   • Flask 자동 이스케이프")
        print("   • 데이터베이스 제약조건")

        print("\n⚠️  개선 필요:")
        print("   • 인증 메커니즘 추가 (높음)")
        print("   • CSRF 보호 추가 (중간)")
        print("   • API 레이트 제한 (중간)")
        print("   • 감사 로깅 강화 (중간)")

        print("\n📊 취약점 요약:")
        for i, fix in enumerate(self.fixes, 1):
            print(f"\n   {i}. [{fix['severity']}] {fix['issue']}")
            print(f"      → {fix['recommendation']}")

    def export_report(self):
        """보고서 저장"""
        report = {
            'timestamp': datetime.now().isoformat(),
            'overall_score': '4/5',
            'status': '양호 - 프로덕션 배포 전 개선 필요',
            'findings': self.fixes,
            'recommendations': [
                'JWT 기반 인증 시스템 구현',
                'CSRF 토큰 추가',
                'API 레이트 제한',
                'HTTPS 적용',
                '감사 로깅 강화',
                'WAF(Web Application Firewall) 고려'
            ]
        }

        import json
        with open('security_report.json', 'w', encoding='utf-8') as f:
            json.dump(report, f, indent=2, ensure_ascii=False)

        print(f"\n✅ 보안 보고서 저장: security_report.json")


def main():
