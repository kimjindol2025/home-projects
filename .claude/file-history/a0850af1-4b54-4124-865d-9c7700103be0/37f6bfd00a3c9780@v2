            'recommendation': 'Flask-JWT 확장 추가'
        })

    def check_data_validation(self):
        """데이터 검증"""
        print("\n" + "="*80)
        print("【 ✅ 데이터 검증 】")
        print("="*80 + "\n")

        validations = [
            ('이메일 형식', '정규표현식 검증', '✅'),
            ('전화번호 형식', '010-XXXX-XXXX 패턴', '✅'),
            ('학번 형식', '7자리 숫자', '✅'),
            ('성적 범위', '0-100', '✅'),
            ('출석 상태', 'CHECK 제약조건', '✅'),
            ('학년 범위', '1-4', '⚠️ (클라이언트만)'),
        ]

        for field, method, status in validations:
            print(f"{status} {field:20} {method}")

