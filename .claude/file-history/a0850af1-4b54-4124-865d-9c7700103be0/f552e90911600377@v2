/* ==================== 기본 스타일 ==================== */

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

:root {
    --primary: #007bff;
    --success: #28a745;
    --info: #17a2b8;
    --warning: #ffc107;
    --danger: #dc3545;
    --light: #f8f9fa;
    --dark: #343a40;
    --gray: #6c757d;
    --border: #dee2e6;
    --shadow: 0 2px 8px rgba(0,0,0,0.1);
    --shadow-lg: 0 4px 12px rgba(0,0,0,0.15);
}

html {
    scroll-behavior: smooth;
}

body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    color: #333;
    background: #f5f7fa;
    line-height: 1.6;
}

.container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1rem;
}

/* ==================== 네비게이션 ==================== */

.navbar {
    background: white;
    border-bottom: 2px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: var(--shadow);
}

.navbar .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem;
    gap: 2rem;
}

.navbar-brand {
    display: flex;
    align-items: center;
}

.navbar-title {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--primary);
    text-decoration: none;
    transition: color 0.3s;
}

.navbar-title:hover {
    color: var(--dark);
}

.navbar-menu {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
}

.nav-link {
    padding: 0.5rem 1rem;
    color: #666;
    text-decoration: none;
    border-radius: 4px;
    transition: all 0.3s;
    font-size: 0.95rem;
}

.nav-link:hover,
.nav-link.active {
    background: var(--light);
    color: var(--primary);
    font-weight: 600;
}

.nav-button {
    background: var(--primary);
    color: white;
    font-weight: 600;
}

.nav-button:hover {
    background: #0056b3;
}

/* ==================== 메인 컨텐츠 ==================== */

.main-content {
    min-height: calc(100vh - 120px);
    padding: 2rem 0;
}

/* ==================== 페이지 제목 ==================== */

.page-title {
    font-size: 2rem;
    color: var(--dark);
    margin-bottom: 2rem;
    text-align: center;
}

.page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
}

.info-text {
    font-size: 1rem;
    color: var(--gray);
}

/* ==================== 통계 카드 ==================== */

.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
}

.stat-card {
    background: white;
    padding: 2rem;
    border-radius: 8px;
    box-shadow: var(--shadow);
    display: flex;
    align-items: center;
    gap: 1.5rem;
    transition: transform 0.3s, box-shadow 0.3s;
}

.stat-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
}

.stat-icon {
    font-size: 2.5rem;
    min-width: 60px;
    text-align: center;
}

.stat-content h3 {
    font-size: 0.9rem;
    color: var(--gray);
    margin-bottom: 0.5rem;
}

.stat-number {
    font-size: 2rem;
    font-weight: bold;
    color: var(--primary);
}

.stat-link {
    display: inline-block;
    margin-top: 0.5rem;
    color: var(--primary);
    text-decoration: none;
    font-size: 0.9rem;
    transition: all 0.3s;
}

.stat-link:hover {
    transform: translateX(4px);
}

/* ==================== 기능 섹션 ==================== */

.features-section,
.tech-info,
.quick-access {
    margin: 3rem 0;
}

.features-section h2,
.tech-info h2,
.quick-access h2 {
    font-size: 1.5rem;
    color: var(--dark);
    margin-bottom: 1.5rem;
}

.features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
}

.feature-card {
    background: white;
    padding: 1.5rem;
    border-radius: 8px;
    border-left: 4px solid var(--primary);
    box-shadow: var(--shadow);
    transition: all 0.3s;
}

.feature-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
}

.feature-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
}

.feature-card h3 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
    color: var(--dark);
}

.feature-card p {
    font-size: 0.9rem;
    color: var(--gray);
}

/* ==================== 기술 정보 ==================== */

.tech-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1rem;
}

.tech-item {
    display: flex;
    gap: 1rem;
    align-items: center;
    padding: 1rem;
    background: white;
    border-radius: 6px;
    border-left: 3px solid var(--primary);
}

.tech-label {
    font-weight: 600;
    color: var(--gray);
    min-width: 80px;
}

.tech-value {
    color: var(--dark);
}

/* ==================== 버튼 ==================== */

.button-group {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
}

.btn {
    padding: 0.5rem 1rem;
    border: none;
    border-radius: 4px;
    text-decoration: none;
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 500;
    transition: all 0.3s;
    display: inline-block;
    text-align: center;
}

.btn-primary {
    background: var(--primary);
    color: white;
}

.btn-primary:hover {
    background: #0056b3;
    transform: translateY(-2px);
}

.btn-success {
    background: var(--success);
    color: white;
}

.btn-success:hover {
    background: #218838;
}

.btn-info {
    background: var(--info);
    color: white;
}

.btn-info:hover {
    background: #138496;
}

.btn-warning {
    background: var(--warning);
    color: #333;
}

.btn-warning:hover {
    background: #e0a800;
}

.btn-secondary {
    background: var(--light);
    color: var(--dark);
    border: 1px solid var(--border);
}

.btn-secondary:hover {
    background: var(--border);
}

.btn-small {
    padding: 0.35rem 0.75rem;
    font-size: 0.85rem;
}

.btn-large {
    padding: 0.75rem 2rem;
    font-size: 1rem;
}

/* ==================== 테이블 ==================== */

.table-responsive {
    overflow-x: auto;
    margin-bottom: 1.5rem;
}

.data-table {
    width: 100%;
    border-collapse: collapse;
    background: white;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: var(--shadow);
}

.data-table thead {
    background: var(--light);
    font-weight: 600;
    color: var(--dark);
}

.data-table th,
.data-table td {
    padding: 1rem;
    text-align: left;
    border-bottom: 1px solid var(--border);
}

.data-table tbody tr:hover {
    background: #f0f3f7;
}

.data-table tbody tr:last-child td {
    border-bottom: none;
}

.cell-action {
    text-align: center;
}

.score-cell {
    font-weight: 600;
    color: var(--primary);
}

/* ==================== 배지 ==================== */

.grade-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
}

.grade-A+ {
    background: #d4edda;
    color: #155724;
}

.grade-A {
    background: #d1ecf1;
    color: #0c5460;
}

.grade-B+ {
    background: #fff3cd;
    color: #856404;
}

.grade-B {
    background: #f8d7da;
    color: #721c24;
}

.status-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: 500;
}

.status-present {
    background: #d4edda;
    color: #155724;
}

.status-late {
    background: #fff3cd;
    color: #856404;
}

.status-absent {
    background: #f8d7da;
    color: #721c24;
}

/* ==================== 카드 레이아웃 ==================== */

.student-grades-card,
.student-attendance-card,
.stats-card-large {
    background: white;
    border-radius: 8px;
    box-shadow: var(--shadow);
    margin-bottom: 2rem;
    overflow: hidden;
}

.card-header {
    background: var(--light);
    padding: 1.5rem;
    border-bottom: 1px solid var(--border);
}

.card-header h3 {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin: 0;
    color: var(--dark);
}

.student-no {
    font-size: 0.85rem;
    color: var(--gray);
}

.dept-name {
    background: var(--primary);
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
}

.card-body {
    padding: 1.5rem;
}

.card-footer {
    padding: 1rem 1.5rem;
    background: var(--light);
    border-top: 1px solid var(--border);
    text-align: right;
}

.gpa-display,
.gpa-info {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
}

.gpa-card,
.gpa-box {
    background: linear-gradient(135deg, var(--primary), #0056b3);
    color: white;
    padding: 1.5rem;
    border-radius: 8px;
    text-align: center;
    flex: 1;
}

.gpa-label {
    font-size: 0.9rem;
    opacity: 0.9;
    margin: 0 0 0.5rem 0;
}

.gpa-value {
    font-size: 2rem;
    font-weight: bold;
    margin: 0;
}

.gpa-meta {
    font-size: 0.85rem;
    margin-top: 0.5rem;
    opacity: 0.9;
}

.mini-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
}

.mini-table th,
.mini-table td {
    padding: 0.75rem;
    text-align: left;
    border-bottom: 1px solid var(--border);
}

.mini-table th {
    background: #f0f3f7;
    font-weight: 600;
}

.attendance-summary {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
}

.summary-item {
    background: var(--light);
    padding: 1rem;
    border-radius: 6px;
    text-align: center;
}

.summary-item .label {
    display: block;
    font-size: 0.9rem;
    color: var(--gray);
    margin-bottom: 0.5rem;
}

.summary-item .value {
    display: block;
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--primary);
}

.grades-container {
    display: grid;
    gap: 1.5rem;
}

.attendance-container {
    display: grid;
    gap: 1.5rem;
}

/* ==================== 통계 페이지 ==================== */

.stats-grid-large {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
}

.comparison-section {
    margin: 3rem 0;
}

.comparison-card {
    background: white;
    padding: 2rem;
    border-radius: 8px;
    box-shadow: var(--shadow);
    margin-bottom: 2rem;
}

.comparison-card h3 {
    margin-top: 0;
    color: var(--dark);
}

.chart-container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.chart-bar {
    display: flex;
    align-items: center;
    gap: 1rem;
}

.chart-label {
    min-width: 150px;
    font-weight: 500;
    color: var(--dark);
}

.bar-container {
    flex: 1;
    background: var(--light);
    border-radius: 4px;
    overflow: hidden;
    height: 30px;
}

.bar {
    height: 100%;
    background: linear-gradient(90deg, var(--primary), #0056b3);
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: 0.5rem;
    color: white;
    font-weight: 600;
    font-size: 0.85rem;
    min-width: 50px;
}

.summary-section {
    background: white;
    padding: 2rem;
    border-radius: 8px;
    box-shadow: var(--shadow);
}

.summary-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
}

.summary-card {
    background: var(--light);
    padding: 1.5rem;
    border-radius: 6px;
    text-align: center;
    border-left: 4px solid var(--primary);
}

.summary-label {
    font-size: 0.9rem;
    color: var(--gray);
    margin-bottom: 0.5rem;
}

.summary-value {
    font-size: 1.8rem;
    font-weight: bold;
    color: var(--primary);
    margin: 0.5rem 0;
}

.summary-note {
    font-size: 0.85rem;
    color: var(--gray);
}

/* ==================== 학과 통계 ==================== */

.department-stats {
    margin: 2rem 0;
}

.dept-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
}

.dept-card {
    background: white;
    padding: 1.5rem;
    border-radius: 8px;
    border-left: 4px solid var(--primary);
    box-shadow: var(--shadow);
    text-align: center;
}

.dept-card h3 {
    margin-top: 0;
    color: var(--dark);
    font-size: 1rem;
}

.dept-count {
    font-size: 2rem;
    font-weight: bold;
    color: var(--primary);
    margin: 1rem 0;
}

.stats-section {
    background: white;
    padding: 1.5rem;
    border-radius: 8px;
    box-shadow: var(--shadow);
    margin: 2rem 0;
}

.stat-info {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1rem;
}

.stat-item {
    text-align: center;
    padding: 1rem;
    background: var(--light);
    border-radius: 6px;
}

.stat-item .label {
    font-size: 0.85rem;
    color: var(--gray);
}

.stat-item .value {
    font-size: 1.8rem;
    font-weight: bold;
    color: var(--primary);
    margin-top: 0.5rem;
}

/* ==================== 진행 바 ==================== */

.progress-section {
    margin-top: 1rem;
}

.progress-label {
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--gray);
}

.progress-bar {
    height: 24px;
    background: var(--light);
    border-radius: 4px;
    overflow: hidden;
}

.progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--primary), #0056b3);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 600;
    font-size: 0.85rem;
    transition: width 0.3s;
}

/* ==================== 빈 상태 ==================== */

.empty-state,
.empty-message {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--gray);
    background: white;
    border-radius: 8px;
}

.empty-state p {
    font-size: 1.1rem;
    margin-bottom: 1.5rem;
}

.empty-state .btn {
    margin-top: 1rem;
}

.empty-message {
    padding: 2rem;
}

/* ==================== 푸터 ==================== */

.footer {
    background: var(--dark);
    color: white;
    text-align: center;
    padding: 2rem;
    margin-top: 4rem;
}

.footer p {
    margin: 0;
}

/* ==================== 반응형 디자인 ==================== */

@media (max-width: 768px) {
    .navbar .container {
        flex-direction: column;
        gap: 1rem;
    }

    .navbar-menu {
        width: 100%;
        flex-direction: column;
    }

    .nav-link {
        width: 100%;
        text-align: center;
    }

    .page-title {
        font-size: 1.5rem;
    }

    .page-header {
        flex-direction: column;
        align-items: stretch;
    }

    .page-header .btn {
        width: 100%;
    }

    .stats-grid,
    .features-grid,
    .tech-grid,
    .dept-grid,
    .summary-grid {
        grid-template-columns: 1fr;
    }

    .stat-card {
        flex-direction: column;
        text-align: center;
    }

    .form-row {
        grid-template-columns: 1fr;
    }

    .button-group {
        flex-direction: column;
    }

    .button-group .btn {
        width: 100%;
    }

    .attendance-summary {
        grid-template-columns: repeat(2, 1fr);
    }

    .chart-label {
        min-width: 100px;
        font-size: 0.9rem;
    }
}

@media (max-width: 480px) {
    .container {
        padding: 0 0.5rem;
    }

    .page-title {
        font-size: 1.25rem;
    }

    .main-content {
        padding: 1rem 0;
    }

    .data-table th,
    .data-table td {
        padding: 0.5rem;
        font-size: 0.9rem;
    }

    .button-group {
        gap: 0.5rem;
    }

    .attendance-summary {
        grid-template-columns: 1fr;
    }
}
