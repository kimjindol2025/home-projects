    - 스키마 설계
    - CRUD 작업
    - 보안 (SQL Injection 방어)
    - 성능 (인덱싱)
    - 트랜잭션
    """

    @staticmethod
    def initialize_database():
        """데이터베이스 초기화"""

        with get_db(':memory:') as (cursor, conn):
            # 테이블 설계
            cursor.execute('''
                CREATE TABLE IF NOT EXISTS researchers (
                    researcher_id INTEGER PRIMARY KEY,
                    name TEXT NOT NULL UNIQUE,
                    department TEXT,
                    email TEXT
                )
            ''')

            cursor.execute('''
                CREATE TABLE IF NOT EXISTS experiments (
                    experiment_id INTEGER PRIMARY KEY AUTOINCREMENT,
                    researcher_id INTEGER NOT NULL,
                    title TEXT NOT NULL,
                    description TEXT,
                    start_date DATE,
                    end_date DATE,
                    status TEXT CHECK(status IN ('진행중', '완료', '중단')),
                    FOREIGN KEY(researcher_id) REFERENCES researchers(researcher_id)
                )
            ''')

            cursor.execute('''
                CREATE TABLE IF NOT EXISTS results (
                    result_id INTEGER PRIMARY KEY AUTOINCREMENT,
                    experiment_id INTEGER NOT NULL,
                    metric TEXT NOT NULL,
                    value REAL,
                    recorded_at DATETIME DEFAULT CURRENT_TIMESTAMP,
                    FOREIGN KEY(experiment_id) REFERENCES experiments(experiment_id)
                )
            ''')

            # 인덱스 생성
            cursor.execute("CREATE INDEX IF NOT EXISTS idx_researcher ON experiments(researcher_id)")
            cursor.execute("CREATE INDEX IF NOT EXISTS idx_experiment ON results(experiment_id)")

            print("✅ 데이터베이스 초기화 완료")
            return cursor, conn


