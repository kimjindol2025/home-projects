# ==================== PHASE 1: 기초 개념 ====================

class Phase1_BasicCRUD:
    """
    【 PHASE 1 】기본 CRUD (Create, Read, Update, Delete)

    데이터베이스의 4대 기본 작업을 이해합니다.
    """

    @staticmethod
    def demo_basic_crud():
        """가장 단순한 CRUD 예제"""

        # Step 1: 데이터베이스 연결 (파일이 없으면 자동 생성)
        conn = sqlite3.connect(':memory:')  # 메모리 DB (테스트용)
        cursor = conn.cursor()

        print("=" * 80)
        print("【 PHASE 1 】 기본 CRUD 작업")
        print("=" * 80)

        # Step 2: 테이블 생성 (스키마 정의)
        print("\n[Step 1] 테이블 생성 (CREATE TABLE)")
        cursor.execute('''
            CREATE TABLE experiments (
                id INTEGER PRIMARY KEY AUTOINCREMENT,
                subject TEXT NOT NULL,
                result REAL,
                timestamp DATETIME DEFAULT CURRENT_TIMESTAMP
            )
        ''')
        print("✅ 테이블 생성 완료")

        # Step 3: 데이터 삽입 (CREATE)
        print("\n[Step 2] 데이터 삽입 (INSERT)")

        test_data = [
            ("비동기 엔진 테스트", 98.5),
            ("메타클래스 검증", 100.0),
            ("데코레이터 성능", 95.0),
        ]

        for subject, result in test_data:
            cursor.execute(
                "INSERT INTO experiments (subject, result) VALUES (?, ?)",
                (subject, result)
            )
            print(f"  💾 저장: {subject} = {result}")

        conn.commit()
        print("✅ 모든 데이터 저장 완료")

        # Step 4: 데이터 읽기 (READ)
        print("\n[Step 3] 데이터 읽기 (SELECT)")
        cursor.execute("SELECT * FROM experiments")
        rows = cursor.fetchall()

        print("\n  --- [실험 기록 전체] ---")
        for row in rows:
            print(f"  ID: {row[0]:2d} | 주제: {row[1]:20s} | 결과: {row[2]:5.1f}% | 시각: {row[3]}")

        # Step 5: 데이터 수정 (UPDATE)
        print("\n[Step 4] 데이터 수정 (UPDATE)")
        cursor.execute(
            "UPDATE experiments SET result = ? WHERE subject = ?",
            (99.5, "비동기 엔진 테스트")
        )
        conn.commit()
        print("✅ 비동기 엔진 테스트 결과 수정: 98.5% → 99.5%")

        # Step 6: 데이터 삭제 (DELETE)
        print("\n[Step 5] 데이터 삭제 (DELETE)")
        cursor.execute(
            "DELETE FROM experiments WHERE result < ?",
            (96.0,)
        )
        conn.commit()
        print("✅ 96% 미만 기록 삭제 완료")

        # Step 7: 최종 결과
        print("\n[최종 결과]")
        cursor.execute("SELECT * FROM experiments")
        rows = cursor.fetchall()
        print(f"  총 {len(rows)}개 기록 남음")

        conn.close()


# ==================== PHASE 2: 스키마 설계 ====================

class Phase2_SchemaDesign:
    """
    【 PHASE 2 】 스키마 설계와 정규화

    데이터를 어떻게 구조화할 것인가?
    - Primary Key (PK): 각 행을 유일하게 식별
    - Foreign Key (FK): 테이블 간 관계 정의
    - 정규화: 데이터 중복 최소화
    """

    @staticmethod
    def demo_schema_design():
        """여러 테이블의 관계 설계"""

        conn = sqlite3.connect(':memory:')
        cursor = conn.cursor()

        print("\n" + "=" * 80)
        print("【 PHASE 2 】 스키마 설계와 정규화")
        print("=" * 80)

        # 학생 테이블 (1번 정규화)
        print("\n[테이블 1] 학생 정보")
        cursor.execute('''
            CREATE TABLE students (
                student_id INTEGER PRIMARY KEY,
                name TEXT NOT NULL,
                major TEXT,
                gpa REAL
            )
        ''')

        # 강의 테이블
        print("[테이블 2] 강의 정보")
        cursor.execute('''
            CREATE TABLE courses (
                course_id INTEGER PRIMARY KEY,
                title TEXT NOT NULL,
                professor TEXT,
                credits INTEGER
            )
        ''')

        # 수강 관계 테이블 (N:M 관계)
        print("[테이블 3] 수강 관계 (학생-강의 다대다 관계)")
        cursor.execute('''
            CREATE TABLE enrollments (
                enrollment_id INTEGER PRIMARY KEY,
                student_id INTEGER NOT NULL,
                course_id INTEGER NOT NULL,
                grade TEXT,
                semester TEXT,
                FOREIGN KEY(student_id) REFERENCES students(student_id),
                FOREIGN KEY(course_id) REFERENCES courses(course_id)
            )
        ''')

        # 데이터 삽입
        students = [
            (1, "김설계자", "컴퓨터과학", 3.8),
            (2, "이분석가", "데이터과학", 3.5),
            (3, "박개발자", "소프트웨어공학", 3.9),
        ]

        courses = [
            (101, "데이터베이스", "박교수", 3),
            (102, "웹개발", "김교수", 4),
            (103, "알고리즘", "이교수", 3),
        ]

        enrollments = [
            (1, 1, 101, "A+", "2026-1"),
            (2, 1, 102, "A", "2026-1"),
            (3, 2, 101, "A", "2026-1"),
            (4, 2, 103, "B+", "2026-1"),
            (5, 3, 102, "A+", "2026-1"),
        ]

        cursor.executemany("INSERT INTO students VALUES (?, ?, ?, ?)", students)
        cursor.executemany("INSERT INTO courses VALUES (?, ?, ?, ?)", courses)
        cursor.executemany("INSERT INTO enrollments VALUES (?, ?, ?, ?, ?)", enrollments)

        conn.commit()
        print("✅ 모든 데이터 삽입 완료")

        # JOIN 쿼리: 학생의 강의 수강 이력
        print("\n[JOIN 쿼리] 학생-강의-성적 조회")
        print("  --- [김설계자의 수강 강의 내역] ---")

        cursor.execute('''
            SELECT
                s.name,
                c.title,
                e.grade,
                e.semester
            FROM enrollments e
            JOIN students s ON e.student_id = s.student_id
            JOIN courses c ON e.course_id = c.course_id
            WHERE s.student_id = 1
        ''')

        for row in cursor.fetchall():
            print(f"  학생: {row[0]} | 강의: {row[1]} | 성적: {row[2]} | 학기: {row[3]}")

        conn.close()


# ==================== PHASE 3: 보안과 무결성 ====================

class Phase3_SecurityAndIntegrity:
    """
    【 PHASE 3 】 보안 (SQL Injection 방어)과 데이터 무결성

    "SQL Injection"은 악의적인 사용자가 SQL 문장을 조작하여
    데이터베이스를 손상시키는 공격입니다.

    방어책: 파라미터 바인딩 (? 사용)
    """

    @staticmethod
    def demo_sql_injection_danger():
        """SQL Injection 위험성 시연"""

        print("\n" + "=" * 80)
        print("【 PHASE 3 】 보안과 데이터 무결성")
        print("=" * 80)

        conn = sqlite3.connect(':memory:')
        cursor = conn.cursor()

        # 테이블 생성
        cursor.execute('''
            CREATE TABLE users (
                id INTEGER PRIMARY KEY,
                username TEXT,
                password TEXT
            )
        ''')

        cursor.execute("INSERT INTO users VALUES (1, 'admin', 'secret123')")
        cursor.execute("INSERT INTO users VALUES (2, 'user', 'pass456')")
        conn.commit()

        print("\n【 위험 예 1】 직접 문자열 연결 (SQL Injection 취약점)")
        print("-" * 60)

        # ❌ 잘못된 방법
        user_input = "admin' OR '1'='1"  # 공격자의 입력

        print(f"사용자 입력: {user_input}")
        print(f"\n❌ 위험한 코드:")
        print(f"   query = f\"SELECT * FROM users WHERE username = '{user_input}'\"")

        # 실제로는 이렇게 되어 모든 사용자가 조회됨
        dangerous_query = f"SELECT * FROM users WHERE username = '{user_input}'"
        print(f"\n생성된 SQL: {dangerous_query}")
        print("\n결과: 모든 사용자 정보가 반환됨! (보안 위반)")

        print("\n【 안전 예 1】 파라미터 바인딩 (권장)")
        print("-" * 60)

        # ✅ 올바른 방법
        print(f"사용자 입력: {user_input}")
        print(f"\n✅ 안전한 코드:")
        print(f"   cursor.execute(\"SELECT * FROM users WHERE username = ?\", (user_input,))")

        cursor.execute("SELECT * FROM users WHERE username = ?", (user_input,))
        results = cursor.fetchall()

        print(f"\n생성된 SQL: SELECT * FROM users WHERE username = ?")
        print(f"파라미터: ('{user_input}',)")
        print(f"\n결과: {len(results)}개 행 (안전! 공격 방어됨)")

        print("\n【 데이터 무결성 】 제약 조건 (Constraints)")
        print("-" * 60)

        conn2 = sqlite3.connect(':memory:')
        cursor2 = conn2.cursor()

        cursor2.execute('''
            CREATE TABLE products (
                id INTEGER PRIMARY KEY,
                name TEXT NOT NULL,           -- NOT NULL: 필수 입력
                price REAL CHECK(price > 0), -- CHECK: 양수만 허용
                quantity INTEGER DEFAULT 0   -- DEFAULT: 기본값
            )
        ''')

        print("제약 조건 설정:")
        print("  - name TEXT NOT NULL: 상품명 필수")
        print("  - price REAL CHECK(price > 0): 가격은 양수만")
        print("  - quantity INTEGER DEFAULT 0: 기본 재고 0")

        # ✅ 유효한 데이터
        print("\n✅ 유효한 데이터 삽입:")
        cursor2.execute("INSERT INTO products (name, price) VALUES (?, ?)", ("노트북", 1500000))
        print("   INSERT INTO products (name, price) VALUES ('노트북', 1500000)")

        # ❌ 무결성 위반
        print("\n❌ 위반 시도 1: 음수 가격")
        try:
            cursor2.execute("INSERT INTO products (name, price) VALUES (?, ?)", ("마우스", -5000))
        except sqlite3.IntegrityError as e:
            print(f"   오류: {e}")

        print("\n❌ 위반 시도 2: NULL 상품명")
        try:
            cursor2.execute("INSERT INTO products (name, price) VALUES (?, ?)", (None, 5000))
        except sqlite3.IntegrityError as e:
            print(f"   오류: {e}")

        conn.close()
        conn2.close()


# ==================== PHASE 4: 성능 최적화 ====================

class Phase4_PerformanceOptimization:
    """
    【 PHASE 4 】 성능 최적화: 인덱싱

    인덱스(Index)란?
    - 책의 '찾아보기'처럼, 특정 컬럼의 값으로 빠르게 검색할 수 있게 함
    - 예: 100만 개 기록 중 ID=12345인 사람을 찾을 때
      - 인덱스 없음: 100만 개 모두 조사 (선형 탐색, O(n))
      - 인덱스 있음: B-tree로 빠르게 찾음 (O(log n))
    """

    @staticmethod
    def demo_indexing():
        """인덱싱의 효과"""

        print("\n" + "=" * 80)
        print("【 PHASE 4 】 성능 최적화: 인덱싱")
        print("=" * 80)

        conn = sqlite3.connect(':memory:')
        cursor = conn.cursor()

        # 대규모 데이터 생성
        print("\n[준비] 100,000개 레코드 생성...")
        cursor.execute('CREATE TABLE logs (id INTEGER, user_id INTEGER, message TEXT)')

        # 대량 삽입
        cursor.execute("BEGIN TRANSACTION")
        for i in range(100000):
            cursor.execute(
                "INSERT INTO logs VALUES (?, ?, ?)",
                (i, i % 1000, f'Log entry {i}')
            )
        cursor.execute("COMMIT")

        print("✅ 테이블 생성 완료 (100,000 행)")

        # 인덱스 없이 검색
        print("\n【 성능 테스트 1】 인덱스 없이 검색")
        print("-" * 60)

        start = time.time()
        cursor.execute("SELECT * FROM logs WHERE user_id = 500")
        rows_no_index = cursor.fetchall()
        time_no_index = time.time() - start

        print(f"검색어: user_id = 500")
        print(f"결과: {len(rows_no_index)}개 행")
        print(f"소요 시간: {time_no_index*1000:.2f}ms")

        # 인덱스 생성
        print("\n【 인덱스 생성】")
        print("-" * 60)
        print("CREATE INDEX idx_user_id ON logs(user_id)")

        cursor.execute("CREATE INDEX idx_user_id ON logs(user_id)")
        print("✅ 인덱스 생성 완료")

        # 인덱스 사용하여 검색
        print("\n【 성능 테스트 2】 인덱스 사용하여 검색")
        print("-" * 60)

        start = time.time()
        cursor.execute("SELECT * FROM logs WHERE user_id = 500")
        rows_with_index = cursor.fetchall()
        time_with_index = time.time() - start

        print(f"검색어: user_id = 500")
        print(f"결과: {len(rows_with_index)}개 행")
        print(f"소요 시간: {time_with_index*1000:.2f}ms")

        # 성능 개선
        print("\n【 성능 개선】")
        print("-" * 60)
        improvement = time_no_index / time_with_index if time_with_index > 0 else 0
        print(f"속도 향상: {improvement:.1f}배")
        print(f"시간 단축: {(time_no_index - time_with_index)*1000:.2f}ms")

        conn.close()


# ==================== PHASE 5: 고급 주제 ====================

class Phase5_AdvancedTopics:
    """
    【 PHASE 5 】 고급 주제

    - 트랜잭션 (Transaction): 여러 작업을 원자적으로 수행
    - 뷰 (View): 가상 테이블
    - 트리거 (Trigger): 자동 작동하는 규칙
    """

    @staticmethod
    def demo_transaction():
        """트랜잭션: 은행 이체 시뮬레이션"""

        print("\n" + "=" * 80)
        print("【 PHASE 5-1】 트랜잭션 (원자성 보장)")
        print("=" * 80)

        conn = sqlite3.connect(':memory:')
        cursor = conn.cursor()

        # 은행 계좌 테이블
        cursor.execute('''
            CREATE TABLE accounts (
                account_id INTEGER PRIMARY KEY,
                holder TEXT,
                balance REAL
            )
        ''')

        cursor.execute("INSERT INTO accounts VALUES (1, '김설계자', 1000000)")
        cursor.execute("INSERT INTO accounts VALUES (2, '이분석가', 500000)")
        conn.commit()

        print("\n【 초기 상태】")
        print("  김설계자: 1,000,000원")
        print("  이분석가:   500,000원")

        print("\n【 이체 작업: 김설계자 → 이분석가 300,000원】")
        print("-" * 60)

        try:
            print("\n1️⃣  트랜잭션 시작 (BEGIN)")
            cursor.execute("BEGIN")

            # 김설계자 인출
            print("2️⃣  김설계자 계좌에서 300,000원 인출")
            cursor.execute("UPDATE accounts SET balance = balance - 300000 WHERE account_id = 1")

            # 이분석가 입금
            print("3️⃣  이분석가 계좌에 300,000원 입금")
            cursor.execute("UPDATE accounts SET balance = balance + 300000 WHERE account_id = 2")

            # 트랜잭션 커밋
            print("4️⃣  트랜잭션 완료 (COMMIT)")
            conn.commit()

            print("\n✅ 이체 완료")

        except Exception as e:
            print(f"\n❌ 오류 발생: {e}")
            print("   트랜잭션 롤백 (ROLLBACK)")
            conn.rollback()

        # 최종 상태
        print("\n【 최종 상태】")
        cursor.execute("SELECT * FROM accounts")
        for row in cursor.fetchall():
            print(f"  {row[1]}: {row[2]:,}원")

        conn.close()

    @staticmethod
    def demo_view():
        """뷰: 가상 테이블"""

        print("\n" + "=" * 80)
        print("【 PHASE 5-2】 뷰 (View)")
        print("=" * 80)

        conn = sqlite3.connect(':memory:')
        cursor = conn.cursor()

        # 테이블 생성
        cursor.execute('''
            CREATE TABLE sales (
                id INTEGER PRIMARY KEY,
                product TEXT,
                amount REAL,
                region TEXT
            )
        ''')

        sales_data = [
            (1, "노트북", 1500000, "서울"),
            (2, "마우스", 50000, "서울"),
            (3, "키보드", 150000, "부산"),
            (4, "모니터", 300000, "서울"),
            (5, "노트북", 1500000, "대구"),
        ]

        cursor.executemany("INSERT INTO sales VALUES (?, ?, ?, ?)", sales_data)
        conn.commit()

        # 뷰 생성: 지역별 매출 요약
        print("\n【 뷰 생성】 지역별 총 매출")
        print("-" * 60)

        cursor.execute('''
            CREATE VIEW region_sales AS
            SELECT region, COUNT(*) as count, SUM(amount) as total
            FROM sales
            GROUP BY region
        ''')

        print("CREATE VIEW region_sales AS")
        print("  SELECT region, COUNT(*) as count, SUM(amount) as total")
        print("  FROM sales GROUP BY region")

        # 뷰 조회
        print("\n【 뷰 조회】")
        print("-" * 60)

        cursor.execute("SELECT * FROM region_sales")
        print(f"{'지역':<10} {'판매건수':<10} {'총 매출':<15}")
        print("-" * 35)

        for row in cursor.fetchall():
            print(f"{row[0]:<10} {row[1]:<10} {row[2]:>13,}원")

        conn.close()


# ==================== PHASE 6: 실제 프로젝트 ====================

@contextmanager
def get_db(filename: str = 'gogs_research.db'):
    """데이터베이스 컨텍스트 매니저 (v3.3 스타일)"""
    conn = sqlite3.connect(filename)
    cursor = conn.cursor()
    try:
        yield cursor, conn
    finally:
        conn.commit()
        conn.close()


