// ============================================================================
// Phase 5 v6.0 [6~7단계]: 트레이트 경계와 다중 경계 설계
// (Trait Bounds & Multiple Bounds)
// ============================================================================
// 철학: "함수는 깐깐한 전문가다.
//       특정 능력을 갖춘 객체들만 엄격하게 심사한다."
//
// [Step 6]: 트레이트 경계(Trait Bounds)
//         - 함수가 특정 트레이트를 구현한 타입만 허용
//         - "T: Summary" → Summary 구현체만 환영
//
// [Step 7]: 다중 경계 설계(Multiple Bounds)
//         - 여러 조건을 복합적으로 조합
//         - "T: Summary + SecurityLevel" → 둘 다 구현해야 함
// ============================================================================

// ============================================================================
// [트레이트 1] Summary: 항목을 요약하는 능력
// ============================================================================
trait Summary {
    /// 필수 구현: 항목을 한 줄로 요약
    fn summarize(&self) -> String;

    /// 기본 구현: 상세 설명 (오버라이드 가능)
    fn detailed_summary(&self) -> String {
        format!("Summary: {}", self.summarize())
    }
}

// ============================================================================
// [트레이트 2] SecurityLevel: 보안 수준을 판단하는 능력
// ============================================================================
trait SecurityLevel {
    /// 필수 구현: 보안 수준 반환 (0~10)
    fn level(&self) -> u8;

    /// 기본 구현: 보안 등급 이름 (level()에 기반)
    fn level_name(&self) -> &'static str {
        match self.level() {
            0..=3 => "🟢 낮음",
            4..=6 => "🟡 중간",
            7..=9 => "🔴 높음",
            10 => "🚨 초고위험",
            _ => "❓ 미정의",
        }
    }

    /// 기본 구현: 고위험 여부 판단
    fn is_critical(&self) -> bool {
        self.level() > 7
    }
}

// ============================================================================
// [구현 1] SecurityLog: 보안 로그 (두 트레이트 모두 구현)
// ============================================================================
struct SecurityLog {
    id: u32,
    event_code: String,
    clearance_level: u8,
}

impl SecurityLog {
    fn new(id: u32, event_code: &str, clearance_level: u8) -> Self {
        Self {
            id,
            event_code: String::from(event_code),
            clearance_level,
        }
    }
}

impl Summary for SecurityLog {
    fn summarize(&self) -> String {
        format!("Log#{}: [{}]", self.id, self.event_code)
    }

    fn detailed_summary(&self) -> String {
        format!("SecurityLog#{}: Event=[{}], ClearanceLevel={}",
                self.id, self.event_code, self.clearance_level)
    }
}

impl SecurityLevel for SecurityLog {
    fn level(&self) -> u8 {
        self.clearance_level
    }
}

// ============================================================================
// [구현 2] AuditRecord: 감사 기록 (두 트레이트 모두 구현)
// ============================================================================
struct AuditRecord {
    timestamp: String,
    action: String,
    risk_score: u8,
}

impl AuditRecord {
    fn new(timestamp: &str, action: &str, risk_score: u8) -> Self {
        Self {
            timestamp: String::from(timestamp),
            action: String::from(action),
            risk_score,
        }
    }
}

impl Summary for AuditRecord {
    fn summarize(&self) -> String {
        format!("[{}] {}", self.timestamp, self.action)
    }

    fn detailed_summary(&self) -> String {
        format!("AuditRecord: Time=[{}], Action=[{}], RiskScore={}",
                self.timestamp, self.action, self.risk_score)
    }
}

impl SecurityLevel for AuditRecord {
    fn level(&self) -> u8 {
        self.risk_score
    }
}

// ============================================================================
// [구현 3] SystemAlert: 시스템 경고 (Summary만 구현)
// ============================================================================
struct SystemAlert {
    message: String,
    category: String,
}

impl SystemAlert {
    fn new(message: &str, category: &str) -> Self {
        Self {
            message: String::from(message),
            category: String::from(category),
        }
    }
}

impl Summary for SystemAlert {
    fn summarize(&self) -> String {
        format!("[{}] {}", self.category, self.message)
    }
}

// 주의: SecurityLevel은 구현하지 않음!
// → monitor_system<T: Summary + SecurityLevel>에서 사용 불가

// ============================================================================
// [Step 6] 트레이트 경계 함수들
// ============================================================================

/// [경계 1] Summary 트레이트만 요구
/// "이 함수는 summarize()가 있는 모든 타입을 환영한다"
fn simple_display<T: Summary>(item: &T) {
    println!("📋 {}", item.summarize());
}

/// [경계 2] SecurityLevel 트레이트만 요구
/// "이 함수는 level()이 있는 모든 타입을 환영한다"
fn check_security_only<T: SecurityLevel>(item: &T) {
    println!("🔒 보안 수준: {}/10", item.level());
}

/// [경계 3] Summary + Clone (두 가지 경계, 복사 필요)
fn duplicate_and_display<T: Summary + Clone>(item: &T) {
    let copy = item.clone();
    println!("원본: {}", item.summarize());
    println!("복사본: {}", copy.summarize());
}

// ============================================================================
// [Step 7] 다중 경계 설계: 통합 모니터링 함수
// ============================================================================

/// [핵심] 다중 경계: Summary + SecurityLevel
/// "이 함수는 두 능력을 모두 갖춘 타입만 처리한다"
fn monitor_system<T: Summary + SecurityLevel>(item: &T) {
    println!("╔════════════════════════════════════════════╗");
    println!("║          🌐 시스템 모니터링                ║");
    println!("╚════════════════════════════════════════════╝");
    println!("항목: {}", item.summarize());
    println!("보안수준: {} ({})", item.level(), item.level_name());

    // 조건부 처리: SecurityLevel의 level() 메서드 활용
    if item.is_critical() {
        println!("⚠️  [고위험] 즉시 대응 필요!");
    } else {
        println!("✓ [정상] 정상 범위");
    }
    println!();
}

/// [다중 경계 예시] Summary + SecurityLevel + Clone
/// 복사하면서 비교해야 하는 경우
fn compare_and_log<T: Summary + SecurityLevel + Clone>(original: &T, modified: &T) {
    let copy = original.clone();
    println!("원본: {} (보안수준: {})", copy.summarize(), copy.level());
    println!("변경됨: {} (보안수준: {})", modified.summarize(), modified.level());
}

// ============================================================================
// [Step 6 ~ 7 통합 검증 함수]
// ============================================================================

/// [다형성] Summary 구현체들의 백터 처리
fn process_summaries(items: &[&dyn Summary]) {
    println!("═════════════════════════════════════════════");
    println!("🔹 모든 Summary 구현체 처리 (다형성)");
    println!("═════════════════════════════════════════════\n");

    for item in items {
        println!("📋 {}", item.summarize());
    }
    println!();
}

/// [다형성] SecurityLevel 구현체들의 백터 처리
fn process_security_levels(items: &[&dyn SecurityLevel]) {
    println!("═════════════════════════════════════════════");
    println!("🔒 모든 SecurityLevel 구현체 처리 (다형성)");
    println!("═════════════════════════════════════════════\n");

    for item in items {
        println!("🔒 보안 수준: {}/10", item.level());
    }
    println!();
}

