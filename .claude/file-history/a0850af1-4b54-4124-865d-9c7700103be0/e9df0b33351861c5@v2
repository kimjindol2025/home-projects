print(f"""
컨텍스트 매니저 프로토콜:
  __enter__() → 리소스 획득 후 반환
  __exit__()  → 리소스 해제 (에러 여부 상관없음)
""")


class Timer:
    """실행 시간을 측정하는 컨텍스트 매니저"""

    def __init__(self, name: str = "Operation"):
        self.name = name
        self.start_time = None

    def __enter__(self):
        """with 블록 진입"""
        import time
        self.start_time = time.time()
        print(f"  [TIMER] '{self.name}' 시작")
        return self

    def __exit__(self, exc_type, exc_val, exc_tb):
        """with 블록 퇴출"""
        import time
        elapsed = time.time() - self.start_time
        print(f"  [TIMER] '{self.name}' 완료: {elapsed:.4f}초")

        if exc_type:
            print(f"  [ERROR] {exc_type.__name__}")

        return False  # 에러 전파


print(f"\n[사용]")
with Timer("Calculation") as timer:
    result = sum(range(1000000))

print(f"\n[프로토콜의 의미]")
print(f"  Timer는 __enter__와 __exit__를 구현했으므로")
print(f"  자동으로 with 문과 호환됩니다")


