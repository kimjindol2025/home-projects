이 메소드들을 구현하면 sorted(), min(), max() 등과
자동으로 호환됩니다.
""")


class Student:
    """학생 정보"""

    def __init__(self, name: str, score: float):
        self.name = name
        self.score = score

    def __repr__(self) -> str:
        return f"Student('{self.name}', {self.score})"

    def __lt__(self, other: "Student") -> bool:
        """< 연산자: 성적이 낮은 순서"""
        if isinstance(other, Student):
            return self.score < other.score
        return NotImplemented

    def __eq__(self, other: "Student") -> bool:
        """== 연산자"""
        if isinstance(other, Student):
            return self.score == other.score
        return NotImplemented


students = [
    Student("Alice", 85),
    Student("Bob", 92),
    Student("Charlie", 78)
]

print(f"\n[원본]")
for s in students:
    print(f"  {s}")

print(f"\n[sorted() - 비교 프로토콜 사용]")
sorted_students = sorted(students)
for s in sorted_students:
    print(f"  {s}")

print(f"\n[min(), max()]")
print(f"  min(students): {min(students)}")
print(f"  max(students): {max(students)}")

print(f"\n[프로토콜의 의미]")
print(f"  Student는 __lt__를 구현했으므로")
print(f"  sorted()와 자동으로 호환됩니다")


