# [탐구 1] 이터러블 프로토콜 (Iterable Protocol)
# ============================================================================

print("\n" + "="*70)
print("# [탐구 1] 이터러블 프로토콜")
print("="*70)

print(f"""
파이썬 이터러블 프로토콜:
  __iter__() → Iterator 반환

파이썬 이터레이터 프로토콜:
  __iter__() → self 반환
  __next__() → 다음 값 또는 StopIteration 발생
""")


class CountUp:
    """특정 숫자까지 세는 이터러블"""

    def __init__(self, max_value: int):
        self.max_value = max_value

    def __iter__(self):
        """이터레이터 반환"""
        return CountUpIterator(self.max_value)

    def __repr__(self) -> str:
        return f"CountUp({self.max_value})"


class CountUpIterator:
    """실제 이터레이션을 수행하는 이터레이터"""

    def __init__(self, max_value: int):
        self.max_value = max_value
        self.current = 0

    def __iter__(self):
        """자기 자신을 반환"""
        return self

    def __next__(self):
        """다음 값을 반환하거나 StopIteration 발생"""
        if self.current < self.max_value:
            self.current += 1
            return self.current
        else:
            raise StopIteration


print(f"\n[이터러블 사용]")
counter = CountUp(5)
print(f"  for i in {counter}:")
for i in counter:
    print(f"    {i}")

print(f"\n[프로토콜의 의미]")
print(f"  CountUp은 __iter__()를 구현했으므로 이터러블입니다")
print(f"  파이썬의 for 루프는 자동으로 이를 감지하고 사용합니다")


