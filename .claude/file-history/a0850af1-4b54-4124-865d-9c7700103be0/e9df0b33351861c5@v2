이 메소드를 구현하면 len() 함수와 호환됩니다.
""")


class Deck:
    """카드 덱"""

    def __init__(self, cards: list):
        self.cards = cards

    def __len__(self) -> int:
        """len() 함수 지원"""
        return len(self.cards)

    def __repr__(self) -> str:
        return f"Deck({len(self.cards)} cards)"


deck = Deck(['♠A', '♥K', '♦Q', '♣J'])

print(f"\n[사용]")
print(f"  deck: {deck}")
print(f"  len(deck): {len(deck)}")
print(f"  bool(deck): {bool(deck)}")  # __len__ 기반으로 판단

empty_deck = Deck([])
print(f"  empty_deck: {empty_deck}")
print(f"  bool(empty_deck): {bool(empty_deck)}")


