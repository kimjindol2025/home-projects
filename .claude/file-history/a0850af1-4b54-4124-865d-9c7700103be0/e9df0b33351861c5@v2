시퀀스 프로토콜:
  __getitem__(), __len__(), (+ 선택: __contains__, __reversed__)

이 메소드들을 구현하면 리스트처럼 사용 가능합니다.
""")


class Fibonacci:
    """피보나치 수열을 시퀀스처럼 접근"""

    def __init__(self, length: int):
        self.length = length

    def __len__(self) -> int:
        """길이"""
        return self.length

    def __getitem__(self, index: int) -> int:
        """인덱싱"""
        if index < 0 or index >= self.length:
            raise IndexError("피보나치 인덱스 범위 초과")

        if index <= 1:
            return index

        a, b = 0, 1
        for _ in range(2, index + 1):
            a, b = b, a + b
        return b

    def __repr__(self) -> str:
        return f"Fibonacci({self.length})"


fib = Fibonacci(10)

print(f"\n[시퀀스처럼 사용]")
print(f"  fib: {fib}")
print(f"  len(fib): {len(fib)}")
print(f"  fib[0]: {fib[0]}")
print(f"  fib[5]: {fib[5]}")
print(f"  fib[9]: {fib[9]}")

print(f"\n[슬라이싱]")
print(f"  fib[2:7]: {[fib[i] for i in range(2, 7)]}")

print(f"\n[이터레이션]")
print(f"  for i in fib: (처음 5개)")
for i, val in enumerate(fib):
    if i >= 5:
        break
    print(f"    {val}")


