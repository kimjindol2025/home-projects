#!/usr/bin/env python3
# -*- coding: utf-8 -*-

"""
🧪 REST API 테스트 스크립트

Flask 서버 없이 직접 테스트할 수 있는 데모 버전
"""

import sqlite3
import json
from datetime import datetime


class APISimulator:
    """REST API 시뮬레이터 (Flask 없이 테스트)"""

    def __init__(self, db_file='gogs_research.db'):
        self.db_file = db_file

    def get_connection(self):
        """DB 연결"""
        conn = sqlite3.connect(self.db_file)
        conn.row_factory = sqlite3.Row
        return conn

    def GET_researchers(self):
        """GET /api/researchers"""
        try:
            conn = self.get_connection()
            cursor = conn.cursor()
            cursor.execute("SELECT * FROM researchers")
            researchers = [dict(row) for row in cursor.fetchall()]
            conn.close()

            return {
                'status': 'success',
                'count': len(researchers),
                'data': researchers
            }, 200
        except Exception as e:
            return {'status': 'error', 'message': str(e)}, 500

    def GET_experiments(self):
        """GET /api/experiments"""
        try:
            conn = self.get_connection()
            cursor = conn.cursor()
            cursor.execute("""
                SELECT
                    e.experiment_id,
                    e.title,
                    e.description,
                    e.status,
                    e.start_date,
                    e.end_date,
                    r.name as researcher_name
                FROM experiments e
                JOIN researchers r ON e.researcher_id = r.researcher_id
                ORDER BY e.experiment_id DESC
            """)
            experiments = [dict(row) for row in cursor.fetchall()]
            conn.close()

            return {
                'status': 'success',
                'count': len(experiments),
                'data': experiments
            }, 200
        except Exception as e:
            return {'status': 'error', 'message': str(e)}, 500

    def GET_measurements(self):
        """GET /api/measurements"""
        try:
            conn = self.get_connection()
            cursor = conn.cursor()
            cursor.execute("""
                SELECT
                    m.measurement_id,
                    m.metric_name,
                    m.value,
                    m.unit,
                    m.recorded_at,
                    e.title as experiment_title
                FROM measurements m
                JOIN experiments e ON m.experiment_id = e.experiment_id
                ORDER BY m.recorded_at DESC
                LIMIT 10
            """)
            measurements = [dict(row) for row in cursor.fetchall()]
            conn.close()

            return {
                'status': 'success',
                'count': len(measurements),
                'data': measurements
            }, 200
        except Exception as e:
            return {'status': 'error', 'message': str(e)}, 500

    def GET_statistics(self):
        """GET /api/statistics"""
        try:
            conn = self.get_connection()
            cursor = conn.cursor()

            stats = {}

            cursor.execute("SELECT COUNT(*) as count FROM researchers")
            stats['total_researchers'] = cursor.fetchone()['count']

            cursor.execute("SELECT COUNT(*) as count FROM experiments")
            stats['total_experiments'] = cursor.fetchone()['count']

            cursor.execute("SELECT COUNT(*) as count FROM experiments WHERE status = '완료'")
            stats['completed_experiments'] = cursor.fetchone()['count']

            cursor.execute("SELECT COUNT(*) as count FROM measurements")
            stats['total_measurements'] = cursor.fetchone()['count']

            cursor.execute("SELECT AVG(value) as avg_value FROM measurements WHERE metric_name = 'throughput'")
            row = cursor.fetchone()
            stats['avg_throughput'] = row['avg_value'] if row['avg_value'] else 0

            conn.close()

            return {
                'status': 'success',
                'data': stats
            }, 200
        except Exception as e:
            return {'status': 'error', 'message': str(e)}, 500

    def POST_researcher(self, name, department=None, email=None):
        """POST /api/researchers"""
        try:
            if not name or not name.strip():
                return {'status': 'error', 'message': 'Name cannot be empty'}, 400

            conn = self.get_connection()
            cursor = conn.cursor()

            try:
                cursor.execute(
                    "INSERT INTO researchers (name, department, email) VALUES (?, ?, ?)",
                    (name, department, email)
                )
                conn.commit()
                researcher_id = cursor.lastrowid
                conn.close()

                return {
                    'status': 'success',
                    'message': f'Researcher created with ID {researcher_id}',
                    'researcher_id': researcher_id
                }, 201

            except sqlite3.IntegrityError:
                conn.close()
                return {
                    'status': 'error',
                    'message': 'Duplicate name or constraint violation'
                }, 409

        except Exception as e:
            return {'status': 'error', 'message': str(e)}, 500

    def POST_measurement(self, experiment_id, metric_name, value, unit=None):
        """POST /api/measurements"""
        try:
            conn = self.get_connection()
            cursor = conn.cursor()

            cursor.execute(
                "INSERT INTO measurements (experiment_id, metric_name, value, unit) VALUES (?, ?, ?, ?)",
                (experiment_id, metric_name, value, unit)
            )
            conn.commit()
            measurement_id = cursor.lastrowid
            conn.close()

            return {
                'status': 'success',
                'message': f'Measurement created with ID {measurement_id}',
                'measurement_id': measurement_id
            }, 201

        except Exception as e:
            return {'status': 'error', 'message': str(e)}, 500

    def PUT_experiment(self, experiment_id, status):
        """PUT /api/experiments/{id}"""
        try:
            valid_statuses = ['진행중', '완료', '중단']
            if status not in valid_statuses:
                return {
                    'status': 'error',
                    'message': f'Invalid status. Must be one of {valid_statuses}'
                }, 400

            conn = self.get_connection()
            cursor = conn.cursor()

            cursor.execute("SELECT * FROM experiments WHERE experiment_id = ?", (experiment_id,))
            if not cursor.fetchone():
                conn.close()
                return {
                    'status': 'error',
                    'message': f'Experiment {experiment_id} not found'
                }, 404

            cursor.execute("UPDATE experiments SET status = ? WHERE experiment_id = ?", (status, experiment_id))
            conn.commit()
            conn.close()

            return {
                'status': 'success',
                'message': f'Experiment {experiment_id} updated to {status}'
            }, 200

        except Exception as e:
            return {'status': 'error', 'message': str(e)}, 500


def print_response(method, endpoint, response, status_code):
    """응답 출력"""
    print(f"\n【 {method} {endpoint} 】")
    print(f"상태: {status_code}")
    print(f"응답:")
    print(json.dumps(response, indent=2, ensure_ascii=False))


def main():
    """API 테스트"""

    print("=" * 80)
    print("🧪 REST API 테스트")
    print("=" * 80)

    api = APISimulator()

    # PHASE 1: GET (READ)
    print("\n" + "=" * 80)
    print("【 PHASE 1: GET (READ) 메서드 】")
    print("=" * 80)

    response, status = api.GET_researchers()
    print_response("GET", "/api/researchers", response, status)

    response, status = api.GET_experiments()
    print_response("GET", "/api/experiments", response, status)

    response, status = api.GET_measurements()
    print_response("GET", "/api/measurements", response, status)

    response, status = api.GET_statistics()
    print_response("GET", "/api/statistics", response, status)

    # PHASE 2: POST (CREATE)
    print("\n" + "=" * 80)
    print("【 PHASE 2: POST (CREATE) 메서드 】")
    print("=" * 80)

    print("\n[새 연구자 추가]")
    response, status = api.POST_researcher("이새로움", "인공지능과", "lee.new@gogs.dev")
    print_response("POST", "/api/researchers", response, status)

    print("\n[새 측정 결과 추가]")
    response, status = api.POST_measurement(1, "accuracy", 96.5, "%")
    print_response("POST", "/api/measurements", response, status)

    # PHASE 3: PUT (UPDATE)
    print("\n" + "=" * 80)
    print("【 PHASE 3: PUT (UPDATE) 메서드 】")
    print("=" * 80)

    print("\n[실험 상태 변경: 진행중 → 완료]")
    response, status = api.PUT_experiment(3, "완료")
    print_response("PUT", "/api/experiments/3", response, status)

    # PHASE 4: 결과 확인
    print("\n" + "=" * 80)
    print("【 PHASE 4: 변경 확인 】")
    print("=" * 80)

    response, status = api.GET_statistics()
    print_response("GET", "/api/statistics (변경 후)", response, status)

    # 최종 요약
    print("\n" + "=" * 80)
    print("✨ API 테스트 완료!")
    print("=" * 80)

    print("\n【 HTTP 상태 코드 해석 】")
