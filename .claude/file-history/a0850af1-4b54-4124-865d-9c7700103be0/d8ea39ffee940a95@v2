    shared_counter = mp.Value('i', 0)  # 공유 정수 (i = int)
    lock = Lock()

    def increment_without_lock(counter, num):
        """Lock 없이 증가"""
        for _ in range(num):
            counter.value += 1

    def increment_with_lock(counter, lock, num):
        """Lock으로 보호"""
        for _ in range(num):
            with lock:
                counter.value += 1

    # 안전하지 않은 방식
    counter1 = mp.Value('i', 0)
    processes_unsafe = [
        Process(target=increment_without_lock, args=(counter1, 1000))
        for _ in range(4)
    ]

    print("✓ Lock 없이 증가 (안전하지 않음):")
    for p in processes_unsafe:
        p.start()
    for p in processes_unsafe:
        p.join()
    print(f"  최종 값: {counter1.value} (기대값: 4000) ❌")
    print()

    # 안전한 방식
    counter2 = mp.Value('i', 0)
    processes_safe = [
        Process(target=increment_with_lock, args=(counter2, lock, 1000))
        for _ in range(4)
    ]

    print("✓ Lock으로 보호하여 증가 (안전함):")
    for p in processes_safe:
        p.start()
    for p in processes_safe:
        p.join()
    print(f"  최종 값: {counter2.value} (기대값: 4000) ✅")
    print()

    print("💡 결론: Lock으로 공유 자원을 보호합니다!")
    print()


