    print("  2️⃣ Pipe: 일대일 통신 (한 쌍의 프로세스)")
    print()

    def producer(queue, num):
        """데이터 생산 프로세스"""
        for i in range(num):
            data = f"Item {i+1}"
            queue.put(data)
            print(f"  [생산] {data} 추가")
            time.sleep(0.1)
        queue.put(None)  # 종료 신호

    def consumer(queue):
        """데이터 소비 프로세스"""
        while True:
            data = queue.get()
            if data is None:
                print(f"  [소비] 작업 완료!")
                break
            print(f"  [소비] {data} 처리")
            time.sleep(0.15)

    print("✓ Queue를 사용한 프로듀서-컨슈머:")
    print()

    q = Queue()
    p_producer = Process(target=producer, args=(q, 3))
    p_consumer = Process(target=consumer, args=(q,))

    p_producer.start()
    p_consumer.start()

    p_producer.join()
    p_consumer.join()

    print()

    def ping_pong_sender(conn, num):
        """핑퐁 송신자"""
        for i in range(num):
            conn.send(f"Ping {i+1}")
            response = conn.recv()
            print(f"  [송신] {response} 수신")
            time.sleep(0.1)
        conn.close()

    def ping_pong_receiver(conn, num):
        """핑퐁 수신자"""
        for i in range(num):
            message = conn.recv()
            print(f"  [수신] {message} 받음")
            conn.send(f"Pong {i+1}")
            time.sleep(0.1)
        conn.close()

    print("✓ Pipe를 사용한 양방향 통신:")
    print()

    parent_conn, child_conn = Pipe()
    p_sender = Process(target=ping_pong_sender, args=(child_conn, 3))
    p_receiver = Process(target=ping_pong_receiver, args=(parent_conn, 3))

    p_sender.start()
    p_receiver.start()

    p_sender.join()
    p_receiver.join()

    print()

    print("💡 결론: Queue와 Pipe로 프로세스 간 통신합니다!")
    print()


