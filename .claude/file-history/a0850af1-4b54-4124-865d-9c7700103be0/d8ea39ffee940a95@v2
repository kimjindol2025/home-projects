    # 패턴 1: 맵-리듀스 (데이터 분산 처리)
    def map_function(data):
        """각 프로세스에서 실행"""
        return sum(x * x for x in data)

    def reduce_function(results):
        """결과 합산"""
        return sum(results)

    print("✓ 맵-리듀스 패턴 (대용량 데이터 분산 처리):")
    print()

    # 데이터를 4개 청크로 분할
    all_data = list(range(1, 101))
    chunk_size = len(all_data) // 4
    chunks = [all_data[i:i+chunk_size] for i in range(0, len(all_data), chunk_size)]

    with Pool(4) as pool:
        map_results = pool.map(map_function, chunks)

    final_result = reduce_function(map_results)
    print(f"  입력 데이터: 1~100 (100개)")
    print(f"  각 청크 제곱합: {map_results}")
    print(f"  최종 결과: {final_result}")
    print()

