// Phase 13 v14.2: Parser — 프랫 파싱과 우선순위의 질서
// Lexer 출력을 받아 AST(Abstract Syntax Tree)로 변환하는 파서 구현

use crate::v14_0_lexer::{Lexer, Token, TokenKind};
use std::fmt;

/// 연산자의 우선순위(결합력)
#[derive(Debug, Clone, Copy, PartialOrd, PartialEq, Ord, Eq)]
pub enum Precedence {
    Lowest = 1,
    Equality = 2,      // ==, !=
    Comparison = 3,    // <, >, <=, >=
    Sum = 4,           // +, -
    Product = 5,       // *, /
    Prefix = 6,        // -x, !x
    Call = 7,          // 함수 호출
}

impl Precedence {
    fn as_i32(&self) -> i32 {
        *self as i32
    }
}

/// 전위 연산자 (단항)
#[derive(Debug, Clone, PartialEq)]
pub enum PrefixOp {
    Minus,
    Bang,
}

impl fmt::Display for PrefixOp {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        match self {
            Self::Minus => write!(f, "-"),
            Self::Bang => write!(f, "!"),
        }
    }
}

/// 중위 연산자 (이항)
#[derive(Debug, Clone, PartialEq)]
pub enum InfixOp {
    Plus,
    Minus,
    Multiply,
    Divide,
    Modulo,
    Equal,
    NotEqual,
    Less,
    LessEqual,
    Greater,
    GreaterEqual,
}

impl fmt::Display for InfixOp {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        match self {
            Self::Plus => write!(f, "+"),
            Self::Minus => write!(f, "-"),
            Self::Multiply => write!(f, "*"),
            Self::Divide => write!(f, "/"),
            Self::Modulo => write!(f, "%"),
            Self::Equal => write!(f, "=="),
            Self::NotEqual => write!(f, "!="),
            Self::Less => write!(f, "<"),
            Self::LessEqual => write!(f, "<="),
            Self::Greater => write!(f, ">"),
            Self::GreaterEqual => write!(f, ">="),
        }
    }
}

/// AST 노드: 표현식(Expression)
#[derive(Debug, Clone, PartialEq)]
pub enum Expression {
    /// 정수 리터럴
    Literal(i32),

    /// 실수 리터럴
    FloatLiteral(f64),

    /// 전위 연산 (예: -5, !true)
    Prefix {
        operator: PrefixOp,
        operand: Box<Expression>,
    },

    /// 중위 연산 (예: 5 + 3, x * y)
    Infix {
        left: Box<Expression>,
        operator: InfixOp,
        right: Box<Expression>,
    },

    /// 괄호 표현식
    Grouped(Box<Expression>),
}

impl fmt::Display for Expression {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        match self {
            Self::Literal(n) => write!(f, "{}", n),
            Self::FloatLiteral(n) => write!(f, "{}", n),
            Self::Prefix { operator, operand } => {
                write!(f, "({}{})", operator, operand)
            }
            Self::Infix {
                left,
                operator,
                right,
            } => {
                write!(f, "({} {} {})", left, operator, right)
            }
            Self::Grouped(expr) => write!(f, "({})", expr),
        }
    }
}

/// 파서: 토큰 스트림을 AST로 변환
pub struct Parser {
    lexer: Lexer,
    cur_token: Token,
    peek_token: Token,
}

impl Parser {
    /// 파서를 초기화합니다.
    pub fn new(mut lexer: Lexer) -> Self {
        let cur_token = lexer.next_token();
        let peek_token = lexer.next_token();
        Parser {
            lexer,
            cur_token,
            peek_token,
        }
    }

    /// 다음 토큰으로 이동합니다.
    fn next_token(&mut self) {
        self.cur_token = self.peek_token.clone();
        self.peek_token = self.lexer.next_token();
    }

    /// 다음 토큰의 우선순위를 반환합니다.
    fn peek_precedence(&self) -> Precedence {
        self.token_precedence(&self.peek_token)
    }

    /// 현재 토큰의 우선순위를 반환합니다.
    fn cur_precedence(&self) -> Precedence {
        self.token_precedence(&self.cur_token)
    }

    /// 토큰의 우선순위를 반환합니다.
    fn token_precedence(&self, token: &Token) -> Precedence {
        match &token.kind {
            TokenKind::Plus | TokenKind::Minus => Precedence::Sum,
            TokenKind::Star | TokenKind::Slash | TokenKind::Percent => Precedence::Product,
            TokenKind::EqualEqual | TokenKind::NotEqual => Precedence::Equality,
            TokenKind::Less
            | TokenKind::Greater
            | TokenKind::LessEqual
            | TokenKind::GreaterEqual => Precedence::Comparison,
            _ => Precedence::Lowest,
        }
    }

    /// 다음 토큰이 주어진 종류인지 확인합니다.
    fn peek_token_is(&self, kind: &TokenKind) -> bool {
        std::mem::discriminant(&self.peek_token.kind) == std::mem::discriminant(kind)
    }

    /// 현재 토큰이 주어진 종류인지 확인합니다.
    fn cur_token_is(&self, kind: &TokenKind) -> bool {
        std::mem::discriminant(&self.cur_token.kind) == std::mem::discriminant(kind)
    }

    /// 파일 끝에 도달했는지 확인합니다.
    fn is_at_end(&self) -> bool {
        matches!(self.cur_token.kind, TokenKind::Eof)
    }

    /// 프로그램(여러 표현식)을 파싱합니다.
    pub fn parse_program(&mut self) -> Result<Vec<Expression>, String> {
        let mut expressions = Vec::new();

        while !self.is_at_end() {
            if matches!(self.cur_token.kind, TokenKind::Semicolon) {
                self.next_token();
                continue;
            }

            match self.parse_expression(Precedence::Lowest) {
                Ok(expr) => expressions.push(expr),
                Err(e) => return Err(e),
            }

            // 다음 표현식까지 이동
            if matches!(self.peek_token.kind, TokenKind::Semicolon | TokenKind::Eof) {
                self.next_token();
            }
        }

        Ok(expressions)
    }

    /// 전위 연산자를 파싱합니다.
    fn parse_prefix(&mut self) -> Result<Expression, String> {
        match &self.cur_token.kind {
            // 정수 리터럴
            TokenKind::Int(n) => Ok(Expression::Literal(*n)),

            // 실수 리터럴
            TokenKind::Float(f) => Ok(Expression::FloatLiteral(*f)),

            // 전위 연산자: - 또는 !
            TokenKind::Minus => {
                self.next_token();
                let operand = self.parse_expression(Precedence::Prefix)?;
                Ok(Expression::Prefix {
                    operator: PrefixOp::Minus,
                    operand: Box::new(operand),
                })
            }

            TokenKind::Bang => {
                self.next_token();
                let operand = self.parse_expression(Precedence::Prefix)?;
                Ok(Expression::Prefix {
                    operator: PrefixOp::Bang,
                    operand: Box::new(operand),
                })
            }

            // 괄호 표현식
            TokenKind::LeftParen => {
                self.next_token();
                let expr = self.parse_expression(Precedence::Lowest)?;

                if !self.peek_token_is(&TokenKind::RightParen) {
                    return Err(format!(
                        "Expected ')', got '{}'",
                        self.peek_token.kind
                    ));
                }
                self.next_token();

                Ok(Expression::Grouped(Box::new(expr)))
            }

            _ => Err(format!(
                "Unexpected token in prefix position: {}",
                self.cur_token.kind
            )),
        }
    }

    /// 중위 연산자를 파싱합니다.
    fn parse_infix(&mut self, left: Expression) -> Result<Expression, String> {
        let cur_precedence = self.cur_precedence();

        let operator = match &self.cur_token.kind {
            TokenKind::Plus => InfixOp::Plus,
            TokenKind::Minus => InfixOp::Minus,
            TokenKind::Star => InfixOp::Multiply,
            TokenKind::Slash => InfixOp::Divide,
            TokenKind::Percent => InfixOp::Modulo,
            TokenKind::EqualEqual => InfixOp::Equal,
            TokenKind::NotEqual => InfixOp::NotEqual,
            TokenKind::Less => InfixOp::Less,
            TokenKind::LessEqual => InfixOp::LessEqual,
            TokenKind::Greater => InfixOp::Greater,
            TokenKind::GreaterEqual => InfixOp::GreaterEqual,
            _ => return Err(format!("Unknown infix operator: {}", self.cur_token.kind)),
        };

        self.next_token();

        // 오른쪽을 더 높은 우선순위로 파싱
        let right = self.parse_expression(cur_precedence)?;

        Ok(Expression::Infix {
            left: Box::new(left),
            operator,
            right: Box::new(right),
        })
    }

    /// [핵심] 프랫 파싱: 우선순위를 비교하며 표현식을 재귀적으로 파싱합니다.
    pub fn parse_expression(&mut self, precedence: Precedence) -> Result<Expression, String> {
        // 1단계: 전위 처리 (숫자 또는 -x 등)
        let mut left_exp = self.parse_prefix()?;

        // 2단계: 루프 (우선순위가 떨어질 때까지 계속 결합)
        while !self.peek_token_is(&TokenKind::Semicolon)
            && !self.peek_token_is(&TokenKind::Eof)
            && !self.peek_token_is(&TokenKind::RightParen)
            && precedence < self.peek_precedence()
        {
            self.next_token();
            left_exp = self.parse_infix(left_exp)?;
        }

        Ok(left_exp)
    }
}

