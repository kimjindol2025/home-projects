fn demo_literal() {
    println!("[데모 1] 단순 숫자");
    println!("─────────────────────");

    let code = "5;";
    println!("Input: {}", code);

    let lexer = Lexer::new(code);
    let mut parser = Parser::new(lexer);

    match parser.parse_program() {
        Ok(exprs) => {
            for expr in &exprs {
                println!("AST: {}", expr);
            }
        }
        Err(e) => println!("Error: {}", e),
    }
    println!();
}

