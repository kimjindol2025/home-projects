    match parser.parse_program() {
        Ok(exprs) => {
            for expr in &exprs {
                println!("AST: {}", expr);
                println!("해석: 2 + (3 * 4) = 2 + 12 = 14");
            }
        }
        Err(e) => println!("Error: {}", e),
    }
    println!();
}

