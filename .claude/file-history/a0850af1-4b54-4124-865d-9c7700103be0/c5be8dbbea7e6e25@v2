fn demo_complex_expression() {
    println!("[데모 7] 프랫 파싱 핵심 예제");
    println!("─────────────────────");

    let code = "5 + 10 * 2;";
    println!("Input: {}", code);
    println!("Naive (잘못된) 파싱: (5 + 10) * 2 = 15 * 2 = 30 ❌");
    println!("Pratt (올바른) 파싱: 5 + (10 * 2) = 5 + 20 = 25 ✓");

    let lexer = Lexer::new(code);
    let mut parser = Parser::new(lexer);

    match parser.parse_program() {
        Ok(exprs) => {
            for expr in &exprs {
                println!("AST: {}", expr);
            }
        }
        Err(e) => println!("Error: {}", e),
    }
    println!();
}

fn demo_deep_nesting() {
    println!("[데모 8] 깊은 중첩");
    println!("─────────────────────");

    let code = "1 + 2 * 3 + 4 * 5;";
    println!("Input: {}", code);

    let lexer = Lexer::new(code);
    let mut parser = Parser::new(lexer);

    match parser.parse_program() {
        Ok(exprs) => {
            for expr in &exprs {
                println!("AST: {}", expr);
                println!("해석: (1 + (2 * 3)) + (4 * 5)");
                println!("     = (1 + 6) + 20");
                println!("     = 7 + 20");
                println!("     = 27");
            }
        }
        Err(e) => println!("Error: {}", e),
    }
    println!();
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_parse_literal() {
        let lexer = Lexer::new("42;");
        let mut parser = Parser::new(lexer);
        let exprs = parser.parse_program().unwrap();
        assert_eq!(exprs.len(), 1);
        assert_eq!(exprs[0], Expression::Literal(42));
    }

    #[test]
    fn test_parse_prefix_minus() {
        let lexer = Lexer::new("-5;");
        let mut parser = Parser::new(lexer);
        let exprs = parser.parse_program().unwrap();
        assert_eq!(exprs.len(), 1);
        match &exprs[0] {
            Expression::Prefix {
                operator: PrefixOp::Minus,
                ..
            } => (),
            _ => panic!("Expected prefix minus"),
        }
    }

    #[test]
    fn test_parse_infix_addition() {
        let lexer = Lexer::new("2 + 3;");
        let mut parser = Parser::new(lexer);
        let exprs = parser.parse_program().unwrap();
        assert_eq!(exprs.len(), 1);
        match &exprs[0] {
            Expression::Infix {
                operator: InfixOp::Plus,
                ..
            } => (),
            _ => panic!("Expected infix plus"),
        }
    }

    #[test]
    fn test_precedence_multiplication_over_addition() {
        let lexer = Lexer::new("2 + 3 * 4;");
        let mut parser = Parser::new(lexer);
        let exprs = parser.parse_program().unwrap();

        // AST should be: (2 + (3 * 4))
        match &exprs[0] {
            Expression::Infix {
                left,
                operator: InfixOp::Plus,
                right,
            } => {
                assert_eq!(**left, Expression::Literal(2));
                match &**right {
                    Expression::Infix {
                        operator: InfixOp::Multiply,
                        ..
                    } => (),
                    _ => panic!("Expected multiplication on right"),
                }
            }
            _ => panic!("Expected infix plus at top level"),
        }
    }

    #[test]
    fn test_grouped_expression() {
        let lexer = Lexer::new("(2 + 3) * 4;");
        let mut parser = Parser::new(lexer);
        let exprs = parser.parse_program().unwrap();

        // AST should be: ((2 + 3) * 4)
        match &exprs[0] {
            Expression::Infix {
                left,
                operator: InfixOp::Multiply,
                ..
            } => {
                match &**left {
                    Expression::Grouped(_) => (),
                    _ => panic!("Expected grouped expression on left"),
                }
            }
            _ => panic!("Expected multiplication at top level"),
        }
    }

    #[test]
    fn test_complex_precedence() {
        let lexer = Lexer::new("5 + 10 * 2;");
        let mut parser = Parser::new(lexer);
        let exprs = parser.parse_program().unwrap();

        // AST should be: (5 + (10 * 2))
        match &exprs[0] {
            Expression::Infix {
                left,
                operator: InfixOp::Plus,
                right,
            } => {
                assert_eq!(**left, Expression::Literal(5));
                match &**right {
                    Expression::Infix {
                        left: inner_left,
                        operator: InfixOp::Multiply,
                        right: inner_right,
                    } => {
                        assert_eq!(**inner_left, Expression::Literal(10));
                        assert_eq!(**inner_right, Expression::Literal(2));
                    }
                    _ => panic!("Expected multiplication on right"),
                }
            }
            _ => panic!("Expected infix plus at top level"),
        }
    }

    #[test]
    fn test_left_associative() {
        let lexer = Lexer::new("1 + 2 + 3;");
        let mut parser = Parser::new(lexer);
        let exprs = parser.parse_program().unwrap();

        // AST should be: ((1 + 2) + 3)
        match &exprs[0] {
            Expression::Infix {
                left,
                operator: InfixOp::Plus,
                right,
            } => {
                // Left should be another addition
                match &**left {
                    Expression::Infix {
                        operator: InfixOp::Plus,
                        ..
                    } => (),
                    _ => panic!("Expected another addition on left"),
                }
                assert_eq!(**right, Expression::Literal(3));
            }
            _ => panic!("Expected infix plus at top level"),
        }
    }

    #[test]
    fn test_mixed_operators() {
        let lexer = Lexer::new("1 + 2 * 3 + 4 * 5;");
        let mut parser = Parser::new(lexer);
        let exprs = parser.parse_program().unwrap();

        // AST should be: ((1 + (2 * 3)) + (4 * 5))
        assert_eq!(exprs.len(), 1);
        assert!(matches!(&exprs[0], Expression::Infix { .. }));
    }
}
