// ============================================================================
// [1] 단순 패턴 매칭 (Simple Pattern Matching)
// ============================================================================
//
// match를 통한 값 비교와 할당
//
fn simple_patterns() {
    println!("[1] 단순 패턴 매칭");
    println!("────────────────────────────────────────────────────────────");

    // 패턴 1: 기본 값 비교
    {
        println!("✓ 기본 값 비교");
        let x = 5;
        match x {
            1 => println!("  x = 1"),
            2 => println!("  x = 2"),
            5 => println!("  x = 5"),
            _ => println!("  x = 기타"),
        }
    }

    // 패턴 2: match를 표현식으로 사용
    {
        println!("✓ match를 값으로 할당");
        let day = 3;
        let day_name = match day {
            1 => "월요일",
            2 => "화요일",
            3 => "수요일",
            4 => "목요일",
            5 => "금요일",
            6 => "토요일",
            7 => "일요일",
            _ => "미정의",
        };
        println!("  요일 = {}", day_name);
    }

    // 패턴 3: 상태에 따른 처리
    {
        println!("✓ 상태 기반 처리");
        let status = "RUNNING";
        match status {
            "IDLE" => println!("  상태: 유휴"),
            "RUNNING" => println!("  상태: 실행 중"),
            "STOPPED" => println!("  상태: 중지"),
            _ => println!("  상태: 미정의"),
        }
    }

    println!();
}

// ============================================================================
// [2] 전수 조사 (Exhaustiveness Check)
// ============================================================================
//
// 모든 경우를 빠짐없이 처리
//
fn exhaustiveness_check() {
    println!("[2] 전수 조사");
    println!("────────────────────────────────────────────────────────────");

    // 조사 1: 와일드카드 사용
    {
        println!("✓ 와일드카드(_)로 모든 경우 처리");
        let x = 100;
        match x {
            1 => println!("  1입니다"),
            2 => println!("  2입니다"),
            _ => println!("  그 외입니다"),
        }
    }

    // 조사 2: 이진 선택
    {
        println!("✓ 이진 선택: true/false");
        let is_valid = true;
        match is_valid {
            true => println!("  유효함"),
            false => println!("  유효하지 않음"),
        }
    }

    // 조사 3: 범위 커버리지
    {
        println!("✓ 범위로 모든 경우 커버");
        let score = 85;
        match score {
            0..=60 => println!("  F학점"),
            61..=70 => println!("  D학점"),
            71..=80 => println!("  C학점"),
            81..=90 => println!("  B학점"),
            91..=100 => println!("  A학점"),
            _ => println!("  오류"),
        }
    }

    // 조사 4: 복합 상태
    {
        println!("✓ 여러 상태의 완전한 처리");
        let cmd = "help";
        match cmd {
            "start" => println!("  시작"),
            "stop" => println!("  중지"),
            "help" => println!("  도움말"),
            "exit" => println!("  종료"),
            _ => println!("  알 수 없는 명령"),
        }
    }

    println!();
}

// ============================================================================
// [3] 다중 패턴 (Multiple Patterns)
// ============================================================================
//
// OR 패턴(|)으로 여러 값을 한 번에 처리
//
fn multiple_patterns() {
    println!("[3] 다중 패턴");
    println!("────────────────────────────────────────────────────────────");

    // 다중 1: OR 패턴
    {
        println!("✓ OR 패턴: 여러 값이 같은 처리");
        let vowel = 'e';
        match vowel {
            'a' | 'e' | 'i' | 'o' | 'u' => println!("  모음"),
            _ => println!("  자음"),
        }
    }

    // 다중 2: 명령어 그룹
    {
        println!("✓ 명령어 그룹");
        let key = "q";
        match key {
            "exit" | "quit" | "q" => println!("  프로그램 종료"),
            "help" | "h" | "?" => println!("  도움말 표시"),
            "run" | "execute" | "go" => println!("  실행"),
            _ => println!("  알 수 없는 명령"),
        }
    }

    // 다중 3: 범위 + 다중 패턴
    {
        println!("✓ 범위와 명시적 값 결합");
        let code = 201;
        match code {
            200 | 201 | 202 => println!("  성공 (200~202)"),
            300..=307 => println!("  리다이렉트 (300~307)"),
            400..=499 => println!("  클라이언트 오류 (400~499)"),
            _ => println!("  기타"),
        }
    }

    println!();
}

// ============================================================================
// [4] 가드 패턴 (Guard Pattern)
// ============================================================================
//
// 패턴 매칭 후 추가 조건 (if guard)
//
fn guard_patterns() {
    println!("[4] 가드 패턴");
    println!("────────────────────────────────────────────────────────────");

    // 가드 1: 기본 가드
    {
        println!("✓ 가드로 세밀한 조건 표현");
        let age = 25;
        match age {
            0..=17 if age < 13 => println!("  어린이 ({} 세)", age),
            0..=17 => println!("  청소년 ({} 세)", age),
            18..=64 if age >= 65 => println!("  노인 ({} 세)", age),
            18..=64 => println!("  성인 ({} 세)", age),
            _ => println!("  미정의"),
        }
    }

    // 가드 2: 상태 + 조건
    {
        println!("✓ 상태와 값의 결합");
        let core_id = 7;
        let system_status = "OVERLOAD";
        match core_id {
            1 => println!("  [Core 1] 메인 프로세서"),
            2..=4 => println!("  [Cores 2-4] 보조 프로세서 그룹"),
            5..=10 if system_status == "OVERLOAD" => {
                println!("  [Critical] Core {} 과부하! 즉각 조치 필요", core_id);
            }
            5..=10 => println!("  [Stable] Core {} 대기", core_id),
            _ => println!("  [Unknown] 미정의 코어"),
        }
    }

    // 가드 3: 복잡한 조건
    {
        println!("✓ 복합 조건 (가드)");
        let value = 50;
        let threshold = 70;
        match value {
            v if v > threshold => println!("  높음 ({})", v),
            v if v > threshold / 2 => println!("  중간 ({})", v),
            _ => println!("  낮음 ({})", value),
        }
    }

    println!();
}

// ============================================================================
// [5] 구조적 분해 (Destructuring)
// ============================================================================
//
// 복잡한 데이터를 패턴으로 분해
//
fn destructuring_patterns() {
    println!("[5] 구조적 분해");
    println!("────────────────────────────────────────────────────────────");

    // 분해 1: 튜플 분해
    {
        println!("✓ 튜플 분해");
        let result = (true, 42, "success");
        match result {
            (true, code, msg) => {
                println!("  성공: 코드={}, 메시지={}", code, msg);
            }
            (false, _, msg) => {
                println!("  실패: {}", msg);
            }
        }
    }

    // 분해 2: 중첩된 튜플
    {
        println!("✓ 중첩 튜플 분해");
        let system = ("RUNNING", (7, 85));  // (상태, (코어ID, 부하))
        match system {
            ("RUNNING", (core, load)) if load > 80 => {
                println!("  Core {} 과부하: {}%", core, load);
            }
            ("RUNNING", (core, load)) => {
                println!("  Core {} 정상: {}%", core, load);
            }
            (status, _) => {
                println!("  상태: {}", status);
            }
        }
    }

    // 분해 3: 와일드카드 사용
    {
        println!("✓ 불필요한 값은 와일드카드(_)로");
        let data = (100, 200, 300);
        match data {
            (a, _, c) => {
                println!("  첫 번째: {}, 세 번째: {}", a, c);
            }
        }
    }

    println!();
}

// ============================================================================
// [6] 상태 머신 설계 (State Machine)
// ============================================================================
//
// 상태와 전이를 match로 표현
//
fn state_machine_design() {
    println!("[6] 상태 머신 설계");
    println!("────────────────────────────────────────────────────────────");

    // 상태 머신 1: 시스템 상태
    {
        println!("✓ 시스템 상태 전이");
        #[derive(Debug)]
        enum State {
            IDLE,
            RUNNING(u32),      // 코어ID
            ERROR(String),      // 에러 메시지
        }

        let current_state = State::RUNNING(7);

        match current_state {
            State::IDLE => {
                println!("  상태: 유휴 (대기 중)");
            }
            State::RUNNING(core_id) => {
                println!("  상태: 실행 중 (Core {})", core_id);
            }
            State::ERROR(msg) => {
                println!("  상태: 오류 ({})", msg);
            }
        }
    }

    // 상태 머신 2: 상태 전이 로직
    {
        println!("✓ 상태-이벤트 전이");
        enum State {
            IDLE,
            RUNNING,
            SHUTDOWN,
        }

        enum Event {
            START,
            STOP,
            RESTART,
        }

        let current_state = State::RUNNING;
        let event = Event::STOP;

        let next_state = match (current_state, event) {
            (State::IDLE, Event::START) => {
                println!("  전이: IDLE → RUNNING");
                State::RUNNING
            }
            (State::RUNNING, Event::STOP) => {
                println!("  전이: RUNNING → IDLE");
                State::IDLE
            }
            (State::RUNNING, Event::RESTART) => {
                println!("  전이: RUNNING → RUNNING (재시작)");
                State::RUNNING
            }
            (state, _) => {
                println!("  전이 불가능");
                state
            }
        };
    }

    // 상태 머신 3: 액션 플랜
    {
        println!("✓ 상태에 따른 액션 플랜");
        let system_status = "OVERLOAD";

        let action_plan = match system_status {
            "STABLE" => "Monitor (모니터링)",
            "WARNING" => "Alert (경고)",
            "OVERLOAD" => "Force Cooling (강제 냉각)",
            _ => "Standard Procedure (표준 절차)",
        };

        println!("  Action Plan: {}", action_plan);
    }

    println!();
}

// ============================================================================
// [7] 복잡한 패턴 조합 (Complex Patterns)
// ============================================================================
//
// 실무에서 사용하는 복잡한 패턴들
//
fn complex_patterns() {
    println!("[7] 복잡한 패턴 조합");
    println!("────────────────────────────────────────────────────────────");

    // 복잡 1: 실무 시스템 모니터링
    {
        println!("✓ 시스템 모니터링 로직");
        struct SystemStatus {
            state: String,
            temperature: u32,
            load: u32,
        }

        let system = SystemStatus {
            state: "RUNNING".to_string(),
            temperature: 95,
            load: 85,
        };

        let action = match (&system.state, system.temperature, system.load) {
            ("RUNNING", 100..=u32::MAX, _) => "EMERGENCY_SHUTDOWN",
            ("RUNNING", 80..=99, load) if load > 90 => "CRITICAL_ALERT",
            ("RUNNING", 80..=99, _) => "THROTTLE",
            ("RUNNING", _, _) => "MONITOR",
            ("IDLE", _, _) => "STANDBY",
            ("ERROR", _, _) => "INVESTIGATE",
            _ => "UNKNOWN",
        };

        println!("  Action: {}", action);
    }

    // 복잡 2: 통신 메시지 처리
    {
        println!("✓ 메시지 처리");
        enum Message {
            Connect { addr: String, port: u16 },
            Disconnect,
            Data(usize),
        }

        let msg = Message::Connect {
            addr: "192.168.1.1".to_string(),
            port: 8080,
        };

        match msg {
            Message::Connect { port, .. } if port == 8080 => {
                println!("  HTTP 연결 감지");
            }
            Message::Connect { port, .. } => {
                println!("  포트 {} 연결", port);
            }
            Message::Disconnect => println!("  연결 해제"),
            Message::Data(bytes) if bytes > 1024 => {
                println!("  대용량 데이터: {} bytes", bytes);
            }
            Message::Data(bytes) => {
                println!("  데이터 수신: {} bytes", bytes);
            }
        }
    }

    // 복잡 3: 모든 패턴의 결합
    {
        println!("✓ 패턴의 종합 예제");
        let (status, (core_id, temp)) = ("RUNNING", (5, 85));

        match (status, core_id) {
            ("RUNNING", 1) => println!("  Main Core"),
            ("RUNNING", 2..=4) | ("RUNNING", 6..=8) => {
                println!("  Auxiliary Core Group");
            }
            ("RUNNING", id) if id > 8 => println!("  Extended Core"),
            ("IDLE", _) => println!("  Idle State"),
            _ => println!("  Unknown"),
        }
    }

    println!();
}

// ============================================================================
// v3.4 핵심 학습 요소
// ============================================================================
//
// 1. 패턴 매칭의 강점
//    - 모든 경우를 동시에 고려
//    - 컴파일러가 누락된 경우를 감지
//    - 코드 가독성 극대화
//
// 2. Match 표현식
//    - 값으로 사용 가능
//    - 패턴 → 표현식 매핑
//
// 3. 전수 조사 (Exhaustiveness)
//    - 와일드카드(_)는 필수
//    - 모든 경로가 처리됨
//    - 런타임 예외 없음
//
// 4. 가드 (if guard)
//    - 패턴 + 추가 조건
//    - 세밀한 제어 가능
//
// 5. 다중 패턴 (|)
//    - 여러 값을 한 번에 처리
//    - 패턴 우선순위 명확
//
// 6. 구조적 분해
//    - 튜플, 구조체 분해
//    - 필요한 값만 추출
//
// 7. 상태 머신
//    - 상태 전이 명확화
//    - 이벤트 기반 설계
//
// 8. 패턴 순서
//    - 구체적 패턴이 먼저
//    - 와일드카드는 마지막
//
// ============================================================================

