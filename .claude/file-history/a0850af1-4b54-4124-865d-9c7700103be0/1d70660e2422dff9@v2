// [예제 8] HashMap vs 다른 컬렉션 - 선택 가이드
// ============================================================================
fn hashmap_vs_others() {
    println!("\n[예제 8] HashMap vs 다른 컬렉션 - 언제 뭘 쓸까?");
    println!("═════════════════════════════════════════");

    println!("\n[HashMap vs Vec]");
    println!("HashMap: 의미 기반 접근 O(1), 순서 없음");
    println!("  → '이름으로 찾기', '설정값 저장'");
    println!("Vec: 인덱스 기반 접근 O(1), 순서 있음");
    println!("  → '첫 번째 아이템 가져오기', '순차 처리'");

    println!("\n[HashMap vs BTreeMap]");
    println!("HashMap: 무작위 순서, O(1) 조회, 예측 불가능");
    println!("BTreeMap: 정렬된 순서, O(log n) 조회, 범위 검색 가능");

    let mut hash_map = HashMap::new();
    hash_map.insert(3, "c");
    hash_map.insert(1, "a");
    hash_map.insert(2, "b");
    println!("HashMap 순회: {:?} (무작위)", hash_map);

    println!("\n[HashMap vs Array (고정 크기)]");
    println!("HashMap: 동적 크기, 임의의 키, 메모리 오버헤드");
    println!("Array: 고정 크기, 정수 인덱스, 오버헤드 없음");

    let mut array = [0; 10];
    array[5] = 100;
    println!("Array[5] = {}", array[5]);

    println!("\n[선택 가이드]");
    println!("1. '이름으로 찾기' → HashMap");
    println!("2. '번호로 찾기' → Vec");
    println!("3. '범위 검색' → BTreeMap");
    println!("4. '고정 크기 인덱싱' → Array");
}

