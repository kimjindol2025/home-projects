use std::collections::HashMap;

// ============================================================================
// [예제 1] HashMap의 기본 - 생성, 삽입, 조회, 제거
// ============================================================================
fn hashmap_basics() {
    println!("\n[예제 1] HashMap의 기본 - 의미 기반 검색");
    println!("═════════════════════════════════════════");

    println!("\n[HashMap 생성]");
    let mut map = HashMap::new();
    println!("empty map: len = {}", map.len());

    println!("\n[데이터 삽입]");
    map.insert("alice", 28);
    map.insert("bob", 35);
    map.insert("charlie", 32);
    println!("삽입 후: {:?}", map);

    println!("\n[데이터 조회]");
    match map.get("alice") {
        Some(age) => println!("alice의 나이: {}", age),
        None => println!("alice를 찾을 수 없습니다"),
    }
    println!("bob이 존재하는가? {}", map.contains_key("bob"));
    println!("david가 존재하는가? {}", map.contains_key("david"));

    println!("\n[데이터 제거]");
    if let Some(removed_age) = map.remove("alice") {
        println!("alice 제거됨 (나이: {})", removed_age);
    }
    println!("제거 후: {:?}", map);
    println!("현재 크기: {}", map.len());

    println!("\n[O(1) 성능]");
    println!("✓ insert: 평균 O(1)");
    println!("✓ get: 평균 O(1)");
    println!("✓ remove: 평균 O(1)");
}

// ============================================================================
// [예제 2] 소유권 관리 - String 소유권 이전 vs &str 참조
// ============================================================================
fn ownership_management() {
    println!("\n[예제 2] 소유권 관리 - 데이터 흐름 제어");
    println!("═════════════════════════════════════════");

    println!("\n[패턴 1: String 소유권 이전]");
    let key = String::from("user_id");
    let value = String::from("alice");
    let mut map = HashMap::new();
    map.insert(key, value);
    // println!("{}", key);      // ❌ 컴파일 에러 - 소유권 이전됨
    // println!("{}", value);    // ❌ 컴파일 에러 - 소유권 이전됨
    println!("map: {:?}", map);
    println!("✓ String은 HashMap에 저장되며 소유권 이전");

    println!("\n[패턴 2: &str 참조만 저장]");
    let name = "bob";
    let age = "35";
    let mut map2: HashMap<&str, &str> = HashMap::new();
    map2.insert(name, age);
    println!("name: {}, age: {}", name, age);
    println!("map: {:?}", map2);
    println!("✓ &str은 참조만 저장하므로 원본 유지");

    println!("\n[패턴 3: 복제를 통한 유지]");
    let key3 = String::from("id");
    let mut map3 = HashMap::new();
    map3.insert(key3.clone(), "charlie");
    println!("key: {}", key3);
    println!("map: {:?}", map3);
    println!("✓ clone()으로 복제하면 원본 유지");
}

// ============================================================================
// [예제 3] entry API - 안전한 조건부 수정
// ============================================================================
fn entry_api() {
    println!("\n[예제 3] entry API - 없으면 넣고, 있으면 수정하기");
    println!("═════════════════════════════════════════");

    println!("\n[패턴 1: 단어 카운팅]");
    let text = "rust rust hash map hash code";
    let mut word_count = HashMap::new();

    for word in text.split_whitespace() {
        *word_count.entry(word).or_insert(0) += 1;
    }
    println!("텍스트: \"{}\"", text);
    println!("단어 빈도: {:?}", word_count);

    println!("\n[패턴 2: or_insert_with로 복잡한 기본값]");
    let mut user_groups: HashMap<&str, Vec<&str>> = HashMap::new();

    user_groups.entry("admin").or_insert_with(Vec::new).push("alice");
    user_groups.entry("admin").or_insert_with(Vec::new).push("bob");
    user_groups.entry("user").or_insert_with(Vec::new).push("charlie");

    println!("그룹: {:?}", user_groups);
    println!("✓ 없으면 Vec::new(), 있으면 push()");

    println!("\n[패턴 3: Occupied vs Vacant]");
    let mut scores = HashMap::new();
    scores.insert("player1", 100);

    match scores.entry("player1") {
        std::collections::hash_map::Entry::Occupied(mut entry) => {
            println!("player1 점수 (수정 전): {}", entry.get());
            *entry.get_mut() += 50;
            println!("player1 점수 (수정 후): {}", entry.get());
        }
        std::collections::hash_map::Entry::Vacant(entry) => {
            entry.insert(50);
        }
    }

    match scores.entry("player2") {
        std::collections::hash_map::Entry::Occupied(entry) => {
            println!("player2: 이미 존재 ({})", entry.get());
        }
        std::collections::hash_map::Entry::Vacant(entry) => {
            println!("player2: 새로 생성");
            entry.insert(0);
        }
    }
}

// ============================================================================
// [예제 4] 순회 방법 - 불변, 가변, 소유권 이전
// ============================================================================
fn iteration_methods() {
    println!("\n[예제 4] 순회 방법 - 데이터 접근 형태");
    println!("═════════════════════════════════════════");

    let mut map = HashMap::new();
    map.insert("a", 1);
    map.insert("b", 2);
    map.insert("c", 3);

    println!("\n[불변 순회 - &]");
    for (key, value) in &map {
        println!("  {}: {}", key, value);
    }
    println!("map 여전히 사용 가능");

    println!("\n[가변 순회 - &mut]");
    for (key, value) in &mut map {
        *value *= 2;
        println!("  {}: {} → {}", key, *value / 2, *value);
    }
    println!("수정 후: {:?}", map);

    println!("\n[소유권 이전 순회]");
    let map2 = HashMap::from([("x", 10), ("y", 20), ("z", 30)]);
    for (key, value) in map2 {
        println!("  {} → {} (소유권 이전)", key, value);
    }
    // println!("{:?}", map2);  // ❌ map2는 더 이상 사용 불가능

    println!("\n[keys(), values() 메서드]");
    let map3 = HashMap::from([("a", 1), ("b", 2), ("c", 3)]);
    println!("keys: {:?}", map3.keys().collect::<Vec<_>>());
    println!("values: {:?}", map3.values().collect::<Vec<_>>());
}

// ============================================================================
// [예제 5] 커스텀 키 타입 - Eq + Hash + Clone
// ============================================================================
fn custom_keys() {
    println!("\n[예제 5] 커스텀 키 타입 - 모든 타입을 키로 사용");
    println!("═════════════════════════════════════════");

    #[derive(Eq, PartialEq, Hash, Clone, Debug)]
    struct UserId(u32);

    #[derive(Eq, PartialEq, Hash, Clone, Debug)]
    struct Email(String);

    println!("\n[패턴 1: UserId 키]");
    let mut user_map = HashMap::new();
    user_map.insert(UserId(1), "alice");
    user_map.insert(UserId(2), "bob");
    user_map.insert(UserId(3), "charlie");

    println!("UserId(1) 조회: {:?}", user_map.get(&UserId(1)));
    println!("UserId(2) 조회: {:?}", user_map.get(&UserId(2)));

    println!("\n[패턴 2: Email 키]");
    let mut email_map = HashMap::new();
    email_map.insert(Email("alice@example.com".to_string()), 28);
    email_map.insert(Email("bob@example.com".to_string()), 35);

    println!("alice 나이: {:?}", email_map.get(&Email("alice@example.com".to_string())));

    println!("\n[복합 키 타입]");
    let mut mixed = HashMap::new();
    mixed.insert(1, "number");
    mixed.insert(2, "key");
    mixed.insert(3, "works");

    for (key, value) in &mixed {
        println!("  {} → {}", key, value);
    }
    println!("✓ i32, String, 커스텀 구조체 모두 가능");
}

// ============================================================================
// [예제 6] 성능과 내부 구조 - 로드 팩터, 해시 함수, SipHash
// ============================================================================
fn performance_patterns() {
    println!("\n[예제 6] 성능 패턴 - 내부 동작 이해하기");
    println!("═════════════════════════════════════════");

    println!("\n[로드 팩터와 자동 확장]");
    let mut map = HashMap::with_capacity(2);
    println!("초기 용량: {}", map.capacity());

    map.insert(1, "a");
    println!("1개 삽입: capacity = {}", map.capacity());

    map.insert(2, "b");
    println!("2개 삽입: capacity = {}", map.capacity());

    map.insert(3, "c");
    println!("3개 삽입 (확장 발생): capacity = {}", map.capacity());

    println!("\n[로드 팩터 = 항목수 / 용량]");
    let len = map.len() as f64;
    let cap = map.capacity() as f64;
    println!("항목 수: {}, 용량: {}, 로드 팩터: {:.2}", len as i32, cap as i32, len / cap);

    println!("\n[with_capacity로 성능 최적화]");
    let mut optimized = HashMap::with_capacity(100);
    for i in 0..50 {
        optimized.insert(i, i * 2);
    }
    println!("50개 미리 예약 후 삽입: capacity = {} (재할당 최소화)", optimized.capacity());

    println!("\n[성능 특성]");
    println!("✓ 평균 시간복잡도: O(1)");
    println!("✓ 최악 시간복잡도: O(n) (해시 충돌 많을 때, 매우 드문 경우)");
    println!("✓ Rust: SipHash 사용 (DoS 공격 방어)");
}

// ============================================================================
// [예제 7] 실제 패턴 - 카운팅, 캐싱, 그룹화, 역인덱싱
// ============================================================================
fn real_world_patterns() {
    println!("\n[예제 7] 실제 사용 패턴 - 현실의 문제 해결");
    println!("═════════════════════════════════════════");

    println!("\n[패턴 1: 카운팅]");
    let items = vec!["apple", "banana", "apple", "cherry", "banana", "apple"];
    let mut counts = HashMap::new();
    for item in &items {
        *counts.entry(*item).or_insert(0) += 1;
    }
    println!("아이템: {:?}", items);
    println!("카운트: {:?}", counts);

    println!("\n[패턴 2: 캐싱]");
    let mut cache: HashMap<i32, i32> = HashMap::new();
    fn fibonacci(n: i32, cache: &mut HashMap<i32, i32>) -> i32 {
        if n <= 1 {
            return n;
        }
        if let Some(&result) = cache.get(&n) {
            return result;
        }
        let result = fibonacci(n - 1, cache) + fibonacci(n - 2, cache);
        cache.insert(n, result);
        result
    }
    let result = fibonacci(10, &mut cache);
    println!("fibonacci(10) = {} (캐시 크기: {})", result, cache.len());

    println!("\n[패턴 3: 그룹화]");
    let students = vec![
        ("alice", "A"),
        ("bob", "B"),
        ("charlie", "A"),
        ("david", "B"),
    ];
    let mut by_grade: HashMap<&str, Vec<&str>> = HashMap::new();
    for (name, grade) in &students {
        by_grade.entry(*grade).or_insert_with(Vec::new).push(name);
    }
    println!("학생: {:?}", students);
    println!("성적별 그룹: {:?}", by_grade);

    println!("\n[패턴 4: 역인덱싱]");
    let user_ids = HashMap::from([
        ("alice", 1001),
        ("bob", 1002),
        ("charlie", 1003),
    ]);
    let mut id_to_name: HashMap<u32, &str> = HashMap::new();
    for (name, id) in &user_ids {
        id_to_name.insert(*id, name);
    }
    println!("name → id: {:?}", user_ids);
    println!("id → name: {:?}", id_to_name);
}

