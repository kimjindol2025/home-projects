## 📊 Compiler 상태 관리

```rust
pub struct Compiler {
    instructions: Vec<u8>,
    constants: Vec<CompileObject>,

    // 점프 위치 스택 (백필링용)
    scopes: Vec<CompilationScope>,
    scope_index: usize,
}

pub struct CompilationScope {
    instructions: Vec<u8>,
    last_instruction: EmittedInstruction,
    previous_instruction: EmittedInstruction,

    // v15.2: 백필링 메타데이터
    jump_patches: Vec<JumpPatch>,  // 수정할 점프 위치 목록
}

pub struct JumpPatch {
    position: usize,          // 수정할 명령어 위치
    target_type: JumpType,    // 전방/후방
}

pub enum JumpType {
    Forward,   // if/else: 미래 주소 기다려야 함
    Backward,  // while: 과거 주소 이미 알고 있음
}
```

