#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_basic_pointer() {
        let mut x = 42_i32;
        let ptr = &mut x as *mut i32;

        unsafe {
            assert_eq!(*ptr, 42);
            *ptr = 100;
            assert_eq!(*ptr, 100);
        }

        assert_eq!(x, 100);
    }

    #[test]
    fn test_null_pointer() {
        let null_ptr: *const i32 = ptr::null();
        assert!(null_ptr.is_null());
    }

    #[test]
    fn test_pointer_arithmetic() {
        let arr = [1, 2, 3, 4, 5];
        let ptr = &arr[0] as *const i32;

        unsafe {
            assert_eq!(*ptr, 1);
            assert_eq!(*ptr.add(1), 2);
            assert_eq!(*ptr.add(4), 5);
        }
    }

    #[test]
    fn test_type_casting() {
        let data: [u8; 4] = [0x01, 0x02, 0x03, 0x04];
        let ptr = &data[0] as *const u8;

        unsafe {
            let ptr_u16 = ptr as *const u16;
            let ptr_u32 = ptr as *const u32;

            // 메모리는 같지만 해석이 다름
            assert_eq!(*ptr, 0x01);
            assert_ne!(*ptr_u16, 0x01);  // 다른 해석
            assert_ne!(*ptr_u32, 0x01);  // 다른 해석
        }
    }

    #[test]
    fn test_safe_memory_view() {
        let mut vec = vec![10, 20, 30];
        let mut view = SafeMemoryView::from_vec(&mut vec);

        assert_eq!(view.get(0), Some(&10));
        assert_eq!(view.get(1), Some(&20));
        assert_eq!(view.get(3), None);  // 범위 밖

        if let Some(val) = view.get_mut(1) {
            *val = 999;
        }

        assert_eq!(vec[1], 999);
    }

    #[test]
    fn test_point_struct() {
        let point = Point { x: 42, y: 100 };
        assert_eq!(mem::size_of::<Point>(), 8);  // 4 + 4 bytes
    }
}
