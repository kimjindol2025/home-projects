// Phase 11 v12.0: Unsafe Rust & Memory Management
// 메모리 주권 선언 - 컴파일러 제작의 첫 발

use std::mem;
use std::ptr;

// =============================================================================
// Demo 1: 기본 로우 포인터 (Raw Pointers)
// =============================================================================

fn demo_basic_raw_pointers() {
    println!("\n=== Demo 1: 기본 로우 포인터 ===");

    let mut data = 100_u32;

    // [안전 영역] 포인터 생성은 안전합니다
    let ptr: *mut u32 = &mut data as *mut u32;
    let const_ptr: *const u32 = &data as *const u32;

    println!("  [INFO] 변수 주소: {:p}", ptr);
    println!("  [INFO] 변수 크기: {} bytes", mem::size_of_val(&data));
    println!("  [INFO] 변수 정렬: {} bytes", mem::align_of_val(&data));

    // [위험 영역] 포인터 역참조는 unsafe 필수
    unsafe {
        println!("  [UNSAFE] 원본 값 (const_ptr): {}", *const_ptr);

        *ptr = 200;  // 로우 포인터를 통해 값 변경
        println!("  [UNSAFE] 변경 후 값: {}", *ptr);
    }

    println!("  [SAFE] 최종 값: {}", data);

    // [정보] Null 포인터 생성 (위험!)
    let null_ptr: *const u32 = ptr::null();
    println!("\n  [INFO] Null 포인터: {:p}", null_ptr);
    println!("  ⚠️  이 포인터를 역참조하면 CRASH!");
}

// =============================================================================
// Demo 2: 다중 포인터 및 타입 해석 (Type Casting)
// =============================================================================

fn demo_multiple_pointers_and_casting() {
    println!("\n=== Demo 2: 다중 포인터 및 타입 해석 ===");

    // [설정] 4바이트 데이터
    let data: [u8; 4] = [0x12, 0x34, 0x56, 0x78];

    // [포인터] 세 가지 타입으로 같은 메모리 해석
    let ptr_u8 = &data[0] as *const u8;
    let ptr_u16 = ptr_u8 as *const u16;
    let ptr_u32 = ptr_u8 as *const u32;

    unsafe {
        println!("  [메모리 바이트]: 0x12, 0x34, 0x56, 0x78");
        println!("\n  [u8로 해석]");
        println!("    첫 번째: 0x{:02x}", *ptr_u8);
        println!("    두 번째: 0x{:02x}", *ptr_u8.add(1));

        println!("\n  [u16으로 해석]");
        println!("    첫 번째: 0x{:04x}", *ptr_u16);
        println!("    두 번째: 0x{:04x}", *ptr_u16.add(1));

        println!("\n  [u32로 해석]");
        println!("    전체: 0x{:08x}", *ptr_u32);

        println!("\n  [메시지]");
        println!("    같은 메모리, 다른 해석!");
        println!("    이것이 바로 '타입은 메모리의 의미'입니다.");
    }
}

// =============================================================================
// Demo 3: 포인터 산술 (Pointer Arithmetic)
// =============================================================================

fn demo_pointer_arithmetic() {
    println!("\n=== Demo 3: 포인터 산술 ===");

    let arr = [10, 20, 30, 40, 50];
    let ptr = &arr[0] as *const i32;

    println!("  [배열] {:?}", arr);
    println!("  [기준점] arr[0] = 10 @ {:p}", ptr);

    unsafe {
        // [add] 다음 원소로 이동
        let ptr_next = ptr.add(1);
        println!("\n  [add(1)] arr[1] = {} @ {:p}", *ptr_next, ptr_next);

        // [add] 3칸 앞으로
        let ptr_far = ptr.add(3);
        println!("  [add(3)] arr[3] = {} @ {:p}", *ptr_far, ptr_far);

        // [offset] 음수 오프셋 (뒤로 이동, 주의!)
        // 이건 안전하지 않을 수 있음
        let ptr_next_from_far = ptr_far.offset(-1);
        println!("  [offset(-1) from arr[3]] = {} @ {:p}", *ptr_next_from_far, ptr_next_from_far);

        // [sub] 1칸 뒤로
        let ptr_back = ptr_far.sub(1);
        println!("  [sub(1) from arr[3]] arr[2] = {} @ {:p}", *ptr_back, ptr_back);

        println!("\n  [메시지]");
        println!("    포인터는 주소일 뿐입니다.");
        println!("    더하고 빼는 것도 자유합니다.");
        println!("    하지만... 유효한 범위 내에서만!");
    }
}

// =============================================================================
// Demo 4: Null 포인터 안전 처리
// =============================================================================

fn demo_null_pointer_safety() {
    println!("\n=== Demo 4: Null 포인터 안전 처리 ===");

    // [시뮬레이션] 함수가 결과를 포인터로 반환하는 경우
    fn find_value(target: i32, arr: &[i32]) -> *const i32 {
        for item in arr {
            if *item == target {
                return item as *const i32;
            }
        }
        ptr::null()  // 찾지 못함: Null 반환
    }

    let data = [10, 20, 30, 40, 50];

    // [케이스 1] 찾음
    let result1 = find_value(30, &data);
    unsafe {
        if !result1.is_null() {
            println!("  [케이스 1] 30 찾음: {} @ {:p}", *result1, result1);
        }
    }

    // [케이스 2] 못 찾음
    let result2 = find_value(999, &data);
    if result2.is_null() {
        println!("  [케이스 2] 999 못 찾음: Null 포인터");
    }

    // [방어] Option으로 변환
    let result_opt = if result1.is_null() {
        None
    } else {
        unsafe { Some(*result1) }
    };

    println!("\n  [Option으로 변환]");
    match result_opt {
        Some(value) => println!("    찾음: {}", value),
        None => println!("    못 찾음"),
    }

    println!("\n  [메시지]");
    println!("    포인터는 Null일 수 있습니다.");
    println!("    is_null()로 반드시 확인하세요!");
}

// =============================================================================
// Demo 5: 메모리 직접 접근 및 구조체 재해석
// =============================================================================

#[repr(C)]
struct Point {
    x: i32,
    y: i32,
}

fn demo_memory_direct_access() {
    println!("\n=== Demo 5: 메모리 직접 접근 ===");

    let mut point = Point { x: 10, y: 20 };

    println!("  [구조체] Point {{ x: 10, y: 20 }}");
    println!("  [크기] {} bytes", mem::size_of::<Point>());
    println!("  [정렬] {} bytes", mem::align_of::<Point>());

    let ptr = &mut point as *mut Point;
    let ptr_bytes = ptr as *mut u8;

    unsafe {
        println!("\n  [바이트 단위 접근]");

        // 각 바이트 출력
        for i in 0..mem::size_of::<Point>() {
            let byte = *ptr_bytes.add(i);
            println!("    바이트 {}: 0x{:02x}", i, byte);
        }

        // 필드 직접 수정
        println!("\n  [필드 직접 수정]");
        (*ptr).x = 100;
        (*ptr).y = 200;
        println!("    Point 수정 후: {{ x: {}, y: {} }}", point.x, point.y);

        // 포인터로도 접근 가능
        let ptr_x = ptr as *mut i32;
        let ptr_y = (ptr as *mut i32).add(1);

        println!("\n  [필드 포인터]");
        println!("    x @ {:p} = {}", ptr_x, *ptr_x);
        println!("    y @ {:p} = {}", ptr_y, *ptr_y);
    }
}

// =============================================================================
// Demo 6: 안전한 래퍼 (Safe Wrapper)
// =============================================================================

/// [안전 인터페이스] 로우 포인터를 안전하게 감싼 구조체
struct SafeMemoryView<T> {
    ptr: *mut T,
    len: usize,
}

impl<T> SafeMemoryView<T> {
    /// [안전] 벡터에서 뷰 생성
    fn from_vec(vec: &mut Vec<T>) -> Self {
        SafeMemoryView {
            ptr: vec.as_mut_ptr(),
            len: vec.len(),
        }
    }

    /// [안전] 안전하게 요소 접근
    fn get(&self, index: usize) -> Option<&T> {
        if index < self.len {
            unsafe { Some(&*self.ptr.add(index)) }
        } else {
            None
        }
    }

    /// [안전] 안전하게 요소 수정
    fn get_mut(&mut self, index: usize) -> Option<&mut T> {
        if index < self.len {
            unsafe { Some(&mut *self.ptr.add(index)) }
        } else {
            None
        }
    }

    /// [안전] 요소 개수
    fn len(&self) -> usize {
        self.len
    }

    /// [내부 unsafe] 직접 메모리 접근
    unsafe fn raw_get(&self, index: usize) -> &T {
        // 호출자가 유효성을 보장해야 함
        &*self.ptr.add(index)
    }
}

fn demo_safe_wrapper() {
    println!("\n=== Demo 6: 안전한 래퍼 ===");

    let mut vec = vec![10, 20, 30, 40, 50];
    let mut view = SafeMemoryView::from_vec(&mut vec);

    println!("  [벡터] {:?}", vec);
    println!("  [길이] {}", view.len());

    // [안전 접근]
    println!("\n  [안전한 접근]");
    match view.get(2) {
        Some(val) => println!("    view[2] = {}", val),
        None => println!("    index out of range"),
    }

    // [안전 수정]
    println!("\n  [안전한 수정]");
    if let Some(val) = view.get_mut(1) {
        *val = 999;
    }

    println!("  [수정 후] {:?}", vec);

    // [범위 밖 접근 - 안전하게 거부]
    println!("\n  [범위 밖 접근]");
    match view.get(100) {
        Some(_) => println!("    찾음"),
        None => println!("    index out of range (안전하게 거부!)"),
    }

    println!("\n  [메시지]");
    println!("    • 내부에 unsafe 코드");
    println!("    • 외부에는 안전한 인터페이스");
    println!("    • 이것이 러스트의 철학입니다!");
}

