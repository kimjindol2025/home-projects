# 예제 3: 클래스 생성 시 통계
class StatsMeta(type):
    """클래스 생성 통계를 수집하는 메타클래스"""
    stats = {
        'total_classes': 0,
        'total_methods': 0,
        'total_attributes': 0,
    }

    def __new__(mcs, name, bases, attrs):
        # 통계 계산
        methods = [v for v in attrs.values() if callable(v) and not str(v).startswith('<')]
        non_methods = [v for v in attrs.values() if not callable(v)]

        mcs.stats['total_classes'] += 1
        mcs.stats['total_methods'] += len(methods)
        mcs.stats['total_attributes'] += len(non_methods)

        return super().__new__(mcs, name, bases, attrs)

print("✓ 클래스 생성 통계:")
print()

