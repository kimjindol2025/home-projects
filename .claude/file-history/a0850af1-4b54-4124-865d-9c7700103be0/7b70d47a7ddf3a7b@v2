# 예제 2: 클래스의 모든 메서드 자동 추적
class TracingMeta(type):
    """클래스의 모든 메서드를 자동으로 추적하는 메타클래스"""

    def __new__(mcs, name, bases, attrs):
        print(f"  ✅ [{name}] 클래스 분석:")

        # 메서드 찾기
        methods = [k for k, v in attrs.items() if callable(v) and not k.startswith('_')]
        print(f"     - 메서드: {methods}")

        # 속성 찾기
        properties = [k for k, v in attrs.items() if not callable(v) and not k.startswith('_')]
        print(f"     - 속성: {properties}")

        return super().__new__(mcs, name, bases, attrs)

print("✓ 클래스 분석 메타클래스:")
print()

class Calculator(metaclass=TracingMeta):
    version = "1.0"

    def add(self, a, b):
        return a + b

