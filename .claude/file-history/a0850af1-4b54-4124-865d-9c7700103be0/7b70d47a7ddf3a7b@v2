# 예제: 자동 로깅 추가
class LoggingMeta(type):
    """모든 메서드에 자동으로 로깅을 추가하는 메타클래스"""

    def __new__(mcs, name, bases, attrs):
        for attr_name, attr_value in attrs.items():
            if callable(attr_value) and not attr_name.startswith('_'):
                # 원본 메서드를 감싼 새로운 메서드
                def make_logged_method(original_method, method_name):
                    def logged_method(*args, **kwargs):
                        print(f"    📝 [{method_name}] 호출됨")
                        result = original_method(*args, **kwargs)
                        print(f"    ✅ [{method_name}] 완료")
                        return result
                    return logged_method

                attrs[attr_name] = make_logged_method(attr_value, attr_name)

        return super().__new__(mcs, name, bases, attrs)

print("✓ 자동 로깅 추가:")
print()

class DataProcessor(metaclass=LoggingMeta):
    def load(self):
        return "데이터 로드"

    def process(self):
        return "데이터 처리"

    def save(self):
        return "데이터 저장"

