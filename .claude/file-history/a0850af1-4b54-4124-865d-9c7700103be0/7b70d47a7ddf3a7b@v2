# 프로덕션급 메타클래스
class ProductionFrameworkMeta(type):
    """프로덕션 환경에서 사용할 수 있는 프레임워크 메타클래스"""

    registry = {}
    validators = {}

    def __new__(mcs, name, bases, attrs):
        # 1단계: 기본 검증
        if bases and name != 'FrameworkBase':
            # 이름 규칙 검증
            if not name[0].isupper():
                raise TypeError(f"클래스 이름 '{name}'은 대문자로 시작해야 합니다")

            # 필수 속성 확인
            required_attrs = attrs.get('__required_attrs__', [])
            for req_attr in required_attrs:
                if req_attr not in attrs:
                    raise TypeError(f"'{name}'은 '{req_attr}'을 구현해야 합니다")

        cls = super().__new__(mcs, name, bases, attrs)

        # 2단계: 자동 등록
        if bases and name != 'FrameworkBase':
            mcs.registry[name] = {
                'class': cls,
                'created_at': datetime.now().isoformat(),
                'methods': [m for m in dir(cls) if not m.startswith('_')],
                'bases': bases,
            }
            print(f"  ✅ [{name}] 자동 등록 완료")

        return cls

    @classmethod
    def list_classes(mcs):
        return list(mcs.registry.keys())

    @classmethod
    def get_class_info(mcs, name):
        return mcs.registry.get(name)

print("✓ 프로덕션급 프레임워크 메타클래스:")
print()

class FrameworkBase(metaclass=ProductionFrameworkMeta):
    __required_attrs__ = ['process']

class DataProcessor(FrameworkBase):
    def process(self):
        return "데이터 처리"

class ImageProcessor(FrameworkBase):
    def process(self):
        return "이미지 처리"

class VideoProcessor(FrameworkBase):
    def process(self):
        return "비디오 처리"

print()
print(f"  등록된 클래스: {ProductionFrameworkMeta.list_classes()}")
print()
for class_name in ProductionFrameworkMeta.list_classes():
    info = ProductionFrameworkMeta.get_class_info(class_name)
    print(f"  [{class_name}]")
    print(f"    - 생성: {info['created_at']}")
    print(f"    - 메서드: {info['methods'][:3]}...")
