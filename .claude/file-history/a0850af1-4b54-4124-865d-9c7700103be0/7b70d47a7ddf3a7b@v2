# 패턴 1: 데이터 검증 메타클래스
class ValidatedMeta(type):
    """클래스 속성에 타입 검증을 추가"""

    def __new__(mcs, name, bases, attrs):
        # 타입 힌트가 있는 속성을 검증하도록 설정
        type_hints = attrs.get('__annotations__', {})

        if type_hints:
            print(f"  🔍 [{name}] 타입 검증 설정:")
            for attr_name, attr_type in type_hints.items():
                print(f"     - {attr_name}: {attr_type.__name__}")

        return super().__new__(mcs, name, bases, attrs)

print("✓ 데이터 검증:")
print()

class User(metaclass=ValidatedMeta):
    username: str
    age: int
    email: str

print()

# 패턴 2: 싱글톤 메타클래스
class SingletonMeta(type):
    """클래스의 인스턴스가 하나만 존재하도록 보장"""
    _instances = {}

    def __call__(cls, *args, **kwargs):
        if cls not in cls._instances:
            cls._instances[cls] = super().__call__(*args, **kwargs)
            print(f"  🔒 [{cls.__name__}] 새 인스턴스 생성 (싱글톤)")
        else:
            print(f"  🔒 [{cls.__name__}] 기존 인스턴스 반환")
        return cls._instances[cls]

print("✓ 싱글톤 패턴:")
print()

class Database(metaclass=SingletonMeta):
    def __init__(self):
        self.connected = True

db1 = Database()
db2 = Database()
print(f"  같은 인스턴스? {db1 is db2}")
print()

# 패턴 3: 추상 베이스 메타클래스
class StrictABCMeta(ABCMeta):
    """추상 메서드 구현을 엄격하게 검증"""

    def __new__(mcs, name, bases, attrs):
        print(f"  📋 [{name}] 추상 클래스 검증")
        return super().__new__(mcs, name, bases, attrs)

print("✓ 추상 메서드 검증:")
print()

class Shape(metaclass=StrictABCMeta):
    @abstractmethod
    def area(self):
        pass

class Circle(Shape):
    def __init__(self, radius):
        self.radius = radius

    def area(self):
        return 3.14 * self.radius ** 2

print(f"  원의 넓이: {Circle(5).area():.2f}")
print()

