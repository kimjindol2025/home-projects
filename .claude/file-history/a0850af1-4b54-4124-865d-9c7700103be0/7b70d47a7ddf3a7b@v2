# 예제 2: 필수 메서드 강제
class RequiredMethodsMeta(type):
    """클래스가 특정 메서드를 반드시 구현하도록 강제"""

    REQUIRED_METHODS = ['initialize', 'execute', 'cleanup']

    def __new__(mcs, name, bases, attrs):
        # 추상 클래스는 검증하지 않음
        if bases:
            for method in mcs.REQUIRED_METHODS:
                if method not in attrs:
                    raise TypeError(
                        f"❌ 규칙 위반: '{name}'은 반드시 '{method}' 메서드를 구현해야 합니다"
                    )
            print(f"  ✅ [{name}] 필수 메서드 모두 구현됨")

        return super().__new__(mcs, name, bases, attrs)

print("✓ 필수 메서드 강제:")
print()

