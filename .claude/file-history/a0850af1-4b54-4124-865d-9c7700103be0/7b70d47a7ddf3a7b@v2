# 예제: 자동 문서화 메타클래스
class DocumentMeta(type):
    """클래스 정보를 자동으로 문서화하는 메타클래스"""

    def __new__(mcs, name, bases, attrs):
        cls = super().__new__(mcs, name, bases, attrs)

        # 인트로스펙션으로 메서드 정보 수집
        methods = {}
        for attr_name in dir(cls):
            if not attr_name.startswith('_'):
                attr = getattr(cls, attr_name)
                if callable(attr):
                    sig = inspect.signature(attr) if hasattr(attr, '__call__') else "N/A"
                    methods[attr_name] = str(sig)

        # 문서화 정보 저장
        cls._methods_doc = methods
        return cls

print("✓ 자동 문서화:")
print()

