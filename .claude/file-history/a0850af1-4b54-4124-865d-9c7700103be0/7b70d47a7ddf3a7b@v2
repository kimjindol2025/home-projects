# 예제 1: 이름 규칙 검증
class NamingRuleMeta(type):
    """클래스 이름이 특정 규칙을 따르도록 강제"""

    def __new__(mcs, name, bases, attrs):
        # 예외: 기본 클래스는 검증하지 않음
        if bases:
            # 규칙: 클래스 이름은 대문자로 시작
            if not name[0].isupper():
                raise TypeError(f"❌ 규칙 위반: '{name}'은 대문자로 시작해야 합니다")

            # 규칙: 클래스 이름에 특수문자 없음
            if not name.replace('_', '').isalnum():
                raise TypeError(f"❌ 규칙 위반: '{name}'에 특수문자가 있습니다")

            print(f"  ✅ [{name}] 이름 규칙 통과")

        return super().__new__(mcs, name, bases, attrs)

print("✓ 이름 규칙 검증:")
print()

