#!/bin/bash

# 🚀 v6.3: 자동 배포 스크립트
# 원버튼 배포로 수동 개입 최소화

set -e  # 에러 발생 시 즉시 종료

# 색상 정의
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'  # 색상 초기화

# 설정
APP_NAME="student-management-system"
REGISTRY="ghcr.io"
IMAGE_NAME="${REGISTRY}/kim/${APP_NAME}"
ENVIRONMENT="${1:-production}"
VERSION="v6.3"

# ============= 함수 정의 =============

log_info() {
    echo -e "${BLUE}ℹ️  $1${NC}"
}

log_success() {
    echo -e "${GREEN}✅ $1${NC}"
}

log_warning() {
    echo -e "${YELLOW}⚠️  $1${NC}"
}

log_error() {
    echo -e "${RED}❌ $1${NC}"
}

# ============= 1. 사전 확인 =============

echo ""
echo -e "${BLUE}═══════════════════════════════════════${NC}"
echo -e "${BLUE}🚀 v6.3 자동 배포 스크립트${NC}"
echo -e "${BLUE}═══════════════════════════════════════${NC}"
echo ""

log_info "배포 환경: ${ENVIRONMENT}"
log_info "이미지: ${IMAGE_NAME}:latest"

# 필수 도구 확인
for cmd in docker docker-compose git; do
    if ! command -v $cmd &> /dev/null; then
        log_error "$cmd가 설치되어 있지 않습니다."
        exit 1
    fi
done

log_success "모든 필수 도구가 설치되어 있습니다."

# ============= 2. 코드 버전 확인 =============

echo ""
log_info "Git 상태 확인 중..."

if [ -n "$(git status --porcelain)" ]; then
    log_warning "수정되지 않은 파일이 있습니다:"
    git status --short
    read -p "계속 진행하시겠습니까? (y/n) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        log_error "배포 취소됨"
        exit 1
    fi
fi

COMMIT_HASH=$(git rev-parse --short HEAD)
BRANCH=$(git rev-parse --abbrev-ref HEAD)
log_success "커밋: ${COMMIT_HASH} (브랜치: ${BRANCH})"

# ============= 3. 테스트 실행 =============

echo ""
log_info "테스트 실행 중..."

if command -v pytest &> /dev/null; then
    pytest --tb=short --quiet || {
        log_error "테스트 실패!"
        exit 1
    }
    log_success "모든 테스트 통과"
else
    log_warning "pytest를 찾을 수 없습니다. 테스트를 건너뜁니다."
fi

# ============= 4. Docker 이미지 빌드 =============

echo ""
log_info "Docker 이미지 빌드 중..."

BUILD_TAG="${IMAGE_NAME}:${VERSION}-${COMMIT_HASH}"

docker build \
    --file Dockerfile.optimized \
    --tag ${BUILD_TAG} \
    --tag ${IMAGE_NAME}:latest \
    --build-arg VERSION=${VERSION} \
    --build-arg BUILD_DATE=$(date -u +'%Y-%m-%dT%H:%M:%SZ') \
    --build-arg VCS_REF=${COMMIT_HASH} \
    . || {
        log_error "Docker 빌드 실패!"
        exit 1
    }

log_success "Docker 이미지 빌드 완료: ${BUILD_TAG}"

# ============= 5. 환경별 배포 =============

case ${ENVIRONMENT} in
    development)
        echo ""
        log_info "개발 환경으로 배포 중..."
        docker-compose -f docker-compose.optimized.yml up -d
        log_success "개발 환경 배포 완료"
        ;;

    staging)
        echo ""
        log_info "스테이징 환경으로 배포 중..."
        # Staging 환경 배포 로직
        docker-compose -f docker-compose.optimized.yml up -d
        log_success "스테이징 환경 배포 완료"
        ;;

    production)
        echo ""
        log_warning "프로덕션 환경 배포를 시작합니다!"
        log_warning "현재 상태: $(docker ps --filter name=${APP_NAME} --format '{{.Status}}')"

        read -p "프로덕션 배포를 승인하시겠습니까? (y/n) " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            log_error "배포 취소됨"
            exit 1
        fi

        # 현재 상태 백업
        log_info "현재 컨테이너 상태 백업 중..."
        docker-compose -f docker-compose.optimized.yml ps > backup_state.txt

        # 새 이미지로 배포
        docker-compose -f docker-compose.optimized.yml pull
        docker-compose -f docker-compose.optimized.yml up -d --no-deps --build web

        # 헬스체크
        log_info "헬스체크 진행 중..."
        sleep 5

        if docker exec student-web curl -f http://localhost:8000/health > /dev/null 2>&1; then
            log_success "프로덕션 환경 배포 완료"
            log_success "서비스 상태: 정상"
        else
            log_error "헬스체크 실패! 롤백 시도..."
            docker-compose -f docker-compose.optimized.yml down
            log_error "배포 실패. 관리자에게 문의하세요."
            exit 1
        fi
        ;;

    *)
        log_error "알 수 없는 환경: ${ENVIRONMENT}"
        log_info "사용 가능한 환경: development, staging, production"
        exit 1
        ;;
esac

# ============= 6. 로그 및 모니터링 =============

echo ""
log_info "배포 로그 확인 중..."
docker-compose -f docker-compose.optimized.yml logs --tail=20 web

# ============= 7. 완료 =============

echo ""
echo -e "${GREEN}═══════════════════════════════════════${NC}"
echo -e "${GREEN}✅ 배포 완료!${NC}"
echo -e "${GREEN}═══════════════════════════════════════${NC}"

log_success "애플리케이션: http://localhost (또는 configured URL)"
log_success "버전: ${VERSION}-${COMMIT_HASH}"
log_success "환경: ${ENVIRONMENT}"
log_success "배포 시간: $(date '+%Y-%m-%d %H:%M:%S')"

echo ""
log_info "다음 단계:"
echo "  • 로그 확인: docker-compose -f docker-compose.optimized.yml logs -f"
echo "  • 롤백: git revert ${COMMIT_HASH} && ./deploy.sh ${ENVIRONMENT}"
echo "  • 중지: docker-compose -f docker-compose.optimized.yml down"

# 선택사항: Slack 알림
if [ -n "${SLACK_WEBHOOK}" ]; then
    curl -X POST ${SLACK_WEBHOOK} \
        -H 'Content-Type: application/json' \
        -d "{\"text\":\"✅ 배포 성공\\n환경: ${ENVIRONMENT}\\n버전: ${VERSION}-${COMMIT_HASH}\"}"
fi

log_success "배포 스크립트 종료"
