print("\n[10단계] 실용 예제: 간단한 계산기")
print("-" * 70)

def calculate(a, operation, b):
    """두 숫자와 연산자를 받아 계산하는 함수"""
    if operation == "+":
        return a + b
    elif operation == "-":
        return a - b
    elif operation == "*":
        return a * b
    elif operation == "/":
        if b == 0:
            return "0으로 나눌 수 없습니다!"
        return a / b
    else:
        return "알 수 없는 연산입니다."

print("계산기 함수 테스트:")
print(f"  10 + 5 = {calculate(10, '+', 5)}")
print(f"  10 - 3 = {calculate(10, '-', 3)}")
print(f"  10 * 2 = {calculate(10, '*', 2)}")
print(f"  10 / 2 = {calculate(10, '/', 2)}")
print(f"  10 / 0 = {calculate(10, '/', 0)}")

