print("\n[4단계] 리스트를 다루는 함수")
print("-" * 70)

def sum_all_numbers(numbers_list):
    """리스트의 모든 숫자를 더하는 함수"""
    total = 0
    for num in numbers_list:
        total = total + num
    return total

def average_numbers(numbers_list):
    """리스트의 평균을 구하는 함수"""
    if len(numbers_list) == 0:
        return 0
    total = sum_all_numbers(numbers_list)
    average = total / len(numbers_list)
    return average

scores = [85, 90, 78, 92, 88]
print(f"점수 목록: {scores}")
print(f"모든 점수의 합: {sum_all_numbers(scores)}")
print(f"평균 점수: {average_numbers(scores):.2f}")

