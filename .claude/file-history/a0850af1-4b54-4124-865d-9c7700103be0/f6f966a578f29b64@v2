def greet(name, greeting="안녕하세요"):
    """인사말을 선택할 수 있는 함수

    greeting의 기본값은 "안녕하세요"입니다.
    다른 인사말을 원하면 지정해주면 됩니다.
    """
    return f"{greeting}, {name}님!"

