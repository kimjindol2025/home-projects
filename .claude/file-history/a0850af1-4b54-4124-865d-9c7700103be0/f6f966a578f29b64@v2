print("\n[9단계] 복잡한 함수 예제 - 특정 단어 찾기")
print("-" * 70)

def find_fruit(basket, target_fruit):
    """바구니에서 특정 과일을 찾는 함수"""
    for i, fruit in enumerate(basket):
        if fruit == target_fruit:
            return f"찾았습니다! {target_fruit}은 위치 {i}번에 있습니다."
    return f"아쉽게도 {target_fruit}은 바구니에 없습니다."

fruits_basket = ["사과", "바나나", "포도", "딸기", "망고"]
print(f"과일 바구니: {fruits_basket}")
print(f"검색 결과: {find_fruit(fruits_basket, '포도')}")
print(f"검색 결과: {find_fruit(fruits_basket, '수박')}")

