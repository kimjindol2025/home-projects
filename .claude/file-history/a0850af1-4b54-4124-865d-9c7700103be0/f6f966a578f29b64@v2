print("-" * 70)

def get_min_max(numbers_list):
    """리스트에서 최솟값과 최댓값을 찾는 함수"""
    if len(numbers_list) == 0:
        return None, None

    min_value = numbers_list[0]
    max_value = numbers_list[0]

    for num in numbers_list:
        if num < min_value:
            min_value = num
        if num > max_value:
            max_value = num

    return min_value, max_value

numbers = [45, 23, 67, 12, 89, 34]
print(f"숫자 목록: {numbers}")

min_num, max_num = get_min_max(numbers)
print(f"최솟값: {min_num}")
print(f"최댓값: {max_num}")

