def is_even(number):
    """숫자가 짝수인지 홀수인지 판별하는 함수"""
    if number % 2 == 0:
        return True   # 짝수
    else:
        return False  # 홀수

print("짝수/홀수 판별 함수 테스트:")
for test_num in [7, 12, 3, 20, 15]:
    if is_even(test_num):
        print(f"  {test_num}은 짝수입니다. ✓")
    else:
        print(f"  {test_num}은 홀수입니다. ✗")

