from datetime import datetime
import json
import os

class AdvancedGogsStorage:
    """완전한 기능을 가진 스마트 저장소 클래스"""

    def __init__(self, owner, capacity=100, backup_interval=5):
        self.owner = owner
        self.capacity = capacity
        self.backup_interval = backup_interval
        self._data = []
        self._backup = []
        self._access_count = 0
        self._created_at = datetime.now()
        print(f"📦 [{self.owner}]의 저장소 생성됨 (용량: {self.capacity})")

    def save(self, data, tag=""):
        """데이터 저장"""
        try:
            if len(self._data) >= self.capacity:
                raise OverflowError(f"용량 초과 ({len(self._data)}/{self.capacity})")

            entry = {
                "id": len(self._data) + 1,
                "data": data,
                "tag": tag,
                "timestamp": datetime.now().isoformat()
            }

            self._data.append(entry)
            self._access_count += 1

            # 자동 백업
            if self._access_count % self.backup_interval == 0:
                self._backup = self._data.copy()
                print(f"  🔄 자동 백업 완료 ({len(self._backup)}건)")

            print(f"✅ 저장: '{data}' [{tag}] (사용량: {len(self._data)}/{self.capacity})")

        except OverflowError as e:
            print(f"❌ 저장 실패: {e}")

    def search(self, keyword):
        """키워드로 데이터 검색"""
        results = [entry for entry in self._data if keyword in entry["data"]]
        print(f"\n🔍 검색 결과: '{keyword}' ({len(results)}건)")
        for entry in results:
            print(f"  - {entry['data']} [{entry['tag']}]")
        return results

    def get_statistics(self):
        """통계 정보"""
        return {
            "owner": self.owner,
            "total": len(self._data),
            "capacity": self.capacity,
            "usage_percent": (len(self._data) / self.capacity * 100),
            "access_count": self._access_count,
            "backup_count": len(self._backup)
        }

    def __str__(self):
        """저장소 상태 표시"""
        stats = self.get_statistics()
        return f"저장소[{stats['owner']}]: {stats['total']}/{stats['capacity']} ({stats['usage_percent']:.1f}%)"

    def __len__(self):
        """저장된 데이터 수"""
        return len(self._data)

