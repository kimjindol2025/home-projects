class Book:
    """책 정보를 관리하는 클래스"""

    def __init__(self, title, author, year, pages):
        self.title = title
        self.author = author
        self.year = year
        self.pages = pages

    def __str__(self):
        """사용자 친화적 표현 (print할 때)"""
        return f"📖 《{self.title}》 - {self.author} 저, {self.year}년 출판"

    def __repr__(self):
        """개발자 친화적 표현 (디버깅할 때)"""
        return f"Book('{self.title}', '{self.author}', {self.year}, {self.pages})"

    def __len__(self):
        """len()을 호출할 때 페이지 수 반환"""
        return self.pages

print("【 특수 메서드 사용 】")
print()

book = Book("파이썬 완벽 가이드", "김설계", 2024, 520)

print("print()로 출력 (str() 호출):")
print(book)

print()
print("repr() 함수로 표현:")
print(repr(book))

print()
print("len()으로 페이지 수 확인:")
print(f"이 책의 페이지 수: {len(book)}페이지")

print()
print("💡 핵심: 특수 메서드를 정의하면 객체가 더 자연스럽게 동작합니다.")
print()

