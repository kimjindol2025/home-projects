class BankAccount:
    """은행 계좌를 관리하는 클래스"""

    def __init__(self, owner, balance=0):
        self.owner = owner
        self.balance = balance
        print(f"💳 {self.owner}님의 계좌 개설 (잔액: {self.balance}원)")

    def deposit(self, amount):
        """입금 메서드"""
        self.balance += amount
        print(f"✅ {self.owner}님이 {amount}원을 입금했습니다. (잔액: {self.balance}원)")

    def withdraw(self, amount):
        """출금 메서드"""
        if self.balance >= amount:
            self.balance -= amount
            print(f"✅ {self.owner}님이 {amount}원을 출금했습니다. (잔액: {self.balance}원)")
        else:
            print(f"❌ 잔액 부족! (현재 잔액: {self.balance}원)")

    def transfer(self, other_account, amount):
        """송금 메서드 (다른 메서드 호출)"""
        if self.balance >= amount:
            self.withdraw(amount)  # 자신의 메서드 호출
            other_account.deposit(amount)  # 다른 객체의 메서드 호출
            print(f"💸 송금 완료: {self.owner} → {other_account.owner}")
        else:
            print(f"❌ 송금 불가: 잔액 부족!")

print("【 계좌 생성 】")
print()

