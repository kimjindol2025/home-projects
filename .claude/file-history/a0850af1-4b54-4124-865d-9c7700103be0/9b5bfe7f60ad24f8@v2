class GogsStorage:
    """데이터를 안전하게 저장하고 관리하는 스마트 저장소 클래스"""

    def __init__(self, owner, capacity=100):
        self.owner = owner
        self.capacity = capacity
        self._stored_data = []  # 언더스코어(_)로 시작: "private하다" 표시
        self._access_log = []
        print(f"📦 [{self.owner}]님의 전용 저장소가 생성되었습니다. (용량: {self.capacity})")

    def save(self, data):
        """데이터를 저장소에 추가 (캡슐화된 메서드)"""
        if len(self._stored_data) < self.capacity:
            self._stored_data.append(data)
            self._log_access(f"저장: {data}")
            print(f"✅ 기록 완료: '{data}' (사용량: {len(self._stored_data)}/{self.capacity})")
        else:
            self._log_access(f"저장 실패 (용량초과): {data}")
            print("❌ 용량 초과: 더 이상 기록할 수 없습니다!")

    def get_usage(self):
        """저장소 사용량 반환"""
        return len(self._stored_data), self.capacity

    def show_all(self):
        """저장된 모든 데이터 출력"""
        print(f"\n--- {self.owner}의 기록 목록 ---")
        if not self._stored_data:
            print("(저장된 데이터가 없습니다)")
        else:
            for i, data in enumerate(self._stored_data, 1):
                print(f"{i}. {data}")

    def _log_access(self, action):
        """내부 로깅 메서드 (언더스코어: private)"""
        from datetime import datetime
        timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        self._access_log.append(f"[{timestamp}] {action}")

    def show_log(self):
        """접근 로그 표시"""
        print(f"\n--- {self.owner}의 접근 로그 ---")
        for log in self._access_log:
            print(log)

print("【 저장소 생성 및 사용 】")
print()

