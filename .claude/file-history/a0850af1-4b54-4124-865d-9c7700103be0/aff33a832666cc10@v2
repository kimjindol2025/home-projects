HOST = '127.0.0.1'
PORT = 9999
BUFFER_SIZE = 1024

def simple_server():
    """간단한 에코 서버"""
    server_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    server_socket.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    server_socket.bind((HOST, PORT))
    server_socket.listen(1)

    print(f"  [서버] 📡 {HOST}:{PORT}에서 대기 중...")

    try:
        # 타임아웃 설정
        server_socket.settimeout(3)
        client_socket, addr = server_socket.accept()

        print(f"  [서버] 🤝 클라이언트 접속: {addr}")

        # 데이터 수신
        data = client_socket.recv(BUFFER_SIZE)
        message = data.decode('utf-8')
        print(f"  [서버] 📥 수신: {message}")

        # 데이터 재전송 (Echo)
        client_socket.sendall(data)
        print(f"  [서버] 📤 송신: {message} (Echo)")

        client_socket.close()

    except socket.timeout:
        print(f"  [서버] ⏱️ 타임아웃 - 클라이언트 미접속")
    finally:
        server_socket.close()

def simple_client():
    """간단한 에코 클라이언트"""
    time.sleep(0.5)  # 서버 준비 대기

    client_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)

    try:
        print(f"  [클라이언트] 🔌 서버 연결: {HOST}:{PORT}")
        client_socket.connect((HOST, PORT))

        # 데이터 전송
        message = "Hello, Server!"
        client_socket.sendall(message.encode('utf-8'))
        print(f"  [클라이언트] 📤 송신: {message}")

        # 응답 수신
        data = client_socket.recv(BUFFER_SIZE)
        response = data.decode('utf-8')
        print(f"  [클라이언트] 📥 수신: {response}")

    except Exception as e:
        print(f"  [클라이언트] ❌ 오류: {e}")
    finally:
        client_socket.close()

