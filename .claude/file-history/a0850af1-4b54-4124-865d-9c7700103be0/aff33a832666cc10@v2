def production_server():
    server_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    server_socket.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    server_socket.bind(('127.0.0.1', 12000))
    server_socket.listen(5)
    server_socket.settimeout(2)

    print(f"  🚀 프로덕션 서버 시작 (포트 12000)")

    connection_count = 0
    try:
        while connection_count < 2:
            try:
                client_socket, addr = server_socket.accept()
                connection_count += 1
                print(f"  ✅ 접속 #{connection_count}: {addr}")

                data = client_socket.recv(BUFFER_SIZE)
                if data:
                    print(f"  📥 수신: {data.decode('utf-8')}")
                    client_socket.sendall(data)
                    print(f"  📤 송신 완료")

                client_socket.close()
            except socket.timeout:
                continue
    finally:
        server_socket.close()
        print(f"  🛑 서버 종료 (총 {connection_count}건 처리)")

def production_clients():
    time.sleep(0.5)
    for i in range(2):
        time.sleep(0.3)
        try:
            client_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            client_socket.connect(('127.0.0.1', 12000))

            message = f"Production Message {i+1}"
            client_socket.sendall(message.encode('utf-8'))

            data = client_socket.recv(BUFFER_SIZE)
            print(f"  🔔 클라이언트 #{i+1} 응답 수신")

            client_socket.close()
        except Exception as e:
            print(f"  ❌ 클라이언트 #{i+1} 오류: {e}")

server_thread = threading.Thread(target=production_server)
client_thread = threading.Thread(target=production_clients)

