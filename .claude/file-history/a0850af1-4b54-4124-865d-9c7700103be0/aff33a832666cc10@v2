def is_port_available(port):
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        s.bind(('127.0.0.1', port))
        s.close()
        return True
    except OSError:
        return False

for port in [8000, 9000, 9999, 10000]:
    status = "✅ 사용 가능" if is_port_available(port) else "❌ 사용 중"
    print(f"  포트 {port}: {status}")

