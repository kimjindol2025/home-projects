def multi_client_server():
    """다중 클라이언트를 처리하는 서버"""
    server_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    server_socket.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    server_socket.bind(('127.0.0.1', 10000))
    server_socket.listen(5)
    server_socket.settimeout(3)

    print(f"  [다중서버] 📡 포트 10000에서 대기 중...")

    client_count = 0
    try:
        while client_count < 3:
            try:
                client_socket, addr = server_socket.accept()
                client_count += 1
                print(f"  [다중서버] 🤝 클라이언트 #{client_count} 접속: {addr}")

                # 각 클라이언트를 별도 스레드에서 처리
                def handle_client(sock, client_id):
                    try:
                        data = sock.recv(BUFFER_SIZE)
                        message = data.decode('utf-8')
                        print(f"  [다중서버] 📥 클라이언트 #{client_id}: {message}")
                        sock.sendall(data)
                    finally:
                        sock.close()

                handler = threading.Thread(target=handle_client, args=(client_socket, client_count))
                handler.daemon = True
                handler.start()

            except socket.timeout:
                continue
    finally:
        server_socket.close()

def multi_client_clients(num_clients=3):
    """여러 클라이언트"""
    time.sleep(0.5)

    for i in range(num_clients):
        def client_worker(client_id):
            time.sleep(i * 0.3)  # 순차적으로 연결
            client_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            try:
                print(f"  [클라이언트 #{client_id}] 🔌 서버 연결 시도...")
                client_socket.connect(('127.0.0.1', 10000))

                message = f"Message from Client {client_id}"
                client_socket.sendall(message.encode('utf-8'))
                print(f"  [클라이언트 #{client_id}] 📤 송신: {message}")

                data = client_socket.recv(BUFFER_SIZE)
                print(f"  [클라이언트 #{client_id}] 📥 수신: {data.decode('utf-8')}")
            except Exception as e:
                print(f"  [클라이언트 #{client_id}] ❌ 오류: {e}")
            finally:
                client_socket.close()

        t = threading.Thread(target=client_worker, args=(i+1,))
        t.daemon = True
        t.start()

print("✓ 다중 클라이언트 처리:")
