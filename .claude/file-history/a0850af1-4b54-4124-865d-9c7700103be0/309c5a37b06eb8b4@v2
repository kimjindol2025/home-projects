version: '3.8'

services:
  # 웹 애플리케이션
  web:
    build: .
    container_name: student-management-web
    ports:
      - "5000:5000"
    environment:
      - FLASK_ENV=production
      - PYTHONUNBUFFERED=1
    volumes:
      - ./:/app
      - db_data:/app/data
    restart: unless-stopped
    networks:
      - student-network
    labels:
      - "com.example.project=student-management"
      - "com.example.environment=production"

  # 데이터베이스 (선택적 - PostgreSQL)
  # postgres:
  #   image: postgres:15-alpine
  #   container_name: student-management-db
  #   environment:
  #     - POSTGRES_USER=admin
  #     - POSTGRES_PASSWORD=secure_password
  #     - POSTGRES_DB=student_db
  #   volumes:
  #     - postgres_data:/var/lib/postgresql/data
  #   restart: unless-stopped
  #   networks:
  #     - student-network

  # 리버스 프록시 (Nginx)
  nginx:
    image: nginx:alpine
    container_name: student-management-nginx
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
      - ./ssl:/etc/nginx/ssl:ro
    depends_on:
      - web
    restart: unless-stopped
    networks:
      - student-network

  # 모니터링 (선택적)
  # prometheus:
  #   image: prom/prometheus:latest
  #   ports:
  #     - "9090:9090"
  #   volumes:
  #     - ./prometheus.yml:/etc/prometheus/prometheus.yml
  #   networks:
  #     - student-network

volumes:
  db_data:
  # postgres_data:

networks:
  student-network:
    driver: bridge
