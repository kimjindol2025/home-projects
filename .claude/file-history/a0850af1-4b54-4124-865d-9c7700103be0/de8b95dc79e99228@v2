def calculate_score_good(total, count):
    """견고한 함수"""
    try:
        if count == 0:
            raise ValueError("학생 수는 0이 될 수 없습니다")

        average = total / count

        if average < 0 or average > 100:
            raise ValueError("점수는 0~100 범위여야 합니다")

        return average

    except ValueError as e:
        print(f"⚠️ 유효성 검사 오류: {e}")
        return None
    except Exception as e:
        print(f"❌ 예상 못 한 오류: {e}")
        return None
    finally:
        print("   (함수 실행 완료)")

result1 = calculate_score_good(100, 0)     # ValueError 발생
result2 = calculate_score_good(150, 2)     # ValueError 발생 (범위 초과)
result3 = calculate_score_good(90, 3)      # 정상 (평균 30)

