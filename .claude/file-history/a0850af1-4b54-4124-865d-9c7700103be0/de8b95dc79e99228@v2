import random

# 향상된 상품 클래스 (모든 개념 포함)
class ShoppingItem(Item):
    """쇼핑 시스템의 확장 상품"""

    item_id_counter = 0

    def __init__(self, name, price):
        super().__init__(name, price)
        ShoppingItem.item_id_counter += 1
        self.item_id = ShoppingItem.item_id_counter
        self.rating = Decimal(str(random.uniform(3.5, 5.0))).quantize(Decimal("0.1"))

    def validate_purchase(self, quantity):
        """v2.1: 예외 처리로 검증"""
        try:
            if quantity <= 0:
                raise ValueError("구매 수량은 1 이상이어야 합니다")
            return True
        except ValueError as e:
            print(f"❌ 검증 실패: {e}")
            return False

    def get_info_json(self):
        """v2.4: JSON으로 정보 반환"""
        return {
            "id": self.item_id,
            "name": self.name,
            "price": int(self.price),
            "rating": float(self.rating)
        }

# 쇼핑 시스템
class ShoppingCart:
    """v2.2: 클래스로 장바구니 구현"""

    def __init__(self):
        self.items = []
        self.created_at = datetime.datetime.now()

    def add_item(self, item, quantity):
        """v2.1: 예외 처리 포함"""
        try:
            if not isinstance(item, ShoppingItem):
                raise TypeError("ShoppingItem 객체만 추가 가능합니다")

            if not item.validate_purchase(quantity):
                return False

            self.items.append({"item": item, "quantity": quantity})
            return True

        except TypeError as e:
            print(f"❌ 타입 오류: {e}")
            return False

    def get_total(self):
        """총액 계산"""
        total = Decimal("0")
        for entry in self.items:
            item_total = Decimal(str(entry["item"].price)) * Decimal(str(entry["quantity"]))
            total += item_total
        return total

    def to_json(self):
        """v2.4: JSON 형식으로"""
        return {
            "cart_created": self.created_at.isoformat(),
            "items_count": len(self.items),
            "total_price": int(self.get_total()),
            "items": [
                {
                    "product": entry["item"].get_info_json(),
                    "quantity": entry["quantity"]
                }
                for entry in self.items
            ]
        }

# 실제 사용
print("🛒 쇼핑 시스템 동작:")
print()

# 상품 생성
laptop = ShoppingItem("노트북", 1500000)
mouse = ShoppingItem("마우스", 50000)
keyboard = ShoppingItem("키보드", 80000)

# 장바구니에 추가 (v2.1 예외 처리 테스트)
