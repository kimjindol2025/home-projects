# 상품 클래스
class Product:
    """쇼핑 시스템의 상품"""

    def __init__(self, name, price, stock):
        self.name = name
        self.price = price
        self.stock = stock
        self.sales = 0  # 판매량

    def buy(self, quantity):
        """상품 구매 (예외 처리 포함!)"""
        try:
            if quantity <= 0:
                raise ValueError("구매 수량은 1 이상이어야 합니다")
            if quantity > self.stock:
                raise ValueError(f"재고 부족! (현재 재고: {self.stock})")

            self.stock -= quantity
            self.sales += quantity
            total_price = self.price * quantity

            return total_price

        except ValueError as e:
            print(f"❌ 구매 실패: {e}")
            return None

    def info(self):
        """상품 정보"""
        print(f"상품명: {self.name}")
        print(f"가격: {self.price:,}원")
        print(f"재고: {self.stock}개")
        print(f"판매량: {self.sales}개")

# 객체 생성
