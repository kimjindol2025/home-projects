# 부모 클래스: 모든 상품의 기본
class Item:
    """모든 상품의 기본 클래스"""

    def __init__(self, name, price):
        self.name = name
        self.price = price

    def display(self):
        return f"{self.name} ({self.price:,}원)"

# 자식 클래스 1: 전자제품 (특화: 보증)
class ElectronicItem(Item):
    def __init__(self, name, price, warranty_months):
        super().__init__(name, price)
        self.warranty_months = warranty_months

    def display(self):
        return f"{super().display()} [보증: {self.warranty_months}개월]"

# 자식 클래스 2: 신선식품 (특화: 유통기한)
class FoodItem(Item):
    def __init__(self, name, price, expiry_days):
        super().__init__(name, price)
        self.expiry_days = expiry_days

    def display(self):
        return f"{super().display()} [유통기한: {self.expiry_days}일]"

