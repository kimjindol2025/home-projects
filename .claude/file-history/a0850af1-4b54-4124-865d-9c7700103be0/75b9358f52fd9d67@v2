class SecureTokenManager:
    """토큰 관리 (v6.2 보안)"""

    def __init__(self):
        self.tokens: Dict[str, Dict] = {}

    def generate_token(self, user_id: str, role: str) -> str:
        """안전한 토큰 생성"""
        token = secrets.token_urlsafe(32)
        self.tokens[token] = {
            "user_id": user_id,
            "role": role,
            "created_at": time.time(),
            "expires_at": time.time() + 3600
        }
        return token

    def verify_token(self, token: str) -> Optional[Dict]:
        """토큰 검증 (v6.2)"""
        if token not in self.tokens:
            return None

        token_data = self.tokens[token]
        if token_data["expires_at"] < time.time():
            del self.tokens[token]
            return None

        return token_data

    def revoke_token(self, token: str):
        """토큰 취소 (로그아웃)"""
        if token in self.tokens:
            del self.tokens[token]


class IAMSystem:
    """Identity & Access Management (v6.2)"""

    def __init__(self):
        self.users: Dict[str, Dict] = {}
        self.roles: Dict[str, List[str]] = {
            "admin": ["read", "write", "delete"],
            "user": ["read"],
            "guest": []
        }

    def create_user(self, user_id: str, password: str, role: str) -> bool:
        """사용자 생성"""
        if user_id in self.users:
            return False

        salt = secrets.token_bytes(32)
        hash_obj = hashlib.pbkdf2_hmac(
            'sha256',
            password.encode('utf-8'),
            salt,
            100000
        )

        self.users[user_id] = {
            "password_hash": hash_obj.hex(),
            "salt": salt.hex(),
            "role": role,
            "created_at": datetime.now()
        }
        return True

    def verify_credentials(self, user_id: str, password: str) -> bool:
        """자격증명 검증"""
        if user_id not in self.users:
            return False

        user = self.users[user_id]
        salt = bytes.fromhex(user["salt"])
        hash_obj = hashlib.pbkdf2_hmac(
            'sha256',
            password.encode('utf-8'),
            salt,
            100000
        )

        return hash_obj.hex() == user["password_hash"]

    def has_permission(self, user_id: str, action: str) -> bool:
        """권한 확인"""
        if user_id not in self.users:
            return False

        role = self.users[user_id]["role"]
        return action in self.roles.get(role, [])


