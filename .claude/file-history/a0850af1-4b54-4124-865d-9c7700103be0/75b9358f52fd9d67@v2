def test_stage7_performance():
    """Stage 7: 성능 최적화"""
    print("\n" + "=" * 80)
    print("✅ STAGE 7: 성능 최적화 — v5.3 알고리즘")
    print("=" * 80)

    # 이진 탐색 vs 선형 탐색
    import random
    data = sorted([random.randint(1, 100000) for _ in range(10000)])

    # 이진 탐색
    time_binary = timeit.timeit(
        lambda: PerformanceOptimizer.binary_search(data, 50000),
        number=10000
    )

    # 선형 탐색
    time_linear = timeit.timeit(
        lambda: data.index(50000) if 50000 in data else -1,
        number=10000
    )

    print(f"  이진 탐색:   {time_binary:.4f}초 O(log n) ✨")
    print(f"  선형 탐색:   {time_linear:.4f}초 O(n)")
    print(f"  성능 개선:   {time_linear/time_binary:.1f}배")

    # 정렬 알고리즘
    unsorted = [random.randint(1, 1000) for _ in range(1000)]

    time_merge = timeit.timeit(
        lambda: PerformanceOptimizer.merge_sort(unsorted.copy()),
        number=100
    )

    print(f"\n  병합 정렬:   {time_merge:.4f}초 O(n log n) ✅")


