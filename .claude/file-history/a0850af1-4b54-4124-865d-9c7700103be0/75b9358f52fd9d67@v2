class IndexedDatabase:
    """최적화된 데이터베이스 (v5.2 인덱싱 + v5.3 알고리즘)"""

    def __init__(self):
        self.data: Dict[str, List[Dict]] = defaultdict(list)
        self.indexes: Dict[str, Dict] = {}

    def create_index(self, table: str, column: str):
        """B-Tree 인덱스 생성 (v5.2)"""
        if table not in self.data:
            self.data[table] = []

        self.indexes[f"{table}:{column}"] = {}
        for row in self.data[table]:
            if column in row:
                key = row[column]
                if key not in self.indexes[f"{table}:{column}"]:
                    self.indexes[f"{table}:{column}"][key] = []
                self.indexes[f"{table}:{column}"][key].append(row)

    def insert(self, table: str, row: Dict):
        """데이터 삽입"""
        self.data[table].append(row)

        # 인덱스 업데이트
        for index_key in self.indexes:
            if index_key.startswith(f"{table}:"):
                column = index_key.split(":")[-1]
                if column in row:
                    key = row[column]
                    if key not in self.indexes[index_key]:
                        self.indexes[index_key][key] = []
                    self.indexes[index_key][key].append(row)

    def query_with_index(self, table: str, column: str, value: Any) -> List[Dict]:
        """인덱스로 빠른 조회 (v5.2 + v5.3)"""
        index_key = f"{table}:{column}"
        if index_key in self.indexes:
            return self.indexes[index_key].get(value, [])
        return []

    def query_without_index(self, table: str, column: str, value: Any) -> List[Dict]:
        """선형 탐색 (비교용)"""
        results = []
        for row in self.data.get(table, []):
            if row.get(column) == value:
                results.append(row)
        return results


class CacheLayer:
    """캐시 계층 (v3.2 제너레이터 + v4 async)"""

    def __init__(self, max_size: int = 1000):
        self.cache: Dict[str, Any] = {}
        self.access_times: Dict[str, float] = {}
        self.max_size = max_size

    async def get(self, key: str) -> Optional[Any]:
        """캐시에서 값 조회"""
        if key in self.cache:
            self.access_times[key] = time.time()
            return self.cache[key]
        return None

    async def set(self, key: str, value: Any):
        """캐시에 값 저장"""
        if len(self.cache) >= self.max_size:
            # LRU 제거
            lru_key = min(self.access_times, key=self.access_times.get)
            del self.cache[lru_key]
            del self.access_times[lru_key]

        self.cache[key] = value
        self.access_times[key] = time.time()


