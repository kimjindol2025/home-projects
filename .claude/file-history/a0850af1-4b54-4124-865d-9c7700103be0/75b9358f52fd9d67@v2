class LoadBalancer:
    """로드 밸런서 (v6.1)"""

    def __init__(self, instances: List[str]):
        self.instances = instances
        self.current_index = 0
        self.health_status: Dict[str, bool] = {
            instance: True for instance in instances
        }

    def select_instance(self) -> Optional[str]:
        """라운드 로빈 선택 (v6.1)"""
        healthy = [
            inst for inst in self.instances
            if self.health_status.get(inst, False)
        ]

        if not healthy:
            return None

        selected = healthy[self.current_index % len(healthy)]
        self.current_index += 1
        return selected

    def mark_healthy(self, instance: str):
        """인스턴스 건강 표시"""
        self.health_status[instance] = True

    def mark_unhealthy(self, instance: str):
        """인스턴스 불건강 표시"""
        self.health_status[instance] = False


class CircuitBreaker:
    """서킷 브레이커 (v6.1 신뢰성)"""

    class State(Enum):
        CLOSED = "closed"
        OPEN = "open"
        HALF_OPEN = "half_open"

    def __init__(self, failure_threshold: int = 5, timeout: int = 60):
        self.failure_threshold = failure_threshold
        self.timeout = timeout
        self.state = self.State.CLOSED
        self.failure_count = 0
        self.last_failure_time = None

    async def call(self, func: Callable) -> Optional[Any]:
        """서킷 브레이커를 통한 호출"""
        if self.state == self.State.OPEN:
            if time.time() - self.last_failure_time > self.timeout:
                self.state = self.State.HALF_OPEN
            else:
                return None

        try:
            result = await func() if asyncio.iscoroutinefunction(func) else func()

            if self.state == self.State.HALF_OPEN:
                self.state = self.State.CLOSED
                self.failure_count = 0

            return result
        except Exception as e:
            self.failure_count += 1
            self.last_failure_time = time.time()

            if self.failure_count >= self.failure_threshold:
                self.state = self.State.OPEN

            return None


