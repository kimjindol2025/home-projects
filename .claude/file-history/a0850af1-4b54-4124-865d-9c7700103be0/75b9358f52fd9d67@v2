class PerformanceOptimizer:
    """성능 최적화 (v5.3)"""

    @staticmethod
    def binary_search(sorted_list: List, target: Any) -> Optional[int]:
        """이진 탐색 O(log n) (v5.3)"""
        left, right = 0, len(sorted_list) - 1

        while left <= right:
            mid = (left + right) // 2
            if sorted_list[mid] == target:
                return mid
            elif sorted_list[mid] < target:
                left = mid + 1
            else:
                right = mid - 1

        return None

    @staticmethod
    def merge_sort(arr: List) -> List:
        """병합 정렬 O(n log n) (v5.3)"""
        if len(arr) <= 1:
            return arr

        mid = len(arr) // 2
        left = PerformanceOptimizer.merge_sort(arr[:mid])
        right = PerformanceOptimizer.merge_sort(arr[mid:])

        return PerformanceOptimizer._merge(left, right)

    @staticmethod
    def _merge(left: List, right: List) -> List:
        """병합 보조 함수"""
        result = []
        i = j = 0

        while i < len(left) and j < len(right):
            if left[i] <= right[j]:
                result.append(left[i])
                i += 1
            else:
                result.append(right[j])
                j += 1

        result.extend(left[i:])
        result.extend(right[j:])
        return result


class ParallelExecutor:
    """병렬 실행 (v4.2 멀티프로세싱)"""

    def __init__(self, max_workers: int = 4):
        self.executor = ThreadPoolExecutor(max_workers=max_workers)

    async def parallel_map(self, func: Callable, items: List) -> List:
        """병렬 맵 (v4.2)"""
        loop = asyncio.get_event_loop()
        tasks = [
            loop.run_in_executor(self.executor, func, item)
            for item in items
        ]
        return await asyncio.gather(*tasks)


