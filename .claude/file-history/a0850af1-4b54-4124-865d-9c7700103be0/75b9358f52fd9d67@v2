@dataclass
class Metric:
    """메트릭"""
    name: str
    value: float
    timestamp: float
    tags: Dict[str, str]


class ObservabilitySystem:
    """모니터링 시스템 (v4.3 + v6)"""

    def __init__(self):
        self.metrics: List[Metric] = []
        self.traces: Dict[str, List[str]] = defaultdict(list)
        self.alerts: List[Dict] = []

    def record_metric(self, name: str, value: float, tags: Dict[str, str] = None):
        """메트릭 기록"""
        metric = Metric(
            name=name,
            value=value,
            timestamp=time.time(),
            tags=tags or {}
        )
        self.metrics.append(metric)

    def start_trace(self, trace_id: str, operation: str):
        """분산 추적 시작"""
        self.traces[trace_id].append(f"[{time.time():.3f}] START: {operation}")

    def end_trace(self, trace_id: str, operation: str):
        """분산 추적 종료"""
        self.traces[trace_id].append(f"[{time.time():.3f}] END: {operation}")

    def check_alerts(self) -> List[Dict]:
        """알림 확인 (임계값)"""
        alerts = []

        # 최근 10개 메트릭 분석
        recent = self.metrics[-10:]
        for metric in recent:
            if metric.name == "response_time" and metric.value > 1000:
                alerts.append({
                    "level": "warning",
                    "message": f"High response time: {metric.value}ms",
                    "timestamp": metric.timestamp
                })
            elif metric.name == "error_rate" and metric.value > 0.05:
                alerts.append({
                    "level": "error",
                    "message": f"High error rate: {metric.value*100}%",
                    "timestamp": metric.timestamp
                })

        return alerts


