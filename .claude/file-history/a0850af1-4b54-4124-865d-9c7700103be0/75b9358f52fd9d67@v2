class AuthDecorator:
    """인증 데코레이터 (v3.1 메타프로그래밍)"""

    def __init__(self, required_role: str):
        self.required_role = required_role

    def __call__(self, func: Callable) -> Callable:
        async def wrapper(request: Dict) -> Dict:
            # v6 보안: 토큰 검증
            token = request.get("token")
            if not token:
                return {"error": "Unauthorized"}

            user_role = self._verify_token(token)
            if user_role != self.required_role:
                return {"error": "Forbidden"}

            return await func(request)

        return wrapper

    @staticmethod
    def _verify_token(token: str) -> str:
        """v6 보안: 토큰 검증"""
        hash_obj = hashlib.sha256(token.encode()).hexdigest()
        return "admin" if hash_obj.endswith("a") else "user"


class RateLimitDecorator:
    """속도 제한 데코레이터 (v3.1 메타프로그래밍)"""

    def __init__(self, max_requests: int, window_seconds: int):
        self.max_requests = max_requests
        self.window_seconds = window_seconds
        self.requests = defaultdict(list)

    def __call__(self, func: Callable) -> Callable:
        async def wrapper(request: Dict) -> Dict:
            client_id = request.get("client_id", "unknown")
            now = time.time()

            # 만료된 요청 제거
            self.requests[client_id] = [
                ts for ts in self.requests[client_id]
                if now - ts < self.window_seconds
            ]

            # 제한 확인
            if len(self.requests[client_id]) >= self.max_requests:
                return {"error": "Rate limit exceeded"}

            self.requests[client_id].append(now)
            return await func(request)

        return wrapper


class ApiGateway:
    """API 게이트웨이 (v3 + v6 통합)"""

    def __init__(self):
        self.routes: Dict[str, Callable] = {}
        self.request_count = 0

    def register(self, path: str, decorator_list: List[Callable]):
        """데코레이터 체인으로 라우트 등록 (v3.1)"""
        async def route_handler(request: Dict) -> Dict:
            self.request_count += 1
            service_name = path.split("/")[1]
            return {
                "service": service_name,
                "status": "ok",
                "request_id": str(uuid.uuid4())[:8]
            }

        # 데코레이터 체인 적용
        for decorator in reversed(decorator_list):
            route_handler = decorator(route_handler)

        self.routes[path] = route_handler

    async def handle_request(self, path: str, request: Dict) -> Dict:
        """요청 처리 (라우팅 + 데코레이터)"""
        if path not in self.routes:
            return {"error": "Not found"}

        return await self.routes[path](request)


