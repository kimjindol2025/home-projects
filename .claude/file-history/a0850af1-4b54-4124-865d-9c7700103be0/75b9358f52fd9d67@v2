    )

    # 인덱스 미사용 (O(n))
    time_without_index = timeit.timeit(
        lambda: db.query_without_index("users", "id", 500),
        number=10000
    )

    print(f"  인덱스 사용:    {time_with_index:.4f}초")
    print(f"  인덱스 미사용:  {time_without_index:.4f}초")
    print(f"  성능 개선:      {time_without_index/time_with_index:.1f}배 ✨")


