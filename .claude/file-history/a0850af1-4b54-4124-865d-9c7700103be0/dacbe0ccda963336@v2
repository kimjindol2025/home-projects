class Person:
    def __init__(self, name, age):
        self.name = name
        self.age = age
        print(f"👤 사람: {name} ({age}세)")

class Student(Person):
    def __init__(self, name, age, student_id):
        super().__init__(name, age)
        self.student_id = student_id
        print(f"🎓 학번: {student_id}")

    def introduce(self):
        return f"{self.name}, {self.age}세, 학번 {self.student_id}"

student = Student("철수", 17, "2024001")
print(f"\n소개: {student.introduce()}")
print()
print("💡 핵심: super()로 부모의 기능을 재사용")
