    SecureGogsStorage("사용자B", 5, "pass"),
    CloudSecureGogsStorage("사용자C", 5, "pass", "user@cloud")
]

for i, storage in enumerate(storages, 1):
    process_storage(storage, f"데이터 {i}")

print()
