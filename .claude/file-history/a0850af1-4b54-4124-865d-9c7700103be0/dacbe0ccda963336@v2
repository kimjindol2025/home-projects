class CloudSecureGogsStorage(SecureGogsStorage):
    def __init__(self, owner, capacity=100, password="", cloud_account=""):
        super().__init__(owner, capacity, password)
        self.cloud_account = cloud_account
        self._cloud_backup = []
        print(f"☁️ 클라우드 연결: {cloud_account}")

    def save(self, item):
        super().save(item)
        self._cloud_backup.append(item)
        print(f"☁️ 클라우드 백업됨")

    def show_backup(self):
        print(f"\n--- {self.owner}의 클라우드 백업 ---")
        for item in self._cloud_backup:
            print(f"  ☁️ {item}")

print("【 3단계 상속 시연 】")
