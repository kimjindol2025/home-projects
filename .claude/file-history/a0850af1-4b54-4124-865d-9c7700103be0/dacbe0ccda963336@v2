【 오버라이딩이란? 】

부모 클래스의 메서드를 자식 클래스에서 다시 정의하는 것

예:
  부모: def save(self): print("기본 저장")
  자식: def save(self): print("보안 저장")
""")

print("✅ 예제: GogsStorage → SecureGogsStorage")
print()

class GogsStorage:
    def __init__(self, owner, capacity=100):
        self.owner = owner
        self.capacity = capacity
        self._data = []
        print(f"📦 [{self.owner}]의 저장소 생성")

    def save(self, item):
        if len(self._data) < self.capacity:
            self._data.append(item)
            print(f"✅ 저장: '{item}'")
        else:
            print(f"❌ 용량 초과!")

class SecureGogsStorage(GogsStorage):
    def __init__(self, owner, capacity=100, password=""):
        super().__init__(owner, capacity)
        self.password = password
        self._access_log = []
        print(f"🔐 보안 모드 활성화")

    def save(self, item):
        super().save(item)
        self._access_log.append(f"[저장] {item}")
        print(f"📝 보안 로그 기록됨")

    def show_logs(self):
        print(f"\n--- {self.owner}의 보안 로그 ---")
        for log in self._access_log:
            print(f"  {log}")

print("【 기본 저장소 】")
basic = GogsStorage("철수", capacity=3)
basic.save("파일 A")

print()
print("【 보안 저장소 (메서드 오버라이딩) 】")
secure = SecureGogsStorage("영희", capacity=3, password="pass123")
secure.save("파일 B")
secure.show_logs()

print()
print("💡 핵심: super().save()로 부모 기능을 유지하면서 새 기능을 추가")
print()

