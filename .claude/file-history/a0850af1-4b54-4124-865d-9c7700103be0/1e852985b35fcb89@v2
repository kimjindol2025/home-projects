        let security_clearance = if is_admin && system_online && !maintenance_mode {
            "Full Access Granted"
        } else if is_admin || system_online {
            "Limited Access Granted"
        } else {
            "Access Denied"
        };

        println!("✓ 보안: {}", security_clearance);
    }

    // 예제 2: 온도 관리
    {
        let temperature = 85;
        let fan_active = false;
        let emergency_mode = false;

        let action = if temperature > 100 && !emergency_mode {
            "Emergency Shutdown"
        } else if temperature > 80 && !fan_active {
            "Activate Fans"
        } else if temperature < 20 {
            "Heater On"
        } else {
            "Optimal"
        };

        println!("✓ 온도: {}°C → {}", temperature, action);
    }

    // 예제 3: 사용자 권한
    {
        let age = 25;
        let is_member = true;
        let purchase_history = 150000;

        let eligible_for_vip = if age >= 18 && is_member && purchase_history > 100000 {
            true
        } else if age >= 65 || purchase_history > 500000 {
            true
        } else {
            false
        };

        println!("✓ VIP 자격: {}", if eligible_for_vip { "Yes" } else { "No" });
    }

    println!();
}

// ============================================================================
// [8] 무결성 검증: v3.1 체크리스트
// ============================================================================
//
// v3.1 설계가 안전한지 검증합니다.
//
fn integrity_verification() {
    println!("[8] 무결성 검증");
    println!("────────────────────────────────────────────────────────────");

    // 검증 1: 타입 일치
    {
        let condition = true;

        let result: i32 = if condition {
            42
        } else {
            0
        };

        println!("✓ 검증 1: 타입 일치 (if = {}, else = {})", 42, 0);
    }

    // 검증 2: 모든 경로 처리 (else if-else)
    {
        let score = 75;

        let grade = if score >= 90 {
            "A"
        } else if score >= 80 {
            "B"
        } else if score >= 70 {
            "C"
        } else {
            "F"  // 모든 경우가 처리됨
        };

        println!("✓ 검증 2: 모든 경로 처리 (score={}→{})", score, grade);
    }

    // 검증 3: 괄호로 명확하게
    {
        let a = true;
        let b = false;
        let c = true;

        // 명확한 의도: (a && b) || c
        let result = if (a && b) || c {
            "true"
        } else {
            "false"
        };

        println!("✓ 검증 3: 괄호로 명확하게 표현 → {}", result);
    }

    // 검증 4: 의미 있는 변수명
    {
        let temp = 85;
        let pressure = 40;

        let is_system_critical = temp > 80 && pressure > 50;

        if is_system_critical {
            println!("✓ 검증 4: 의미 있는 변수명 (is_system_critical)");
        }
    }

    println!();
}

