// ============================================================================
// [1] AND 연산자 (&&): 모두 만족해야 함
// ============================================================================
//
// AND는 모든 조건이 true일 때만 true를 반환합니다.
// Short-circuit: 첫 번째가 false면 나머지를 계산하지 않습니다.
//
fn compound_conditions_and() {
    println!("[1] AND 연산자 (&&): 모두 만족");
    println!("────────────────────────────────────────────────────────────");

    // 기본 AND: 나이와 면허증
    {
        let age = 25;
        let has_license = true;

        if age >= 18 && has_license {
            println!("✓ AND: 나이({}세)가 충분하고 면허증이 있습니다.", age);
        }
    }

    // 3중 AND: 모두 만족해야 함
    {
        let is_admin = true;
        let system_online = true;
        let maintenance_mode = false;

        if is_admin && system_online && !maintenance_mode {
            println!("✓ AND 3중: 관리자이고, 시스템이 온라인이고, 유지보수 중이 아닙니다.");
        }
    }

    // AND의 효율성: 첫 번째가 false면 나머지 계산 안 함
    {
        let is_admin = false;
        let mut check_count = 0;

        // is_admin이 false이므로 나머지는 계산되지 않음
        if is_admin && {
            check_count += 1;
            check_count > 0
        } {
            println!("실행되지 않음");
        }

        println!("✓ AND Short-circuit: check_count = {} (계산 생략됨)", check_count);
    }

    println!();
}

// ============================================================================
// [2] OR 연산자 (||): 하나만 만족해도 됨
// ============================================================================
//
// OR은 하나라도 true면 true를 반환합니다.
// Short-circuit: 첫 번째가 true면 나머지를 계산하지 않습니다.
//
fn compound_conditions_or() {
    println!("[2] OR 연산자 (||): 하나만 만족");
    println!("────────────────────────────────────────────────────────────");

    // 기본 OR: 주말 또는 휴일
    {
        let is_weekend = true;
        let is_holiday = false;

        if is_weekend || is_holiday {
            println!("✓ OR: 주말({}) 또는 휴일({})입니다.", is_weekend, is_holiday);
        }
    }

    // 3중 OR: 하나라도 만족
    {
        let is_admin = false;
        let is_developer = true;
        let is_manager = false;

        if is_admin || is_developer || is_manager {
            println!("✓ OR 3중: 관리자, 개발자, 또는 관리자 중 하나입니다.");
        }
    }

    // OR의 효율성: 첫 번째가 true면 나머지 계산 안 함
    {
        let is_weekend = true;
        let mut check_count = 0;

        // is_weekend가 true이므로 나머지는 계산되지 않음
        if is_weekend || {
            check_count += 1;
            check_count > 0
        } {
            println!("✓ OR Short-circuit: check_count = {} (계산 생략됨)", check_count);
        }
    }

    println!();
}

// ============================================================================
// [3] 연산자 우선순위: && 가 || 보다 먼저 계산됨
// ============================================================================
//
// 위험: 괄호 없이 && 와 ||를 섞으면 의도하지 않은 결과가 나올 수 있습니다.
// 안전: 항상 괄호로 명확하게 표현합니다.
//
fn operator_precedence() {
    println!("[3] 연산자 우선순위 & 괄호");
    println!("────────────────────────────────────────────────────────────");

    // 위험한 패턴: 괄호 없음
    {
        let is_admin = false;
        let system_online = true;
        let is_developer = true;

        // 해석: (is_admin && system_online) || is_developer
        // 즉, "관리자이면서 온라인" 또는 "개발자"
        if is_admin && system_online || is_developer {
            println!("✓ 우선순위 1: is_developer만으로도 true가 됩니다.");
        }
    }

    // 안전한 패턴: 괄호로 명확하게
    {
        let is_admin = false;
        let system_online = true;
        let is_developer = true;

        // 명확한 의도: (is_admin && system_online) || is_developer
        if (is_admin && system_online) || is_developer {
            println!("✓ 우선순위 2: 괄호로 명확하게 표현했습니다.");
        }
    }

    // 다른 의도: 다른 괄호
    {
        let is_admin = false;
        let system_online = true;
        let is_developer = true;

        // 의도: is_admin이고 (system_online 또는 developer)
        if is_admin && (system_online || is_developer) {
            println!("이 블록은 실행되지 않습니다.");
        } else {
            println!("✓ 우선순위 3: 다른 괄호로 다른 의미가 됩니다.");
        }
    }

    println!();
}

// ============================================================================
// [4] 표현식으로서의 IF: 결과를 변수에 할당
// ============================================================================
//
// if/else는 값을 반환할 수 있습니다.
// 이를 변수에 할당하면 불변성을 유지하며 코드가 간결해집니다.
//
fn if_as_expression() {
    println!("[4] 표현식으로서의 IF");
    println!("────────────────────────────────────────────────────────────");

    // 기본: if/else가 값을 반환
    {
        let score = 85;

        let grade = if score >= 90 {
            "A"
        } else if score >= 80 {
            "B"
        } else if score >= 70 {
            "C"
        } else {
            "F"
        };

        println!("✓ 점수 {}: {} 학점", score, grade);
    }

    // 복합 조건: 보안 권한
    {
        let is_admin = true;
        let system_online = true;
        let access_level = 8;

        let permission = if is_admin && system_online {
            "Full Access"
        } else if access_level > 5 || is_admin {
            "Limited Access"
        } else {
            "Denied"
        };

        println!("✓ 권한: {}", permission);
    }

    // 복잡한 조건: 요금 계산
    {
        let age = 20;
        let is_student = true;
        let is_member = false;
        let base_price = 10000;

        let discounted_price = if age < 18 && !is_student {
            (base_price as f64 * 0.8) as i32  // 20% 할인
        } else if age > 65 {
            (base_price as f64 * 0.5) as i32  // 50% 할인
        } else if is_member && access_count > 5 {
            (base_price as f64 * 0.85) as i32 // 15% 할인
        } else {
            base_price
        };

        println!("✓ 원가: {}, 할인가: {}", base_price, discounted_price);
    }

    println!();
}

// ============================================================================
// [5] 중첩 조건문: 평탄화의 중요성
// ============================================================================
//
// 중첩된 if는 읽기 어렵습니다. 가능하면 AND로 평탄화합니다.
//
fn nested_conditions() {
    println!("[5] 중첩 조건문 vs 평탄화");
    println!("────────────────────────────────────────────────────────────");

    // 중첩 (읽기 어려움)
    {
        let is_admin = true;
        let system_online = true;
        let has_backup = false;

        if is_admin {
            if system_online {
                if has_backup {
                    println!("✓ 중첩 1: 모든 조건 만족 (읽기 어려움)");
                } else {
                    println!("✓ 중첩 1: 백업이 필요합니다.");
                }
            }
        }
    }

    // 평탄화 (읽기 쉬움)
    {
        let is_admin = true;
        let system_online = true;
        let has_backup = false;

        if is_admin && system_online && !has_backup {
            println!("✓ 평탄화 1: 백업이 필요합니다 (읽기 쉬움)");
        }
    }

    // 표현식으로 평탄화
    {
        let is_admin = true;
        let system_online = true;

        let status = if is_admin && system_online {
            "Ready"
        } else if is_admin {
            "Waiting for System"
        } else {
            "Unauthorized"
        };

        println!("✓ 평탄화 2: 상태 = {}", status);
    }

    println!();
}

// ============================================================================
// [6] Short-Circuit Evaluation: 효율성 최적화
// ============================================================================
//
// 조건식의 순서를 최적화하면 불필요한 계산을 생략합니다.
//
fn short_circuit_evaluation() {
    println!("[6] Short-Circuit Evaluation");
    println!("────────────────────────────────────────────────────────────");

    // AND에서의 short-circuit
    {
        let mut expensive_call_count = 0;

        // is_admin이 false이므로 expensive_call()은 실행되지 않음
        if false && {
            expensive_call_count += 1;
            true
        } {
            println!("실행되지 않음");
        }

        println!("✓ AND Short-circuit: 계산 횟수 = {} (0번)", expensive_call_count);
    }

    // OR에서의 short-circuit
    {
        let mut expensive_call_count = 0;

        // true이므로 expensive_call()은 실행되지 않음
        if true || {
            expensive_call_count += 1;
            true
        } {
            println!("✓ OR Short-circuit: true로 인해 나머지 계산 생략");
        }

        println!("  계산 횟수 = {} (0번)", expensive_call_count);
    }

    // 효율적 순서: 빠른 계산을 먼저
    {
        let is_admin = false;
        let expensive_check = true;

        // 효율적: is_admin이 false면 나머지 계산 안 함
        if is_admin && expensive_check {
            println!("실행되지 않음");
        } else {
            println!("✓ 효율적 순서: is_admin을 먼저 검사하여 계산 생략");
        }
    }

    println!();
}

