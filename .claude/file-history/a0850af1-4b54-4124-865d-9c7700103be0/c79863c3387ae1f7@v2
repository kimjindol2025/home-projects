/// Gogs Node: 다중 경로에서 접근 가능한 공유 노드
///
/// Rc<T>를 사용하여 여러 곳에서 같은 데이터를 소유할 수 있습니다.
#[derive(Debug, Clone)]
enum GogsNode {
    /// 데이터와 다음 노드를 공유하는 노드
    /// Rc로 감싸진 다음 노드는 여러 경로에서 접근 가능
    Share(i32, Rc<GogsNode>),
    /// 노드의 끝
    Nil,
}

impl GogsNode {
    /// 새로운 공유 노드를 생성합니다.
    fn new(value: i32, next: GogsNode) -> Rc<Self> {
        Rc::new(GogsNode::Share(value, Rc::new(next)))
    }

    /// 노드의 값을 반환합니다.
    fn value(&self) -> Option<i32> {
        match self {
            GogsNode::Share(val, _) => Some(*val),
            GogsNode::Nil => None,
        }
    }

    /// 다음 노드를 공유 가능한 형태로 반환합니다.
    fn next_shared(&self) -> Option<Rc<GogsNode>> {
        match self {
            GogsNode::Share(_, next) => Some(Rc::clone(next)),
            GogsNode::Nil => None,
        }
    }

    /// 이 노드가 현재 몇 곳에서 소유되고 있는지 확인합니다.
    fn owner_count(&self) -> usize {
        match self {
            GogsNode::Share(_, next) => {
                // 자신의 카운트는 구할 수 없음 (Rc 외부에 있으므로)
                // 대신 next의 카운트를 반환
                Rc::strong_count(next)
            }
            GogsNode::Nil => 0,
        }
    }
}

fn demo_shared_node() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║          [Demo 2] 공유 노드 (Shared Gogs Node)               ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    // [1] 기본 노드 생성
    let base = Rc::new(GogsNode::Share(10, Rc::new(GogsNode::Nil)));
    println!("기본 노드 생성: GogsNode::Share(10, Nil)");
    println!("  초기 카운트: {}\n", Rc::strong_count(&base));

    // [2] 첫 번째 경로 - base를 공유
    let path_a = GogsNode::Share(5, Rc::clone(&base));
    println!("경로 A 생성: Share(5, clone(&base))");
    println!("  base 카운트: {}", Rc::strong_count(&base));
    println!("  path_a = {:?}\n", path_a);

    // [3] 두 번째 경로 - base를 공유
    let path_b = GogsNode::Share(3, Rc::clone(&base));
    println!("경로 B 생성: Share(3, clone(&base))");
    println!("  base 카운트: {}", Rc::strong_count(&base));
    println!("  path_b = {:?}\n", path_b);

    // [4] 스코프 내에서 세 번째 경로
    {
        let path_c = GogsNode::Share(7, Rc::clone(&base));
        println!("내부 스코프: 경로 C 생성");
        println!("  base 카운트: {}", Rc::strong_count(&base));
        println!("  path_c = {:?}\n", path_c);
    }

    println!("내부 스코프 벗어남 (path_c 소멸)");
    println!("  base 카운트: {}\n", Rc::strong_count(&base));

    println!("✅ 모두 같은 base를 공유하면서도 각각 독립적인 경로!");
}

