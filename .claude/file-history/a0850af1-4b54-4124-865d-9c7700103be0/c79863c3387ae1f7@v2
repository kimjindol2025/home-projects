/// 그래프 노드: 여러 엣지로 연결 가능
#[derive(Debug)]
struct GraphNode<T> {
    value: T,
    neighbors: Vec<Rc<GraphNode<T>>>,
}

impl<T: fmt::Display> GraphNode<T> {
    fn new(value: T) -> Rc<Self> {
        Rc::new(Self {
            value,
            neighbors: Vec::new(),
        })
    }

    /// DFS로 그래프를 순회합니다.
    fn traverse_dfs(&self, visited: &mut Vec<String>, depth: usize) {
        let indent = "  ".repeat(depth);
        visited.push(format!("{}{}", indent, self.value));

        for neighbor in &self.neighbors {
            neighbor.traverse_dfs(visited, depth + 1);
        }
    }

    /// 연결된 노드의 수를 계산합니다.
    fn neighbor_count(&self) -> usize {
        let mut total = self.neighbors.len();
        for neighbor in &self.neighbors {
            // 무한 순환을 피하기 위해 여기서는 단순 계산만
            total += neighbor.neighbors.len();
        }
        total
    }
}

fn demo_graph_structure() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║              [Demo 3] 그래프 구조 (Graph)                    ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    // [1] 그래프 노드 생성
    //     A
    //    / \
    //   B   C
    //    \ /
    //     D

    let a = GraphNode::new("A");
    let b = GraphNode::new("B");
    let c = GraphNode::new("C");
    let d = GraphNode::new("D");

    println!("그래프 구조:");
    println!("    A");
    println!("   / \\");
    println!("  B   C");
    println!("   \\ /");
    println!("    D\n");

    // [2] 연결 관계 설정 (예시용 - 실제로는 RefCell 필요)
    println!("노드별 카운트:");
    println!("  A: {} 명이 소유 중", Rc::strong_count(&a));
    println!("  B: {} 명이 소유 중", Rc::strong_count(&b));
    println!("  C: {} 명이 소유 중", Rc::strong_count(&c));
    println!("  D: {} 명이 소유 중\n", Rc::strong_count(&d));

    println!("💡 주의: 동적으로 노드를 연결하려면 RefCell<T>이 필요합니다.");
    println!("   지금은 생성 후 읽기만 가능합니다.");
}

