#[derive(Debug, Clone)]
struct NetworkNode {
    id: String,
    data: Rc<String>,
}

impl NetworkNode {
    fn new(id: &str, data: Rc<String>) -> Self {
        Self {
            id: id.to_string(),
            data,
        }
    }

    fn report_ownership(&self) {
        println!("  [{}] 소유 카운트: {}", self.id, Rc::strong_count(&self.data));
    }
}

fn demo_multi_path_network() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║          [Demo 6] 다중 경로 네트워크 (Multi-Path)           ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    // 중앙 데이터 뱅크
    let central_data = Rc::new("중앙 데이터 뱅크".to_string());
    println!("중앙 데이터 생성: {}", *central_data);
    println!("초기 소유자: {}\n", Rc::strong_count(&central_data));

    // 여러 노드가 같은 데이터를 참고
    let node_a = NetworkNode::new("A", Rc::clone(&central_data));
    println!("노드 A 생성");
    node_a.report_ownership();

    let node_b = NetworkNode::new("B", Rc::clone(&central_data));
    println!("노드 B 생성");
    node_b.report_ownership();

    let node_c = NetworkNode::new("C", Rc::clone(&central_data));
    println!("노드 C 생성");
    node_c.report_ownership();

    println!("\n네트워크 구조:");
    println!("        중앙 데이터");
    println!("       /    |    \\");
    println!("      A     B     C");

    println!("\n노드별 데이터 확인:");
    println!("  A의 데이터: {}", *node_a.data);
    println!("  B의 데이터: {}", *node_b.data);
    println!("  C의 데이터: {}", *node_c.data);

    println!("\n💡 모두 같은 데이터를 가리키면서도 각각 소유!");
}

