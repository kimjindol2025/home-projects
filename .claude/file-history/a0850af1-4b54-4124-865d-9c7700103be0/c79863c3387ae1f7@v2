#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_rc_basic() {
        let value = Rc::new(42);
        let shared = Rc::clone(&value);
        assert_eq!(*value, *shared);
        assert_eq!(Rc::strong_count(&value), 2);
    }

    #[test]
    fn test_gogs_node() {
        let base = Rc::new(GogsNode::Share(10, Rc::new(GogsNode::Nil)));
        assert_eq!(base.value(), Some(10));
        assert_eq!(Rc::strong_count(&base), 1);
    }

    #[test]
    fn test_shared_node() {
        let base = Rc::new(GogsNode::Share(10, Rc::new(GogsNode::Nil)));
        let _path_a = GogsNode::Share(5, Rc::clone(&base));
        let _path_b = GogsNode::Share(3, Rc::clone(&base));
        assert_eq!(Rc::strong_count(&base), 3);
    }

    #[test]
    fn test_network_node() {
        let data = Rc::new("test data".to_string());
        let node_a = NetworkNode::new("A", Rc::clone(&data));
        let node_b = NetworkNode::new("B", Rc::clone(&data));

        assert_eq!(*node_a.data, "test data");
        assert_eq!(*node_b.data, "test data");
        assert_eq!(Rc::strong_count(&data), 3);
    }
}
