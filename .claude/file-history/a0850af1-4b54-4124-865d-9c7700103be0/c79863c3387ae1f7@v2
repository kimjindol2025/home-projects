/// Rc<T>를 사용한 기본 공유 소유권
fn demo_basic_rc() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║              [Demo 1] Rc<T>: 기본 공유 소유권                ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    // [1] 단일 소유권 (Box<T>)
    println!("❌ Box<T>의 한계: 단일 소유권만 가능");
    {
        let value = Box::new(42);
        let _owner1 = value;  // 소유권 이전
        // let _owner2 = value;  // ❌ 컴파일 에러!
        println!("   Box는 오직 하나의 소유자만 가능\n");
    }

    // [2] 다중 소유권 (Rc<T>)
    println!("✅ Rc<T>의 해답: 다중 소유권");
    {
        let value = Rc::new(42);
        println!("   초기 카운트: {}", Rc::strong_count(&value));

        let owner1 = Rc::clone(&value);
        println!("   owner1 생성 후: {}", Rc::strong_count(&value));

        let owner2 = Rc::clone(&value);
        println!("   owner2 생성 후: {}", Rc::strong_count(&value));

        let owner3 = Rc::clone(&value);
        println!("   owner3 생성 후: {}", Rc::strong_count(&value));

        // 세 개의 owner가 모두 같은 데이터 42를 소유
        println!("   value = {}, owner1 = {}, owner2 = {}, owner3 = {}",
            *value, *owner1, *owner2, *owner3);
    }

    println!("   모든 owner가 스코프를 벗어남 → 자동 해제\n");
}

