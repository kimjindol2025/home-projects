// [v9.1: 관찰] Rc::clone(&) vs clone()
// ============================================================================

fn demo_clone_difference() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║       [Demo 4] Rc::clone(&x) vs x.clone()의 차이            ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    // [1] Rc::clone(&) - 가벼운 카운트 증가
    println!("✅ Rc::clone(&x) - 카운트만 증가");
    {
        let value = Rc::new(vec![1, 2, 3, 4, 5]);
        println!("  초기 카운트: {}", Rc::strong_count(&value));

        let shared = Rc::clone(&value);
        println!("  Rc::clone(&value) 후: {}", Rc::strong_count(&value));

        let shared2 = Rc::clone(&value);
        println!("  Rc::clone(&value) 후: {}", Rc::strong_count(&value));

        // value와 shared, shared2가 모두 같은 Vec을 가리킴
        println!("  value = {:?}", *value);
        println!("  shared = {:?}", *shared);
        println!("  shared2 = {:?}", *shared2);
        println!("  모두 같은 데이터!\n");
    }

    // [2] clone() - 전체 데이터 복사 (비추천)
    println!("❌ x.clone() - 데이터 전체 복사 (비효율)");
    {
        let original = Rc::new(vec![1, 2, 3, 4, 5]);
        println!("  초기 카운트: {}", Rc::strong_count(&original));

        let copied = original.clone();  // 데이터 전체 복사 + 새 Rc 생성
        println!("  .clone() 후: {}", Rc::strong_count(&original));

        // 이제 copied는 다른 Vec을 소유!
        println!("  original = {:?} (주소: {:p})", *original, original.as_ref());
        println!("  copied = {:?} (주소: {:p})", *copied, copied.as_ref());
        println!("  다른 데이터!\n");
    }

    println!("결론: Rc<T>를 다룰 때는 항상 Rc::clone(&x)를 사용하세요!");
}

// ============================================================================
// [v9.1: 메모리 추적] 카운트 변화 관찰
// ============================================================================

struct RefCountTracker {
    name: String,
    data: Rc<String>,
}

impl RefCountTracker {
    fn new(name: &str, data: Rc<String>) -> Self {
        println!("  [ENTER] {} 생성", name);
        println!("    카운트: {}", Rc::strong_count(&data));
        Self {
            name: name.to_string(),
            data,
        }
    }

    fn report(&self) {
        println!("  [{}] 카운트: {}", self.name, Rc::strong_count(&self.data));
    }
}

impl Drop for RefCountTracker {
    fn drop(&mut self) {
        println!("  [EXIT] {} 소멸", self.name);
        println!("    카운트: {}", Rc::strong_count(&self.data));
    }
}

fn demo_refcount_tracking() {
    println!("\n╔═══════════════════════════════════════════════════════════════╗");
    println!("║            [Demo 5] 참조 카운트 추적 (Tracking)              ║");
    println!("╚═══════════════════════════════════════════════════════════════╝\n");

    let shared_data = Rc::new("공유 데이터".to_string());
    println!("공유 데이터 생성");
    println!("초기 카운트: {}\n", Rc::strong_count(&shared_data));

    println!("scope 1:");
    {
        let _tracker1 = RefCountTracker::new("tracker1", Rc::clone(&shared_data));

        println!("scope 2:");
        {
            let _tracker2 = RefCountTracker::new("tracker2", Rc::clone(&shared_data));

            println!("scope 3:");
            {
                let _tracker3 = RefCountTracker::new("tracker3", Rc::clone(&shared_data));
                _tracker3.report();
            }
            println!();
            _tracker2.report();
        }
        println!();
        _tracker1.report();
    }

    println!("\n최종 카운트: {}", Rc::strong_count(&shared_data));
}

