// Phase 13 v14.4: Environment — 변수의 생존 공간
// 변수 바인딩과 스코프 체인을 구현하는 심볼 테이블 엔진

use crate::v14_2_pratt_parsing::{Expression, InfixOp, PrefixOp};
use crate::v14_3_evaluator::{Object, Evaluator};
use std::collections::HashMap;
use std::fmt;

/// 프로그램의 명령문 (Statement)
#[derive(Debug, Clone, PartialEq)]
pub enum Statement {
    /// 변수 선언: let x = 5;
    Let { name: String, value: Expression },
    /// 표현식 평가: x + 10;
    Expression(Expression),
}

/// 확장된 Expression: 식별자 추가
#[derive(Debug, Clone, PartialEq)]
pub enum ExtendedExpression {
    /// 정수 리터럴
    Literal(i32),
    /// 실수 리터럴
    FloatLiteral(f64),
    /// 변수 식별자: x, y, count_123
    Identifier(String),
    /// 전위 연산
    Prefix {
        operator: PrefixOp,
        operand: Box<ExtendedExpression>,
    },
    /// 중위 연산
    Infix {
        left: Box<ExtendedExpression>,
        operator: InfixOp,
        right: Box<ExtendedExpression>,
    },
    /// 괄호 표현식
    Grouped(Box<ExtendedExpression>),
}

impl fmt::Display for ExtendedExpression {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        match self {
            Self::Literal(n) => write!(f, "{}", n),
            Self::FloatLiteral(n) => write!(f, "{}", n),
            Self::Identifier(name) => write!(f, "{}", name),
            Self::Prefix { operator, operand } => {
                write!(f, "({}{})", operator, operand)
            }
            Self::Infix {
                left,
                operator,
                right,
            } => {
                write!(f, "({} {} {})", left, operator, right)
            }
            Self::Grouped(expr) => write!(f, "({})", expr),
        }
    }
}

/// 환경: 변수 저장소 (심볼 테이블)
/// 스코프 체인을 통해 중첩된 스코프를 관리합니다.
#[derive(Clone)]
pub struct Environment {
    /// 현재 스코프의 변수 저장소
    store: HashMap<String, Object>,
    /// 상위 스코프를 가리키는 포인터
    outer: Option<Box<Environment>>,
}

impl Environment {
    /// 새로운 전역 환경을 생성합니다.
    pub fn new() -> Self {
        Environment {
            store: HashMap::new(),
            outer: None,
        }
    }

    /// 현재 환경을 바탕으로 자식 스코프를 생성합니다.
    pub fn extend(outer: Environment) -> Self {
        Environment {
            store: HashMap::new(),
            outer: Some(Box::new(outer)),
        }
    }

    /// 변수를 등록합니다 (let 문 처리).
    pub fn set(&mut self, name: String, value: Object) {
        self.store.insert(name, value);
    }

    /// 변수를 조회합니다 (식별자 참조).
    /// 현재 스코프에 없으면 상위 스코프를 재귀적으로 탐색합니다.
    pub fn get(&self, name: &str) -> Option<Object> {
        match self.store.get(name) {
            Some(val) => Some(val.clone()),
            None => {
                // 현재 스코프에 없으면 상위 스코프에서 탐색
                self.outer
                    .as_ref()
                    .and_then(|outer| outer.get(name))
            }
        }
    }

    /// 변수가 존재하는지 확인합니다.
    pub fn contains(&self, name: &str) -> bool {
        if self.store.contains_key(name) {
            true
        } else {
            self.outer
                .as_ref()
                .map_or(false, |outer| outer.contains(name))
        }
    }

    /// 현재 스코프의 모든 변수를 출력합니다.
    pub fn print_local_vars(&self) {
        if self.store.is_empty() {
            println!("  (no variables)");
        } else {
            for (name, value) in &self.store {
                println!("  {} => {}", name, value);
            }
        }
    }
}

impl Default for Environment {
    fn default() -> Self {
        Self::new()
    }
}

impl fmt::Debug for Environment {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        f.debug_struct("Environment")
            .field("store", &self.store)
            .field("outer", &self.outer.is_some())
            .finish()
    }
}

/// 확장 평가기: 변수 바인딩 지원
pub struct ExtendedEvaluator;

impl ExtendedEvaluator {
    /// 명령문을 평가합니다.
    pub fn eval_statement(
        &self,
        stmt: &Statement,
        env: &mut Environment,
    ) -> Object {
        match stmt {
            // let 문: 변수 등록
            Statement::Let { name, value } => {
                // 기존 v14_3 Evaluator를 사용하여 값 평가
                // (v14_3은 Identifier를 지원하지 않으므로, 여기서는 단순 표현식만)
                let val = if let Expression::Literal(n) = value {
                    Object::Integer(*n)
                } else if let Expression::FloatLiteral(f) = value {
                    Object::Float(*f)
                } else {
                    // 더 복잡한 표현식은 ExtendedExpression으로 변환 필요
                    Object::Null
                };

                if !val.is_error() {
                    env.set(name.clone(), val.clone());
                }
                val
            }

            // 표현식 평가
            Statement::Expression(expr) => {
                // v14_3 Evaluator 사용 (v14_3의 Environment 별도 사용)
                let mut v14_3_env = crate::v14_3_evaluator::Environment::new();
                let evaluator = Evaluator;
                evaluator.eval(expr, &mut v14_3_env)
            }
        }
    }

    /// 확장 표현식을 평가합니다 (변수 지원).
    pub fn eval_extended(
        &self,
        expr: &ExtendedExpression,
        env: &Environment,
    ) -> Object {
        match expr {
            // 정수 리터럴
            ExtendedExpression::Literal(val) => Object::Integer(*val),

            // 실수 리터럴
            ExtendedExpression::FloatLiteral(f) => Object::Float(*f),

            // 식별자: 환경에서 조회
            ExtendedExpression::Identifier(name) => {
                env.get(name).unwrap_or_else(|| {
                    Object::Error(format!("undefined variable: '{}'", name))
                })
            }

            // 전위 연산
            ExtendedExpression::Prefix { operator, operand } => {
                let operand_val = self.eval_extended(operand, env);
                if operand_val.is_error() {
                    operand_val
                } else {
                    self.eval_prefix(operator, operand_val)
                }
            }

            // 중위 연산
            ExtendedExpression::Infix {
                left,
                operator,
                right,
            } => {
                let left_val = self.eval_extended(left, env);
                if left_val.is_error() {
                    return left_val;
                }

                let right_val = self.eval_extended(right, env);
                if right_val.is_error() {
                    return right_val;
                }

                self.eval_infix(left_val, operator, right_val)
            }

            // 괄호 표현식
            ExtendedExpression::Grouped(expr) => self.eval_extended(expr, env),
        }
    }

    /// 전위 연산자를 평가합니다.
    fn eval_prefix(&self, op: &PrefixOp, operand: Object) -> Object {
        match op {
            PrefixOp::Minus => match operand {
                Object::Integer(val) => Object::Integer(-val),
                Object::Float(val) => Object::Float(-val),
                _ => Object::Error(format!("unknown operator: -{}", operand)),
            },
            PrefixOp::Bang => Object::Boolean(!operand.is_truthy()),
        }
    }

    /// 중위 연산자를 평가합니다.
    fn eval_infix(&self, left: Object, op: &InfixOp, right: Object) -> Object {
        match (&left, &right) {
            (Object::Integer(l), Object::Integer(r)) => {
                self.eval_integer_infix(*l, op, *r)
            }
            (Object::Float(l), Object::Float(r)) => {
                self.eval_float_infix(*l, op, *r)
            }
            (Object::Integer(l), Object::Float(r)) => {
                self.eval_float_infix(*l as f64, op, *r)
            }
            (Object::Float(l), Object::Integer(r)) => {
                self.eval_float_infix(*l, op, *r as f64)
            }
            (Object::Boolean(l), Object::Boolean(r)) => {
                self.eval_boolean_infix(*l, op, *r)
            }
            _ => Object::Error(format!(
                "type mismatch: {} {:?} {}",
                left, op, right
            )),
        }
    }

    /// 정수 중위 연산을 평가합니다.
    fn eval_integer_infix(&self, left: i32, op: &InfixOp, right: i32) -> Object {
        match op {
            InfixOp::Plus => Object::Integer(left + right),
            InfixOp::Minus => Object::Integer(left - right),
            InfixOp::Multiply => Object::Integer(left * right),
            InfixOp::Divide => {
                if right == 0 {
                    Object::Error("division by zero".to_string())
                } else {
                    Object::Integer(left / right)
                }
            }
            InfixOp::Modulo => {
                if right == 0 {
                    Object::Error("modulo by zero".to_string())
                } else {
                    Object::Integer(left % right)
                }
            }
            InfixOp::Equal => Object::Boolean(left == right),
            InfixOp::NotEqual => Object::Boolean(left != right),
            InfixOp::Less => Object::Boolean(left < right),
            InfixOp::LessEqual => Object::Boolean(left <= right),
            InfixOp::Greater => Object::Boolean(left > right),
            InfixOp::GreaterEqual => Object::Boolean(left >= right),
        }
    }

    /// 실수 중위 연산을 평가합니다.
    fn eval_float_infix(&self, left: f64, op: &InfixOp, right: f64) -> Object {
        match op {
            InfixOp::Plus => Object::Float(left + right),
            InfixOp::Minus => Object::Float(left - right),
            InfixOp::Multiply => Object::Float(left * right),
            InfixOp::Divide => {
                if right == 0.0 {
                    Object::Error("division by zero".to_string())
                } else {
                    Object::Float(left / right)
                }
            }
            InfixOp::Modulo => Object::Float(left % right),
            InfixOp::Equal => Object::Boolean((left - right).abs() < f64::EPSILON),
            InfixOp::NotEqual => Object::Boolean((left - right).abs() >= f64::EPSILON),
            InfixOp::Less => Object::Boolean(left < right),
            InfixOp::LessEqual => Object::Boolean(left <= right),
            InfixOp::Greater => Object::Boolean(left > right),
            InfixOp::GreaterEqual => Object::Boolean(left >= right),
        }
    }

    /// 불리언 중위 연산을 평가합니다.
    fn eval_boolean_infix(&self, left: bool, op: &InfixOp, right: bool) -> Object {
        match op {
            InfixOp::Equal => Object::Boolean(left == right),
            InfixOp::NotEqual => Object::Boolean(left != right),
            _ => Object::Error(format!("invalid operation for booleans: {:?}", op)),
        }
    }
}

pub fn main() {
    println!("\n=== v14.4: Environment — 변수의 생존 공간 ===\n");

    // 데모 1: 단순 변수
    demo_simple_variable();

    // 데모 2: 여러 변수
    demo_multiple_variables();

    // 데모 3: 변수 재사용
    demo_variable_reuse();

    // 데모 4: 스코프 체인
    demo_scope_chain();

    // 데모 5: 변수 그림자 현상
    demo_shadowing();

    // 데모 6: 미정의 변수 에러
    demo_undefined_variable();

    // 데모 7: 중첩 스코프
    demo_nested_scopes();

    // 데모 8: 스코프 체인에서의 계산
    demo_complex_scope_chain();
}

fn demo_simple_variable() {
    println!("[데모 1] 단순 변수 등록 및 조회");
    println!("─────────────────────");

    let mut env = Environment::new();
    let evaluator = ExtendedEvaluator;

    // let x = 5;
    env.set("x".to_string(), Object::Integer(5));

    // x 조회
    match env.get("x") {
        Some(val) => println!("let x = 5;\neval(x) = {}", val),
        None => println!("Error: x not found"),
    }
    println!();
}

fn demo_multiple_variables() {
    println!("[데모 2] 여러 변수");
    println!("─────────────────────");

    let mut env = Environment::new();

    env.set("x".to_string(), Object::Integer(5));
    env.set("y".to_string(), Object::Integer(10));

    println!("let x = 5;");
    println!("let y = 10;");
    println!("Current variables:");
    env.print_local_vars();
    println!();
}

fn demo_variable_reuse() {
    println!("[데모 3] 변수 재사용");
    println!("─────────────────────");

    let mut env = Environment::new();
    let evaluator = ExtendedEvaluator;

    // let x = 5;
    env.set("x".to_string(), Object::Integer(5));

    // let y = x + 3; (수동 계산)
    match env.get("x") {
        Some(Object::Integer(x_val)) => {
            let y_val = Object::Integer(x_val + 3);
            env.set("y".to_string(), y_val.clone());
            println!("let x = 5;");
            println!("let y = x + 3;");
            println!("y = {}", y_val);
        }
        _ => println!("Error"),
    }
    println!();
}

fn demo_scope_chain() {
    println!("[데모 4] 스코프 체인");
    println!("─────────────────────");

    // 전역 스코프
    let mut global = Environment::new();
    global.set("a".to_string(), Object::Integer(1));

    // 함수 스코프 (전역의 자식)
    let mut function_scope = Environment::extend(global.clone());
    function_scope.set("b".to_string(), Object::Integer(2));

    // 함수 스코프에서 a 접근 (상위 스코프에서 찾음)
    println!("Global scope:");
    println!("  let a = 1;");
    println!("Function scope:");
    println!("  let b = 2;");
    println!("  get(a) = {:?} (상위 스코프에서 찾음)", function_scope.get("a"));
    println!("  get(b) = {:?}", function_scope.get("b"));
    println!();
}

fn demo_shadowing() {
    println!("[데모 5] 변수 그림자 현상 (Shadowing)");
    println!("─────────────────────");

    // 외부 스코프
    let mut outer = Environment::new();
    outer.set("x".to_string(), Object::Integer(5));

    // 내부 스코프
    let mut inner = Environment::extend(outer.clone());
    inner.set("x".to_string(), Object::Integer(10)); // x를 다시 정의 (가림)

    println!("let x = 5;        // 외부 스코프");
    println!("{{");
    println!("  let x = 10;     // 내부 스코프 (외부 x를 가림)");
    println!("  x = {} (내부 스코프의 x)", inner.get("x").unwrap());
    println!("}}");
    println!("x = {} (외부 스코프의 x)", outer.get("x").unwrap());
    println!();
}

fn demo_undefined_variable() {
    println!("[데모 6] 미정의 변수 에러");
    println!("─────────────────────");

    let env = Environment::new();

    println!("trying to access: y");
    match env.get("y") {
        Some(val) => println!("y = {}", val),
        None => println!("Error: undefined variable 'y'"),
    }
    println!();
}

fn demo_nested_scopes() {
    println!("[데모 7] 중첩 스코프");
    println!("─────────────────────");

    let mut global = Environment::new();
    global.set("x".to_string(), Object::Integer(1));

    let mut level2 = Environment::extend(global);
    level2.set("x".to_string(), Object::Integer(2));

    let mut level3 = Environment::extend(level2);
    level3.set("x".to_string(), Object::Integer(3));

    println!("let x = 1;");
    println!("{{");
    println!("  let x = 2;");
    println!("  {{");
    println!("    let x = 3;");
    println!("    x = {}", level3.get("x").unwrap());
    println!("  }}");
    println!("}}");
    println!();
}

fn demo_complex_scope_chain() {
    println!("[데모 8] 스코프 체인에서의 계산");
    println!("─────────────────────");

    let mut global = Environment::new();
    global.set("x".to_string(), Object::Integer(10));
    global.set("y".to_string(), Object::Integer(20));

    let function_scope = Environment::extend(global);
    // z는 스코프 체인을 통해 x, y를 접근 가능

    match (
        function_scope.get("x"),
        function_scope.get("y"),
    ) {
        (Some(Object::Integer(x)), Some(Object::Integer(y))) => {
            let result = x + y;
            println!("let x = 10;");
            println!("let y = 20;");
            println!("{{");
            println!("  x + y = {} (스코프 체인에서 x, y 찾음)", result);
            println!("}}");
        }
        _ => println!("Error"),
    }
    println!();
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_set_and_get() {
        let mut env = Environment::new();
        env.set("x".to_string(), Object::Integer(5));
        assert_eq!(env.get("x"), Some(Object::Integer(5)));
    }

    #[test]
    fn test_undefined_variable() {
        let env = Environment::new();
        assert_eq!(env.get("x"), None);
    }

    #[test]
    fn test_scope_chain() {
        let mut outer = Environment::new();
        outer.set("a".to_string(), Object::Integer(1));

        let inner = Environment::extend(outer);
        assert_eq!(inner.get("a"), Some(Object::Integer(1)));
    }

    #[test]
    fn test_shadowing() {
        let mut outer = Environment::new();
        outer.set("x".to_string(), Object::Integer(5));

        let mut inner = Environment::extend(outer);
        inner.set("x".to_string(), Object::Integer(10));

        assert_eq!(inner.get("x"), Some(Object::Integer(10)));
    }

    #[test]
    fn test_multiple_variables() {
        let mut env = Environment::new();
        env.set("x".to_string(), Object::Integer(1));
        env.set("y".to_string(), Object::Integer(2));
        env.set("z".to_string(), Object::Integer(3));

        assert_eq!(env.get("x"), Some(Object::Integer(1)));
        assert_eq!(env.get("y"), Some(Object::Integer(2)));
        assert_eq!(env.get("z"), Some(Object::Integer(3)));
    }

    #[test]
    fn test_nested_scopes() {
        let mut global = Environment::new();
        global.set("x".to_string(), Object::Integer(1));

        let mut level2 = Environment::extend(global);
        level2.set("y".to_string(), Object::Integer(2));

        let mut level3 = Environment::extend(level2);
        level3.set("z".to_string(), Object::Integer(3));

        assert_eq!(level3.get("x"), Some(Object::Integer(1)));
        assert_eq!(level3.get("y"), Some(Object::Integer(2)));
        assert_eq!(level3.get("z"), Some(Object::Integer(3)));
    }

    #[test]
    fn test_extended_eval_literal() {
        let env = Environment::new();
        let evaluator = ExtendedEvaluator;
        let expr = ExtendedExpression::Literal(42);
        assert_eq!(evaluator.eval_extended(&expr, &env), Object::Integer(42));
    }

    #[test]
    fn test_extended_eval_identifier() {
        let mut env = Environment::new();
        env.set("x".to_string(), Object::Integer(5));
        let evaluator = ExtendedEvaluator;
        let expr = ExtendedExpression::Identifier("x".to_string());
        assert_eq!(
            evaluator.eval_extended(&expr, &env),
            Object::Integer(5)
        );
    }

    #[test]
    fn test_extended_eval_undefined_identifier() {
        let env = Environment::new();
        let evaluator = ExtendedEvaluator;
        let expr = ExtendedExpression::Identifier("undefined".to_string());
        match evaluator.eval_extended(&expr, &env) {
            Object::Error(msg) => assert!(msg.contains("undefined")),
            _ => panic!("Expected error"),
        }
    }
}
