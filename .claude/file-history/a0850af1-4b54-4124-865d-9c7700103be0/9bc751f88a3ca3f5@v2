print(f"  - greet_python() = {greet_python()}")
print()

# 예제 2: 상태를 보존하는 클로저
def counter():
    """
    클로저를 이용해 상태(count)를 보존하는 함수
    """
    count = 0  # 상태 보존

    def increment():
        nonlocal count  # 바깥쪽 변수를 수정
        count += 1
        return count

    return increment

print("✓ 클로저가 상태를 보존하기:")
my_counter = counter()
for i in range(3):
    print(f"  - {i+1}번째 호출: {my_counter()}")
print()

