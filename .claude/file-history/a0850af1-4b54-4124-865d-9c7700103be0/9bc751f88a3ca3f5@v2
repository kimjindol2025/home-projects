print()

# 예제 2: 권한 확인 데코레이터
def require_role(required_role):
    """
    특정 역할을 가진 사용자만 함수 실행 허용
    """
    def decorator(func):
        @wraps(func)
        def wrapper(user_role, *args, **kwargs):
            if user_role == required_role:
                print(f"  ✅ [{user_role}] 권한 확인됨, 함수 실행")
                return func(*args, **kwargs)
            else:
                print(f"  ❌ [{user_role}] 권한 없음, 실행 거부")
                return "권한이 없습니다."
        return wrapper
    return decorator

@require_role("admin")
def delete_database():
    return "데이터베이스 삭제 완료"

