# 최종 예제: 프로덕션급 데코레이터
def production_decorator(retry_count=3, timeout=5):
    """
    프로덕션 환경에서 사용할 수 있는 데코레이터
    - 재시도 로직
    - 타임아웃 처리
    - 상세한 로깅
    """
    def decorator(func):
        @wraps(func)
        def wrapper(*args, **kwargs):
            execution_log = {
                "function": func.__name__,
                "timestamp": datetime.now().isoformat(),
                "attempts": 0,
                "success": False,
                "result": None,
                "error": None
            }

            for attempt in range(1, retry_count + 1):
                try:
                    execution_log["attempts"] = attempt
                    print(f"  🔄 시도 {attempt}/{retry_count}: {func.__name__}()")

                    result = func(*args, **kwargs)

                    execution_log["success"] = True
                    execution_log["result"] = str(result)
                    print(f"  ✅ 성공!")
                    return result

                except Exception as e:
                    execution_log["error"] = str(e)
                    print(f"  ❌ 실패: {e}")

                    if attempt < retry_count:
                        time.sleep(1)
                    else:
                        print(f"  🚫 {retry_count}회 모두 실패")

            # 실행 로그 저장
            print(f"\n  📋 실행 로그:")
            for key, value in execution_log.items():
                print(f"     - {key}: {value}")

            return None

        return wrapper
    return decorator

@production_decorator(retry_count=2, timeout=5)
def unreliable_operation():
    """불안정한 작업"""
    import random
    if random.random() < 0.7:
        raise ConnectionError("네트워크 연결 실패")
    return "작업 완료"

