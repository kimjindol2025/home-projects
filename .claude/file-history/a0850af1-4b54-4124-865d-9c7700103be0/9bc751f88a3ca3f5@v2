# 예제 1: 가변 인자를 지원하는 데코레이터
def gogs_timer(func):
    """
    함수의 실행 시간을 측정하는 데코레이터
    *args, **kwargs를 사용하여 어떤 함수에도 적용 가능
    """
    @wraps(func)  # 원본 함수의 메타데이터 보존
    def wrapper(*args, **kwargs):
        start_time = time.time()
        print(f"  ⏱️ [{func.__name__}] 실행 시작...")

        result = func(*args, **kwargs)

        elapsed_time = time.time() - start_time
        print(f"  ⏱️ [{func.__name__}] 완료 ({elapsed_time:.4f}초)")
        return result

    return wrapper

# 인자가 없는 함수
@gogs_timer
def no_args():
    time.sleep(0.1)
    return "완료"

# 위치 인자가 있는 함수
@gogs_timer
def with_args(a, b):
    time.sleep(0.1)
    return a + b

# 키워드 인자가 있는 함수
@gogs_timer
def with_kwargs(name, age=0):
    time.sleep(0.1)
    return f"{name} ({age})"

print("✓ 가변 인자를 지원하는 범용 데코레이터:")
print()
print("  1️⃣ 인자가 없는 함수:")
