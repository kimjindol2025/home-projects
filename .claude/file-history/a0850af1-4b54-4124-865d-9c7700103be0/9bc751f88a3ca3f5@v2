print()

# 예제 2: 함수의 인자와 반환값을 기록하는 데코레이터
def gogs_logger(func):
    """
    함수의 인자와 반환값을 기록하는 데코레이터
    """
    @wraps(func)
    def wrapper(*args, **kwargs):
        print(f"  📝 [{func.__name__}] 호출됨")
        print(f"      - 위치인자: {args}")
        print(f"      - 키워드인자: {kwargs}")

        result = func(*args, **kwargs)

        print(f"      - 반환값: {result}")
        return result

    return wrapper

@gogs_logger
def calculate(x, y, operation="add"):
    if operation == "add":
        return x + y
    else:
        return x * y

