def create_logger(prefix):
    """
    어떤 접두사를 가진 로거를 만드는 함수
    """
    def log(message):
        timestamp = datetime.now().strftime("%H:%M:%S")
        return f"[{timestamp}] [{prefix}] {message}"

    return log

