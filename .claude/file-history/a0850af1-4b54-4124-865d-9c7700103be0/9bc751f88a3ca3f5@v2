# 예제 3: 결과 변환 데코레이터
def transform_result(to_format):
    """
    함수의 반환값을 특정 형식으로 변환
    """
    def decorator(func):
        @wraps(func)
        def wrapper(*args, **kwargs):
            result = func(*args, **kwargs)
            if to_format == "json":
                return json.dumps({"result": result})
            elif to_format == "upper":
                return result.upper()
            else:
                return result
        return wrapper
    return decorator

@transform_result("json")
def get_user_info():
    return "user created successfully"

@transform_result("upper")
def get_greeting():
    return "hello world"

print("✓ 결과 변환 데코레이터:")
print(f"  - JSON 변환: {get_user_info()}")
print(f"  - UPPER 변환: {get_greeting()}")
print()

