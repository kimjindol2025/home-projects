# 2. 예외 처리 데코레이터
def handle_exceptions(default_return=None):
    """
    함수 실행 중 발생하는 예외를 처리
    """
    def decorator(func):
        @wraps(func)
        def wrapper(*args, **kwargs):
            try:
                return func(*args, **kwargs)
            except Exception as e:
                print(f"  ⚠️ 예외 발생: {type(e).__name__}: {e}")
                return default_return
        return wrapper
    return decorator

@handle_exceptions(default_return="오류 발생")
def risky_operation(value):
    if value < 0:
        raise ValueError("음수는 안 됩니다!")
    return f"성공: {value}"

print("✓ 예외 처리 데코레이터:")
print("  - 정상 호출:")
risky_operation(10)
print()
print("  - 예외 발생:")
risky_operation(-5)
print()

# 3. 속도 제한 데코레이터 (Rate Limiting)
def rate_limit(max_calls, time_window):
    """
    시간 윈도우 내에서 함수를 호출할 수 있는 횟수 제한
    """
    def decorator(func):
        calls = []

        @wraps(func)
        def wrapper(*args, **kwargs):
            now = time.time()
            # 시간 윈도우를 벗어난 호출 제거
            calls[:] = [call_time for call_time in calls if call_time > now - time_window]

            if len(calls) >= max_calls:
                print(f"  🚫 호출 제한 초과 ({max_calls}회/{time_window}초)")
                return None

            calls.append(now)
            print(f"  📞 호출 가능 ({len(calls)}/{max_calls})")
            return func(*args, **kwargs)

        return wrapper
    return decorator

@rate_limit(max_calls=3, time_window=2)
def api_call():
    return "API 응답"

print("✓ 속도 제한 데코레이터 (Rate Limiting):")
for i in range(4):
    print(f"  {i+1}번째 호출:")
    api_call()
print()

# 4. 입력값 검증 데코레이터
def validate_inputs(**validators):
    """
    함수의 입력값을 검증
    """
    def decorator(func):
        @wraps(func)
        def wrapper(*args, **kwargs):
            for key, validator in validators.items():
                if key in kwargs:
                    if not validator(kwargs[key]):
                        print(f"  ❌ 입력값 검증 실패: {key} = {kwargs[key]}")
                        return None

            print(f"  ✓ 모든 입력값 검증 성공")
            return func(*args, **kwargs)

        return wrapper
    return decorator

@validate_inputs(
    age=lambda x: 0 < x < 150,
    email=lambda x: "@" in x
)
def create_user(name, age=0, email=""):
    return f"사용자 생성: {name}, {age}세, {email}"

print("✓ 입력값 검증 데코레이터:")
print("  - 유효한 입력:")
create_user("클로드", age=25, email="claude@anthropic.com")
print()
print("  - 유효하지 않은 입력:")
create_user("클로드", age=1000, email="invalid-email")
print()

