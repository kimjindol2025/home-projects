# 예제 1: 클로저의 기본
def outer(name):
    """바깥쪽 함수"""
    greeting_msg = f"안녕, {name}!"  # 바깥쪽 함수의 변수

    def inner():
        """안쪽 함수가 바깥쪽 함수의 변수를 사용"""
        return greeting_msg  # name을 기억!

    return inner

