# 예제 1: 파라미터를 받는 데코레이터
def repeat(times):
    """
    함수를 여러 번 실행하는 데코레이터
    파라미터: times - 반복 횟수
    """
    def decorator(func):
        @wraps(func)
        def wrapper(*args, **kwargs):
            print(f"  🔄 [{func.__name__}] {times}번 반복 실행:")
            results = []
            for i in range(times):
                result = func(*args, **kwargs)
                results.append(result)
                print(f"     {i+1}회차: {result}")
            return results
        return wrapper
    return decorator

# 파라미터가 있는 데코레이터 사용
@repeat(times=3)
def hello(name):
    return f"안녕, {name}!"

print("✓ 파라미터가 있는 데코레이터:")
print("  - @repeat(times=3)를 적용한 함수:")
