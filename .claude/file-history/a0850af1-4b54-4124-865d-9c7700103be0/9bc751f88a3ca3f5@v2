# 1. 캐싱 데코레이터 (Memoization)
def cache_result(func):
    """
    함수의 결과를 캐싱하는 데코레이터
    같은 인자로 다시 호출되면 캐시된 결과 반환
    """
    cache = {}

    @wraps(func)
    def wrapper(*args):
        if args in cache:
            print(f"  💾 캐시에서 반환: {args}")
            return cache[args]

        print(f"  🔄 새로 계산: {args}")
        result = func(*args)
        cache[args] = result
        return result

    return wrapper

@cache_result
def fibonacci(n):
    """피보나치 수열 (느린 버전)"""
    if n <= 1:
        return n
    return fibonacci(n-1) + fibonacci(n-2)

print("✓ 캐싱 데코레이터 (Memoization):")
print("  - fibonacci(5) 첫 호출 (캐시 없음):")
fibonacci(5)
print()
print("  - fibonacci(5) 재호출 (캐시에서):")
