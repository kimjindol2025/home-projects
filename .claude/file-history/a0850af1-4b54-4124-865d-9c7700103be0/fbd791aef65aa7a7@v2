// Phase 9 v10.3: Send and Sync Traits Demo
// Understanding marker traits for thread safety certification
// "불가능을 사전에 차단하기" - Preventing the Impossible Proactively

use std::sync::{Arc, Mutex};
use std::thread;
use std::rc::Rc;
use std::cell::Cell;
use std::marker::PhantomData;

// ============================================================================
// Demo 1: Send Trait Understanding
// ============================================================================
// Send 트레이트: 소유권 이동이 스레드 안전한가?

struct SecurityToken {
    token_id: String,
    access_level: u32,
}

// SecurityToken은 자동으로 Send를 구현함
// (모든 필드가 Send이므로 → Rust 컴파일러가 자동 판정)

fn demo_send_trait_basic() {
    println!("\n=== Demo 1: Send Trait Understanding ===");

    let token = SecurityToken {
        token_id: "SEC-12345".to_string(),
        access_level: 5,
    };

    // token을 스레드로 이동 (move semantics)
    // SecurityToken이 Send이므로 컴파일 성공
    thread::spawn(move || {
        println!("✓ Successfully transferred token to thread");
        println!("  Token ID: {}", token.token_id);
        println!("  Access Level: {}", token.access_level);
        println!("  (원래 스레드에서는 token을 더 이상 사용할 수 없음)");
    }).join().unwrap();

    println!("✓ Main thread continues after worker thread completes");
}

// ============================================================================
// Demo 2: Sync Trait Understanding
// ============================================================================
// Sync 트레이트: 참조(&T) 공유가 스레드 안전한가?

struct ConfigData {
    max_connections: u32,
    timeout_ms: u64,
}

// ConfigData의 &ConfigData를 여러 스레드에서 공유해도 안전함
// (읽기 전용이므로 → 자동으로 Sync 구현)

fn demo_sync_trait_basic() {
    println!("\n=== Demo 2: Sync Trait Understanding ===");

    // Arc<Mutex<T>>를 사용하여 여러 스레드가 안전하게 공유
    let config = Arc::new(Mutex::new(ConfigData {
        max_connections: 100,
        timeout_ms: 5000,
    }));

    // 3개의 워커 스레드가 같은 config에 접근
    let mut handles = vec![];

    for worker_id in 1..=3 {
        let config_clone = Arc::clone(&config);
        let handle = thread::spawn(move || {
            let data = config_clone.lock().unwrap();
            println!("✓ Worker {} read config safely", worker_id);
            println!("  Max Connections: {}", data.max_connections);
            println!("  Timeout: {}ms", data.timeout_ms);
        });
        handles.push(handle);
    }

    for handle in handles {
        handle.join().unwrap();
    }

    println!("✓ All workers safely shared the same reference");
}

// ============================================================================
// Demo 3: Rc vs Arc - The Key Difference
// ============================================================================
// Rc는 !Send, !Sync (비원자적 참조 카운팅)
// Arc는 Send + Sync (원자적 참조 카운팅)

fn demo_rc_vs_arc() {
    println!("\n=== Demo 3: Rc vs Arc Comparison ===");

    println!("\n📍 Rc<T> 분석:");
    println!("  ├─ 내부: Cell<usize> (참조 카운트)");
    println!("  ├─ Cell<usize>는 !Sync (스레드 공유 불가)");
    println!("  └─ 결론: Rc는 !Send, !Sync ❌");

    println!("\n📍 Arc<T> 분석:");
    println!("  ├─ 내부: AtomicUsize (원자적 참조 카운트)");
    println!("  ├─ AtomicUsize는 Send + Sync (스레드 안전)");
    println!("  └─ 결론: Arc는 Send + Sync ✓");

    // 컴파일러는 자동으로 이를 확인하므로
    // Rc를 스레드로 보내려고 하면 컴파일 에러!
    // let rc = Rc::new(5);
    // thread::spawn(move || {  // ERROR: cannot be sent between threads safely
    //     println!("{}", rc);
    // });

    println!("\n코드로 확인:");
    println!("  // ❌ Rc를 스레드로 보내기 (컴파일 실패)");
    println!("  let rc = Rc::new(5);");
    println!("  thread::spawn(move || println!(\"{{}}\", rc));");
    println!("  // ERROR[E0277]: `Rc<_>` cannot be sent between threads safely");

    println!("\n  // ✅ Arc를 스레드로 보내기 (컴파일 성공)");
    println!("  let arc = Arc::new(5);");
    println!("  thread::spawn(move || println!(\"{{}}\", arc)).join().unwrap();");

    // Arc 예제
    let counter = Arc::new(Mutex::new(0));
    let mut handles = vec![];

    for _ in 0..3 {
        let counter_clone = Arc::clone(&counter);
        let handle = thread::spawn(move || {
            let mut num = counter_clone.lock().unwrap();
            *num += 1;
        });
        handles.push(handle);
    }

    for handle in handles {
        handle.join().unwrap();
    }

    println!("\n✓ Arc allowed safe thread-crossing: final count = {}",
             *counter.lock().unwrap());
}

// ============================================================================
// Demo 4: Mutex Characteristics (Send + Sync)
// ============================================================================
// Mutex<T>는 T가 Send이면 자동으로 Send를 구현
// Mutex<T>는 T가 어떤 타입이든 항상 Sync를 구현

struct SharedState {
    value: i32,
}

fn demo_mutex_send_sync() {
    println!("\n=== Demo 4: Mutex Send + Sync Characteristics ===");

    println!("\n📍 Mutex<T>의 특성:");
    println!("  ├─ Mutex<T>는 항상 Sync 구현");
    println!("  ├─ Mutex<T>는 T가 Send이면 Send 구현");
    println!("  └─ 결론: &Mutex<T>를 여러 스레드에서 공유 가능 ✓");

    let shared_state = Arc::new(Mutex::new(SharedState { value: 0 }));

    // 2개 스레드가 같은 뮤텍스 수정
    let mut handles = vec![];

    for thread_id in 0..2 {
        let state = Arc::clone(&shared_state);
        let handle = thread::spawn(move || {
            for step in 0..5 {
                let mut guard = state.lock().unwrap();
                guard.value += 1;
                println!("✓ Thread {} step {}: value = {}",
                         thread_id, step, guard.value);
            }
        });
        handles.push(handle);
    }

    for handle in handles {
        handle.join().unwrap();
    }

    println!("\n✓ Mutex enabled safe concurrent modification: final = {}",
             shared_state.lock().unwrap().value);
}

// ============================================================================
// Demo 5: Custom Type Auto-Implementation
// ============================================================================
// 컴파일러는 타입의 구성을 분석하여 Send/Sync를 자동 구현

struct AutoSendType {
    data: i32,
    string: String,
    // 모든 필드가 Send + Sync → 타입도 Send + Sync
}

struct PartialSendType {
    data: i32,
    rc_ptr: Rc<String>,
    // Rc는 !Send, !Sync → 타입도 !Send, !Sync
}

fn demo_custom_type_auto_impl() {
    println!("\n=== Demo 5: Custom Type Auto-Implementation ===");

    println!("\n📍 AutoSendType 분석:");
    println!("  ├─ data: i32 → Send + Sync");
    println!("  ├─ string: String → Send + Sync");
    println!("  └─ 결론: AutoSendType은 Send + Sync ✓ (자동)");

    let auto_type = AutoSendType {
        data: 42,
        string: "thread-safe".to_string(),
    };

    thread::spawn(move || {
        println!("✓ Successfully moved AutoSendType: {} - {}",
                 auto_type.data, auto_type.string);
    }).join().unwrap();

    println!("\n📍 PartialSendType 분석:");
    println!("  ├─ data: i32 → Send + Sync");
    println!("  ├─ rc_ptr: Rc<String> → !Send, !Sync");
    println!("  └─ 결론: PartialSendType은 !Send, !Sync ✓ (자동)");

    println!("\n  코드로 확인:");
    println!("  let partial = PartialSendType {{");
    println!("    data: 42,");
    println!("    rc_ptr: Rc::new(\"text\".to_string()),");
    println!("  }};");
    println!("  thread::spawn(move || println!(\"{{}}\", partial));");
    println!("  // ERROR: `Rc<String>` cannot be sent between threads safely");

    println!("\n✓ Compiler auto-determined trait implementation");
}

// ============================================================================
// Demo 6: Unsafe Impl Dangers (Read-Only Demonstration)
// ============================================================================
// unsafe impl는 매우 위험함 - 절대 사용하면 안됨

struct DangerousType {
    value: u32,
}

// ❌ 이런 코드는 절대 작성하면 안됩니다!
// unsafe impl Send for DangerousType {}
// ↑ 컴파일러의 안전 보장을 무시함 → 데이터 경합 유발 가능

fn demo_unsafe_impl_dangers() {
    println!("\n=== Demo 6: Unsafe Impl Dangers (Read-Only) ===");

    println!("\n🚨 경고: unsafe impl은 절대 금지!");
    println!("\n❌ 위험한 코드 (절대 사용 금지):");
    println!("  struct DangerousType {{ value: u32 }}");
    println!("  unsafe impl Send for DangerousType {{}}");
    println!("  // ↑ 컴파일러의 안전 검사를 무시함!");

    println!("\n🔴 문제점:");
    println!("  ├─ 내부 가변성 없이도 스레드로 보낼 수 있음");
    println!("  ├─ 여러 스레드가 동시에 수정 가능 → 데이터 경합");
    println!("  ├─ 경쟁 조건(Race Condition) 발생");
    println!("  └─ 메모리 안전성 위반 → 미정의 동작(UB)");

    println!("\n✅ 올바른 방법:");
    println!("  ├─ Arc<Mutex<T>>를 사용");
    println!("  ├─ AtomicT를 사용");
    println!("  └─ 컴파일러의 안전 보장을 따름");

    println!("\n📌 규칙:");
    println!("  \"unsafe impl Send/Sync를 직접 작성하지 마세요\"");
    println!("  \"컴파일러의 자동 구현을 믿고 사용하세요\"");

    // 안전한 방법의 예
    let safe_type = Arc::new(Mutex::new(DangerousType { value: 0 }));

    let mut handles = vec![];
    for _ in 0..2 {
        let clone = Arc::clone(&safe_type);
        let handle = thread::spawn(move || {
            let mut guard = clone.lock().unwrap();
            guard.value += 1;
        });
        handles.push(handle);
    }

    for handle in handles {
        handle.join().unwrap();
    }

    println!("\n✓ Safe approach with Arc<Mutex<T>>: value = {}",
             safe_type.lock().unwrap().value);
}

