// ============================================================================
// [1] 루프의 삼요소 (Loop Trilogy)
// ============================================================================
//
// 모든 반복문은 다음 세 가지가 명확해야 합니다:
// 1. 초기화 (Initialization): 어디서 시작?
// 2. 조건식 (Condition): 언제까지?
// 3. 변화식 (Increment/Decrement): 어떻게 진행?
//
fn loop_trilogy() {
    println!("[1] 루프의 삼요소");
    println!("────────────────────────────────────────────────────────────");

    // for 루프: 삼요소가 명확함
    {
        println!("✓ for 루프:");
        println!("  초기화: i = 1");
        println!("  조건: i <= 3");
        println!("  변화: i += 1");

        for i in 1..=3 {
            println!("  실행: i = {}", i);
        }
    }

    // while 루프: 수동으로 명시
    {
        println!("✓ while 루프:");
        let mut count = 1;  // 초기화

        println!("  초기화: count = 1");
        println!("  조건: count <= 3");
        println!("  변화: count += 1");

        while count <= 3 {  // 조건
            println!("  실행: count = {}", count);
            count += 1;     // 변화
        }
    }

    // loop: 모두 수동으로 명시
    {
        println!("✓ loop:");
        let mut value = 1;  // 초기화

        println!("  초기화: value = 1");
        println!("  조건: value <= 3 (if 문으로)");
        println!("  변화: value += 1");

        loop {
            if value > 3 {  // 조건
                break;
            }
            println!("  실행: value = {}", value);
            value += 1;     // 변화
        }
    }

    println!();
}

// ============================================================================
// [2] for 루프: 범위 루프 (가장 안전)
// ============================================================================
//
// for는 범위가 명확하므로 무한 루프가 불가능합니다.
// 범위가 정해졌다면 항상 for를 선택하세요.
//
fn for_loop_patterns() {
    println!("[2] for 루프 패턴");
    println!("────────────────────────────────────────────────────────────");

    // 기본 범위
    {
        print!("✓ for 1..5: ");
        for i in 1..5 {
            print!("{} ", i);
        }
        println!("(5는 포함 안 됨)");
    }

    // 포함 범위
    {
        print!("✓ for 1..=5: ");
        for i in 1..=5 {
            print!("{} ", i);
        }
        println!("(5 포함)");
    }

    // 역순 범위
    {
        print!("✓ for (1..=5).rev(): ");
        for i in (1..=5).rev() {
            print!("{} ", i);
        }
        println!("(역순)");
    }

    // 누적: 합계 계산
    {
        let mut sum = 0;
        for i in 1..=10 {
            sum += i;
        }
        println!("✓ 누적: 1~10의 합 = {}", sum);
    }

    // 필터링: 조건에 맞는 것만
    {
        print!("✓ 필터링 (짝수만): ");
        for i in 1..=10 {
            if i % 2 == 0 {
                print!("{} ", i);
            }
        }
        println!();
    }

    println!();
}

// ============================================================================
// [3] while 루프: 조건 루프 (유연함)
// ============================================================================
//
// while은 조건이 더 복잡할 때 사용합니다.
// 반드시 루프 변수가 조건에 영향을 주어야 합니다.
//
fn while_loop_patterns() {
    println!("[3] while 루프 패턴");
    println!("────────────────────────────────────────────────────────────");

    // 기본 while: 조건 기반
    {
        let mut n = 10;
        print!("✓ while n > 0: ");

        while n > 0 {
            print!("{} ", n);
            n -= 1;
        }
        println!();
    }

    // 복잡한 조건
    {
        let mut x = 1;
        println!("✓ while (복잡한 조건):");

        while x < 20 && x % 3 != 0 {
            println!("  x = {}", x);
            x += 2;
        }
    }

    // 수렴: 값이 목표에 수렴
    {
        let mut value = 100;
        println!("✓ 수렴 (반으로 줄이기):");

        while value > 1 {
            println!("  value = {}", value);
            value /= 2;
        }
    }

    println!();
}

// ============================================================================
// [4] loop: 무한 루프 (강력함)
// ============================================================================
//
// loop는 명시적으로 break할 때까지 반복합니다.
// 복잡한 탈출 조건이 있을 때 사용합니다.
//
fn loop_patterns() {
    println!("[4] loop 루프 패턴");
    println!("────────────────────────────────────────────────────────────");

    // 기본 loop: 명시적 탈출
    {
        let mut count = 0;
        println!("✓ loop (count == 3에서 탈출):");

        loop {
            if count == 3 {
                println!("  탈출!");
                break;
            }
            println!("  count = {}", count);
            count += 1;
        }
    }

    // loop에서 값 반환
    {
        let result = loop {
            let val = 42;
            break val * 2;  // 84를 반환
        };
        println!("✓ loop 반환값: {}", result);
    }

    // 조건부 탈출
    {
        let mut attempts = 0;
        println!("✓ loop (조건부 탈출):");

        loop {
            attempts += 1;
            println!("  시도 {}", attempts);

            if attempts >= 3 {
                println!("  최대 시도 도달. 탈출.");
                break;
            }
        }
    }

    println!();
}

// ============================================================================
// [5] 루프 최적화: 세 가지 전략
// ============================================================================
//
// 최적화는 안전성을 해치지 않으면서 효율성을 높입니다.
//
fn loop_optimization() {
    println!("[5] 루프 최적화");
    println!("────────────────────────────────────────────────────────────");

    // 최적화 1: 범위가 명확하면 for 사용
    {
        println!("✓ 최적화 1: 범위 명확 → for 사용");
        for i in 1..=5 {
            println!("  i = {}", i);
        }
    }

    // 최적화 2: 루프 변수의 최소 범위
    {
        println!("✓ 최적화 2: 루프 변수의 범위 최소화");

        for i in 1..=3 {
            // i는 루프 블록 내에서만 유효
            let squared = i * i;
            println!("  {} → {}", i, squared);
        }
        // i는 여기서 접근 불가
    }

    // 최적화 3: break를 통한 조기 종료
    {
        println!("✓ 최적화 3: 찾으면 즉시 탈출");

        for i in 1..=100 {
            if i == 50 {
                println!("  찾음: {}", i);
                break;  // 나머지 반복 스킵
            }
        }
    }

    println!();
}

// ============================================================================
// [6] 중첩 루프: 조심스럽게 다루기
// ============================================================================
//
// 중첩 루프는 복잡도가 기하급수적으로 증가합니다.
// 가능하면 피하고, 피할 수 없으면 최적화하세요.
//
fn nested_loops() {
    println!("[6] 중첩 루프");
    println!("────────────────────────────────────────────────────────────");

    // 기본 이중 루프
    {
        println!("✓ 이중 루프 (3×3 = 9번 실행):");
        for i in 1..=3 {
            for j in 1..=3 {
                print!("({},{})", i, j);
            }
        }
        println!();
    }

    // 최적화: 중첩 루프 최소화
    {
        println!("✓ 최적화: 대각선만 출력 (3번만 실행):");
        for i in 1..=3 {
            println!("  ({},{})", i, i);
        }
    }

    // 루프 라벨을 통한 외부 루프 제어
    {
        println!("✓ 루프 라벨 (외부 루프 탈출):");
        let mut found = false;

        'outer: for i in 1..=3 {
            for j in 1..=3 {
                if i == 2 && j == 2 {
                    println!("  ({},{}): 타겟 발견!", i, j);
                    found = true;
                    break 'outer;  // 외부 루프 탈출
                }
                print!("({},{})", i, j);
            }
        }
        println!();
    }

    println!();
}

// ============================================================================
// [7] break와 continue의 전략적 사용
// ============================================================================
//
// break: 루프 탈출
// continue: 현재 반복 스킵, 다음 반복으로
//
fn break_continue_strategy() {
    println!("[7] break와 continue 전략");
    println!("────────────────────────────────────────────────────────────");

    // break: 조건 만족 시 탈출
    {
        println!("✓ break (50 찾으면 탈출):");
        for i in 1..=100 {
            if i == 50 {
                println!("  찾음: {}", i);
                break;
            }
        }
    }

    // continue: 현재 반복 스킵
    {
        print!("✓ continue (홀수만 출력): ");
        for i in 1..=10 {
            if i % 2 == 0 {
                continue;  // 짝수는 스킵
            }
            print!("{} ", i);
        }
        println!();
    }

    // break와 continue 복합 사용
    {
        println!("✓ break + continue (복합 전략):");
        for i in 1..=20 {
            // 홀수만 처리
            if i % 2 == 0 {
                continue;
            }

            // 15 이상이면 탈출
            if i >= 15 {
                println!("  종료");
                break;
            }

            println!("  홀수: {}", i);
        }
    }

    println!();
}

// ============================================================================
// [8] 실전 패턴: 반복 시나리오
// ============================================================================
//
// 현실 세계의 반복 패턴을 구현합니다.
//
fn practical_iteration() {
    println!("[8] 실전 패턴");
    println!("────────────────────────────────────────────────────────────");

    // 패턴 1: 누적 (Accumulation)
    {
        let mut product = 1;
        for i in 1..=5 {
            product *= i;
        }
        println!("✓ 누적: 1! × 2! × 3! × 4! × 5! = {}", product);
    }

    // 패턴 2: 개수 세기
    {
        let mut count = 0;
        for i in 1..=20 {
            if i % 3 == 0 {
                count += 1;
            }
        }
        println!("✓ 개수: 1~20 중 3의 배수 = {}개", count);
    }

    // 패턴 3: 변환
    {
        println!("✓ 변환 (제곱):");
        for i in 1..=5 {
            println!("  {} → {}", i, i * i);
        }
    }

    // 패턴 4: 검색
    {
        println!("✓ 검색 (처음 찾은 3의 배수):");
        for i in 1..=20 {
            if i % 3 == 0 {
                println!("  찾음: {}", i);
                break;
            }
        }
    }

    println!();
}

// ============================================================================
// [9] 무결성 검증: v3.2 체크리스트
// ============================================================================
//
// v3.2 설계가 안전한지 검증합니다.
//
fn loop_integrity_check() {
    println!("[9] 무결성 검증");
    println!("────────────────────────────────────────────────────────────");

    // 검증 1: 루프의 삼요소
    {
        println!("✓ 검증 1: 루프의 삼요소");
        println!("  초기화: for i in 1..=5");
        println!("  조건: i가 1부터 5까지");
        println!("  변화: i는 자동으로 증가");

        for i in 1..=5 {
            println!("  i = {}", i);
        }
    }

    // 검증 2: while의 조건이 거짓이 될 수 있는가?
    {
        println!("✓ 검증 2: while 조건 수렴");
        let mut n = 16;

        while n > 0 {
            println!("  n = {}", n);
            n /= 2;  // 반드시 감소!
        }
        println!("  n = {} (루프 종료)", n);
    }

    // 검증 3: break가 명확한가?
    {
        println!("✓ 검증 3: 명확한 탈출 조건");
        let mut attempts = 0;
        let max_attempts = 3;

        loop {
            attempts += 1;
            if attempts >= max_attempts {
                println!("  최대 시도 도달 (탈출)");
                break;
            }
            println!("  시도 {}", attempts);
        }
    }

    println!();
}

