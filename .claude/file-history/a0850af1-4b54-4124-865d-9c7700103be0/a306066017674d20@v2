#[cfg(test)]
mod daemon_test {
    use super::*;

    #[test]
    fn demon_scenario_complete() {
        // 최악의 시나리오: Async + FFI + GC 동시 실행
        let executor = AsyncExecutor::new();

        println!("\n[악마 테스트] 유령 포인터 시나리오 복현 및 해결 검증");
        println!("────────────────────────────────────────────────────");

        // Step 1: 버퍼 생성 및 Handle 획득
        let buffer_id = 42u64;
        let original_ptr = 0x1000 as *mut u8;

        let handle = executor.execute_with_ffi(|handle_table| {
            let handle = handle_table.create_safe_handle(buffer_id, original_ptr);
            handle_table.pin_object(buffer_id);
            println!("✓ Step 1: Buffer 생성 + Handle 획득 + Pinning");
            Ok(())
        }).expect("Step 1 성공");

        // Step 2: GC 시뮬레이션 (메모리 이동)
        let new_ptr = 0x2000 as *mut u8;
        executor.gc_mark_and_sweep(&[buffer_id]);

        if let Ok(mut table) = executor.handle_table.lock() {
            table.on_gc_moved(original_ptr, new_ptr);
            println!("✓ Step 2: GC 실행 (메모리 0x{:X} → 0x{:X} 이동)", 0x1000, 0x2000);
        }

        // Step 3: Handle을 통한 안전한 접근 (새 주소)
        let result = executor.execute_with_ffi(|handle_table| {
            let deref = handle_table.dereference_safe(handle)?;
            assert_eq!(deref, new_ptr);
            println!("✓ Step 3: Handle 통해 새 주소(0x{:X})에서 안전하게 접근", 0x2000);
            Ok(())
        });

        assert!(result.is_ok(), "악마 테스트 완전 해결");
        println!("✓ Step 4: 최악의 시나리오 완전 격파 ✅");
        println!();
        println!("🏆 결론: 유령 포인터 문제는 안전하게 해결되었습니다");
    }
