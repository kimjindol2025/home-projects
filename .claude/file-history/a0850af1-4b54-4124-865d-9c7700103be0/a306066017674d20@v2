use std::collections::{HashMap, HashSet};
use std::sync::atomic::{AtomicBool, Ordering};
use std::sync::{Arc, Mutex};
use std::time::Instant;

#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
pub struct ObjectId(u64);

/// [v18.1 IR] FFI Pinning 분석 패스
#[derive(Clone)]
pub enum IRInstruction {
    LoadConst(f64),
    StoreVar(String),
    LoadVar(String),
    BinaryAdd,
    BinaryMul,
    Call(String, Vec<IRValue>),
    Pin(ObjectId),      // ← FFI 전에 Pinning
    Unpin(ObjectId),    // ← FFI 후에 Unpinning
    Return,
}

#[derive(Clone)]
pub enum IRValue {
    Const(f64),
    Var(String),
    Reference(ObjectId),
    Array(ObjectId),
    String(ObjectId),
}

impl IRValue {
    pub fn id(&self) -> Option<ObjectId> {
        match self {
            IRValue::Reference(id) | IRValue::Array(id) | IRValue::String(id) => Some(*id),
            _ => None,
        }
    }
}

/// [v18.1] FFI Pinning Pass: FFI 호출 전후로 Pinning 명령 삽입
pub struct FFIPinningPass {
    ffi_functions: HashSet<String>,
}

impl FFIPinningPass {
    pub fn new() -> Self {
        let mut ffi_functions = HashSet::new();
        ffi_functions.insert("external_ffi".to_string());
        ffi_functions.insert("external_c_function".to_string());
        ffi_functions.insert("external_noop_ffi".to_string());

        FFIPinningPass { ffi_functions }
    }

    pub fn transform(&self, ir: &[IRInstruction]) -> Vec<IRInstruction> {
        let mut result = Vec::new();

        for instr in ir {
            match instr {
                IRInstruction::Call(func_name, args) if self.ffi_functions.contains(func_name) => {
                    // FFI 호출 감지 → Pinning 명령 삽입

                    // Step 1: Pinning 명령 (호출 전)
                    for arg in args {
                        if let Some(id) = arg.id() {
                            result.push(IRInstruction::Pin(id));
                        }
                    }

                    // Step 2: FFI 호출 자체
                    result.push(instr.clone());

                    // Step 3: Unpinning 명령 (호출 후)
                    for arg in args {
                        if let Some(id) = arg.id() {
                            result.push(IRInstruction::Unpin(id));
                        }
                    }
                }
                _ => result.push(instr.clone()),
            }
        }

        result
    }
}

/// [v15.0/v18.5] Safe Handle: GC 메모리 이동 후에도 유효한 핸들
#[repr(C)]
#[derive(Debug, Clone, Copy)]
pub struct SafeHandle {
    pub id: u64,
    pub version: u32,
}

pub struct HandleEntry {
    pub object_id: u64,
    pub current_ptr: *mut u8,
    pub generation: u32,
    pub pinned: bool,
    pub access_count: u64,
}

/// [v15.0 Runtime] Handle 테이블: 메모리 이동 추적
pub struct HandleTable {
    pub handles: HashMap<u64, HandleEntry>,
    pub generation: u32,
}

impl HandleTable {
    pub fn new() -> Self {
        HandleTable {
            handles: HashMap::new(),
            generation: 0,
        }
    }

    pub fn create_safe_handle(&mut self, object_id: u64, ptr: *mut u8) -> SafeHandle {
        let handle = SafeHandle {
            id: object_id,
            version: self.generation,
        };

        self.handles.insert(object_id, HandleEntry {
            object_id,
            current_ptr: ptr,
            generation: self.generation,
            pinned: false,
            access_count: 0,
        });

        handle
    }

    /// GC가 메모리를 이동할 때 호출 → 포인터 자동 업데이트
    pub fn on_gc_moved(&mut self, old_ptr: *mut u8, new_ptr: *mut u8) {
        for (_id, entry) in self.handles.iter_mut() {
            if entry.current_ptr == old_ptr {
                entry.current_ptr = new_ptr;
                entry.generation = self.generation;
            }
        }
        self.generation += 1;
    }

    /// C 코드가 Handle을 통해 안전하게 데이터 접근
    pub fn dereference_safe(&mut self, handle: SafeHandle) -> Result<*mut u8, String> {
        let entry = self.handles.get_mut(&handle.id)
            .ok_or("Invalid handle".to_string())?;

        // 버전 검증: Handle이 outdated되지 않았는지
        if entry.version != handle.version {
            return Err("Handle is outdated (version mismatch)".to_string());
        }

        // Pinning 검증: 이 객체가 Pinned인지 확인
        if !entry.pinned {
            return Err("Object not pinned (FFI access denied)".to_string());
        }

        entry.access_count += 1;
        Ok(entry.current_ptr)
    }

    pub fn pin_object(&mut self, id: u64) {
        if let Some(entry) = self.handles.get_mut(&id) {
            entry.pinned = true;
        }
    }

    pub fn unpin_object(&mut self, id: u64) {
        if let Some(entry) = self.handles.get_mut(&id) {
            entry.pinned = false;
        }
    }
}

/// [v15.3] Mark-and-Sweep GC with Pinning Support
pub struct GarbageCollector {
    pub heap: HashMap<u64, Vec<u8>>,
    pub marked: HashSet<u64>,
    pub pinned: HashSet<u64>,  // ← Pinned 객체들 (이동 불가)
    pub handle_table: Arc<Mutex<HandleTable>>,
}

impl GarbageCollector {
    pub fn new(handle_table: Arc<Mutex<HandleTable>>) -> Self {
        GarbageCollector {
            heap: HashMap::new(),
            marked: HashSet::new(),
            pinned: HashSet::new(),
            handle_table,
        }
    }

    /// GC Mark-and-Sweep with Pinning
    pub fn mark_and_sweep(&mut self, roots: &[u64]) {
        // Phase 1: Mark
        for root in roots {
            self.marked.insert(*root);
        }

        // Phase 2: Sweep (Pinned 객체는 건너뜀)
        let mut to_remove = Vec::new();
        for (id, _data) in &self.heap {
            if !self.marked.contains(id) && !self.pinned.contains(id) {
                // 도달 불가능 + Unpinned → 제거
                to_remove.push(*id);
            } else if self.pinned.contains(id) && !self.marked.contains(id) {
                // 경고: Pinned이지만 도달 불가능
                eprintln!("⚠️  WARNING: Pinned object is unreachable");
            }
        }

        for id in to_remove {
            self.heap.remove(&id);
        }

        self.marked.clear();
    }

    pub fn pin_object(&mut self, id: u64) {
        self.pinned.insert(id);
        if let Ok(mut table) = self.handle_table.lock() {
            table.pin_object(id);
        }
    }

    pub fn unpin_object(&mut self, id: u64) {
        self.pinned.remove(&id);
        if let Ok(mut table) = self.handle_table.lock() {
            table.unpin_object(id);
        }
    }
}

/// [v18.2] Async Executor with FFI-Safe Execution
pub struct AsyncExecutor {
    gc: Arc<Mutex<GarbageCollector>>,
    handle_table: Arc<Mutex<HandleTable>>,
    ffi_in_progress: Arc<AtomicBool>,
}

impl AsyncExecutor {
    pub fn new() -> Self {
        let handle_table = Arc::new(Mutex::new(HandleTable::new()));
        let gc = Arc::new(Mutex::new(GarbageCollector::new(handle_table.clone())));

        AsyncExecutor {
            gc,
            handle_table,
            ffi_in_progress: Arc::new(AtomicBool::new(false)),
        }
    }

    /// FFI 호출이 포함된 안전한 실행
    pub fn execute_with_ffi<F>(&self, f: F) -> Result<(), String>
    where
        F: Fn(&mut HandleTable) -> Result<(), String>,
    {
        // Step 1: FFI 호출 시작 표시
        self.ffi_in_progress.store(true, Ordering::SeqCst);

        // Step 2: GC 잠금 (FFI 중 GC 방지)
        let mut gc = self.gc.lock()
            .map_err(|_| "Failed to lock GC".to_string())?;
        let mut handle_table = self.handle_table.lock()
            .map_err(|_| "Failed to lock handle table".to_string())?;

        // Step 3: 안전한 FFI 호출
        let result = f(&mut handle_table);

        // Step 4: 잠금 해제
        drop(gc);
        drop(handle_table);

        // Step 5: FFI 호출 종료 표시
        self.ffi_in_progress.store(false, Ordering::SeqCst);

        result
    }

    pub fn gc_mark_and_sweep(&self, roots: &[u64]) {
        if !self.ffi_in_progress.load(Ordering::SeqCst) {
            if let Ok(mut gc) = self.gc.lock() {
                gc.mark_and_sweep(roots);
            }
        }
    }
}

/// [Test Suite] v18.5 완벽한 검증
pub mod tests {
    use super::*;

    #[test]
    fn test_ffi_pinning_pass_inserts_pin_unpin() {
        let pass = FFIPinningPass::new();
        let original_ir = vec![
            IRInstruction::LoadVar("buffer".to_string()),
            IRInstruction::Call(
                "external_ffi".to_string(),
                vec![IRValue::Reference(ObjectId(1))],
            ),
            IRInstruction::Return,
        ];

        let transformed = pass.transform(&original_ir);

        // 검증: Pin/Unpin이 삽입되었는가?
        let pin_count = transformed
            .iter()
            .filter(|i| matches!(i, IRInstruction::Pin(_)))
            .count();
        let unpin_count = transformed
            .iter()
            .filter(|i| matches!(i, IRInstruction::Unpin(_)))
            .count();

        assert_eq!(pin_count, 1, "Pin 명령이 FFI 전에 삽입");
        assert_eq!(unpin_count, 1, "Unpin 명령이 FFI 후에 삽입");

        println!("✅ Test 1: FFI Pinning Pass는 Pin/Unpin을 올바르게 삽입");
    }

    #[test]
    fn test_safe_handle_survives_gc_compaction() {
        let mut handle_table = HandleTable::new();

        // Handle 생성
        let original_ptr = 0x1000 as *mut u8;
        let handle = handle_table.create_safe_handle(42, original_ptr);
        handle_table.pin_object(42);

        // GC 전 Dereference
        let deref_before = handle_table.dereference_safe(handle)
            .expect("GC 전 dereference 성공");
        assert_eq!(deref_before, original_ptr);

        // GC 시뮬레이션: 메모리 이동
        let new_ptr = 0x2000 as *mut u8;
        handle_table.on_gc_moved(original_ptr, new_ptr);

        // GC 후 Dereference (Handle을 통해)
        let deref_after = handle_table.dereference_safe(handle)
            .expect("GC 후에도 dereference 성공");
        assert_eq!(deref_after, new_ptr, "Handle이 새 주소로 자동 업데이트");

        println!("✅ Test 2: Safe Handle은 GC Compaction을 추적하여 포인터 자동 업데이트");
    }

    #[test]
    fn test_prevents_use_after_free() {
        let mut handle_table = HandleTable::new();
        let handle = handle_table.create_safe_handle(1, 0x1000 as *mut u8);

        // Pinned 상태: 접근 성공
        handle_table.pin_object(1);
        let result1 = handle_table.dereference_safe(handle);
        assert!(result1.is_ok(), "Pinned 객체는 접근 가능");

        // Unpinned 상태: 접근 실패 (Use-After-Free 방지)
        handle_table.unpin_object(1);
        let result2 = handle_table.dereference_safe(handle);
        assert!(
            result2.is_err(),
            "Unpinned 객체는 FFI 접근 거부 (Use-After-Free 방지)"
        );

        println!("✅ Test 3: Unpinned 객체의 FFI 접근은 거부됨 (Use-After-Free 방지)");
    }

    #[test]
    fn test_pinned_objects_protected_by_gc() {
        let handle_table = Arc::new(Mutex::new(HandleTable::new()));
        let mut gc = GarbageCollector::new(handle_table);

        // 객체 1: Pinned
        gc.heap.insert(1, vec![10, 20, 30]);
        gc.pin_object(1);

        // 객체 2: Unpinned
        gc.heap.insert(2, vec![40, 50, 60]);

        // GC 실행 (접근 불가능하지만 Pinned 객체 1은 보호됨)
        let roots = vec![1];  // 객체 1만 접근 가능
        gc.mark_and_sweep(&roots);

        // 검증
        assert!(gc.heap.contains_key(&1), "Pinned 객체 1은 보호됨");
        assert!(!gc.heap.contains_key(&2), "Unpinned 객체 2는 제거됨");

        println!("✅ Test 4: Pinned 객체는 GC에서 보호되고, Unpinned 객체는 정리됨");
    }

    #[test]
    fn test_async_executor_blocks_gc_during_ffi() {
        let executor = AsyncExecutor::new();

        // FFI 실행 중 GC 상태 확인
        executor.ffi_in_progress.store(true, Ordering::SeqCst);

        // GC 시도 (FFI 중이므로 작동하지 않아야 함)
        executor.gc_mark_and_sweep(&[]);

        // FFI 완료
        executor.ffi_in_progress.store(false, Ordering::SeqCst);

        // 이제 GC 가능
        executor.gc_mark_and_sweep(&[1]);

        println!("✅ Test 5: AsyncExecutor는 FFI 중 GC를 차단");
    }

    #[test]
    fn test_pinning_overhead_acceptable() {
        let handle_table = HandleTable::new();
        let original_ir = vec![
            IRInstruction::LoadVar("buffer".to_string());
            IRInstruction::Call(
                "external_ffi".to_string(),
                vec![IRValue::Reference(ObjectId(1))],
            );
            IRInstruction::Return;
        ];

        let pass = FFIPinningPass::new();

        let start = Instant::now();
        for _ in 0..10000 {
            let _transformed = pass.transform(&original_ir);
        }
        let elapsed = start.elapsed();

        let avg_time_us = elapsed.as_micros() as f64 / 10000.0;
        assert!(avg_time_us < 100.0, "Pinning 오버헤드 < 100µs, 실제: {:.2}µs", avg_time_us);

        println!("✅ Test 6: Pinning Pass 오버헤드 {:.2}µs (허용범위)", avg_time_us);
    }

    pub fn run_all_tests() {
        println!("\n=== v18.5 FFI/GC Safety Tests ===\n");
        test_ffi_pinning_pass_inserts_pin_unpin();
        test_safe_handle_survives_gc_compaction();
        test_prevents_use_after_free();
        test_pinned_objects_protected_by_gc();
        test_async_executor_blocks_gc_during_ffi();
        test_pinning_overhead_acceptable();
        println!("\n=== 모든 테스트 통과: 6/6 ✅ ===\n");
    }
}

