### ✅ 해결책 3: 명시적 getter/setter 메서드

```python
# ✅ 올바른 방법 3: 명시적 메서드
class DatabaseConnection:
    def __init__(self, connection_string):
        self._db_key = connection_string

    def get_db_key(self):
        """읽기"""
        return self._db_key

    def set_db_key(self, value):
        """쓰기 (검증 포함)"""
        if not value:
            raise ValueError("Empty connection string")
        self._db_key = value

class SecureDatabaseConnection(DatabaseConnection):
    def get_db_key(self):
        """오버라이드"""
        return super().get_db_key() + "_secure"

# 사용
conn = SecureDatabaseConnection("mongodb://localhost")
print(conn.get_db_key())  # "mongodb://localhost_secure"
conn.set_db_key("mongodb://remote")  # ✅ 유효성 검사
```

