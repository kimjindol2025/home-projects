### ✅ 해결책 1: bisect 모듈 사용 (표준 라이브러리)

```python
# ✅ 최선의 선택 (내장 모듈)
import bisect

class SortedDataSet:
    """bisect를 사용한 정렬 유지"""

    def __init__(self):
        self.data = []

    def add(self, value):
        """O(log n) 찾기 + O(n) 삽입 = O(n)"""
        position = bisect.bisect_left(self.data, value)
        self.data.insert(position, value)
        # 실제로는 O(n)이지만, 대부분의 경우 빠름

    def search(self, value):
        """O(log n) 이진 탐색"""
        position = bisect.bisect_left(self.data, value)
        if position < len(self.data) and self.data[position] == value:
            return position
        return -1

    def __contains__(self, value):
        return self.search(value) != -1

# 사용 예
ds = SortedDataSet()
for val in [5, 2, 8, 1, 9, 3]:
    ds.add(val)
    print(ds.data)  # 항상 정렬됨

# 결과:
# [5]
# [2, 5]
# [2, 5, 8]
# [1, 2, 5, 8]
# [1, 2, 5, 8, 9]
# [1, 2, 3, 5, 8, 9]
```

**코드 분석**:

```python
import bisect

values = [1, 3, 5, 7, 9]

# bisect_left: 같은 값이 있으면 왼쪽
bisect.bisect_left(values, 5)   # 2 (values[2] = 5)

# bisect_right: 같은 값이 있으면 오른쪽
bisect.bisect_right(values, 5)  # 3

# insert 활용
values.insert(bisect.bisect_left(values, 4), 4)
# [1, 3, 4, 5, 7, 9]
```

