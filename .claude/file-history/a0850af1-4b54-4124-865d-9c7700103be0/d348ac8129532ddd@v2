### ✅ 해결책 2: 직접 컨텍스트 매니저 구현

```python
# ✅ 올바른 코드 (방법 2: 클래스 기반)
class LogReader:
    """파일과 제너레이터를 동시에 관리"""

    def __init__(self, filename):
        self.filename = filename
        self.file = None

    def __enter__(self):
        self.file = open(self.filename, 'r')
        return self  # 자신을 반환

    def __exit__(self, exc_type, exc_val, exc_tb):
        if self.file:
            self.file.close()
        return False  # 예외 전파

    def __iter__(self):
        """제너레이터로 사용 가능"""
        for line in self.file:
            if 'ERROR' in line:
                yield line

# 사용법
with LogReader('huge.log') as reader:
    for line in reader:
        print(line)
    # with 블록 내에서만 순회 → 안전함
```

**분석**:
- `__enter__` / `__exit__` 메서드가 리소스 관리
- `__iter__` 메서드가 제너레이터 제공
- 리소스의 생명주기가 `with` 블록과 정확히 일치

