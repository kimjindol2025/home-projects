### ✅ 해결책 2: SortedList (타사 라이브러리)

```python
# ✅ 더 좋은 성능이 필요한 경우
from sortedcontainers import SortedList

# 설치: pip install sortedcontainers

class OptimizedDataSet:
    """SortedList를 사용한 고성능 정렬"""

    def __init__(self):
        self.data = SortedList()

    def add(self, value):
        """O(log n) 찾기 + O(1) 평균 삽입"""
        self.data.add(value)

    def search(self, value):
        """O(log n) 이진 탐색"""
        try:
            return self.data.index(value)
        except ValueError:
            return -1

# 성능 비교
import time

# 10,000개 값 추가
data_bisect = SortedDataSet()
data_sorted = OptimizedDataSet()

# bisect 방식
start = time.time()
for i in range(10000):
    data_bisect.add(i)
time_bisect = time.time() - start

# SortedList 방식
start = time.time()
for i in range(10000):
    data_sorted.add(i)
time_sorted = time.time() - start

print(f"bisect: {time_bisect:.2f}s")      # ~1.5초 (O(n²))
print(f"SortedList: {time_sorted:.2f}s")  # ~0.05초 (O(n log n))
