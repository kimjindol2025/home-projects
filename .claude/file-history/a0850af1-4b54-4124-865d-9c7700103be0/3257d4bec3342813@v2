# 🐳 v6.3: Docker 최적화 버전 (멀티스테이지 빌드)
# 프로덕션 환경을 위한 경량화된 이미지 생성

# ============= Stage 1: Builder 스테이지 =============
FROM python:3.11-slim as builder

# 작업 디렉토리 설정
WORKDIR /build

# 시스템 의존성 설치 (빌드용)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Python 의존성 설치 및 바이너리 생성
COPY requirements.txt .
RUN pip install --user --no-cache-dir -r requirements.txt


# ============= Stage 2: Runtime 스테이지 =============
FROM python:3.11-slim

# 보안: 비루트 사용자 생성
RUN useradd -m -u 1000 appuser

# 작업 디렉토리 설정
WORKDIR /app

# Builder 스테이지에서 설치된 패키지 복사
COPY --from=builder /root/.local /home/appuser/.local

# 애플리케이션 코드 복사
COPY --chown=appuser:appuser . .

# 환경 변수 설정
ENV PATH=/home/appuser/.local/bin:$PATH
ENV PYTHONUNBUFFERED=1
ENV FLASK_APP=app.py
ENV FLASK_ENV=production

# 비루트 사용자로 전환
USER appuser

# 헬스체크 추가
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health').read()" || exit 1

# 포트 노출
EXPOSE 8000

# 애플리케이션 시작
CMD ["gunicorn", "--bind", "0.0.0.0:8000", "--workers", "4", "--timeout", "120", "--access-logfile", "-", "app:app"]
