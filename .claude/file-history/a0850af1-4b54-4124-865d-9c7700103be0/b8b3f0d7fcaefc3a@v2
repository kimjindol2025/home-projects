// =============================================================================
// Demo 1: 기본 패턴 매칭 - 인자 개수에 따른 다양한 처리
// =============================================================================

macro_rules! gogs_say {
    // 패턴 1: 인자 없음
    () => {
        println!("[GOGS] 안녕하세요!");
    };

    // 패턴 2: 단일 메시지
    ($msg:expr) => {
        println!("[GOGS] 메시지: {}", $msg);
    };

    // 패턴 3: 메시지와 하나의 값
    ($msg:expr, $val:expr) => {
        println!("[GOGS] {} → {}", $msg, $val);
    };

    // 패턴 4: 메시지와 두 개의 값
    ($msg:expr, $val1:expr, $val2:expr) => {
        println!("[GOGS] {} = {} + {}", $msg, $val1, $val2);
    };
}

fn demo_basic_pattern_matching() {
    println!("\n=== Demo 1: 기본 패턴 매칭 ===");

    println!("  [패턴 1: 인자 없음]");
