#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_gogs_say_patterns() {
        // 패턴 1: 인자 없음
        gogs_say!();

        // 패턴 2: 단일 메시지
        gogs_say!("test message");

        // 패턴 3: 메시지 + 값
        gogs_say!("result", 42);

        // 패턴 4: 메시지 + 두 값
        gogs_say!("sum", 10, 20);
    }

    #[test]
    fn test_declare_macro() {
        declare!(test_var = 100);
        declare!(type TestType = String);
    }

    #[test]
    fn test_sum_macro() {
        assert_eq!(sum!(), 0);
        assert_eq!(sum!(5), 5);
        assert_eq!(sum!(1, 2, 3, 4, 5), 15);
        assert_eq!(sum!(10, 20, 30), 60);
    }

    #[test]
    fn test_vec_create_macro() {
        let v1 = vec_create!(1, 2, 3);
        assert_eq!(v1, vec![1, 2, 3]);

        let v2 = vec_create!("a", "b", "c");
        assert_eq!(v2, vec!["a", "b", "c"]);
    }

    #[test]
    fn test_count_items() {
        assert_eq!(count_items!(), 0);
        assert_eq!(count_items!(a), 1);
        assert_eq!(count_items!(a b c), 3);
        assert_eq!(count_items!(a b c d e f), 6);
    }

    #[test]
    fn test_gogs_log_levels() {
        gogs_log!(ERROR: "error message");
        gogs_log!(WARN: "warning message");
        gogs_log!(INFO: "info message");
        gogs_log!(DEBUG: "debug", value1, value2);
    }

    #[test]
    fn test_stringify_macro() {
        let s1 = stringify!(x);
        assert_eq!(s1, "x");

        let s2 = stringify!(2 + 2);
        assert_eq!(s2, "2 + 2");

        // stringify! 매크로는 토큰을 공백과 함께 출력
        let s3 = stringify!(Vec<String>);
        // "Vec < String >" 형태로 변환됨
        assert!(s3.contains("Vec"));
        assert!(s3.contains("String"));
    }

    #[test]
    fn test_query_dsl() {
        let _result = query!(
            SELECT id, name
            FROM table
            WHERE true
        );
    }

    #[test]
    fn test_config_dsl() {
        let _config = config! {
            key1: "value1",
            key2: 42,
        };
    }
}
