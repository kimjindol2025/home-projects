        host: "localhost",
        port: 8080,
        debug: true,
        timeout: 30,
    };

    println!("\n  [DSL의 강력함]");
    println!("    • 도메인 특화 문법");
    println!("    • 가독성 향상");
    println!("    • 컴파일 타임 검증");
}

