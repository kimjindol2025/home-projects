    println!("\n  [패턴 2: 메시지만]");
    gogs_say!("컴파일러 엔진 시작");

    println!("\n  [패턴 3: 메시지 + 값]");
    gogs_say!("메모리 주소", "0xAF12");

    println!("\n  [패턴 4: 메시지 + 두 값]");
    gogs_say!("합계", 10, 20);

    println!("\n  [메커니즘]");
    println!("    • 컴파일 시점에 패턴 매칭");
    println!("    • 각 패턴에 맞는 코드로 확장");
    println!("    • 런타임 오버헤드 0%");
}

// =============================================================================
// Demo 2: 지정자 활용 - 다양한 토큰 타입
// =============================================================================

macro_rules! declare {
    // 식별자 + 표현식
    ($name:ident = $val:expr) => {
        let $name = $val;
        println!("  변수 '{}' 선언: {:?}", stringify!($name), $name);
    };

    // 함수처럼 보이게
    (fn $name:ident() => $result:expr) => {
        fn $name() {
            println!("  함수 {}() 호출", stringify!($name));
            $result
        }
    };

    // 경로 타입
    (type $name:ident = $ty:ty) => {
        type $name = $ty;
        println!("  타입 별칭 '{}' 정의", stringify!($name));
    };
}

fn demo_designators() {
    println!("\n=== Demo 2: 지정자 활용 ===");

    println!("  [ident: 식별자]");
