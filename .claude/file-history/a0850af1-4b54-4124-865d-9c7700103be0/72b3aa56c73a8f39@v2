/// [문제 1] 모듈 설계 (v4.4: Modules)
///
/// 요구사항:
/// - mod security_unit 모듈 정의
/// - pub fn validate_admin(msg: &str) -> bool 함수 구현
/// - 메시지의 첫 5글자가 "ADMIN"인지 판별 (슬라이스 사용)
mod security_unit {
    /// 관리자 권한 검증 함수
    ///
    /// [v4.3 슬라이스 활용]
    /// - &str 타입: 문자열 슬라이스 (Fat Pointer: 포인터 + 길이)
    /// - msg[0..5]: 메시지의 첫 5글자만 추출
    /// - [..5]: 처음부터 5글자까지 (동일한 의미)
    ///
    /// [v4.2 참조]
    /// - &str 매개변수: 소유권을 받지 않고 빌려만 받음
    /// - 함수 호출 후 원본 데이터는 여전히 main에서 사용 가능
    pub fn validate_admin(msg: &str) -> bool {
        // [슬라이스를 사용한 정밀한 부분 참조]
        // msg.len() >= 5: 메시지가 5글자 이상인지 확인
        // &msg[0..5]: 첫 5글자 추출 (슬라이스 문법)
        // == "ADMIN": 추출한 부분과 "ADMIN" 문자열 리터럴 비교

        if msg.len() >= 5 {
            // [방법 1] [0..5]: 0번부터 4번까지 (5번 제외)
            &msg[0..5] == "ADMIN"
        } else {
            false
        }
    }

    /// [추가 함수] 보안 강도 분석
    ///
    /// [v4.2 불변 참조]
    /// - &str 매개변수로 메시지를 읽기만 함
    /// - 원본 수정 불가능 (컴파일 시점 보장)
    pub fn analyze_security_level(msg: &str) -> &'static str {
        let length = msg.len();

        if length < 5 {
            "약함"
        } else if length < 10 {
            "보통"
        } else if length < 20 {
            "강함"
        } else {
            "매우강함"
        }
    }
}

/// [문제 5번] 외부 크레이트 시뮬레이션 (v4.5)
///
/// 요구사항:
/// - rand 크레이트를 사용한다고 가정
/// - 0~100 사이의 난수를 생성하여 보안 점수 반환
/// - 실제 rand 크레이트 또는 의사 코드 가능
fn generate_security_score() -> u32 {
    // [v4.5 크레이트 통합]
    // 실제 구현:
    // use rand::Rng;
    // let mut rng = rand::thread_rng();
    // rng.gen_range(0..101)

    // [의사 코드] 간단한 계산을 통한 난수 유사값
    let seed = std::time::SystemTime::now()
        .duration_since(std::time::UNIX_EPOCH)
        .unwrap()
        .as_millis() as u32;

    (seed % 101) as u32
}

/// [메인 프로그램]
///
/// 설계 검증:
/// 1. String 생성 (main이 소유권 보유)
/// 2. 참조로 security_unit::validate_admin 호출
/// 3. 함수 호출 후에도 main에서 원본 메시지 재사용
/// 4. 보안 점수 생성 및 출력
/// 5. 조건부 실행 (true → 허가, false → 거부)
fn main() {
    println!("════════════════════════════════════════════════════════════");
    println!("  Phase 3 중간고사: 보안 통신 모듈 설계");
    println!("════════════════════════════════════════════════════════════");
    println!();

    // [문제 2번] 소유권과 참조 (v4.1, v4.2)
    //
    // [v4.1: 소유권]
    // - let message = String::from(...): main이 String 소유권 보유
    // - 메모리는 이 블록 끝에서 해제됨
    //
    // [v4.2: 참조]
    // - security_unit::validate_admin(&message): 참조로 전달
    // - 함수는 읽기만 하고 소유권은 변하지 않음

    println!("[1단계] 메시지 생성 (소유권 보유)");
    let message = String::from("ADMIN_USER_001");
    println!("  메시지: {}", message);
    println!("  길이: {} 글자", message.len());
    println!();

    // [문제 3번] 슬라이스와 부분 참조 (v4.3)
    //
    // security_unit::validate_admin(&message):
    // - &message: String → &str 자동 변환 (Deref coercion)
    // - 내부에서 msg[0..5]로 첫 5글자 추출
    // - Fat Pointer (포인터 + 길이)로 효율적 처리

    println!("[2단계] 관리자 권한 검증 (참조로 전달)");
    let is_admin = security_unit::validate_admin(&message);

    let first_five = &message[0..5];  // 슬라이스 직접 사용
    println!("  첫 5글자: '{}'", first_five);
    println!("  검증 결과: {}",
        if is_admin { "관리자 확인" } else { "일반 사용자" });
    println!();

    // [소유권 유지 증명]
    // validate_admin 호출 후에도 main에서 message 재사용 가능
    // 이것이 참조(&)의 힘: 소유권을 빌려주기만 함

    println!("[3단계] 원본 메시지 재사용 (소유권 유지)");
    println!("  메시지 여전히 유효: '{}'", message);

    let security_level = security_unit::analyze_security_level(&message);
    println!("  보안 강도: {}", security_level);
    println!();

    // [문제 4번] 외부 크레이트 시뮬레이션 (v4.5)
    //
    // generate_security_score(): rand 크레이트 대신 시스템 시간 사용
    // - v4.5의 의존성 관리 개념 적용
    // - 외부 도구 없이 기능 확장

    println!("[4단계] 보안 점수 생성 (v4.5 크레이트 시뮬레이션)");
    let security_score = generate_security_score();
    println!("  보안 점수: {} / 100", security_score);
    println!();

    // [문제 5번] 조건부 실행
    //
    // validate_admin 결과에 따라:
    // - true: 접속 허가 + 보안 점수 표시
    // - false: 접속 거부

    println!("[5단계] 최종 판정");
    if is_admin {
        println!("✅ 접속 허가 (관리자 권한 인증 완료)");
        println!("   점수: {} / 100", security_score);
        if security_score >= 80 {
            println!("   등급: 우수");
        } else if security_score >= 60 {
            println!("   등급: 정상");
        } else {
            println!("   등급: 주의");
        }
    } else {
        println!("❌ 접속 거부 (권한 없음)");
    }
    println!();

    // [문제 6번] 기록
    println!("════════════════════════════════════════════════════════════");
    println!("저장 필수 너는 기록이 증명이다 gogs");
    println!("════════════════════════════════════════════════════════════");
    println!();

    // [최종 검증 요약]
    println!("✓ 설계 검증 결과:");
    println!("  [v4.4] 모듈화: mod security_unit 정의 ✓");
    println!("  [v4.2] 참조: &str 매개변수 사용 ✓");
    println!("  [v4.3] 슬라이스: [0..5] 범위 문법 사용 ✓");
    println!("  [v4.1] 소유권: 함수 호출 후 메시지 재사용 ✓");
    println!("  [v4.5] 크레이트: 난수 생성 시뮬레이션 ✓");
    println!("  [통합] 조건부 실행: true/false 구분 ✓");
    println!();
    println!("✓ Phase 3 (v4.0~v4.5) 통합 마스터 인증 완료!");
}

