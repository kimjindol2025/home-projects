// ============================================================================
// [예제 1] 기본 열거형 정의와 사용
// ============================================================================
enum Direction {
    Up,
    Down,
    Left,
    Right,
}

enum Color {
    Red,
    Green,
    Blue,
    Black,
    White,
}

fn enum_basics() {
    println!(\"\\n[예제 1] 기본 열거형 정의와 사용\");
    println!(\"═════════════════════════════════════════\");

    // 열거자 선택
    let direction = Direction::Up;
    let color = Color::Red;

    // 패턴 매칭으로 처리
    match direction {
        Direction::Up => println!(\"↑ 위로 이동\"),
        Direction::Down => println!(\"↓ 아래로 이동\"),
        Direction::Left => println!(\"← 왼쪽으로 이동\"),
        Direction::Right => println!(\"→ 오른쪽으로 이동\"),
    }

    match color {
        Color::Red => println!(\"🔴 빨강\"),
        Color::Green => println!(\"🟢 초록\"),
        Color::Blue => println!(\"🔵 파랑\"),
        Color::Black => println!(\"⚫ 검정\"),
        Color::White => println!(\"⚪ 하양\"),
    }
}

// ============================================================================
// [예제 2] 연관 데이터를 가진 열거형
// ============================================================================
enum Message {
    Quit,
    Move { x: i32, y: i32 },
    Write(String),
    ChangeColor(u8, u8, u8),
}

fn associated_data() {
    println!(\"\\n[예제 2] 연관 데이터를 가진 열거형\");
    println!(\"═════════════════════════════════════════\");

    let messages = vec![
        Message::Quit,
        Message::Move { x: 10, y: 20 },
        Message::Write(\"Hello\".to_string()),
        Message::ChangeColor(255, 0, 128),
    ];

    for msg in messages {
        match msg {
            Message::Quit => println!(\"종료 메시지\"),
            Message::Move { x, y } => println!(\"이동: ({}, {})\", x, y),
            Message::Write(text) => println!(\"쓰기: {}\", text),
            Message::ChangeColor(r, g, b) => {
                println!(\"색 변경: RGB({}, {}, {})\", r, g, b)
            }
        }
    }
}

// ============================================================================
// [예제 3] 패턴 매칭
// ============================================================================
enum Status {
    Active,
    Inactive,
    Pending,
    Error(String),
}

fn pattern_matching() {
    println!(\"\\n[예제 3] 패턴 매칭\");
    println!(\"═════════════════════════════════════════\");

    let statuses = vec![
        Status::Active,
        Status::Inactive,
        Status::Pending,
        Status::Error(\"연결 실패\".to_string()),
    ];

    for status in statuses {
        // match: 모든 경우를 강제로 처리
        match status {
            Status::Active => println!(\"✓ 활성화됨\"),
            Status::Inactive => println!(\"○ 비활성화됨\"),
            Status::Pending => println!(\"⏳ 대기 중\"),
            Status::Error(msg) => println!(\"✗ 에러: {}\", msg),
        }
    }

    // matches! 매크로로 간단한 검사
    let status = Status::Active;
    if matches!(status, Status::Active) {
        println!(\"활성 상태입니다\");
    }
}

// ============================================================================
// [예제 4] Option<T> 사용
// ============================================================================
fn find_fruit(name: &str) -> Option<String> {
    let fruits = vec![\"사과\", \"바나나\", \"포도\"];
    if fruits.contains(&name) {
        Some(format!(\"찾음: {}\", name))
    } else {
        None
    }
}

fn option_enum() {
    println!(\"\\n[예제 4] Option<T> 사용\");
    println!(\"═════════════════════════════════════════\");

    // 패턴 매칭으로 처리
    println!(\"\\n[패턴 매칭]\");
    match find_fruit(\"사과\") {
        Some(result) => println!(\"{}\", result),
        None => println!(\"찾지 못함\"),
    }

    match find_fruit(\"귤\") {
        Some(result) => println!(\"{}\", result),
        None => println!(\"찾지 못함\"),
    }

    // unwrap(): None이면 panic
    println!(\"\\n[unwrap() 사용]\");
    let apple = find_fruit(\"사과\").unwrap();
    println!(\"{}\", apple);

    // unwrap_or(): 기본값 제공
    println!(\"\\n[unwrap_or() 사용]\");
    let result = find_fruit(\"귤\").unwrap_or(\"기본값\".to_string());
    println!(\"{}\", result);

    // is_some(), is_none()
    println!(\"\\n[is_some(), is_none() 사용]\");
    let option = find_fruit(\"포도\");
    if option.is_some() {
        println!(\"값이 있습니다\");
    }
    if option.is_none() == false {
        println!(\"값이 있습니다 (is_none의 반대)\");
    }
}

// ============================================================================
// [예제 5] Result<T, E> 사용
// ============================================================================
fn divide(a: i32, b: i32) -> Result<i32, String> {
    if b == 0 {
        Err(\"0으로 나눌 수 없습니다\".to_string())
    } else {
        Ok(a / b)
    }
}

fn parse_number(s: &str) -> Result<i32, String> {
    match s.parse::<i32>() {
        Ok(n) => {
            if n < 0 {
                Err(\"음수는 허용되지 않습니다\".to_string())
            } else {
                Ok(n)
            }
        }
        Err(_) => Err(\"숫자로 변환할 수 없습니다\".to_string()),
    }
}

fn result_enum() {
    println!(\"\\n[예제 5] Result<T, E> 사용\");
    println!(\"═════════════════════════════════════════\");

    // 패턴 매칭으로 성공/실패 처리
    println!(\"\\n[나누기 연산]\");
    match divide(10, 2) {
        Ok(result) => println!(\"10 ÷ 2 = {}\", result),
        Err(error) => println!(\"에러: {}\", error),
    }

    match divide(10, 0) {
        Ok(result) => println!(\"10 ÷ 0 = {}\", result),
        Err(error) => println!(\"에러: {}\", error),
    }

    // 숫자 파싱
    println!(\"\\n[숫자 파싱]\");
    match parse_number(\"42\") {
        Ok(n) => println!(\"파싱됨: {}\", n),
        Err(e) => println!(\"에러: {}\", e),
    }

    match parse_number(\"-5\") {
        Ok(n) => println!(\"파싱됨: {}\", n),
        Err(e) => println!(\"에러: {}\", e),
    }

    match parse_number(\"abc\") {
        Ok(n) => println!(\"파싱됨: {}\", n),
        Err(e) => println!(\"에러: {}\", e),
    }

    // unwrap_or(): 기본값
    println!(\"\\n[unwrap_or() 사용]\");
    let result = divide(10, 0).unwrap_or(-1);
    println!(\"결과: {}\", result);

    // is_ok(), is_err()
    println!(\"\\n[is_ok(), is_err() 사용]\");
    if divide(10, 2).is_ok() {
        println!(\"나누기 성공\");
    }
    if divide(10, 0).is_err() {
        println!(\"나누기 실패\");
    }
}

// ============================================================================
// [예제 6] 열거형에 메서드 추가
// ============================================================================
enum Size {
    Small,
    Medium,
    Large,
}

impl Size {
    fn description(&self) -> String {
        match self {
            Size::Small => \"작음\".to_string(),
            Size::Medium => \"중간\".to_string(),
            Size::Large => \"큼\".to_string(),
        }
    }

    fn to_inches(&self) -> u32 {
        match self {
            Size::Small => 5,
            Size::Medium => 10,
            Size::Large => 15,
        }
    }

    fn is_large(&self) -> bool {
        matches!(self, Size::Large)
    }
}

fn enum_with_methods() {
    println!(\"\\n[예제 6] 열거형에 메서드 추가\");
    println!(\"═════════════════════════════════════════\");

    let sizes = vec![Size::Small, Size::Medium, Size::Large];

    for size in sizes {
        println!(\"크기: {}\", size.description());
        println!(\"인치: {}\\\"\", size.to_inches());
        println!(\"매우 큼?: {}\", size.is_large());
        println!();
    }
}

// ============================================================================
// [예제 7] 상태 기계 패턴
// ============================================================================
enum TrafficLight {
    Red,
    Yellow,
    Green,
}

impl TrafficLight {
    fn next(&self) -> TrafficLight {
        match self {
            TrafficLight::Red => TrafficLight::Green,
            TrafficLight::Green => TrafficLight::Yellow,
            TrafficLight::Yellow => TrafficLight::Red,
        }
    }

    fn wait_seconds(&self) -> u32 {
        match self {
            TrafficLight::Red => 30,
            TrafficLight::Yellow => 5,
            TrafficLight::Green => 25,
        }
    }

    fn display(&self) {
        match self {
            TrafficLight::Red => println!(\"🔴 빨강 (정지)\"),
            TrafficLight::Yellow => println!(\"🟡 노랑 (주의)\"),
            TrafficLight::Green => println!(\"🟢 초록 (진행)\"),
        }
    }
}

fn state_machine() {
    println!(\"\\n[예제 7] 상태 기계 패턴\");
    println!(\"═════════════════════════════════════════\");

    println!(\"\\n[신호등 상태 전이]\");
    let mut light = TrafficLight::Red;

    for _ in 0..6 {
        light.display();
        println!(\"대기: {}초\", light.wait_seconds());
        light = light.next();
        println!();
    }
}

// ============================================================================
// [예제 8] 실제 예제 (Job 열거형)
// ============================================================================
enum Job {
    Developer { language: String, years: u32 },
    Designer { tool: String, style: String },
    Manager { team_size: u32 },
    Executive,
}

impl Job {
    fn title(&self) -> String {
        match self {
            Job::Developer { .. } => \"개발자\".to_string(),
            Job::Designer { .. } => \"디자이너\".to_string(),
            Job::Manager { .. } => \"매니저\".to_string(),
            Job::Executive => \"임원\".to_string(),
        }
    }

    fn describe(&self) -> String {
        match self {
            Job::Developer { language, years } => {
                format!(\"{}로 {}년 경력 개발자\", language, years)
            }
            Job::Designer { tool, style } => {
                format!(\"{}을 사용하는 {} 디자이너\", tool, style)
            }
            Job::Manager { team_size } => {
                format!(\"{}명 팀을 관리하는 매니저\", team_size)
            }
            Job::Executive => \"임원진 (전략 및 의사결정)\".to_string(),
        }
    }

    fn salary_range(&self) -> (u32, u32) {
        match self {
            Job::Developer { years, .. } => {
                let base = 40 + (years * 2);
                (base, base + 20)
            }
            Job::Designer { .. } => (35, 55),
            Job::Manager { team_size } => {
                let base = 50 + (team_size / 2);
                (base, base + 30)
            }
            Job::Executive => (100, 200),
        }
    }

    fn display(&self) {
        println!(\"직책: {}\", self.title());
        println!(\"설명: {}\", self.describe());

        let (min, max) = self.salary_range();
        println!(\"연봉: {}~{} 만원\", min, max);
    }
}

fn real_world_example() {
    println!(\"\\n[예제 8] 실제 예제 - 직무 정보\");
    println!(\"═════════════════════════════════════════\");

    let jobs = vec![
        Job::Developer {
            language: \"Rust\".to_string(),
            years: 5,
        },
        Job::Designer {
            tool: \"Figma\".to_string(),
            style: \"모더니즘\".to_string(),
        },
        Job::Manager { team_size: 10 },
        Job::Executive,
    ];

    for job in jobs {
        job.display();
        println!();
    }

    // if let으로 특정 경우만 처리
    println!(\"[개발자만 필터링]\");
    let job = Job::Developer {
        language: \"TypeScript\".to_string(),
        years: 3,
    };

    if let Job::Developer { language, years } = job {
        println!(\"개발 언어: {}, 경력: {}년\", language, years);
    }
}

