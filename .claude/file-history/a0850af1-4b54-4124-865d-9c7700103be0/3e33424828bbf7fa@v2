{% extends "base.html" %}

{% block title %}통계 - 학생관리 시스템{% endblock %}

{% block content %}
<div class="statistics-page">
    <h1 class="page-title">📈 학과 통계</h1>

    <div class="page-header">
        <p class="info-text">총 <strong>{{ stats|length }}</strong>개 학과의 통계 정보</p>
    </div>

    {% if stats %}
    <div class="stats-grid-large">
        {% for stat in stats %}
        <div class="stats-card-large">
            <div class="card-header">
                <h3>{{ stat.dept_name }}</h3>
            </div>

            <div class="card-body">
                <div class="stat-row">
                    <span class="stat-label">👥 총 학생 수</span>
                    <span class="stat-value">{{ stat.total_students }}명</span>
                </div>

                <div class="stat-row">
                    <span class="stat-label">📚 개설 과목 수</span>
                    <span class="stat-value">{{ stat.total_courses }}개</span>
                </div>

                <div class="stat-row">
                    <span class="stat-label">📊 평균 GPA</span>
                    <span class="stat-value">{{ stat.avg_gpa }}/100</span>
                </div>

                <!-- 시각화 바 -->
                <div class="progress-section">
                    <p class="progress-label">평균 GPA 진행 상황</p>
                    <div class="progress-bar">
                        {% set percentage = (stat.avg_gpa / 100) * 100 %}
                        <div class="progress-fill" style="width: {{ percentage }}%;">
                            {{ stat.avg_gpa }}%
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>

    <!-- 학과별 비교 -->
    <div class="comparison-section">
        <h2>🔍 학과별 비교</h2>

        <!-- 학생 수 비교 -->
        <div class="comparison-card">
            <h3>👥 학생 수 비교</h3>
            <div class="chart-container">
                {% for stat in stats %}
                <div class="chart-bar">
                    <p class="chart-label">{{ stat.dept_name }}</p>
                    <div class="bar-container">
                        <div class="bar" style="width: {% if stat.total_students > 0 %}{{ (stat.total_students / 3) * 100 }}%{% else %}0%{% endif %};">
                            {{ stat.total_students }}명
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>

        <!-- GPA 비교 -->
        <div class="comparison-card">
            <h3>📊 평균 GPA 비교</h3>
            <div class="chart-container">
                {% for stat in stats %}
                <div class="chart-bar">
                    <p class="chart-label">{{ stat.dept_name }}</p>
                    <div class="bar-container">
                        <div class="bar" style="width: {% if stat.avg_gpa > 0 %}{{ stat.avg_gpa }}%{% else %}0%{% endif %};">
                            {{ stat.avg_gpa }}
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>

    <!-- 종합 통계 -->
    <div class="summary-section">
        <h2>📌 종합 통계</h2>
        <div class="summary-grid">
            {% set total_students = 0 %}
            {% set total_courses = 0 %}
            {% set avg_gpa_sum = 0 %}

            {% for stat in stats %}
                {% set total_students = total_students + stat.total_students %}
                {% set total_courses = total_courses + stat.total_courses %}
                {% set avg_gpa_sum = avg_gpa_sum + stat.avg_gpa %}
            {% endfor %}

            <div class="summary-card">
                <p class="summary-label">전체 학생</p>
                <p class="summary-value">{{ total_students }}명</p>
                <p class="summary-note">{{ stats|length }}개 학과</p>
            </div>

            <div class="summary-card">
                <p class="summary-label">전체 과목</p>
                <p class="summary-value">{{ total_courses }}개</p>
                <p class="summary-note">평균 {{ (total_courses / stats|length)|round(1) }}개/학과</p>
            </div>

            <div class="summary-card">
                <p class="summary-label">전체 평균 GPA</p>
                <p class="summary-value">{{ (avg_gpa_sum / stats|length)|round(2) }}</p>
                <p class="summary-note">/100</p>
            </div>

            <div class="summary-card">
                <p class="summary-label">최고 GPA 학과</p>
                <p class="summary-value">
                    {% set max_gpa = stats|map(attribute='avg_gpa')|max %}
                    {% for stat in stats %}
                        {% if stat.avg_gpa == max_gpa %}
                            {{ stat.dept_name }}
                        {% endif %}
                    {% endfor %}
                </p>
                <p class="summary-note">{{ max_gpa }}/100</p>
            </div>
        </div>
    </div>

    {% else %}
    <div class="empty-state">
        <p>통계 정보가 없습니다.</p>
    </div>
    {% endif %}
</div>
{% endblock %}
