{% extends "base.html" %}

{% block title %}성적 - 학생관리 시스템{% endblock %}

{% block content %}
<div class="grades-page">
    <h1 class="page-title">📊 성적 현황</h1>

    <div class="page-header">
        <p class="info-text">총 <strong>{{ grades_data|length }}</strong>명의 학생 성적</p>
    </div>

    {% if grades_data %}
    <div class="grades-container">
        {% for item in grades_data %}
        <div class="student-grades-card">
            <div class="card-header">
                <h3>
                    {{ item.student.name }}
                    <span class="student-no">({{ item.student.student_no }})</span>
                </h3>
                <span class="dept-name">{{ item.student.dept_name }}</span>
            </div>

            <div class="card-body">
                {% if item.gpa %}
                <div class="gpa-info">
                    <div class="gpa-box">
                        <p class="gpa-label">평점</p>
                        <p class="gpa-value">{{ item.gpa.gpa }}</p>
                    </div>
                    <div class="gpa-box">
                        <p class="gpa-label">수강 과목</p>
                        <p class="gpa-value">{{ item.gpa.courses_taken }}개</p>
                    </div>
                </div>
                {% endif %}

                {% if item.grades %}
                <div class="grades-list">
                    <table class="mini-table">
                        <thead>
                            <tr>
                                <th>학기</th>
                                <th>과목</th>
                                <th>점수</th>
                                <th>등급</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for grade in item.grades %}
                            <tr>
                                <td>{{ grade.semester }}</td>
                                <td>{{ grade.course_name }}</td>
                                <td class="score">{{ grade.score|round(1) }}</td>
                                <td>
                                    <span class="grade-badge grade-{{ grade.grade }}">{{ grade.grade }}</span>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% endif %}
            </div>

            <div class="card-footer">
                <a href="/student/{{ item.student.student_id }}" class="btn-small btn-info">상세보기</a>
            </div>
        </div>
        {% endfor %}
    </div>

    <!-- 성적 통계 -->
    <div class="stats-section">
        <h2>📈 성적 통계</h2>
        <div class="stat-info">
            <div class="stat-item">
                <p class="label">평균 GPA</p>
                <p class="value">
                    {% set total_gpa = 0 %}
                    {% set count_gpa = 0 %}
                    {% for item in grades_data %}
                        {% if item.gpa %}
                            {% set total_gpa = total_gpa + item.gpa.gpa %}
                            {% set count_gpa = count_gpa + 1 %}
                        {% endif %}
                    {% endfor %}
                    {% if count_gpa > 0 %}
                        {{ (total_gpa / count_gpa)|round(2) }}
                    {% else %}
                        N/A
                    {% endif %}
                </p>
            </div>
        </div>
    </div>

    {% else %}
    <div class="empty-state">
        <p>등록된 성적이 없습니다.</p>
    </div>
    {% endif %}
</div>
{% endblock %}
