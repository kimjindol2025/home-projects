{% extends "base.html" %}

{% block title %}학생 추가 - 학생관리 시스템{% endblock %}

{% block content %}
<div class="add-student-page">
    <h1 class="page-title">➕ 새 학생 추가</h1>

    <div class="form-container">
        {% if error %}
        <div class="alert alert-error">
            <p>❌ {{ error }}</p>
        </div>
        {% endif %}

        <form method="POST" class="student-form">
            <div class="form-group">
                <label for="student_no">학번 *</label>
                <input
                    type="text"
                    id="student_no"
                    name="student_no"
                    placeholder="예: 2024001"
                    required
                    pattern="[0-9]{7}"
                    title="학번은 7자리 숫자입니다"
                >
                <p class="form-hint">7자리 숫자로 입력해주세요</p>
            </div>

            <div class="form-group">
                <label for="name">이름 *</label>
                <input
                    type="text"
                    id="name"
                    name="name"
                    placeholder="예: 김학생"
                    required
                >
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="dept_id">학과 *</label>
                    <select id="dept_id" name="dept_id" required>
                        <option value="">-- 학과 선택 --</option>
                        <option value="1">컴퓨터과학과</option>
                        <option value="2">데이터과학과</option>
                        <option value="3">소프트웨어공학과</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="year">학년 *</label>
                    <select id="year" name="year" required>
                        <option value="">-- 학년 선택 --</option>
                        <option value="1">1학년</option>
                        <option value="2">2학년</option>
                        <option value="3">3학년</option>
                        <option value="4">4학년</option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label for="email">이메일 *</label>
                <input
                    type="email"
                    id="email"
                    name="email"
                    placeholder="예: student@uni.ac.kr"
                    required
                >
            </div>

            <div class="form-group">
                <label for="phone">연락처 *</label>
                <input
                    type="tel"
                    id="phone"
                    name="phone"
                    placeholder="예: 010-0000-0000"
                    pattern="01[0-9]-[0-9]{3,4}-[0-9]{4}"
                    title="연락처 형식: 010-0000-0000"
                    required
                >
                <p class="form-hint">010-0000-0000 형식으로 입력해주세요</p>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary btn-large">✅ 학생 추가</button>
                <a href="/students" class="btn btn-secondary btn-large">취소</a>
            </div>
        </form>
    </div>

    <!-- 입력 예제 -->
    <div class="example-section">
        <h2>📝 입력 예제</h2>
        <div class="example-card">
            <p><strong>학번:</strong> 2024005</p>
            <p><strong>이름:</strong> 신학생</p>
            <p><strong>학과:</strong> 데이터과학과</p>
            <p><strong>학년:</strong> 1학년</p>
            <p><strong>이메일:</strong> shin.student@uni.ac.kr</p>
            <p><strong>연락처:</strong> 010-6666-6666</p>
        </div>
    </div>
</div>

<style>
    .add-student-page {
        max-width: 600px;
        margin: 0 auto;
    }

    .form-container {
        background: white;
        padding: 2rem;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        margin-bottom: 2rem;
    }

    .student-form {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .form-group label {
        font-weight: 600;
        color: #333;
    }

    .form-group input,
    .form-group select {
        padding: 0.75rem;
        border: 1px solid #ddd;
        border-radius: 4px;
        font-size: 1rem;
    }

    .form-group input:focus,
    .form-group select:focus {
        outline: none;
        border-color: #007bff;
        box-shadow: 0 0 0 3px rgba(0,123,255,0.1);
    }

    .form-hint {
        font-size: 0.875rem;
        color: #666;
    }

    .form-actions {
        display: flex;
        gap: 1rem;
        margin-top: 1rem;
    }

    .btn-large {
        padding: 0.75rem 2rem;
        font-size: 1rem;
    }

    .example-section {
        background: #f8f9fa;
        padding: 2rem;
        border-radius: 8px;
    }

    .example-section h2 {
        margin-top: 0;
    }

    .example-card {
        background: white;
        padding: 1.5rem;
        border-left: 4px solid #007bff;
        border-radius: 4px;
    }

    .example-card p {
        margin: 0.5rem 0;
        line-height: 1.6;
    }

    .alert {
        padding: 1rem;
        border-radius: 4px;
        margin-bottom: 1rem;
    }

    .alert-error {
        background: #fee;
        color: #c33;
        border: 1px solid #fcc;
    }
</style>
{% endblock %}
