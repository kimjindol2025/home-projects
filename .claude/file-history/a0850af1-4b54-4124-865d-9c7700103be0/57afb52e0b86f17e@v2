error_log = []

def log_error(func_name, error_type, message):
    """에러 정보를 로그에 기록"""
    error_log.append({
        "timestamp": datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        "function": func_name,
        "error_type": error_type,
        "message": message
    })

def logged_operation(a, b):
    try:
        result = a / b
        return result
    except ZeroDivisionError as e:
        log_error("logged_operation", "ZeroDivisionError", str(e))
        print(f"  [ERROR] 0으로 나눌 수 없습니다. (로그 기록됨)")
        return None
    except TypeError as e:
        log_error("logged_operation", "TypeError", str(e))
        print(f"  [ERROR] 타입 에러 (로그 기록됨)")
        return None

print("테스트: 여러 연산 수행 (에러 로깅)")
logged_operation(10, 2)
logged_operation(10, 0)  # 에러 발생
logged_operation(10, "hello")  # 에러 발생
logged_operation(100, 5)

print("\n기록된 에러 로그:")
for i, log in enumerate(error_log, 1):
    print(f"  [{i}] {log['timestamp']} | {log['function']} | {log['error_type']}")
    print(f"      메시지: {log['message']}")

