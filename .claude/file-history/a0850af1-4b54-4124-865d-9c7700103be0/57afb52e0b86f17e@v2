"""
Python High School v2.1 - 예외 처리(Exception Handling) — 에러를 다스리는 법

탐구(고등학교): "실패를 기록하고, 다시 일어서는 시스템"

중학교까지의 코드는 에러(Error)가 발생하면 그 즉시 멈춰버렸습니다.
하지만 고등 과정에서는 에러가 발생해도 시스템이 죽지 않게 보호하고,
무엇이 잘못되었는지 '기록'한 뒤 다음 단계로 넘어가는 법을 배웁니다.

이것이 바로 "견고한(Robust) 프로그램"의 특징입니다.

1. try-except 구조
   - try: "일단 이 코드를 실행해봐!"
   - except: "만약 에러가 나면 여기서 처리해!"
   - finally: "에러가 나든 안 나든, 마지막엔 무조건 이걸 실행해!"

2. 왜 고등 과정인가요?
   - 사용자의 잘못된 입력
   - 네트워크 단절
   - 파일 없음
   - 데이터베이스 연결 실패
   이런 예측 불가능한 상황에 대비해야 진짜 견고한 시스템이 됩니다.

3. 에러를 데이터로 관리
   - 어떤 에러가 발생했는지 기록
   - 언제 발생했는지 시간 기록
   - 어떻게 처리했는지 로그 기록
   이것이 대규모 시스템의 디버깅을 가능하게 합니다.
"""

from datetime import datetime

print("=" * 70)
print("# Python High School v2.1 - 예외 처리(Exception Handling)")
print("=" * 70)

# ============================================================================
# [1단계] try-except 기본 구조
# ============================================================================

print("\n[1단계] try-except 기본 구조")
print("-" * 70)

print("❌ 에러 처리 없는 코드 (프로그램 중단):")
print('  result = 10 / 0  # ZeroDivisionError 발생 → 프로그램 중단!')
print()

print("✅ 에러 처리가 있는 코드 (프로그램 계속):")
print("  try:")
print("      result = 10 / 0")
print("  except ZeroDivisionError:")
print("      print('0으로 나눌 수 없습니다!')")
print("      result = 0")
print()

try:
    result = 10 / 0
except ZeroDivisionError:
    print("✓ [ERROR] 0으로 나눌 수 없습니다!")
    result = 0

print(f"결과: {result} (프로그램이 계속 진행됩니다)")
print("\n설명:")
print("  ✓ 에러가 발생해도 프로그램이 멈추지 않습니다.")
print("  ✓ except 블록에서 안전하게 처리합니다.")

# ============================================================================
# [2단계] ZeroDivisionError 처리
# ============================================================================

print("\n[2단계] ZeroDivisionError 처리 - 0으로 나누기 방어")
print("-" * 70)

def safe_divide(a, b):
    try:
        print(f"  시도: {a} ÷ {b}")
        return a / b
    except ZeroDivisionError:
        print("  [ERROR] 0으로 나눌 수 없습니다. 기본값 0 반환")
        return 0

print("테스트:")
print(f"  10 ÷ 2 = {safe_divide(10, 2)}")
print(f"  10 ÷ 0 = {safe_divide(10, 0)}")
print(f"  100 ÷ 5 = {safe_divide(100, 5)}")

# ============================================================================
# [3단계] TypeError 처리
# ============================================================================

print("\n[3단계] TypeError 처리 - 잘못된 타입 입력")
print("-" * 70)

def safe_add(a, b):
    try:
        print(f"  시도: {a} + {b}")
        return a + b
    except TypeError:
        print(f"  [ERROR] {type(a).__name__}과 {type(b).__name__}은 더할 수 없습니다.")
        return None

print("테스트:")
print(f"  5 + 3 = {safe_add(5, 3)}")
print(f"  '안녕' + ' 세상' = {safe_add('안녕', ' 세상')}")
print(f"  5 + 'gogs' = {safe_add(5, 'gogs')}")

# ============================================================================
# [4단계] finally 블록 - 항상 실행
# ============================================================================

print("\n[4단계] finally 블록 - 에러 여부 상관없이 항상 실행")
print("-" * 70)

def operation_with_cleanup(value):
    try:
        print(f"  연산 시작: {value}")
        result = 100 / value
        print(f"  연산 성공: 100 / {value} = {result}")
        return result
    except ZeroDivisionError:
        print(f"  [ERROR] 0으로 나눌 수 없습니다.")
        return 0
    finally:
        print(f"  [CLEANUP] 연산 마무리 (에러 여부 상관없음)")

print("테스트 1: 정상 실행")
operation_with_cleanup(5)

print("\n테스트 2: 에러 발생")
operation_with_cleanup(0)

print("\n설명:")
print("  ✓ finally는 에러가 나든 안 나든 항상 실행됩니다.")
print("  ✓ 파일 닫기, 연결 해제 등 정리 작업에 사용됩니다.")

