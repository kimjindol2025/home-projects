print("\n[10단계] 예외 체이닝 - 예외의 원인 추적")
print("-" * 70)

def data_processing_chain(data):
    try:
        try:
            value = int(data)
        except ValueError as original_error:
            raise RuntimeError(f"데이터 처리 실패: {data}") from original_error
    except RuntimeError as e:
        print(f"  [ERROR] {e}")
        print(f"  [CAUSE] 원인: {e.__cause__}")

print("테스트: 잘못된 데이터 체이닝")
data_processing_chain("invalid_data")

print("\n설명:")
print("  ✓ raise ... from ...으로 원래 예외를 추적할 수 있습니다.")
print("  ✓ 디버깅 시 에러의 근본 원인을 알 수 있습니다.")

