print("\n[5단계] as e로 에러 메시지 캡처")
print("-" * 70)

def detailed_operation(a, b):
    try:
        result = a / b
        return result
    except ZeroDivisionError as e:
        print(f"  [ERROR] 에러 타입: {type(e).__name__}")
        print(f"  [ERROR] 에러 메시지: {str(e)}")
        return None
    except TypeError as e:
        print(f"  [ERROR] 타입 에러: {str(e)}")
        return None

print("테스트 1: 0으로 나누기")
detailed_operation(10, 0)

print("\n테스트 2: 타입 에러")
detailed_operation(10, "hello")

print("\n설명:")
print("  ✓ 'as e'로 에러 객체를 변수에 담을 수 있습니다.")
print("  ✓ str(e)로 에러 메시지를 문자열로 변환합니다.")
print("  ✓ type(e).__name__으로 에러의 정확한 타입을 알 수 있습니다.")

