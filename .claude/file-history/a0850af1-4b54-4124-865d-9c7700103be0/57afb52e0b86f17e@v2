def safe_int_input(value):
    try:
        num = int(value)
        print(f"  ✓ 입력값 '{value}'를 정수로 변환: {num}")
        return num
    except ValueError:
        print(f"  [ERROR] 입력값 '{value}'는 정수로 변환할 수 없습니다.")
        return 0

print("테스트:")
