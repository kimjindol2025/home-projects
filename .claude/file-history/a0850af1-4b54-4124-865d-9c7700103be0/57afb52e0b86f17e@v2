print("\n[9단계] 커스텀 예외 - raise로 에러 발생시키기")
print("-" * 70)

class InvalidAgeError(Exception):
    """나이가 유효하지 않을 때 발생하는 커스텀 예외"""
    pass

def register_user(name, age):
    try:
        if age < 0 or age > 150:
            raise InvalidAgeError(f"나이는 0~150 사이여야 합니다. 입력값: {age}")
        if not name:
            raise ValueError("이름은 공백일 수 없습니다.")

        print(f"  ✓ 사용자 등록 성공: {name} ({age}세)")
        return True
    except InvalidAgeError as e:
        print(f"  [CUSTOM ERROR] {e}")
        return False
    except ValueError as e:
        print(f"  [VALUE ERROR] {e}")
        return False

print("테스트 1: 유효한 등록")
register_user("Alice", 25)

print("\n테스트 2: 나이 범위 초과")
register_user("Bob", 200)

print("\n테스트 3: 빈 이름")
register_user("", 30)

print("\n설명:")
print("  ✓ Exception을 상속하여 커스텀 예외를 만들 수 있습니다.")
print("  ✓ raise로 명시적으로 예외를 발생시킵니다.")

