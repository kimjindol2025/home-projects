def safe_file_read(filename):
    try:
        with open(filename, "r", encoding="utf-8") as file:
            content = file.read()
            print(f"  ✓ '{filename}' 읽기 성공")
            return content
    except FileNotFoundError:
        print(f"  [ERROR] 파일 '{filename}'을 찾을 수 없습니다.")
        return None
    except IOError as e:
        print(f"  [ERROR] 파일 읽기 중 오류: {e}")
        return None

