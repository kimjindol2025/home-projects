print("\n[6단계] 여러 except 블록 - 여러 종류 에러 처리")
print("-" * 70)

def multi_error_handler(operation, a, b):
    try:
        if operation == "divide":
            return a / b
        elif operation == "index":
            numbers = [1, 2, 3]
            return numbers[a]
        elif operation == "dict":
            data = {"name": "Alice", "age": 20}
            return data[b]
    except ZeroDivisionError:
        print("  [ERROR] 0으로 나눌 수 없습니다.")
        return None
    except IndexError:
        print(f"  [ERROR] 리스트 인덱스 {a}는 범위를 벗어났습니다.")
        return None
    except KeyError:
        print(f"  [ERROR] 딕셔너리 키 '{b}'를 찾을 수 없습니다.")
        return None
    except Exception as e:
        print(f"  [ERROR] 예상하지 못한 에러: {type(e).__name__}")
        return None

print("테스트 1: 나누기 에러")
multi_error_handler("divide", 10, 0)

print("\nテスト 2: 리스트 범위 에러")
multi_error_handler("index", 10, 0)

print("\n테스트 3: 딕셔너리 키 에러")
multi_error_handler("dict", 0, "phone")

