## 📊 OpCode 정의

```rust
#[repr(u8)]
pub enum OpCode {
    // 상수
    OpConstant = 0x00,

    // 산술
    OpAdd = 0x01,
    OpSubtract = 0x02,
    OpMultiply = 0x03,
    OpDivide = 0x04,

    // 비교
    OpEqual = 0x05,
    OpNotEqual = 0x06,
    OpGreaterThan = 0x07,
    OpLessThan = 0x08,
    OpLessThanOrEqual = 0x09,
    OpGreaterThanOrEqual = 0x0A,

    // 논리
    OpNot = 0x0B,

    // 반환
    OpReturn = 0x0C,

    // 팝
    OpPop = 0x0D,
}
```

