use std::collections::HashMap;
use std::fmt;

// ============================================================================
// [1단계] SignalType 열거형 - 신호 상태 정의
// ============================================================================
#[derive(Clone)]
enum SignalType {
    Beacon,              // 정상 신호 🟢
    Data(String),        // 데이터 전송 📦
    Emergency(u8),       // 비상 신호 🔴 (심각도 0-10)
}

// Display 구현: 신호를 읽기 쉽게 출력
impl fmt::Display for SignalType {
    fn fmt(&self, f: &mut fmt::Formatter) -> fmt::Result {
        match self {
            SignalType::Beacon => write!(f, "🟢 정상 신호"),
            SignalType::Data(msg) => write!(f, "📦 데이터: {}", msg),
            SignalType::Emergency(level) => write!(f, "🔴 비상! (심각도: {})", level),
        }
    }
}

// ============================================================================
// [2단계] NodeID 뉴타입 - 의미론적 안전성 확보
// ============================================================================
// "같은 u32이지만 의미가 다르면 다른 타입이다"
struct NodeID(u32);

impl NodeID {
    fn new(id: u32) -> Self {
        NodeID(id)
    }

    fn value(&self) -> u32 {
        self.0
    }
}

impl fmt::Display for NodeID {
    fn fmt(&self, f: &mut fmt::Formatter) -> fmt::Result {
        write!(f, "Node#{}", self.0)
    }
}

impl Clone for NodeID {
    fn clone(&self) -> Self {
        NodeID(self.0)
    }
}

impl Copy for NodeID {}

impl PartialEq for NodeID {
    fn eq(&self, other: &Self) -> bool {
        self.0 == other.0
    }
}

impl Eq for NodeID {}

// ============================================================================
// [3단계] Node 구조체 - 은하 네트워크 노드
// ============================================================================
struct Node {
    id: NodeID,
    location: String,
    last_signal: SignalType,
}

impl Node {
    /// 새로운 노드 생성 (신호는 Beacon으로 초기화)
    fn new(id: NodeID, location: &str) -> Self {
        Self {
            id,
            location: String::from(location),
            last_signal: SignalType::Beacon,
        }
    }

    /// 신호 업데이트 (새로운 상태 반영)
    fn update_signal(&mut self, signal: SignalType) {
        self.last_signal = signal;
    }

    /// 노드 상태 보고 (패턴 매칭으로 안전하게 처리)
    fn report(&self) {
        println!("  ┌─ {} (위치: {})", self.id, self.location);
        match &self.last_signal {
            SignalType::Beacon => {
                println!("  └─ 신호: 🟢 정상 작동");
            }
            SignalType::Data(msg) => {
                println!("  └─ 신호: 📦 데이터 전송");
                println!("     └─ 내용: {}", msg);
            }
            SignalType::Emergency(level) => {
                println!("  └─ 신호: 🔴 비상! (심각도: {})", level);
            }
        }
    }

    /// 위험 수준 판정 (비상 신호 심각도 검사)
    fn is_critical(&self) -> bool {
        matches!(&self.last_signal, SignalType::Emergency(level) if *level > 7)
    }
}

// ============================================================================
// [4단계] GalaxyNetwork 구조체 - 전체 네트워크 관리
// ============================================================================
struct GalaxyNetwork {
    nodes: HashMap<u32, Node>,
}

impl GalaxyNetwork {
    /// 새로운 네트워크 생성
    fn new() -> Self {
        Self {
            nodes: HashMap::new(),
        }
    }

    /// 노드 추가
    fn add_node(&mut self, node: Node) {
        self.nodes.insert(node.id.value(), node);
    }

    /// 노드 조회 (읽기 전용)
    fn get_node(&self, id: u32) -> Option<&Node> {
        self.nodes.get(&id)
    }

    /// 노드 조회 (가변 참조)
    fn get_node_mut(&mut self, id: u32) -> Option<&mut Node> {
        self.nodes.get_mut(&id)
    }

    /// 모든 노드 나열
    fn list_all(&self) {
        println!("\n┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓");
        println!("┃ 🌌 은하 네트워크 현황 ({}개 노드) ┃", self.nodes.len());
        println!("┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛");
        for (_, node) in &self.nodes {
            node.report();
        }
    }

    /// 비상 상황 검사 (패턴 매칭으로 안전하게)
    fn handle_emergencies(&self) {
        println!("\n┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓");
        println!("┃ ⚠️  비상 상황 검사 ┃");
        println!("┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛");

        let mut has_emergency = false;

        for (_, node) in &self.nodes {
            // match로 모든 경우를 안전하게 처리
            match &node.last_signal {
                SignalType::Emergency(level) => {
                    has_emergency = true;
                    if *level > 7 {
                        println!("🚨 [위험] {}에서 심각한 비상 신호 발생! (심각도: {})", node.id, level);
                    } else if *level > 4 {
                        println!("⚠️  [경고] {}에서 비상 신호 발생 (심각도: {})", node.id, level);
                    } else {
                        println!("⚡ [정보] {}에서 비상 신호 발생 (심각도: {})", node.id, level);
                    }
                }
                _ => {
                    // Beacon이나 Data는 무시
                }
            }
        }

        if !has_emergency {
            println!("✓ 모든 노드가 안전합니다.");
        }
    }

    /// 데이터 신호 통계
    fn count_signals(&self) -> (usize, usize, usize) {
        let (mut beacons, mut data, mut emergencies) = (0, 0, 0);

        for (_, node) in &self.nodes {
            match &node.last_signal {
                SignalType::Beacon => beacons += 1,
                SignalType::Data(_) => data += 1,
                SignalType::Emergency(_) => emergencies += 1,
            }
        }

        (beacons, data, emergencies)
    }

    /// 네트워크 상태 요약
    fn summary(&self) {
        let (beacons, data, emergencies) = self.count_signals();
        println!("\n📊 네트워크 요약:");
        println!("  🟢 정상: {} | 📦 데이터: {} | 🔴 비상: {}", beacons, data, emergencies);
    }
}

// ============================================================================
// [5단계] Packet<T> 제네릭 구조체 - 범용 데이터 전송
// ============================================================================
struct Packet<T> {
    sender: NodeID,
    receiver: NodeID,
    data: T,
    priority: u8,
}

impl<T> Packet<T> {
    /// 새로운 패킷 생성
    fn new(sender: NodeID, receiver: NodeID, data: T) -> Self {
        Self {
            sender,
            receiver,
            data,
            priority: 5,
        }
    }

    /// 우선순위 설정
    fn with_priority(mut self, priority: u8) -> Self {
        self.priority = priority;
        self
    }

    /// 패킷의 발신자와 수신자 확인
    fn route_info(&self) {
        println!("  📨 패킷 경로: {} → {}", self.sender, self.receiver);
        println!("  ⭐ 우선순위: {}/10", self.priority);
    }
}

// T가 Display 가능할 때만 display_data 메서드 제공
impl<T: fmt::Display> Packet<T> {
    fn display_data(&self) {
        println!("  📄 데이터: {}", self.data);
    }
}

