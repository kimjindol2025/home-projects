## V. Convergence Test 구현

### 테스트 프로토콜

```rust
/// [v21.0] Ouroboros Convergence Integrity Test
pub struct ConvergenceTest {
    seed_binary: PathBuf,      // Compiler A (Rust)
    source_code: PathBuf,      // compiler.gogs
    work_dir: PathBuf,
}

impl ConvergenceTest {
    pub fn run(&self) -> Result<ConvergenceReport, TestError> {
        println!("🐍 Starting Ouroboros Convergence Test...\n");

        // Stage 1: Rust → Gen1
        let gen1_binary = self.stage_1()?;
        let hash1 = calculate_hash(&gen1_binary)?;
        println!("  [Stage 1] Rust compiler → Gen1");
        println!("  SHA256(Gen1): {}", hash1);

        // Stage 2: Gen1 → Gen2
        let gen2_binary = self.stage_2(&gen1_binary)?;
        let hash2 = calculate_hash(&gen2_binary)?;
        println!("  [Stage 2] Gen1 → Gen2");
        println!("  SHA256(Gen2): {}", hash2);

        // Stage 3: Gen2 → Gen3
        let gen3_binary = self.stage_3(&gen2_binary)?;
        let hash3 = calculate_hash(&gen3_binary)?;
        println!("  [Stage 3] Gen2 → Gen3");
        println!("  SHA256(Gen3): {}", hash3);

        // Convergence Check
        let converged = hash2 == hash3;

        let report = ConvergenceReport {
            stage1_hash: hash1,
            stage2_hash: hash2,
            stage3_hash: hash3,
            converged,
            non_determinism_sources: if !converged {
                self.analyze_non_determinism(&gen2_binary, &gen3_binary)?
            } else {
                Vec::new()
            },
        };

        self.print_result(&report);
        Ok(report)
    }

    fn stage_1(&self) -> Result<Vec<u8>, TestError> {
        // Rust 컴파일러로 compiler.gogs 컴파일
        let output = std::process::Command::new(&self.seed_binary)
            .arg(&self.source_code)
            .output()?;

        if !output.status.success() {
            return Err(TestError::CompilationFailed("Stage 1".to_string()));
        }

        Ok(output.stdout)
    }

    fn stage_2(&self, gen1_binary: &[u8]) -> Result<Vec<u8>, TestError> {
        // Gen1 컴파일러로 compiler.gogs 컴파일
        let gen1_path = self.work_dir.join("gen1_compiler");
        std::fs::write(&gen1_path, gen1_binary)?;

        let output = std::process::Command::new(&gen1_path)
            .arg(&self.source_code)
            .output()?;

        if !output.status.success() {
            return Err(TestError::CompilationFailed("Stage 2".to_string()));
        }

        Ok(output.stdout)
    }

    fn stage_3(&self, gen2_binary: &[u8]) -> Result<Vec<u8>, TestError> {
        // Gen2 컴파일러로 compiler.gogs 컴파일
        let gen2_path = self.work_dir.join("gen2_compiler");
        std::fs::write(&gen2_path, gen2_binary)?;

        let output = std::process::Command::new(&gen2_path)
            .arg(&self.source_code)
            .output()?;

        if !output.status.success() {
            return Err(TestError::CompilationFailed("Stage 3".to_string()));
        }

        Ok(output.stdout)
    }

    fn analyze_non_determinism(
        &self,
        gen2: &[u8],
        gen3: &[u8],
    ) -> Result<Vec<NonDeterminismSource>, TestError> {
        let mut sources = Vec::new();

        // 바이너리 비교
        for (i, (b2, b3)) in gen2.iter().zip(gen3.iter()).enumerate() {
            if b2 != b3 {
                // 어느 섹션에서 다른지 분석
                sources.push(self.classify_difference(i, b2, b3)?);
            }
        }

        Ok(sources)
    }

    fn classify_difference(
        &self,
        offset: usize,
        byte2: &u8,
        byte3: &u8,
    ) -> Result<NonDeterminismSource, TestError> {
        // 오프셋 범위로부터 비결정성 원인 추론
        match offset {
            0..100 => Ok(NonDeterminismSource::Header),
            100..1000 => Ok(NonDeterminismSource::SymbolTable),
            1000..10000 => Ok(NonDeterminismSource::CodeSection),
            _ => Ok(NonDeterminismSource::Unknown),
        }
    }

    fn print_result(&self, report: &ConvergenceReport) {
        println!("\n╔════════════════════════════════════════════════╗");
        if report.converged {
            println!("║  ✅ CONVERGENCE ACHIEVED                       ║");
            println!("║  Gogs-Lang is now deterministically identical  ║");
            println!("║  무한히 반복해도 비트 단위로 완벽함            ║");
        } else {
            println!("║  ❌ CONVERGENCE FAILED                         ║");
            println!("║  Non-determinism detected in:                  ║");
            for source in &report.non_determinism_sources {
                println!("║    - {:?}", source);
            }
        }
        println!("╚════════════════════════════════════════════════╝");
    }
}

pub struct ConvergenceReport {
    pub stage1_hash: String,
    pub stage2_hash: String,
    pub stage3_hash: String,
    pub converged: bool,
    pub non_determinism_sources: Vec<NonDeterminismSource>,
}

#[derive(Debug)]
pub enum NonDeterminismSource {
    Header,
    SymbolTable,
    CodeSection,
    Unknown,
}

#[derive(Debug)]
pub enum TestError {
    CompilationFailed(String),
    IoError(std::io::Error),
    HashError(String),
}
```

