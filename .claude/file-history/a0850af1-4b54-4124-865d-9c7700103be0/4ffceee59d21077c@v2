// ❌ 문제 코드
pub fn save_environment(env: &HashMap<String, Value>) -> Vec<u8> {
    let mut bytecode = Vec::new();
    for (key, value) in env.iter() {
        // HashMap의 순회 순서는 임의!
        bytecode.push_entry(key, value);
    }
    bytecode
}

// ✅ 해결책: BTreeMap 또는 정렬
pub fn save_environment_deterministic(env: &HashMap<String, Value>) -> Vec<u8> {
    let mut bytecode = Vec::new();
    let mut sorted_keys: Vec<_> = env.keys().collect();
    sorted_keys.sort();  // 정렬 필수!

    for key in sorted_keys {
        bytecode.push_entry(key, &env[key]);
    }
    bytecode
}
```

