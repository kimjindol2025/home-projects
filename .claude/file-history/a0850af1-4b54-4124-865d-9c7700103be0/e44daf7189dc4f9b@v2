/// [구조체 예제 1] 내부에 참조자를 보유하는 구조체
struct Message<'a> {
    content: &'a str,
    priority: u8,
}

impl<'a> Message<'a> {
    /// [메서드 1] 메시지 생성
    fn new(content: &'a str, priority: u8) -> Self {
        Self { content, priority }
    }

    /// [메서드 2] 메시지 내용 반환
    /// 반환값의 수명이 self의 수명을 따름
    fn get_content(&self) -> &'a str {
        self.content
    }

    /// [메서드 3] 두 메시지의 길이 비교
    fn is_longer_than(&self, other: &Message<'a>) -> bool {
        self.content.len() > other.content.len()
    }

    /// [메서드 4] 메시지를 보기 좋게 표시
    fn display(&self) {
        let priority_mark = match self.priority {
            1..=3 => "🟢 낮음",
            4..=6 => "🟡 중간",
            7..=10 => "🔴 높음",
            _ => "❓ 미정의",
        };

        println!("[{}] {}", priority_mark, self.content);
    }
}

/// [구조체 예제 2] 여러 참조자를 보유하는 구조체
struct MessagePair<'a, 'b> {
    first: &'a str,
    second: &'b str,
}

impl<'a, 'b> MessagePair<'a, 'b> {
    fn new(first: &'a str, second: &'b str) -> Self {
        Self { first, second }
    }

    /// [메서드] 두 메시지 중 더 짧은 것 반환
    /// 반환값의 수명은 더 짧은 쪽을 따름
    fn shorter(&self) -> &str {
        if self.first.len() < self.second.len() {
            self.first
        } else {
            self.second
        }
    }

    /// [메서드] 두 메시지를 연결한 길이
    fn total_length(&self) -> usize {
        self.first.len() + self.second.len()
    }
}

// ============================================================================
// [Step 5] 정적 수명 (Static Lifetime)
// ============================================================================

/// [특수한 수명] 'static: 프로그램의 전 생명 주기 동안 유효
fn longest_static<'a>(x: &'a str, y: &'static str) -> &'a str {
    // y는 프로그램 전체 동안 존재
    // x는 'a 동안만 존재
    // 반환값은 x의 수명을 따름

    if x.len() > y.len() {
        x
    } else {
        y  // 이것도 'a 동안 유효 (y가 더 오래 살아있으니까)
    }
}

