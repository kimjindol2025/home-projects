// ============================================================================
// [Step 3] 다중 참조자의 수명 (수명 명시 필수)
// ============================================================================

/// [핵심: 최장 생존 메시지 추적기]
///
/// <'a>: 수명 매개변수
/// x: &'a str: x는 'a 동안 유효한 &str
/// y: &'a str: y는 'a 동안 유효한 &str
/// -> &'a str: 반환값도 'a 동안 유효하며, 입력 중 더 짧게 사는 것을 따름
fn longest<'a>(x: &'a str, y: &'a str) -> &'a str {
    if x.len() > y.len() {
        x
    } else {
        y
    }
}

/// [다중 수명] 입력과 출력의 수명이 다른 경우
fn longest_with_announcement<'a, 'b>(x: &'a str, y: &'b str) -> &'a str
where
    'b: 'a,  // 'b가 'a보다 같거나 오래 산다는 조건
{
    println!("공지: 두 메시지를 비교합니다.");

    // 반드시 'a의 수명을 따르는 값을 반환해야 함
    if x.len() > y.len() {
        x
    } else {
        x  // y는 'b의 수명이므로 직접 반환 불가
    }
}

