// ============================================================================
// [Step 1] 단일 참조자의 수명 (가장 간단한 경우)
// ============================================================================

/// [기본 예제 1] 수명 명시 없어도 동작 (생략 규칙)
/// 입력이 1개의 참조자만 있으므로 반환값의 수명이 명확함
fn first_word(s: &str) -> &str {
    // 컴파일러가 자동으로 해석:
    // fn first_word<'a>(s: &'a str) -> &'a str
    let bytes = s.as_bytes();

    for (i, &item) in bytes.iter().enumerate() {
        if item == b' ' {
            return &s[0..i];
        }
    }

    &s[..]
}

