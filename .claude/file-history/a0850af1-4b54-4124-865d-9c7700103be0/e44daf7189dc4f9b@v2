/// [문서 구조]
struct Document<'a> {
    title: &'a str,
    content: &'a str,
    author: &'a str,
}

impl<'a> Document<'a> {
    fn new(title: &'a str, content: &'a str, author: &'a str) -> Self {
        Self {
            title,
            content,
            author,
        }
    }

    /// [메서드 1] 문서 요약
    fn summary(&self) -> String {
        format!(
            "문서: '{}' (저자: {}) - {}자",
            self.title,
            self.author,
            self.content.len()
        )
    }

    /// [메서드 2] 처음 100자 미리보기
    fn preview(&self) -> &'a str {
        if self.content.len() > 100 {
            &self.content[0..100]
        } else {
            self.content
        }
    }

    /// [메서드 3] 두 문서 중 더 긴 것
    fn longer_than<'b>(&'a self, other: &Document<'b>) -> &'a str
    where
        'b: 'a,
    {
        if self.content.len() > other.content.len() {
            self.content
        } else {
            other.content
        }
    }
}

