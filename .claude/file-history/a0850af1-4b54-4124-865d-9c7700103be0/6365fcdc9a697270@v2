let product = 2 * 3;
```

### Phase 2 (v3.0)
```rust
// 조건
if x > 0 { } else { }

// 매칭
match x {
    1 => { },
    _ => { },
}

// 반복
for i in 1..10 { }
while x > 0 { }
```

### Phase 3 (v4.0)
```rust
// 함수
fn add(a: i32, b: i32) -> i32 {
    a + b
}

// 모듈
mod math {
    pub fn calculate() { }
}
```

### Phase 4 (v5.0)
```rust
// 구조체
struct Point {
    x: i32,
    y: i32,
}

// 제네릭
fn first<T>(arr: &[T]) -> Option<T> {
    if arr.len() > 0 {
        Some(arr[0])
    } else {
        None
    }
}
```

