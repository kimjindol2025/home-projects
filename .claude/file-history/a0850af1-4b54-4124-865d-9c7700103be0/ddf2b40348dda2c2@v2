## ⚠️ Undefined Behavior (UB) - 반드시 피해야 할 것들

```rust
unsafe {
    // ❌ UB 1: Null 역참조
    let null_ptr: *const i32 = std::ptr::null();
    println!("{}", *null_ptr);  // CRASH!

    // ❌ UB 2: 대역 외(Out-of-bounds) 접근
    let arr = [1, 2, 3];
    let ptr = &arr[0] as *const i32;
    println!("{}", *ptr.add(100));  // CRASH!

    // ❌ UB 3: Use-After-Free
    let ptr = Box::into_raw(Box::new(42));
    Box::from_raw(ptr);  // Box 해제
    println!("{}", *ptr);  // CRASH! (메모리 반환됨)

    // ❌ UB 4: 잘못된 정렬
    let bytes = [1u8, 2u3, 4];
    let ptr = &bytes[1] as *const u8;
    let ptr_u32 = ptr as *const u32;
    println!("{}", *ptr_u32);  // CRASH! (정렬 위반)

    // ❌ UB 5: Data Race (스레드 간)
    // 여러 스레드가 동시에 같은 메모리 수정

    // ❌ UB 6: 초기화되지 않은 메모리
    let x: i32 = std::mem::uninitialized();
    println!("{}", x);  // 미정의 값!
}
```

