# 인덱스 생성
cursor.execute("CREATE INDEX idx_email ON users(email)")

# 인덱스로 검색
start = time.perf_counter()
cursor.execute("SELECT * FROM users WHERE email = 'user500@example.com'")
result = cursor.fetchone()
elapsed_with_index = time.perf_counter() - start
print(f"  인덱스로 검색:  {elapsed_with_index*1000:.3f}ms")

speedup = elapsed_no_index / max(elapsed_with_index, 0.0001)
print(f"  속도 향상: {speedup:.1f}배")
print()

