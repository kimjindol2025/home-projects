def transfer_money(from_id: int, to_id: int, amount: int, force_error: bool = False):
    """트랜잭션을 사용한 안전한 송금"""
    try:
        print(f"  💸 {amount}원 송금 시도 ({from_id} → {to_id})")

        # 보내는 사람 잔액 감소
        cursor.execute(
            "UPDATE accounts SET balance = balance - ? WHERE id = ?",
            (amount, from_id)
        )
        print(f"     📤 발신자 잔액 감소")

        # 의도적 오류 시뮬레이션
        if force_error:
            raise Exception("네트워크 연결 끊김!")

        # 받는 사람 잔액 증가
        cursor.execute(
            "UPDATE accounts SET balance = balance + ? WHERE id = ?",
            (amount, to_id)
        )
        print(f"     📥 수신자 잔액 증가")

        # 모든 작업이 성공했으므로 커밋 (확정)
        db.commit()
        print(f"  ✅ 송금 성공 및 저장 완료")

    except Exception as e:
        # 하나라도 실패하면 롤백 (취소)
        db.rollback()
        print(f"  ❌ 오류 발생: {e}")
        print(f"     모든 변경사항 취소됨 (Rollback)")

print("  시나리오 1: 정상 송금")
cursor.execute("DELETE FROM accounts")
cursor.execute("INSERT INTO accounts VALUES (1, '설계자', 10000)")
cursor.execute("INSERT INTO accounts VALUES (2, '친구', 5000)")
db.commit()

transfer_money(1, 2, 3000)

