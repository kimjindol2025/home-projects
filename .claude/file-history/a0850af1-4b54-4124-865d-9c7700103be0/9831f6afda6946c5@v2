@dataclass
class DatabaseSystem:
    """프로덕션급 데이터베이스 시스템"""
    tables: int = 0
    records: int = 0
    indexes: int = 0
    backup_count: int = 0

    def add_table(self, name):
        self.tables += 1
        print(f"  📊 테이블 추가: {name}")

    def add_records(self, count):
        self.records += count
        print(f"  📝 레코드 {count}개 삽입")

    def create_index(self, name):
        self.indexes += 1
        print(f"  🔍 인덱스 생성: {name}")

    def backup(self):
        self.backup_count += 1
        print(f"  💾 백업 #{self.backup_count}")

    def status(self):
        print(f"\n  📈 시스템 현황:")
        print(f"     테이블: {self.tables}개")
        print(f"     레코드: {self.records:,}개")
        print(f"     인덱스: {self.indexes}개")
        print(f"     백업: {self.backup_count}회")

system = DatabaseSystem()
system.add_table("users")
system.add_table("orders")
system.add_table("products")
system.add_records(10000)
system.create_index("idx_user_email")
system.create_index("idx_order_date")
system.backup()
system.backup()
system.status()

