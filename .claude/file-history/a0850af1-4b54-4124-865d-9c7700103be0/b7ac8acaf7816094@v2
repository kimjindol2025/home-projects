// ============================================================================
// [프로젝트 1] 범용 봉투: GogsEnvelope<T>
// ============================================================================
struct GogsEnvelope<T> {
    id: u32,
    data: T,
}

impl<T> GogsEnvelope<T> {
    fn wrap(id: u32, data: T) -> Self {
        Self { id, data }
    }

    fn peek(&self) -> &T {
        &self.data
    }

    fn unwrap(self) -> T {
        self.data
    }

    fn id(&self) -> u32 {
        self.id
    }
}

// Clone 가능한 T에만 제공
impl<T: Clone> GogsEnvelope<T> {
    fn clone_data(&self) -> T {
        self.data.clone()
    }

    fn duplicate(&self) -> Self {
        Self {
            id: self.id,
            data: self.data.clone(),
        }
    }
}

// Display 가능한 T에만 제공
impl<T: Display> GogsEnvelope<T> {
    fn display_info(&self) {
        println!("  [봉투 #{}] 데이터: {}", self.id, self.data);
    }
}

// i32에만 특별 메서드
impl GogsEnvelope<i32> {
    fn increment(&mut self) {
        self.data += 1;
    }

    fn multiply(&mut self, factor: i32) {
        self.data *= factor;
    }
}

fn generic_envelope() {
    println!("\n[프로젝트 1] 범용 봉투 (GogsEnvelope<T>)");
    println!("═════════════════════════════════════════");

    println!("\n[정수 봉투]");
    let mut int_env = GogsEnvelope::wrap(1, 1024);
    println!("  생성: #{} → {}", int_env.id(), int_env.peek());
    int_env.increment();
    println!("  증가: #{} → {}", int_env.id(), int_env.peek());
    int_env.multiply(2);
    println!("  곱셈: #{} → {}", int_env.id(), int_env.peek());

    println!("\n[문자열 봉투]");
    let str_env = GogsEnvelope::wrap(2, String::from("보안 프로토콜"));
    str_env.display_info();

    println!("\n[벡터 봉투]");
    let vec_env = GogsEnvelope::wrap(3, vec![10, 20, 30, 40]);
    println!("  생성: #{} → {:?}", vec_env.id(), vec_env.peek());

    println!("\n[복합 타입 봉투]");
    let opt_env = GogsEnvelope::wrap(4, Some(99));
    println!("  생성: #{} → {:?}", opt_env.id(), opt_env.peek());

    println!("\n[복제 기능]");
    let env = GogsEnvelope::wrap(5, String::from("데이터"));
    let env_dup = env.duplicate();
    println!("  원본: #{} → {}", env.id(), env.peek());
    println!("  복제: #{} → {}", env_dup.id(), env_dup.peek());

    println!("\n✓ 설계: 하나의 GogsEnvelope<T>로 모든 타입 수용");
    println!("✓ 유연성: Display, Clone 조건에 따라 다른 메서드 제공");
    println!("✓ 특화: i32에만 increment, multiply 메서드");
}

// ============================================================================
// [프로젝트 2] 범용 저장소: Repository<T>
// ============================================================================
struct Repository<T> {
    items: Vec<T>,
    name: String,
}

impl<T> Repository<T> {
    fn new(name: &str) -> Self {
        Self {
            items: Vec::new(),
            name: String::from(name),
        }
    }

    fn add(&mut self, item: T) {
        self.items.push(item);
    }

    fn count(&self) -> usize {
        self.items.len()
    }

    fn is_empty(&self) -> bool {
        self.items.is_empty()
    }
}

// Clone 가능한 T에만 제공
impl<T: Clone> Repository<T> {
    fn get_all(&self) -> Vec<T> {
        self.items.clone()
    }

    fn get(&self, index: usize) -> Option<T> {
        self.items.get(index).cloned()
    }
}

// Display 가능한 T에만 제공
impl<T: Display> Repository<T> {
    fn list_all(&self) {
        println!(">>> {} ({}개) <<<", self.name, self.count());
        for (idx, item) in self.items.iter().enumerate() {
            println!("  [{}] {}", idx, item);
        }
    }
}

fn generic_storage() {
    println!("\n[프로젝트 2] 범용 저장소 (Repository<T>)");
    println!("═════════════════════════════════════════");

    println!("\n[정수 저장소]");
    let mut repo_int: Repository<i32> = Repository::new("정수 저장소");
    repo_int.add(10);
    repo_int.add(20);
    repo_int.add(30);
    repo_int.list_all();
    println!("  총 개수: {}", repo_int.count());

    println!("\n[문자열 저장소]");
    let mut repo_str: Repository<String> = Repository::new("문자열 저장소");
    repo_str.add("보안".to_string());
    repo_str.add("로그".to_string());
    repo_str.add("프로토콜".to_string());
    repo_str.list_all();

    println!("\n[부동소수점 저장소]");
    let mut repo_float: Repository<f64> = Repository::new("센서 데이터");
    repo_float.add(3.14);
    repo_float.add(2.71);
    repo_float.add(1.41);
    repo_float.list_all();

    println!("\n[복제 기능]");
    let items = repo_int.get_all();
    println!("  모든 항목: {:?}", items);
    if let Some(first) = repo_int.get(0) {
        println!("  첫 번째: {}", first);
    }

    println!("\n✓ 설계: Repository<T>로 모든 타입의 저장소 구현");
    println!("✓ 조건: Clone 가능하면 get_all, Display 가능하면 list_all");
}

// ============================================================================
// [프로젝트 3] 제네릭 결과: Operation<T>
// ============================================================================
struct Operation<T> {
    result: Result<T, String>,
}

impl<T> Operation<T> {
    fn success(value: T) -> Self {
        Self { result: Ok(value) }
    }

    fn failure(error: &str) -> Self {
        Self { result: Err(String::from(error)) }
    }

    fn is_ok(&self) -> bool {
        self.result.is_ok()
    }

    fn is_err(&self) -> bool {
        self.result.is_err()
    }
}

// Clone 가능한 T에만 제공
impl<T: Clone> Operation<T> {
    fn unwrap_or(&self, default: T) -> T {
        self.result.clone().unwrap_or(default)
    }

    fn map<U: Clone, F: Fn(&T) -> U>(&self, f: F) -> Option<U> {
        if self.is_ok() {
            self.result.as_ref().ok().map(|val| f(val))
        } else {
            None
        }
    }
}

// Display 가능한 T에만 제공
impl<T: Display> Operation<T> {
    fn report(&self) {
        match &self.result {
            Ok(val) => println!("  ✓ 성공: {}", val),
            Err(e) => println!("  ✗ 실패: {}", e),
        }
    }
}

fn generic_result() {
    println!("\n[프로젝트 3] 제네릭 결과 (Operation<T>)");
    println!("═════════════════════════════════════════");

    println!("\n[성공 케이스]");
    let op_success: Operation<i32> = Operation::success(42);
    op_success.report();
    println!("  상태: {}", if op_success.is_ok() { "성공" } else { "실패" });

    println!("\n[실패 케이스]");
    let op_failure: Operation<String> = Operation::failure("데이터 없음");
    op_failure.report();
    println!("  상태: {}", if op_failure.is_err() { "오류" } else { "정상" });

    println!("\n[기본값으로 처리]");
    let op_str: Operation<String> = Operation::success("성공".to_string());
    let result = op_str.unwrap_or(String::from("기본값"));
    println!("  결과: {}", result);

    let op_fail: Operation<String> = Operation::failure("오류");
    let result = op_fail.unwrap_or(String::from("대체값"));
    println!("  대체: {}", result);

    println!("\n[변환 (map)]");
    let op_transform: Operation<i32> = Operation::success(10);
    if let Some(doubled) = op_transform.map(|val| val * 2) {
        println!("  변환 결과: {}", doubled);
    }

    println!("\n✓ 설계: Operation<T>로 모든 타입의 성공/실패 처리");
    println!("✓ 패턴: Result를 래핑한 범용 오류 처리");
}

// ============================================================================
// [프로젝트 4] 제네릭 데이터 파이프라인: Pipeline<T>
// ============================================================================
struct Pipeline<T> {
    stage: usize,
    data: T,
    history: Vec<String>,
}

impl<T> Pipeline<T> {
    fn start(data: T) -> Self {
        Self {
            stage: 1,
            data,
            history: vec!["[Stage 1] 파이프라인 시작".to_string()],
        }
    }

    fn get_data(&self) -> &T {
        &self.data
    }

    fn get_stage(&self) -> usize {
        self.stage
    }

    fn add_history(&mut self, message: &str) {
        self.history.push(format!("[Stage {}] {}", self.stage, message));
    }
}

// Clone 가능한 T에만 제공
impl<T: Clone> Pipeline<T> {
    fn process<F: Fn(T) -> T>(mut self, f: F) -> Self {
        self.stage += 1;
        self.data = f(self.data);
        self.add_history("처리 완료");
        self
    }

    fn duplicate_data(&self) -> T {
        self.data.clone()
    }
}

// Display 가능한 T에만 제공
impl<T: Display> Pipeline<T> {
    fn report(&self) {
        println!(">>> 파이프라인 리포트 <<<");
        println!("  현재 Stage: {}", self.stage);
        println!("  데이터: {}", self.data);
        println!("  히스토리:");
        for entry in &self.history {
            println!("    {}", entry);
        }
    }
}

fn generic_pipeline() {
    println!("\n[프로젝트 4] 제네릭 파이프라인 (Pipeline<T>)");
    println!("═════════════════════════════════════════");

    println!("\n[정수 파이프라인]");
    let pipeline = Pipeline::start(10)
        .process(|x| x * 2)
        .process(|x| x + 5)
        .process(|x| x * 3);
    pipeline.report();
    println!("  최종 결과: {}", pipeline.get_data());

    println!("\n[문자열 파이프라인]");
    let pipeline_str = Pipeline::start("Rust".to_string())
        .process(|s| s.to_uppercase())
        .process(|s| format!("{}!", s));
    pipeline_str.report();

    println!("\n[벡터 파이프라인]");
    let pipeline_vec = Pipeline::start(vec![1, 2, 3])
        .process(|mut v| {
            v.push(4);
            v
        })
        .process(|mut v| {
            v.push(5);
            v
        });
    println!("  최종 결과: {:?}", pipeline_vec.get_data());
    println!("  Stage: {}", pipeline_vec.get_stage());

    println!("\n✓ 설계: Pipeline<T>로 데이터 변환 체인 구축");
    println!("✓ 패턴: 함수형 체이닝으로 단계별 처리");
    println!("✓ 추적: 각 단계의 히스토리 자동 기록");
}

