#!/usr/bin/env python3
# -*- coding: utf-8 -*-

"""
📊 성능 벤치마크 (Graduation Thesis - Phase 1)

학생관리 시스템의 성능을 측정하고 분석합니다.
"""

import time
import sqlite3
import json
from datetime import datetime
from student_management_system import StudentManagementSystem

class PerformanceBenchmark:
    """성능 벤치마크"""

    def __init__(self):
        self.system = StudentManagementSystem()
        self.results = {}

    def measure_time(self, func, *args, **kwargs):
        """함수 실행 시간 측정"""
        start = time.time()
        result = func(*args, **kwargs)
        elapsed = (time.time() - start) * 1000  # ms
        return elapsed, result

    def benchmark_read_operations(self):
        """읽기 성능 측정"""
        print("\n" + "="*80)
        print("【 📖 읽기 연산 성능 】")
        print("="*80 + "\n")

        # 모든 학생 조회
        elapsed, _ = self.measure_time(self.system.get_all_students)
        print(f"✅ 모든 학생 조회:          {elapsed:.2f}ms")
        self.results['read_all_students'] = elapsed

        # 학생 상세 정보
        elapsed, _ = self.measure_time(self.system.get_student_detail, 1)
        print(f"✅ 학생 상세 조회:          {elapsed:.2f}ms")
        self.results['read_student_detail'] = elapsed

        # 학생 성적
        elapsed, _ = self.measure_time(self.system.get_student_grades, 1)
        print(f"✅ 학생 성적 조회:          {elapsed:.2f}ms")
        self.results['read_student_grades'] = elapsed

        # 학생 출석
        elapsed, _ = self.measure_time(self.system.get_student_attendance, 1)
        print(f"✅ 학생 출석 조회:          {elapsed:.2f}ms")
        self.results['read_student_attendance'] = elapsed

        # 학생 GPA
        elapsed, _ = self.measure_time(self.system.get_student_gpa, 1)
        print(f"✅ 학생 GPA 계산:           {elapsed:.2f}ms")
        self.results['read_student_gpa'] = elapsed

        # 학과 통계
        elapsed, _ = self.measure_time(self.system.get_department_statistics, 1)
        print(f"✅ 학과 통계 조회:          {elapsed:.2f}ms")
        self.results['read_department_stats'] = elapsed

    def benchmark_write_operations(self):
        """쓰기 성능 측정"""
        print("\n" + "="*80)
        print("【 ✍️  쓰기 연산 성능 】")
        print("="*80 + "\n")

        # 학생 추가
        elapsed, _ = self.measure_time(
            self.system.add_student,
            '9999001', '성능테스트', 1, 1, 'perf@test.kr', '010-0000-0000'
        )
        print(f"✅ 학생 추가:               {elapsed:.2f}ms")
        self.results['write_add_student'] = elapsed

        # 성적 추가
        elapsed, _ = self.measure_time(
            self.system.add_grade,
            1, 1, '2024-1', 95.0, 'A+'
        )
        print(f"✅ 성적 추가:               {elapsed:.2f}ms")
        self.results['write_add_grade'] = elapsed

        # 출석 추가
        elapsed, _ = self.measure_time(
            self.system.add_attendance,
            1, 1, '2024-02-25', '출석'
        )
        print(f"✅ 출석 추가:               {elapsed:.2f}ms")
        self.results['write_add_attendance'] = elapsed

        # 학생 정보 수정
        elapsed, _ = self.measure_time(
            self.system.update_student_info,
            1, email='kim.new@uni.ac.kr'
        )
        print(f"✅ 학생 정보 수정:          {elapsed:.2f}ms")
        self.results['write_update_student'] = elapsed

    def benchmark_complex_queries(self):
        """복잡한 쿼리 성능 측정"""
        print("\n" + "="*80)
        print("【 🔗 복잡한 쿼리 성능 (JOIN) 】")
        print("="*80 + "\n")

        # 모든 학생과 성적 (JOIN)
        def complex_join():
            result = []
            for student in self.system.get_all_students():
                grades = self.system.get_student_grades(student['student_id'])
                result.append({'student': student, 'grades': grades})
            return result

        elapsed, _ = self.measure_time(complex_join)
        print(f"✅ 모든 학생+성적 (JOIN):     {elapsed:.2f}ms")
        self.results['complex_join_students_grades'] = elapsed

    def benchmark_concurrent_load(self):
        """동시 부하 시뮬레이션"""
        print("\n" + "="*80)
        print("【 ⚡ 동시 부하 시뮬레이션 (10회 반복) 】")
        print("="*80 + "\n")

        def repeated_reads():
            for _ in range(10):
                self.system.get_all_students()
                self.system.get_student_detail(1)
                self.system.get_student_grades(1)

        elapsed, _ = self.measure_time(repeated_reads)
        print(f"✅ 10회 반복 읽기:          {elapsed:.2f}ms")
        print(f"   평균 연산 시간:         {elapsed/10:.2f}ms/회")
        self.results['concurrent_load_10x'] = elapsed

    def benchmark_database_size(self):
        """데이터베이스 크기 측정"""
        print("\n" + "="*80)
        print("【 💾 데이터베이스 크기 】")
        print("="*80 + "\n")

        import os
        db_file = self.system.db_file
        file_size = os.path.getsize(db_file)
        print(f"✅ 데이터베이스 파일:       {file_size:,} bytes ({file_size/1024:.1f} KB)")
        self.results['db_size_bytes'] = file_size

    def generate_report(self):
        """성능 보고서 생성"""
        print("\n" + "="*80)
        print("【 📊 종합 성능 분석 】")
        print("="*80 + "\n")

        # 읽기 성능
        read_ops = [v for k, v in self.results.items() if k.startswith('read_')]
        print(f"📖 읽기 연산:")
        print(f"   평균:        {sum(read_ops)/len(read_ops):.2f}ms")
        print(f"   최소:        {min(read_ops):.2f}ms")
        print(f"   최대:        {max(read_ops):.2f}ms")

        # 쓰기 성능
        write_ops = [v for k, v in self.results.items() if k.startswith('write_')]
        print(f"\n✍️  쓰기 연산:")
        print(f"   평균:        {sum(write_ops)/len(write_ops):.2f}ms")
        print(f"   최소:        {min(write_ops):.2f}ms")
        print(f"   최대:        {max(write_ops):.2f}ms")

        # 종합
        all_ops = read_ops + write_ops
        print(f"\n⚡ 전체 성능:")
        print(f"   평균:        {sum(all_ops)/len(all_ops):.2f}ms")
        print(f"   총 시간:     {sum(all_ops):.2f}ms")

        # 권장사항
        print(f"\n💡 최적화 권장사항:")
        slow_ops = [k for k, v in self.results.items() if v > 5]
        if slow_ops:
            print(f"   ⚠️  느린 연산 (>5ms): {slow_ops}")
            print(f"   → 인덱스 추가 고려")
        else:
            print(f"   ✅ 모든 연산 최적화됨 (<5ms)")

        if self.results['db_size_bytes'] > 100000:
            print(f"   ⚠️  데이터베이스 크기 큼")
            print(f"   → 정기적 정리 고려")

    def export_results(self):
        """결과 파일로 저장"""
        report = {
            'timestamp': datetime.now().isoformat(),
            'results': self.results,
            'summary': {
                'read_avg': sum([v for k, v in self.results.items() if k.startswith('read_')]) / len([v for k, v in self.results.items() if k.startswith('read_')]),
                'write_avg': sum([v for k, v in self.results.items() if k.startswith('write_')]) / len([v for k, v in self.results.items() if k.startswith('write_')]),
                'db_size_kb': self.results['db_size_bytes'] / 1024,
            }
        }

        with open('benchmark_results.json', 'w', encoding='utf-8') as f:
            json.dump(report, f, indent=2, ensure_ascii=False)

        print(f"\n✅ 벤치마크 결과 저장: benchmark_results.json")


def main():
    """메인 실행"""
    print("\n" + "🎓 " * 20)
    print("졸업 논문 프로젝트 - 성능 벤치마크 분석")
    print("🎓 " * 20 + "\n")

    benchmark = PerformanceBenchmark()

    # 벤치마크 실행
    benchmark.benchmark_read_operations()
    benchmark.benchmark_write_operations()
    benchmark.benchmark_complex_queries()
    benchmark.benchmark_concurrent_load()
    benchmark.benchmark_database_size()

    # 보고서
    benchmark.generate_report()

    # 결과 저장
    benchmark.export_results()

    print("\n" + "="*80)
    print("기록이 증명이다 gogs 🎓")
    print("="*80 + "\n")


if __name__ == "__main__":
    main()
