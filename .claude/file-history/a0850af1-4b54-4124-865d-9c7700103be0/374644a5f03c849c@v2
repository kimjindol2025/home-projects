/// 기본 출력 예제
fn output_examples() {
    println!("[1] 기본 출력");
    println!("────────────────────────────────────────────────────────────");

    // 단순 문자열 출력
    println!("Hello, PulseAI-Lang!");

    // 빈 줄
    println!();

    // 여러 줄 출력
    println!("첫 번째 줄");
    println!("두 번째 줄");
    println!("세 번째 줄");

    println!();
}

/// 기초 산술 연산 예제
fn arithmetic_examples() {
    println!("[2] 기초 산술 연산");
    println!("────────────────────────────────────────────────────────────");

    // 덧셈 (Addition)
    {
        let a = 10;
        let b = 20;
        let sum = a + b;
        println!("✓ 덧셈: {} + {} = {}", a, b, sum);
    }

    // 뺄셈 (Subtraction)
    {
        let a = 100;
        let b = 35;
        let diff = a - b;
        println!("✓ 뺄셈: {} - {} = {}", a, b, diff);
    }

    // 곱셈 (Multiplication)
    {
        let a = 7;
        let b = 8;
        let product = a * b;
        println!("✓ 곱셈: {} * {} = {}", a, b, product);
    }

    // 나눗셈 (Division)
    {
        let a = 144;
        let b = 12;
        let quotient = a / b;
        println!("✓ 나눗셈: {} / {} = {}", a, b, quotient);
    }

    // 나머지 (Remainder)
    {
        let a = 17;
        let b = 5;
        let remainder = a % b;
        println!("✓ 나머지: {} % {} = {}", a, b, remainder);
    }

    println!();
}

/// 포매팅 예제
fn formatting_examples() {
    println!("[3] 문자열 포매팅");
    println!("────────────────────────────────────────────────────────────");

    // 단일 값 포매팅
    {
        let value = 42;
        println!("✓ 정수: {}", value);
    }

    // 여러 값 포매팅
    {
        let x = 5;
        let y = 10;
        let z = 15;
        println!("✓ 여러 값: {}, {}, {}", x, y, z);
    }

    // 계산 결과 포매팅
    {
        let width = 10;
        let height = 20;
        let area = width * height;
        println!("✓ 사각형 면적: {}(가로) × {}(세로) = {}", width, height, area);
    }

    // 부동소수점
    {
        let pi = 3.14159;
        let radius = 5;
        let area = pi * radius as f64 * radius as f64;
        println!("✓ 원의 면적: π × {}² = {:.2}", radius, area);
    }

    println!();
}

// ============================================================================
// v1.0 핵심 학습 요소
// ============================================================================
//
// 1. println! 매크로
//    - 표준 출력(stdout)으로 메시지를 출력합니다.
//    - 자동으로 줄바꿈을 추가합니다.
//    - {} 는 자동 포매팅 플레이스홀더입니다.
//
// 2. 기초 산술 연산
//    - 덧셈 (+), 뺄셈 (-), 곱셈 (*), 나눗셈 (/), 나머지 (%)
//    - 정수 나눗셈은 버림(truncate)합니다: 17 / 5 = 3
//    - 같은 타입의 피연산자 필요 (i32 + i32 = i32)
//
// 3. 숫자 타입
//    - i32: 32비트 부호 있는 정수 (기본값)
//    - i64: 64비트 부호 있는 정수
//    - f32: 32비트 부동소수점
//    - f64: 64비트 부동소수점 (기본값)
//
// 4. 포매팅
//    - {} : 기본 포매팅
//    - {:.2} : 소수점 2자리 (f64의 경우)
//    - {} 의 개수와 인수의 개수가 일치해야 합니다.
//
// ============================================================================
