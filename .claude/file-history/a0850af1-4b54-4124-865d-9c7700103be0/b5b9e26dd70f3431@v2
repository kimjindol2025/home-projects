// Phase 11 v12.2: FFI & External Functions
// 이종 언어 간 통신 - 경계를 넘는 안전한 통로

use std::ffi::{CString, CStr};
use std::os::raw::c_char;
use std::panic::{catch_unwind, AssertUnwindSafe};

// =============================================================================
// Demo 1: 기본 외부 함수 호출 - C 표준 라이브러리
// =============================================================================

// [선언] C 표준 수학 함수들
extern "C" {
    fn abs(input: i32) -> i32;
    fn sqrt(x: f64) -> f64;
    fn pow(base: f64, exp: f64) -> f64;
}

fn demo_basic_external_functions() {
    println!("\n=== Demo 1: 기본 외부 함수 호출 ===");

    unsafe {
        // [호출 1] 절대값 계산
        let negative = -42;
        let result = abs(negative);
        println!("  [C-abs] {} → {}", negative, result);

        // [호출 2] 제곱근 계산
        let value = 16.0;
        let root = sqrt(value);
        println!("  [C-sqrt] √{} = {}", value, root);

        // [호출 3] 거듭제곱 계산
        let base = 2.0;
        let exp = 8.0;
        let power = pow(base, exp);
        println!("  [C-pow] {}^{} = {}", base, exp, power);

        println!("\n  [메시지]");
        println!("    • 러스트 코드에서 C 함수를 직접 호출");
        println!("    • 모든 호출은 unsafe 블록 내에서");
        println!("    • 컴파일러가 내부 안전성을 보장할 수 없음");
    }
}

// =============================================================================
// Demo 2: 문자열 마샬링 - Rust String ↔ C String
// =============================================================================

extern "C" {
    fn strlen(s: *const c_char) -> usize;
}

fn demo_string_marshalling() {
    println!("\n=== Demo 2: 문자열 마샬링 ===");

    unsafe {
        // [변환 1] Rust String → C String
        println!("  [Rust → C 변환]");
        let rust_string = "저장 필수 너는 기록이 증명이다 gogs";
        let c_string = CString::new(rust_string).expect("CString 생성 실패");

        println!("    Rust: '{}'", rust_string);
        println!("    C:    {:?}", c_string);

        // [호출] C의 strlen 함수 사용
        let length = strlen(c_string.as_ptr());
        println!("    strlen() 결과: {} 바이트", length);

        // [변환 2] C String → Rust String
        println!("\n  [C → Rust 변환]");
        let c_cstr = CStr::from_ptr(c_string.as_ptr());
        let rust_back = c_cstr.to_string_lossy();
        println!("    C: {:?}", c_cstr);
        println!("    Rust: '{}'", rust_back);

        // [안내] Null-terminated 문자열
        println!("\n  [Null-terminated 문자열]");
        println!("    C 문자열은 마지막에 '\\0'으로 끝남");
        println!("    Rust의 String은 길이를 명시적으로 저장");
        println!("    이 차이가 마샬링의 핵심!");
    }
}

// =============================================================================
// Demo 3: 배열과 벡터 마샬링 - Rust Vec ↔ C 배열
// =============================================================================

fn demo_array_marshalling() {
    println!("\n=== Demo 3: 배열과 벡터 마샬링 ===");

    // [이론] 배열을 C 함수에 전달하는 방식
    println!("  [배열 포인터 추출]");
    let numbers = vec![1, 2, 3, 4, 5];
    println!("    배열: {:?}", numbers);
    println!("    포인터: {:p}", numbers.as_ptr());
    println!("    길이: {}", numbers.len());

    // [이론] 러스트에서 C 함수 호출 방식 (예제)
    println!("\n  [C 함수 호출 패턴]");
    println!("    // C 함수 선언");
    println!("    extern \"C\" {{");
    println!("        fn sum_array(arr: *const i32, len: usize) -> i32;");
    println!("    }}");
    println!("");
    println!("    // 호출");
    println!("    unsafe {{");
    println!("        let total = sum_array(numbers.as_ptr(), numbers.len());");
    println!("    }}");

    // [실습] 수동 계산으로 검증
    println!("\n  [수동 합계 계산 (for 루프)]");
    let sum: i32 = numbers.iter().sum();
    println!("    {:?} 합계: {}", numbers, sum);

    // [이론] 가변 배열 전달
    println!("\n  [가변 배열 전달 (as_mut_ptr)]");
    let mut values = vec![1, 2, 3, 4, 5];
    println!("    수정 전: {:?}", values);
    println!("    수정 후: (C 함수가 수정한다면)");

    // [실습] 안전한 방식으로 변경
    for v in &mut values {
        *v *= 2;
    }
    println!("    실제 결과: {:?}", values);

    println!("\n  [마샬링 규칙]");
    println!("    • as_ptr(): &[T] → *const T (읽기용)");
    println!("    • as_mut_ptr(): &mut [T] → *mut T (쓰기용)");
    println!("    • 포인터와 길이를 함께 전달 (slice 시뮬레이션)");
}

// =============================================================================
// Demo 4: 구조체 호환성 - #[repr(C)]
// =============================================================================

#[repr(C)]
pub struct Point {
    x: i32,
    y: i32,
}

fn demo_struct_compatibility() {
    println!("\n=== Demo 4: 구조체 호환성 ===");

    // [메모리 레이아웃]
    println!("  [repr(C) 구조체 레이아웃]");
    println!("    크기: {} bytes", std::mem::size_of::<Point>());
    println!("    정렬: {} bytes", std::mem::align_of::<Point>());

    // [케이스 1] 구조체 값 전달
    println!("\n  [거리 계산 예제]");
    let p1 = Point { x: 0, y: 0 };
    let p2 = Point { x: 3, y: 4 };

    println!("    P1: ({}, {})", p1.x, p1.y);
    println!("    P2: ({}, {})", p2.x, p2.y);

    // [수동 계산] 거리 공식
    let dx = (p2.x - p1.x) as f64;
    let dy = (p2.y - p1.y) as f64;
    let distance = (dx * dx + dy * dy).sqrt();
    println!("    거리: {:.2} (3-4-5 직각삼각형)", distance);

    // [이론] C 함수 호출 방식
    println!("\n  [C 함수 호출 패턴]");
    println!("    // C 함수 선언");
    println!("    extern \"C\" {{");
    println!("        fn calculate_distance(p1: Point, p2: Point) -> f64;");
    println!("    }}");
    println!("");
    println!("    // 호출");
    println!("    unsafe {{");
    println!("        let dist = calculate_distance(p1, p2);");
    println!("    }}");

    // [케이스 2] 구조체 포인터
    println!("\n  [구조체 포인터 전달]");
    let mut point = Point { x: 1, y: 0 };
    println!("    회전 전: ({}, {})", point.x, point.y);
    println!("    회전 후: (C 함수가 수정한다면)");

    // [실습] 수동 회전 (90도)
    let temp = point.x;
    point.x = -point.y;
    point.y = temp;
    println!("    실제 90도 회전: ({}, {})", point.x, point.y);

    println!("\n  [repr(C)의 중요성]");
    println!("    • C와 러스트 간에 동일한 메모리 배치 보장");
    println!("    • 필드 순서 고정 (최적화 불가)");
    println!("    • 포인터 전달 가능");
    println!("    • 직렬화/역직렬화에도 사용");
}

// =============================================================================
// Demo 5: 콜백 구현 - C가 Rust 함수 호출
// =============================================================================

pub type MathCallback = extern "C" fn(i32, i32) -> i32;

pub extern "C" fn add_callback(a: i32, b: i32) -> i32 {
    a + b
}

pub extern "C" fn multiply_callback(a: i32, b: i32) -> i32 {
    a * b
}

pub extern "C" fn max_callback(a: i32, b: i32) -> i32 {
    if a > b { a } else { b }
}

fn demo_callbacks() {
    println!("\n=== Demo 5: 콜백 구현 ===");

    println!("  [콜백 함수들]");
    println!("    • add_callback: 덧셈");
    println!("    • multiply_callback: 곱셈");
    println!("    • max_callback: 최댓값");

    // [직접 호출] 콜백 함수를 러스트에서 직접 호출
    println!("\n  [직접 호출 예제]");
    let result1 = add_callback(10, 20);
    println!("    add_callback(10, 20) = {}", result1);

    let result2 = multiply_callback(10, 20);
    println!("    multiply_callback(10, 20) = {}", result2);

    let result3 = max_callback(10, 20);
    println!("    max_callback(10, 20) = {}", result3);

    // [이론] C 함수가 콜백을 사용하는 패턴
    println!("\n  [C 함수 호출 패턴]");
    println!("    // C 함수 선언");
    println!("    extern \"C\" {{");
    println!("        fn apply_operation(a: i32, b: i32,");
    println!("                          cb: MathCallback) -> i32;");
    println!("    }}");
    println!("");
    println!("    // 호출");
    println!("    unsafe {{");
    println!("        let res = apply_operation(10, 20, add_callback);");
    println!("    }}");

    println!("\n  [양방향 통신]");
    println!("    • Rust → C: extern \"C\" 블록");
    println!("    • C → Rust: extern \"C\" fn (콜백)");
    println!("    • 함수 포인터로 동작 제어");
}

// =============================================================================
// Demo 6: 안전한 래퍼 - Unsafe를 감싼 Safe API
// =============================================================================

/// [안전 인터페이스] C strlen을 감싼 래퍼
pub fn safe_c_strlen(s: &str) -> usize {
    unsafe {
        let c_str = CString::new(s).expect("CString 생성 실패");
        strlen(c_str.as_ptr())
    }
}

/// [안전 인터페이스] C abs를 감싼 래퍼
pub fn safe_c_abs(x: i32) -> i32 {
    unsafe { abs(x) }
}

/// [안전 인터페이스] 두 점 사이의 거리
pub fn safe_distance(x1: i32, y1: i32, x2: i32, y2: i32) -> f64 {
    let dx = (x2 - x1) as f64;
    let dy = (y2 - y1) as f64;
    (dx * dx + dy * dy).sqrt()
}

/// [안전 인터페이스] 배열 합계 (panic 안전)
pub fn safe_sum_array(numbers: &[i32]) -> Result<i32, String> {
    if numbers.is_empty() {
        return Ok(0);
    }

    match catch_unwind(AssertUnwindSafe(|| {
        numbers.iter().sum::<i32>()
    })) {
        Ok(result) => Ok(result),
        Err(_) => Err("합계 계산 중 오류 발생".to_string()),
    }
}

fn demo_safe_wrappers() {
    println!("\n=== Demo 6: 안전한 래퍼 ===");

    // [케이스 1] 문자열 길이 (Safe)
    println!("  [안전한 strlen]");
    let text = "Hello, FFI!";
    let len = safe_c_strlen(text);
    println!("    '{}' 길이: {}", text, len);

    // [케이스 2] 절대값 (Safe)
    println!("\n  [안전한 abs]");
    let nums = vec![-42, -15, 100];
    for n in nums {
        let abs_val = safe_c_abs(n);
        println!("    abs({}) = {}", n, abs_val);
    }

    // [케이스 3] 거리 계산 (Safe)
    println!("\n  [안전한 거리 계산]");
    let dist = safe_distance(0, 0, 3, 4);
    println!("    (0,0) → (3,4): {:.2}", dist);

    // [케이스 4] 배열 합계 (Panic Safe)
    println!("\n  [안전한 배열 합계 (Panic 보호)]");
    let numbers = vec![1, 2, 3, 4, 5];
    match safe_sum_array(&numbers) {
        Ok(sum) => println!("    {:?} 합계: {}", numbers, sum),
        Err(e) => println!("    에러: {}", e),
    }

    println!("\n  [안전 설계의 핵심]");
    println!("    • 내부: unsafe (C FFI 호출)");
    println!("    • 외부: safe (공개 인터페이스)");
    println!("    • Panic 방지: catch_unwind 사용");
    println!("    • 에러 처리: Result 반환");
}

