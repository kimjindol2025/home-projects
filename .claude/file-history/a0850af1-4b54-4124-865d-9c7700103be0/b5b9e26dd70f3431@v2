#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_basic_c_abs() {
        let result = safe_c_abs(-42);
        assert_eq!(result, 42);
    }

    #[test]
    fn test_c_strlen() {
        let len = safe_c_strlen("hello");
        assert_eq!(len, 5);
    }

    #[test]
    fn test_distance_calculation() {
        let dist = safe_distance(0, 0, 3, 4);
        assert!((dist - 5.0).abs() < 0.01);  // 3-4-5 직각삼각형
    }

    #[test]
    fn test_sum_array_valid() {
        let numbers = vec![1, 2, 3, 4, 5];
        let result = safe_sum_array(&numbers);
        assert_eq!(result, Ok(15));
    }

    #[test]
    fn test_sum_array_empty() {
        let numbers: Vec<i32> = vec![];
        let result = safe_sum_array(&numbers);
        assert_eq!(result, Ok(0));
    }

    #[test]
    fn test_cstring_conversion() {
        let rust_str = "test";
        let c_str = CString::new(rust_str).unwrap();
        let back = c_str.to_str().unwrap();
        assert_eq!(back, rust_str);
    }

    #[test]
    fn test_repr_c_struct_size() {
        // repr(C) 구조체는 특정 크기를 가짐
        assert_eq!(std::mem::size_of::<Point>(), 8);  // i32 + i32
        assert_eq!(std::mem::align_of::<Point>(), 4);
    }

    #[test]
    fn test_direct_callbacks() {
        // 콜백 함수를 직접 호출하는 테스트
        let add_result = add_callback(5, 3);
        assert_eq!(add_result, 8);

        let mul_result = multiply_callback(5, 3);
        assert_eq!(mul_result, 15);

        let max_result = max_callback(5, 3);
        assert_eq!(max_result, 5);
    }
}
