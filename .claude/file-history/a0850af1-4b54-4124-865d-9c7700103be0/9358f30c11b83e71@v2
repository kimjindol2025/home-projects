#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_qubit_state_creation() {
        let register = QuantumRegister::new(3, 1);
        assert_eq!(register.n_qubits(), 3);
        for i in 0..3 {
            assert_eq!(register.qubit(i), Some(QubitState::Zero));
        }
        println!("✅ Qubit state creation test passed");
    }

    #[test]
    fn test_hadamard_gate() {
        let mut vm = QuantumVM::new();
        let reg_id = vm.allocate_register(1);

        let gate = QuantumGate::Hadamard { target: 0 };
        vm.execute_gate(reg_id, gate).unwrap();

        if let Some(register) = vm.get_register(reg_id) {
            assert!(matches!(
                register.qubit(0),
                Some(QubitState::Superposition { .. })
            ));
        }
        println!("✅ Hadamard gate test passed");
    }

    #[test]
    fn test_pauli_x_gate() {
        let mut vm = QuantumVM::new();
        let reg_id = vm.allocate_register(1);

        let gate = QuantumGate::PauliX { target: 0 };
        vm.execute_gate(reg_id, gate).unwrap();

        assert_eq!(vm.get_register(reg_id).unwrap().qubit(0), Some(QubitState::One));
        println!("✅ Pauli-X gate test passed");
    }

    #[test]
    fn test_cnot_entanglement() {
        let mut vm = QuantumVM::new();
        let reg_id = vm.allocate_register(2);

        // q[0] = 1 (PauliX)
        vm.execute_gate(reg_id, QuantumGate::PauliX { target: 0 }).unwrap();

        // CNOT: control=0, target=1 (얽힘)
        vm.execute_gate(reg_id, QuantumGate::CNOT { control: 0, target: 1 })
            .unwrap();

        let register = vm.get_register(reg_id).unwrap();
        assert_eq!(register.qubit(0), Some(QubitState::One));
        assert_eq!(register.qubit(1), Some(QubitState::One)); // CNOT에 의해 flip됨
        assert_eq!(register.entanglements.len(), 1);

        println!("✅ CNOT entanglement test passed");
    }

    #[test]
    fn test_hybrid_execution() {
        let mut bridge = QuantumBridge::new();
        let reg_id = bridge.allocate_quantum_register(2);

        let mut circuit = QuantumCircuit::new(2);
        circuit.push(QuantumGate::Hadamard { target: 0 });
        circuit.push(QuantumGate::CNOT {
            control: 0,
            target: 1,
        });

        bridge.execute_probabilistic(reg_id, &circuit).unwrap();

        assert!(bridge.classical_decisions.len() > 0);
        println!("✅ Hybrid execution test passed");
        println!("{}", bridge.report());
    }

    #[test]
    fn test_quantum_error_correction() {
        let qec = QuantumErrorCorrection::new(3);
        let mut qubits = vec![
            QubitState::Zero,
            QubitState::Zero,
            QubitState::One, // Error
        ];

        let has_error = qec.detect_error(&qubits);
        assert!(has_error);

        qec.correct_error(&mut qubits).unwrap();
        println!("✅ Quantum error correction test passed");
        println!("{}", qec.report());
    }
}

