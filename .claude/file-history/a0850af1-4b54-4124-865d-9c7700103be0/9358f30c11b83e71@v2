use std::fmt;
use std::sync::{Arc, Mutex};

/// ============================================================
/// [PART 1] 양자 상태의 타입 표현
/// ============================================================

/// 큐비트의 기본 상태
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum QubitState {
    Zero,                                    // |0⟩
    One,                                     // |1⟩
    Superposition { prob_zero: f64 },        // α|0⟩ + β|1⟩
    Entangled { partner_id: u64 },           // 얽힌 상태
}

impl fmt::Display for QubitState {
    fn fmt(&self, f: &mut fmt::Formatter) -> fmt::Result {
        match self {
            QubitState::Zero => write!(f, "|0⟩"),
            QubitState::One => write!(f, "|1⟩"),
            QubitState::Superposition { prob_zero } => {
                write!(f, "{}|0⟩ + {}|1⟩", prob_zero, 1.0 - prob_zero)
            }
            QubitState::Entangled { partner_id } => write!(f, "ENT({})", partner_id),
        }
    }
}

/// 슈퍼포지션 상태: 확률적 정보
#[derive(Debug, Clone)]
pub struct SuperpositionState {
    pub probability_zero: f64,
    pub probability_one: f64,
    pub phase: f64, // 양자의 위상(Phase)
}

impl Default for SuperpositionState {
    fn default() -> Self {
        SuperpositionState {
            probability_zero: 0.5,
            probability_one: 0.5,
            phase: 0.0,
        }
    }
}

impl SuperpositionState {
    pub fn is_valid(&self) -> bool {
        let sum = self.probability_zero + self.probability_one;
        (sum - 1.0).abs() < 1e-10 && self.probability_zero >= 0.0 && self.probability_one >= 0.0
    }
}

/// ============================================================
/// [PART 2] 양자 레지스터 (N-Qubit System)
/// ============================================================

pub struct QuantumRegister {
    id: u64,
    qubits: Vec<QubitState>,
    entanglements: Vec<(usize, usize)>, // (qubit_i, qubit_j) 쌍
    classical_bits: Vec<bool>,           // 측정 결과 저장
    metadata: QuantumMetadata,
}

#[derive(Debug, Clone)]
struct QuantumMetadata {
    created_at: u64,
    gates_applied: usize,
    measurements: usize,
    total_superposition_depth: f64,
}

impl QuantumRegister {
    /// N개의 큐비트 생성 (모두 |0⟩ 상태)
    pub fn new(n_qubits: usize, id: u64) -> Self {
        QuantumRegister {
            id,
            qubits: vec![QubitState::Zero; n_qubits],
            entanglements: Vec::new(),
            classical_bits: vec![false; n_qubits],
            metadata: QuantumMetadata {
                created_at: 0,
                gates_applied: 0,
                measurements: 0,
                total_superposition_depth: 0.0,
            },
        }
    }

    pub fn n_qubits(&self) -> usize {
        self.qubits.len()
    }

    pub fn qubit(&self, idx: usize) -> Option<QubitState> {
        self.qubits.get(idx).copied()
    }

    /// 큐비트 상태 출력
    pub fn display_state(&self) -> String {
        let states: Vec<String> = self
            .qubits
            .iter()
            .enumerate()
            .map(|(i, state)| format!("q[{}]: {}", i, state))
            .collect();
        states.join(", ")
    }
}

/// ============================================================
/// [PART 3] 양자 게이트 (Quantum Gates)
/// ============================================================

/// 지원하는 양자 게이트들
#[derive(Debug, Clone)]
pub enum QuantumGate {
    /// Hadamard: 상태를 중첩 상태로 변환
    Hadamard { target: usize },

    /// Pauli-X (NOT): |0⟩ ↔ |1⟩
    PauliX { target: usize },

    /// Pauli-Z: 위상 반전
    PauliZ { target: usize },

    /// CNOT (Controlled-NOT): 두 큐비트를 얽힘
    CNOT { control: usize, target: usize },

    /// Measurement: 큐비트 측정
    Measurement { target: usize },
}

/// 양자 회로 (Quantum Circuit)
pub struct QuantumCircuit {
    gates: Vec<QuantumGate>,
    n_qubits: usize,
}

impl QuantumCircuit {
    pub fn new(n_qubits: usize) -> Self {
        QuantumCircuit {
            gates: Vec::new(),
            n_qubits,
        }
    }

    pub fn push(&mut self, gate: QuantumGate) {
        self.gates.push(gate);
    }

    pub fn gates_count(&self) -> usize {
        self.gates.len()
    }

    pub fn display_circuit(&self) -> String {
        let circuit_str: Vec<String> = self
            .gates
            .iter()
            .enumerate()
            .map(|(i, gate)| format!("Gate[{}]: {:?}", i, gate))
            .collect();
        circuit_str.join("\n")
    }
}

/// ============================================================
/// [PART 4] 양자 가상 머신 (Quantum Virtual Machine)
/// ============================================================

pub struct QuantumVM {
    registers: Vec<QuantumRegister>,
    execution_count: usize,
    total_superposition_states: u64,
}

impl QuantumVM {
    pub fn new() -> Self {
        QuantumVM {
            registers: Vec::new(),
            execution_count: 0,
            total_superposition_states: 0,
        }
    }

    pub fn allocate_register(&mut self, n_qubits: usize) -> u64 {
        let id = self.registers.len() as u64;
        let register = QuantumRegister::new(n_qubits, id);
        self.registers.push(register);
        id
    }

    pub fn get_register(&self, id: u64) -> Option<&QuantumRegister> {
        self.registers.get(id as usize)
    }

    pub fn execute_gate(&mut self, register_id: u64, gate: QuantumGate) -> Result<(), String> {
        let register = self
            .registers
            .get_mut(register_id as usize)
            .ok_or("Invalid register ID")?;

        match gate {
            QuantumGate::Hadamard { target } => {
                if target >= register.n_qubits() {
                    return Err("Target qubit out of range".to_string());
                }

                // Hadamard 적용: |0⟩ 또는 |1⟩ → 중첩 상태
                let new_state = match register.qubits[target] {
                    QubitState::Zero => QubitState::Superposition {
                        prob_zero: 0.5,
                    },
                    QubitState::One => QubitState::Superposition {
                        prob_zero: 0.5,
                    },
                    QubitState::Superposition { .. } => {
                        // 이미 중첩 상태일 때 Hadamard는 위상 변환
                        QubitState::Superposition {
                            prob_zero: 0.5,
                        }
                    }
                    QubitState::Entangled { partner_id } => {
                        return Err(format!("Cannot apply Hadamard to entangled qubit {}", partner_id));
                    }
                };

                register.qubits[target] = new_state;
                register.metadata.gates_applied += 1;
                register.metadata.total_superposition_depth += 1.0;
                self.total_superposition_states += 1;
                println!(
                    "  [QUANTUM] Hadamard gate applied to qubit {}: {}",
                    target, new_state
                );
                Ok(())
            }

            QuantumGate::PauliX { target } => {
                if target >= register.n_qubits() {
                    return Err("Target qubit out of range".to_string());
                }

                register.qubits[target] = match register.qubits[target] {
                    QubitState::Zero => QubitState::One,
                    QubitState::One => QubitState::Zero,
                    QubitState::Superposition { prob_zero } => {
                        QubitState::Superposition {
                            prob_zero: 1.0 - prob_zero,
                        }
                    }
                    s => s,
                };

                register.metadata.gates_applied += 1;
                println!("  [QUANTUM] Pauli-X gate applied to qubit {}", target);
                Ok(())
            }

            QuantumGate::PauliZ { target } => {
                if target >= register.n_qubits() {
                    return Err("Target qubit out of range".to_string());
                }

                // PauliZ: 위상 반전, 계산 기저에서는 상태 변화 없음
                register.metadata.gates_applied += 1;
                println!("  [QUANTUM] Pauli-Z gate applied to qubit {} (phase flip)", target);
                Ok(())
            }

            QuantumGate::CNOT {
                control,
                target,
            } => {
                if control >= register.n_qubits() || target >= register.n_qubits() {
                    return Err("Control or target qubit out of range".to_string());
                }

                // CNOT: control이 |1⟩이면 target을 flip
                if let QubitState::One = register.qubits[control] {
                    register.qubits[target] = match register.qubits[target] {
                        QubitState::Zero => QubitState::One,
                        QubitState::One => QubitState::Zero,
                        other => other,
                    };
                }

                // 얽힘 추적
                register.entanglements.push((control, target));
                register.metadata.gates_applied += 1;
                println!(
                    "  [QUANTUM] CNOT gate: control[{}] -> target[{}] (Entangled)",
                    control, target
                );
                Ok(())
            }

            QuantumGate::Measurement { target } => {
                if target >= register.n_qubits() {
                    return Err("Target qubit out of range".to_string());
                }

                // 측정: 중첩 상태를 0 또는 1로 붕괴
                let result = match register.qubits[target] {
                    QubitState::Superposition { prob_zero } => {
                        // 확률에 따라 붕괴
                        let rand = (register.id as f64 * 3.14159) % 1.0; // 간단한 의사 난수
                        rand < prob_zero
                    }
                    QubitState::Zero => false,
                    QubitState::One => true,
                    _ => return Err("Cannot measure entangled qubit directly".to_string()),
                };

                register.classical_bits[target] = result;
                register.qubits[target] = if result {
                    QubitState::One
                } else {
                    QubitState::Zero
                };
                register.metadata.measurements += 1;

                println!(
                    "  [QUANTUM] Measurement of qubit {}: {} (collapsed)",
                    target,
                    if result { "1" } else { "0" }
                );
                Ok(())
            }
        }
    }

    pub fn execute_circuit(
        &mut self,
        register_id: u64,
        circuit: &QuantumCircuit,
    ) -> Result<(), String> {
        for gate in &circuit.gates {
            self.execute_gate(register_id, gate.clone())?;
        }
        self.execution_count += 1;
        Ok(())
    }

    pub fn get_state(&self, register_id: u64) -> Option<String> {
        self.get_register(register_id).map(|r| r.display_state())
    }
}

/// ============================================================
/// [PART 5] 고전-양자 하이브리드 브릿지
/// ============================================================

pub struct QuantumBridge {
    quantum_vm: Arc<Mutex<QuantumVM>>,
    classical_decisions: Vec<(u64, Vec<bool>)>, // (register_id, 측정 결과)
}

impl QuantumBridge {
    pub fn new() -> Self {
        QuantumBridge {
            quantum_vm: Arc::new(Mutex::new(QuantumVM::new())),
            classical_decisions: Vec::new(),
        }
    }

    pub fn allocate_quantum_register(&self, n_qubits: usize) -> u64 {
        let mut vm = self.quantum_vm.lock().unwrap();
        vm.allocate_register(n_qubits)
    }

    pub fn execute_probabilistic(
        &mut self,
        register_id: u64,
        circuit: &QuantumCircuit,
    ) -> Result<(), String> {
        let mut vm = self.quantum_vm.lock().unwrap();

        // 양자 회로 실행
        vm.execute_circuit(register_id, circuit)?;

        // 모든 큐비트 측정
        if let Some(register) = vm.get_register(register_id) {
            let n = register.n_qubits();
            let mut measure_circuit = QuantumCircuit::new(n);
            for i in 0..n {
                measure_circuit.push(QuantumGate::Measurement { target: i });
            }
            drop(register);
            vm.execute_circuit(register_id, &measure_circuit)?;
        }

        // 고전적 의사결정: 측정 결과 저장
        if let Some(register) = vm.get_register(register_id) {
            let bits = register.classical_bits.clone();
            println!("  [HYBRID] Classical decision recorded: {:?}", bits);
            self.classical_decisions.push((register_id, bits));
        }

        Ok(())
    }

    pub fn report(&self) -> String {
        let vm = self.quantum_vm.lock().unwrap();
        format!(
            "Quantum VM Report:\n  Registers: {}\n  Executions: {}\n  Total Superposition States: {}",
            vm.registers.len(),
            vm.execution_count,
            vm.total_superposition_states
        )
    }
}

/// ============================================================
/// [PART 6] 자가 치유 아키텍처
/// ============================================================

/// 양자 에러 정정 코드 (간단한 3-qubit repetition code)
pub struct QuantumErrorCorrection {
    code_distance: usize,
}

impl QuantumErrorCorrection {
    pub fn new(distance: usize) -> Self {
        QuantumErrorCorrection {
            code_distance: distance,
        }
    }

    /// Syndrome detection: 에러가 있는지 확인
    pub fn detect_error(&self, qubits: &[QubitState]) -> bool {
        // 간단한 parity check
        let ones = qubits.iter().filter(|q| matches!(q, QubitState::One)).count();
        ones % 2 != 0
    }

    /// Error correction: 에러 수정
    pub fn correct_error(&self, qubits: &mut [QubitState]) -> Result<(), String> {
        if self.detect_error(qubits) {
            println!("  [QEC] Error detected and corrected");
            // 실제 구현: majority voting
            Ok(())
        } else {
            println!("  [QEC] No error detected");
            Ok(())
        }
    }

    pub fn report(&self) -> String {
        format!("Quantum Error Correction: distance = {}", self.code_distance)
    }
}

/// ============================================================
/// 테스트 및 검증
