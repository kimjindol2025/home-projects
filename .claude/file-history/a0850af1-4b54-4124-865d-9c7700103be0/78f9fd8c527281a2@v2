use std::collections::HashMap;

// ============================================================================
// [예제 1] Vec 기본 - 동적 배열
// ============================================================================
fn vec_basics() {
    println!("\n[예제 1] Vec<T> 기본 - 동적 배열");
    println!("═════════════════════════════════════════");

    println!("\n[벡터 생성]");
    let mut vec = Vec::new();
    println!("Vec::new() 생성 ✓");

    let vec2 = vec![1, 2, 3];
    println!("vec![1, 2, 3] 매크로 생성 ✓");

    println!("\n[요소 추가/제거]");
    let mut numbers = vec![1, 2, 3];
    println!("초기: {:?}", numbers);

    numbers.push(4);
    println!("push(4) 후: {:?}", numbers);

    let popped = numbers.pop();
    println!("pop() 결과: {:?}, 남은 벡터: {:?}", popped, numbers);

    println!("\n[인덱싱과 안전한 접근]");
    let data = vec![10, 20, 30, 40, 50];

    // 위험한 인덱싱 (범위 초과 시 panic)
    let first = &data[0];
    println!("data[0] = {}", first);

    // 안전한 접근 (Option 반환)
    match data.get(2) {
        Some(value) => println!("data.get(2) = Some({})", value),
        None => println!("data.get(2) = None"),
    }

    match data.get(10) {
        Some(value) => println!("data.get(10) = Some({})", value),
        None => println!("data.get(10) = None ✓"),
    }

    println!("\n[길이와 용량]");
    let vec3 = vec![1, 2, 3];
    println!("vec3.len() = {}", vec3.len());
    println!("vec3.capacity() = {}", vec3.capacity());
}

// ============================================================================
// [예제 2] Vec 순회 - 소유권과 차용
// ============================================================================
fn vec_iteration() {
    println!("\n[예제 2] Vec 순회 - 다양한 방법");
    println!("═════════════════════════════════════════");

    println!("\n[방법 1: 참조로 순회 (불변)]");
    let numbers = vec![1, 2, 3, 4, 5];
    for num in &numbers {
        print!("{} ", num);
    }
    println!();
    println!("numbers는 여전히 사용 가능 ✓");

    println!("\n[방법 2: 가변 참조로 순회]");
    let mut nums = vec![1, 2, 3];
    for num in &mut nums {
        *num *= 2;
    }
    println!("2배 변환: {:?}", nums);

    println!("\n[방법 3: 소유권 이전으로 순회]");
    let strings = vec![
        "Hello".to_string(),
        "World".to_string(),
        "Rust".to_string(),
    ];
    for s in strings {
        println!("소유권 이전: {}", s);
    }
    // strings는 이제 사용 불가능 (소유권 이전됨)

    println!("\n[방법 4: iter() 메서드]");
    let data = vec!["a", "b", "c"];
    for item in data.iter() {
        println!("iter: {}", item);
    }
    println!("data는 여전히 사용 가능 ✓");

    println!("\n[방법 5: enumerate() - 인덱스와 함께]");
    let items = vec!["first", "second", "third"];
    for (idx, item) in items.iter().enumerate() {
        println!("[{}] = {}", idx, item);
    }
}

// ============================================================================
// [예제 3] String 작업 - 동적 문자열
// ============================================================================
fn string_operations() {
    println!("\n[예제 3] String - 동적 문자열");
    println!("═════════════════════════════════════════");

    println!("\n[String 생성]");
    let s1 = String::new();
    println!("String::new() → 빈 문자열 ✓");

    let s2 = String::from("Hello");
    println!("String::from(\"Hello\") ✓");

    let s3 = "Rust".to_string();
    println!("\"Rust\".to_string() ✓");

    println!("\n[String 수정]");
    let mut text = String::from("Hello");
    println!("초기: {}", text);

    text.push_str(" World");
    println!("push_str(\" World\") 후: {}", text);

    text.push('!');
    println!("push('!') 후: {}", text);

    println!("\n[String 길이]");
    let greeting = "Hello";
    println!("\"Hello\".len() = {}", greeting.len());
    println!("\"Hello\".chars().count() = {}", greeting.chars().count());

    println!("\n[String vs &str]");
    let owned: String = "owned".to_string();  // String (소유)
    let borrowed: &str = "borrowed";         // &str (빌림)

    println!("owned (String): {}", owned);
    println!("borrowed (&str): {}", borrowed);
    println!("both work with fmt ✓");

    println!("\n[형식화]");
    let name = "Alice";
    let age = 30;
    let formatted = format!("{} is {} years old", name, age);
    println!("format!() → {}", formatted);

    println!("\n[문자 순회]");
    for ch in "Hello".chars() {
        print!("{}-", ch);
    }
    println!();
}

