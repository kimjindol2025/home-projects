// [예제 4] HashMap - 키-값 맵
// ============================================================================
fn hashmap_basics() {
    println!("\n[예제 4] HashMap - 키-값 매핑");
    println!("═════════════════════════════════════════");

    println!("\n[HashMap 생성]");
    let mut map = HashMap::new();
    map.insert("Alice", 30);
    map.insert("Bob", 25);
    map.insert("Charlie", 35);
    println!("HashMap 생성 및 데이터 삽입 ✓");

    println!("\n[조회]");
    match map.get("Alice") {
        Some(age) => println!("Alice의 나이: {}", age),
        None => println!("찾을 수 없음"),
    }

    match map.get("David") {
        Some(age) => println!("David의 나이: {}", age),
        None => println!("David를 찾을 수 없음 ✓"),
    }

    println!("\n[반복]");
    for (name, age) in &map {
        println!("  {}: {}세", name, age);
    }

    println!("\n[수정]");
    map.insert("Alice", 31);
    println!("Alice 나이 업데이트 → {:?}", map.get("Alice"));

    println!("\n[제거]");
    let removed = map.remove("Bob");
    println!("Bob 제거: {:?}", removed);
    println!("남은 항목: {}", map.len());

    println!("\n[entry API]");
    let mut scores = HashMap::new();
    *scores.entry("team_a").or_insert(0) += 5;
    *scores.entry("team_a").or_insert(0) += 3;
    println!("team_a 점수: {}", scores.get("team_a").unwrap());
}

