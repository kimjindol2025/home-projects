// [예제 5] 소유권과 차용 (컬렉션)
// ============================================================================
fn ownership_with_collections() {
    println!("\n[예제 5] 소유권과 차용 (Collections)");
    println!("═════════════════════════════════════════");

    println!("\n[소유권 이전]");
    let vec1 = vec![1, 2, 3];
    let vec2 = vec1;  // 소유권 이전
    println!("vec2: {:?}", vec2);
    // println!("{:?}", vec1);  // ❌ 컴파일 에러

    println!("\n[참조로 빌려주기]");
    let numbers = vec![10, 20, 30];
    let ref_numbers = &numbers;
    println!("numbers: {:?}", numbers);
    println!("ref_numbers: {:?}", ref_numbers);
    println!("numbers는 여전히 사용 가능 ✓");

    println!("\n[가변 차용]");
    let mut data = vec![1, 2, 3];
    {
        let data_mut = &mut data;
        data_mut.push(4);
        println!("data_mut 내부에서: {:?}", data_mut);
    }
    println!("data는 여전히 사용 가능: {:?}", data);

    println!("\n[동시 불변 + 가변 차용 금지]");
    let vec = vec![1, 2, 3];
    let immutable = &vec;
    // let mutable = &mut vec;  // ❌ 컴파일 에러
    println!("불변만 사용 가능: {:?}", immutable);

    println!("\n[String의 소유권]");
    let s1 = String::from("hello");
    let s2 = s1;  // 소유권 이전
    // println!("{}", s1);  // ❌ 컴파일 에러
    println!("s2: {}", s2);
}

// ============================================================================
// [예제 6] Iterator 패턴 - 함수형 변환
// ============================================================================
fn iterator_patterns() {
    println!("\n[예제 6] Iterator 패턴 - 함수형 변환");
    println!("═════════════════════════════════════════");

    println!("\n[map: 변환]");
    let numbers = vec![1, 2, 3, 4, 5];
    let doubled: Vec<i32> = numbers.iter()
        .map(|x| x * 2)
        .collect();
    println!("원본: {:?}", numbers);
    println!("2배: {:?}", doubled);

    println!("\n[filter: 필터링]");
    let evens: Vec<i32> = numbers.iter()
        .filter(|x| x % 2 == 0)
        .map(|x| *x)
        .collect();
    println!("짝수만: {:?}", evens);

    println!("\n[fold: 축약]");
    let sum: i32 = numbers.iter()
        .fold(0, |acc, x| acc + x);
    println!("합계: {}", sum);

    println!("\n[take: 처음 n개]");
    let first_three: Vec<i32> = numbers.iter()
        .take(3)
        .map(|x| *x)
        .collect();
    println!("처음 3개: {:?}", first_three);

    println!("\n[복합 변환]");
    let result: Vec<i32> = numbers.iter()
        .filter(|x| x > &&2)
        .map(|x| x * x)
        .take(2)
        .map(|x| *x)
        .collect();
    println!("2보다 크고, 제곱하고, 2개만: {:?}", result);

    println!("\n[any/all 검사]");
    let has_even = numbers.iter().any(|x| x % 2 == 0);
    let all_positive = numbers.iter().all(|x| x > &0);
    println!("짝수 있음: {}", has_even);
    println!("모두 양수: {}", all_positive);
}

// ============================================================================
// [예제 7] 메모리 관리 - 동적 할당
// ============================================================================
fn memory_management() {
    println!("\n[예제 7] 메모리 관리 - 동적 할당");
    println!("═════════════════════════════════════════");

    println!("\n[Vec의 내부 구조]");
    println!("Vec<T> = (pointer, length, capacity)");
    let vec = vec![1, 2, 3];
    println!("vec.len() = {} (현재 요소)", vec.len());
    println!("vec.capacity() = {} (할당된 용량)", vec.capacity());

    println!("\n[용량과 재할당]");
    let mut vec = Vec::with_capacity(1);
    println!("초기 capacity: {}", vec.capacity());

    vec.push(1);
    println!("push(1) → len={}, capacity={}", vec.len(), vec.capacity());

    vec.push(2);
    println!("push(2) → len={}, capacity={} (재할당됨)", vec.len(), vec.capacity());

    vec.push(3);
    println!("push(3) → len={}, capacity={} (다시 재할당)", vec.len(), vec.capacity());

    println!("\n[메모리 재할당 전략]");
    println!("Rust의 Vec은 용량이 부족할 때:");
    println!("  - 보통 2배씩 증가 (amortized O(1) push)");
    println!("  - 새 메모리 할당 → 복사 → 이전 메모리 해제");

    println!("\n[스코프와 Drop]");
    {
        let _temp_vec = vec![10, 20, 30];
        println!("temp_vec 생성 ✓");
    }
    println!("scope 벗어남 → temp_vec 자동 해제 (Drop trait) ✓");

    println!("\n[명시적 해제]");
    let vec = vec![1, 2, 3, 4, 5];
    println!("vec: {:?}", vec);
    drop(vec);
    println!("drop(vec) 호출 → 메모리 해제 ✓");
    // println!("{:?}", vec);  // ❌ 컴파일 에러
}

// ============================================================================
// [예제 8] 실제 데이터 처리 패턴
// ============================================================================
fn real_world_collections() {
    println!("\n[예제 8] 실제 데이터 처리 - 다양한 패턴");
    println!("═════════════════════════════════════════");

    println!("\n[패턴 1: 필터링 및 변환]");
    let data = vec!["Alice:30", "Bob:25", "Charlie:35"];
    let ages: Vec<u32> = data.iter()
        .filter_map(|s| {
            let parts: Vec<&str> = s.split(':').collect();
            if parts.len() == 2 {
                parts[1].parse().ok()
            } else {
                None
            }
        })
        .filter(|age| age > &20)
        .collect();
    println!("20세 이상: {:?}", ages);

    println!("\n[패턴 2: 그룹화]");
    let users = vec![
        ("team_a", 100),
        ("team_b", 150),
        ("team_a", 200),
        ("team_b", 180),
    ];
    let mut groups: HashMap<&str, Vec<i32>> = HashMap::new();
    for (team, score) in users.iter() {
        groups.entry(team)
            .or_insert_with(Vec::new)
            .push(*score);
    }
    println!("팀별 점수:");
    for (team, scores) in &groups {
        println!("  {}: {:?}", team, scores);
    }

    println!("\n[패턴 3: 데이터베이스 같은 구조]");
    struct Item {
        id: u32,
        name: String,
        price: f64,
    }

    let items = vec![
        Item { id: 1, name: "Apple".to_string(), price: 1.5 },
        Item { id: 2, name: "Banana".to_string(), price: 0.5 },
        Item { id: 3, name: "Orange".to_string(), price: 2.0 },
    ];

    let id_map: HashMap<u32, (String, f64)> = items.iter()
        .map(|item| (item.id, (item.name.clone(), item.price)))
        .collect();

    println!("ID 맵:");
    for (id, (name, price)) in &id_map {
        println!("  {}: {} (${:.2})", id, name, price);
    }

    println!("\n[패턴 4: 복합 필터링 및 정렬]");
    let scores = vec![85, 92, 78, 95, 88, 70, 99];
    let high_scores: Vec<i32> = scores.iter()
        .filter(|s| s > &&80)
        .map(|s| *s)
        .collect();
    let mut sorted = high_scores.clone();
    sorted.sort();
    println!("80점 이상: {:?}", high_scores);
    println!("정렬 후: {:?}", sorted);

    println!("\n[패턴 5: 중복 제거]");
    let mut numbers = vec![1, 2, 2, 3, 3, 3, 4, 4, 4, 4];
    numbers.sort();
    numbers.dedup();
    println!("중복 제거: {:?}", numbers);
}

