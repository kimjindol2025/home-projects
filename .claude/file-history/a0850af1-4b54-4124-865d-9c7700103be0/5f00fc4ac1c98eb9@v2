"""
Python Middle School v1.7 - 딕셔너리(Dictionary) — 이름표로 데이터 찾기

탐구(중학교): "번호표 대신 '이름'으로 데이터 관리하기"

리스트는 0, 1, 2라는 번호표(인덱스)로 데이터를 찾았습니다.
하지만 데이터가 수만 개라면 몇 번이 누구인지 기억하기 힘들겠죠?
딕셔너리는 현실의 사전처럼 '키(Key)'와 '값(Value)'을 쌍으로 묶어 관리합니다.

1. 딕셔너리의 구조
   - 중괄호 { }: 딕셔너리를 만드는 기호
   - 키(Key): 데이터를 찾기 위한 이름 (사전의 단어)
   - 값(Value): 실제 데이터 (사전의 뜻)
   - 형태: { "이름": "Gogs", "나이": 20 }

2. 왜 딕셔너리를 쓰나요?
   - 빠른 검색: 번호를 몰라도 "이름"만 알면 즉시 데이터를 찾을 수 있습니다.
   - 의미 있는 데이터: 숫자로 된 번호표보다 데이터의 의미가 명확해집니다.
"""

print("=" * 70)
print("# Python Middle School v1.7 - 딕셔너리(Dictionary)")
print("=" * 70)

# ============================================================================
# [1단계] 딕셔너리 기본 - 정보 담기
# ============================================================================

print("\n[1단계] 딕셔너리 기본 - 정보 담기")
print("-" * 70)

user_info = {
    "name": "설계자",
    "level": "중학생",
    "major": "시스템 공학",
    "point": 100
}

print("딕셔너리 생성:")
print(f"user_info = {user_info}")

print("\n설명:")
print("  ✓ 중괄호 { }로 감싸여 있습니다.")
print("  ✓ '키': '값' 형태로 정보를 저장합니다.")
print("  ✓ 리스트와 달리 번호표(인덱스)가 아닌 이름으로 접근합니다.")

# ============================================================================
# [2단계] 데이터 꺼내기 (접근)
# ============================================================================

print("\n[2단계] 데이터 꺼내기 - 키(Key)를 사용한 접근")
print("-" * 70)

print("--- 사용자 정보 조회 ---")
print(f"이름: {user_info['name']}")
print(f"레벨: {user_info['level']}")
print(f"전공: {user_info['major']}")
print(f"포인트: {user_info['point']}")

print("\n설명:")
print("  ✓ 딕셔너리이름['키'] 형태로 값을 가져옵니다.")
print("  ✓ 리스트처럼 [0], [1]이 아니라 ['name'], ['level']입니다.")

# ============================================================================
# [3단계] 데이터 수정과 추가
# ============================================================================

print("\n[3단계] 데이터 수정과 추가")
print("-" * 70)

print("수정 전:")
print(f"  포인트: {user_info['point']}")

user_info["point"] = 150  # 수정
print("\nuser_info['point'] = 150 (수정)")
print(f"  포인트: {user_info['point']}")

user_info["is_active"] = True  # 추가
print("\nuser_info['is_active'] = True (추가)")
print(f"  활동 상태: {user_info['is_active']}")

print("\n설명:")
print("  ✓ 기존 키에 새 값을 할당하면 수정됩니다.")
print("  ✓ 없던 키에 값을 할당하면 새로 추가됩니다.")

# ============================================================================
# [4단계] 키(Key) 목록 보기
# ============================================================================

print("\n[4단계] 키(Key) 목록 보기 - .keys() 메서드")
print("-" * 70)

print("현재 딕셔너리의 모든 키:")
print(f"user_info.keys() = {user_info.keys()}")

print("\n--- 저장된 정보 항목 리스트 ---")
for key in user_info.keys():
    print(f"  - {key}")

# ============================================================================
# [5단계] 값(Value) 목록 보기
# ============================================================================

print("\n[5단계] 값(Value) 목록 보기 - .values() 메서드")
print("-" * 70)

print("현재 딕셔너리의 모든 값:")
print(f"user_info.values() = {user_info.values()}")

print("\n--- 저장된 데이터 값 리스트 ---")
for value in user_info.values():
    print(f"  - {value}")

# ============================================================================
# [6단계] 키-값 쌍 보기
# ============================================================================

print("\n[6단계] 키-값 쌍 보기 - .items() 메서드")
print("-" * 70)

print("모든 키-값 쌍:")
print(f"user_info.items() = {user_info.items()}")

print("\n--- 항목별 정보 ---")
for key, value in user_info.items():
    print(f"  {key}: {value}")

# ============================================================================
# [7단계] 키가 존재하는지 확인
# ============================================================================

print("\n[7단계] 키 존재 여부 확인 - in 연산자")
print("-" * 70)

print("특정 키가 딕셔너리에 있는지 확인:")
print(f"  'name' in user_info: {'name' in user_info}")
print(f"  'email' in user_info: {'email' in user_info}")
print(f"  'point' in user_info: {'point' in user_info}")

print("\n설명:")
print("  ✓ in 연산자로 키의 존재 여부를 확인할 수 있습니다.")
print("  ✓ 없는 키에 접근하면 KeyError가 발생합니다.")

# ============================================================================
# [8단계] get() 메서드 - 안전한 접근
# ============================================================================

print("\n[8단계] get() 메서드 - 안전한 데이터 접근")
print("-" * 70)

print("일반 접근 vs get() 메서드:")
print(f"  user_info['name'] = {user_info['name']}")
print(f"  user_info.get('name') = {user_info.get('name')}")

print("\n없는 키 접근:")
print(f"  user_info.get('email') = {user_info.get('email')}")
print(f"  user_info.get('email', '정보 없음') = {user_info.get('email', '정보 없음')}")

print("\n설명:")
print("  ✓ get('키')는 없는 키에도 None을 반환합니다.")
print("  ✓ get('키', '기본값')으로 기본값을 지정할 수 있습니다.")

# ============================================================================
# [9단계] 데이터 삭제
# ============================================================================

print("\n[9단계] 데이터 삭제 - del과 pop()")
print("-" * 70)

test_dict = {"a": 1, "b": 2, "c": 3}
print(f"원본: {test_dict}")

del test_dict["b"]  # del 키워드 사용
print(f"del test_dict['b'] 후: {test_dict}")

removed_value = test_dict.pop("c")  # pop() 메서드 사용
print(f"test_dict.pop('c') 후: {test_dict}, 삭제된 값: {removed_value}")

# ============================================================================
# [10단계] 리스트 vs 딕셔너리
# ============================================================================

print("\n[10단계] 리스트 vs 딕셔너리 비교")
print("-" * 70)

student_list = ["Gogs", 20, "시스템 공학"]
student_dict = {"name": "Gogs", "age": 20, "major": "시스템 공학"}

print("리스트 방식:")
print(f"  student_list = {student_list}")
print(f"  이름: student_list[0] = {student_list[0]}")
print(f"  나이: student_list[1] = {student_list[1]}")
print(f"  → 0번이 뭔지, 1번이 뭔지 기억해야 함!")

print("\n딕셔너리 방식:")
print(f"  student_dict = {student_dict}")
print(f"  이름: student_dict['name'] = {student_dict['name']}")
print(f"  나이: student_dict['age'] = {student_dict['age']}")
print(f"  → 'name', 'age'로 명확하게 접근!")

# ============================================================================
# [11단계] 실용 예제: 상품 관리 시스템
# ============================================================================

print("\n[11단계] 실용 예제: 상품 관리 시스템")
print("-" * 70)

products = {
    "노트북": {"가격": 150000, "수량": 5, "판매량": 2},
    "마우스": {"가격": 25000, "수량": 20, "판매량": 8},
    "키보드": {"가격": 80000, "수량": 10, "판매량": 3}
}

print("상품 정보:")
for product, info in products.items():
    print(f"\n[{product}]")
    print(f"  가격: {info['가격']:,}원")
    print(f"  수량: {info['수량']}개")
    print(f"  판매량: {info['판매량']}개")
    profit = (info['가격'] * info['판매량'])
    print(f"  판매수익: {profit:,}원")

# ============================================================================
# [12단계] 딕셔너리 복사
# ============================================================================

print("\n[12단계] 딕셔너리 복사")
print("-" * 70)

original = {"a": 1, "b": 2}
print(f"원본: {original}")

# 얕은 복사
copy_dict = original.copy()
copy_dict["a"] = 999
print(f"\n.copy() 사용 후 copy_dict['a'] = 999")
print(f"원본: {original}")
print(f"복사본: {copy_dict}")
print("✓ 원본은 영향을 받지 않습니다!")

# ============================================================================
# [최종 증명]
# ============================================================================

print("\n" + "=" * 70)
print("# [최종 증명] 딕셔너리의 힘")
print("=" * 70)

print("""
✓ [딕셔너리의 기본 구조]
  dict_name = {'키1': '값1', '키2': '값2'}

✓ [데이터 접근]
  dict_name['키'] → 값 반환
  dict_name.get('키') → 안전한 접근
  dict_name.get('키', '기본값') → 기본값 제공

✓ [데이터 수정 및 추가]
  dict_name['키'] = 새값 → 수정 또는 추가

✓ [유용한 메서드]
  .keys() → 모든 키 반환
  .values() → 모든 값 반환
  .items() → 키-값 쌍 반환
  .pop('키') → 삭제하며 값 반환
  .copy() → 복사본 생성

✓ [리스트와의 차이]
  리스트: 번호표로 접근 (느림, 의미 불명확)
  딕셔너리: 이름으로 접근 (빠름, 의미 명확)

✓ [응용]
  - 사용자 정보 관리
  - 상품 정보 시스템
  - 설정값 저장
  - 데이터베이스 같은 구조

결론:
  딕셔너리는 현실의 사전처럼 작동합니다.
  '키'라는 이름으로 '값'을 즉시 찾을 수 있습니다.

  이것이 효율적인 데이터 관리의 시작입니다!

저장 필수 너는 기록이 증명이다 gogs
""")
