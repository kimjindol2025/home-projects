{% extends "base.html" %}

{% block title %}출석 - 학생관리 시스템{% endblock %}

{% block content %}
<div class="attendance-page">
    <h1 class="page-title">✅ 출석 현황</h1>

    <div class="page-header">
        <p class="info-text">총 <strong>{{ attendance_data|length }}</strong>명의 학생 출석 기록</p>
    </div>

    {% if attendance_data %}
    <div class="attendance-container">
        {% for item in attendance_data %}
        <div class="student-attendance-card">
            <div class="card-header">
                <h3>
                    {{ item.student.name }}
                    <span class="student-no">({{ item.student.student_no }})</span>
                </h3>
                <span class="dept-name">{{ item.student.dept_name }}</span>
            </div>

            <div class="card-body">
                {% if item.records %}
                <!-- 출석 통계 -->
                {% set total = item.records|length %}
                {% set present = item.records|selectattr('status', 'equalto', '출석')|list|length %}
                {% set late = item.records|selectattr('status', 'equalto', '지각')|list|length %}
                {% set absent = item.records|selectattr('status', 'equalto', '결석')|list|length %}

                <div class="attendance-summary">
                    <div class="summary-item">
                        <span class="label">✅ 출석</span>
                        <span class="value">{{ present }}</span>
                    </div>
                    <div class="summary-item">
                        <span class="label">⏰ 지각</span>
                        <span class="value">{{ late }}</span>
                    </div>
                    <div class="summary-item">
                        <span class="label">❌ 결석</span>
                        <span class="value">{{ absent }}</span>
                    </div>
                    <div class="summary-item">
                        <span class="label">📊 합계</span>
                        <span class="value">{{ total }}</span>
                    </div>
                </div>

                <!-- 출석 기록 테이블 -->
                <div class="attendance-records">
                    <table class="mini-table">
                        <thead>
                            <tr>
                                <th>날짜</th>
                                <th>과목</th>
                                <th>상태</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for record in item.records %}
                            <tr>
                                <td>{{ record.date }}</td>
                                <td>{{ record.course_name }}</td>
                                <td>
                                    {% if record.status == '출석' %}
                                    <span class="status-badge status-present">✅ 출석</span>
                                    {% elif record.status == '지각' %}
                                    <span class="status-badge status-late">⏰ 지각</span>
                                    {% else %}
                                    <span class="status-badge status-absent">❌ 결석</span>
                                    {% endif %}
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% else %}
                <p class="empty-message">등록된 출석 기록이 없습니다.</p>
                {% endif %}
            </div>

            <div class="card-footer">
                <a href="/student/{{ item.student.student_id }}" class="btn-small btn-info">상세보기</a>
            </div>
        </div>
        {% endfor %}
    </div>

    <!-- 전체 통계 -->
    <div class="overall-stats">
        <h2>📊 전체 출석 통계</h2>
        <div class="stats-grid">
            {% set grand_total = 0 %}
            {% set grand_present = 0 %}
            {% set grand_late = 0 %}
            {% set grand_absent = 0 %}

            {% for item in attendance_data %}
                {% for record in item.records %}
                    {% set grand_total = grand_total + 1 %}
                    {% if record.status == '출석' %}
                        {% set grand_present = grand_present + 1 %}
                    {% elif record.status == '지각' %}
                        {% set grand_late = grand_late + 1 %}
                    {% else %}
                        {% set grand_absent = grand_absent + 1 %}
                    {% endif %}
                {% endfor %}
            {% endfor %}

            <div class="stat-card">
                <p class="stat-label">✅ 총 출석</p>
                <p class="stat-value">{{ grand_present }}</p>
            </div>
            <div class="stat-card">
                <p class="stat-label">⏰ 총 지각</p>
                <p class="stat-value">{{ grand_late }}</p>
            </div>
            <div class="stat-card">
                <p class="stat-label">❌ 총 결석</p>
                <p class="stat-value">{{ grand_absent }}</p>
            </div>
            <div class="stat-card">
                <p class="stat-label">📊 총 기록</p>
                <p class="stat-value">{{ grand_total }}</p>
            </div>
        </div>
    </div>

    {% else %}
    <div class="empty-state">
        <p>등록된 출석 기록이 없습니다.</p>
    </div>
    {% endif %}
</div>
{% endblock %}
