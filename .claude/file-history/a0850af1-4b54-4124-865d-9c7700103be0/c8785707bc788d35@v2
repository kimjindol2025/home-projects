# 🔐 v6.3: 환경 설정 파일 예시
# .env 파일을 .env.example 기반으로 생성하고 실제 값으로 채워주세요
# 절대 .env 파일을 Git에 커밋하지 마세요!

# ============= 애플리케이션 설정 =============

# Flask 애플리케이션 설정
FLASK_APP=app.py
FLASK_ENV=production  # 또는 development, testing
DEBUG=False
SECRET_KEY=your-secret-key-change-this-in-production-12345

# ============= 데이터베이스 설정 =============

# SQLite (개발용)
DATABASE_URL=sqlite:////data/student.db
DB_PATH=/data/student.db

# PostgreSQL (프로덕션 권장)
# DATABASE_URL=postgresql://user:password@localhost:5432/student_db
# POSTGRES_USER=admin
# POSTGRES_PASSWORD=secure_password_here
# POSTGRES_DB=student_management

# ============= 서버 설정 =============

# 호스트 및 포트
HOST=0.0.0.0
PORT=8000
WORKERS=4
WORKER_CLASS=sync
WORKER_CONNECTIONS=100
TIMEOUT=120

# ============= 로깅 설정 =============

# 로그 레벨: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_FORMAT=json  # 또는 text
LOG_FILE=/app/logs/app.log
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5

# ============= 보안 설정 =============

# CORS 설정
CORS_ORIGINS=http://localhost:3000,http://localhost:5000
CORS_ALLOW_HEADERS=Content-Type,Authorization
CORS_ALLOW_CREDENTIALS=True

# HTTPS 설정
USE_HTTPS=True
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# 세션 설정
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Strict
SESSION_TIMEOUT=3600  # 1시간

# ============= API 설정 =============

# API Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100  # 요청 수
RATE_LIMIT_PERIOD=3600   # 시간 (초)

# API 키
API_KEY=your-api-key-here
API_SECRET=your-api-secret-here

# ============= 외부 서비스 =============

# AWS S3 (파일 업로드)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-northeast-1
S3_BUCKET_NAME=student-app-files

# Slack 알림
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# 이메일 알림
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SENDER_EMAIL=noreply@student-app.com

# ============= 모니터링 설정 =============

# Sentry (에러 추적)
SENTRY_DSN=https://key@sentry.io/project-id

# DataDog (성능 모니터링)
DATADOG_API_KEY=your-datadog-api-key
DATADOG_SITE=datadoghq.com

# ============= 클라우드 설정 =============

# AWS 배포
AWS_ECR_REGISTRY=123456789.dkr.ecr.ap-northeast-1.amazonaws.com
AWS_ECS_CLUSTER=student-app-cluster
AWS_ECS_SERVICE=web
AWS_ECS_TASK_DEFINITION=student-app-task

# Google Cloud
GCP_PROJECT_ID=your-project-id
GCP_REGION=asia-northeast1
GCP_IMAGE_NAME=student-app

# ============= 개발 설정 =============

# 테스트 데이터 생성
SEED_DATA=False
TEST_MODE=False

# 캐시 설정
CACHE_TYPE=simple  # 또는 redis
CACHE_DEFAULT_TIMEOUT=300
REDIS_URL=redis://localhost:6379/0
