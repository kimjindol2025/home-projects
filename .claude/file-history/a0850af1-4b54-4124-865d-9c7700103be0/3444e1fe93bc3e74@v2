version: '3.8'

services:
  # ============= 데이터베이스 서비스 =============
  db:
    image: sqlite  # 개발용 SQLite (프로덕션은 PostgreSQL 권장)
    container_name: student-db
    volumes:
      - db_volume:/data
    environment:
      - DB_PATH=/data/student.db
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "test", "-f", "/data/student.db"]
      interval: 30s
      timeout: 10s
      retries: 3
    networks:
      - app_network

  # ============= 웹 애플리케이션 서비스 =============
  web:
    build:
      context: .
      dockerfile: Dockerfile.optimized
    container_name: student-web
    environment:
      - FLASK_ENV=production
      - DATABASE_URL=sqlite:////data/student.db
      - SECRET_KEY=${SECRET_KEY:-your-secret-key-change-in-production}
      - DEBUG=False
      - LOG_LEVEL=INFO
    volumes:
      - db_volume:/data
      - ./logs:/app/logs
    ports:
      - "8000:8000"
    depends_on:
      db:
        condition: service_healthy
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s
    networks:
      - app_network
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

  # ============= Nginx 리버스 프록시 =============
  nginx:
    image: nginx:alpine
    container_name: student-nginx
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
      - ./ssl:/etc/nginx/ssl:ro  # SSL 인증서
      - ./logs/nginx:/var/log/nginx
    depends_on:
      - web
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "wget", "--quiet", "--tries=1", "--spider", "http://localhost/health"]
      interval: 30s
      timeout: 10s
      retries: 3
    networks:
      - app_network
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

  # ============= 로그 수집 서비스 (선택사항) =============
  # 프로덕션에서는 ELK Stack 또는 Datadog 사용 권장
  logs:
    image: alpine
    container_name: student-logs
    volumes:
      - ./logs:/logs
    command: sh -c "tail -f /logs/*.log"
    restart: unless-stopped
    networks:
      - app_network
    depends_on:
      - web

# ============= 네트워크 정의 =============
networks:
  app_network:
    driver: bridge

# ============= 볼륨 정의 =============
volumes:
  db_volume:
    driver: local
