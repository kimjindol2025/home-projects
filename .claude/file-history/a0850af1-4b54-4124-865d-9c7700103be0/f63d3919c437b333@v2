fn divide(a: i32, b: i32) -> Result<i32, String> {
    if b == 0 {
        Err(\"0мңјлЎң лӮҳлҲҢ мҲҳ м—ҶмҠөлӢҲлӢӨ\".to_string())
    } else {
        Ok(a / b)
    }
}

fn result_basics() {
    println!(\"\\n[мҳҲм ң 3] Result<T, E> кё°ліё\");
    println!(\"в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\");

    println!(\"\\n[м„ұкіө кІҪмҡ°]\");
    match divide(10, 2) {
        Ok(result) => println!(\"10 Г· 2 = {}\", result),
        Err(e) => println!(\"м—җлҹ¬: {}\", e),
    }

    println!(\"\\n[мӢӨнҢЁ кІҪмҡ°]\");
    match divide(10, 0) {
        Ok(result) => println!(\"10 Г· 0 = {}\", result),
        Err(e) => println!(\"м—җлҹ¬: {}\", e),
    }

    println!(\"\\n[if let]\");
    if let Ok(result) = divide(20, 4) {
        println!(\"20 Г· 4 = {}\", result);
    }
}

