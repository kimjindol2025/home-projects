// [мҳҲм ң 2] Optionмқҳ л©”м„ңл“ңл“Ө
// ============================================================================
fn parse_number(s: &str) -> Option<i32> {
    s.parse::<i32>().ok()
}

fn option_methods() {
    println!(\"\\n[мҳҲм ң 2] Optionмқҳ л©”м„ңл“ңл“Ө\");
    println!(\"в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\");

    println!(\"\\n[unwrapкіј unwrap_or]\");
    let some_value = Some(42);
    let none_value: Option<i32> = None;

    println!(\"Some(42).unwrap() = {}\", some_value.unwrap());
    println!(\"None.unwrap_or(0) = {}\", none_value.unwrap_or(0));

    println!(\"\\n[is_someкіј is_none]\");
    if some_value.is_some() {
        println!(\"some_valueлҠ” к°’мқ„ к°Җм§җ\");
    }
    if none_value.is_none() {
        println!(\"none_valueлҠ” None\");
    }

    println!(\"\\n[map: Optionмқ„ ліҖнҷҳ]\");
    let doubled = Some(5).map(|x| x * 2);
    println!(\"Some(5).map(|x| x * 2) = {:?}\", doubled);

    let none_doubled = None::<i32>.map(|x| x * 2);
    println!(\"None.map(|x| x * 2) = {:?}\", none_doubled);

    println!(\"\\n[and_then: мӨ‘мІ©лҗң Option]\");
    let result = parse_number(\"42\")
        .and_then(|x| {
            if x > 0 { Some(x * 2) } else { None }
        });
    println!(\"parse_number(\\\"42\\\").and_then(...) = {:?}\", result);

    println!(\"\\n[filter: мЎ°кұҙ н•„н„°л§Ғ]\");
    let filtered = Some(5).filter(|x| x > &3);
    println!(\"Some(5).filter(|x| x > &3) = {:?}\", filtered);

    let filtered_none = Some(2).filter(|x| x > &3);
    println!(\"Some(2).filter(|x| x > &3) = {:?}\", filtered_none);
}

