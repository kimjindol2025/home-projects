// [мҳҲм ң 8] мӢӨм ң мӮ¬мҡ© мҳҲм ң
// ============================================================================
struct DataRecord {
    id: u32,
    value: i32,
}

fn parse_record(line: &str) -> Result<DataRecord, String> {
    let parts: Vec<&str> = line.split(',').collect();

    if parts.len() != 2 {
        return Err(format!(\"нҳ•мӢқ мҳӨлҘҳ: {} к°ңмқҳ н•ӯлӘ©\", parts.len()));
    }

    let id = parts[0].trim()
        .parse::<u32>()
        .map_err(|_| \"IDлҠ” мҲ«мһҗм—¬м•ј н•©лӢҲлӢӨ\".to_string())?;

    let value = parts[1].trim()
        .parse::<i32>()
        .map_err(|_| \"VALUEлҠ” мҲ«мһҗм—¬м•ј н•©лӢҲлӢӨ\".to_string())?;

    if value < 0 || value > 1000 {
        return Err(\"VALUEлҠ” 0~1000 лІ”мң„м—¬м•ј н•©лӢҲлӢӨ\".to_string());
    }

    Ok(DataRecord { id, value })
}

fn process_records(lines: &[&str]) -> Vec<DataRecord> {
    lines.iter()
        .enumerate()
        .filter_map(|(idx, line)| {
            match parse_record(line) {
                Ok(record) => {
                    println!(\"вң“ мӨ„ {}: ID={}, VALUE={}\", idx + 1, record.id, record.value);
                    Some(record)
                }
                Err(e) => {
                    println!(\"вң— мӨ„ {}: {}\", idx + 1, e);
                    None
                }
            }
        })
        .collect()
}

fn real_world_example() {
    println!(\"\\n[мҳҲм ң 8] мӢӨм ң мӮ¬мҡ© мҳҲм ң - CSV нҢҢмӢұ\");
    println!(\"в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\");

    let data = vec![
        \"1, 100\",
        \"2, 250\",
        \"invalid, 300\",
        \"4, -50\",
        \"5, 500\",
        \"6, 1500\",
        \"7, 750\",
    ];

    println!(\"\\n[нҢҢмӢұ кІ°кіј]\");
    let records = process_records(&data);

    println!(\"\\n[мІҳлҰ¬лҗң л ҲмҪ”л“ң]\");
    let sum: i32 = records.iter().map(|r| r.value).sum();
    let count = records.len();
    println!(\"мҙқ {} к°ң л ҲмҪ”л“ң мІҳлҰ¬лҗЁ\", count);
    println!(\"н•©кі„: {}\", sum);
    if count > 0 {
        println!(\"нҸүк· : {}\", sum / count as i32);
    }
}

