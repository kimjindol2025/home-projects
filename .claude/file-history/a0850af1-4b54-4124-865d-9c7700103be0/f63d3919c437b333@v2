fn result_methods() {
    println!(\"\\n[мҳҲм ң 4] Resultмқҳ л©”м„ңл“ңл“Ө\");
    println!(\"в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\");

    println!(\"\\n[is_okмҷҖ is_err]\");
    let ok_result: Result<i32, String> = Ok(42);
    let err_result: Result<i32, String> = Err(\"мӢӨнҢЁ\".to_string());

    println!(\"Ok(42).is_ok() = {}\", ok_result.is_ok());
    println!(\"Err(...).is_err() = {}\", err_result.is_err());

    println!(\"\\n[unwrapкіј unwrap_or]\");
    println!(\"Ok(42).unwrap() = {}\", ok_result.unwrap());
    println!(\"Err(...).unwrap_or(0) = {}\", err_result.unwrap_or(0));

    println!(\"\\n[map: OkлҘј ліҖнҷҳ]\");
    let mapped = divide(10, 2).map(|x| x * 2);
    println!(\"divide(10, 2).map(|x| x * 2) = {:?}\", mapped);

    println!(\"\\n[map_err: Errмқ„ ліҖнҷҳ]\");
    let mapped_err = divide(10, 0)
        .map_err(|_| \"лӮҳлҲ—м…Ҳ мӢӨнҢЁ\".to_string());
    println!(\"divide(10, 0).map_err(...) = {:?}\", mapped_err);

    println!(\"\\n[and_then: ResultлҘј л°ҳнҷҳн•ҳлҠ” н•ЁмҲҳ м—°кІ°]\");
    let result = divide(10, 2)
        .and_then(|x| divide(x, 2));
    println!(\"divide(10, 2).and_then(|x| divide(x, 2)) = {:?}\", result);

    println!(\"\\n[or_else: Errмқј л•Ң лӢӨлҘё Result]\");
    let result = divide(10, 0)
        .or_else(|_| Ok(999));
    println!(\"divide(10, 0).or_else(|_| Ok(999)) = {:?}\", result);
}

