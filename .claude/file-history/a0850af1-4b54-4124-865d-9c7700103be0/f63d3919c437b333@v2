// ============================================================================
// [мҳҲм ң 1] Option<T> кё°ліё
// ============================================================================
fn search_user(users: &[(u32, &str)], id: u32) -> Option<String> {
    for (user_id, name) in users {
        if *user_id == id {
            return Some(name.to_string());
        }
    }
    None
}

fn option_basics() {
    println!(\"\\n[мҳҲм ң 1] Option<T> кё°ліё\");
    println!(\"в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\");

    let users = vec![(1, \"Alice\"), (2, \"Bob\"), (3, \"Charlie\")];

    // matchлЎң мІҳлҰ¬
    println!(\"\\n[нҢЁн„ҙ л§Өм№ӯ]\");
    match search_user(&users, 1) {
        Some(name) => println!(\"м°ҫмқҢ: {}\", name),
        None => println!(\"м°ҫм§Җ лӘ»н•Ё\"),
    }

    match search_user(&users, 99) {
        Some(name) => println!(\"м°ҫмқҢ: {}\", name),
        None => println!(\"м°ҫм§Җ лӘ»н•Ё\"),
    }

    // if letмңјлЎң к°„лӢЁн•ҳкІҢ
    println!(\"\\n[if let]\");
    if let Some(name) = search_user(&users, 2) {
        println!(\"мӮ¬мҡ©мһҗ мқҙлҰ„: {}\", name);
    }
}

