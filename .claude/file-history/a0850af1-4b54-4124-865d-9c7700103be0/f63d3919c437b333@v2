fn safe_divide_chain(a: i32, b: i32, c: i32) -> Result<i32, String> {
    // ? м—°мӮ°мһҗ: Errмқҙл©ҙ мҰүмӢң н•ЁмҲҳ л°ҳнҷҳ
    let result1 = divide(a, b)?;  // Errмқҙл©ҙ м—¬кё°м„ң л°ҳнҷҳ
    let result2 = divide(result1, c)?;  // Errмқҙл©ҙ м—¬кё°м„ң л°ҳнҷҳ
    Ok(result2)  // лӘЁл‘җ м„ұкіөн–Ҳмңјл©ҙ мөңмў… кІ°кіј
}

fn question_mark_operator() {
    println!(\"\\n[мҳҲм ң 5] ? м—°мӮ°мһҗ\");
    println!(\"в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\");

    println!(\"\\n[? м—°мӮ°мһҗ мӮ¬мҡ©]\");
    match safe_divide_chain(100, 5, 2) {
        Ok(result) => println!(\"100 Г· 5 Г· 2 = {}\", result),
        Err(e) => println!(\"м—җлҹ¬: {}\", e),
    }

    println!(\"\\n[мӢӨнҢЁ кІҪмҡ°]\");
    match safe_divide_chain(100, 0, 2) {
        Ok(result) => println!(\"100 Г· 0 Г· 2 = {}\", result),
        Err(e) => println!(\"м—җлҹ¬: {}\", e),
    }
}

