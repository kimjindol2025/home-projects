fn parse_positive_number(s: &str) -> Result<u32, String> {
    let n = s.parse::<i32>()
        .map_err(|_| \"мҲ«мһҗк°Җ м•„лӢҷлӢҲлӢӨ\".to_string())?;

    if n < 0 {
        return Err(\"мқҢмҲҳлҠ” н—Ҳмҡ©лҗҳм§Җ м•ҠмҠөлӢҲлӢӨ\".to_string());
    }

    Ok(n as u32)
}

fn chaining_operations() {
    println!(\"\\n[мҳҲм ң 7] л©”м„ңл“ң мІҙмқҙлӢқ\");
    println!(\"в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\");

    println!(\"\\n[Option мІҙмқҙлӢқ]\");
    let result = parse_number(\"42\")
        .map(|n| n * 2)
        .filter(|n| n > &50)
        .map(|n| format!(\"кІ°кіј: {}\", n))
        .unwrap_or(\"мӢӨнҢЁ\".to_string());
    println!(\"parse_number(\\\"42\\\") мІҙмқҙлӢқ = {}\", result);

    println!(\"\\n[Result мІҙмқҙлӢқ]\");
    let result = parse_positive_number(\"100\")
        .map(|n| n / 10)
        .and_then(|n| {
            if n > 5 {
                Ok(n * 2)
            } else {
                Err(\"к°’мқҙ л„Ҳл¬ҙ мһ‘мқҢ\".to_string())
            }
        });
    println!(\"parse_positive_number(\\\"100\\\") мІҙмқҙлӢқ = {:?}\", result);

    println!(\"\\n[мӢӨнҢЁ кІҪмҡ°]\");
    let result = parse_positive_number(\"-50\")
        .map(|n| n / 10)
        .unwrap_or(0);
    println!(\"parse_positive_number(\\\"-50\\\") мІҙмқҙлӢқ = {}\", result);
}

