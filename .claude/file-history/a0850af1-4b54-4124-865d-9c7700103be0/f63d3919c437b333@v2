#[derive(Debug)]
enum MathError {
    DivideByZero,
    NegativeNumber(String),
    OutOfRange,
}

impl fmt::Display for MathError {
    fn fmt(&self, f: &mut fmt::Formatter) -> fmt::Result {
        match self {
            MathError::DivideByZero => write!(f, \"0мңјлЎң лӮҳлҲҢ мҲҳ м—ҶмҠөлӢҲлӢӨ\"),
            MathError::NegativeNumber(msg) => write!(f, \"мқҢмҲҳ мҳӨлҘҳ: {}\", msg),
            MathError::OutOfRange => write!(f, \"лІ”мң„лҘј лІ—м–ҙлӮ¬мҠөлӢҲлӢӨ\"),
        }
    }
}

fn safe_divide_custom(a: i32, b: i32) -> Result<i32, MathError> {
    if b == 0 {
        return Err(MathError::DivideByZero);
    }
    if a < 0 || b < 0 {
        return Err(MathError::NegativeNumber(
            format!(\"a={}, b={}\", a, b),
        ));
    }
    Ok(a / b)
}

fn custom_error_types() {
    println!(\"\\n[мҳҲм ң 6] м»ӨмҠӨн…Җ м—җлҹ¬ нғҖмһ…\");
    println!(\"в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ\");

    println!(\"\\n[м„ұкіө]\");
    match safe_divide_custom(10, 2) {
        Ok(result) => println!(\"кІ°кіј: {}\", result),
        Err(e) => println!(\"м—җлҹ¬: {}\", e),
    }

    println!(\"\\n[0мңјлЎң лӮҳлҲ„кё°]\");
    match safe_divide_custom(10, 0) {
        Ok(result) => println!(\"кІ°кіј: {}\", result),
        Err(e) => println!(\"м—җлҹ¬: {}\", e),
    }

    println!(\"\\n[мқҢмҲҳ]\");
    match safe_divide_custom(-10, 2) {
        Ok(result) => println!(\"кІ°кіј: {}\", result),
        Err(e) => println!(\"м—җлҹ¬: {}\", e),
    }
}

