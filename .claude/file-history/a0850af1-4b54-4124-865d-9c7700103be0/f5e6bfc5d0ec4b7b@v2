/// Phase 14 v15.2: Conditional Branching & Backfilling
///
/// 백필링(Backfilling): 점프 명령어를 먼저 내뱉지만 점프할 주소는 나중에 채우는 기법
/// 이를 통해 if/else, while 루프 등의 비선형 제어 흐름을 구현합니다.

use std::fmt;

// ============================================================================
// OpCode 정의 (v15.2: 점프 명령어 추가)
// ============================================================================

#[repr(u8)]
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum OpCode {
    // 상수 & 연산 (v15.1)
    OpConstant = 0x00,

    OpAdd = 0x01,
    OpSubtract = 0x02,
    OpMultiply = 0x03,
    OpDivide = 0x04,

    OpEqual = 0x05,
    OpNotEqual = 0x06,
    OpGreaterThan = 0x07,
    OpLessThan = 0x08,
    OpLessThanOrEqual = 0x09,
    OpGreaterThanOrEqual = 0x0A,

    OpNot = 0x0B,
    OpReturn = 0x0C,
    OpPop = 0x0D,

    // 점프 명령어 (v15.2) ← 새로 추가!
    OpJump = 0x0E,
    OpJumpNotTruthy = 0x0F,
}

impl OpCode {
    pub fn operand_widths(&self) -> Vec<usize> {
        match self {
            OpCode::OpConstant => vec![2],
            OpCode::OpJump | OpCode::OpJumpNotTruthy => vec![2],
            _ => vec![],
        }
    }
}

impl From<u8> for OpCode {
    fn from(b: u8) -> Self {
        match b {
            0x00 => OpCode::OpConstant,
            0x01 => OpCode::OpAdd,
            0x02 => OpCode::OpSubtract,
            0x03 => OpCode::OpMultiply,
            0x04 => OpCode::OpDivide,
            0x05 => OpCode::OpEqual,
            0x06 => OpCode::OpNotEqual,
            0x07 => OpCode::OpGreaterThan,
            0x08 => OpCode::OpLessThan,
            0x09 => OpCode::OpLessThanOrEqual,
            0x0A => OpCode::OpGreaterThanOrEqual,
            0x0B => OpCode::OpNot,
            0x0C => OpCode::OpReturn,
            0x0D => OpCode::OpPop,
            0x0E => OpCode::OpJump,
            0x0F => OpCode::OpJumpNotTruthy,
            _ => OpCode::OpReturn,
        }
    }
}

impl fmt::Display for OpCode {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        match self {
            OpCode::OpConstant => write!(f, "OpConstant"),
            OpCode::OpAdd => write!(f, "OpAdd"),
            OpCode::OpSubtract => write!(f, "OpSubtract"),
            OpCode::OpMultiply => write!(f, "OpMultiply"),
            OpCode::OpDivide => write!(f, "OpDivide"),
            OpCode::OpEqual => write!(f, "OpEqual"),
            OpCode::OpNotEqual => write!(f, "OpNotEqual"),
            OpCode::OpGreaterThan => write!(f, "OpGreaterThan"),
            OpCode::OpLessThan => write!(f, "OpLessThan"),
            OpCode::OpLessThanOrEqual => write!(f, "OpLessThanOrEqual"),
            OpCode::OpGreaterThanOrEqual => write!(f, "OpGreaterThanOrEqual"),
            OpCode::OpNot => write!(f, "OpNot"),
            OpCode::OpReturn => write!(f, "OpReturn"),
            OpCode::OpPop => write!(f, "OpPop"),
            OpCode::OpJump => write!(f, "OpJump"),
            OpCode::OpJumpNotTruthy => write!(f, "OpJumpNotTruthy"),
        }
    }
}

