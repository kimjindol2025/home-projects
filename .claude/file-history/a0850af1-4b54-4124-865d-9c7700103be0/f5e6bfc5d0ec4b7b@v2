#[derive(Debug, Clone, PartialEq, Eq)]
pub enum CompileObject {
    Integer(i32),
    Float(i64),
    Boolean(bool),
    Null,
}

impl fmt::Display for CompileObject {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        match self {
            CompileObject::Integer(n) => write!(f, "{}", n),
            CompileObject::Float(n) => write!(f, "{}", n),
            CompileObject::Boolean(b) => write!(f, "{}", b),
            CompileObject::Null => write!(f, "null"),
        }
    }
}

// ============================================================================
// 바이트코드 정의
// ============================================================================

#[derive(Debug, Clone)]
pub struct Bytecode {
    pub instructions: Vec<u8>,
    pub constants: Vec<CompileObject>,
}

impl Bytecode {
    pub fn new() -> Self {
        Bytecode {
            instructions: Vec::new(),
            constants: Vec::new(),
        }
    }
}

// ============================================================================
// 백필링 메타데이터
// ============================================================================

#[derive(Debug, Clone)]
pub struct JumpPatch {
    pub position: usize,  // 수정할 OpJumpNotTruthy 명령어 위치
}

#[derive(Debug, Clone)]
pub struct CompilationScope {
    pub instructions: Vec<u8>,
    pub jump_patches: Vec<JumpPatch>,  // 수정 대기 중인 점프
}

// ============================================================================
// 컴파일러
// ============================================================================

pub struct Compiler {
    pub instructions: Vec<u8>,
    pub constants: Vec<CompileObject>,
    pub scopes: Vec<CompilationScope>,
    pub scope_index: usize,
}

impl Compiler {
    pub fn new() -> Self {
        Compiler {
            instructions: Vec::new(),
            constants: Vec::new(),
            scopes: vec![CompilationScope {
                instructions: Vec::new(),
                jump_patches: Vec::new(),
            }],
            scope_index: 0,
        }
    }

    // ========================================================================
    // 명령어 생성
    // ========================================================================

    /// OpCode와 피연산자를 명령어 스트림에 추가
    pub fn emit(&mut self, op: OpCode, operands: &[u16]) -> usize {
        let scope = &mut self.scopes[self.scope_index];
        let ins_len = scope.instructions.len();

        scope.instructions.push(op as u8);

        for &operand in operands {
            let bytes = operand.to_be_bytes();
            scope.instructions.push(bytes[0]);
            scope.instructions.push(bytes[1]);
        }

        ins_len
    }

    /// 이미 내보낸 명령어의 피연산자를 수정 (백필링의 핵심!)
    pub fn change_operand(&mut self, pos: usize, operand: u16) {
        let scope = &mut self.scopes[self.scope_index];

        let bytes = operand.to_be_bytes();
        scope.instructions[pos + 1] = bytes[0];
        scope.instructions[pos + 2] = bytes[1];
    }

    // ========================================================================
    // 상수 풀 관리
    // ========================================================================

    fn add_constant(&mut self, obj: CompileObject) -> usize {
        if let Some(idx) = self.constants.iter().position(|c| *c == obj) {
            return idx;
        }
        self.constants.push(obj);
        self.constants.len() - 1
    }

    // ========================================================================
    // if/else 컴파일 (백필링 사용)
    // ========================================================================

    /// if 조건문 컴파일
    ///
    /// if (condition) { consequence } [else { alternative }]
    pub fn compile_if_expression(
        &mut self,
        condition: i32,
        consequence_code: &str,
        alternative: Option<&str>,
    ) -> Result<(), String> {
        // 1. 조건식 컴파일
        let cond_idx = self.add_constant(CompileObject::Integer(condition));
        self.emit(OpCode::OpConstant, &[cond_idx as u16]);

        // 2. 거짓이면 점프 (점프할 주소는 아직 모름!)
        let jump_not_truthy_pos = self.emit(OpCode::OpJumpNotTruthy, &[0, 0]);

        // 3. 참 블록 컴파일
        for token in consequence_code.split_whitespace() {
            if token == "push" {
                if let Ok(n) = token.parse::<i32>() {
                    let idx = self.add_constant(CompileObject::Integer(n));
                    self.emit(OpCode::OpConstant, &[idx as u16]);
                }
            } else if let Ok(n) = token.parse::<i32>() {
                let idx = self.add_constant(CompileObject::Integer(n));
                self.emit(OpCode::OpConstant, &[idx as u16]);
            }
        }

        // 4. [백필링 핵심] 참 블록 끝났으니 실제 점프 주소 확정
        let after_consequence_pos = self.scopes[self.scope_index].instructions.len();
        self.change_operand(jump_not_truthy_pos, after_consequence_pos as u16);

        // 5. else 블록 처리
        if let Some(alt_code) = alternative {
            // else로 점프 (조건이 참이었으므로 else 건너뛰기)
            let jump_pos = self.emit(OpCode::OpJump, &[0, 0]);

            // else 블록 컴파일
            for token in alt_code.split_whitespace() {
                if let Ok(n) = token.parse::<i32>() {
                    let idx = self.add_constant(CompileObject::Integer(n));
                    self.emit(OpCode::OpConstant, &[idx as u16]);
                }
            }

            // [백필링] else 끝 위치 확정
            let after_alternative_pos = self.scopes[self.scope_index].instructions.len();
            self.change_operand(jump_pos, after_alternative_pos as u16);
        }

        Ok(())
    }

    // ========================================================================
    // while 루프 컴파일
    // ========================================================================

    /// while 루프 컴파일
    ///
    /// while (condition) { body }
    pub fn compile_while_loop(
        &mut self,
        condition: i32,
        body_code: &str,
    ) -> Result<(), String> {
        // 1. 루프 시작 위치 기록
        let loop_start = self.scopes[self.scope_index].instructions.len();

        // 2. 조건식 컴파일
        let cond_idx = self.add_constant(CompileObject::Integer(condition));
        self.emit(OpCode::OpConstant, &[cond_idx as u16]);

        // 3. 거짓이면 루프 탈출 (점프할 주소는 아직 모름!)
        let exit_jump_pos = self.emit(OpCode::OpJumpNotTruthy, &[0, 0]);

        // 4. 루프 본체 컴파일
        for token in body_code.split_whitespace() {
            if let Ok(n) = token.parse::<i32>() {
                let idx = self.add_constant(CompileObject::Integer(n));
                self.emit(OpCode::OpConstant, &[idx as u16]);
            }
        }

        // 5. 루프 시작으로 돌아가기 (후방 점프, 주소를 이미 알고 있음!)
        self.emit(OpCode::OpJump, &[loop_start as u16]);

        // 6. [백필링] 루프 탈출 위치 확정
        let after_loop_pos = self.scopes[self.scope_index].instructions.len();
        self.change_operand(exit_jump_pos, after_loop_pos as u16);

        Ok(())
    }

    // ========================================================================
    // 바이트코드 생성
    // ========================================================================

    pub fn bytecode(&self) -> Bytecode {
        Bytecode {
            instructions: self.scopes[self.scope_index].instructions.clone(),
            constants: self.constants.clone(),
        }
    }
}

// ============================================================================
// 역컴파일러
// ============================================================================

pub fn disassemble(bytecode: &Bytecode) -> String {
    let mut result = String::new();

    let mut offset = 0;
    while offset < bytecode.instructions.len() {
        let (line, next_offset) = disassemble_instruction(&bytecode.instructions, offset);
        result.push_str(&format!("{:04} {}\n", offset, line));
        offset = next_offset;
    }

    result
}

pub fn disassemble_instruction(instructions: &[u8], offset: usize) -> (String, usize) {
    if offset >= instructions.len() {
        return ("(end)".to_string(), offset + 1);
    }

    let op = OpCode::from(instructions[offset]);

    match op {
        OpCode::OpConstant => {
            if offset + 2 < instructions.len() {
                let const_idx = read_uint16(&instructions[offset + 1..]);
                (
                    format!("OpConstant {}", const_idx),
                    offset + 3,
                )
            } else {
                (format!("{} (incomplete)", op), offset + 1)
            }
        }
        OpCode::OpJump | OpCode::OpJumpNotTruthy => {
            if offset + 2 < instructions.len() {
                let target = read_uint16(&instructions[offset + 1..]);
                (
                    format!("{} {}", op, target),
                    offset + 3,
                )
            } else {
                (format!("{} (incomplete)", op), offset + 1)
            }
        }
        _ => {
            (
                op.to_string(),
                offset + 1,
            )
        }
    }
}

fn read_uint16(bytes: &[u8]) -> u16 {
    ((bytes[0] as u16) << 8) | (bytes[1] as u16)
}

