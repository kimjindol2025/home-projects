        compiler.compile_if_expression(1, "10", Some("20")).unwrap();
        let bc = compiler.bytecode();

        println!("  코드: if (1) {{ 10 }} else {{ 20 }}");
        println!("  바이트코드:");
        println!("{}", disassemble(&bc).lines().map(|l| format!("    {}", l)).collect::<Vec<_>>().join("\n"));

        // 백필링 검증
        println!("  [백필링 검증]");
        let op1 = OpCode::from(bc.instructions[3]);
        if op1 == OpCode::OpJumpNotTruthy {
            let target1 = read_uint16(&bc.instructions[4..]);
            println!("    위치 3: {} → 목표 {}", op1, target1);
        }
        println!();
    }

    // Demo 3: 거짓 조건
    println!("【Demo 3】거짓 조건 처리");
    {
        let mut compiler = Compiler::new();
        compiler.compile_if_expression(0, "10", Some("20")).unwrap();
        let bc = compiler.bytecode();

        println!("  코드: if (0) {{ 10 }} else {{ 20 }}  ← 0은 거짓");
        println!("  바이트코드:");
        println!("{}", disassemble(&bc).lines().map(|l| format!("    {}", l)).collect::<Vec<_>>().join("\n"));
        println!();
    }

    // Demo 4: while 루프
    println!("【Demo 4】while 루프 (후방 점프)");
    {
        let mut compiler = Compiler::new();
        compiler.compile_while_loop(1, "5").unwrap();
        let bc = compiler.bytecode();

        println!("  코드: while (1) {{ 5 }}");
        println!("  바이트코드:");
        println!("{}", disassemble(&bc).lines().map(|l| format!("    {}", l)).collect::<Vec<_>>().join("\n"));

        // 루프 검증
        println!("  [루프 검증]");
        println!("    조건식 검사 → 거짓이면 탈출");
        println!("    본체 실행");
        println!("    처음으로 돌아가기 (후방 점프)");
        println!();
    }

    // Demo 5: 중첩 if
    println!("【Demo 5】중첩 조건문");
    {
        println!("  코드:");
        println!("    if (5 > 3) {{");
        println!("      if (2 > 1) {{");
        println!("        100");
        println!("      }}");
        println!("    }}");

        let mut compiler = Compiler::new();
        // 첫 번째 조건
        let cond1_idx = compiler.add_constant(CompileObject::Integer(5));
        compiler.emit(OpCode::OpConstant, &[cond1_idx as u16]);
        let cond1b_idx = compiler.add_constant(CompileObject::Integer(3));
        compiler.emit(OpCode::OpConstant, &[cond1b_idx as u16]);
        compiler.emit(OpCode::OpGreaterThan, &[]);

        let jump1_pos = compiler.emit(OpCode::OpJumpNotTruthy, &[0, 0]);

        // 두 번째 조건 (중첩)
        let cond2_idx = compiler.add_constant(CompileObject::Integer(2));
        compiler.emit(OpCode::OpConstant, &[cond2_idx as u16]);
        let cond2b_idx = compiler.add_constant(CompileObject::Integer(1));
        compiler.emit(OpCode::OpConstant, &[cond2b_idx as u16]);
        compiler.emit(OpCode::OpGreaterThan, &[]);

        let jump2_pos = compiler.emit(OpCode::OpJumpNotTruthy, &[0, 0]);

        // 내부 블록
        let val_idx = compiler.add_constant(CompileObject::Integer(100));
        compiler.emit(OpCode::OpConstant, &[val_idx as u16]);

        let after2_pos = compiler.scopes[compiler.scope_index].instructions.len();
        compiler.change_operand(jump2_pos, after2_pos as u16);

        let after1_pos = compiler.scopes[compiler.scope_index].instructions.len();
        compiler.change_operand(jump1_pos, after1_pos as u16);

        let bc = compiler.bytecode();
        println!("  바이트코드:");
        println!("{}", disassemble(&bc).lines().map(|l| format!("    {}", l)).collect::<Vec<_>>().join("\n"));
