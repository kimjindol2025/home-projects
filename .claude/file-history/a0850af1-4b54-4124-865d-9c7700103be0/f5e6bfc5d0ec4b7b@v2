#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_simple_if() {
        let mut compiler = Compiler::new();
        compiler.compile_if_expression(1, "10", None).unwrap();
        let bc = compiler.bytecode();

        assert!(bc.instructions.len() > 0);
        assert_eq!(OpCode::from(bc.instructions[0]), OpCode::OpConstant);
        assert_eq!(OpCode::from(bc.instructions[3]), OpCode::OpJumpNotTruthy);
    }

    #[test]
    fn test_if_else_backfilling() {
        let mut compiler = Compiler::new();
        compiler.compile_if_expression(1, "10", Some("20")).unwrap();
        let bc = compiler.bytecode();

        // OpJumpNotTruthy 위치 확인
        let jump_target = read_uint16(&bc.instructions[4..]);
        // 점프 대상이 0이 아님 (백필링되었음)
        assert!(jump_target > 0);
    }

    #[test]
    fn test_while_loop_backward_jump() {
        let mut compiler = Compiler::new();
        compiler.compile_while_loop(1, "5").unwrap();
        let bc = compiler.bytecode();

        // 루프 시작 위치로 돌아가는 OpJump 찾기
        let mut found_backward_jump = false;
        let mut offset = 0;
        while offset < bc.instructions.len() {
            let op = OpCode::from(bc.instructions[offset]);
            if op == OpCode::OpJump {
                let target = read_uint16(&bc.instructions[offset + 1..]);
                if target == 0 {
                    found_backward_jump = true;
                }
            }
            offset += 1;
        }
        assert!(found_backward_jump);
    }

    #[test]
    fn test_nested_if() {
        let mut compiler = Compiler::new();

        let cond1_idx = compiler.add_constant(CompileObject::Integer(5));
        compiler.emit(OpCode::OpConstant, &[cond1_idx as u16]);
        let jump1_pos = compiler.emit(OpCode::OpJumpNotTruthy, &[0, 0]);

        let cond2_idx = compiler.add_constant(CompileObject::Integer(3));
        compiler.emit(OpCode::OpConstant, &[cond2_idx as u16]);
        let jump2_pos = compiler.emit(OpCode::OpJumpNotTruthy, &[0, 0]);

        let inner_idx = compiler.add_constant(CompileObject::Integer(100));
        compiler.emit(OpCode::OpConstant, &[inner_idx as u16]);

        let after_inner = compiler.scopes[compiler.scope_index].instructions.len();
        compiler.change_operand(jump2_pos, after_inner as u16);

        let after_outer = compiler.scopes[compiler.scope_index].instructions.len();
        compiler.change_operand(jump1_pos, after_outer as u16);

        let bc = compiler.bytecode();
        assert!(bc.instructions.len() > 0);
    }

    #[test]
    fn test_change_operand() {
        let mut compiler = Compiler::new();
        let pos = compiler.emit(OpCode::OpJump, &[0, 0]);
        compiler.change_operand(pos, 42);

        let bc = compiler.bytecode();
        let target = read_uint16(&bc.instructions[pos + 1..]);
        assert_eq!(target, 42);
    }

    #[test]
    fn test_disassemble_jump() {
        let mut compiler = Compiler::new();
        compiler.emit(OpCode::OpJump, &[100]);
        compiler.emit(OpCode::OpReturn, &[]);

        let bc = compiler.bytecode();
        let disasm = disassemble(&bc);
        assert!(disasm.contains("OpJump"));
        assert!(disasm.contains("100"));
    }

    #[test]
    fn test_backward_jump_in_loop() {
        let mut compiler = Compiler::new();
        compiler.compile_while_loop(1, "5").unwrap();

        let bc = compiler.bytecode();
        // 루프는 조건 검사로 시작해야 함
        assert_eq!(OpCode::from(bc.instructions[0]), OpCode::OpConstant);

        // OpJump가 있어야 함
        let has_jump = bc.instructions.iter().any(|&b| OpCode::from(b) == OpCode::OpJump);
        assert!(has_jump);
    }

    #[test]
    fn test_if_false_condition() {
        let mut compiler = Compiler::new();
        compiler.compile_if_expression(0, "10", Some("20")).unwrap();
        let bc = compiler.bytecode();

        assert!(bc.instructions.len() > 0);
        // 거짓 조건(0)도 컴파일되어야 함
        assert_eq!(OpCode::from(bc.instructions[0]), OpCode::OpConstant);
    }

    #[test]
    fn test_multiple_constants() {
        let mut compiler = Compiler::new();
        compiler.compile_if_expression(5, "10 20 30", Some("40 50")).unwrap();

        let bc = compiler.bytecode();
        // 여러 상수가 풀에 저장되어야 함
        assert!(bc.constants.len() >= 4);
    }

    #[test]
    fn test_opcode_width() {
        assert_eq!(OpCode::OpConstant.operand_widths(), vec![2]);
        assert_eq!(OpCode::OpJump.operand_widths(), vec![2]);
        assert_eq!(OpCode::OpAdd.operand_widths(), vec![]);
    }

    #[test]
    fn test_backfilling_accuracy() {
        let mut compiler = Compiler::new();

        // 정확한 점프 거리 검증
        let cond_idx = compiler.add_constant(CompileObject::Integer(1));
        compiler.emit(OpCode::OpConstant, &[cond_idx as u16]);

        let jump_pos = compiler.emit(OpCode::OpJumpNotTruthy, &[0, 0]);

        // 10바이트 분량의 코드 추가
        for i in 0..5 {
            let idx = compiler.add_constant(CompileObject::Integer(i));
            compiler.emit(OpCode::OpConstant, &[idx as u16]);
        }

        let target_pos = compiler.scopes[compiler.scope_index].instructions.len();
        compiler.change_operand(jump_pos, target_pos as u16);

        let bc = compiler.bytecode();
        let actual_target = read_uint16(&bc.instructions[jump_pos + 1..]);
        assert_eq!(actual_target, target_pos as u16);
    }
