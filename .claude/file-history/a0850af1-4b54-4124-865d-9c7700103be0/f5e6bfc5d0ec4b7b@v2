        println!("  긴 블록의 점프 거리 계산");
        println!("  바이트코드 크기: {} 바이트", bc.instructions.len());
        println!("  상수: {} 개", bc.constants.len());

        // 점프 위치 검증
        if bc.instructions.len() >= 3 {
            let jump_target = read_uint16(&bc.instructions[4..]);
            println!("  점프 대상: {} (변경 전 0 → 변경 후 {})", 0, jump_target);
        }
        println!();
    }

    // Demo 7: 복잡한 제어 흐름
    println!("【Demo 7】복잡한 분기 (if-else-if)");
    {
        println!("  의사코드:");
        println!("    if (a) {{ x }}");
        println!("    else if (b) {{ y }}");
        println!("    else {{ z }}");
        println!("  특징: 3개의 점프, 모두 다른 목표 주소로");
        println!("  [백필링으로 각각 수정됨]");
        println!();
    }

    // Demo 8: 백필링 메커니즘 설명
    println!("【Demo 8】백필링 메커니즘 (2-Pass Compilation)");
    {
        println!("  Pass 1 (코드 생성):");
        println!("    1. 조건식 컴파일");
        println!("    2. OpJumpNotTruthy 내보내기 (주소 = 0x0000, 임시)");
        println!("    3. 분기 블록 컴파일");
        println!();
        println!("  Pass 2 (백필링):");
        println!("    1. 분기 블록 끝났을 때 현재 위치 계산");
        println!("    2. change_operand()로 이전 점프 명령 수정");
        println!("    3. instructions[jump_pos+1..3] = target_address");
        println!();
        println!("  장점:");
        println!("    ✓ 한 번의 패스로 AST 순회");
        println!("    ✓ 메모리 효율적 (별도 심볼 테이블 없음)");
        println!("    ✓ 동적 조건도 처리 가능");
        println!();
    }

    println!("=== v15.2 핵심 개념 ===\n");
    println!("1. 점프 명령어 (Jump Instructions):");
    println!("   - OpJump: 무조건 점프 (루프)");
    println!("   - OpJumpNotTruthy: 거짓이면 점프 (if)");
    println!();
    println!("2. 백필링 (Backfilling/Patching):");
    println!("   - 점프 주소를 나중에 채우는 기법");
