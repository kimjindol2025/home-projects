// Phase 12 v13.0.2: Recursive Macros and DSL Design (재귀적 매크로와 DSL 설계)
// 미니 컴파일러로서의 매크로 - 복잡한 구조를 분할 정복하라

// =============================================================================
// Demo 1: 기본 재귀 - Base Case + Recursive Case 패턴
// =============================================================================

macro_rules! count_items {
    // Base case: 종료 조건 (빈 경우)
    () => {
        0
    };

    // Recursive case: 첫 항목 처리 + 나머지 재귀
    ($head:tt $($tail:tt)*) => {
        1 + count_items!($($tail)*)
    };
}

macro_rules! print_each {
    // 종료 조건
    () => {
        println!("  [완료]");
    };

    // 첫 항목 출력 + 나머지 재귀
    ($head:expr, $($tail:expr),*) => {
        println!("    • 항목: {}", $head);
        print_each!($($tail),*);
    };

    // 마지막 항목 (쉼표 없음)
    ($last:expr) => {
        println!("    • 항목: {}", $last);
        println!("  [완료]");
    };
}

fn demo_basic_recursion() {
    println!("\n=== Demo 1: 기본 재귀 매크로 ===");

    println!("  [재귀적 항목 개수 세기]");
    let count1 = count_items!(a b c d e);
    println!("    count_items!(a b c d e) = {}", count1);

    let count2 = count_items!(x y);
    println!("    count_items!(x y) = {}", count2);

    let count3 = count_items!();
    println!("    count_items!() = {}", count3);

    println!("\n  [재귀적 항목 출력]");
    print_each!("첫번째", "두번째", "세번째", "네번째", "다섯번째");

    println!("\n  [원리]");
    println!("    • Base case: () → 0 또는 종료");
    println!("    • Recursive case: 첫 항목 처리 + 나머지 재귀");
    println!("    • count_items!(a b c d e)");
    println!("      = 1 + count_items!(b c d e)");
    println!("      = 1 + 1 + count_items!(c d e)");
    println!("      = 1 + 1 + 1 + count_items!(d e)");
    println!("      = 1 + 1 + 1 + 1 + count_items!(e)");
    println!("      = 1 + 1 + 1 + 1 + 1 + count_items!()");
    println!("      = 5");
}

// =============================================================================
// Demo 2: 설정 DSL - key => value 문법
// =============================================================================

macro_rules! config {
    // Base case: 종료
    () => {
        vec![]
    };

    // Recursive case: 첫 설정 처리 + 나머지 재귀
    ($key:ident => $val:expr, $($rest:tt)*) => {
        {
            let mut _items = vec![
                format!("{} = {}", stringify!($key), $val)
            ];
            let mut _rest = config!($($rest)*);
            _items.append(&mut _rest);
            _items
        }
    };

    // 마지막 항목 (쉼표 없음)
    ($key:ident => $val:expr) => {
        vec![format!("{} = {}", stringify!($key), $val)]
    };
}

fn demo_config_dsl() {
    println!("\n=== Demo 2: 설정 DSL (Configuration Language) ===");

    println!("  [직관적 설정 문법]");
    let config_result = config!(
        version => "1.0",
        debug => true,
        max_workers => 8,
        timeout => 30
    );

    println!("    설정 로드 완료:");
    for item in config_result {
        println!("      • {}", item);
    }

    println!("\n  [동작 원리]");
    println!("    • 사용자 친화적 문법: version => \"1.0\"");
    println!("    • key => value 패턴 인식");
    println!("    • 첫 설정 처리 후 나머지 재귀");
    println!("    • 복잡한 구조를 간단하게");
    println!("\n  [비교]");
    println!("    ❌ config_parse(vec![(\"version\", \"1.0\"), ...])");
    println!("    ✅ config!(version => \"1.0\", ...)");
}

// =============================================================================
// Demo 3: 빌더 패턴 DSL (@ 마커로 내부 규칙 분리)
// =============================================================================

macro_rules! build_system {
    // Recursive case: 첫 규칙 출력 + 나머지 재귀
    ($rule:expr, $($rest:expr),*) => {
        println!("      • {}", $rule);
        build_system!($($rest),*);
    };

    // Base case: 마지막 규칙
    ($rule:expr) => {
        println!("      • {}", $rule);
    };
}

fn demo_builder_pattern() {
    println!("\n=== Demo 3: 빌더 패턴 DSL (내부 규칙 분리) ===");

    println!("  [재귀적 규칙 처리]");
    println!("    시스템 빌드 규칙:");
    build_system!(
        "캐시 초기화",
        "연결 풀 생성",
        "리스너 시작",
        "워커 스레드 시작"
    );

    println!("\n  [@ 마커의 역할]");
    println!("    • build_system!(...) - 공개 인터페이스 (사용자가 호출)");
    println!("    • @impl, @rules 등 - 내부 구현 (캡슐화)");
    println!("    • 사용자는 공개 인터페이스만 알면 됨");
    println!("\n  [이점]");
    println!("    • 공개 API가 명확함");
    println!("    • 복잡한 내부 구조가 숨겨짐");
    println!("    • 재귀적 처리가 자동화됨");
}

// =============================================================================
// Demo 4: 상태 머신 DSL
// =============================================================================

macro_rules! state_machine {
    // Base case
    () => {
        println!("  [상태 전이 완료]");
    };

    // Recursive case
    ($state:expr => $next:expr, $($rest:tt)*) => {
        println!("    {} → {}", $state, $next);
        state_machine!($($rest)*)
    };

    // 마지막
    ($state:expr => $next:expr) => {
        println!("    {} → {}", $state, $next);
        println!("  [상태 전이 완료]");
    };
}

fn demo_state_machine() {
    println!("\n=== Demo 4: 상태 머신 DSL ===");

    println!("  [상태 전이 정의]");
    state_machine!(
        "시작" => "대기",
        "대기" => "실행",
        "실행" => "완료",
        "완료" => "종료"
    );

    println!("\n  [용도]");
    println!("    • 상태 다이어그램을 코드로 표현");
    println!("    • 컴파일 타임 상태 검증 (가능)");
    println!("    • 프로토콜 상태 머신 정의");
}

// =============================================================================
// Demo 5: 규칙 엔진 DSL
// =============================================================================

macro_rules! rule_engine {
    // Base case
    () => {
        println!("  [규칙 평가 완료]");
    };

    // Recursive case
    (when $cond:expr, then $action:expr; $($rest:tt)*) => {
        if $cond {
            println!("    [규칙 매칭] {}", $action);
        }
        rule_engine!($($rest)*)
    };

    // 마지막
    (when $cond:expr, then $action:expr) => {
        if $cond {
            println!("    [규칙 매칭] {}", $action);
        }
        println!("  [규칙 평가 완료]");
    };
}

fn demo_rule_engine() {
    println!("\n=== Demo 5: 규칙 엔진 DSL ===");

    println!("  [선언적 규칙 정의]");
    let score = 85;
    rule_engine!(
        when score >= 90, then "등급: A";
        when score >= 80, then "등급: B";
        when score >= 70, then "등급: C";
        when score >= 60, then "등급: D"
    );

    println!("\n  [다른 예: 배포 규칙]");
    let cpu_usage = 95;
    let memory_usage = 88;
    rule_engine!(
        when cpu_usage > 90, then "경고: CPU 높음";
        when memory_usage > 85, then "경고: 메모리 높음";
        when cpu_usage > 90 && memory_usage > 85, then "긴급: 리소스 부족"
    );

    println!("\n  [특징]");
    println!("    • when-then 문법으로 직관적");
    println!("    • Prolog처럼 선언적");
    println!("    • 규칙 추가가 쉬움");
}

// =============================================================================
// Demo 6: 복잡한 트리 구조 DSL (재귀적 중첩)
// =============================================================================

macro_rules! tree_node {
    // Leaf node (종료)
    ($val:expr) => {
        format!("[{}]", $val)
    };

    // Left child only
    ($val:expr => left $l:expr) => {
        format!("[{}]←L:{}", $val, tree_node!($l))
    };

    // Both children
    ($val:expr => left $l:expr, right $r:expr) => {
        format!("[{}]←L:{}|R:{}", $val, tree_node!($l), tree_node!($r))
    };
}

fn demo_tree_structure() {
    println!("\n=== Demo 6: 복잡한 트리 구조 DSL (재귀적 중첩) ===");

    println!("  [간단한 리프 노드]");
    let t1 = tree_node!(1);
    println!("    {}", t1);

    println!("\n  [좌측 자식만]");
    let t2 = tree_node!(1 => left 2);
    println!("    {}", t2);

    println!("\n  [양쪽 자식]");
    let t3 = tree_node!(1 => left 2, right 3);
    println!("    {}", t3);

    println!("\n  [깊은 중첩 구조]");
    let t4 = tree_node!(1 =>
        left (tree_node!(2)),
        right (tree_node!(3 => left 4, right 5))
    );
    println!("    {}", t4);

    println!("\n  [원리]");
    println!("    • tree_node!(val) - 기본 리프 노드");
    println!("    • tree_node!(val => left ...) - 재귀적 좌측 확장");
    println!("    • tree_node!(val => left ..., right ...) - 양쪽 재귀");
    println!("\n  [이점]");
    println!("    • ❌ 기존: Node {{ value: 1, left: Some(Box::new(...)) }}");
    println!("    • ✅ DSL: tree_node!(1 => left 2, right 3)");
    println!("    • 재귀를 통해 임의 깊이 표현 가능");
}

