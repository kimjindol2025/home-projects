"""
FreeLang CLI 진입점
"""

import sys
import argparse
from pathlib import Path
from .lexer import Lexer
from .errors import FreeLangError


def main():
    """메인 진입점"""
    parser = argparse.ArgumentParser(
        description="FreeLang - Python 구현",
        prog="freelang"
    )
    parser.add_argument("file", help="FreeLang 소스 파일 (.fl)")
    parser.add_argument("--dump-tokens", action="store_true", help="토큰 출력")
    parser.add_argument("--dump-ast", action="store_true", help="AST 출력")
    parser.add_argument("--dump-bc", action="store_true", help="바이트코드 출력")

    args = parser.parse_args()

    # 파일 읽기
    try:
        file_path = Path(args.file)
        if not file_path.exists():
            print(f"Error: 파일을 찾을 수 없습니다: {args.file}", file=sys.stderr)
            sys.exit(1)

        source_code = file_path.read_text(encoding="utf-8")
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)

    # 어휘 분석
    try:
        lexer = Lexer(source_code)
        tokens = lexer.tokenize()

        if args.dump_tokens:
            print("=== Tokens ===")
            for token in tokens:
                print(token)
            return

        print("✓ 어휘 분석 완료")

    except FreeLangError as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
