class Observer(ABC):
    """옵저버: 상태 변화를 감시하는 객체"""

    @abstractmethod
    def update(self, subject: 'Subject') -> None:
        pass


class Subject:
    """주체: 상태를 가지고 옵저버들에게 알림"""

    def __init__(self):
        self._observers: List[Observer] = []
        self._state = None

    def attach(self, observer: Observer) -> None:
        """옵저버 등록"""
        if observer not in self._observers:
            self._observers.append(observer)

    def detach(self, observer: Observer) -> None:
        """옵저버 해제"""
        if observer in self._observers:
            self._observers.remove(observer)

    def notify(self) -> None:
        """모든 옵저버에게 알림"""
        for observer in self._observers:
            observer.update(self)

    @property
    def state(self):
        return self._state

    @state.setter
    def state(self, value):
        self._state = value
        self.notify()


class EmailNotifier(Observer):
    """이메일 알림"""

    def update(self, subject: Subject) -> None:
        print(f"   📧 이메일 알림: 상태 변경됨 → {subject.state}")


class SMSNotifier(Observer):
    """SMS 알림"""

    def update(self, subject: Subject) -> None:
        print(f"   📱 SMS 알림: 상태 변경됨 → {subject.state}")


class SlackNotifier(Observer):
    """Slack 알림"""

    def update(self, subject: Subject) -> None:
        print(f"   💬 Slack 알림: 상태 변경됨 → {subject.state}")


class Strategy(ABC):
    """전략: 알고리즘을 캡슐화"""

    @abstractmethod
    def execute(self, data: Any) -> Any:
        pass


class QuickSortStrategy(Strategy):
    """Quick Sort 전략"""

    def execute(self, data: List[int]) -> List[int]:
        return sorted(data)


class MergeSortStrategy(Strategy):
    """Merge Sort 전략"""

    def execute(self, data: List[int]) -> List[int]:
        return sorted(data)  # 실제로는 다른 구현


class HeapSortStrategy(Strategy):
    """Heap Sort 전략"""

    def execute(self, data: List[int]) -> List[int]:
        return sorted(data)  # 실제로는 다른 구현


class DataSorter:
    """데이터 정렬기: Strategy 패턴 사용"""

    def __init__(self, strategy: Strategy):
        self._strategy = strategy

    def set_strategy(self, strategy: Strategy) -> None:
        """런타임에 전략 변경"""
        self._strategy = strategy

    def sort(self, data: List[int]) -> List[int]:
        """현재 전략으로 정렬"""
        return self._strategy.execute(data)


class TemplateMethod(ABC):
    """템플릿 메서드: 알고리즘의 골격을 정의"""

    def process(self) -> None:
        """템플릿 메서드: 전체 프로세스의 골격"""
        self.step1_initialize()
        self.step2_validate()
        self.step3_execute()
        self.step4_finalize()

    def step1_initialize(self) -> None:
        print("   1️⃣ 초기화 중...")

    @abstractmethod
    def step2_validate(self) -> None:
        """서브클래스에서 구현"""
        pass

    @abstractmethod
    def step3_execute(self) -> None:
        """서브클래스에서 구현"""
        pass

    def step4_finalize(self) -> None:
        print("   4️⃣ 종료 중...")


class PaymentTemplate(TemplateMethod):
    """결제 프로세스: 템플릿 메서드 사용"""

    def step2_validate(self) -> None:
        print("   2️⃣ 결제 정보 검증 중...")

    def step3_execute(self) -> None:
        print("   3️⃣ 결제 처리 중...")


class RefundTemplate(TemplateMethod):
    """환불 프로세스: 템플릿 메서드 사용"""

    def step2_validate(self) -> None:
        print("   2️⃣ 환불 가능 여부 확인 중...")

    def step3_execute(self) -> None:
        print("   3️⃣ 환불 처리 중...")


def demonstrate_behavioral_patterns():
    """행위 패턴 시연"""
    print("\n" + "="*80)
    print("STAGE 4: 행위 패턴 (Behavioral Patterns)")
    print("="*80)

    # Observer 패턴
    print("\n📊 Observer 패턴: 상태 변화 알림")
    subject = Subject()

    email = EmailNotifier()
    sms = SMSNotifier()
    slack = SlackNotifier()

    subject.attach(email)
    subject.attach(sms)
    subject.attach(slack)

    print("   상태 변경 → 모든 옵저버에게 알림:")
