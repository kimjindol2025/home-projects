    # Strategy 패턴
    print("\n📊 Strategy 패턴: 런타임에 알고리즘 변경")
    data = [3, 1, 4, 1, 5, 9, 2, 6]

    sorter = DataSorter(QuickSortStrategy())
    print(f"   QuickSort로 정렬: {sorter.sort(data)}")

    sorter.set_strategy(MergeSortStrategy())
    print(f"   전략 변경 → MergeSort로 정렬: {sorter.sort(data)}")

    # Template Method 패턴
    print("\n📊 Template Method 패턴: 알고리즘 골격 정의")
    print("   결제 프로세스:")
    payment = PaymentTemplate()
    payment.process()

    print("\n   환불 프로세스:")
    refund = RefundTemplate()
    refund.process()


