class Singleton:
    """싱글톤 패턴: 객체가 단 하나만 존재하도록 보장"""
    _instances: Dict[type, Any] = {}

    def __new__(cls, *args, **kwargs):
        if cls not in cls._instances:
            cls._instances[cls] = super().__new__(cls)
        return cls._instances[cls]


class SystemLogger(Singleton):
    """시스템 로거: 애플리케이션 전체에서 단 하나의 인스턴스"""

    def __init__(self):
        if not hasattr(self, 'initialized'):
            self.logs: List[str] = []
            self.initialized = True

    def log(self, message: str, level: str = "INFO") -> None:
        """로그 기록"""
        timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        log_entry = f"[{timestamp}] [{level}] {message}"
        self.logs.append(log_entry)

    def get_logs(self) -> List[str]:
        """모든 로그 반환"""
        return self.logs


class DatabaseConnection(Singleton):
    """데이터베이스 연결: 연결 풀 관리"""

    def __init__(self):
        if not hasattr(self, 'initialized'):
            self.connection_count = 0
            self.initialized = True

    def connect(self) -> str:
        """데이터베이스 연결"""
        self.connection_count += 1
        return f"DB Connection #{self.connection_count}"


class Factory:
    """팩토리 패턴: 객체 생성 로직을 캡슐화"""
    pass


class PaymentProcessor(ABC):
    """결제 프로세서: 추상 인터페이스"""

    @abstractmethod
    def process_payment(self, amount: float) -> bool:
        pass


class CreditCardProcessor(PaymentProcessor):
    """신용카드 결제"""

    def process_payment(self, amount: float) -> bool:
        return f"💳 신용카드로 ${amount} 결제 완료"


class PayPalProcessor(PaymentProcessor):
    """PayPal 결제"""

    def process_payment(self, amount: float) -> bool:
        return f"🅿️ PayPal로 ${amount} 결제 완료"


class CryptoProcessor(PaymentProcessor):
    """암호화폐 결제"""

    def process_payment(self, amount: float) -> bool:
        return f"₿ 암호화폐로 ${amount} 결제 완료"


class PaymentFactory:
    """결제 프로세서 생성 팩토리"""

    _processors: Dict[str, type] = {
        "credit_card": CreditCardProcessor,
        "paypal": PayPalProcessor,
        "crypto": CryptoProcessor,
    }

    @classmethod
    def create(cls, payment_type: str) -> PaymentProcessor:
        """결제 방식에 따라 적절한 프로세서 반환"""
        processor_class = cls._processors.get(payment_type)
        if processor_class is None:
            raise ValueError(f"Unknown payment type: {payment_type}")
        return processor_class()


