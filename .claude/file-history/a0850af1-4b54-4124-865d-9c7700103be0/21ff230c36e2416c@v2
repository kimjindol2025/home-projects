def demonstrate_refactoring():
    """리팩터링 기법 시연"""
    print("\n" + "="*80)
    print("STAGE 6: 리팩터링 기법")
    print("="*80)

    # Before: 나쁜 코드
    print("\n❌ Before (나쁜 코드):")
    print("""
    def process_user_data(u):
        if u['age'] >= 18 and u['status'] == 'active' and u['credit'] > 100:
            if u['country'] in ['US', 'UK', 'CA']:
                return u['salary'] * 0.9
            else:
                return u['salary'] * 0.8
        else:
            return 0
    """)

    # After: 리팩터링된 코드
    print("\n✅ After (리팩터링된 코드):")
    print("""
    def is_eligible_for_bonus(user: Dict) -> bool:
        \"\"\"사용자가 보너스 대상인지 확인\"\"\"
        return (
            user['age'] >= 18 and
            user['status'] == 'active' and
            user['credit'] > 100
        )

    def get_bonus_rate(country: str) -> float:
        \"\"\"국가별 보너스 비율\"\"\"
        developed_countries = {'US', 'UK', 'CA'}
