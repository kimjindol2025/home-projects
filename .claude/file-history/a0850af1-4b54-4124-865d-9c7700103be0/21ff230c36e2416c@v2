class Adapter:
    """어댑터 패턴: 호환되지 않는 인터페이스를 연결"""

    def __init__(self, object_):
        self.object = object_

    def get_data(self):
        return self.object.fetch_data()


class OldSystem:
    """기존 레거시 시스템"""

    def fetch_data(self) -> str:
        return '{"user": "John", "age": 30}'  # 구식 JSON


class NewSystem:
    """새로운 시스템"""

    def get_info(self) -> Dict:
        return {"user": "John", "age": 30}  # 현대식 Dict


class LegacyAdapter:
    """기존 시스템을 새로운 시스템에 적응시키는 어댑터"""

    def __init__(self, legacy_system: OldSystem):
        self.legacy = legacy_system

    def get_info(self) -> Dict:
        """기존 시스템의 데이터를 변환"""
        data_str = self.legacy.fetch_data()
        return json.loads(data_str)


class Facade:
    """파사드 패턴: 복잡한 시스템을 단순한 인터페이스로 제공"""
    pass


class PaymentFacade:
    """결제 시스템 파사드: 복잡한 결제 프로세스를 단순화"""

    def __init__(self):
        self.logger = SystemLogger()
        self.db = DatabaseConnection()

    def process_order(self, user_id: int, amount: float, payment_type: str) -> bool:
        """주문 처리의 복잡한 과정을 단일 메서드로 제공"""
        try:
            # 1. 로깅
            self.logger.log(f"Order started for user {user_id}, amount ${amount}")

            # 2. DB 연결
            connection = self.db.connect()
            self.logger.log(f"Connected: {connection}")

            # 3. 결제 처리
            processor = PaymentFactory.create(payment_type)
            payment_result = processor.process_payment(amount)
            self.logger.log(f"Payment: {payment_result}")

            # 4. 주문 저장
            self.logger.log(f"Order saved for user {user_id}")

            return True
        except Exception as e:
            self.logger.log(f"Order failed: {str(e)}", "ERROR")
            return False


class Proxy:
    """프록시 패턴: 객체에 대한 접근 제어"""
    pass


class ExpensiveResource:
    """비용이 많이 드는 리소스"""

    def __init__(self, data: str):
        print(f"   🔄 비용이 많이 드는 리소스 로딩: {data}")
        self.data = data
        time.sleep(0.1)  # 로딩 시뮬레이션

    def get_data(self) -> str:
        return self.data


class ResourceProxy:
    """비용이 많이 드는 리소스에 대한 프록시 (지연 로딩)"""

    def __init__(self, data: str):
        self.data = data
        self.resource: Optional[ExpensiveResource] = None

    def get_data(self) -> str:
        """처음 접근할 때만 실제 리소스 생성"""
        if self.resource is None:
            self.resource = ExpensiveResource(self.data)
        return self.resource.get_data()


