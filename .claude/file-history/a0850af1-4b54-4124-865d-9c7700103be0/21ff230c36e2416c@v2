@dataclass
class TechnicalDebt:
    """기술 부채 추적"""
    name: str
    description: str
    impact: str  # High, Medium, Low
    effort_to_fix: str  # High, Medium, Low
    date_identified: str


class TechnicalDebtTracker:
    """기술 부채 추적 시스템"""

    def __init__(self):
        self.debts: List[TechnicalDebt] = []

    def add_debt(self, debt: TechnicalDebt) -> None:
        """기술 부채 등록"""
        self.debts.append(debt)

    def get_urgent_debts(self) -> List[TechnicalDebt]:
        """긴급 기술 부채 (영향도 높음, 해결 쉬움)"""
        return [d for d in self.debts if d.impact == "High" and d.effort_to_fix == "Low"]

    def get_priority_debts(self) -> List[TechnicalDebt]:
        """우선순위 기술 부채"""
        return sorted(
            [d for d in self.debts if d.impact == "High"],
            key=lambda x: (x.effort_to_fix == "Low", x.effort_to_fix == "Medium"),
            reverse=True
        )


