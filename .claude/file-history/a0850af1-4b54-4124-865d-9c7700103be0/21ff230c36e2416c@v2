@dataclass
class User:
    """사용자 객체"""
    id: int
    name: str
    email: str
    preferences: Dict = field(default_factory=dict)


class MusicStreamingService:
    """뮤직 스트리밍 서비스: 모든 패턴 활용"""

    def __init__(self):
        self.logger = SystemLogger()
        self.users: Dict[int, User] = {}
        self.user_id_counter = 1

    def register_user(self, name: str, email: str) -> User:
        """사용자 등록 (Factory)"""
        user = User(self.user_id_counter, name, email)
        self.users[self.user_id_counter] = user
        self.user_id_counter += 1

        self.logger.log(f"User registered: {name}")
        return user

    def get_user_preferences(self, user_id: int) -> Dict:
        """사용자 선호도 조회 (Facade)"""
        if user_id not in self.users:
            self.logger.log(f"User {user_id} not found", "ERROR")
            return {}

        return self.users[user_id].preferences

    def recommend_songs(self, user_id: int, strategy: Strategy) -> List[str]:
        """곡 추천 (Strategy)"""
        if user_id not in self.users:
            return []

        recommendations = ["Song A", "Song B", "Song C"]
        self.logger.log(f"Recommendations for user {user_id}")
        return recommendations


