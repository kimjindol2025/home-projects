//! Unit tests for FreeLang VM
//!
//! Tests individual VM components and instructions

use freelang_vm::vm::VM;
use freelang_vm::bytecode::{BytecodeLoader, Opcode};
use freelang_vm::memory::Memory;
use freelang_vm::gc::GarbageCollector;

// ====== Bytecode Loader Tests ======

#[test]
fn test_bytecode_loader_valid_empty_program() {
    // Valid bytecode with HALT instruction
    let data = vec![
        0x46, 0x4C, 0x56, 0x4D, // Magic: FLVM
        0x01, 0x00,             // Version: 0x0100
        0x00, 0x00,             // Flags: 0x0000
        0x00, 0x00, 0x00, 0x01, // Code size: 1
        0x00, 0x00, 0x00, 0x10, // Code offset: 16
        0x61,                   // HALT opcode
    ];

    let loader = BytecodeLoader::new(&data);
    assert!(loader.is_ok());
}

#[test]
fn test_bytecode_loader_invalid_magic() {
    let data = vec![
        0xFF, 0xFF, 0xFF, 0xFF, // Invalid magic
        0x01, 0x00,
        0x00, 0x00,
        0x00, 0x00, 0x00, 0x00,
        0x00, 0x00, 0x00, 0x10,
    ];

    let loader = BytecodeLoader::new(&data);
    assert!(loader.is_err());
}

#[test]
fn test_bytecode_loader_too_small() {
    let data = vec![0x01, 0x02, 0x03];
    let loader = BytecodeLoader::new(&data);
    assert!(loader.is_err());
}

// ====== Opcode Tests ======

#[test]
fn test_opcode_push() {
    assert_eq!(Opcode::from_byte(0x01), Some(Opcode::Push));
}

#[test]
fn test_opcode_pop() {
    assert_eq!(Opcode::from_byte(0x02), Some(Opcode::Pop));
}

#[test]
fn test_opcode_halt() {
    assert_eq!(Opcode::from_byte(0x61), Some(Opcode::Halt));
}

#[test]
fn test_opcode_print() {
    assert_eq!(Opcode::from_byte(0x60), Some(Opcode::Print));
}

#[test]
fn test_opcode_invalid() {
    assert_eq!(Opcode::from_byte(0xFF), None);
}

// ====== Memory Tests ======

#[test]
fn test_memory_read_write() {
    let mut mem = Memory::new();
    mem.write(0, 42).unwrap();
    assert_eq!(mem.read(0).unwrap(), 42);
}

#[test]
fn test_memory_multiple_values() {
    let mut mem = Memory::new();
    for i in 0..10 {
        mem.write(i, (i * 2) as u64).unwrap();
    }
    for i in 0..10 {
        assert_eq!(mem.read(i).unwrap(), (i * 2) as u64);
    }
}

#[test]
fn test_memory_out_of_bounds() {
    let mut mem = Memory::new();
    let result = mem.write(20000, 0);
    assert!(result.is_err());
}

#[test]
fn test_memory_stack_operations() {
    let mut mem = Memory::new();
    let mut sp = 0;

    // Push values
    mem.stack_push(&mut sp, 10).unwrap();
    mem.stack_push(&mut sp, 20).unwrap();
    mem.stack_push(&mut sp, 30).unwrap();

    // Pop values (LIFO)
    assert_eq!(mem.stack_pop(&mut sp).unwrap(), 30);
    assert_eq!(mem.stack_pop(&mut sp).unwrap(), 20);
    assert_eq!(mem.stack_pop(&mut sp).unwrap(), 10);
}

