// ====== Memory Tests ======

#[test]
fn test_memory_read_write() {
    let mut mem = Memory::new();
    mem.write(0, 42).unwrap();
    assert_eq!(mem.read(0).unwrap(), 42);
}

#[test]
fn test_memory_multiple_values() {
    let mut mem = Memory::new();
    for i in 0..10 {
        mem.write(i, (i * 2) as u64).unwrap();
    }
    for i in 0..10 {
        assert_eq!(mem.read(i).unwrap(), (i * 2) as u64);
    }
}

#[test]
fn test_memory_out_of_bounds() {
    let mut mem = Memory::new();
    let result = mem.write(20000, 0);
    assert!(result.is_err());
}

#[test]
fn test_memory_stack_operations() {
    let mut mem = Memory::new();
    let mut sp = 0;

    // Push values
    mem.stack_push(&mut sp, 10).unwrap();
    mem.stack_push(&mut sp, 20).unwrap();
    mem.stack_push(&mut sp, 30).unwrap();

    // Pop values (LIFO)
    assert_eq!(mem.stack_pop(&mut sp).unwrap(), 30);
    assert_eq!(mem.stack_pop(&mut sp).unwrap(), 20);
    assert_eq!(mem.stack_pop(&mut sp).unwrap(), 10);
}

