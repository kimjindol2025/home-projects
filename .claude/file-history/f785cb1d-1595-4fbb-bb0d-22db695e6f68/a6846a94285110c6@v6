#[test]
fn test_variable_reassignment() {
    // Test: PUSH 10, STORE 0, PUSH 20, STORE 0, LOAD 0
    let bytecode = vec![
        0x46, 0x4C, 0x56, 0x4D,  // Magic
        0x01, 0x00,              // Version
        0x00, 0x00,              // Flags
        0x00, 0x00, 0x00, 0x16,  // Code size: 22
        0x00, 0x00, 0x00, 0x10,  // Code offset: 16
        // PUSH 10
        0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x0A,
        // STORE 0
        0x04, 0x00,
        // PUSH 20
        0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x14,
        // STORE 0
        0x04, 0x00,
        // LOAD 0
        0x03, 0x00,
    ];

    let mut vm = VM::new(&bytecode).unwrap();
    vm.step().unwrap();  // PUSH 10
    vm.step().unwrap();  // STORE 0 (local[0] = 10)
    assert_eq!(vm.memory.read(vm.bp).unwrap(), 10);

    vm.step().unwrap();  // PUSH 20
    vm.step().unwrap();  // STORE 0 (local[0] = 20, overwrite)
    assert_eq!(vm.memory.read(vm.bp).unwrap(), 20);

    vm.step().unwrap();  // LOAD 0
    assert_eq!(vm.sp, 1);
    assert_eq!(vm.memory.read(0).unwrap(), 20);
}

