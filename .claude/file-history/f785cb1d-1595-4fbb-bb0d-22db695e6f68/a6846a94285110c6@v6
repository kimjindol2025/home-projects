#[test]
fn test_control_flow_if_else() {
    // if-else pattern: PUSH 10, PUSH 5, LT, JIT(else), PUSH 100, JMP(end),
    // (else:) PUSH 200, (end:) HALT 0
    // 10 < 5 is false, so else branch executes
    let bytecode = vec![
        0x46, 0x4C, 0x56, 0x4D, 0x01, 0x00, 0x00, 0x00,
        0x00, 0x00, 0x00, 0x3C, 0x00, 0x00, 0x00, 0x10,
        0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x0A, // PUSH 10
        0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x05, // PUSH 5
        0x26,                                                   // LT
        0x32, 0x00, 0x00, 0x00, 0x31,                         // JIT 49 (else)
        0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x64, // PUSH 100
        0x30, 0x00, 0x00, 0x00, 0x35,                         // JMP 53 (end)
        0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0xC8, // PUSH 200
        0x61, 0x00,                                             // HALT 0
    ];

    let mut vm = VM::new(&bytecode).unwrap();
    let _ = vm.run();
    // Should have 200 (else branch)
    assert_eq!(vm.sp, 1);
    assert_eq!(vm.memory.read(0).unwrap(), 200);
}
