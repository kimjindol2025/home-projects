# Arithmetic Operations in FreeLang Bytecode
#
# Computes: 3 + 5 = 8
#
# Output: 8

.version 1.0

.code
  # PUSH 3
  PUSH 3
  # PUSH 5
  PUSH 5
  # ADD (pops 5 and 3, pushes 3+5=8)
  ADD
  # PRINT (prints 8)
  PRINT
  # HALT with exit code 0
  HALT 0

.end

