fn test_composed_proof() -> TestResult {
  println("  Test: Composed Proof (2+3 == 1+4)")

  let op1 = BinaryOp {
    left: Int(2),
    operator: "add",
    right: Int(3),
    expected_result: Int(5),
    recorded_timestamp: 0,
    recorded_runtime_version: "v2.0",
    witness: "add1"
  }

  let op2 = BinaryOp {
    left: Int(1),
    operator: "add",
    right: Int(4),
    expected_result: Int(5),
    recorded_timestamp: 0,
    recorded_runtime_version: "v2.0",
    witness: "add2"
  }

  let proof = Proof {
    predicate: "2+3==1+4",
    primitives: [op1, op2],
    proof_tree: ProofTree {
      root: ProofNode {
        goal: "2+3==1+4",
        rule: "equality",
        premises: [
          ProofNode {
            goal: "2+3==5",
            rule: "arithmetic",
            premises: [],
            conclusion: "2+3==5",
            qed_timestamp: 0
          },
          ProofNode {
            goal: "1+4==5",
            rule: "arithmetic",
            premises: [],
            conclusion: "1+4==5",
            qed_timestamp: 0
          }
        ],
        conclusion: "2+3==1+4",
        qed_timestamp: 0
      },
      depth: 2,
      node_count: 3
    },
    invariants: [],
    digest: "composed_proof",
    verification_level: 1,
    timestamp: 0
  }

  let verified = verify_proof(proof)
  println("    Result: " + to_string(verified) + " (expected true)")

  return TestResult {
    name: "composed_proof",
    passed: verified,
    assertion_count: 1,
    reason: "Composed proof with multiple primitives should verify"
  }
}

