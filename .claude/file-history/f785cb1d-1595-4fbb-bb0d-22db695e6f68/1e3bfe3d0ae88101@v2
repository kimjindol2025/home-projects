// ========================================

fn test_proof_tree_depth_1() -> TestResult {
  println("  Test: Proof Tree with Depth 1 (Leaf Node)")

  let node = ProofNode {
    goal: "2+3==5",
    rule: "arithmetic",
    premises: [],
    conclusion: "2+3==5",
    qed_timestamp: 0
  }

  let tree = ProofTree {
    root: node,
    depth: 1,
    node_count: 1
  }

  let valid = verify_proof_tree(tree)
  println("    Result: " + to_string(valid) + " (expected true)")

  return TestResult {
    name: "tree_depth_1",
    passed: valid,
    assertion_count: 1,
    reason: "Leaf node should be valid"
  }
}

