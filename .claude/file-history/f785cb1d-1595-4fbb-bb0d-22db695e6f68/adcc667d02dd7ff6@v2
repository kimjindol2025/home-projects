//! Standard library functions
//!
//! Built-in functions for printing, type conversion, array operations, etc.

use crate::memory::Memory;

/// Print a 64-bit integer value
///
/// # Arguments
///
/// * `value` - Value to print
pub fn println_int(value: i64) {
    println!("{}", value);
}

/// Print a 64-bit unsigned integer value
///
/// # Arguments
///
/// * `value` - Value to print
pub fn println_uint(value: u64) {
    println!("{}", value);
}

/// Convert 64-bit integer to string
///
/// # Arguments
///
/// * `value` - Value to convert
///
/// # Returns
///
/// String representation
pub fn to_string_int(value: i64) -> String {
    format!("{}", value)
}

/// Convert 64-bit unsigned integer to string
///
/// # Arguments
///
/// * `value` - Value to convert
///
/// # Returns
///
/// String representation
pub fn to_string_uint(value: u64) -> String {
    format!("{}", value)
}

/// Array operations

/// Get array length
///
/// Arrays are stored with length prefix in first 64-bit word
pub fn array_length(array_addr: usize, memory: &Memory) -> Result<usize, String> {
    let len_value = memory.read(array_addr)?;
    Ok(len_value as usize)
}

/// Read array element
///
/// # Arguments
///
/// * `array_addr` - Base address of array
/// * `index` - Element index
/// * `memory` - Memory instance
pub fn array_get(
    array_addr: usize,
    index: usize,
    memory: &Memory,
) -> Result<u64, String> {
    let len = array_length(array_addr, memory)?;
    if index >= len {
        return Err(format!("Array index out of bounds: {} >= {}", index, len));
    }
    // Array elements start at array_addr + 1 (after length)
    memory.read(array_addr + 1 + index)
}

/// Write array element
///
/// # Arguments
///
/// * `array_addr` - Base address of array
/// * `index` - Element index
/// * `value` - Value to write
/// * `memory` - Memory instance
pub fn array_set(
    array_addr: usize,
    index: usize,
    value: u64,
    memory: &mut Memory,
) -> Result<(), String> {
    let len = array_length(array_addr, memory)?;
    if index >= len {
        return Err(format!("Array index out of bounds: {} >= {}", index, len));
    }
    // Array elements start at array_addr + 1 (after length)
    memory.write(array_addr + 1 + index, value)
}

/// String operations

/// Get string length
///
/// Strings are stored with length prefix in first 64-bit word (as UTF-8 byte count)
pub fn string_length(string_addr: usize, memory: &Memory) -> Result<usize, String> {
    let len_value = memory.read(string_addr)?;
    Ok(len_value as usize)
}

/// Read string character
///
/// # Arguments
///
/// * `string_addr` - Base address of string
/// * `index` - Character index (in bytes)
/// * `memory` - Memory instance
pub fn string_get(
    string_addr: usize,
    index: usize,
    memory: &Memory,
) -> Result<u8, String> {
    let len = string_length(string_addr, memory)?;
    if index >= len {
        return Err(format!("String index out of bounds: {} >= {}", index, len));
    }
    // String data starts at string_addr + 1
    // Each u64 contains 8 bytes, need to extract the right byte
    let word_addr = string_addr + 1 + (index / 8);
    let word = memory.read(word_addr)?;
    let byte_offset = index % 8;
    let byte_value = ((word >> (byte_offset * 8)) & 0xFF) as u8;
    Ok(byte_value)
}

/// Math operations

/// Absolute value
pub fn abs_int(value: i64) -> i64 {
    value.abs()
}

/// Maximum of two values
pub fn max_int(a: i64, b: i64) -> i64 {
    if a > b {
        a
    } else {
        b
    }
}

/// Minimum of two values
pub fn min_int(a: i64, b: i64) -> i64 {
    if a < b {
        a
    } else {
        b
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_to_string_int() {
        assert_eq!(to_string_int(42), "42");
        assert_eq!(to_string_int(-42), "-42");
        assert_eq!(to_string_int(0), "0");
    }

    #[test]
    fn test_to_string_uint() {
        assert_eq!(to_string_uint(42), "42");
        assert_eq!(to_string_uint(0), "0");
    }

    #[test]
    fn test_abs_int() {
        assert_eq!(abs_int(42), 42);
        assert_eq!(abs_int(-42), 42);
        assert_eq!(abs_int(0), 0);
    }

    #[test]
    fn test_max_int() {
        assert_eq!(max_int(42, 10), 42);
        assert_eq!(max_int(10, 42), 42);
        assert_eq!(max_int(-5, -10), -5);
    }

    #[test]
    fn test_min_int() {
        assert_eq!(min_int(42, 10), 10);
        assert_eq!(min_int(10, 42), 10);
        assert_eq!(min_int(-5, -10), -10);
    }
}
