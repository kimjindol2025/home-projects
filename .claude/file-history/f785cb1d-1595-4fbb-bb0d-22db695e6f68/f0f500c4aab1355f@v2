//! Memory management
//!
//! Manages the 64KB memory space with stack, heap, and global regions.
//!
//! # Memory Layout
//!
//! ```text
//! 0x0000 ┌──────────────────────┐
//!        │ Stack (20KB)         │  0x0000 - 0x4FFF
//!        │ (grows upward)       │
//! 0x5000 ├──────────────────────┤
//!        │ Heap (44KB)          │  0x5000 - 0xFFFD
//!        │ (dynamic objects)    │
//! 0xFFFE ├──────────────────────┤
//!        │ Globals (1KB)        │  0xFFFE - 0xFFFF
//! 0xFFFF └──────────────────────┘
//! ```

/// Stack region start (0x0000)
pub const STACK_START: usize = 0x0000;

/// Stack region end (0x4FFF, 20KB)
pub const STACK_END: usize = 0x5000;

/// Heap region start (0x5000)
pub const HEAP_START: usize = 0x5000;

/// Heap region end (0xFFFD, 44KB)
pub const HEAP_END: usize = 0xFFFE;

/// Global region start (0xFFFE)
pub const GLOBALS_START: usize = 0xFFFE;

/// Global region end (0xFFFF, 1KB)
pub const GLOBALS_END: usize = 0x10000;

/// Total memory size: 64KB = 16384 × 8 bytes
pub const MEMORY_SIZE: usize = 16384;

/// Memory manager
pub struct Memory {
    /// Raw memory: 16384 × u64 = 64KB
    data: [u64; MEMORY_SIZE],
}

impl Memory {
    /// Create a new memory instance
    pub fn new() -> Self {
        Memory {
            data: [0u64; MEMORY_SIZE],
        }
    }

    /// Read a 64-bit value from memory
    ///
    /// # Arguments
    ///
    /// * `addr` - Memory address (in 64-bit words, 0-16383)
    ///
    /// # Returns
    ///
    /// * `Ok(value)` - Value at address
    /// * `Err(String)` - Address out of bounds
    pub fn read(&self, addr: usize) -> Result<u64, String> {
        if addr >= MEMORY_SIZE {
            return Err(format!("Memory access out of bounds: {}", addr));
        }
        Ok(self.data[addr])
    }

    /// Write a 64-bit value to memory
    ///
    /// # Arguments
    ///
    /// * `addr` - Memory address (in 64-bit words, 0-16383)
    /// * `value` - Value to write
    ///
    /// # Returns
    ///
    /// * `Ok(())` - Write successful
    /// * `Err(String)` - Address out of bounds
    pub fn write(&mut self, addr: usize, value: u64) -> Result<(), String> {
        if addr >= MEMORY_SIZE {
            return Err(format!("Memory access out of bounds: {}", addr));
        }
        self.data[addr] = value;
        Ok(())
    }

    /// Stack push
    pub fn stack_push(&mut self, sp: &mut usize, value: u64) -> Result<(), String> {
        if *sp >= STACK_END {
            return Err("Stack overflow".to_string());
        }
        self.write(*sp, value)?;
        *sp += 1;
        Ok(())
    }

    /// Stack pop
    pub fn stack_pop(&mut self, sp: &mut usize) -> Result<u64, String> {
        if *sp == 0 {
            return Err("Stack underflow".to_string());
        }
        *sp -= 1;
        self.read(*sp)
    }

    /// Allocate memory on heap
    ///
    /// TODO: Implement proper heap allocation with alignment
    pub fn heap_allocate(&mut self, size: usize) -> Result<usize, String> {
        // TODO: Implement first-fit allocation
        // For now, return fixed address
        if size > (HEAP_END - HEAP_START) {
            return Err("Heap allocation too large".to_string());
        }
        Ok(HEAP_START)
    }

    /// Get total memory usage (for statistics)
    pub fn total_usage(&self) -> usize {
        MEMORY_SIZE
    }

    /// Clear memory (for testing)
    pub fn clear(&mut self) {
        self.data = [0u64; MEMORY_SIZE];
    }
}

impl Default for Memory {
    fn default() -> Self {
        Self::new()
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_memory_read_write() {
        let mut mem = Memory::new();
        mem.write(0, 42).unwrap();
        assert_eq!(mem.read(0).unwrap(), 42);
    }

    #[test]
    fn test_memory_bounds() {
        let mut mem = Memory::new();
        let result = mem.write(MEMORY_SIZE, 0);
        assert!(result.is_err());
    }

    #[test]
    fn test_stack_push_pop() {
        let mut mem = Memory::new();
        let mut sp = 0;

        mem.stack_push(&mut sp, 42).unwrap();
        assert_eq!(sp, 1);

        let val = mem.stack_pop(&mut sp).unwrap();
        assert_eq!(val, 42);
        assert_eq!(sp, 0);
    }

    #[test]
    fn test_stack_overflow() {
        let mut mem = Memory::new();
        let mut sp = STACK_END;
        let result = mem.stack_push(&mut sp, 0);
        assert!(result.is_err());
    }

    #[test]
    fn test_stack_underflow() {
        let mut mem = Memory::new();
        let mut sp = 0;
        let result = mem.stack_pop(&mut sp);
        assert!(result.is_err());
    }
}
