fn test_proof_chain_integrity_violation() -> TestResult {
  println("  Test: ProofChain Integrity Violation Detection")

  let chain = ProofChain {
    proofs: [],
    chain_created_at: 0,
    total_proofs: 0,
    chain_integrity: true
  }

  let record1 = ProofRecord {
    proof_id: "proof_001",
    timestamp: 100,
    freelang_version: "v2.0",
    integrity_engine_version: "v2.0-layer3",
    proof_json: "{\"p\": \"2+3==5\"}",
    previous_proof_digest: "genesis",
    self_digest: "hash_001",
    external_validator: "validator-rs",
    external_result: true,
    external_timestamp: 105,
    human_reviewer: "kim@example.com",
    audit_notes: "Proof 1"
  }

  let record2_broken = ProofRecord {
    proof_id: "proof_002",
    timestamp: 110,
    freelang_version: "v2.0",
    integrity_engine_version: "v2.0-layer3",
    proof_json: "{\"p\": \"2+3==1+4\"}",
    previous_proof_digest: "WRONG_HASH",  // 잘못된 연결!
    self_digest: "hash_002",
    external_validator: "validator-rs",
    external_result: true,
    external_timestamp: 115,
    human_reviewer: "kim@example.com",
    audit_notes: "Broken proof"
  }

  chain.add_proof_record(record1)
  chain.add_proof_record(record2_broken)

  // 체인이 깨진 것을 감지했는가?
  let integrity_detected = not chain.chain_integrity

  println("    Integrity violation detected: " + to_string(integrity_detected))

  return TestResult {
    name: "chain_integrity_violation",
    passed: integrity_detected,
    assertion_count: 1,
    reason: "ProofChain should detect integrity violations"
  }
}

