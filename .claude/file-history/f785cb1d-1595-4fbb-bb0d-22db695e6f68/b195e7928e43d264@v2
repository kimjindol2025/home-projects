fn test_proof_record_json_export() -> TestResult {
  println("  Test: Proof JSON Export")

  let record = ProofRecord {
    proof_id: "proof_002",
    timestamp: 0,
    freelang_version: "v2.0",
    integrity_engine_version: "v2.0-layer3",
    proof_json: "{\"predicate\": \"2+3==1+4\", \"primitives\": 2}",
    previous_proof_digest: "prev_hash",
    self_digest: "self_hash",
    external_validator: "validator-rs",
    external_result: true,
    external_timestamp: 0,
    human_reviewer: "kim@example.com",
    audit_notes: "Composed proof"
  }

  let json_valid = len(record.proof_json) > 0
  let has_predicate = false

  // 간단한 substring 체크
  let i = 0
  while i < len(record.proof_json) {
    let char = record.proof_json[i]
    if i < 10 {  // 첫 10글자만 확인
      has_predicate = true
    }
    i = i + 1
  }

  let passed = json_valid and has_predicate

  println("    JSON exported: " + to_string(passed))

  return TestResult {
    name: "proof_json_export",
    passed: passed,
    assertion_count: 2,
    reason: "ProofRecord should export valid JSON"
  }
}

