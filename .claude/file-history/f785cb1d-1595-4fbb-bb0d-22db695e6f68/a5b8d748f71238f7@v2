//! Bytecode loader and instruction definitions
//!
//! This module handles loading and validating bytecode files.
//!
//! # File Format
//!
//! ```text
//! Offset  Size  Field           Description
//! -------+-----+-------------+----------------------------------
//! 0x0000    4   Magic         0x464C5056 ("FLVM")
//! 0x0004    2   Version       0x0100 (v1.0)
//! 0x0006    2   Flags         0x0000 (reserved)
//! 0x0008    4   Code Size     Code section byte count
//! 0x000C    4   Code Offset   Code section start
//! 0x0010    N   Code          Bytecode instructions
//! ...
//! ```

/// Bytecode file magic number "FLVM"
const MAGIC: u32 = 0x464C5056;

/// Bytecode format version
const VERSION: u16 = 0x0100;

/// Bytecode instruction opcodes
#[derive(Clone, Copy, Debug, PartialEq, Eq)]
pub enum Opcode {
    // Load/Store
    Push = 0x01,
    Pop = 0x02,
    Load = 0x03,
    Store = 0x04,
    LoadG = 0x05,
    StoreG = 0x06,
    Dup = 0x07,
    Swap = 0x08,

    // Arithmetic
    Add = 0x10,
    Sub = 0x11,
    Mul = 0x12,
    Div = 0x13,
    Mod = 0x14,
    Neg = 0x15,
    Abs = 0x16,
    Incr = 0x17,

    // Logic
    And = 0x20,
    Or = 0x21,
    Not = 0x22,
    Eq = 0x23,
    Ne = 0x24,
    Lt = 0x25,
    Le = 0x26,
    Ge = 0x27,

    // Control Flow
    Jmp = 0x30,
    Jz = 0x31,
    Jnz = 0x32,
    Call = 0x33,
    Ret = 0x34,
    Loop = 0x35,

    // Array
    Newarr = 0x40,
    Aload = 0x41,
    Astore = 0x42,
    Alen = 0x43,

    // String
    Newstr = 0x50,
    Sload = 0x51,
    Sstore = 0x52,
    Slen = 0x53,

    // Built-in
    Print = 0x60,
    Halt = 0x61,
}

impl Opcode {
    /// Convert byte to opcode
    pub fn from_byte(byte: u8) -> Option<Self> {
        match byte {
            0x01 => Some(Opcode::Push),
            0x02 => Some(Opcode::Pop),
            0x03 => Some(Opcode::Load),
            0x04 => Some(Opcode::Store),
            0x05 => Some(Opcode::LoadG),
            0x06 => Some(Opcode::StoreG),
            0x07 => Some(Opcode::Dup),
            0x08 => Some(Opcode::Swap),
            0x10 => Some(Opcode::Add),
            0x11 => Some(Opcode::Sub),
            0x12 => Some(Opcode::Mul),
            0x13 => Some(Opcode::Div),
            0x14 => Some(Opcode::Mod),
            0x15 => Some(Opcode::Neg),
            0x16 => Some(Opcode::Abs),
            0x17 => Some(Opcode::Incr),
            0x20 => Some(Opcode::And),
            0x21 => Some(Opcode::Or),
            0x22 => Some(Opcode::Not),
            0x23 => Some(Opcode::Eq),
            0x24 => Some(Opcode::Ne),
            0x25 => Some(Opcode::Lt),
            0x26 => Some(Opcode::Le),
            0x27 => Some(Opcode::Ge),
            0x30 => Some(Opcode::Jmp),
            0x31 => Some(Opcode::Jz),
            0x32 => Some(Opcode::Jnz),
            0x33 => Some(Opcode::Call),
            0x34 => Some(Opcode::Ret),
            0x35 => Some(Opcode::Loop),
            0x40 => Some(Opcode::Newarr),
            0x41 => Some(Opcode::Aload),
            0x42 => Some(Opcode::Astore),
            0x43 => Some(Opcode::Alen),
            0x50 => Some(Opcode::Newstr),
            0x51 => Some(Opcode::Sload),
            0x52 => Some(Opcode::Sstore),
            0x53 => Some(Opcode::Slen),
            0x60 => Some(Opcode::Print),
            0x61 => Some(Opcode::Halt),
            _ => None,
        }
    }
}

/// Bytecode loader
pub struct BytecodeLoader {
    code: Vec<u8>,
    // TODO: data: Vec<u8>,
    // TODO: symbols: Vec<Symbol>,
}

impl BytecodeLoader {
    /// Load and validate bytecode
    pub fn new(data: &[u8]) -> Result<Self, String> {
        // Validate minimum size
        if data.len() < 16 {
            return Err("Bytecode file too small".to_string());
        }

        // Check magic number
        let magic = u32::from_be_bytes([data[0], data[1], data[2], data[3]]);
        if magic != MAGIC {
            return Err(format!("Invalid magic number: 0x{:08x}", magic));
        }

        // Check version
        let version = u16::from_be_bytes([data[4], data[5]]);
        if version != VERSION {
            return Err(format!("Unsupported bytecode version: 0x{:04x}", version));
        }

        // Check flags (reserved, must be 0)
        let _flags = u16::from_be_bytes([data[6], data[7]]);

        // Parse code section
        let code_size = u32::from_be_bytes([data[8], data[9], data[10], data[11]]) as usize;
        let code_offset = u32::from_be_bytes([data[12], data[13], data[14], data[15]]) as usize;

        // Validate code section bounds
        if code_offset + code_size > data.len() {
            return Err(format!(
                "Code section out of bounds: offset={}, size={}, total={}",
                code_offset,
                code_size,
                data.len()
            ));
        }

        // Extract code
        let code = data[code_offset..code_offset + code_size].to_vec();

        // TODO: Parse data section
        // TODO: Parse symbol table

        Ok(BytecodeLoader { code })
    }

    /// Get bytecode instructions
    pub fn code(&self) -> Vec<u8> {
        self.code.clone()
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_opcode_push() {
        let opcode = Opcode::from_byte(0x01);
        assert_eq!(opcode, Some(Opcode::Push));
    }

    #[test]
    fn test_opcode_halt() {
        let opcode = Opcode::from_byte(0x61);
        assert_eq!(opcode, Some(Opcode::Halt));
    }

    #[test]
    fn test_opcode_invalid() {
        let opcode = Opcode::from_byte(0xFF);
        assert_eq!(opcode, None);
    }

    #[test]
    fn test_bytecode_loader_invalid_magic() {
        let data = vec![0xFF, 0xFF, 0xFF, 0xFF]; // Invalid magic
        let result = BytecodeLoader::new(&data);
        assert!(result.is_err());
    }

    #[test]
    fn test_bytecode_loader_too_small() {
        let data = vec![0x01, 0x02, 0x03];
        let result = BytecodeLoader::new(&data);
        assert!(result.is_err());
    }

    #[test]
    fn test_bytecode_loader_valid_empty() {
        // Valid header with 0-byte code section
        let data = vec![
            0x46, 0x4C, 0x56, 0x4D, // Magic: FLVM
            0x01, 0x00,             // Version: 0x0100
            0x00, 0x00,             // Flags: 0x0000
            0x00, 0x00, 0x00, 0x00, // Code size: 0
            0x00, 0x00, 0x00, 0x10, // Code offset: 16
        ];
        let loader = BytecodeLoader::new(&data);
        assert!(loader.is_ok());
    }
}
