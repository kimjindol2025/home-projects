        0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x0F, // PUSH 15
        0x26,                                                   // LT (30 < 15 = 0, but we want 30 > 15)
        0x22,                                                   // NOT to flip
        0x61, 0x00,                                             // HALT 0
    ];

    let mut vm = VM::new(&bytecode).unwrap();
    let _ = vm.run();
    assert_eq!(vm.sp, 1);
