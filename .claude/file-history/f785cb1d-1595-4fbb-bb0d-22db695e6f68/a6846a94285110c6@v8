// ====== LOAD/STORE Instruction Tests ======

#[test]
fn test_load_after_store() {
    let bytecode = vec![
        0x46, 0x4C, 0x56, 0x4D,  // Magic
        0x01, 0x00,              // Version
        0x00, 0x00,              // Flags
        0x00, 0x00, 0x00, 0x0C,  // Code size: 12
        0x00, 0x00, 0x00, 0x10,  // Code offset: 16
        // PUSH 42
        0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x2A,
        // STORE 0
        0x04, 0x00,
        // LOAD 0
        0x03, 0x00,
    ];

    let mut vm = VM::new(&bytecode).unwrap();
    vm.step().unwrap();  // PUSH 42
    assert_eq!(vm.sp, 1);
    vm.step().unwrap();  // STORE 0
    assert_eq!(vm.sp, 0);
    assert_eq!(vm.memory.read(vm.bp).unwrap(), 42);
    vm.step().unwrap();  // LOAD 0
    assert_eq!(vm.sp, 1);
    assert_eq!(vm.memory.read(0).unwrap(), 42);
}

