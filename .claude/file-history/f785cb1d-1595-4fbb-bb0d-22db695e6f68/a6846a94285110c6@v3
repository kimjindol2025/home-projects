// ====== LOAD/STORE Instruction Tests ======

#[test]
fn test_load_after_store() {
    let bytecode = vec![
        0x46, 0x4C, 0x56, 0x4D,  // Magic
        0x01, 0x00,              // Version
        0x00, 0x00,              // Flags
        0x00, 0x00, 0x00, 0x0C,  // Code size: 12
        0x00, 0x00, 0x00, 0x10,  // Code offset: 16
        // PUSH 42
        0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x2A,
        // STORE 0
        0x04, 0x00,
        // LOAD 0
        0x03, 0x00,
    ];

    let mut vm = VM::new(&bytecode).unwrap();
    vm.step().unwrap();  // PUSH 42
    assert_eq!(vm.sp, 1);
    vm.step().unwrap();  // STORE 0
    assert_eq!(vm.sp, 0);
    assert_eq!(vm.memory.read(vm.bp).unwrap(), 42);
    vm.step().unwrap();  // LOAD 0
    assert_eq!(vm.sp, 1);
    assert_eq!(vm.memory.read(0).unwrap(), 42);
}

#[test]
fn test_dup_instruction() {
    let bytecode = vec![
        0x46, 0x4C, 0x56, 0x4D,  // Magic
        0x01, 0x00,              // Version
        0x00, 0x00,              // Flags
        0x00, 0x00, 0x00, 0x0A,  // Code size: 10
        0x00, 0x00, 0x00, 0x10,  // Code offset: 16
        // PUSH 42
        0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x2A,
        // DUP
        0x07,
    ];

    let mut vm = VM::new(&bytecode).unwrap();
    vm.step().unwrap();  // PUSH
    assert_eq!(vm.sp, 1);
    vm.step().unwrap();  // DUP
    assert_eq!(vm.sp, 2);
    assert_eq!(vm.memory.read(0).unwrap(), 42);
    assert_eq!(vm.memory.read(1).unwrap(), 42);
}

#[test]
fn test_swap_instruction() {
    let bytecode = vec![
        0x46, 0x4C, 0x56, 0x4D,  // Magic
        0x01, 0x00,              // Version
        0x00, 0x00,              // Flags
        0x00, 0x00, 0x00, 0x13,  // Code size: 19
        0x00, 0x00, 0x00, 0x10,  // Code offset: 16
        // PUSH 10
        0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x0A,
        // PUSH 20
        0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x14,
        // SWAP
        0x08,
    ];

    let mut vm = VM::new(&bytecode).unwrap();
    vm.step().unwrap();  // PUSH 10
    vm.step().unwrap();  // PUSH 20
    assert_eq!(vm.memory.read(0).unwrap(), 10);
    assert_eq!(vm.memory.read(1).unwrap(), 20);
    vm.step().unwrap();  // SWAP
    assert_eq!(vm.memory.read(0).unwrap(), 20);
    assert_eq!(vm.memory.read(1).unwrap(), 10);
}

