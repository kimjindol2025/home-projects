// ====== PUSH Instruction Tests ======

#[test]
fn test_push_single_value() {
    let bytecode = vec![
        0x46, 0x4C, 0x56, 0x4D,  // Magic
        0x01, 0x00,              // Version
        0x00, 0x00,              // Flags
        0x00, 0x00, 0x00, 0x09,  // Code size: 9
        0x00, 0x00, 0x00, 0x10,  // Code offset: 16
        // PUSH 42
        0x01,
        0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x2A,
    ];

    let mut vm = VM::new(&bytecode).unwrap();
    vm.step().unwrap();  // Execute PUSH
    assert_eq!(vm.sp, 1);  // Stack pointer moved
    assert_eq!(vm.memory.read(0).unwrap(), 42);  // Value on stack
}

#[test]
fn test_push_multiple_values() {
    let bytecode = vec![
        0x46, 0x4C, 0x56, 0x4D,  // Magic
        0x01, 0x00,              // Version
        0x00, 0x00,              // Flags
        0x00, 0x00, 0x00, 0x12,  // Code size: 18
        0x00, 0x00, 0x00, 0x10,  // Code offset: 16
        // PUSH 10
        0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x0A,
        // PUSH 20
        0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x14,
    ];

    let mut vm = VM::new(&bytecode).unwrap();
    vm.step().unwrap();  // PUSH 10
    assert_eq!(vm.sp, 1);
    vm.step().unwrap();  // PUSH 20
    assert_eq!(vm.sp, 2);
    assert_eq!(vm.memory.read(0).unwrap(), 10);
    assert_eq!(vm.memory.read(1).unwrap(), 20);
}

// ====== POP Instruction Tests ======

#[test]
fn test_pop_after_push() {
    let bytecode = vec![
        0x46, 0x4C, 0x56, 0x4D,  // Magic
        0x01, 0x00,              // Version
        0x00, 0x00,              // Flags
        0x00, 0x00, 0x00, 0x0A,  // Code size: 10
        0x00, 0x00, 0x00, 0x10,  // Code offset: 16
        // PUSH 42
        0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x2A,
        // POP
        0x02,
    ];

    let mut vm = VM::new(&bytecode).unwrap();
    vm.step().unwrap();  // PUSH
    assert_eq!(vm.sp, 1);
    vm.step().unwrap();  // POP
    assert_eq!(vm.sp, 0);
}

