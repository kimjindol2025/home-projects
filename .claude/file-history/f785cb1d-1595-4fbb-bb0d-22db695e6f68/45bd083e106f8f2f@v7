//! Virtual Machine core execution engine
//!
//! This module implements the stack-based VM that executes bytecode instructions.
//!
//! # Architecture
//!
//! - **Memory**: [u64; 16384] = 64KB (8-byte words)
//!   - Stack: 0x0000 - 0x4FFF (20KB, grows upward)
//!   - Heap: 0x5000 - 0xFFFD (44KB)
//!   - Globals: 0xFFFE - 0xFFFF (1KB)
//!
//! - **Registers**:
//!   - PC (Program Counter): Current instruction address
//!   - SP (Stack Pointer): Top of stack
//!   - BP (Base Pointer): Frame base for local variables
//!   - ACC (Accumulator): Temporary value storage
//!
//! - **Call Stack**: Function call frames with return addresses

use crate::bytecode::BytecodeLoader;
use crate::memory::Memory;
use crate::gc::GarbageCollector;

/// Call frame for function calls
#[derive(Clone, Debug)]
pub struct CallFrame {
    /// Return PC when function returns
    pub return_pc: usize,
    /// Saved base pointer
    pub saved_bp: usize,
}

/// Main virtual machine
pub struct VM {
    /// 64KB memory (16384 × 8 bytes)
    pub memory: Memory,

    /// Program counter (current instruction)
    pub pc: usize,

    /// Stack pointer (top of stack)
    pub sp: usize,

    /// Base pointer (frame base)
    pub bp: usize,

    /// Heap pointer (for array/string allocation)
    pub heap_ptr: usize,

    /// Bytecode instructions
    pub code: Vec<u8>,

    /// Function call stack
    pub call_stack: Vec<CallFrame>,

    /// Garbage collector
    pub gc: GarbageCollector,
}

impl VM {
    /// Create a new VM instance and load bytecode
    ///
    /// # Arguments
    ///
    /// * `bytecode` - Raw bytecode bytes
    ///
    /// # Returns
    ///
    /// * `Ok(VM)` - Initialized VM
    /// * `Err(String)` - Initialization error
    pub fn new(bytecode: &[u8]) -> Result<Self, String> {
        // Load and validate bytecode
        let loader = BytecodeLoader::new(bytecode)?;
        let code = loader.code();

        // Initialize VM state
        let mut vm = VM {
            memory: Memory::new(),
            pc: 0,
            sp: 0,
            bp: 0,
            heap_ptr: 0x5000,  // Heap starts at 0x5000 (20KB offset)
            code,
            call_stack: Vec::new(),
            gc: GarbageCollector::new(),
        };

        // TODO: Load data section and symbol table

        Ok(vm)
    }

    /// Run the VM until HALT or end-of-code
    ///
    /// # Returns
    ///
    /// * `Ok(exit_code)` - Program exit code
    /// * `Err(String)` - Runtime error
    pub fn run(&mut self) -> Result<u64, String> {
        loop {
            // Check program end
            if self.pc >= self.code.len() {
                break;
            }

            // Execute next instruction
            self.step()?;
        }

        Ok(0) // Default exit code
    }

    /// Execute one instruction
    ///
    /// # Returns
    ///
    /// * `Ok(())` - Instruction executed successfully
    /// * `Err(String)` - Instruction execution error
    pub fn step(&mut self) -> Result<(), String> {
        // Fetch instruction
        if self.pc >= self.code.len() {
            return Err("Unexpected end of bytecode".to_string());
        }

        let opcode = self.code[self.pc];
        self.pc += 1;

        // Decode and execute
        match opcode {
            // Load/Store instructions
            0x01 => self.exec_push()?,
            0x02 => self.exec_pop()?,
            0x03 => self.exec_load()?,
            0x04 => self.exec_store()?,
            0x05 => self.exec_loadg()?,
            0x06 => self.exec_storeg()?,
            0x07 => self.exec_dup()?,
            0x08 => self.exec_swap()?,

            // Arithmetic instructions
            0x10 => self.exec_add()?,
            0x11 => self.exec_sub()?,
            0x12 => self.exec_mul()?,
            0x13 => self.exec_div()?,
            0x14 => self.exec_mod()?,
            0x15 => self.exec_neg()?,
            0x16 => self.exec_abs()?,
            0x17 => self.exec_incr()?,

            // Logic instructions
            0x20 => self.exec_and()?,
            0x21 => self.exec_or()?,
            0x22 => self.exec_not()?,
            0x23 => self.exec_xor()?,
            0x24 => self.exec_eq()?,
            0x25 => self.exec_neq()?,
            0x26 => self.exec_lt()?,
            0x27 => self.exec_lte()?,

            // Control flow instructions
            0x30 => self.exec_jmp()?,
            0x31 => self.exec_jif()?,
            0x32 => self.exec_jit()?,
            0x33 => self.exec_call()?,
            0x34 => self.exec_ret()?,
            0x35 => self.exec_loop()?,
            0x36 => self.exec_cmpjmp()?,
            0x37 => self.exec_nop()?,

            // Array instructions
            0x40 => self.exec_arralloc()?,
            0x41 => self.exec_arrget()?,
            0x42 => self.exec_arrset()?,
            0x43 => self.exec_arrlen()?,

            // String instructions
            0x50 => self.exec_stralloc()?,
            0x51 => self.exec_strget()?,
            0x52 => self.exec_strset()?,
            0x53 => self.exec_strlen()?,

            // Built-in instructions
            0x60 => self.exec_print()?,
            0x61 => self.exec_halt()?,

            _ => return Err(format!("Unknown opcode: 0x{:02x}", opcode)),
        }

        Ok(())
    }

    // ====== Load/Store Instructions ======

    fn exec_push(&mut self) -> Result<(), String> {
        // Read 8-byte value from bytecode
        let value = self.read_u64()?;

        // Push value onto stack
        self.push(value)?;

        Ok(())
    }

    fn exec_pop(&mut self) -> Result<(), String> {
        // Pop value from stack (discarded)
        let _value = self.pop()?;

        Ok(())
    }

    fn exec_load(&mut self) -> Result<(), String> {
        // Read local variable index (1 byte)
        if self.pc >= self.code.len() {
            return Err("Expected operand for LOAD".to_string());
        }
        let index = self.code[self.pc] as usize;
        self.pc += 1;

        // Calculate address: BP + index
        let addr = self.bp.checked_add(index)
            .ok_or("LOAD address overflow".to_string())?;

        // Read value from memory
        let value = self.memory.read(addr)?;

        // Push to stack
        self.push(value)?;

        Ok(())
    }

    fn exec_store(&mut self) -> Result<(), String> {
        // Read local variable index (1 byte)
        if self.pc >= self.code.len() {
            return Err("Expected operand for STORE".to_string());
        }
        let index = self.code[self.pc] as usize;
        self.pc += 1;

        // Pop value from stack
        let value = self.pop()?;

        // Calculate address: BP + index
        let addr = self.bp.checked_add(index)
            .ok_or("STORE address overflow".to_string())?;

        // Write to memory
        self.memory.write(addr, value)?;

        Ok(())
    }

    fn exec_loadg(&mut self) -> Result<(), String> {
        // Load from global variable
        if self.pc >= self.code.len() {
            return Err("Expected operand for LOADG".to_string());
        }
        let index = self.code[self.pc] as usize;
        self.pc += 1;

        // Global variables at 0xFFFE + index
        let addr = 0xFFFE + index;
        let value = self.memory.read(addr)?;
        self.push(value)?;

        Ok(())
    }

    fn exec_storeg(&mut self) -> Result<(), String> {
        // Store to global variable
        if self.pc >= self.code.len() {
            return Err("Expected operand for STOREG".to_string());
        }
        let index = self.code[self.pc] as usize;
        self.pc += 1;

        let value = self.pop()?;
        let addr = 0xFFFE + index;
        self.memory.write(addr, value)?;

        Ok(())
    }

    fn exec_dup(&mut self) -> Result<(), String> {
        // Duplicate top of stack
        if self.sp == 0 {
            return Err("Stack underflow".to_string());
        }

        // Read top of stack (without popping)
        let top_value = self.memory.read(self.sp - 1)?;

        // Push duplicate
        self.push(top_value)?;

        Ok(())
    }

    fn exec_swap(&mut self) -> Result<(), String> {
        // Swap top two stack values
        if self.sp < 2 {
            return Err("Stack underflow".to_string());
        }

        // Read two top values
        let top = self.memory.read(self.sp - 1)?;
        let second = self.memory.read(self.sp - 2)?;

        // Swap them
        self.memory.write(self.sp - 1, second)?;
        self.memory.write(self.sp - 2, top)?;

        Ok(())
    }

    // ====== Built-in Instructions ======

    fn exec_print(&mut self) -> Result<(), String> {
        // Pop value from stack and print it
        let value = self.pop()?;

        // Print as signed 64-bit integer
        println!("{}", value as i64);

        Ok(())
    }

    fn exec_halt(&mut self) -> Result<(), String> {
        // Pop exit code and halt
        let exit_code = self.pop()?;

        // Exit the program
        std::process::exit(exit_code as i32);
    }

    // ====== Arithmetic Instructions ======

    fn exec_add(&mut self) -> Result<(), String> {
        // Pop two values (order matters!)
        let b = self.pop()?;  // Second operand (top)
        let a = self.pop()?;  // First operand

        // Add them
        let result = a.wrapping_add(b);

        // Push result
        self.push(result)?;

        Ok(())
    }

    fn exec_sub(&mut self) -> Result<(), String> {
        // Pop two values
        let b = self.pop()?;  // Subtrahend (top)
        let a = self.pop()?;  // Minuend

        // Subtract them
        let result = a.wrapping_sub(b);

        // Push result
        self.push(result)?;

        Ok(())
    }

    fn exec_mul(&mut self) -> Result<(), String> {
        // Pop two values
        let b = self.pop()?;
        let a = self.pop()?;

        // Multiply them
        let result = a.wrapping_mul(b);

        // Push result
        self.push(result)?;

        Ok(())
    }

    fn exec_div(&mut self) -> Result<(), String> {
        // Pop two values
        let b = self.pop()?;  // Divisor
        let a = self.pop()?;  // Dividend

        // Check for division by zero
        if b == 0 {
            return Err("Division by zero".to_string());
        }

        // Perform signed division
        let a_i64 = a as i64;
        let b_i64 = b as i64;
        let result = a_i64.wrapping_div(b_i64);

        // Push result
        self.push(result as u64);

        Ok(())
    }

    fn exec_mod(&mut self) -> Result<(), String> {
        // Pop two values
        let b = self.pop()?;  // Divisor
        let a = self.pop()?;  // Dividend

        // Check for modulo by zero
        if b == 0 {
            return Err("Modulo by zero".to_string());
        }

        // Perform signed modulo
        let a_i64 = a as i64;
        let b_i64 = b as i64;
        let result = a_i64.wrapping_rem(b_i64);

        // Push result
        self.push(result as u64);

        Ok(())
    }

    fn exec_neg(&mut self) -> Result<(), String> {
        // Pop value
        let a = self.pop()?;

        // Perform negation (two's complement)
        let a_i64 = a as i64;
        let result = a_i64.wrapping_neg();

        // Push result
        self.push(result as u64);

        Ok(())
    }

    fn exec_abs(&mut self) -> Result<(), String> {
        // Pop value
        let a = self.pop()?;

        // Perform absolute value
        let a_i64 = a as i64;
        let result = a_i64.abs();

        // Push result
        self.push(result as u64);

        Ok(())
    }

    fn exec_incr(&mut self) -> Result<(), String> {
        // Pop value
        let a = self.pop()?;

        // Increment by 1
        let result = a.wrapping_add(1);

        // Push result
        self.push(result)?;

        Ok(())
    }

    // ====== Logic Instructions ======

    fn exec_and(&mut self) -> Result<(), String> {
        // Pop two values
        let b = self.pop()?;  // Second operand (top)
        let a = self.pop()?;  // First operand

        // Bitwise AND
        let result = a & b;

        // Push result
        self.push(result)?;

        Ok(())
    }

    fn exec_or(&mut self) -> Result<(), String> {
        // Pop two values
        let b = self.pop()?;
        let a = self.pop()?;

        // Bitwise OR
        let result = a | b;

        // Push result
        self.push(result)?;

        Ok(())
    }

    fn exec_not(&mut self) -> Result<(), String> {
        // Pop value
        let a = self.pop()?;

        // Bitwise NOT
        let result = !a;

        // Push result
        self.push(result)?;

        Ok(())
    }

    fn exec_xor(&mut self) -> Result<(), String> {
        // Pop two values
        let b = self.pop()?;
        let a = self.pop()?;

        // Bitwise XOR
        let result = a ^ b;

        // Push result
        self.push(result)?;

        Ok(())
    }

    fn exec_eq(&mut self) -> Result<(), String> {
        // Pop two values
        let b = self.pop()?;
        let a = self.pop()?;

        // Compare equality: 1 if equal, 0 if not
        let result = if a == b { 1 } else { 0 };

        // Push result
        self.push(result)?;

        Ok(())
    }

    fn exec_neq(&mut self) -> Result<(), String> {
        // Pop two values
        let b = self.pop()?;
        let a = self.pop()?;

        // Compare inequality: 1 if not equal, 0 if equal
        let result = if a != b { 1 } else { 0 };

        // Push result
        self.push(result)?;

        Ok(())
    }

    fn exec_lt(&mut self) -> Result<(), String> {
        // Pop two values
        let b = self.pop()?;  // Right operand
        let a = self.pop()?;  // Left operand

        // Signed comparison
        let a_i64 = a as i64;
        let b_i64 = b as i64;
        let result = if a_i64 < b_i64 { 1 } else { 0 };

        // Push result
        self.push(result)?;

        Ok(())
    }

    fn exec_lte(&mut self) -> Result<(), String> {
        // Pop two values
        let b = self.pop()?;
        let a = self.pop()?;

        // Signed comparison
        let a_i64 = a as i64;
        let b_i64 = b as i64;
        let result = if a_i64 <= b_i64 { 1 } else { 0 };

        // Push result
        self.push(result)?;

        Ok(())
    }

    // ====== Control Flow Instructions ======

    fn exec_jmp(&mut self) -> Result<(), String> {
        // Read 4-byte address from bytecode
        if self.pc + 4 > self.code.len() {
            return Err("JMP: Expected 4-byte address".to_string());
        }

        let addr_bytes = &self.code[self.pc..self.pc + 4];
        let addr = u32::from_be_bytes([
            addr_bytes[0], addr_bytes[1], addr_bytes[2], addr_bytes[3],
        ]) as usize;

        self.pc += 4;

        // Validate and jump
        if addr >= self.code.len() {
            return Err("JMP: Target address out of bounds".to_string());
        }

        self.pc = addr;
        Ok(())
    }

    fn exec_jif(&mut self) -> Result<(), String> {
        // Read 4-byte address
        if self.pc + 4 > self.code.len() {
            return Err("JIF: Expected 4-byte address".to_string());
        }

        let addr_bytes = &self.code[self.pc..self.pc + 4];
        let addr = u32::from_be_bytes([
            addr_bytes[0], addr_bytes[1], addr_bytes[2], addr_bytes[3],
        ]) as usize;

        self.pc += 4;

        // Pop condition
        let cond = self.pop()?;

        // Jump if false (cond == 0)
        if cond == 0 {
            if addr >= self.code.len() {
                return Err("JIF: Target address out of bounds".to_string());
            }
            self.pc = addr;
        }

        Ok(())
    }

    fn exec_jit(&mut self) -> Result<(), String> {
        // Read 4-byte address
        if self.pc + 4 > self.code.len() {
            return Err("JIT: Expected 4-byte address".to_string());
        }

        let addr_bytes = &self.code[self.pc..self.pc + 4];
        let addr = u32::from_be_bytes([
            addr_bytes[0], addr_bytes[1], addr_bytes[2], addr_bytes[3],
        ]) as usize;

        self.pc += 4;

        // Pop condition
        let cond = self.pop()?;

        // Jump if true (cond != 0)
        if cond != 0 {
            if addr >= self.code.len() {
                return Err("JIT: Target address out of bounds".to_string());
            }
            self.pc = addr;
        }

        Ok(())
    }

    fn exec_call(&mut self) -> Result<(), String> {
        // Read 4-byte target address
        if self.pc + 4 > self.code.len() {
            return Err("CALL: Expected 4-byte address".to_string());
        }

        let addr_bytes = &self.code[self.pc..self.pc + 4];
        let target_addr = u32::from_be_bytes([
            addr_bytes[0], addr_bytes[1], addr_bytes[2], addr_bytes[3],
        ]) as usize;

        // Save return address (after reading the address)
        let return_addr = self.pc + 4;

        // Validate target
        if target_addr >= self.code.len() {
            return Err("CALL: Target address out of bounds".to_string());
        }

        // Push call frame
        self.call_stack.push(CallFrame {
            return_pc: return_addr,
            saved_bp: self.bp,
        });

        // Set BP to current SP for local variables
        self.bp = self.sp;

        // Jump to function
        self.pc = target_addr;

        Ok(())
    }

    fn exec_ret(&mut self) -> Result<(), String> {
        // Pop call frame
        let frame = self.call_stack.pop()
            .ok_or("RET: Call stack underflow".to_string())?;

        // Restore base pointer
        self.bp = frame.saved_bp;

        // Jump to return address
        self.pc = frame.return_pc;

        Ok(())
    }

    fn exec_loop(&mut self) -> Result<(), String> {
        // Read 4-byte loop address
        if self.pc + 4 > self.code.len() {
            return Err("LOOP: Expected 4-byte address".to_string());
        }

        let addr_bytes = &self.code[self.pc..self.pc + 4];
        let loop_addr = u32::from_be_bytes([
            addr_bytes[0], addr_bytes[1], addr_bytes[2], addr_bytes[3],
        ]) as usize;

        self.pc += 4;

        // Pop loop counter
        let counter = self.pop()?;

        if counter > 0 {
            // Decrement and push back
            let new_counter = counter - 1;
            self.push(new_counter)?;

            // Jump back to loop
            if loop_addr >= self.code.len() {
                return Err("LOOP: Target address out of bounds".to_string());
            }
            self.pc = loop_addr;
        }

        Ok(())
    }

    fn exec_cmpjmp(&mut self) -> Result<(), String> {
        // Read 4-byte address
        if self.pc + 4 > self.code.len() {
            return Err("CMPJMP: Expected 4-byte address".to_string());
        }

        let addr_bytes = &self.code[self.pc..self.pc + 4];
        let addr = u32::from_be_bytes([
            addr_bytes[0], addr_bytes[1], addr_bytes[2], addr_bytes[3],
        ]) as usize;

        self.pc += 4;

        // Pop two values
        let b = self.pop()?;
        let a = self.pop()?;

        // Jump if equal
        if a == b {
            if addr >= self.code.len() {
                return Err("CMPJMP: Target address out of bounds".to_string());
            }
            self.pc = addr;
        }

        Ok(())
    }

    fn exec_nop(&mut self) -> Result<(), String> {
        // No operation - just continue
        Ok(())
    }

    // ====== Array Instructions ======

    fn exec_arralloc(&mut self) -> Result<(), String> {
        // Pop array size
        let size = self.pop()?;

        // Get current heap pointer
        let array_addr = self.heap_ptr;

        // Check heap bounds (heap: 0x5000 - 0xFFFD, ~28K words)
        if array_addr + size as usize + 1 >= 0xFFFE {
            return Err("ARRALLOC: Heap overflow".to_string());
        }

        // Write metadata (length)
        self.memory.write(array_addr, size)?;

        // Initialize array elements to 0
        for i in 0..size as usize {
            self.memory.write(array_addr + 1 + i, 0)?;
        }

        // Update heap pointer
        self.heap_ptr += (size as usize) + 1;

        // Push array address
        self.push(array_addr as u64)?;

        Ok(())
    }

    fn exec_arrget(&mut self) -> Result<(), String> {
        // Pop index
        let index = self.pop()?;

        // Pop array address
        let array_addr = self.pop()? as usize;

        // Read array length
        let length = self.memory.read(array_addr)?;

        // Check bounds
        if index >= length {
            return Err(format!("ARRGET: Index out of bounds: {} >= {}", index, length));
        }

        // Read element
        let element = self.memory.read(array_addr + 1 + index as usize)?;

        // Push element
        self.push(element)?;

        Ok(())
    }

    fn exec_arrset(&mut self) -> Result<(), String> {
        // Pop value
        let value = self.pop()?;

        // Pop index
        let index = self.pop()?;

        // Pop array address
        let array_addr = self.pop()? as usize;

        // Read array length
        let length = self.memory.read(array_addr)?;

        // Check bounds
        if index >= length {
            return Err(format!("ARRSET: Index out of bounds: {} >= {}", index, length));
        }

        // Write element
        self.memory.write(array_addr + 1 + index as usize, value)?;

        Ok(())
    }

    fn exec_arrlen(&mut self) -> Result<(), String> {
        // Pop array address
        let array_addr = self.pop()? as usize;

        // Check if address is in valid heap range
        if array_addr < 0x5000 || array_addr >= 0xFFFE {
            return Err("ARRLEN: Invalid array address".to_string());
        }

        // Read array length
        let length = self.memory.read(array_addr)?;

        // Push length
        self.push(length)?;

        Ok(())
    }

    // ====== String Instructions ======

    fn exec_stralloc(&mut self) -> Result<(), String> {
        // Pop string length
        let length = self.pop()?;

        // Get current heap pointer
        let string_addr = self.heap_ptr;

        // Check heap bounds
        if string_addr + length as usize + 1 >= 0xFFFE {
            return Err("STRALLOC: Heap overflow".to_string());
        }

        // Write metadata (length)
        self.memory.write(string_addr, length)?;

        // Initialize string to 0 (null bytes)
        for i in 0..length as usize {
            self.memory.write(string_addr + 1 + i, 0)?;
        }

        // Update heap pointer
        self.heap_ptr += (length as usize) + 1;

        // Push string address
        self.push(string_addr as u64)?;

        Ok(())
    }

    fn exec_strget(&mut self) -> Result<(), String> {
        // Pop index
        let index = self.pop()?;

        // Pop string address
        let string_addr = self.pop()? as usize;

        // Read string length
        let length = self.memory.read(string_addr)?;

        // Check bounds
        if index >= length {
            return Err(format!("STRGET: Index out of bounds: {} >= {}", index, length));
        }

        // Read character
        let char_val = self.memory.read(string_addr + 1 + index as usize)?;

        // Push character
        self.push(char_val)?;

        Ok(())
    }

    fn exec_strset(&mut self) -> Result<(), String> {
        // Pop character value
        let char_val = self.pop()?;

        // Pop index
        let index = self.pop()?;

        // Pop string address
        let string_addr = self.pop()? as usize;

        // Read string length
        let length = self.memory.read(string_addr)?;

        // Check bounds
        if index >= length {
            return Err(format!("STRSET: Index out of bounds: {} >= {}", index, length));
        }

        // Write character (store in lower 8 bits)
        let masked_char = char_val & 0xFF;
        self.memory.write(string_addr + 1 + index as usize, masked_char)?;

        Ok(())
    }

    fn exec_strlen(&mut self) -> Result<(), String> {
        // Pop string address
        let string_addr = self.pop()? as usize;

        // Check if address is in valid heap range
        if string_addr < 0x5000 || string_addr >= 0xFFFE {
            return Err("STRLEN: Invalid string address".to_string());
        }

        // Read string length
        let length = self.memory.read(string_addr)?;

        // Push length
        self.push(length)?;

        Ok(())
    }

    // ====== Helper Methods ======

    /// Push a value onto the stack
    pub fn push(&mut self, value: u64) -> Result<(), String> {
        if self.sp >= 0x5000 {
            return Err("Stack overflow".to_string());
        }
        self.memory.write(self.sp, value)?;
        self.sp += 1;
        Ok(())
    }

    /// Pop a value from the stack
    pub fn pop(&mut self) -> Result<u64, String> {
        if self.sp == 0 {
            return Err("Stack underflow".to_string());
        }
        self.sp -= 1;
        self.memory.read(self.sp)
    }

    /// Read 8-byte value from code at current PC
    pub fn read_u64(&mut self) -> Result<u64, String> {
        if self.pc + 8 > self.code.len() {
            return Err("Unexpected end of bytecode".to_string());
        }

        let bytes = &self.code[self.pc..self.pc + 8];
        self.pc += 8;

        Ok(u64::from_be_bytes([
            bytes[0], bytes[1], bytes[2], bytes[3],
            bytes[4], bytes[5], bytes[6], bytes[7],
        ]))
    }
}

