# Hello, World! in FreeLang Bytecode Assembly
#
# This is an assembly representation of the bytecode.
# The actual binary file would be compiled from this.
#
# Output: "Hello, World!"

.version 1.0

.code
  # PUSH reference to "Hello, World!" string
  PUSH "Hello, World!"
  # PRINT the string
  PRINT
  # HALT with exit code 0
  HALT 0

.end
