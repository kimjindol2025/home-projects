  println("=" * 80)
  println("FreeLang Integrity Engine v2.0 - Layer 2: Formal Verification Engine")
  println("=" * 80)
  println("")

  // 테스트 1: 간단한 증명
  println("Test 1: Simple Arithmetic Proof")
  println("-" * 80)

  let op1 = BinaryOp {
    left: Int(2),
    operator: "add",
    right: Int(3),
    expected_result: Int(5),
    recorded_timestamp: 0,
    recorded_runtime_version: "v2.0-layer1",
    witness: "add_assertion"
  }

  let proof1 = create_simple_proof("2+3==5", op1, 0)
  let result1 = verify_proof(proof1)

  println(generate_verification_report(result1))
  println("")

  // 테스트 2: 더 복잡한 증명
  println("Test 2: Composition Proof (2+3 == 1+4)")
  println("-" * 80)

  let op2a = BinaryOp {
    left: Int(2),
    operator: "add",
    right: Int(3),
    expected_result: Int(5),
    recorded_timestamp: 0,
    recorded_runtime_version: "v2.0-layer1",
    witness: "add_assertion_a"
  }

  let op2b = BinaryOp {
    left: Int(1),
    operator: "add",
    right: Int(4),
    expected_result: Int(5),
    recorded_timestamp: 0,
    recorded_runtime_version: "v2.0-layer1",
    witness: "add_assertion_b"
  }

  let proof2 = Proof {
    predicate: "2+3 == 1+4",
    primitives: [op2a, op2b],
    proof_tree: ProofTree {
      root: ProofNode {
        goal: "2+3 == 1+4",
        rule: "equality",
        premises: [
          ProofNode {
            goal: "2+3==5",
            rule: "arithmetic",
            premises: [],
            conclusion: "2+3==5",
            qed_timestamp: 0
          },
          ProofNode {
            goal: "1+4==5",
            rule: "arithmetic",
            premises: [],
            conclusion: "1+4==5",
            qed_timestamp: 0
          }
        ],
        conclusion: "2+3 == 1+4",
        qed_timestamp: 0
      },
      depth: 2,
      node_count: 3
    },
    invariants: [],
    digest: "composition_digest",
    verification_level: 1,
    timestamp: 0
  }

  let result2 = verify_proof(proof2)
  println(generate_verification_report(result2))
  println("")

  println("=" * 80)
  if result1.result and result2.result {
    println("✅ Layer 2 검증 완료: 모든 증명이 유효합니다!")
    println("")
    println("중요: 이것은 여전히 자신의 기록입니다.")
    println("다음: Layer 3 (외부 검증) 구현")
  } else {
    println("❌ 일부 증명이 유효하지 않습니다")
  }
  println("=" * 80)
