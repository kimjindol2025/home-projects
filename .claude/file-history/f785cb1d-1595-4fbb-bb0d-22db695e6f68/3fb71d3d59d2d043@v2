#[cfg(test)]
mod tests {
    use freelang_vm::VM;

    #[test]
    fn test_push_pop() {
        let bytecode = vec![
            0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x2A,  // PUSH 42
            0x02,  // POP
            0x61, 0x00,  // HALT 0
        ];

        let mut vm = VM::new(&bytecode).unwrap();
        let result = vm.run().unwrap();
        assert_eq!(result, 0);
    }

    #[test]
    fn test_arithmetic() {
        let bytecode = vec![
            0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x03,  // PUSH 3
            0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x05,  // PUSH 5
            0x10,  // ADD
            0x60,  // PRINT
            0x61, 0x00,  // HALT 0
        ];

        let mut vm = VM::new(&bytecode).unwrap();
        vm.run().unwrap();  // 8 출력
    }
}
