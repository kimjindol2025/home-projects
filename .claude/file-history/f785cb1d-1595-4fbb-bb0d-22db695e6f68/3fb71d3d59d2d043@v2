## 💾 Rust 코드 구조

### 1. main.rs (진입점)

```rust
use freelang_vm::VM;

fn main() {
    let args: Vec<String> = std::env::args().collect();

    if args.len() < 2 {
        eprintln!("Usage: freelang-vm <bytecode.bc>");
        std::process::exit(1);
    }

    let bytecode = std::fs::read(&args[1])
        .expect("Failed to read bytecode file");

    let mut vm = VM::new(&bytecode)
        .expect("Failed to initialize VM");

    match vm.run() {
        Ok(exit_code) => std::process::exit(exit_code as i32),
        Err(e) => {
            eprintln!("Runtime error: {}", e);
            std::process::exit(1);
        }
    }
}
```

### 2. vm.rs (핵심 VM)

```rust
pub struct VM {
    memory: [u64; 16384],           // 64KB (8-byte words)
    pc: usize,                      // Program Counter
    sp: usize,                      // Stack Pointer
    bp: usize,                      // Base Pointer
    code: Vec<u8>,                  // Bytecode
    call_stack: Vec<CallFrame>,     // 함수 호출 스택
    gc: GarbageCollector,
}

#[derive(Clone)]
struct CallFrame {
    return_pc: usize,
    saved_bp: usize,
}

impl VM {
    pub fn new(bytecode: &[u8]) -> Result<Self> {
        let mut vm = VM {
            memory: [0u64; 16384],
            pc: 0,
            sp: 0,
            bp: 0,
            code: Vec::new(),
            call_stack: Vec::new(),
            gc: GarbageCollector::new(),
        };

        // 바이트코드 로드
        let loader = BytecodeLoader::new(bytecode)?;
        vm.code = loader.code();
        // 데이터, 심볼 로드...

        Ok(vm)
    }

    pub fn run(&mut self) -> Result<u64> {
        loop {
            // 프로그램 끝
            if self.pc >= self.code.len() {
                break;
            }

            // 다음 명령어 실행
            self.step()?;
        }

        Ok(0)  // 기본 exit code
    }

    pub fn step(&mut self) -> Result<()> {
        let opcode = self.code[self.pc];
        self.pc += 1;

        match opcode {
            0x01 => self.exec_push()?,      // PUSH
            0x02 => self.exec_pop()?,       // POP
            0x03 => self.exec_load()?,      // LOAD
            0x04 => self.exec_store()?,     // STORE
            // ... 더 많은 명령어
            0x60 => self.exec_print()?,     // PRINT
            0x61 => self.exec_halt()?,      // HALT
            _ => return Err(format!("Unknown opcode: 0x{:02x}", opcode)),
        }

        Ok(())
    }

    fn exec_push(&mut self) -> Result<()> {
        let value = self.read_u64()?;
        self.push(value);
        Ok(())
    }

    fn exec_add(&mut self) -> Result<()> {
        let b = self.pop();
        let a = self.pop();
        self.push(a.wrapping_add(b));
        Ok(())
    }

    fn push(&mut self, value: u64) {
        self.memory[self.sp] = value;
        self.sp += 1;
    }

    fn pop(&mut self) -> u64 {
        self.sp -= 1;
        self.memory[self.sp]
    }

    fn read_u64(&mut self) -> Result<u64> {
        if self.pc + 8 > self.code.len() {
            return Err("Unexpected end of bytecode".to_string());
        }

        let bytes = &self.code[self.pc..self.pc+8];
        self.pc += 8;

        Ok(u64::from_be_bytes([
            bytes[0], bytes[1], bytes[2], bytes[3],
            bytes[4], bytes[5], bytes[6], bytes[7],
        ]))
    }

    fn exec_print(&mut self) -> Result<()> {
        let value = self.pop();
        println!("{}", value);
        Ok(())
    }

    fn exec_halt(&mut self) -> Result<()> {
        let exit_code = self.pop();
        std::process::exit(exit_code as i32);
    }
}
```

### 3. memory.rs (메모리 관리)

```rust
pub struct Memory {
    data: [u64; 16384],
}

impl Memory {
    pub fn new() -> Self {
        Memory {
            data: [0u64; 16384],
        }
    }

    pub fn read(&self, addr: usize) -> u64 {
        self.data[addr]
    }

    pub fn write(&mut self, addr: usize, value: u64) {
        self.data[addr] = value;
    }

    pub fn stack_push(&mut self, sp: &mut usize, value: u64) {
        self.data[*sp] = value;
        *sp += 1;
    }

    pub fn stack_pop(&mut self, sp: &mut usize) -> u64 {
        *sp -= 1;
        self.data[*sp]
    }

    pub fn heap_allocate(&mut self, size: usize) -> usize {
        // 단순 할당 (나중에 GC 연동)
        0x5000  // 힙 시작 주소
    }
}
```

### 4. gc.rs (가비지 컬렉터)

```rust
pub struct GarbageCollector {
    marked: Vec<bool>,
    reachable: Vec<usize>,
}

impl GarbageCollector {
    pub fn new() -> Self {
        GarbageCollector {
            marked: vec![false; 16384],
            reachable: Vec::new(),
        }
    }

    pub fn collect(&mut self, memory: &mut Memory, roots: &[usize]) {
        // Mark phase
        for root in roots {
            self.mark(*root, memory);
        }

        // Sweep phase
        for i in 0..16384 {
            if !self.marked[i] {
                memory.write(i, 0);
            }
        }

        // Reset
        self.marked.fill(false);
    }

    fn mark(&mut self, addr: usize, memory: &Memory) {
        if self.marked[addr] {
            return;
        }

        self.marked[addr] = true;

        // 참조 추적...
        // 배열/문자열의 요소들 마킹
    }
}
```

### 5. stdlib.rs (표준 라이브러리)

```rust
pub fn println_value(value: u64) {
    println!("{}", value);
}

pub fn to_string(value: u64) -> String {
    format!("{}", value)
}

pub fn array_new(size: usize) -> Vec<u64> {
    vec![0u64; size]
}

pub fn array_get(arr: &[u64], index: usize) -> Result<u64> {
    arr.get(index)
        .copied()
        .ok_or_else(|| "Index out of bounds".to_string())
}

pub fn array_set(arr: &mut [u64], index: usize, value: u64) -> Result<()> {
    if index < arr.len() {
        arr[index] = value;
        Ok(())
    } else {
        Err("Index out of bounds".to_string())
    }
}
```

