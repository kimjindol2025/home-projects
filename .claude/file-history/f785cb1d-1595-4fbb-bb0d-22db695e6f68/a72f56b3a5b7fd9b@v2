## 🔒 검증 규칙

### 로드 시 검증

```rust
fn validate_bytecode(data: &[u8]) -> Result<()> {
  // 1. 최소 크기 확인
  if data.len() < 8 { return Err("Too small"); }

  // 2. 매직 넘버 확인
  if &data[0..4] != b"FLVM" {
    return Err("Invalid magic");
  }

  // 3. 버전 확인
  if data[4..6] != [0x01, 0x00] {
    return Err("Unsupported version");
  }

  // 4. 오프셋 검증
  let code_size = u32::from_be_bytes([data[8], data[9], data[10], data[11]]);
  let code_offset = u32::from_be_bytes([data[12], data[13], data[14], data[15]]);

  if code_offset + code_size > data.len() as u32 {
    return Err("Code section out of bounds");
  }

  // 5. 명령어 검증
  for addr in code_offset..code_offset + code_size {
    let opcode = data[addr as usize];
    if opcode > 0x61 || (opcode >= 0x04 && opcode <= 0x08 && /* args check */) {
      return Err("Invalid opcode");
    }
  }

  Ok(())
}
```

