        0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x64,
        // MOD
        0x14,
    ];

    let mut vm = VM::new(&bytecode).unwrap();
    vm.step().unwrap();  // PUSH 0
    vm.step().unwrap();  // PUSH 100
    let result = vm.step();
    assert!(result.is_err());  // Should error on modulo by zero
}

