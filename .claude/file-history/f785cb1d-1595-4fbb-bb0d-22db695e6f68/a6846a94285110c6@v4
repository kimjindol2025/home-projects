// ====== Bytecode Loader Tests ======

#[test]
fn test_bytecode_loader_valid_empty_program() {
    // Valid bytecode with HALT instruction
    let data = vec![
        0x46, 0x4C, 0x56, 0x4D, // Magic: FLVM
        0x01, 0x00,             // Version: 0x0100
        0x00, 0x00,             // Flags: 0x0000
        0x00, 0x00, 0x00, 0x01, // Code size: 1
        0x00, 0x00, 0x00, 0x10, // Code offset: 16
        0x61,                   // HALT opcode
    ];

    let loader = BytecodeLoader::new(&data);
    assert!(loader.is_ok());
}

#[test]
fn test_bytecode_loader_invalid_magic() {
    let data = vec![
        0xFF, 0xFF, 0xFF, 0xFF, // Invalid magic
        0x01, 0x00,
        0x00, 0x00,
        0x00, 0x00, 0x00, 0x00,
        0x00, 0x00, 0x00, 0x10,
