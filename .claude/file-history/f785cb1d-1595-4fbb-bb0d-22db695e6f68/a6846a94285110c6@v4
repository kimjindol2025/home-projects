#[test]
fn test_arithmetic_complex() {
    // PUSH 10, PUSH 20, ADD = 30
    // PUSH 3, MUL = 90
    // PUSH 9, DIV = 10
    let bytecode = vec![
        0x46, 0x4C, 0x56, 0x4D,  // Magic
        0x01, 0x00,              // Version
        0x00, 0x00,              // Flags
        0x00, 0x00, 0x00, 0x1F,  // Code size: 31
        0x00, 0x00, 0x00, 0x10,  // Code offset: 16
        // PUSH 10
        0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x0A,
        // PUSH 20
        0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x14,
        // ADD
        0x10,
        // PUSH 3
        0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x03,
        // MUL
        0x12,
        // PUSH 9
        0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x09,
        // DIV
        0x13,
    ];

    let mut vm = VM::new(&bytecode).unwrap();
    vm.step().unwrap();  // PUSH 10
    vm.step().unwrap();  // PUSH 20
    vm.step().unwrap();  // ADD (30 on stack)
    vm.step().unwrap();  // PUSH 3
    vm.step().unwrap();  // MUL (90 on stack)
    vm.step().unwrap();  // PUSH 9
    vm.step().unwrap();  // DIV (10 on stack)
    assert_eq!(vm.sp, 1);
    assert_eq!(vm.memory.read(0).unwrap() as i64, 10);
}
