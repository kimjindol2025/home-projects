# Factorial Function in FreeLang Bytecode
#
# Recursive factorial computation:
# factorial(5) = 5 * 4 * 3 * 2 * 1 = 120
#
# Output: 120

.version 1.0

.code
  # main() function
  # Push argument: 5
  PUSH 5
  # CALL factorial
  CALL @factorial
  # PRINT result
  PRINT
  # HALT
  HALT 0

@factorial:
  # factorial(n):
  #   if n <= 1: return 1
  #   else: return n * factorial(n-1)

  # Load argument n (local[0])
  LOAD 0

  # Check if n <= 1
  PUSH 1
  LE              # n <= 1

  # If true, jump to base_case
  JNZ @base_case

  # Recursive case: n > 1
  # Return n * factorial(n-1)

  # Load n
  LOAD 0

  # Load n-1
  LOAD 0
  PUSH 1
  SUB

  # CALL factorial(n-1)
  CALL @factorial

  # MUL (n * factorial(n-1))
  MUL

  # RETURN
  RET

@base_case:
  # Base case: n <= 1, return 1
  PUSH 1
  RET

.end

