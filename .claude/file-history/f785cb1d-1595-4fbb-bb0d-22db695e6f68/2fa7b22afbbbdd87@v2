#!/bin/bash
# Run tests for FreeLang VM

set -e  # Exit on error

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

# Colors for output
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}FreeLang VM Test Suite${NC}"
echo "======================================"

# Check for Rust
if ! command -v cargo &> /dev/null; then
    echo -e "${RED}Error: Rust/Cargo not found${NC}"
    echo "Install from: https://rustup.rs/"
    exit 1
fi

# Run different test modes
case "${1:-all}" in
    all)
        echo -e "${YELLOW}Running all tests...${NC}"
        cargo test --lib
        cargo test --test unit_tests
        ;;
    unit)
        echo -e "${YELLOW}Running unit tests...${NC}"
        cargo test --lib
        ;;
    integration)
        echo -e "${YELLOW}Running integration tests...${NC}"
        cargo test --test unit_tests
        ;;
    quick)
        echo -e "${YELLOW}Running quick tests...${NC}"
        cargo test --lib -- --test-threads=1 --nocapture | head -50
        ;;
    verbose)
        echo -e "${YELLOW}Running tests with output...${NC}"
        cargo test -- --nocapture
        ;;
    clippy)
        echo -e "${YELLOW}Running clippy...${NC}"
        cargo clippy -- -D warnings
        ;;
    format)
        echo -e "${YELLOW}Checking code format...${NC}"
        cargo fmt -- --check
        ;;
    build)
        echo -e "${YELLOW}Building release binary...${NC}"
        cargo build --release
        echo -e "${GREEN}Build successful!${NC}"
        echo "Binary: ./target/release/freelang-vm"
        ;;
    bench)
        echo -e "${YELLOW}Running benchmarks...${NC}"
        cargo bench
        ;;
    help)
        echo "Usage: $0 [command]"
        echo ""
        echo "Commands:"
        echo "  all         - Run all tests (default)"
        echo "  unit        - Run unit tests only"
        echo "  integration - Run integration tests only"
        echo "  quick       - Run quick tests (first 50 lines)"
        echo "  verbose     - Run tests with output"
        echo "  clippy      - Run clippy linter"
        echo "  format      - Check code formatting"
        echo "  build       - Build release binary"
        echo "  bench       - Run benchmarks"
        echo "  help        - Show this help message"
        ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        $0 help
        exit 1
        ;;
esac

echo ""
echo -e "${GREEN}Tests completed!${NC}"
