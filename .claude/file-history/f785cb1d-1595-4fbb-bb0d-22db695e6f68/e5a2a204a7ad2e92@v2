#### 3️⃣ Mark Phase 구현

```rust
fn mark_reachable(&mut self, stack: &[u64], globals: &[u64]) {
    // Clear all marks
    for obj in &mut self.heap_objects {
        obj.marked = false;
    }

    let mut to_visit = Vec::new();

    // Add roots (stack + globals)
    for &value in stack {
        if self.is_heap_pointer(value) {
            to_visit.push(value as usize);
        }
    }
    for &value in globals {
        if self.is_heap_pointer(value) {
            to_visit.push(value as usize);
        }
    }

    // DFS traversal
    while let Some(addr) = to_visit.pop() {
        if let Some(obj) = self.find_object(addr) {
            if obj.marked {
                continue; // Already visited
            }
            obj.marked = true;

            // For arrays: scan elements for pointers
            if let ObjectType::Array(size) = obj.object_type {
                for i in 0..size {
                    let elem_addr = addr + 1 + i;
                    // Read value from heap and check if pointer
                    // (implementation depends on memory model)
                }
            }
        }
    }
}
```

**목적**: Reachable objects 마크

#### 4️⃣ Sweep Phase 구현

```rust
fn sweep(&mut self) {
    let mut freed_count = 0;
    let mut freed_bytes = 0;

    for obj in &mut self.heap_objects {
        if !obj.allocated {
            continue; // Skip already-free objects
        }

        if !obj.marked {
            // Unmarked object → free it
            obj.allocated = false;
            freed_count += 1;
            freed_bytes += obj.size;
            self.free_list.push(obj.address);
        }
    }

    // Update statistics
    self.gc_stats.collections += 1;
    self.gc_stats.objects_freed += freed_count;
    self.gc_stats.total_freed_bytes += freed_bytes as u64;
}
```

**목적**: 사용하지 않는 objects 회수

#### 5️⃣ Integration with VM (src/vm.rs 수정)

```rust
pub struct VM {
    // ... existing fields ...
    gc: GarbageCollector,
    gc_threshold: usize, // Trigger GC when heap usage > threshold
}

impl VM {
    pub fn run(&mut self) -> Result<u64, String> {
        loop {
            // Check if GC needed
            if self.heap_usage() > self.gc_threshold {
                self.gc.collect(&self.stack[..self.sp], &self.globals);
            }

            // ... fetch and execute instruction ...
        }
    }

    fn heap_usage(&self) -> usize {
        // Sum of all allocated objects
        self.gc.heap_objects.iter()
            .filter(|obj| obj.allocated)
            .map(|obj| obj.size)
            .sum()
    }
}
```

**목적**: VM에 GC 통합

