# Array Operations in FreeLang Bytecode
#
# Create array, set elements, compute sum, and print
#
# Code:
# let arr = [10, 20, 30, 40, 50]
# let sum = 0
# for i in 0..5:
#   sum = sum + arr[i]
# print(sum)
#
# Output: 150 (10 + 20 + 30 + 40 + 50)

.version 1.0

.code
  # Create array with 5 elements
  PUSH 5
  NEWARR          # arr = new array(5)
  STORE 0         # store in local[0]

  # Initialize array elements
  # arr[0] = 10
  LOAD 0
  PUSH 0
  PUSH 10
  ASTORE

  # arr[1] = 20
  LOAD 0
  PUSH 1
  PUSH 20
  ASTORE

  # arr[2] = 30
  LOAD 0
  PUSH 2
  PUSH 30
  ASTORE

  # arr[3] = 40
  LOAD 0
  PUSH 3
  PUSH 40
  ASTORE

  # arr[4] = 50
  LOAD 0
  PUSH 4
  PUSH 50
  ASTORE

  # Sum array elements
  PUSH 0
  STORE 1         # sum = 0 (in local[1])

  PUSH 0
  STORE 2         # i = 0 (in local[2])

@loop:
  # Check if i < 5
  LOAD 2
  PUSH 5
  LT
  JZ @exit_loop

  # sum = sum + arr[i]
  LOAD 1          # load sum
  LOAD 0          # load arr
  LOAD 2          # load i
  ALOAD           # arr[i]
  ADD             # sum + arr[i]
  STORE 1         # store in sum

  # i = i + 1
  LOAD 2
  INCR
  STORE 2

  # Jump back to loop condition
  JMP @loop

@exit_loop:
  # Print sum
  LOAD 1
  PRINT

  # HALT
  HALT 0

.end

# Expected output: 150
