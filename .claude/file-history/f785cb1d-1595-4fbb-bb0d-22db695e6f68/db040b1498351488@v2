//! Garbage collector
//!
//! Implements mark-and-sweep garbage collection for automatic memory management.
//!
//! # Algorithm
//!
//! ## Mark Phase
//! - Start from root references (stack, globals)
//! - DFS to mark all reachable objects
//! - Objects are marked in the mark set
//!
//! ## Sweep Phase
//! - Iterate through memory
//! - Free unmarked objects
//! - Reset mark set for next collection
//!
//! # Color Invariant (Tricolor Marking)
//!
//! - **White**: Unreachable, can be freed
//! - **Gray**: Reachable but not yet processed
//! - **Black**: Reachable and fully processed

use crate::memory::Memory;

/// Object reference (address in memory)
pub type Reference = usize;

/// Garbage collector using mark-and-sweep
pub struct GarbageCollector {
    /// Mark set: which objects are reachable
    marked: Vec<bool>,

    /// Reachable objects during current collection
    reachable: Vec<Reference>,

    /// Total collections performed
    collections: usize,

    /// Total objects freed
    freed_count: usize,
}

impl GarbageCollector {
    /// Create a new garbage collector
    pub fn new() -> Self {
        GarbageCollector {
            marked: vec![false; 16384],
            reachable: Vec::new(),
            collections: 0,
            freed_count: 0,
        }
    }

    /// Run garbage collection
    ///
    /// # Arguments
    ///
    /// * `memory` - Memory to collect
    /// * `roots` - Root references (stack base, globals)
    pub fn collect(&mut self, memory: &mut Memory, roots: &[usize]) -> Result<(), String> {
        // Mark phase: Find all reachable objects
        self.reachable.clear();
        for root in roots {
            self.mark(*root, memory)?;
        }

        // Sweep phase: Free unmarked objects
        let freed = self.sweep(memory)?;
        self.freed_count += freed;

        // Reset for next collection
        self.marked.fill(false);
        self.collections += 1;

        Ok(())
    }

    /// Mark phase: DFS to find reachable objects
    fn mark(&mut self, addr: usize, _memory: &Memory) -> Result<(), String> {
        // TODO: Implement mark phase
        // - Check if already marked
        // - Mark current object
        // - Follow references recursively

        if addr >= self.marked.len() {
            return Err(format!("Invalid address: {}", addr));
        }

        if self.marked[addr] {
            return Ok(()); // Already marked
        }

        self.marked[addr] = true;
        self.reachable.push(addr);

        // TODO: Recursively mark referenced objects
        // For now, just mark the address

        Ok(())
    }

    /// Sweep phase: Free unmarked objects
    fn sweep(&mut self, memory: &mut Memory) -> Result<usize, String> {
        let mut freed = 0;

        for addr in 0..self.marked.len() {
            if !self.marked[addr] {
                // Free unmarked object
                memory.write(addr, 0)?;
                freed += 1;
            }
        }

        Ok(freed)
    }

    /// Get garbage collector statistics
    pub fn stats(&self) -> GCStats {
        GCStats {
            collections: self.collections,
            freed_count: self.freed_count,
            marked_count: self.marked.iter().filter(|&&m| m).count(),
        }
    }
}

impl Default for GarbageCollector {
    fn default() -> Self {
        Self::new()
    }
}

/// Garbage collector statistics
#[derive(Debug, Clone)]
pub struct GCStats {
    /// Total garbage collections
    pub collections: usize,

    /// Total objects freed
    pub freed_count: usize,

    /// Currently marked objects
    pub marked_count: usize,
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_gc_creation() {
        let gc = GarbageCollector::new();
        assert_eq!(gc.collections, 0);
    }

    #[test]
    fn test_gc_stats() {
        let gc = GarbageCollector::new();
        let stats = gc.stats();
        assert_eq!(stats.collections, 0);
        assert_eq!(stats.freed_count, 0);
    }

    #[test]
    fn test_gc_mark() {
        let mut gc = GarbageCollector::new();
        let mut mem = Memory::new();
        let result = gc.mark(0, &mem);
        assert!(result.is_ok());
    }
}
