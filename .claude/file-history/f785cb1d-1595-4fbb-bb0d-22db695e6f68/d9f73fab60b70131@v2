use std::env;
use std::fs;
use std::process;

use freelang_vm::vm::VM;

fn main() {
    let args: Vec<String> = env::args().collect();

    if args.len() < 2 {
        eprintln!("Usage: freelang-vm <bytecode.bc>");
        eprintln!();
        eprintln!("Examples:");
        eprintln!("  freelang-vm program.bc");
        eprintln!("  freelang-vm examples/hello_world.bc");
        eprintln!("  freelang-vm examples/arithmetic.bc");
        process::exit(1);
    }

    let bytecode_path = &args[1];

    // Read bytecode file
    let bytecode = match fs::read(bytecode_path) {
        Ok(data) => data,
        Err(err) => {
            eprintln!("Error reading bytecode file '{}': {}", bytecode_path, err);
            process::exit(1);
        }
    };

    // Initialize VM
    let mut vm = match VM::new(&bytecode) {
        Ok(vm) => vm,
        Err(err) => {
            eprintln!("Error initializing VM: {}", err);
            process::exit(1);
        }
    };

    // Run the program
    match vm.run() {
        Ok(exit_code) => {
            process::exit(exit_code as i32);
        }
        Err(err) => {
            eprintln!("Runtime error: {}", err);
            process::exit(1);
        }
    }
}
