#!/usr/bin/env python3
"""
Simple FreeLang Bytecode Assembler

Converts bytecode assembly (.bc.asm) to binary bytecode (.bc) files.

Usage:
    python assembler.py input.bc.asm -o output.bc
    python assembler.py examples/hello_world.bc.asm
"""

import sys
import argparse
import struct
from pathlib import Path

# Bytecode file constants
MAGIC = 0x464C5056  # "FLVM"
VERSION = 0x0100    # v1.0

# Instruction opcodes
OPCODES = {
    # Load/Store
    'PUSH': 0x01,
    'POP': 0x02,
    'LOAD': 0x03,
    'STORE': 0x04,
    'LOADG': 0x05,
    'STOREG': 0x06,
    'DUP': 0x07,
    'SWAP': 0x08,

    # Arithmetic
    'ADD': 0x10,
    'SUB': 0x11,
    'MUL': 0x12,
    'DIV': 0x13,
    'MOD': 0x14,
    'NEG': 0x15,
    'ABS': 0x16,
    'INCR': 0x17,

    # Logic
    'AND': 0x20,
    'OR': 0x21,
    'NOT': 0x22,
    'EQ': 0x23,
    'NE': 0x24,
    'LT': 0x25,
    'LE': 0x26,
    'GE': 0x27,

    # Control Flow
    'JMP': 0x30,
    'JZ': 0x31,
    'JNZ': 0x32,
    'CALL': 0x33,
    'RET': 0x34,
    'LOOP': 0x35,

    # Array
    'NEWARR': 0x40,
    'ALOAD': 0x41,
    'ASTORE': 0x42,
    'ALEN': 0x43,

    # String
    'NEWSTR': 0x50,
    'SLOAD': 0x51,
    'SSTORE': 0x52,
    'SLEN': 0x53,

    # Built-in
    'PRINT': 0x60,
    'HALT': 0x61,
}


class Assembler:
    def __init__(self):
        self.code = []
        self.labels = {}
        self.symbol_table = {}

    def assemble(self, asm_text):
        """Assemble assembly text to bytecode"""
        lines = asm_text.split('\n')
        self.parse_pass_1(lines)  # Collect labels
        self.parse_pass_2(lines)  # Generate bytecode
        return self.code

    def parse_pass_1(self, lines):
        """First pass: collect label addresses"""
        pc = 0
        for line in lines:
            line = line.split('#')[0].strip()  # Remove comments
            if not line:
                continue

            if line.startswith('.'):
                continue  # Directives

            if line.endswith(':'):
                # Label
                label = line[:-1]
                self.labels[label] = pc
                continue

            # Count bytes this instruction will take
            parts = line.split()
            if not parts:
                continue

            opcode = parts[0]
            if opcode in OPCODES:
                instr_size = 1  # Opcode byte
                if len(parts) > 1:
                    # Has operand (could be 1 or 8 bytes)
                    operand = parts[1]
                    if operand.startswith('"') or operand.startswith("'"):
                        # String literal - size varies
                        instr_size += 8  # For now, assume 8 bytes
                    elif operand.isdigit() or (operand.startswith('-') and operand[1:].isdigit()):
                        # Integer - 8 bytes
                        instr_size += 8
                    else:
                        # Label reference or byte operand
                        instr_size += 1
                pc += instr_size

    def parse_pass_2(self, lines):
        """Second pass: generate bytecode"""
        pc = 0
        for line in lines:
            line = line.split('#')[0].strip()  # Remove comments
            if not line:
                continue

            if line.startswith('.'):
                # Directives
                if line.startswith('.version'):
                    continue  # Already handled
                continue

            if line.endswith(':'):
                # Label - update address
                continue

            parts = line.split()
            if not parts:
                continue

            opcode_name = parts[0]
            if opcode_name not in OPCODES:
                print(f"Warning: Unknown opcode: {opcode_name}")
                continue

            opcode = OPCODES[opcode_name]
            self.code.append(opcode)
            pc += 1

            # Handle operands
            if len(parts) > 1:
                operand = parts[1]

                if operand.startswith('"') or operand.startswith("'"):
                    # String literal
                    string_val = operand.strip('"\'')
                    # For now, store as reference (would be 8-byte index in data section)
                    self.code.extend(struct.pack('>Q', 0))  # Placeholder
                    pc += 8

                elif operand.startswith('@'):
                    # Label reference
                    label = operand[1:]
                    addr = self.labels.get(label, 0)
                    self.code.extend(struct.pack('>Q', addr))
                    pc += 8

                elif operand.isdigit() or (operand.startswith('-') and operand[1:].isdigit()):
                    # Integer literal
                    value = int(operand)
                    self.code.extend(struct.pack('>Q', value & 0xFFFFFFFFFFFFFFFF))
                    pc += 8

                else:
                    # Byte operand
                    try:
                        value = int(operand)
                        self.code.append(value & 0xFF)
                        pc += 1
                    except ValueError:
                        print(f"Warning: Invalid operand: {operand}")

    def generate_file(self):
        """Generate complete bytecode file with header"""
        # Header
        header = struct.pack('>I', MAGIC)  # Magic number
        header += struct.pack('>H', VERSION)  # Version
        header += struct.pack('>H', 0)  # Flags

        # Code section
        code_size = len(self.code)
        code_offset = 16  # Header is 16 bytes
        header += struct.pack('>I', code_size)  # Code size
        header += struct.pack('>I', code_offset)  # Code offset

        # Combine header and code
        bytecode = header + bytes(self.code)
        return bytecode


def main():
    parser = argparse.ArgumentParser(
        description='FreeLang Bytecode Assembler',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  python assembler.py input.bc.asm
  python assembler.py input.bc.asm -o output.bc
  python assembler.py examples/hello_world.bc.asm
        """
    )

    parser.add_argument('input', help='Input assembly file (.bc.asm)')
    parser.add_argument('-o', '--output', help='Output bytecode file (.bc)')
    parser.add_argument('-v', '--verbose', action='store_true', help='Verbose output')

    args = parser.parse_args()

    # Determine output filename
    input_path = Path(args.input)
    if args.output:
        output_path = Path(args.output)
    else:
        # Replace .bc.asm with .bc
        output_path = input_path.with_suffix('')
        if output_path.suffix == '.asm':
            output_path = output_path.with_suffix('')

    # Read input file
    try:
        with open(input_path, 'r') as f:
            asm_text = f.read()
    except FileNotFoundError:
        print(f"Error: File not found: {input_path}")
        sys.exit(1)

    # Assemble
    assembler = Assembler()
    assembler.assemble(asm_text)

    # Generate bytecode
    bytecode = assembler.generate_file()

    # Write output
    try:
        with open(output_path, 'wb') as f:
            f.write(bytecode)
        if args.verbose:
            print(f"Assembled {input_path} -> {output_path}")
            print(f"Bytecode size: {len(bytecode)} bytes")
            print(f"Code size: {len(assembler.code)} bytes")
    except IOError as e:
        print(f"Error: Cannot write output: {e}")
        sys.exit(1)


if __name__ == '__main__':
    main()
