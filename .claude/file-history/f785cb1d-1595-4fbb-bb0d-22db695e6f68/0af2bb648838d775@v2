# String Operations in FreeLang Bytecode
#
# Create string, get length, print
#
# Code:
# let msg = "FreeLang"
# let len = msg.length()
# print(msg)
# print(len)
#
# Output:
# FreeLang
# 8

.version 1.0

.code
  # Create string "FreeLang" (8 characters)
  PUSH "FreeLang"
  STORE 0         # store in local[0]

  # Get string length
  LOAD 0
  SLEN            # string length
  STORE 1         # store in local[1]

  # Print the string
  LOAD 0
  PRINT

  # Print the length
  LOAD 1
  PRINT

  # HALT
  HALT 0

.end

# String length operations:
# SLEN: Get string length (number of bytes in UTF-8)
# SLOAD: Load character at index
# SSTORE: Store character at index
# NEWSTR: Create new string from data

