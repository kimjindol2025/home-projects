cmake_minimum_required(VERSION 3.15)
project(MLIR-Formal-Semantics CXX)

set(CMAKE_CXX_STANDARD 17)
set(CMAKE_CXX_STANDARD_REQUIRED ON)

# ============ MLIR Configuration ============

find_package(MLIR REQUIRED CONFIG)
list(APPEND CMAKE_MODULE_PATH "${MLIR_CMAKE_DIR}")
include(AddMLIR)

# Find Z3 (SMT Solver)
find_package(Z3 REQUIRED)

include_directories(${MLIR_INCLUDE_DIRS})
include_directories(${CMAKE_CURRENT_SOURCE_DIR}/include)
include_directories(${Z3_INCLUDE_DIR})

# ============ Formal Semantics Library ============

add_mlir_library(MLIRFormalSemantics
  lib/Formal/FormalSemantics.cpp

  DEPENDS
  MLIRTensorOpsIncGen
  MLIRAffineIncGen

  LINK_LIBS PRIVATE
  z3::z3
  MLIRTensor
  MLIRAffine
  MLIRLinalg
  MLIRMemRef
  MLIRIR
)

# ============ SMT Encoder Library ============

add_mlir_library(MLIRSMTEncoderZ3
  lib/Formal/SMTEncoderZ3.cpp

  LINK_LIBS PRIVATE
  z3::z3
  MLIRFormalSemantics
)

# ============ Verification Engine Library ============

add_mlir_library(MLIRFormalVerification
  lib/Formal/FormalVerificationEngine.cpp

  LINK_LIBS PRIVATE
  MLIRFormalSemantics
  MLIRSMTEncoderZ3
)

# ============ Verification Pass ============

add_mlir_library(MLIRFormalVerificationPass
  lib/Formal/FormalSemanticVerificationPass.cpp

  LINK_LIBS PRIVATE
  MLIRFormalVerification
  MLIRPass
)

# ============ Tests ============

if(BUILD_TESTING)
  enable_testing()

  # Unit tests
  add_test(
    NAME FormalSemanticsTest
    COMMAND ${CMAKE_CURRENT_BINARY_DIR}/test/FormalSemanticsTest
  )

  add_test(
    NAME SMTEncoderTest
    COMMAND ${CMAKE_CURRENT_BINARY_DIR}/test/SMTEncoderTest
  )

  add_test(
    NAME VerificationEngineTest
    COMMAND ${CMAKE_CURRENT_BINARY_DIR}/test/VerificationEngineTest
  )
endif()

# ============ Installation ============

install(
  DIRECTORY include/mlir/Formal
  DESTINATION include/mlir
  FILES_MATCHING PATTERN "*.h"
)

install(
  TARGETS
  MLIRFormalSemantics
  MLIRSMTEncoderZ3
  MLIRFormalVerification
  MLIRFormalVerificationPass
  LIBRARY DESTINATION lib
  ARCHIVE DESTINATION lib
)
