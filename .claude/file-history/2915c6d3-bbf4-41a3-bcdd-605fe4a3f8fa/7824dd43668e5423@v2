#ifndef MLIR_ADAPTIVE_HARDWARE_AWARE_INTERFACE_H
#define MLIR_ADAPTIVE_HARDWARE_AWARE_INTERFACE_H

#include "mlir/IR/OpInterface.td"
#include <cstdint>
#include <vector>

namespace mlir {
namespace adaptive {

/// Hardware specifications for cost modeling
struct HardwareSpec {
  double peakFLOPS;              // Peak computational throughput (FLOPS)
  double memoryBandwidth;        // DRAM bandwidth (GB/sec)
  int64_t sramSize;              // On-chip fast memory (bytes)
  double memoryLatency;          // Memory access latency (cycles)
  int64_t cacheLineSize = 64;    // Cache line size (bytes)
  int64_t l1CacheSize = 32768;   // L1 cache (bytes)
  double clockFrequencyGHz = 1.0;

  // Predefined hardware profiles
  static HardwareSpec getNvidiaH100();
  static HardwareSpec getAppleNeuralEngine();
  static HardwareSpec getCustomTPU();
};

} // namespace adaptive
} // namespace mlir

#include "mlir/IR/OpInterface.h"

namespace mlir {
namespace adaptive {

/// HardwareAwareInterface - 하드웨어 인식 비용 분석 인터페이스
///
/// 모든 텐서 연산이 구현해야 할 인터페이스로, 주어진 하드웨어에서
/// 특정 최적화의 비용을 정량적으로 계산합니다.
///
/// Example:
///   auto matmul = createMatMulOp(...);
///   HardwareSpec h100 = HardwareSpec::getNvidiaH100();
///
///   int64_t memory = matmul->getMemoryFootprint({64, 64, 64});
///   double time = matmul->estimateComputeTime(h100);
///   bool isMem = matmul->isMemoryBound(h100);
class HardwareAwareInterface {
public:
  virtual ~HardwareAwareInterface() = default;

  /// 주어진 타일 크기에서 필요한 메모리량 계산
  ///
  /// @param tileSizes 각 차원의 타일 크기 (배열)
  /// @return 필요한 메모리량 (bytes)
  ///
  /// Example:
  ///   MatMul(1024×1024×1024)에서 T=64일 때:
  ///   메모리 = 64² × 3개 행렬 × 4bytes = 48KB
  virtual int64_t getMemoryFootprint(
      llvm::ArrayRef<int64_t> tileSizes) = 0;

  /// 주어진 하드웨어에서 예상 연산 시간
  ///
  /// @param spec 하드웨어 스펙
  /// @return 예상 실행 시간 (milliseconds)
  ///
  /// Example:
  ///   MatMul 2×10^9 operations / 1 TFLOPS = 2ms
  virtual double estimateComputeTime(
      const HardwareSpec& spec) = 0;

  /// 메모리 접근이 병목인지 확인
  ///
  /// @param spec 하드웨어 스펙
  /// @return true if memory-bound, false if compute-bound
  ///
  /// Roofline 모델:
  ///   Arithmetic Intensity = Operations / Memory_Accesses
  ///   Peak = min(Peak_FLOPS, BW × AI)
  ///   if (AI < Peak_FLOPS / BW) → memory-bound
  virtual bool isMemoryBound(const HardwareSpec& spec) = 0;

  /// 캐시 효율성 예측
  ///
  /// @param tileSizes 타일 크기
  /// @return 캐시 히트율 (0.0 ~ 1.0)
  ///
  /// Example:
  ///   T=32: SRAM 충분 → 히트율 95%
  ///   T=128: SRAM 초과 → 히트율 30%
  virtual double estimateCacheHitRate(
      llvm::ArrayRef<int64_t> tileSizes) = 0;

  /// Roofline 모델을 통한 성능 상한 분석
  ///
  /// @param spec 하드웨어 스펙
  /// @return 달성 가능한 최대 FLOPS
  ///
  /// Roofline 공식:
  ///   Performance = min(Peak_FLOPS, BW_mem × Arithmetic_Intensity)
  virtual double getRooflinePerformance(
      const HardwareSpec& spec) = 0;

  /// 에너지 소비 예측 (Optional)
  ///
  /// @param spec 하드웨어 스펙
  /// @return 예상 에너지 소비 (Joules)
  ///
  /// 공식:
  ///   Energy = Power × Time
  ///   Power = static_power + dynamic_power × utilization
  virtual double estimateEnergyConsumption(
      const HardwareSpec& spec) {
    return 0.0; // Default: not implemented
  }
};

} // namespace adaptive
} // namespace mlir

#endif // MLIR_ADAPTIVE_HARDWARE_AWARE_INTERFACE_H
