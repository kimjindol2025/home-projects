import torch
import torch.nn as nn
import torch.optim as optim
from torch.distributions import Categorical
import numpy as np
from typing import List, Tuple, Dict
from dataclasses import dataclass
import json

# ============ Configuration ============

CONFIG = {
    'state_dim': 100,           # IR 특징 차원
    'action_dim': 1000,         # 가능한 최적화 수
    'hidden_dim': 256,          # 신경망 은닉층
    'learning_rate': 3e-4,      # 학습률
    'gamma': 0.99,              # 할인율
    'gae_lambda': 0.95,         # GAE 가중치
    'epochs': 2000,             # 학습 에포크
    'batch_size': 32,           # 배치 크기
    'mini_epochs': 10,          # PPO 미니 에포크
    'clip_ratio': 0.2,          # PPO 클립 비율
    'entropy_coef': 0.01,       # 엔트로피 정규화
    'value_coef': 0.5,          # 가치 손실 계수
}

# ============ State & Action ============

@dataclass
class IRState:
    """MLIR IR의 특징을 나타내는 상태"""
    loop_depth: int             # 루프 깊이
    operation_type: int         # 연산 종류
    tensor_dims: List[int]      # 텐서 차원
    stride_pattern: List[int]   # 메모리 접근 패턴
    hw_params: Dict             # 하드웨어 매개변수

    def to_vector(self) -> np.ndarray:
        """상태를 벡터로 변환"""
        vec = np.zeros(CONFIG['state_dim'])
        vec[0] = self.loop_depth
        vec[1] = self.operation_type
        vec[2:5] = self.tensor_dims[:3]  # 처음 3개 차원
        vec[5:8] = self.stride_pattern[:3]
        # ... 추가 특징들
        return vec.astype(np.float32)

@dataclass
class OptimizationAction:
    """최적화 결정"""
    tile_sizes: List[int]
    loop_order: List[int]
    vector_width: int
    fusion: bool
    interchange: bool

class ActionDecoder:
    """연속 행동 공간을 이산 행동으로 변환"""

    def __init__(self):
        self.tile_powers = list(range(4, 11))  # 2^4 ~ 2^10
        self.vector_widths = [4, 8, 16, 32, 64]

    def decode(self, action_idx: int,
               state: IRState) -> OptimizationAction:
        """
        이산 행동 인덱스를 OptimizationAction으로 변환
        """
        # 단순화된 디코딩 (실제로는 더 복잡)
        tile_sizes = [2**self.tile_powers[action_idx % 7],
                     2**self.tile_powers[(action_idx // 7) % 7],
                     2**self.tile_powers[(action_idx // 49) % 7]]

        loop_order = [0, 1, 2]  # TODO: 순열 적용
        vector_width = self.vector_widths[action_idx % 5]
        fusion = (action_idx % 2) == 0
        interchange = (action_idx % 3) == 0

        return OptimizationAction(
            tile_sizes=tile_sizes,
            loop_order=loop_order,
            vector_width=vector_width,
            fusion=fusion,
            interchange=interchange
        )

# ============ Neural Networks ============

class PolicyNetwork(nn.Module):
    """Actor: 상태에서 행동을 선택하는 신경망"""

    def __init__(self):
        super().__init__()

        # 공유 백본
        self.backbone = nn.Sequential(
            nn.Linear(CONFIG['state_dim'], CONFIG['hidden_dim']),
            nn.ReLU(),
            nn.LayerNorm(CONFIG['hidden_dim']),
            nn.Linear(CONFIG['hidden_dim'], 128),
            nn.ReLU(),
            nn.LayerNorm(128)
        )

        # 정책 헤드 (행동 선택)
        self.policy_head = nn.Linear(128, CONFIG['action_dim'])

        # 엔트로피를 위한 온도 (temperature)
        self.temperature = nn.Parameter(torch.ones(1))

    def forward(self, state: torch.Tensor) -> Tuple[torch.Tensor, torch.Tensor]:
        """
        상태에서 행동 분포 추출

        Returns:
            logits: 행동의 로짓 (크기: batch_size × action_dim)
            probs: 행동 확률 (크기: batch_size × action_dim)
        """
        features = self.backbone(state)
        logits = self.policy_head(features) / self.temperature

        # Softmax로 확률 분포 생성
        probs = torch.softmax(logits, dim=-1)

        return logits, probs

    def select_action(self, state: torch.Tensor,
                     action_mask: torch.Tensor = None
                     ) -> Tuple[int, float]:
        """
        상태에서 행동을 샘플링

        Args:
            state: 현재 상태 벡터
            action_mask: 불가능한 행동을 마스킹 (선택)

        Returns:
            action: 선택된 행동 인덱스
            log_prob: 선택된 행동의 로그 확률
        """
        logits, probs = self.forward(state.unsqueeze(0))

        # 제약 조건 마스킹 적용
        if action_mask is not None:
            logits = logits.clone()
            logits[action_mask == 0] = -1e10

        # Categorical 분포에서 샘플
        dist = Categorical(logits=logits[0])
        action = dist.sample()
        log_prob = dist.log_prob(action)

        return action.item(), log_prob.item()


class ValueNetwork(nn.Module):
    """Critic: 상태의 가치를 추정하는 신경망"""

    def __init__(self):
        super().__init__()

        # 공유 백본 (Policy와 동일)
        self.backbone = nn.Sequential(
            nn.Linear(CONFIG['state_dim'], CONFIG['hidden_dim']),
            nn.ReLU(),
            nn.LayerNorm(CONFIG['hidden_dim']),
            nn.Linear(CONFIG['hidden_dim'], 128),
            nn.ReLU(),
            nn.LayerNorm(128)
        )

        # 가치 헤드 (스칼라)
        self.value_head = nn.Linear(128, 1)

    def forward(self, state: torch.Tensor) -> torch.Tensor:
        """
        상태의 가치 추정

        Args:
            state: 상태 벡터 (크기: batch_size × state_dim)

        Returns:
            values: 추정된 가치 (크기: batch_size)
        """
        features = self.backbone(state)
        values = self.value_head(features).squeeze(-1)
        return values

# ============ Action Masking ============

class ConstraintMasker:
    """하드웨어 제약 조건을 기반으로 불가능한 행동 마스킹"""

    def __init__(self, hw_spec: Dict):
        self.hw_spec = hw_spec
        self.sram_size = hw_spec['sram_size']  # bytes
        self.num_inputs = 3  # A, B, C
        self.elem_size = 4   # FP32

    def create_mask(self, state: IRState) -> torch.Tensor:
        """
        현재 상태에서 가능한 행동의 마스크 생성

        Returns:
            mask: 크기 [action_dim], 1 = 가능, 0 = 불가능
        """
        mask = torch.ones(CONFIG['action_dim'])

        # 모든 가능한 행동에 대해 제약 확인
        action_decoder = ActionDecoder()

        for action_idx in range(CONFIG['action_dim']):
            action = action_decoder.decode(action_idx, state)

            # SRAM 제약 확인
            if not self._check_sram_constraint(action):
                mask[action_idx] = 0

            # 차원 크기 제약 확인
            if not self._check_dimension_constraint(action, state):
                mask[action_idx] = 0

        return mask

    def _check_sram_constraint(self, action: OptimizationAction) -> bool:
        """SRAM 용량 초과 확인"""
        memory = 1
        for t in action.tile_sizes:
            memory *= t
        memory *= self.num_inputs * self.elem_size

        return memory <= self.sram_size

    def _check_dimension_constraint(self, action: OptimizationAction,
                                    state: IRState) -> bool:
        """텐서 차원 크기 초과 확인"""
        for i, t in enumerate(action.tile_sizes):
            if i >= len(state.tensor_dims) or t > state.tensor_dims[i]:
                return False
        return True

# ============ Reward Calculator ============

class RewardCalculator:
    """다중 목표 보상 함수"""

    def __init__(self, baseline_latency: float,
                 baseline_energy: float = 1.0):
        self.baseline_latency = baseline_latency
        self.baseline_energy = baseline_energy

    def calculate(self, optimized_latency: float,
                  optimized_energy: float,
                  compile_time: float) -> float:
        """
        통합 보상 계산

        Args:
            optimized_latency: 최적화 후 지연시간 (ms)
            optimized_energy: 최적화 후 에너지 (mJ)
            compile_time: 컴파일 시간 (s)

        Returns:
            reward: [-5, +3] 범위의 보상
        """
        # 성능 보상 (주요 목표: 60%)
        throughput_gain = self.baseline_latency / max(optimized_latency, 0.001)
        r_perf = (throughput_gain - 1) / 10 * 3  # 정규화

        # 에너지 보상 (보조 목표: 20%)
        energy_ratio = self.baseline_energy / max(optimized_energy, 0.001)
        r_energy = energy_ratio if energy_ratio >= 1.0 else -0.5

        # 컴파일 시간 페널티 (20%)
        r_compile = -max(0, (compile_time - 10.0) / 10.0)

        # 통합
        r_total = (0.6 * r_perf +
                   0.2 * r_energy +
                   0.2 * r_compile)

        return np.clip(r_total, -5, 3)

# ============ PPO Trainer ============

class PPOTrainer:
    """PPO 알고리즘으로 에이전트 학습"""

    def __init__(self, hw_spec: Dict):
        self.hw_spec = hw_spec
        self.policy = PolicyNetwork()
        self.value = ValueNetwork()
        self.masker = ConstraintMasker(hw_spec)

        self.optimizer_policy = optim.Adam(
            self.policy.parameters(),
            lr=CONFIG['learning_rate']
        )
        self.optimizer_value = optim.Adam(
            self.value.parameters(),
            lr=CONFIG['learning_rate']
        )

        self.device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
        self.policy.to(self.device)
        self.value.to(self.device)

    def train_epoch(self, states: List[np.ndarray],
                   actions: List[int],
                   rewards: List[float],
                   old_log_probs: List[float]) -> Dict[str, float]:
        """
        한 에포크의 PPO 학습

        Returns:
            손실값 통계
        """
        states = torch.FloatTensor(states).to(self.device)
        actions = torch.LongTensor(actions).to(self.device)
        rewards = torch.FloatTensor(rewards).to(self.device)
        old_log_probs = torch.FloatTensor(old_log_probs).to(self.device)

        # Advantage 계산 (GAE)
        with torch.no_grad():
            values = self.value(states)

        advantages = []
        gae = 0
        for t in reversed(range(len(rewards))):
            if t == len(rewards) - 1:
                next_value = 0
            else:
                next_value = values[t + 1]

            delta = rewards[t] + CONFIG['gamma'] * next_value - values[t]
            gae = delta + CONFIG['gamma'] * CONFIG['gae_lambda'] * gae
            advantages.insert(0, gae)

        advantages = torch.FloatTensor(advantages).to(self.device)
        returns = advantages + values.detach()

        # 정규화
        advantages = (advantages - advantages.mean()) / (advantages.std() + 1e-8)

        # PPO 업데이트
        total_loss = 0.0
        for _ in range(CONFIG['mini_epochs']):
            # 정책 손실
            logits, _ = self.policy(states)
            dist = Categorical(logits=logits)
            new_log_probs = dist.log_prob(actions)

            ratio = torch.exp(new_log_probs - old_log_probs)
            surr1 = ratio * advantages
            surr2 = torch.clamp(
                ratio,
                1 - CONFIG['clip_ratio'],
                1 + CONFIG['clip_ratio']
            ) * advantages

            actor_loss = -torch.min(surr1, surr2).mean()
            entropy = dist.entropy().mean()

            # 가치 손실
            critic_loss = ((self.value(states) - returns) ** 2).mean()

            # 총 손실
            loss = (actor_loss +
                   CONFIG['value_coef'] * critic_loss -
                   CONFIG['entropy_coef'] * entropy)

            self.optimizer_policy.zero_grad()
            self.optimizer_value.zero_grad()
            loss.backward()

            torch.nn.utils.clip_grad_norm_(self.policy.parameters(), 0.5)
            torch.nn.utils.clip_grad_norm_(self.value.parameters(), 0.5)

            self.optimizer_policy.step()
            self.optimizer_value.step()

            total_loss += loss.item()

        return {
            'actor_loss': actor_loss.item(),
            'critic_loss': critic_loss.item(),
            'entropy': entropy.item(),
            'avg_advantage': advantages.mean().item()
        }

    def save(self, path: str) -> None:
        """모델 저장"""
        torch.save({
            'policy': self.policy.state_dict(),
            'value': self.value.state_dict(),
        }, path)
        print(f"✅ Model saved to {path}")

    def load(self, path: str) -> None:
        """모델 로드"""
        checkpoint = torch.load(path)
        self.policy.load_state_dict(checkpoint['policy'])
        self.value.load_state_dict(checkpoint['value'])
        print(f"✅ Model loaded from {path}")

# ============ Main Training Loop ============

def main():
    print("=" * 70)
    print("RL-based Optimization Engine - PPO Training")
    print("Phase 1.3: AI Agent Learning")
    print("=" * 70)

    # 하드웨어 스펙
    hw_spec = {
        'peak_flops': 3.96e12,
        'memory_bandwidth': 3.94e12,
        'sram_size': 192 * 1024,  # 192 KB
    }

    print(f"\n📊 Hardware: NVIDIA H100")
    print(f"  SRAM: {hw_spec['sram_size']/1024:.0f} KB")

    # 에이전트 생성
    trainer = PPOTrainer(hw_spec)
    print(f"\n🤖 Agent created (Policy + Value Networks)")

    # 학습 루프
    best_reward = -float('inf')
    reward_history = []

    print(f"\n🚀 Training started...")

    for epoch in range(CONFIG['epochs']):
        # 경험 수집 (시뮬레이션)
        states = []
        actions = []
        rewards = []
        log_probs = []

        for _ in range(CONFIG['batch_size']):
            # 임의의 상태 생성 (실제로는 IR에서)
            state_vec = np.random.randn(CONFIG['state_dim']).astype(np.float32)
            state_tensor = torch.FloatTensor(state_vec)

            # 행동 선택
            action, log_prob = trainer.policy.select_action(state_tensor)

            # 보상 계산 (임의)
            reward = np.random.randn() + 1.0  # 평균 1.0, 표준편차 1.0

            states.append(state_vec)
            actions.append(action)
            rewards.append(reward)
            log_probs.append(log_prob)

        # PPO 업데이트
        stats = trainer.train_epoch(states, actions, rewards, log_probs)
        avg_reward = np.mean(rewards)
        reward_history.append(avg_reward)

        # 모니터링
        if (epoch + 1) % 100 == 0:
            print(f"\n📈 Epoch {epoch+1}/{CONFIG['epochs']}")
            print(f"  Avg Reward: {avg_reward:.3f}")
            print(f"  Actor Loss: {stats['actor_loss']:.4f}")
            print(f"  Critic Loss: {stats['critic_loss']:.4f}")
            print(f"  Entropy: {stats['entropy']:.4f}")

        if avg_reward > best_reward:
            best_reward = avg_reward

    # 최종 모델 저장
    trainer.save('rl_agent.pth')

    print(f"\n✅ Training complete!")
    print(f"  Final Best Reward: {best_reward:.3f}")
    print(f"  Model saved: rl_agent.pth")

if __name__ == "__main__":
    main()
