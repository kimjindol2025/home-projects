class CertifiedStrategyLibrary:
    """검증을 통과한 최적화 전략만 모음"""

    def __init__(self):
        self.strategies = {
            "loop_tiling_32x32": {
                "preconditions": ["N >= 32", "M >= 32"],
                "verified": True,
                "proof_id": "proof_2026_02_27_001",
                "performance_gain": 2.1,  # 2.1배 빠름
                "error_bound": 0.0,  # 정수 연산
                "applicable_to": ["matrix_multiply", "convolution"]
            },
            "fp32_to_bf16_exp": {
                "preconditions": ["x in [-10, 10]"],
                "verified": True,
                "proof_id": "proof_2026_02_27_002",
                "performance_gain": 1.8,  # 1.8배 빠름
                "error_bound": 0.001,  # 0.1% 오차
                "applicable_to": ["softmax", "attention"]
            },
            "loop_interchange_ij": {
                "preconditions": ["no_flow_dependence(i,j)"],
                "verified": True,
                "proof_id": "proof_2026_02_27_003",
                "performance_gain": 1.3,
                "error_bound": 0.0,
                "applicable_to": ["stencil_computation"]
            }
        }

    def get_applicable_strategies(self, kernel_type, constraints):
        """커널에 적용 가능한 검증된 전략 추천"""
        candidates = []
        for name, strategy in self.strategies.items():
            if strategy["verified"] and self._check_preconditions(strategy, constraints):
                candidates.append((name, strategy))
        return sorted(candidates, key=lambda x: x[1]["performance_gain"], reverse=True)
