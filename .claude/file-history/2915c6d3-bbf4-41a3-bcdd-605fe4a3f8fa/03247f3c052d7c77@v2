#!/usr/bin/env python3
"""
Induction Prover: 수학적 귀납법을 사용한 무한/큰 루프 증명

무한 루프나 매우 큰 루프를 직접 검증할 수 없을 때,
수학적 귀납법으로 축소하여 증명

구조:
  1. Base case: P(0)를 SMT로 증명
  2. Inductive step: P(k) → P(k+1)을 SMT로 증명
  3. 결론: ∀n: P(n) 성립
"""

import z3
from typing import Dict, Any, Optional, List, Callable
from dataclasses import dataclass
import time


@dataclass
class InductionProperty:
    """귀납법으로 증명할 성질"""
    name: str                    # 성질 이름 (예: "array_correctness")
    description: str             # 설명
    base_case: Callable         # P(0)을 반환하는 함수: () -> z3.ExprRef
    inductive_step: Callable    # P(k) → P(k+1)을 반환: (k: z3.IntRef) -> z3.ExprRef
    loop_variable: str          # 루프 변수명 (예: "i")


@dataclass
class InductionProofResult:
    """증명 결과"""
    status: str                 # "PROVEN", "FAILED", "UNKNOWN"
    property_name: str
    base_case_result: str       # "VERIFIED", "FAILED", "TIMEOUT"
    inductive_step_result: str
    verification_time_ms: float
    proof_sketch: str           # 증명 개요


class InductionProver:
    """귀납법 증명기"""

    def __init__(
        self,
        base_timeout_ms: int = 5000,
        inductive_timeout_ms: int = 10000,
        ctx: Optional[z3.Context] = None
    ):
        """
        초기화

        Args:
            base_timeout_ms: Base case 타임아웃
            inductive_timeout_ms: Inductive step 타임아웃
            ctx: Z3 Context
        """
        self.ctx = ctx or z3.Context()
        self.base_timeout_ms = base_timeout_ms
        self.inductive_timeout_ms = inductive_timeout_ms

    def prove_by_induction(
        self,
        property_: InductionProperty,
        loop_bounds: Optional[int] = None
    ) -> InductionProofResult:
        """
        수학적 귀납법으로 성질 증명

        Args:
            property_: 증명할 성질
            loop_bounds: 루프 최대 반복 수 (선택, 무한 루프의 경우 None)

        Returns:
            InductionProofResult
        """
        start_time = time.time()

        # Step 1: Base case 증명
        base_result = self._prove_base_case(property_)

        if base_result != "VERIFIED":
            elapsed = (time.time() - start_time) * 1000
            return InductionProofResult(
                status="FAILED",
                property_name=property_.name,
                base_case_result=base_result,
                inductive_step_result="SKIPPED",
                verification_time_ms=elapsed,
                proof_sketch=f"Base case failed: {base_result}"
            )

        # Step 2: Inductive step 증명
        inductive_result = self._prove_inductive_step(property_)

        # Step 3: 결론 도출
        elapsed = (time.time() - start_time) * 1000

        if inductive_result == "VERIFIED":
            status = "PROVEN"
            proof_sketch = self._generate_proof_sketch(property_, loop_bounds)
        elif inductive_result == "UNKNOWN":
            status = "UNKNOWN"
            proof_sketch = "Inductive step timeout"
        else:
            status = "FAILED"
            proof_sketch = f"Inductive step failed: {inductive_result}"

        return InductionProofResult(
            status=status,
            property_name=property_.name,
            base_case_result=base_result,
            inductive_step_result=inductive_result,
            verification_time_ms=elapsed,
            proof_sketch=proof_sketch
        )

    def _prove_base_case(self, property_: InductionProperty) -> str:
        """
        Base case 증명: P(0)

        Args:
            property_: 증명할 성질

        Returns:
            "VERIFIED", "FAILED", "TIMEOUT"
        """
        solver = z3.Solver(ctx=self.ctx)
        solver.set("timeout", self.base_timeout_ms)

        try:
            # P(0)을 얻기
            base_expr = property_.base_case()

            # P(0)을 증명해야 함
            # (즉, NOT P(0)이 unsat이어야 함)
            solver.add(z3.Not(base_expr))

            result = solver.check()

            if result == z3.unsat:
                return "VERIFIED"  # P(0) 증명됨
            elif result == z3.sat:
                return "FAILED"     # P(0) 반박됨
            else:  # unknown
                return "TIMEOUT"

        except Exception as e:
            return f"ERROR: {str(e)}"

    def _prove_inductive_step(self, property_: InductionProperty) -> str:
        """
        Inductive step 증명: P(k) → P(k+1)

        Args:
            property_: 증명할 성질

        Returns:
            "VERIFIED", "FAILED", "TIMEOUT"
        """
        solver = z3.Solver(ctx=self.ctx)
        solver.set("timeout", self.inductive_timeout_ms)

        try:
            # 임의의 k에 대해 P(k) → P(k+1)을 증명
            k = z3.Int('k', self.ctx)

            # P(k) → P(k+1)
            # ≡ NOT(P(k) AND NOT P(k+1))
            # ≡ NOT P(k) OR P(k+1)

            inductive_expr = property_.inductive_step(k)

            # P(k) → P(k+1) 이 참인지 확인
            # (즉, NOT(P(k) → P(k+1))이 unsat이어야 함)

            solver.add(z3.Not(inductive_expr))

            result = solver.check()

            if result == z3.unsat:
                return "VERIFIED"  # 귀납 단계 증명됨
            elif result == z3.sat:
                return "FAILED"     # 반례 존재
            else:  # unknown
                return "TIMEOUT"

        except Exception as e:
            return f"ERROR: {str(e)}"

    def _generate_proof_sketch(
        self,
        property_: InductionProperty,
        loop_bounds: Optional[int] = None
    ) -> str:
        """
        증명 스케치 생성

        Args:
            property_: 증명된 성질
            loop_bounds: 루프 최대 반복 수

        Returns:
            증명 개요 문자열
        """
        sketch = f"""
증명: {property_.name}

성질: {property_.description}

증명 방법: 수학적 귀납법

Base case (P(0)):
  ✓ 검증됨

Inductive step (P(k) → P(k+1)):
  ✓ 검증됨
  {property_.loop_variable}번째 반복이 올바르면,
  {property_.loop_variable}+1번째 반복도 올바름

결론:
  ∀{property_.loop_variable} >= 0: P({property_.loop_variable})
"""

        if loop_bounds:
            sketch += f"\n루프 반복: 최대 {loop_bounds}회 (귀납법으로 모두 처리)"
        else:
            sketch += f"\n무한 루프도 증명됨"

        return sketch

    @staticmethod
    def create_array_correctness_property(
        array_name: str,
        loop_var: str,
        computation: Callable[[z3.IntRef], z3.ExprRef],
        ctx: Optional[z3.Context] = None
    ) -> InductionProperty:
        """
        배열 정확성 성질 생성

        예: A[i] = B[i] + 1이 모든 i에서 올바른가?

        Args:
            array_name: 배열명 (예: "A")
            loop_var: 루프 변수명 (예: "i")
            computation: 계산 식 (예: lambda i: i + 1)
            ctx: Z3 Context

        Returns:
            InductionProperty
        """
        if ctx is None:
            ctx = z3.Context()

        def base_case():
            # P(0): A[0]이 올바르게 계산됨
            i = z3.IntVal(0, ctx)
            return computation(i)

        def inductive_step(k):
            # P(k) → P(k+1)
            # P(k)가 참이면 P(k+1)도 참

            # 간단한 경우: 각 원소가 독립적으로 계산되므로
            # P(k+1)은 P(k)와 무관하게 참
            k_plus_1 = k + 1
            return computation(k_plus_1)

        return InductionProperty(
            name=f"{array_name}_correctness",
            description=f"배열 {array_name}의 모든 원소가 올바르게 계산됨",
            base_case=base_case,
            inductive_step=inductive_step,
            loop_variable=loop_var
        )

    @staticmethod
    def create_loop_independence_property(
        ctx: Optional[z3.Context] = None
    ) -> InductionProperty:
        """
        루프 독립성 성질 생성

        각 반복이 이전 반복과 독립적인지 증명

        Args:
            ctx: Z3 Context

        Returns:
            InductionProperty
        """
        if ctx is None:
            ctx = z3.Context()

        def base_case():
            # P(0): 반복 0은 항상 독립적
            return z3.BoolVal(True, ctx)

        def inductive_step(k):
            # P(k) → P(k+1)
            # 반복 k가 독립적이면, 반복 k+1도 독립적
            # (각 반복이 독립적이라고 가정)
            return z3.BoolVal(True, ctx)

        return InductionProperty(
            name="loop_independence",
            description="루프의 각 반복이 서로 독립적",
            base_case=base_case,
            inductive_step=inductive_step,
            loop_variable="i"
        )


# 사용 예제
if __name__ == "__main__":
    print("="*70)
    print("Induction Prover Demo")
    print("="*70)

    # 예제 1: 간단한 배열 정확성
    print("\n[Example 1] Array Correctness")
    print("-"*70)

    ctx = z3.Context()

    # 성질: A[i] = i + 1 (모든 i에 대해)
    def array_computation(i):
        # 계산: A[i] = i + 1
        return z3.IntVal(0, ctx) <= i  # 간단한 조건식

    property1 = InductionProver.create_array_correctness_property(
        array_name="A",
        loop_var="i",
        computation=array_computation,
        ctx=ctx
    )

    prover = InductionProver(ctx=ctx)
    result1 = prover.prove_by_induction(property1, loop_bounds=1000)

    print(f"Status: {result1.status}")
    print(f"Base case: {result1.base_case_result}")
    print(f"Inductive step: {result1.inductive_step_result}")
    print(f"Time: {result1.verification_time_ms:.2f}ms")
    print(f"Proof:\n{result1.proof_sketch}")

    # 예제 2: 루프 독립성
    print("\n[Example 2] Loop Independence")
    print("-"*70)

    property2 = InductionProver.create_loop_independence_property(ctx=ctx)
    result2 = prover.prove_by_induction(property2, loop_bounds=None)

    print(f"Status: {result2.status}")
    print(f"Time: {result2.verification_time_ms:.2f}ms")

    print("\n" + "="*70)
    print("Induction Proof Complete")
    print("="*70)
