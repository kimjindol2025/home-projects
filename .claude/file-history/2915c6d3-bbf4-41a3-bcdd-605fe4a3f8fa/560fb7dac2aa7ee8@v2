#ifndef MLIR_FORMAL_SMT_ENCODER_Z3_H
#define MLIR_FORMAL_SMT_ENCODER_Z3_H

#include "mlir/Formal/FormalSemantics.h"
#include <string>
#include <memory>
#include <optional>

// Forward declaration for Z3
namespace z3 {
class context;
class expr;
class solver;
}

namespace mlir::formal {

/// Z3-based SMT formula encoder
/// Converts formal semantics to Z3 constraints for verification
class SMTEncoderZ3 {
private:
  std::unique_ptr<z3::context> ctx_;
  std::unique_ptr<z3::solver> solver_;

public:
  SMTEncoderZ3();
  ~SMTEncoderZ3();

  /// Encode MatMul operation for tiling verification
  /// Returns: Z3 formula that proves tiled_matmul ≡ original_matmul
  std::string encodeMatMulTiling(
      const TensorSemantics& original,
      const TensorSemantics& tiled,
      int64_t tileSize);

  /// Encode Conv2D operation verification
  std::string encodeConv2DVerification(
      const TensorSemantics& original,
      const TensorSemantics& optimized);

  /// Encode loop fusion verification
  std::string encodeLoopFusion(
      const AffineSemantics& loop1,
      const AffineSemantics& loop2);

  /// Encode address aliasing constraints
  std::string encodeAliasConstraints(
      const MemRefSemantics& memref1,
      const MemRefSemantics& memref2);

  /// Encode floating-point semantics (IEEE-754)
  std::string encodeFloatSemantics(
      const std::string& operation);

  /// Get SMT formula in SMT-LIB2 format
  std::string getSMTLibFormat() const;
};

/// Verification result
struct VerificationResult {
  bool isSound;                           // Transformation is sound
  std::string smtFormula;                 // SMT formula used
  std::optional<std::string> counterexample;  // If unsound, CE
  uint64_t solverTimeMs;                  // Solver execution time
};

} // namespace mlir::formal

#endif // MLIR_FORMAL_SMT_ENCODER_Z3_H
