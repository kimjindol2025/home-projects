#ifndef MLIR_FORMAL_VERIFICATION_ENGINE_H
#define MLIR_FORMAL_VERIFICATION_ENGINE_H

#include "mlir/Formal/SMTEncoderZ3.h"
#include "mlir/IR/Operation.h"
#include <string>
#include <memory>
#include <vector>
#include <unordered_map>

namespace mlir::formal {

/// Main verification engine
/// Orchestrates semantic extraction, SMT encoding, and solver execution
class FormalVerificationEngine {
private:
  std::unique_ptr<SMTEncoderZ3> encoder_;
  std::unordered_map<std::string, VerificationResult> proofCache_;

public:
  FormalVerificationEngine();
  ~FormalVerificationEngine();

  /// Verify that a transformation preserves semantics
  /// Main entry point for verification
  VerificationResult verifyTransform(
      Operation* original,
      Operation* transformed);

  /// Verify tiling transformation is sound
  VerificationResult verifyTiling(
      Operation* op,
      int64_t tileSize);

  /// Verify operation fusion is safe
  VerificationResult verifyFusion(
      ArrayRef<Operation*> operations);

  /// Verify loop transformation preserves order
  VerificationResult verifyLoopTransform(
      Operation* original,
      Operation* transformed);

  /// Clear proof cache
  void clearCache() { proofCache_.clear(); }

  /// Get cache statistics
  struct CacheStats {
    uint64_t hits;
    uint64_t misses;
    uint64_t totalProofs;
  };

  CacheStats getCacheStats() const;
};

/// Proof cache for incremental verification
class ProofCache {
private:
  struct CachedProof {
    bool isSound;
    std::string formula;
    uint64_t timestamp;
  };

  std::unordered_map<std::string, CachedProof> cache_;
  static constexpr uint64_t CACHE_TTL_MS = 3600000; // 1 hour

public:
  bool lookup(const std::string& key, bool& result);
  void cache(const std::string& key, bool result);
  void invalidate(const std::string& pattern);
  size_t size() const { return cache_.size(); }
};

/// Counterexample generator for debugging
class CounterexampleGenerator {
public:
  struct Counterexample {
    std::string tensorValues;
    std::string explanation;
    std::string suggestedFix;
  };

  Counterexample generate(
      const std::string& failureDescription,
      const Operation* failedOp);
};

} // namespace mlir::formal

#endif // MLIR_FORMAL_VERIFICATION_ENGINE_H
