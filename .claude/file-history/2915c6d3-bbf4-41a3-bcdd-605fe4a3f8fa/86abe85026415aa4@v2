```javascript
// 1. quality-service.js - 핵심 로직
class QualityService {
  rate(repo, stars, issues, actions)
  list(filters: {stars?, status?, category?})
  securityReview()
  statistics()
}

// 2. kimsearch-v2-quality-api.js - 포트 40008
GET  /quality/rate         // 평가 저장
GET  /quality/list         // 목록
GET  /quality/security-review
GET  /quality/stats

// 3. 통합
