    def _test_task_graph_building(self):
        """Test 2: 태스크 그래프 생성"""
        print("\n[Test 2] 태스크 그래프 (Task Graph)")
        print("-" * 80)

        try:
            graph = TaskGraph()

            # 작업 추가
            task_a = graph.add_task(
                TaskType.COMPUTE, "matmul_a",
                work_size_flops=1e12,
                target_device="gpu_0"
            )
            graph.tasks[task_a].estimated_time_ms = 20.0

            task_b = graph.add_task(
                TaskType.COMPUTE, "matmul_b",
                work_size_flops=1e12,
                target_device="gpu_1"
            )
            graph.tasks[task_b].estimated_time_ms = 20.0

            # task_a와 task_b는 독립적 (병렬 가능)
            task_reduce = graph.add_task(
                TaskType.COMMUNICATE, "all_reduce",
                data_size_bytes=1e9,
                target_device="gpu_group"
            )
            graph.tasks[task_reduce].estimated_time_ms = 15.0

            # 의존성 추가
            graph.add_dependency(task_a, task_reduce, "data")
            graph.add_dependency(task_b, task_reduce, "data")

            # 위상 정렬
            sorted_tasks = graph.topological_sort()

            # 병렬화 그룹 찾기
            parallel_groups = graph.identify_parallelizable_tasks()

            # 임계 경로 찾기
            max_depth, critical_path = graph.find_critical_path()

            self._record_test("Task graph construction", True)
            print(f"✓ Task graph created with {len(graph.tasks)} tasks")
            print(f"✓ Parallelizable groups: {len(parallel_groups)}")
            print(f"✓ Critical path length: {max_depth:.2f}ms")

        except Exception as e:
