/**
 * KimSearch Mobile - Search Screen Component
 *
 * UI:
 * - 검색창 (텍스트 입력)
 * - 필터 (언어, 별점, 정렬)
 * - 결과 리스트 (파일명, 경로, 품질)
 * - 코드 미리보기 (하이라이팅)
 *
 * Author: Claude (Haiku 4.5)
 * Date: 2026-02-26
 */

import React, { useState, useCallback, useEffect } from 'react';
import {
  View,
  Text,
  TextInput,
  TouchableOpacity,
  FlatList,
  StyleSheet,
  ActivityIndicator,
  SafeAreaView,
  ScrollView,
  Dimensions
} from 'react-native';
import SearchEngine from './searchEngine';
import DatabaseManager from './database';

const { width } = Dimensions.get('window');

interface SearchResult {
  id: number;
  path: string;
  file_name: string;
  extension: string;
  functions: string[];
  classes: string[];
  content: string;
  highlightedContent: string;
  quality: {
    stars: number;
    category: string;
  };
  last_modified: string;
}

const SearchScreen = () => {
  const [query, setQuery] = useState('');
  const [results, setResults] = useState<SearchResult[]>([]);
  const [loading, setLoading] = useState(false);
  const [selectedLang, setSelectedLang] = useState('');
  const [selectedSort, setSelectedSort] = useState('relevance');
  const [minQuality, setMinQuality] = useState(0);
  const [selectedResult, setSelectedResult] = useState<SearchResult | null>(null);
  const [stats, setStats] = useState(null);

  const languages = ['all', 'js', 'py', 'go', 'ts', 'java', 'rb', 'php', 'rs'];
  const sortOptions = ['relevance', 'quality', 'recent'];

  /**
   * 검색 실행
   */
  const handleSearch = useCallback(async () => {
    if (!query.trim()) return;

    setLoading(true);
    try {
      const response = await SearchEngine.search(query, {
        lang: selectedLang === 'all' ? null : selectedLang,
        sort: selectedSort,
        minQuality: minQuality,
        limit: 20
      });

      setResults(response.results);
      setSelectedResult(null);

      // 통계 업데이트
      const cacheStats = SearchEngine.getCacheStats();
      setStats(cacheStats);
    } catch (error) {
      console.error('검색 실패:', error);
      setResults([]);
    } finally {
      setLoading(false);
    }
  }, [query, selectedLang, selectedSort, minQuality]);

  /**
   * 결과 아이템 렌더링
   */
  const renderResultItem = ({ item }: { item: SearchResult }) => {
    const getQualityColor = (stars: number) => {
      if (stars >= 5) return '#4CAF50';
      if (stars >= 4) return '#8BC34A';
      if (stars >= 3) return '#FFC107';
      if (stars >= 2) return '#FF5722';
      return '#f44336';
    };

    const getQualityEmoji = (stars: number) => {
      if (stars >= 5) return '🟢';
      if (stars >= 4) return '🟡';
      if (stars >= 3) return '🟠';
      if (stars >= 2) return '🔴';
      return '⛔';
    };

    return (
      <TouchableOpacity
        onPress={() => setSelectedResult(item)}
        style={[
          styles.resultItem,
          selectedResult?.id === item.id && styles.resultItemSelected
        ]}
      >
        <View style={styles.resultHeader}>
          <Text style={styles.resultFile}>{item.file_name}</Text>
          <Text style={styles.resultQuality}>
            {getQualityEmoji(item.quality.stars)} ⭐{item.quality.stars}
          </Text>
        </View>

        <Text style={styles.resultPath}>{item.path}</Text>

        {item.functions.length > 0 && (
          <Text style={styles.resultMeta}>
            Functions: {item.functions.join(', ')}
          </Text>
        )}

        {item.classes.length > 0 && (
          <Text style={styles.resultMeta}>
            Classes: {item.classes.join(', ')}
          </Text>
        )}

        <Text style={styles.resultPreview} numberOfLines={2}>
          {item.content.substring(0, 80)}...
        </Text>
      </TouchableOpacity>
    );
  };

  /**
   * 상세 보기 렌더링
   */
  const renderDetailView = () => {
    if (!selectedResult) return null;

    return (
      <View style={styles.detailContainer}>
        <TouchableOpacity
          onPress={() => setSelectedResult(null)}
          style={styles.closeButton}
        >
          <Text style={styles.closeButtonText}>✕</Text>
        </TouchableOpacity>

        <ScrollView style={styles.detailContent}>
          <Text style={styles.detailTitle}>{selectedResult.file_name}</Text>
          <Text style={styles.detailPath}>{selectedResult.path}</Text>

          <View style={styles.detailMeta}>
            <Text style={styles.detailMetaLabel}>
              Quality: {selectedResult.quality.stars}⭐
            </Text>
            <Text style={styles.detailMetaLabel}>
              Type: {selectedResult.extension}
            </Text>
            <Text style={styles.detailMetaLabel}>
              Lines: {selectedResult.content.split('\n').length}
            </Text>
          </View>

          {selectedResult.functions.length > 0 && (
            <View style={styles.detailSection}>
              <Text style={styles.detailSectionTitle}>Functions</Text>
              {selectedResult.functions.map((fn, idx) => (
                <Text key={idx} style={styles.detailSectionItem}>
                  • {fn}
                </Text>
              ))}
            </View>
          )}

          {selectedResult.classes.length > 0 && (
            <View style={styles.detailSection}>
              <Text style={styles.detailSectionTitle}>Classes</Text>
              {selectedResult.classes.map((cls, idx) => (
                <Text key={idx} style={styles.detailSectionItem}>
                  • {cls}
                </Text>
              ))}
            </View>
          )}

          <View style={styles.detailSection}>
            <Text style={styles.detailSectionTitle}>Code Preview</Text>
            <Text style={styles.detailCode}>
              {selectedResult.content.substring(0, 500)}...
            </Text>
          </View>
        </ScrollView>
      </View>
    );
  };

  return (
    <SafeAreaView style={styles.container}>
      {/* 헤더 */}
      <View style={styles.header}>
        <Text style={styles.title}>🔍 KimSearch Mobile</Text>
        <Text style={styles.subtitle}>코드 탐색기</Text>
      </View>

      {/* 검색창 */}
      <View style={styles.searchBox}>
        <TextInput
          style={styles.searchInput}
          placeholder="검색어 입력..."
          value={query}
          onChangeText={setQuery}
          onSubmitEditing={handleSearch}
          placeholderTextColor="#999"
        />
        <TouchableOpacity
          onPress={handleSearch}
          style={styles.searchButton}
          disabled={loading}
        >
          {loading ? (
            <ActivityIndicator color="#fff" size="small" />
          ) : (
            <Text style={styles.searchButtonText}>검색</Text>
          )}
        </TouchableOpacity>
      </View>

      {/* 필터 */}
      <ScrollView
        horizontal
        showsHorizontalScrollIndicator={false}
        style={styles.filterScroll}
      >
        <View style={styles.filterGroup}>
          {/* 언어 필터 */}
          {languages.map((lang) => (
            <TouchableOpacity
              key={lang}
              onPress={() => setSelectedLang(lang)}
              style={[
                styles.filterButton,
                selectedLang === lang && styles.filterButtonActive
              ]}
            >
              <Text
                style={[
                  styles.filterButtonText,
                  selectedLang === lang && styles.filterButtonTextActive
                ]}
              >
                {lang.toUpperCase()}
              </Text>
            </TouchableOpacity>
          ))}

          {/* 정렬 필터 */}
          {sortOptions.map((sort) => (
            <TouchableOpacity
              key={sort}
              onPress={() => setSelectedSort(sort)}
              style={[
                styles.filterButton,
                selectedSort === sort && styles.filterButtonActive
              ]}
            >
              <Text
                style={[
                  styles.filterButtonText,
                  selectedSort === sort && styles.filterButtonTextActive
                ]}
              >
                {sort}
              </Text>
            </TouchableOpacity>
          ))}
        </View>
      </ScrollView>

      {/* 통계 */}
      {stats && (
        <View style={styles.stats}>
          <Text style={styles.statsText}>
            🔍 {stats.totalSearches} 검색 | 💾 {stats.cacheSize} 캐시 | ⚡ {stats.hitRate}%
          </Text>
        </View>
      )}

      {/* 결과 리스트 */}
      {selectedResult ? (
        renderDetailView()
      ) : (
        <FlatList
          data={results}
          renderItem={renderResultItem}
          keyExtractor={(item) => item.id.toString()}
          style={styles.resultsList}
          ListEmptyComponent={
            query && !loading ? (
              <View style={styles.emptyContainer}>
                <Text style={styles.emptyText}>
                  "{query}"에 대한 결과가 없습니다.
                </Text>
              </View>
            ) : null
          }
        />
      )}
    </SafeAreaView>
  );
};

