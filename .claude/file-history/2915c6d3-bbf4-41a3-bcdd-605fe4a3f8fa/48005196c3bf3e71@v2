  );
});

// 테스트 13: 캐시 키 생성
test('캐시 키 생성 (기본)', () => {
  const key = engine.getCacheKey('test', { limit: 10 });
  assert(key.includes('test'), '쿼리가 포함되어야 함');
  assert(key.includes('all'), 'all 포함되어야 함');
});

test('캐시 키 생성 (다른 옵션)', () => {
  const key1 = engine.getCacheKey('test', { lang: 'js', limit: 10 });
  const key2 = engine.getCacheKey('test', { lang: 'py', limit: 10 });
  assert(key1 !== key2, '다른 옵션 = 다른 키');
});

// 테스트 14: 유사도 계산 - 동일
test('유사도 계산 (동일 코드)', () => {
  const code = 'const x = 10;';
  const similarity = engine.calculateSimilarity(code, code);
  assertEqual(similarity, 1, '동일한 코드는 유사도 1');
});

// 테스트 15: 유사도 계산 - 다른
test('유사도 계산 (다른 코드)', () => {
  const code1 = 'const x = 10;';
  const code2 = 'class Dog {}';
  const similarity = engine.calculateSimilarity(code1, code2);
  assertLessThan(similarity, 0.5, '다른 코드는 유사도 0.5 이하');
});

// 테스트 16: 유사도 계산 - 부분 유사
test('유사도 계산 (부분 유사)', () => {
  const code1 = 'function add(a, b) { return a + b; }';
  const code2 = 'function add(x, y) { return x + y; }';
  const similarity = engine.calculateSimilarity(code1, code2);
  assertGreaterThan(similarity, 0.45, '부분 유사는 0.45보다 큼');
  assertLessThan(similarity, 1, '부분 유사는 1 미만');
});

// 테스트 17: 유사도 계산 - 빈 문자열
test('유사도 계산 (빈 문자열)', () => {
  const similarity = engine.calculateSimilarity('', '');
  assertEqual(similarity, 1, '동일한 빈 문자열은 유사도 1');
});

// 테스트 18: 캐시 통계 (초기 상태)
test('캐시 통계 (초기)', () => {
  const stats = engine.getCacheStats();
  assertEqual(stats.cacheSize, 0, '초기 캐시 크기는 0');
  assertEqual(stats.totalSearches, 0, '초기 검색 수는 0');
  assertEqual(stats.hitRate, '0', '초기 히트율은 0');
});

// 테스트 19: 캐시 통계 업데이트
test('캐시 통계 (업데이트)', () => {
  engine.searchStats.totalSearches = 10;
  engine.searchStats.cachedResults = 3;
  const stats = engine.getCacheStats();
  assertEqual(stats.totalSearches, 10, '검색 수 업데이트');
  assertEqual(stats.cachedResults, 3, '캐시 결과 업데이트');
  assertEqual(stats.hitRate, '30.0', '히트율 계산 (30%)');
});

// 테스트 20: 캐시 초기화
test('캐시 초기화', () => {
  engine.cache.set('test', { data: 'value' });
  engine.clearCache();
  assertEqual(engine.cache.size, 0, '캐시가 비워져야 함');
});

