/**
 * KimSearch v2 - Quality Assessment Service
 *
 * 핵심 로직:
 * - 저장소 품질 평가 저장/관리
 * - 필터링 & 조회
 * - 통계 계산
 *
 * Author: Claude (Haiku 4.5)
 * Date: 2026-02-27
 */

const fs = require('fs');
const path = require('path');

class QualityService {
  constructor(dataPath = 'quality-assessment.json') {
    this.dataPath = dataPath;
    this.assessments = new Map();
    this.loadFromFile();
  }

  /**
   * 저장소 평가 저장
   */
  rate(repo, stars, category, issues = [], actions = [], deadline = null, owner = 'unknown') {
    if (!repo || typeof stars !== 'number' || stars < 1 || stars > 5) {
      throw new Error('Invalid repo or stars (must be 1-5)');
    }

    const assessment = {
      repo,
      stars,
      category,
      completion: stars * 20,  // 5⭐ = 100%, 1⭐ = 20%
      issues: Array.isArray(issues) ? issues : [issues],
      actions: Array.isArray(actions) ? actions : [actions],
      deadline,
      owner,
      timestamp: new Date().toISOString(),
      status: this.getStatus(stars)
    };

    this.assessments.set(repo, assessment);
    this.saveToFile();

    return assessment;
  }

  /**
   * 별표에 따른 상태 반환
   */
  getStatus(stars) {
    const statuses = {
      5: '🟢 PRODUCTION_READY',
      4: '🟡 GOOD',
      3: '🟠 AVERAGE',
      2: '🔴 SECURITY_REVIEW',
      1: '⛔ INCOMPLETE'
    };
    return statuses[stars] || 'UNKNOWN';
  }

  /**
   * 평가 목록 조회 (필터링)
   */
  list(filters = {}) {
    let results = Array.from(this.assessments.values());

    // 별표 필터 (배열 또는 단일 값)
    if (filters.stars) {
      const starsArray = Array.isArray(filters.stars)
        ? filters.stars
        : [filters.stars];
      results = results.filter(r => starsArray.includes(r.stars));
    }

    // 상태 필터
    if (filters.status) {
      results = results.filter(r => r.status === filters.status);
    }

    // 카테고리 필터
    if (filters.category) {
      results = results.filter(r => r.category === filters.category);
    }

    // 저장소명 필터 (검색)
    if (filters.search) {
      const keyword = filters.search.toLowerCase();
      results = results.filter(r => r.repo.toLowerCase().includes(keyword));
    }

    // 정렬
    if (filters.sort === 'stars-desc') {
      results.sort((a, b) => b.stars - a.stars);
    } else if (filters.sort === 'stars-asc') {
      results.sort((a, b) => a.stars - b.stars);
    }

    // 페이지네이션
    const limit = filters.limit || 100;
    const offset = (filters.page || 0) * limit;
    results = results.slice(offset, offset + limit);

    return results;
  }

  /**
   * 특정 저장소 평가 조회
   */
  get(repo) {
    return this.assessments.get(repo) || null;
  }

  /**
   * 보안 검토 필요 (⭐⭐ 이하)
   */
  securityReview() {
    const critical = this.list({ stars: [1, 2] });

    return {
      critical_count: critical.length,
      urgent: critical.filter(r => r.stars === 2),
      on_hold: critical.filter(r => r.stars === 1),
      all: critical
    };
  }

  /**
   * 통계 계산
   */
  statistics() {
    const all = Array.from(this.assessments.values());

    const byStars = {
      5: all.filter(r => r.stars === 5),
      4: all.filter(r => r.stars === 4),
      3: all.filter(r => r.stars === 3),
      2: all.filter(r => r.stars === 2),
      1: all.filter(r => r.stars === 1)
    };

    const byCategory = this.groupByCategory(all);

    return {
      total: all.length,
      by_stars: {
        '5': { count: byStars[5].length, repos: byStars[5].map(r => r.repo) },
        '4': { count: byStars[4].length, repos: byStars[4].map(r => r.repo) },
        '3': { count: byStars[3].length, repos: byStars[3].map(r => r.repo) },
        '2': { count: byStars[2].length, repos: byStars[2].map(r => r.repo) },
        '1': { count: byStars[1].length, repos: byStars[1].map(r => r.repo) }
      },
      by_category: byCategory,
      summary: {
        production_ready: byStars[5].length,
        good: byStars[4].length,
        average: byStars[3].length,
        security_review: byStars[2].length,
        incomplete: byStars[1].length,
        total_issues: all.reduce((sum, r) => sum + r.issues.length, 0),
        total_actions: all.reduce((sum, r) => sum + r.actions.length, 0)
      }
    };
  }

  /**
   * 카테고리별 그룹핑
   */
  groupByCategory(repos = null) {
    const all = repos || Array.from(this.assessments.values());
    const grouped = {};

    for (const repo of all) {
      if (!grouped[repo.category]) {
        grouped[repo.category] = [];
      }
      grouped[repo.category].push(repo);
    }

    const result = {};
    for (const [cat, repos] of Object.entries(grouped)) {
      result[cat] = {
        count: repos.length,
        avg_stars: (repos.reduce((s, r) => s + r.stars, 0) / repos.length).toFixed(1),
        security_issues: repos.filter(r => r.stars === 2).length,
        repos: repos.map(r => ({ repo: r.repo, stars: r.stars }))
      };
    }

    return result;
  }

  /**
   * JSON 파일에서 로드
   */
  loadFromFile() {
    try {
      if (fs.existsSync(this.dataPath)) {
        const data = fs.readFileSync(this.dataPath, 'utf-8');
        const parsed = JSON.parse(data);

        // 배열 형식 지원
        if (Array.isArray(parsed)) {
          parsed.forEach(item => {
            this.assessments.set(item.repo, item);
          });
        } else if (parsed.gpt_repositories) {
          // 기존 형식 지원
          parsed.gpt_repositories.forEach(item => {
            this.assessments.set(item.repo, item);
          });
        }

        console.log(`✅ Loaded ${this.assessments.size} assessments from ${this.dataPath}`);
      }
    } catch (e) {
      console.warn(`⚠️ Failed to load ${this.dataPath}: ${e.message}`);
    }
  }

  /**
   * JSON 파일에 저장
   */
  saveToFile() {
    try {
      const data = Array.from(this.assessments.values());
      fs.writeFileSync(this.dataPath, JSON.stringify(data, null, 2));
    } catch (e) {
      console.error(`❌ Failed to save ${this.dataPath}: ${e.message}`);
    }
  }

  /**
   * 모든 평가 반환
   */
  getAll() {
    return Array.from(this.assessments.values());
  }

  /**
   * 평가 삭제
   */
  delete(repo) {
    const result = this.assessments.delete(repo);
    if (result) {
      this.saveToFile();
    }
    return result;
  }

  /**
   * 평가 초기화
   */
  clear() {
    this.assessments.clear();
    this.saveToFile();
  }
}

module.exports = QualityService;
