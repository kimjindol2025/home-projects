"""
v7.2 인터셉터 테스트

Layer 2: 인터셉터, 디스커버리, 로드 밸런서 테스트
"""

import unittest
import time

from src.v7_2_grpc.interceptors import (
    LoggingInterceptor,
    AuthInterceptor,
    PerformanceInterceptor,
    RateLimitingInterceptor,
    InterceptorChain,
)
from src.v7_2_grpc.discovery import GogsServiceRegistry, ServiceStatus
from src.v7_2_grpc.load_balancer import GogsLoadBalancer, BalancingStrategy


class TestInterceptors(unittest.TestCase):
    """인터셉터 테스트"""

    def test_logging_interceptor(self):
        """로깅 인터셉터 테스트"""
        logging = LoggingInterceptor()

        logging.log_call(
            method="CreateOrder",
            request_size=100,
            response_size=200,
            status_code=0,
            duration_ms=5.0,
        )

        stats = logging.get_stats()
        self.assertEqual(stats["total_calls"], 1)
        self.assertGreater(stats["avg_duration_ms"], 0)

    def test_auth_interceptor(self):
        """인증 인터셉터 테스트"""
        auth = AuthInterceptor()

        # 유효한 키
        result = auth.validate_api_key("gogs-key-2026")
        self.assertTrue(result["success"])

        # 유효하지 않은 키
        result = auth.validate_api_key("invalid-key")
        self.assertFalse(result["success"])

    def test_performance_interceptor(self):
        """성능 인터셉터 테스트"""
        perf = PerformanceInterceptor()

        perf.measure("CreateOrder", 5.0)
        perf.measure("ProcessPayment", 3.0)
        perf.measure("CreateOrder", 4.5)

        stats = perf.get_stats()
        self.assertEqual(stats["total_requests"], 3)
        self.assertIn("CreateOrder", stats["methods"])

    def test_rate_limiting_interceptor(self):
        """비율 제한 인터셉터 테스트"""
        rate_limit = RateLimitingInterceptor(default_rps_limit=2)

        # 첫 2개 요청: 통과
        result1 = rate_limit.check_rate_limit("CreateOrder")
        self.assertTrue(result1["allowed"])

        result2 = rate_limit.check_rate_limit("CreateOrder")
        self.assertTrue(result2["allowed"])

        # 3번째 요청: 차단
        result3 = rate_limit.check_rate_limit("CreateOrder")
        self.assertFalse(result3["allowed"])

    def test_interceptor_chain(self):
        """인터셉터 체인 테스트"""
        chain = InterceptorChain()

        result = chain.execute_request(
            method="CreateOrder",
            request_size=100,
            api_key="gogs-key-2026",
        )

        self.assertTrue(result["success"])

        # 잘못된 API 키
        result = chain.execute_request(
            method="CreateOrder",
            request_size=100,
            api_key="invalid-key",
        )
        self.assertFalse(result["success"])


class TestServiceDiscovery(unittest.TestCase):
    """서비스 디스커버리 테스트"""

    def test_register_service(self):
        """서비스 등록 테스트"""
        registry = GogsServiceRegistry()

        instance_id = registry.register(
            service_name="OrderService",
            host="localhost",
            port=50051,
        )

        self.assertIsNotNone(instance_id)

    def test_discover_service(self):
        """서비스 발견 테스트"""
        registry = GogsServiceRegistry()

        instance_id = registry.register(
            service_name="OrderService",
            host="localhost",
            port=50051,
        )

        # 하트비트 기록
        registry.heartbeat(instance_id)

        # 발견
        instances = registry.discover("OrderService")
        self.assertEqual(len(instances), 1)

    def test_deregister_service(self):
        """서비스 해제 테스트"""
        registry = GogsServiceRegistry()

        instance_id = registry.register(
            service_name="OrderService",
            host="localhost",
            port=50051,
        )

        success = registry.deregister(instance_id)
        self.assertTrue(success)

        instances = registry.discover("OrderService")
        self.assertEqual(len(instances), 0)

    def test_stale_cleanup(self):
        """TTL 만료 정리 테스트"""
        registry = GogsServiceRegistry(ttl_seconds=1)

        instance_id = registry.register(
            service_name="OrderService",
            host="localhost",
            port=50051,
        )

        # 1초 대기
        time.sleep(1.1)

        # 정리
        removed = registry.cleanup_stale()
        self.assertGreater(removed, 0)


class TestLoadBalancer(unittest.TestCase):
    """로드 밸런서 테스트"""

    def setUp(self):
        self.registry = GogsServiceRegistry()

        # 테스트용 인스턴스 등록
        self.instance_id_1 = self.registry.register(
            service_name="OrderService",
            host="localhost",
            port=50051,
            weight=100,
        )
        self.instance_id_2 = self.registry.register(
            service_name="OrderService",
            host="localhost",
            port=50052,
            weight=50,
        )

        # 하트비트 기록
        self.registry.heartbeat(self.instance_id_1)
        self.registry.heartbeat(self.instance_id_2)

    def test_round_robin(self):
        """라운드 로빈 로드 밸런싱 테스트"""
        lb = GogsLoadBalancer(BalancingStrategy.ROUND_ROBIN)

        instances = self.registry.discover("OrderService")
        self.assertEqual(len(instances), 2)

        selected1 = lb.select_instance(instances, "OrderService")
        selected2 = lb.select_instance(instances, "OrderService")

        self.assertIsNotNone(selected1)
        self.assertIsNotNone(selected2)

    def test_weighted(self):
        """가중치 기반 로드 밸런싱 테스트"""
        lb = GogsLoadBalancer(BalancingStrategy.WEIGHTED)

        instances = self.registry.discover("OrderService")

        selected = lb.select_instance(instances, "OrderService")
        self.assertIsNotNone(selected)


if __name__ == "__main__":
    unittest.main()
