"""
DataLake 스토리지 테스트
- 데이터셋 생성
- 파티션 저장
- 파티션 로드
- 메타데이터 관리
"""

import unittest
import tempfile
import shutil
from pathlib import Path
import sys

sys.path.insert(0, str(Path(__file__).parent.parent.parent / "src"))

from v8_2_data_lake.storage.lake import (
    DataLake,
    DataFormat,
    DataMetadata,
    DataPartitionMetadata
)


class TestDataLake(unittest.TestCase):
    """DataLake 기본 테스트"""

    def setUp(self):
        """테스트 시작 전 설정"""
        self.temp_dir = tempfile.mkdtemp()
        self.lake = DataLake(base_path=self.temp_dir)

    def tearDown(self):
        """테스트 종료 후 정리"""
        shutil.rmtree(self.temp_dir, ignore_errors=True)

    def test_data_lake_initialization(self):
        """데이터 레이크 초기화 테스트"""
        self.assertTrue(Path(self.temp_dir).exists())
        self.assertEqual(len(self.lake.datasets), 0)

    def test_create_dataset(self):
        """데이터셋 생성 테스트"""
        self.lake.create_dataset(
            dataset_id="test_dataset",
            format=DataFormat.JSON,
            source="test_source"
        )

        self.assertIn("test_dataset", self.lake.datasets)
        metadata = self.lake.datasets["test_dataset"]
        self.assertEqual(metadata.dataset_id, "test_dataset")
        self.assertEqual(metadata.format, DataFormat.JSON)

    def test_store_partition_json(self):
        """JSON 파티션 저장 테스트"""
        self.lake.create_dataset("test_dataset", DataFormat.JSON)

        data = [{"id": 1, "value": "a"}, {"id": 2, "value": "b"}]

        partition_path = self.lake.store_partition(
            "test_dataset",
            0,
            data
        )

        self.assertTrue(Path(partition_path).exists())
        self.assertTrue(partition_path.endswith(".json"))

    def test_store_partition_binary(self):
        """Binary 파티션 저장 테스트"""
        self.lake.create_dataset("test_dataset", DataFormat.BINARY)

        data = [1, 2, 3, 4, 5]

        partition_path = self.lake.store_partition(
            "test_dataset",
            0,
            data
        )

        self.assertTrue(Path(partition_path).exists())
        self.assertTrue(partition_path.endswith(".bin"))

    def test_store_partition_text(self):
        """Text 파티션 저장 테스트"""
        self.lake.create_dataset("test_dataset", DataFormat.TEXT)

        data = ["line1", "line2", "line3"]

        partition_path = self.lake.store_partition(
            "test_dataset",
            0,
            data
        )

        self.assertTrue(Path(partition_path).exists())
        self.assertTrue(partition_path.endswith(".txt"))

    def test_load_partition_json(self):
        """JSON 파티션 로드 테스트"""
        self.lake.create_dataset("test_dataset", DataFormat.JSON)

        data = [{"id": 1}, {"id": 2}]

        self.lake.store_partition("test_dataset", 0, data)

        loaded_data = self.lake.load_partition("test_dataset", 0)

        self.assertEqual(len(loaded_data), 2)
        self.assertEqual(loaded_data[0]["id"], 1)

    def test_load_partition_text(self):
        """Text 파티션 로드 테스트"""
        self.lake.create_dataset("test_dataset", DataFormat.TEXT)

        data = ["line1", "line2", "line3"]

        self.lake.store_partition("test_dataset", 0, data)

        loaded_data = self.lake.load_partition("test_dataset", 0)

        self.assertEqual(len(loaded_data), 3)
        self.assertEqual(loaded_data[0], "line1")

    def test_load_entire_dataset(self):
        """전체 데이터셋 로드 테스트"""
        self.lake.create_dataset("test_dataset", DataFormat.JSON)

        # 여러 파티션 저장
        data1 = [{"id": 1}, {"id": 2}]
        data2 = [{"id": 3}, {"id": 4}]

        self.lake.store_partition("test_dataset", 0, data1)
        self.lake.store_partition("test_dataset", 1, data2)

        # 전체 데이터셋 로드
        all_data = self.lake.load_dataset("test_dataset")

        self.assertEqual(len(all_data), 4)

    def test_dataset_info(self):
        """데이터셋 정보 조회 테스트"""
        self.lake.create_dataset("test_dataset", DataFormat.JSON)

        data = list(range(100))
        self.lake.store_partition("test_dataset", 0, data)

        info = self.lake.get_dataset_info("test_dataset")

        self.assertEqual(info["dataset_id"], "test_dataset")
        self.assertEqual(info["record_count"], 100)
        self.assertEqual(info["partition_count"], 1)

    def test_list_datasets(self):
        """데이터셋 목록 조회 테스트"""
        self.lake.create_dataset("dataset1", DataFormat.JSON)
        self.lake.create_dataset("dataset2", DataFormat.JSON)
        self.lake.create_dataset("dataset3", DataFormat.JSON)

        datasets = self.lake.list_datasets()

        self.assertEqual(len(datasets), 3)
        self.assertIn("dataset1", datasets)
        self.assertIn("dataset2", datasets)

    def test_data_lake_statistics(self):
        """데이터 레이크 통계 테스트"""
        self.lake.create_dataset("dataset1", DataFormat.JSON)

        data1 = list(range(100))
        data2 = list(range(50))

        self.lake.store_partition("dataset1", 0, data1)
        self.lake.store_partition("dataset1", 1, data2)

        stats = self.lake.get_statistics()

        self.assertEqual(stats["total_datasets"], 1)
        self.assertEqual(stats["total_records"], 150)
        self.assertEqual(stats["total_partitions"], 2)

    def test_metadata_creation(self):
        """메타데이터 생성 테스트"""
        self.lake.create_dataset("test_dataset", DataFormat.JSON, "test_source")

        data = [1, 2, 3]
        self.lake.store_partition("test_dataset", 0, data)

        metadata = self.lake.datasets["test_dataset"]

        self.assertIsNotNone(metadata.creation_time)
        self.assertEqual(metadata.record_count, 3)

    def test_partition_not_found(self):
        """존재하지 않는 파티션 처리 테스트"""
        self.lake.create_dataset("test_dataset", DataFormat.JSON)

        with self.assertRaises(FileNotFoundError):
            self.lake.load_partition("test_dataset", 999)

    def test_dataset_not_found(self):
        """존재하지 않는 데이터셋 처리 테스트"""
        with self.assertRaises(ValueError):
            self.lake.store_partition("nonexistent", 0, [1, 2, 3])


class TestDataFormat(unittest.TestCase):
    """데이터 포맷 테스트"""

    def test_all_data_formats(self):
        """모든 데이터 포맷 테스트"""
        formats = [
            DataFormat.JSON,
            DataFormat.CSV,
            DataFormat.PARQUET,
            DataFormat.BINARY,
            DataFormat.TEXT
        ]

        self.assertEqual(len(formats), 5)

        for fmt in formats:
            self.assertIsNotNone(fmt.value)


class TestDataMetadata(unittest.TestCase):
    """데이터 메타데이터 테스트"""

    def test_metadata_creation(self):
        """메타데이터 생성 테스트"""
        metadata = DataMetadata(
            dataset_id="test",
            format=DataFormat.JSON,
            creation_time="2026-02-25T10:00:00",
            record_count=1000,
            size_bytes=50000,
            source="test_source"
        )

        self.assertEqual(metadata.dataset_id, "test")
        self.assertEqual(metadata.format, DataFormat.JSON)
        self.assertEqual(metadata.record_count, 1000)

    def test_partition_metadata_creation(self):
        """파티션 메타데이터 생성 테스트"""
        partition_meta = DataPartitionMetadata(
            partition_id=0,
            record_count=1000,
            size_bytes=50000,
            location="/data/partition_000000",
            creation_time="2026-02-25T10:00:00"
        )

        self.assertEqual(partition_meta.partition_id, 0)
        self.assertEqual(partition_meta.record_count, 1000)


class TestDataLakeLargeScale(unittest.TestCase):
    """데이터 레이크 대규모 테스트"""

    def setUp(self):
        """테스트 시작 전 설정"""
        self.temp_dir = tempfile.mkdtemp()
        self.lake = DataLake(base_path=self.temp_dir)

    def tearDown(self):
        """테스트 종료 후 정리"""
        shutil.rmtree(self.temp_dir, ignore_errors=True)

    def test_multiple_datasets(self):
        """다중 데이터셋 테스트"""
        for i in range(10):
            self.lake.create_dataset(f"dataset_{i}", DataFormat.JSON)

        datasets = self.lake.list_datasets()
        self.assertEqual(len(datasets), 10)

    def test_multiple_partitions(self):
        """다중 파티션 테스트"""
        self.lake.create_dataset("test_dataset", DataFormat.JSON)

        # 100개 파티션 저장
        for i in range(100):
            data = list(range(100))
            self.lake.store_partition("test_dataset", i, data)

        info = self.lake.get_dataset_info("test_dataset")
        self.assertEqual(info["partition_count"], 100)
        self.assertEqual(info["record_count"], 10000)

    def test_large_partition_data(self):
        """대규모 파티션 데이터 테스트"""
        self.lake.create_dataset("test_dataset", DataFormat.JSON)

        # 10,000개 레코드가 있는 파티션
        large_data = [{"id": i, "value": i*2} for i in range(10000)]

        partition_path = self.lake.store_partition(
            "test_dataset",
            0,
            large_data
        )

        # 로드해서 확인
        loaded = self.lake.load_partition("test_dataset", 0)
        self.assertEqual(len(loaded), 10000)


if __name__ == "__main__":
    unittest.main()
