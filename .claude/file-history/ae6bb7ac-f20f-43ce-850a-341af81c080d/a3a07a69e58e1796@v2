<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🗺️ Evolution Map: Kim's Research Ecosystem</title>
    <script src="https://d3js.org/d3.v7.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
            color: #e0e0e0;
            padding: 20px;
            min-height: 100vh;
        }

        header {
            text-align: center;
            margin-bottom: 40px;
        }

        header h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
            background: linear-gradient(45deg, #00d4ff, #0099ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        header p {
            font-size: 1.1em;
            color: #00d4ff;
            margin-bottom: 20px;
        }

        .stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }

        .stat-card {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(0, 212, 255, 0.2);
            border-radius: 10px;
            padding: 20px;
            text-align: center;
            backdrop-filter: blur(10px);
            transition: all 0.3s ease;
        }

        .stat-card:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: rgba(0, 212, 255, 0.5);
            transform: translateY(-5px);
        }

        .stat-card h3 {
            font-size: 0.9em;
            color: #00d4ff;
            margin-bottom: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .stat-card .value {
            font-size: 2em;
            font-weight: bold;
            color: #00ff88;
        }

        .container {
            display: grid;
            grid-template-columns: 1fr 3fr;
            gap: 30px;
            margin-bottom: 40px;
        }

        .sidebar {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(0, 212, 255, 0.2);
            border-radius: 10px;
            padding: 20px;
            backdrop-filter: blur(10px);
            max-height: 600px;
            overflow-y: auto;
        }

        .sidebar h2 {
            color: #00d4ff;
            margin-bottom: 20px;
            font-size: 1.3em;
        }

        .axis-list {
            list-style: none;
        }

        .axis-item {
            padding: 12px;
            margin-bottom: 10px;
            border-left: 3px solid #00d4ff;
            background: rgba(0, 212, 255, 0.05);
            cursor: pointer;
            transition: all 0.3s ease;
            border-radius: 5px;
        }

        .axis-item:hover {
            background: rgba(0, 212, 255, 0.15);
            transform: translateX(10px);
        }

        .axis-item.active {
            background: rgba(0, 212, 255, 0.25);
            border-left-color: #00ff88;
        }

        .axis-item span {
            font-weight: bold;
            color: #00ff88;
        }

        .axis-item small {
            display: block;
            color: #999;
            margin-top: 5px;
        }

        .canvas {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(0, 212, 255, 0.2);
            border-radius: 10px;
            overflow: hidden;
        }

        svg {
            width: 100%;
            height: 100%;
            min-height: 600px;
        }

        .node {
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .node circle {
            fill: #00d4ff;
            stroke: #0099ff;
            stroke-width: 2px;
        }

        .node.axis-1 circle {
            fill: #ff6b9d;
            stroke: #ff4081;
        }

        .node.axis-2 circle {
            fill: #a29bfe;
            stroke: #6c5ce7;
        }

        .node.axis-3 circle {
            fill: #00d4ff;
            stroke: #0099ff;
        }

        .node.axis-4 circle {
            fill: #00ff88;
            stroke: #00cc66;
        }

        .node.production circle {
            filter: drop-shadow(0 0 8px currentColor);
        }

        .node text {
            font-size: 11px;
            text-anchor: middle;
            pointer-events: none;
            fill: #fff;
            font-weight: bold;
        }

        .link {
            stroke: rgba(0, 212, 255, 0.2);
            stroke-width: 1px;
        }

        .link.highlight {
            stroke: #00ff88;
            stroke-width: 2px;
        }

        .tooltip {
            position: absolute;
            padding: 12px;
            background: rgba(0, 0, 0, 0.9);
            color: #00d4ff;
            border: 1px solid #00d4ff;
            border-radius: 5px;
            font-size: 12px;
            pointer-events: none;
            z-index: 1000;
            max-width: 300px;
        }

        .tooltip strong {
            color: #00ff88;
        }

        .legend {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 15px;
            margin-top: 40px;
            padding: 20px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(0, 212, 255, 0.2);
            border-radius: 10px;
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .legend-color {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            border: 2px solid;
        }

        .color-1 {
            background: #ff6b9d;
            border-color: #ff4081;
        }

        .color-2 {
            background: #a29bfe;
            border-color: #6c5ce7;
        }

        .color-3 {
            background: #00d4ff;
            border-color: #0099ff;
        }

        .color-4 {
            background: #00ff88;
            border-color: #00cc66;
        }

        .detail-panel {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(0, 212, 255, 0.2);
            border-radius: 10px;
            padding: 20px;
            margin-top: 20px;
            max-height: 300px;
            overflow-y: auto;
        }

        .detail-panel h3 {
            color: #00ff88;
            margin-bottom: 15px;
            font-size: 1.2em;
        }

        .detail-item {
            margin-bottom: 15px;
        }

        .detail-item label {
            color: #00d4ff;
            font-weight: bold;
            display: block;
            margin-bottom: 5px;
        }

        .detail-item value {
            color: #e0e0e0;
            display: block;
        }

        @media (max-width: 1200px) {
            .container {
                grid-template-columns: 1fr;
            }

            .sidebar {
                max-height: none;
            }
        }

        .controls {
            margin-top: 20px;
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        button {
            background: linear-gradient(45deg, #00d4ff, #0099ff);
            border: none;
            color: #000;
            padding: 10px 20px;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            transition: all 0.3s ease;
        }

        button:hover {
            transform: scale(1.05);
            box-shadow: 0 0 10px rgba(0, 212, 255, 0.5);
        }
    </style>
</head>
<body>
    <header>
        <h1>🗺️ Evolution Map: Kim's Research Ecosystem</h1>
        <p>41 Projects | 362,000+ LOC | 3,500+ Tests | 4 Major Axes</p>
    </header>

    <div class="stats">
        <div class="stat-card">
            <h3>Total Projects</h3>
            <div class="value">41</div>
        </div>
        <div class="stat-card">
            <h3>Total LOC</h3>
            <div class="value">362K+</div>
        </div>
        <div class="stat-card">
            <h3>Total Tests</h3>
            <div class="value">3,500+</div>
        </div>
        <div class="stat-card">
            <h3>Avg Tests/Proj</h3>
            <div class="value">85</div>
        </div>
        <div class="stat-card">
            <h3>Production</h3>
            <div class="value">18</div>
        </div>
        <div class="stat-card">
            <h3>Performance Gain</h3>
            <div class="value">8.2x</div>
        </div>
    </div>

    <div class="container">
        <div class="sidebar">
            <h2>📍 Filter by Axis</h2>
            <ul class="axis-list">
                <li class="axis-item active" onclick="filterAxis(null, this)">
                    <span>All Projects</span>
                    <small>41 projects</small>
                </li>
                <li class="axis-item" onclick="filterAxis(1, this)">
                    <span>Language / DSL</span>
                    <small>15 projects</small>
                </li>
                <li class="axis-item" onclick="filterAxis(2, this)">
                    <span>Compiler / Optimization</span>
                    <small>14 projects</small>
                </li>
                <li class="axis-item" onclick="filterAxis(3, this)">
                    <span>Knowledge / Analysis</span>
                    <small>6 projects</small>
                </li>
                <li class="axis-item" onclick="filterAxis(4, this)">
                    <span>Performance / Distributed</span>
                    <small>16 projects</small>
                </li>
            </ul>

            <div class="controls">
                <button onclick="resetZoom()">🔄 Reset View</button>
                <button onclick="togglePhysics()">⚙️ Toggle Physics</button>
            </div>
        </div>

        <div class="canvas" id="canvas"></div>
    </div>

    <div class="legend">
        <div class="legend-item">
            <div class="legend-color color-1"></div>
            <span>Language / DSL</span>
        </div>
        <div class="legend-item">
            <div class="legend-color color-2"></div>
            <span>Compiler / Optimization</span>
        </div>
        <div class="legend-item">
            <div class="legend-color color-3"></div>
            <span>Knowledge / Analysis</span>
        </div>
        <div class="legend-item">
            <div class="legend-color color-4"></div>
            <span>Performance / Distributed</span>
        </div>
    </div>

    <div class="detail-panel" id="detailPanel">
        <h3>📊 Select a project to view details</h3>
    </div>

    <script>
        // Sample data - simplified for visualization
        const data = {
            nodes: [
                // Language/DSL (Axis 1)
                { id: "freelang-v4", name: "FreeLang v4.5", axis: 1, loc: 45000, tests: 500, status: "production", description: "Complete integrated language" },
                { id: "freelang-v6", name: "FreeLang v6", axis: 1, loc: 8000, tests: 60, status: "rd", description: "Next-gen with dependent types" },
                { id: "golang-study", name: "Go Study", axis: 1, loc: 9000, tests: 50, status: "learning", description: "Learning material" },
                { id: "zig-study", name: "Zig Study", axis: 1, loc: 9512, tests: 60, status: "learning", description: "Systems programming" },
                { id: "clarity-lang", name: "Clarity Lang", axis: 1, loc: 6000, tests: 50, status: "mature", description: "Smart contracts language" },

                // Compiler (Axis 2)
                { id: "aria", name: "ARIA (MLIR)", axis: 2, loc: 20170, tests: 200, status: "mature", description: "PhD thesis - 8.2x speedup" },
                { id: "formal-semantics", name: "Formal Semantics", axis: 2, loc: 2088, tests: 0, status: "research", description: "MLIR tensor verification" },
                { id: "mlir-adaptive", name: "MLIR Adaptive", axis: 2, loc: 45940, tests: 68, status: "mature", description: "Phase 2.3 - Float error analysis" },
                { id: "zlang", name: "Z-Lang (LLVM)", axis: 2, loc: 9500, tests: 77, status: "mature", description: "LLVM compiler" },
                { id: "aiacccel", name: "AIAccel", axis: 2, loc: 5530, tests: 77, status: "mature", description: "4-5x speedup" },
                { id: "stochastic", name: "Stochastic Optimizer", axis: 2, loc: 3500, tests: 35, status: "production", description: "Evolutionary search" },

                // Knowledge (Axis 3)
                { id: "gogs", name: "GOGS Knowledge Engine", axis: 3, loc: 21299, tests: 80, status: "production", description: "v8.0 - Production hardened" },
                { id: "kimsearch", name: "KimSearch", axis: 3, loc: 5182, tests: 68, status: "production", description: "Multi-version search system" },

                // Performance (Axis 4)
                { id: "grie", name: "GRIE (Raft)", axis: 4, loc: 8500, tests: 28, status: "production", description: "Consensus engine - <150B memory" },
                { id: "phd-v16", name: "PhD v16 (Byzantine FL)", axis: 4, loc: 1260, tests: 26, status: "rd", description: "Distributed learning" },
                { id: "freelang-concurrency", name: "FreeLang Concurrency", axis: 4, loc: 4800, tests: 48, status: "production", description: "Concurrent runtime" },
            ],
            links: [
                { source: "freelang-v4", target: "aiacccel" },
                { source: "aria", target: "freelang-v4" },
                { source: "mlir-adaptive", target: "aiacccel" },
                { source: "zlang", target: "stochastic" },
                { source: "gogs", target: "kimsearch" },
                { source: "grie", target: "phd-v16" },
                { source: "formal-semantics", target: "mlir-adaptive" },
                { source: "freelang-concurrency", target: "grie" },
            ]
        };

        let simulation;
        let currentFilter = null;
        let physicsEnabled = true;

        function initVisualization() {
            const canvas = document.getElementById('canvas');
            const width = canvas.clientWidth;
            const height = 600;

            const svg = d3.select('#canvas')
                .append('svg')
                .attr('width', width)
                .attr('height', height);

            // Add zoom behavior
            const g = svg.append('g');
            const zoom = d3.zoom().on('zoom', (event) => {
                g.attr('transform', event.transform);
            });
            svg.call(zoom);

            // Create simulation
            simulation = d3.forceSimulation(data.nodes)
                .force('link', d3.forceLink(data.links)
                    .id(d => d.id)
                    .distance(60)
                    .strength(0.3))
                .force('charge', d3.forceManyBody().strength(-150))
                .force('center', d3.forceCenter(width / 2, height / 2).strength(0.5))
                .force('collision', d3.forceCollide().radius(35))
                .force('x', d3.forceX(width / 2).strength(0.1))
                .force('y', d3.forceY(height / 2).strength(0.1));

            // Add links
            const link = g.selectAll('.link')
                .data(data.links)
                .enter()
                .append('line')
                .attr('class', 'link');

            // Add nodes
            const node = g.selectAll('.node')
                .data(data.nodes)
                .enter()
                .append('g')
                .attr('class', d => `node axis-${d.axis} ${d.status}`)
                .call(d3.drag()
                    .on('start', dragstarted)
                    .on('drag', dragged)
                    .on('end', dragended))
                .on('click', (event, d) => showDetails(d));

            node.append('circle')
                .attr('r', d => 20 + Math.log(d.loc));

            node.append('text')
                .text(d => d.name.substring(0, 10))
                .attr('dy', '0.3em');

            // Add tooltip
            node.on('mouseover', function(event, d) {
                const tooltip = document.createElement('div');
                tooltip.className = 'tooltip';
                tooltip.innerHTML = `
                    <strong>${d.name}</strong><br>
                    Axis: ${['', 'Language', 'Compiler', 'Knowledge', 'Performance'][d.axis]}<br>
                    LOC: ${d.loc.toLocaleString()}<br>
                    Tests: ${d.tests}
                `;
                tooltip.style.left = (event.pageX + 10) + 'px';
                tooltip.style.top = (event.pageY + 10) + 'px';
                document.body.appendChild(tooltip);

                d3.select(this).select('circle').style('r', d => 25 + Math.log(d.loc));
            })
            .on('mouseout', function(event, d) {
                document.querySelectorAll('.tooltip').forEach(t => t.remove());
                d3.select(this).select('circle').style('r', d => 20 + Math.log(d.loc));
            });

            simulation.on('tick', () => {
                link
                    .attr('x1', d => d.source.x)
                    .attr('y1', d => d.source.y)
                    .attr('x2', d => d.target.x)
                    .attr('y2', d => d.target.y);

                node.attr('transform', d => `translate(${d.x},${d.y})`);
            });

            function dragstarted(event, d) {
                if (!event.active) simulation.alphaTarget(0.3).restart();
                d.fx = d.x;
                d.fy = d.y;
            }

            function dragged(event, d) {
                d.fx = event.x;
                d.fy = event.y;
            }

            function dragended(event, d) {
                if (!event.active) simulation.alphaTarget(0);
                d.fx = null;
                d.fy = null;
            }
        }

        function filterAxis(axis, element) {
            currentFilter = axis;

            // Update UI
            document.querySelectorAll('.axis-item').forEach(e => e.classList.remove('active'));
            if (element) element.classList.add('active');

            // Filter nodes
            d3.selectAll('.node')
                .style('opacity', d => !axis || d.axis === axis ? 1 : 0.2);
        }

        function resetZoom() {
            d3.select('svg')
                .transition()
                .duration(750)
                .call(d3.zoom().transform, d3.zoomIdentity.translate(50, 50).scale(1));
        }

        function togglePhysics() {
            physicsEnabled = !physicsEnabled;
            if (physicsEnabled) {
                simulation.alpha(1).restart();
            } else {
                simulation.stop();
            }
        }

        function showDetails(d) {
            const statusEmoji = {
                'production': '✅',
                'mature': '⭐',
                'rd': '🔄',
                'research': '🔬',
                'learning': '📚',
                'development': '🚀'
            };

            const axisName = ['', 'Language/DSL', 'Compiler/Optimization', 'Knowledge/Analysis', 'Performance/Distributed'][d.axis];

            document.getElementById('detailPanel').innerHTML = `
                <h3>${statusEmoji[d.status]} ${d.name}</h3>
                <div class="detail-item">
                    <label>📍 Axis:</label>
                    <value>${axisName}</value>
                </div>
                <div class="detail-item">
                    <label>📝 Description:</label>
                    <value>${d.description}</value>
                </div>
                <div class="detail-item">
                    <label>📊 Lines of Code:</label>
                    <value>${d.loc.toLocaleString()}</value>
                </div>
                <div class="detail-item">
                    <label>🧪 Tests:</label>
                    <value>${d.tests}</value>
                </div>
                <div class="detail-item">
                    <label>🏢 Status:</label>
                    <value>${d.status.toUpperCase()}</value>
                </div>
            `;
        }

        // Initialize on load
        document.addEventListener('DOMContentLoaded', initVisualization);
    </script>
</body>
</html>
