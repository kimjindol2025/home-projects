fn test_init_rate_limiter() {
  config = init_rate_limiter()

  assert len(config.rules) == 4
  assert config.global_limit == 10000

  println("✅ test_init_rate_limiter passed")
}

fn test_create_token_bucket() {
  bucket = create_token_bucket("client1", 10, 5, 0)

  assert bucket.client_id == "client1"
  assert bucket.capacity == 10
  assert bucket.tokens == 10
  assert bucket.refill_rate == 5

  println("✅ test_create_token_bucket passed")
}

fn test_refill_tokens() {
  bucket = create_token_bucket("client1", 10, 5, 0)

  // 토큰 2개 소비
  bucket.tokens = 8

  // 2초 후 리필
  bucket = refill_tokens(bucket, 2)

  // 소비된 토큰 2개 + 리필 10개 (5토큰/초 * 2초) = 20개
  // 하지만 최대값 10이므로 = 10개
  assert bucket.tokens == 10

  println("✅ test_refill_tokens passed")
}

fn test_consume_tokens() {
  bucket = create_token_bucket("client1", 10, 5, 0)

  bucket = consume_tokens(bucket, 3, 0)

  assert bucket.tokens == 7

  println("✅ test_consume_tokens passed")
}

fn test_check_rate_limit_allowed() {
  config = init_rate_limiter()
  bucket = create_token_bucket("client1", 20, 10, 0)

  result = check_rate_limit(bucket, config, "user", 0)

  assert result.is_allowed == true
  assert result.remaining_tokens >= 0

  println("✅ test_check_rate_limit_allowed passed")
}

fn test_check_rate_limit_exceeded() {
  config = init_rate_limiter()
  bucket = create_token_bucket("client1", 1, 1, 0)

  // 토큰 모두 소비
  bucket.tokens = 0

  result = check_rate_limit(bucket, config, "user", 0)

  assert result.is_allowed == false
  assert result.retry_after > 0

  println("✅ test_check_rate_limit_exceeded passed")
}

fn test_get_rate_limit_rule() {
  config = init_rate_limiter()

  user_rule = get_rate_limit_rule(config, "user")
  assert user_rule.requests_per_second == 10

  premium_rule = get_rate_limit_rule(config, "premium")
  assert premium_rule.requests_per_second == 100

  println("✅ test_get_rate_limit_rule passed")
}

fn test_rate_limit_store() {
  config = init_rate_limiter()
  store = init_rate_limit_store(config)

  bucket = get_or_create_bucket(store, "client1", "user", 0)
  assert bucket.client_id == "client1"

  // 같은 클라이언트 재조회
  bucket2 = get_or_create_bucket(store, "client1", "user", 0)
  assert bucket2.client_id == "client1"

  println("✅ test_rate_limit_store passed")
}

fn test_calculate_stats() {
  config = init_rate_limiter()
  store = init_rate_limit_store(config)

  get_or_create_bucket(store, "client1", "user", 0)
  get_or_create_bucket(store, "client2", "user", 0)

  stats = calculate_stats(store)

  assert stats.active_clients == 2

  println("✅ test_calculate_stats passed")
}

