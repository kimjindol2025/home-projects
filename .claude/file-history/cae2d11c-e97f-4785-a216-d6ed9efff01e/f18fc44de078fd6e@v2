// ============================================
// Part 1: 속도 제한 기본 구조
// ============================================

/// 토큰 버킷 알고리즘
struct TokenBucket {
  client_id: string,
  capacity: int,        // 최대 토큰 수
  tokens: int,          // 현재 토큰 수
  refill_rate: int,     // 초당 토큰 생성 수
  last_refill_time: int
}

/// 속도 제한 규칙
struct RateLimitRule {
  rule_id: int,
  client_type: string,  // "anonymous", "user", "premium", "service"
  requests_per_second: int,
  burst_size: int,
  is_enabled: bool
}

/// 속도 제한 설정
struct RateLimitConfig {
  rules: [RateLimitRule],
  global_limit: int,
  default_rule_id: int
}

/// 속도 제한 결과
struct RateLimitResult {
  is_allowed: bool,
  remaining_tokens: int,
  reset_time: int,
  retry_after: int
}

/// 속도 제한 초기화
fn init_rate_limiter() -> RateLimitConfig {
  println()
  println("⏱️  Rate Limiter Initialized")
  println("├─ Token Bucket Algorithm")
  println("├─ Per-Client Tracking")
  println("└─ Status: Ready")

  rules = [
    RateLimitRule {
      rule_id: 1,
      client_type: "anonymous",
      requests_per_second: 1,
      burst_size: 5,
      is_enabled: true
    },
    RateLimitRule {
      rule_id: 2,
      client_type: "user",
      requests_per_second: 10,
      burst_size: 20,
      is_enabled: true
    },
    RateLimitRule {
      rule_id: 3,
      client_type: "premium",
      requests_per_second: 100,
      burst_size: 200,
      is_enabled: true
    },
    RateLimitRule {
      rule_id: 4,
      client_type: "service",
      requests_per_second: 1000,
      burst_size: 5000,
      is_enabled: true
    }
  ]

  return RateLimitConfig {
    rules: rules,
    global_limit: 10000,  // 초당 전체 제한
    default_rule_id: 1
  }
}

// ============================================
// Part 2: 토큰 버킷
// ============================================

/// 토큰 버킷 생성
fn create_token_bucket(
  client_id: string,
  capacity: int,
  refill_rate: int,
  current_time: int
) -> TokenBucket {
  return TokenBucket {
    client_id: client_id,
    capacity: capacity,
    tokens: capacity,
    refill_rate: refill_rate,
    last_refill_time: current_time
  }
}

/// 토큰 리필
fn refill_tokens(
  bucket: TokenBucket,
  current_time: int
) -> TokenBucket {
  time_passed = current_time - bucket.last_refill_time

  // 생성할 토큰 수 = refill_rate * 경과시간
  new_tokens = bucket.refill_rate * time_passed

  // 토큰 추가 (최대값 제한)
  bucket.tokens = bucket.tokens + new_tokens

  if bucket.tokens > bucket.capacity {
    bucket.tokens = bucket.capacity
  }

  bucket.last_refill_time = current_time

  return bucket
}

/// 토큰 소비
fn consume_tokens(
  bucket: TokenBucket,
  amount: int,
  current_time: int
) -> TokenBucket {
  // 먼저 리필
  bucket = refill_tokens(bucket, current_time)

  // 토큰 소비
  if bucket.tokens >= amount {
    bucket.tokens = bucket.tokens - amount
  }

  return bucket
}

// ============================================
// Part 3: 속도 제한 검사
// ============================================

/// 클라이언트 타입에 따른 규칙 조회
fn get_rate_limit_rule(
  config: RateLimitConfig,
  client_type: string
) -> RateLimitRule {
  for rule in config.rules {
    if rule.client_type == client_type && rule.is_enabled {
      return rule
    }
  }

  // 기본 규칙 반환
  for rule in config.rules {
    if rule.rule_id == config.default_rule_id {
      return rule
    }
  }

  return config.rules[0]
}

/// 속도 제한 검사
fn check_rate_limit(
  bucket: TokenBucket,
  config: RateLimitConfig,
  client_type: string,
  current_time: int
) -> RateLimitResult {
  println()
  println("⏱️  Checking rate limit for: " + bucket.client_id)

  // 규칙 조회
  rule = get_rate_limit_rule(config, client_type)

  println("   Rule: " + rule.client_type + " (" +
          to_string(rule.requests_per_second) + " req/s)")

  // 토큰 리필
  bucket = refill_tokens(bucket, current_time)

  // 1개 토큰 소비 시도 (= 1개 요청)
  if bucket.tokens >= 1 {
    // 요청 허용
    bucket.tokens = bucket.tokens - 1

    println("   ✅ Request allowed")
    println("   ├─ Remaining tokens: " + to_string(bucket.tokens))
    println("   └─ Limit: " + to_string(rule.requests_per_second) + " req/s")

    return RateLimitResult {
      is_allowed: true,
      remaining_tokens: bucket.tokens,
      reset_time: current_time + rule.requests_per_second,
      retry_after: 0
    }

  } else {
    // 요청 거부
    println("   ❌ Rate limit exceeded")

    // 다음 토큰 생성 시간 (1초)
    retry_after = 1

    return RateLimitResult {
      is_allowed: false,
      remaining_tokens: 0,
      reset_time: current_time + retry_after,
      retry_after: retry_after
    }
  }
}

// ============================================
// Part 4: 클라이언트 관리
// ============================================

/// 클라이언트 토큰 버킷 저장소
struct RateLimitStore {
  buckets: {string: TokenBucket},
  config: RateLimitConfig
}

/// 저장소 초기화
fn init_rate_limit_store(config: RateLimitConfig) -> RateLimitStore {
  return RateLimitStore {
    buckets: {},
    config: config
  }
}

/// 클라이언트 버킷 조회 또는 생성
fn get_or_create_bucket(
  store: RateLimitStore,
  client_id: string,
  client_type: string,
  current_time: int
) -> TokenBucket {
  bucket = store.buckets[client_id]

  if bucket == null {
    // 새 버킷 생성
    rule = get_rate_limit_rule(store.config, client_type)

    bucket = create_token_bucket(
      client_id,
      rule.burst_size,
      rule.requests_per_second,
      current_time
    )

    store.buckets[client_id] = bucket
    println("   📦 New bucket created for: " + client_id)
  }

  return bucket
}

// ============================================
// Part 5: 통계 및 모니터링
// ============================================

/// 속도 제한 통계
struct RateLimitStats {
  total_requests: int,
  allowed_requests: int,
  rejected_requests: int,
  active_clients: int
}

/// 통계 계산
fn calculate_stats(store: RateLimitStore) -> RateLimitStats {
  return RateLimitStats {
    total_requests: 0,
    allowed_requests: 0,
    rejected_requests: 0,
    active_clients: len(store.buckets)
  }
}

/// 속도 제한 상태 출력
fn print_rate_limit_rules(config: RateLimitConfig) {
  println()
  println("⏱️  Rate Limit Rules")
  println("═══════════════════════════════════")

  for rule in config.rules {
    status = rule.is_enabled ? "✅ ENABLED" : "❌ DISABLED"

    println()
    println(rule.client_type + ": " + status)
    println("├─ Requests/sec: " + to_string(rule.requests_per_second))
    println("└─ Burst size: " + to_string(rule.burst_size))
  }
}

