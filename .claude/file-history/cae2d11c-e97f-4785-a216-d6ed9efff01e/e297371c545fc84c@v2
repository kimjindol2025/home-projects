// ============================================
// Part 1: Raft 노드 구조
// ============================================

/// Raft 노드: 분산 시스템의 한 노드
struct RaftNode {
  // 노드 식별정보
  id: int,                          // 이 노드의 ID (0부터 시작)
  peers: [int],                     // 다른 노드들의 ID

  // Persistent State (디스크에 저장해야 함)
  currentTerm: int = 0,             // 현재 term (초기값: 0)
  votedFor: int? = null,            // 현재 term에서 투표한 후보 (null이면 미투표)
  log: [LogEntry] = [],             // 로그 엔트리 배열 (1-indexed)

  // Volatile State (메모리)
  commitIndex: int = 0,             // 적용 가능한 최대 로그 인덱스
  lastApplied: int = 0,             // 상태 기계에 적용한 최대 인덱스

  // 현재 상태
  state: NodeState = NodeState.Follower,

  // 타이머
  electionTimer: Timer? = null,     // 선거 타임아웃
  heartbeatTimer: Timer? = null,    // 하트비트 타임아웃

  // Leader 전용 상태
  nextIndex: {int: int} = {},       // 각 팔로워에 전송할 다음 로그 인덱스
  matchIndex: {int: int} = {},      // 각 팔로워와 일치하는 최대 로그 인덱스

  // 통계
  electionCount: int = 0,           // 선거 횟수
  appendEntriesCount: int = 0,      // AppendEntries 전송 횟수
  appliedCommandCount: int = 0      // 적용한 명령 개수
}

// ============================================
// Part 2: 노드 초기화
// ============================================

/// Raft 노드 생성
fn create_raft_node(id: int, peers: [int]) -> RaftNode {
  node = RaftNode {
    id: id,
    peers: peers,
    currentTerm: 0,
    votedFor: null,
    log: [],
    commitIndex: 0,
    lastApplied: 0,
    state: NodeState.Follower,
    electionTimer: null,
    heartbeatTimer: null,
    nextIndex: {},
    matchIndex: {},
    electionCount: 0,
    appendEntriesCount: 0,
    appliedCommandCount: 0
  }

  // 타이머 초기화
  node.electionTimer = timer_create(
    "election",
    150 + random(0, 150)  // 150-300ms 무작위
  )
  node.heartbeatTimer = timer_create("heartbeat", 50)

  println("✅ Node " + to_string(id) + " created")
  return node
}

// ============================================
// Part 3: 상태 업데이트
// ============================================

/// Higher term 수신 시 상태 업데이트
fn update_term(node: RaftNode, newTerm: int) -> RaftNode {
  if newTerm > node.currentTerm {
    node.currentTerm = newTerm
    node.votedFor = null              // 투표 초기화
    node.state = NodeState.Follower   // Follower로 강등

    println("Node " + to_string(node.id) + ": term updated to " + to_string(newTerm))
  }

  return node
}

/// Term이 낮으면 거부
fn should_accept_rpc(node: RaftNode, rpcTerm: int) -> bool {
  if rpcTerm < node.currentTerm {
    return false              // RPC의 term이 낮으면 거부
  }

  if rpcTerm > node.currentTerm {
    node = update_term(node, rpcTerm)  // Higher term이면 업데이트
  }

  return true
}

// ============================================
// Part 4: 로그 관리
// ============================================

/// 로그에 새 항목 추가 (Leader만 사용)
fn append_log(node: RaftNode, command: string) -> RaftNode {
  entry = LogEntry {
    term: node.currentTerm,
    command: command,
    index: len(node.log) + 1  // 1-indexed
  }

  node.log = node.log + [entry]

  println("Node " + to_string(node.id) + ": appended log[" +
          to_string(entry.index) + "] = " + command)

  return node
}

/// 마지막 로그의 term 조회
fn last_log_term(node: RaftNode) -> int {
  if len(node.log) == 0 {
    return 0  // 로그가 없으면 term 0
  }
  last_entry = node.log[len(node.log) - 1]
  return last_entry.term
}

/// 마지막 로그의 index 조회
fn last_log_index(node: RaftNode) -> int {
  if len(node.log) == 0 {
    return 0
  }
  return len(node.log)
}

/// 로그 항목 조회 (1-indexed)
fn get_log_entry(node: RaftNode, index: int) -> LogEntry? {
  if index < 1 || index > len(node.log) {
    return null  // 범위 초과
  }
  return node.log[index - 1]  // 0-indexed로 변환
}

// ============================================
// Part 5: Log Up-to-Date Check
// ============================================

/// 후보의 로그가 투표자보다 최신인지 확인
/// Raft 논문: Section 5.4.1
fn is_candidate_log_up_to_date(
  candidateLastLogTerm: int,
  candidateLastLogIndex: int,
  voterLastLogTerm: int,
  voterLastLogIndex: int
) -> bool {
  // Term이 더 크면 최신
  if candidateLastLogTerm > voterLastLogTerm {
    return true
  }

  // Term이 작으면 구식
  if candidateLastLogTerm < voterLastLogTerm {
    return false
  }

  // Term이 같으면 index가 더 크면 최신
  return candidateLastLogIndex >= voterLastLogIndex
}

// ============================================
// Part 6: RequestVote RPC
// ============================================

/// RequestVote RPC 핸들러
fn handle_request_vote(
  node: RaftNode,
  req: RequestVoteRequest
) -> (RaftNode, RequestVoteResponse) {
  // 1. Term 확인
  if req.term < node.currentTerm {
    // RPC의 term이 낮으면 거부
    resp = RequestVoteResponse {
      term: node.currentTerm,
      voteGranted: false
    }
    return (node, resp)
  }

  // Higher term이면 업데이트
  if req.term > node.currentTerm {
    node = update_term(node, req.term)
  }

  // 2. 투표 여부 확인
  if node.votedFor != null && node.votedFor != req.candidateId {
    // 이미 다른 후보에게 투표했음
    resp = RequestVoteResponse {
      term: node.currentTerm,
      voteGranted: false
    }
    return (node, resp)
  }

  // 3. Log Up-to-Date 확인
  if !is_candidate_log_up_to_date(
    req.lastLogTerm,
    req.lastLogIndex,
    last_log_term(node),
    last_log_index(node)
  ) {
    // 후보의 로그가 구식
    resp = RequestVoteResponse {
      term: node.currentTerm,
      voteGranted: false
    }
    return (node, resp)
  }

  // 4. 투표!
  node.votedFor = req.candidateId
  node.electionTimer = timer_reset(node.electionTimer)  // timer reset

  println("Node " + to_string(node.id) + ": voted for " + to_string(req.candidateId))

  resp = RequestVoteResponse {
    term: node.currentTerm,
    voteGranted: true
  }
  return (node, resp)
}

// ============================================
// Part 7: AppendEntries RPC
// ============================================

/// AppendEntries RPC 핸들러
fn handle_append_entries(
  node: RaftNode,
  req: AppendEntriesRequest
) -> (RaftNode, AppendEntriesResponse) {
  // 1. Term 확인
  if req.term < node.currentTerm {
    resp = AppendEntriesResponse {
      term: node.currentTerm,
      success: false,
      conflictIndex: 0
    }
    return (node, resp)
  }

  // Higher term이면 업데이트
  if req.term > node.currentTerm {
    node = update_term(node, req.term)
  }

  // Follower 상태로 설정
  if node.state != NodeState.Follower {
    node.state = NodeState.Follower
  }

  // 타이머 리셋
  node.electionTimer = timer_reset(node.electionTimer)

  // 2. Log Matching Check
  // prevLogIndex의 로그가 존재하고, term이 일치하는지 확인
  if req.prevLogIndex > 0 {
    prevLogEntry = get_log_entry(node, req.prevLogIndex)

    if prevLogEntry == null {
      // prevLogIndex의 로그가 없음 → 충돌
      resp = AppendEntriesResponse {
        term: node.currentTerm,
        success: false,
        conflictIndex: len(node.log) + 1
      }
      return (node, resp)
    }

    if prevLogEntry.term != req.prevLogTerm {
      // prevLogIndex의 term이 일치하지 않음 → 충돌
      resp = AppendEntriesResponse {
        term: node.currentTerm,
        success: false,
        conflictIndex: req.prevLogIndex
      }
      return (node, resp)
    }
  }

  // 3. 로그 추가/수정
  for entry in req.entries {
    // 같은 index에 다른 term의 로그가 있으면 삭제 (conflict resolution)
    existingEntry = get_log_entry(node, entry.index)

    if existingEntry != null && existingEntry.term != entry.term {
      // 로그 충돌: 기존 로그 및 이후 로그 삭제
      // 구현 간소화: 새 로그로 교체 (append-only 가정)
      println("Node " + to_string(node.id) + ": log conflict at " + to_string(entry.index))
    }

    // 아직 없는 로그면 추가
    if get_log_entry(node, entry.index) == null {
      node.log = node.log + [entry]
    }
  }

  // 4. commitIndex 업데이트
  if req.leaderCommit > node.commitIndex {
    node.commitIndex = min(req.leaderCommit, last_log_index(node))
  }

  // 5. 상태 기계에 적용 (나중에 별도 함수에서)
  // apply_committed_logs(node)

  println("Node " + to_string(node.id) + ": AppendEntries accepted, log size=" + to_string(len(node.log)))

  resp = AppendEntriesResponse {
    term: node.currentTerm,
    success: true,
    conflictIndex: 0
  }
  return (node, resp)
}

// ============================================
// Part 8: 유틸리티 함수
// ============================================

/// 최솟값
fn min(a: int, b: int) -> int {
  if a < b { return a }
  return b
}

/// 최댓값
fn max(a: int, b: int) -> int {
  if a > b { return a }
  return b
}

/// 난수 생성 (0부터 max까지, max 포함)
fn random(min_val: int, max_val: int) -> int {
  // 간단한 구현 (실제로는 더 복잡할 수 있음)
  range = max_val - min_val + 1
  return min_val + (time.now() % range)
}

/// 통계 출력
fn print_node_stats(node: RaftNode) {
  println()
  println("📊 Node " + to_string(node.id) + " Stats")
  println("├─ State: " + to_string(node.state))
  println("├─ Term: " + to_string(node.currentTerm))
  println("├─ VotedFor: " + to_string(node.votedFor))
  println("├─ Log Size: " + to_string(len(node.log)))
  println("├─ CommitIndex: " + to_string(node.commitIndex))
  println("├─ LastApplied: " + to_string(node.lastApplied))
  println("├─ Elections: " + to_string(node.electionCount))
  println("└─ AppliedCommands: " + to_string(node.appliedCommandCount))
}

