fn test_create_node() {
  peers = [1, 2, 3, 4]
  node = create_raft_node(0, peers)

  assert node.id == 0
  assert node.currentTerm == 0
  assert node.votedFor == null
  assert node.state == NodeState.Follower
  assert node.commitIndex == 0

  println("✅ test_create_node passed")
}

fn test_append_log() {
  peers = [1, 2]
  node = create_raft_node(0, peers)

  node = append_log(node, "transfer 100")
  node = append_log(node, "withdraw 50")

  assert len(node.log) == 2
  assert node.log[0].command == "transfer 100"
  assert node.log[1].command == "withdraw 50"

  println("✅ test_append_log passed")
}

fn test_log_up_to_date() {
  // Candidate: term=2, lastLogIndex=5
  // Voter: term=2, lastLogIndex=3
  // → Candidate가 더 최신
  result = is_candidate_log_up_to_date(2, 5, 2, 3)
  assert result == true

  // Candidate: term=1, lastLogIndex=10
  // Voter: term=2, lastLogIndex=3
  // → Voter가 더 최신
  result = is_candidate_log_up_to_date(1, 10, 2, 3)
  assert result == false

  println("✅ test_log_up_to_date passed")
}

fn test_request_vote_handler() {
  peers = [1, 2]
  node = create_raft_node(0, peers)

  // RequestVote 요청
  req = RequestVoteRequest {
    term: 1,
    candidateId: 1,
    lastLogIndex: 0,
    lastLogTerm: 0
  }

  (node, resp) = handle_request_vote(node, req)

  assert resp.voteGranted == true
  assert node.votedFor == 1
  assert node.currentTerm == 1

  println("✅ test_request_vote_handler passed")
}

fn test_append_entries_handler() {
  peers = [1, 2]
  node = create_raft_node(0, peers)

  // AppendEntries 요청
  req = AppendEntriesRequest {
    term: 1,
    leaderId: 1,
    prevLogIndex: 0,
    prevLogTerm: 0,
    entries: [
      LogEntry { term: 1, command: "cmd1", index: 1 },
      LogEntry { term: 1, command: "cmd2", index: 2 }
    ],
    leaderCommit: 1
  }

  (node, resp) = handle_append_entries(node, req)

  assert resp.success == true
  assert len(node.log) == 2
  assert node.commitIndex == 1

  println("✅ test_append_entries_handler passed")
}

