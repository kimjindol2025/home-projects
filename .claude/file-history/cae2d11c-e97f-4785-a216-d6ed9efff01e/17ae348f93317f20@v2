// ============================================
// Part 1: 기본 데이터 구조
// ============================================

/// LogEntry: Raft 로그의 한 항목
struct LogEntry {
  term: int,          // 이 항목이 생성된 term
  command: string,    // 상태 기계에 적용할 명령
  index: int          // 논리적 인덱스 (1부터 시작)
}

/// LogEntry를 JSON으로 직렬화
fn log_entry_to_json(entry: LogEntry) -> string {
  return json({
    term: entry.term,
    command: entry.command,
    index: entry.index
  })
}

/// JSON에서 LogEntry 복원
fn json_to_log_entry(json_str: string) -> LogEntry {
  data = json_parse(json_str)
  return LogEntry {
    term: data.term,
    command: data.command,
    index: data.index
  }
}

// ============================================
// Part 2: RPC 메시지 타입
// ============================================

/// RequestVote RPC 요청
/// 후보가 투표를 요청할 때 전송
struct RequestVoteRequest {
  term: int,                // 후보의 현재 term
  candidateId: int,         // 후보의 노드 ID
  lastLogIndex: int,        // 후보의 마지막 로그 인덱스
  lastLogTerm: int          // 후보의 마지막 로그의 term
}

/// RequestVote RPC 응답
struct RequestVoteResponse {
  term: int,                // 현재 term (투표자)
  voteGranted: bool         // 투표했는가?
}

/// AppendEntries RPC 요청
/// 리더가 로그를 복제할 때 전송
struct AppendEntriesRequest {
  term: int,                // 리더의 현재 term
  leaderId: int,            // 리더의 노드 ID
  prevLogIndex: int,        // 이전 로그 인덱스
  prevLogTerm: int,         // 이전 로그의 term
  entries: [LogEntry],      // 복제할 로그 엔트리들
  leaderCommit: int         // 리더의 commitIndex
}

/// AppendEntries RPC 응답
struct AppendEntriesResponse {
  term: int,                // 현재 term (팔로워)
  success: bool,            // 복제 성공 여부
  conflictIndex: int        // 실패 시 충돌 인덱스 (최적화용)
}

// ============================================
// Part 3: RPC 직렬화/역직렬화
// ============================================

fn request_vote_request_to_json(req: RequestVoteRequest) -> string {
  return json({
    type: "RequestVote",
    term: req.term,
    candidateId: req.candidateId,
    lastLogIndex: req.lastLogIndex,
    lastLogTerm: req.lastLogTerm
  })
}

fn json_to_request_vote_request(json_str: string) -> RequestVoteRequest {
  data = json_parse(json_str)
  return RequestVoteRequest {
    term: data.term,
    candidateId: data.candidateId,
    lastLogIndex: data.lastLogIndex,
    lastLogTerm: data.lastLogTerm
  }
}

fn request_vote_response_to_json(resp: RequestVoteResponse) -> string {
  return json({
    type: "RequestVoteResp",
    term: resp.term,
    voteGranted: resp.voteGranted
  })
}

fn json_to_request_vote_response(json_str: string) -> RequestVoteResponse {
  data = json_parse(json_str)
  return RequestVoteResponse {
    term: data.term,
    voteGranted: data.voteGranted
  }
}

fn append_entries_request_to_json(req: AppendEntriesRequest) -> string {
  // entries 배열을 JSON으로 변환
  entries_json = []
  for entry in req.entries {
    entries_json = entries_json + [json_parse(log_entry_to_json(entry))]
  }

  return json({
    type: "AppendEntries",
    term: req.term,
    leaderId: req.leaderId,
    prevLogIndex: req.prevLogIndex,
    prevLogTerm: req.prevLogTerm,
    entries: entries_json,
    leaderCommit: req.leaderCommit
  })
}

fn json_to_append_entries_request(json_str: string) -> AppendEntriesRequest {
  data = json_parse(json_str)

  // JSON entries를 LogEntry 배열로 변환
  entries = []
  for entry_data in data.entries {
    entry = LogEntry {
      term: entry_data.term,
      command: entry_data.command,
      index: entry_data.index
    }
    entries = entries + [entry]
  }

  return AppendEntriesRequest {
    term: data.term,
    leaderId: data.leaderId,
    prevLogIndex: data.prevLogIndex,
    prevLogTerm: data.prevLogTerm,
    entries: entries,
    leaderCommit: data.leaderCommit
  }
}

fn append_entries_response_to_json(resp: AppendEntriesResponse) -> string {
  return json({
    type: "AppendEntriesResp",
    term: resp.term,
    success: resp.success,
    conflictIndex: resp.conflictIndex
  })
}

fn json_to_append_entries_response(json_str: string) -> AppendEntriesResponse {
  data = json_parse(json_str)
  return AppendEntriesResponse {
    term: data.term,
    success: data.success,
    conflictIndex: data.conflictIndex
  }
}

// ============================================
// Part 4: Raft 상태 (State Machine)
// ============================================

/// Raft 노드의 역할
enum NodeState {
  Follower,
  Candidate,
  Leader
}

/// RPC 처리 결과
struct RpcResult {
  success: bool,
  error: string?
}

// ============================================
// Part 5: 스냅샷 (Log Compaction용)
// ============================================

/// 스냅샷: 오래된 로그를 압축
struct Snapshot {
  lastIncludedIndex: int,   // 마지막 포함된 로그 인덱스
  lastIncludedTerm: int,    // 마지막 포함된 로그의 term
  state: string             // 상태 기계 스냅샷 (JSON)
}

fn snapshot_to_json(snap: Snapshot) -> string {
  return json({
    lastIncludedIndex: snap.lastIncludedIndex,
    lastIncludedTerm: snap.lastIncludedTerm,
    state: snap.state
  })
}

fn json_to_snapshot(json_str: string) -> Snapshot {
  data = json_parse(json_str)
  return Snapshot {
    lastIncludedIndex: data.lastIncludedIndex,
    lastIncludedTerm: data.lastIncludedTerm,
    state: data.state
  }
}

// ============================================
// Part 6: 타이머
// ============================================

/// 타이머: 시간 기반 이벤트 관리
struct Timer {
  name: string,             // 타이머 이름 (디버깅용)
  startTime: int,           // 시작 시간 (ms)
  timeout: int              // 타임아웃 (ms)
}

fn timer_create(name: string, timeout: int) -> Timer {
  return Timer {
    name: name,
    startTime: time.now(),
    timeout: timeout
  }
}

fn timer_elapsed(t: Timer) -> int {
  return time.now() - t.startTime
}

fn timer_expired(t: Timer) -> bool {
  return timer_elapsed(t) >= t.timeout
}

fn timer_reset(t: Timer) -> Timer {
  t.startTime = time.now()
  return t
}

// ============================================
// Part 7: 통계 (디버깅/모니터링용)
// ============================================

/// Raft 통계
struct RaftStats {
  nodeId: int,
  currentTerm: int,
  votedFor: int?,
  logSize: int,
  commitIndex: int,
  lastApplied: int,
  state: NodeState,
  electionCount: int,
  appendEntriesCount: int,
  appliedCommandCount: int
}

fn stats_to_json(stats: RaftStats) -> string {
  return json({
    nodeId: stats.nodeId,
    currentTerm: stats.currentTerm,
    votedFor: stats.votedFor,
    logSize: stats.logSize,
    commitIndex: stats.commitIndex,
    lastApplied: stats.lastApplied,
    state: stats.state,
    electionCount: stats.electionCount,
    appendEntriesCount: stats.appendEntriesCount,
    appliedCommandCount: stats.appliedCommandCount
  })
}

