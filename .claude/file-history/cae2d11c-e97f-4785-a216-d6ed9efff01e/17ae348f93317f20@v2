fn test_log_entry_serialization() {
  // LogEntry 생성
  entry = LogEntry {
    term: 5,
    command: "transfer 100",
    index: 10
  }

  // JSON으로 직렬화
  json_str = log_entry_to_json(entry)
  println("LogEntry JSON: " + json_str)

  // 복원
  restored = json_to_log_entry(json_str)
  assert restored.term == 5
  assert restored.command == "transfer 100"
  assert restored.index == 10

  println("✅ test_log_entry_serialization passed")
}

fn test_request_vote_rpc() {
  // RequestVote 요청 생성
  req = RequestVoteRequest {
    term: 3,
    candidateId: 1,
    lastLogIndex: 5,
    lastLogTerm: 2
  }

  // JSON 직렬화
  json_str = request_vote_request_to_json(req)
  println("RequestVote JSON: " + json_str)

  // 복원
  restored = json_to_request_vote_request(json_str)
  assert restored.term == 3
  assert restored.candidateId == 1

  println("✅ test_request_vote_rpc passed")
}

fn test_append_entries_rpc() {
  // AppendEntries 요청 생성
  entries = [
    LogEntry { term: 2, command: "cmd1", index: 3 },
    LogEntry { term: 2, command: "cmd2", index: 4 }
  ]

  req = AppendEntriesRequest {
    term: 3,
    leaderId: 1,
    prevLogIndex: 2,
    prevLogTerm: 2,
    entries: entries,
    leaderCommit: 2
  }

  // JSON 직렬화
  json_str = append_entries_request_to_json(req)
  println("AppendEntries JSON length: " + to_string(len(json_str)))

  // 복원
  restored = json_to_append_entries_request(json_str)
  assert restored.term == 3
  assert restored.leaderId == 1
  assert len(restored.entries) == 2

  println("✅ test_append_entries_rpc passed")
}

fn test_timer() {
  // 타이머 생성 (100ms)
  t = timer_create("election", 100)

  // 아직 만료 안 됨
  assert !timer_expired(t)

  // 시간 대기 (실제로는 simulation에서 mock)
  // sleep(150)  // 실제 환경에서만 필요

  // 타이머 리셋
  t = timer_reset(t)
  assert timer_elapsed(t) < 10

  println("✅ test_timer passed")
}

