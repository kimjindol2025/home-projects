---
# ConfigMap: 분산 은행 시스템 설정
apiVersion: v1
kind: ConfigMap
metadata:
  name: distributed-bank-config
  namespace: distributed-bank
  labels:
    app: distributed-bank
data:
  # 로깅 설정
  RUST_LOG: "info"

  # 노드 설정
  NODE_TYPE: "distributed"

  # 보안 설정
  TLS_ENABLED: "true"
  ENCRYPTION_ENABLED: "true"
  JWT_SECRET: "change-me-in-production"

  # 포트 설정
  HTTP_PORT: "8080"
  RAFT_PORT: "9000"

  # 성능 설정
  WORKER_THREADS: "4"
  MAX_CONNECTIONS: "1000"

  # 타임아웃 설정
  REQUEST_TIMEOUT_MS: "30000"
  RAFT_ELECTION_TIMEOUT_MS: "300"

  # 리소스 제한
  MAX_ACCOUNTS: "100000"
  MAX_TRANSACTIONS: "1000000"

---
# ConfigMap: 헬스 체크 스크립트
apiVersion: v1
kind: ConfigMap
metadata:
  name: health-check-script
  namespace: distributed-bank
data:
  health-check.sh: |
    #!/bin/bash
    # 헬스 체크 스크립트

    # HTTP 헬스 체크
    RESPONSE=$(curl -s -o /dev/null -w "%{http_code}" http://localhost:8080/health)

    if [ "$RESPONSE" = "200" ]; then
      echo "✅ Health check passed"
      exit 0
    else
      echo "❌ Health check failed: HTTP $RESPONSE"
      exit 1
    fi
