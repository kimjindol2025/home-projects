[package]
name = "distributed_bank"
version = "1.0.0"
edition = "2021"
authors = ["Claude Code AI <noreply@anthropic.com>"]
description = "Distributed Banking System in Rust - Optimized Version"
license = "MIT"

[dependencies]
# Async runtime
tokio = { version = "1.35", features = ["full"] }
tokio-util = "0.7"

# Serialization
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"

# Networking
hyper = { version = "1.0", features = ["full"] }
http = "1.0"

# Logging
tracing = "0.1"
tracing-subscriber = "0.3"

# Error handling
anyhow = "1.0"
thiserror = "1.0"

# Utilities
uuid = { version = "1.0", features = ["v4", "serde"] }
chrono = { version = "0.4", features = ["serde"] }
parking_lot = "0.12"
dashmap = "5.5"
futures = "0.3"

# Benchmarking
criterion = "0.5"

# TLS & Security (Phase E)
rustls = "0.21"
rustls-pemfile = "2.0"
tokio-rustls = "0.24"
hyper-rustls = "0.24"

# JWT 토큰
jsonwebtoken = "9.0"
base64 = "0.21"

# 암호화
chacha20poly1305 = "0.10"
rand = "0.8"

# 테스트용 인증서 생성 (선택)
rcgen = "0.11"

[dev-dependencies]
tokio-test = "0.4"
mockito = "1.2"

[[bench]]
name = "raft_benchmark"
harness = false

[[bench]]
name = "proxy_benchmark"
harness = false

[[bench]]
name = "bank_benchmark"
harness = false

[[bench]]
name = "security_benchmark"
harness = false

[[bench]]
name = "integrated_benchmark"
harness = false

[profile.release]
opt-level = 3
lto = true
codegen-units = 1
strip = true
