# 분산 은행 시스템 기본 설정값
# 환경별로 values-dev.yaml, values-staging.yaml, values-prod.yaml로 오버라이드

# ============================================
# 전역 설정
# ============================================
global:
  environment: development
  domain: bank.example.com
  tls:
    enabled: true
    issuer: letsencrypt-prod

# ============================================
# 이미지 설정
# ============================================
image:
  repository: distributed-bank
  tag: "1.0.0"
  pullPolicy: IfNotPresent

# ============================================
# 네임스페이스
# ============================================
namespace:
  name: distributed-bank
  create: true

# ============================================
# Deployment 설정
# ============================================
deployment:
  name: distributed-bank
  strategy: RollingUpdate

  # 레플리카
  replicas:
    initial: 3
    min: 3
    max: 10

  # Pod 배치 정책
  affinity:
    podAntiAffinity: preferred  # preferred or required

  # 보안 컨텍스트
  securityContext:
    runAsNonRoot: true
    runAsUser: 1000
    readOnlyRootFilesystem: true

  # 리소스 제한
  resources:
    requests:
      cpu: 100m
      memory: 128Mi
    limits:
      cpu: 500m
      memory: 512Mi

# ============================================
# 헬스체크 (Probe) 설정
# ============================================
healthChecks:
  # Liveness Probe (Pod가 정상인지 확인)
  liveness:
    enabled: true
    path: /health
    initialDelaySeconds: 10
    periodSeconds: 10
    timeoutSeconds: 3
    failureThreshold: 3

  # Readiness Probe (트래픽을 받을 준비가 됐는지)
  readiness:
    enabled: true
    path: /ready
    initialDelaySeconds: 5
    periodSeconds: 5
    timeoutSeconds: 2
    failureThreshold: 2

  # Startup Probe (애플리케이션 시작 시간 허용)
  startup:
    enabled: true
    path: /health
    initialDelaySeconds: 0
    periodSeconds: 1
    failureThreshold: 30

# ============================================
# 서비스 설정
# ============================================
service:
  # 내부 클러스터 서비스
  internal:
    name: distributed-bank
    type: ClusterIP
    ports:
      http: 8080
      raft: 9000

  # 외부 로드 밸런서
  external:
    name: distributed-bank-lb
    type: LoadBalancer
    ports:
      http: 80
      https: 443
    sessionAffinity:
      enabled: true
      timeoutSeconds: 3600

  # Raft 클러스터 헤드리스 서비스
  raft:
    name: distributed-bank-raft
    type: ClusterIP
    headless: true
    port: 9000

# ============================================
# Ingress 설정
# ============================================
ingress:
  enabled: true
  className: nginx

  tls:
    enabled: true
    secretName: distributed-bank-tls

  hosts:
    - name: bank.example.com
      paths:
        - path: /
          pathType: Prefix
          backend: distributed-bank-lb:8080

    - name: api.bank.example.com
      paths:
        - path: /
          pathType: Prefix
          backend: distributed-bank:8080

    - name: health.bank.example.com
      paths:
        - path: /health
          pathType: Exact
          backend: distributed-bank:8080

  annotations:
    nginx.ingress.kubernetes.io/rewrite-target: /
    nginx.ingress.kubernetes.io/ssl-redirect: "true"
    nginx.ingress.kubernetes.io/force-ssl-redirect: "true"
    nginx.ingress.kubernetes.io/limit-rps: "100"
    nginx.ingress.kubernetes.io/proxy-connect-timeout: "30"
    nginx.ingress.kubernetes.io/proxy-send-timeout: "30"
    nginx.ingress.kubernetes.io/proxy-read-timeout: "30"
    nginx.ingress.kubernetes.io/enable-cors: "true"
    nginx.ingress.kubernetes.io/cors-allow-origin: "*"

# ============================================
# 오토스케일링 설정
# ============================================
autoscaling:
  enabled: true
  minReplicas: 3
  maxReplicas: 10

  # 메트릭 기반 스케일링
  metrics:
    cpu:
      enabled: true
      targetUtilization: 70
    memory:
      enabled: true
      targetUtilization: 80

  # 스케일링 동작
  behavior:
    scaleUp:
      stabilizationWindowSeconds: 0
      policies:
        - type: Percent
          value: 100
          periodSeconds: 30
        - type: Pods
          value: 2
          periodSeconds: 30
      selectPolicy: Max

    scaleDown:
      stabilizationWindowSeconds: 300
      policies:
        - type: Percent
          value: 50
          periodSeconds: 60
      selectPolicy: Min

# ============================================
# Pod Disruption Budget
# ============================================
podDisruptionBudget:
  enabled: true
  minAvailable: 2

# ============================================
# 네트워크 정책
# ============================================
networkPolicy:
  enabled: true
  allowIngressFromNamespace: ingress-nginx
  allowEgressToDns: true
  allowEgressToExternal: false

# ============================================
# 모니터링 설정
# ============================================
monitoring:
  enabled: true

  # Prometheus ServiceMonitor
  serviceMonitor:
    enabled: true
    interval: 30s
    path: /metrics

  # 알람 규칙
  alerts:
    enabled: true
    rules:
      - highCpuUsage:
          threshold: 80
          duration: 5m
      - highMemoryUsage:
          threshold: 85
          duration: 5m
      - highPodRestartRate:
          threshold: 0.1
          duration: 15m
      - highErrorRate:
          threshold: 5
          duration: 5m
      - highResponseTime:
          threshold: 50
          duration: 5m
      - podNotReady:
          duration: 5m

# ============================================
# 설정 맵
# ============================================
configMap:
  # 애플리케이션 로그 레벨
  rustLog: info

  # TLS 설정
  tlsEnabled: "true"
  tlsCertPath: /etc/tls/certs/server.crt
  tlsKeyPath: /etc/tls/certs/server.key

  # 암호화 설정
  encryptionEnabled: "true"

  # 데이터베이스 설정
  dbPath: /data/distributed-bank.db
  dbMaxConnections: "100"

  # Raft 설정
  raftNodeId: "1"
  raftPeers: "distributed-bank-raft:9000"
  raftSnapshotInterval: "10000"
  raftElectionTimeout: "1000"
  raftHeartbeatInterval: "100"

# ============================================
# 시크릿 관리
# ============================================
secrets:
  # TLS 인증서
  tls:
    create: true
    # base64로 인코딩된 인증서 (실제 값은 비밀 관리 시스템에서 관리)
    cert: ""
    key: ""

  # JWT 시크릿
  jwt:
    secret: ""

  # 데이터베이스 암호화 키
  encryptionKey: ""

# ============================================
# 볼륨 설정
# ============================================
persistence:
  enabled: true

  # 데이터 볼륨
  data:
    storageClass: default
    size: 10Gi
    mountPath: /data

  # TLS 인증서 볼륨
  tls:
    enabled: true
    mountPath: /etc/tls/certs

# ============================================
# 배포 후 작업
# ============================================
postDeployment:
  # 배포 검증 명령어
  healthCheck:
    enabled: true
    command: /bin/health_check

  # 초기화 작업
  initialization:
    enabled: true
    commands:
      - name: wait-for-leader
        command: sh -c 'until curl http://localhost:8080/health; do sleep 1; done'

# ============================================
# 로깅 및 디버깅
# ============================================
debug:
  enabled: false
  verboseLogging: false
  metricsPort: 8888
  pprofEnabled: false
