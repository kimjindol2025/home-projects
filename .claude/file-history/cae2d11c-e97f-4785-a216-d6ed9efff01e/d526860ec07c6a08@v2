// ============================================
// Distributed Transaction - Two-Phase Commit
// ============================================
// 분산 트랜잭션 관리 (2PC)
// 원자성 보장, 장애 복구, 타임아웃 처리
//
// 작성: Claude Code AI (2026-03-02)
// 난이도: ⭐⭐⭐⭐⭐ 박사 수준
// ============================================

// ============================================
// Part 1: 트랜잭션 상태 관리
// ============================================

/// 트랜잭션 상태
enum TxState {
  Pending,      // 초기 상태
  Prepared,     // Phase 1: 모든 노드가 준비
  Committed,    // Phase 2: 커밋 완료
  Aborted       // 중단됨
}

/// 참여자 투표
enum VoteResult {
  Yes,          // 커밋 가능
  No,           // 커밋 불가능
  Timeout       // 타임아웃
}

/// 참여자 상태
struct Participant {
  node_id: string,
  status: VoteResult,
  prepared_time: int,
  response_time: int
}

/// 분산 트랜잭션
struct DistributedTransaction {
  tx_id: string,
  coordinator: string,
  participants: [Participant],
  state: TxState,
  created_at: int,
  updated_at: int,
  timeout: int,
  phase1_votes: int,
  phase2_acks: int
}

/// 트랜잭션 로그
struct TxLog {
  tx_id: string,
  state: TxState,
  timestamp: int,
  message: string
}

/// 분산 트랜잭션 관리자
struct TransactionManager {
  transactions: {string: DistributedTransaction},
  logs: [TxLog],
  tx_counter: int,
  success_count: int,
  abort_count: int
}

/// 트랜잭션 관리자 초기화
fn init_transaction_manager() -> TransactionManager {
  println()
  println("🔄 Transaction Manager Initialized")
  println("├─ Algorithm: Two-Phase Commit (2PC)")
  println("├─ Timeout: 30000ms")
  println("└─ Status: Ready")

  return TransactionManager {
    transactions: {},
    logs: [],
    tx_counter: 0,
    success_count: 0,
    abort_count: 0
  }
}

// ============================================
// Part 2: Phase 1 - Prepare
// ============================================

/// 트랜잭션 생성
fn begin_transaction(
  manager: TransactionManager,
  coordinator: string,
  participant_nodes: [string],
  current_time: int
) -> DistributedTransaction {
  tx_id = "dtx_" + to_string(manager.tx_counter)
  manager.tx_counter = manager.tx_counter + 1

  participants = []
  for node_id in participant_nodes {
    participants = participants + [
      Participant {
        node_id: node_id,
        status: VoteResult.Timeout,
        prepared_time: 0,
        response_time: 0
      }
    ]
  }

  tx = DistributedTransaction {
    tx_id: tx_id,
    coordinator: coordinator,
    participants: participants,
    state: TxState.Pending,
    created_at: current_time,
    updated_at: current_time,
    timeout: 30000,
    phase1_votes: 0,
    phase2_acks: 0
  }

  manager.transactions[tx_id] = tx

  println()
  println("🎯 Distributed Transaction Started")
  println("├─ TX ID: " + tx_id)
  println("├─ Coordinator: " + coordinator)
  println("└─ Participants: " + to_string(len(participant_nodes)))

  return tx
}

/// Phase 1: Prepare 요청
fn prepare_phase(
  manager: TransactionManager,
  tx_id: string,
  current_time: int
) -> DistributedTransaction {
  tx = manager.transactions[tx_id]

  if tx == null {
    println("❌ Transaction not found: " + tx_id)
    return null
  }

  println()
  println("📤 Phase 1: Sending PREPARE to participants")

  vote_count = 0
  for participant in tx.participants {
    // 시뮬레이션: 90% 확률로 Yes, 10% 확률로 No
    vote = random(0, 99) < 90 ? VoteResult.Yes : VoteResult.No

    participant.status = vote
    participant.prepared_time = current_time

    vote_str = vote == VoteResult.Yes ? "✅ YES" :
              vote == VoteResult.No ? "❌ NO" : "⏱️  TIMEOUT"

    println("   " + participant.node_id + ": " + vote_str)

    if vote == VoteResult.Yes {
      vote_count = vote_count + 1
    }
  }

  tx.state = TxState.Prepared
  tx.phase1_votes = vote_count
  tx.updated_at = current_time

  // 모든 참여자가 Yes여야 커밋 가능
  if vote_count == len(tx.participants) {
    println()
    println("✅ Phase 1 Passed: All participants voted YES")
  } else {
    println()
    println("❌ Phase 1 Failed: Not all participants agreed")
  }

  return tx
}

// ============================================
// Part 3: Phase 2 - Commit/Abort
// ============================================

/// Phase 2: Commit 또는 Abort 결정
fn commit_phase(
  manager: TransactionManager,
  tx_id: string,
  current_time: int
) -> DistributedTransaction {
  tx = manager.transactions[tx_id]

  if tx == null {
    return null
  }

  println()
  println("💾 Phase 2: Sending decision to participants")

  // Phase 1에서 모든 참여자가 Yes했는지 확인
  can_commit = tx.phase1_votes == len(tx.participants)

  if can_commit {
    println("📩 Decision: COMMIT")

    // 모든 참여자에게 COMMIT 전송
    ack_count = 0
    for participant in tx.participants {
      // 시뮬레이션: 95% 확률로 ACK 수신
      acked = random(0, 99) < 95

      if acked {
        participant.response_time = current_time
        ack_count = ack_count + 1
        println("   " + participant.node_id + ": ✅ ACK")
      } else {
        println("   " + participant.node_id + ": ⏱️  No ACK")
      }
    }

    tx.phase2_acks = ack_count
    tx.state = TxState.Committed
    manager.success_count = manager.success_count + 1

    println()
    println("✅ Transaction COMMITTED (" + to_string(ack_count) + "/" +
            to_string(len(tx.participants)) + " ACKs)")

  } else {
    println("📩 Decision: ABORT")

    // 모든 참여자에게 ABORT 전송
    for participant in tx.participants {
      println("   " + participant.node_id + ": 🔙 ROLLBACK")
    }

    tx.state = TxState.Aborted
    manager.abort_count = manager.abort_count + 1

    println()
    println("❌ Transaction ABORTED")
  }

  tx.updated_at = current_time

  return tx
}

// ============================================
// Part 4: 장애 처리
// ============================================

/// 타임아웃 확인
fn check_timeout(
  manager: TransactionManager,
  tx_id: string,
  current_time: int
) -> DistributedTransaction {
  tx = manager.transactions[tx_id]

  if tx == null {
    return null
  }

  time_elapsed = current_time - tx.created_at

  if time_elapsed > tx.timeout {
    println()
    println("⏱️  Transaction timeout: " + tx_id)

    // 타임아웃으로 인한 자동 ABORT
    if tx.state == TxState.Pending || tx.state == TxState.Prepared {
      tx.state = TxState.Aborted
      manager.abort_count = manager.abort_count + 1

      println("   Automatically ABORTED due to timeout")
    }
  }

  return tx
}

/// 참여자 복구
fn recover_participant(
  manager: TransactionManager,
  tx_id: string,
  failed_node: string,
  current_time: int
) -> DistributedTransaction {
  tx = manager.transactions[tx_id]

  if tx == null {
    return null
  }

  println()
  println("🔧 Recovering failed participant: " + failed_node)

  // 트랜잭션 상태에 따라 복구
  if tx.state == TxState.Committed {
    println("   Re-sending COMMIT to: " + failed_node)
  } else if tx.state == TxState.Aborted {
    println("   Re-sending ABORT to: " + failed_node)
  } else {
    println("   Sending ABORT (transaction still pending)")
  }

  println("   ✅ Recovery message sent")

  return tx
}

// ============================================
// Part 5: 모니터링
// ============================================

/// 트랜잭션 통계
struct TxStats {
  total: int,
  committed: int,
  aborted: int,
  pending: int,
  success_rate: int
}

/// 통계 계산
fn calculate_tx_stats(manager: TransactionManager) -> TxStats {
  committed = manager.success_count
  aborted = manager.abort_count
  total = committed + aborted

  success_rate = 0
  if total > 0 {
    success_rate = (committed * 100) / total
  }

  return TxStats {
    total: total,
    committed: committed,
    aborted: aborted,
    pending: len(manager.transactions),
    success_rate: success_rate
  }
}

/// 트랜잭션 상태 출력
fn print_transaction_status(tx: DistributedTransaction) {
  println()
  println("📊 Transaction: " + tx.tx_id)
  println("├─ State: " + (tx.state == TxState.Committed ? "Committed" :
          tx.state == TxState.Prepared ? "Prepared" :
          tx.state == TxState.Aborted ? "Aborted" : "Pending"))
  println("├─ Coordinator: " + tx.coordinator)
  println("├─ Participants: " + to_string(len(tx.participants)))
  println("├─ Phase 1 Votes: " + to_string(tx.phase1_votes))
  println("└─ Phase 2 ACKs: " + to_string(tx.phase2_acks))
}

// ============================================
// Part 6: 테스트
// ============================================

fn test_init_transaction_manager() {
  manager = init_transaction_manager()

  assert manager.tx_counter == 0
  assert manager.success_count == 0

  println("✅ test_init_transaction_manager passed")
}

fn test_begin_transaction() {
  manager = init_transaction_manager()

  nodes = ["node1", "node2", "node3"]
  tx = begin_transaction(manager, "coordinator", nodes, 1000)

  assert tx.tx_id == "dtx_0"
  assert len(tx.participants) == 3
  assert tx.state == TxState.Pending

  println("✅ test_begin_transaction passed")
}

fn test_prepare_phase_success() {
  manager = init_transaction_manager()

  nodes = ["node1", "node2"]
  tx = begin_transaction(manager, "coordinator", nodes, 1000)

  // 모든 참여자가 Yes인 경우를 테스트
  for i = 0; i < len(tx.participants); i = i + 1 {
    tx.participants[i].status = VoteResult.Yes
  }

  tx = prepare_phase(manager, tx.tx_id, 1000)

  assert tx.state == TxState.Prepared

  println("✅ test_prepare_phase_success passed")
}

fn test_commit_phase() {
  manager = init_transaction_manager()

  nodes = ["node1", "node2"]
  tx = begin_transaction(manager, "coordinator", nodes, 1000)

  // Phase 1 모의 통과
  for i = 0; i < len(tx.participants); i = i + 1 {
    tx.participants[i].status = VoteResult.Yes
  }
  tx.state = TxState.Prepared
  tx.phase1_votes = len(tx.participants)

  tx = commit_phase(manager, tx.tx_id, 1000)

  assert tx.state == TxState.Committed

  println("✅ test_commit_phase passed")
}

fn test_abort_on_prepare_failure() {
  manager = init_transaction_manager()

  nodes = ["node1", "node2"]
  tx = begin_transaction(manager, "coordinator", nodes, 1000)

  // 한 참여자가 No라고 응답
  tx.participants[0].status = VoteResult.No

  tx = prepare_phase(manager, tx.tx_id, 1000)
  tx = commit_phase(manager, tx.tx_id, 1000)

  assert tx.state == TxState.Aborted

  println("✅ test_abort_on_prepare_failure passed")
}

fn test_timeout_handling() {
  manager = init_transaction_manager()

  nodes = ["node1", "node2"]
  tx = begin_transaction(manager, "coordinator", nodes, 1000)

  // 타임아웃 시뮬레이션 (35초 후)
  tx = check_timeout(manager, tx.tx_id, 36000)

  assert tx.state == TxState.Aborted

  println("✅ test_timeout_handling passed")
}

fn test_calculate_stats() {
  manager = init_transaction_manager()

  manager.success_count = 8
  manager.abort_count = 2

  stats = calculate_tx_stats(manager)

  assert stats.total == 10
  assert stats.committed == 8
  assert stats.aborted == 2
  assert stats.success_rate == 80

  println("✅ test_calculate_stats passed")
}

