/// 전체 프록시 시스템
struct ProxySystem {
  // Core components
  router: RequestRouter,
  load_balancer: LoadBalancer,
  health_checker: HealthCheckConfig,
  circuit_breaker: CircuitBreaker,

  // Security & Monitoring
  auth: AuthConfig,
  rate_limiter: RateLimitConfig,
  metrics: MetricsCollector,

  // State
  active_backends: [BackendServer],
  token_store: {string: Token},
  token_bucket_store: {string: TokenBucket}
}

/// 시스템 초기화
fn init_proxy_system() -> ProxySystem {
  println()
  println("🚀 Initializing Complete Proxy System")
  println("═════════════════════════════════════")

  // 각 컴포넌트 초기화
  router = init_request_router(0)
  lb = init_load_balancer("round_robin")
  auth = init_auth(3600)
  rl = init_rate_limiter()
  collector = init_metrics_collector()
  cb = init_circuit_breaker("main_proxy")
  hc = init_health_check()

  // Backend 설정
  backends = [
    BackendServer {
      node_id: 0,
      host: "localhost",
      port: 9000,
      weight: 1,
      active: true,
      connection_count: 0,
      total_requests: 0,
      failed_requests: 0
    },
    BackendServer {
      node_id: 1,
      host: "localhost",
      port: 9100,
      weight: 2,
      active: true,
      connection_count: 0,
      total_requests: 0,
      failed_requests: 0
    }
  ]

  // 로드 밸런서에 백엔드 추가
  for backend in backends {
    lb = add_backend(lb, backend.node_id, backend.host,
                    backend.port, backend.weight)
  }

  system = ProxySystem {
    router: router,
    load_balancer: lb,
    health_checker: hc,
    circuit_breaker: cb,
    auth: auth,
    rate_limiter: rl,
    metrics: collector,
    active_backends: backends,
    token_store: {},
    token_bucket_store: {}
  }

  println()
  println("✅ System initialized")
  println("├─ Backends: " + to_string(len(backends)))
  println("├─ Auth TTL: 3600s")
  println("├─ Rate Limiting: Token Bucket")
  println("└─ Monitoring: Active")

  return system
}

// ============================================
// Part 2: 시나리오 테스트
// ============================================

/// 시나리오 1: 정상 요청 흐름
fn test_scenario_normal_request(system: ProxySystem, current_time: int) {
  println()
  println("📋 Scenario 1: Normal Request Flow")
  println("════════════════════════════════════")

  // 1단계: 토큰 생성
  println()
  println("Step 1: Generate token")
  token = generate_token("user1", UserRole.User, system.auth, current_time)
  system.token_store[token.token_id] = token

  // 2단계: 요청 헤더 준비
  println()
  println("Step 2: Prepare request headers")
  request_headers = {
    "Authorization": token.token_id,
    "Content-Type": "application/json"
  }

  // 3단계: 인증
  println()
  println("Step 3: Authenticate request")
  auth_result = authenticate_request(request_headers,
                                     system.token_store,
                                     current_time)

  assert auth_result.is_valid == true

  // 4단계: 속도 제한 확인
  println()
  println("Step 4: Check rate limit")
  bucket = get_or_create_bucket(init_rate_limit_store(system.rate_limiter),
                                "user1", "user", current_time)

  // 5단계: 라우팅
  println()
  println("Step 5: Route request")
  backend_id = select_route(system.router, "/api/users", request_headers)

  // 6단계: Circuit Breaker 확인
  println()
  println("Step 6: Check circuit breaker")
  is_allowed = is_request_allowed(system.circuit_breaker, current_time)
  assert is_allowed == true

  // 7단계: 메트릭 기록
  println()
  println("Step 7: Record metrics")
  system.metrics = record_request(system.metrics, true, 50, false)

  println()
  println("✅ Scenario 1 passed")
}

/// 시나리오 2: 인증 실패
fn test_scenario_auth_failure(system: ProxySystem, current_time: int) {
  println()
  println("📋 Scenario 2: Authentication Failure")
  println("════════════════════════════════════")

  // 토큰 없음
  request_headers = {}

  println()
  println("Attempting request without token")
  auth_result = authenticate_request(request_headers,
                                     system.token_store,
                                     current_time)

  assert auth_result.is_valid == false

  println()
  println("✅ Scenario 2 passed (auth correctly rejected)")
}

/// 시나리오 3: 속도 제한
fn test_scenario_rate_limiting(system: ProxySystem, current_time: int) {
  println()
  println("📋 Scenario 3: Rate Limiting")
  println("════════════════════════════════════")

  // 토큰 생성
  token = generate_token("user2", UserRole.Anonymous, system.auth, current_time)

  // Anonymous 사용자는 1 req/s 제한
  bucket = create_token_bucket("user2", 5, 1, current_time)

  println()
  println("Testing anonymous user (1 req/s limit)")

  // 5개 요청 시도
  allowed_count = 0
  for i = 0; i < 5; i = i + 1 {
    bucket = refill_tokens(bucket, current_time)

    if bucket.tokens >= 1 {
      bucket.tokens = bucket.tokens - 1
      allowed_count = allowed_count + 1
    }
  }

  println("Allowed requests: " + to_string(allowed_count) + "/5")

  println()
  println("✅ Scenario 3 passed")
}

/// 시나리오 4: 헬스 체크 및 장애 감지
fn test_scenario_health_check(system: ProxySystem, current_time: int) {
  println()
  println("📋 Scenario 4: Health Check & Failure Detection")
  println("════════════════════════════════════════════════")

  hc_config = init_health_check()

  println()
  println("Performing health checks on backends")

  backends = system.active_backends
  updated = perform_health_checks(backends, hc_config)

  healthy = 0
  unhealthy = 0

  for backend in updated {
    if backend.active {
      healthy = healthy + 1
    } else {
      unhealthy = unhealthy + 1
    }
  }

  println("Result: " + to_string(healthy) + " healthy, " +
          to_string(unhealthy) + " unhealthy")

  println()
  println("✅ Scenario 4 passed")
}

/// 시나리오 5: 로드 밸런싱 전략
fn test_scenario_load_balancing_strategies(system: ProxySystem, current_time: int) {
  println()
  println("📋 Scenario 5: Load Balancing Strategies")
  println("═════════════════════════════════════════")

  println()
  println("Testing Round-Robin strategy")

  lb_rr = init_load_balancer("round_robin")
  lb_rr = add_backend(lb_rr, 0, "localhost", 9000, 1)
  lb_rr = add_backend(lb_rr, 1, "localhost", 9100, 1)

  b1 = select_backend(lb_rr, "client1")
  b2 = select_backend(lb_rr, "client2")

  assert b1 != null
  assert b2 != null

  println("Backend 1: " + to_string(b1.node_id))
  println("Backend 2: " + to_string(b2.node_id))

  println()
  println("Testing Weighted strategy")

  lb_w = init_load_balancer("weighted")
  lb_w = add_backend(lb_w, 0, "localhost", 9000, 3)
  lb_w = add_backend(lb_w, 1, "localhost", 9100, 1)

  b = select_backend(lb_w, "client1")
  assert b != null

  println("Selected backend: " + to_string(b.node_id))

  println()
  println("✅ Scenario 5 passed")
}

/// 시나리오 6: 완전한 요청 처리 파이프라인
fn test_scenario_full_pipeline(system: ProxySystem, current_time: int) {
  println()
  println("📋 Scenario 6: Full Request Pipeline")
  println("═════════════════════════════════════")

  println()
  println("Pipeline: Auth → RateLimit → Route → LB → CB → Metrics")

  // 1. 토큰 생성
  token = generate_token("user3", UserRole.User, system.auth, current_time)
  system.token_store[token.token_id] = token

  // 2. 요청 헤더
  request_headers = { "Authorization": token.token_id }

  // 3. 인증
  auth_result = authenticate_request(request_headers,
                                     system.token_store,
                                     current_time)
  println("✓ Auth: " + (auth_result.is_valid ? "OK" : "FAIL"))

  // 4. 라우팅
  backend_id = select_route(system.router, "/api/transfer", request_headers)
  println("✓ Route: Backend " + to_string(backend_id))

  // 5. 로드 밸런싱
  selected = select_backend(system.load_balancer, "client_ip")
  println("✓ Load Balancer: Backend " + to_string(selected.node_id))

  // 6. Circuit Breaker
  is_allowed = is_request_allowed(system.circuit_breaker, current_time)
  println("✓ Circuit Breaker: " + (is_allowed ? "CLOSED" : "OPEN"))

  // 7. 메트릭
  system.metrics = record_request(system.metrics, true, 100, false)
  println("✓ Metrics: recorded")

  println()
  println("✅ Scenario 6 passed - Full pipeline working!")
}

