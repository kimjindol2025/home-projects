/// 성능 테스트
fn test_performance(system: ProxySystem) {
  println()
  println("⚡ Performance Test")
  println("═══════════════════════════════════")

  request_count = 100
  successful = 0
  failed = 0

  for i = 0; i < request_count; i = i + 1 {
    is_success = random(0, 99) < 95  // 95% success rate

    if is_success {
      successful = successful + 1
    } else {
      failed = failed + 1
    }
  }

  println()
  println("Results:")
  println("├─ Total requests: " + to_string(request_count))
  println("├─ Successful: " + to_string(successful))
  println("├─ Failed: " + to_string(failed))
  println("└─ Success rate: " + to_string((successful * 100) / request_count) + "%")
}

