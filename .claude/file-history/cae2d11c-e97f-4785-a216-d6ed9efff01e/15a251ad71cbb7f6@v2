  // 2개 노드만 도달 가능 (5-node cluster에서 불충분)
  reachable = [1, 2]

  partition = detect_network_partition(node, reachable)

  // 5-node cluster: 3개 이상 필요한데 3개만 있으므로 분할
  assert partition != null

  println("✅ test_detect_network_partition passed")
}

fn test_exponential_backoff() {
  delay0 = exponential_backoff(0, 5000)
  delay1 = exponential_backoff(1, 5000)
  delay2 = exponential_backoff(2, 5000)

  // 각 시도마다 백오프 증가
  assert delay1 > delay0
  assert delay2 > delay1

  println("✅ test_exponential_backoff passed")
}

