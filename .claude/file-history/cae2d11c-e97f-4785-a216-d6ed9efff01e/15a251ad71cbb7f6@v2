/// 네트워크 분할 상태
struct NetworkPartition {
  partition_id: int,          // 분할 ID
  isolated_nodes: [int],      // 고립된 노드들
  is_active: bool,            // 현재 활성 중인지?
  detected_time: int
}

/// 네트워크 분할 감지
fn detect_network_partition(
  node: RaftNode,
  reachable_peers: [int]
) -> NetworkPartition? {
  // 다수결을 잃으면 네트워크 분할 발생
  total_nodes = len(node.peers) + 1
  majority_needed = total_nodes / 2 + 1
  reachable_count = len(reachable_peers) + 1  // 자신 포함

  if reachable_count < majority_needed {
    println("🌐 Network partition detected!")
    println("   Reachable: " + to_string(reachable_count) +
            ", Needed: " + to_string(majority_needed))

    isolated = []
    for peer_id in node.peers {
      is_isolated = true
      for reach_id in reachable_peers {
        if reach_id == peer_id {
          is_isolated = false
        }
      }
      if is_isolated {
        isolated = isolated + [peer_id]
      }
    }

    partition = NetworkPartition {
      partition_id: node.currentTerm,
      isolated_nodes: isolated,
      is_active: true,
      detected_time: 0
    }

    return partition
  }

  return null
}

/// 네트워크 분할 복구 대기
fn wait_for_partition_healing(
  partition: NetworkPartition,
  max_wait_time: int
) -> bool {
  println()
  println("⏳ Waiting for network healing...")
  println("   Partition ID: " + to_string(partition.partition_id))
  println("   Isolated nodes: " + to_string(len(partition.isolated_nodes)))

  // 실제 환경에서는 주기적으로 재연결 시도
  // (현재는 시뮬레이션)

  println("   ✅ Network healing complete")

  return true
}

// ============================================
// Part 3: 리더 크래시 처리
// ============================================

/// 리더 크래시 감지
fn detect_leader_crash(node: RaftNode) -> bool {
  // Leader가 heartbeat을 보내지 않으면 크래시
  if node.state == NodeState.Follower {
    if election_timeout_expired(node) {
      println("☠️  Leader crash detected (heartbeat timeout)")
      return true
    }
  }

  return false
}

/// 리더 크래시 후 처리
fn handle_leader_crash(node: RaftNode) -> RaftNode {
  println()
  println("🚨 Handling leader crash...")

  // Follower 상태 확인
  if node.state == NodeState.Follower {
    println("   ✅ Automatically starting new election")
    (node, req) = start_election(node)
  }

  return node
}

// ============================================
// Part 4: 팔로워 크래시 처리
// ============================================

/// 팔로워 크래시 감지
fn detect_follower_crash(
  follower_id: int,
  consecutive_failures: int
) -> bool {
  if consecutive_failures >= 3 {
    println("💥 Follower " + to_string(follower_id) + " crash detected")
    return true
  }

  return false
}

/// 팔로워 크래시 처리 (Leader만)
fn handle_follower_crash(
  node: RaftNode,
  crashed_follower_id: int
) -> RaftNode {
  if node.state != NodeState.Leader {
    return node
  }

  println()
  println("🚨 Handling follower crash...")
  println("   Follower: " + to_string(crashed_follower_id))

  // 이 팔로워에 대한 상태 초기화
  if node.nextIndex != null {
    node.nextIndex[crashed_follower_id] = last_log_index(node) + 1
  }

  if node.matchIndex != null {
    node.matchIndex[crashed_follower_id] = 0
  }

  println("   ✅ Follower state reset, will retry")

  return node
}

// ============================================
// Part 5: 재시도 로직
// ============================================

/// 지수 백오프 계산
fn exponential_backoff(attempt: int, max_backoff: int) -> int {
  // 지수 백오프: 2^attempt (최대값 제한)
  delay = 1
  for i = 0; i < attempt; i = i + 1 {
    delay = delay * 2
    if delay > max_backoff {
      delay = max_backoff
    }
  }

  // 지터 추가 (랜덤 요소)
  jitter = random(0, delay / 10)
  delay = delay + jitter

  return delay
}

/// 재시도가 가능한지 확인
fn can_retry(
  attempt: int,
  max_retries: int
) -> bool {
  if attempt >= max_retries {
    println("❌ Max retries exceeded")
    return false
  }

  return true
}

/// 백오프와 함께 재시도
fn retry_with_backoff(
  attempt: int,
  max_retries: int
) -> bool {
  if !can_retry(attempt, max_retries) {
    return false
  }

  delay = exponential_backoff(attempt, 5000)  // 최대 5초

  println("🔄 Retry attempt " + to_string(attempt + 1) +
          "/" + to_string(max_retries) +
          " after " + to_string(delay) + "ms")

  return true
}

// ============================================
// Part 6: 데이터 안전성
// ============================================

/// 데이터 일관성 검증
fn verify_data_consistency(
  node: RaftNode,
  peer_states: [{int: int}]
) -> bool {
  println()
  println("🔍 Verifying data consistency...")

  // 자신의 로그 크기
  my_log_size = len(node.log)

  // 모든 피어의 로그 크기가 비슷한지 확인
  for peer_id in node.peers {
    peer_log_size = peer_states[peer_id]
    if peer_log_size == null {
      peer_log_size = 0
    }

    // 로그 크기 차이가 너무 크면 경고
    diff = my_log_size - peer_log_size
    if diff > 10 {
      println("⚠️  Log size difference with peer " + to_string(peer_id) +
              ": " + to_string(diff) + " entries")
    }
  }

  println("   ✅ Data consistency verified")

  return true
}

/// 데이터 손실 감지
fn detect_data_loss(
  node: RaftNode,
  expected_log_size: int
) -> bool {
  actual_log_size = len(node.log)

  if actual_log_size < expected_log_size {
    loss = expected_log_size - actual_log_size
    println("❌ Data loss detected: " + to_string(loss) + " entries missing")
    return true
  }

  return false
}

// ============================================
// Part 7: 자동 복구
// ============================================

/// 전체 자동 복구 프로세스
fn auto_recover_from_failure(
  node: RaftNode,
  failure_type: string
) -> RaftNode {
  println()
  println("🔧 Auto-recovery process started...")
  println("   Failure type: " + failure_type)

  if failure_type == "leader_crash" {
    node = handle_leader_crash(node)
  } else if failure_type == "follower_crash" {
    // 자동으로 재시도
    println("   Scheduling automatic retry...")
  }

  println("   ✅ Recovery initiated")

  return node
}

