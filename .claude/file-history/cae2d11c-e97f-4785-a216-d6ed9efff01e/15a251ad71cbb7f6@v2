  for i = 0; i < 5; i = i + 1 {
    node = append_log(node, "cmd" + to_string(i))
  }

  peer_states = {}
  peer_states[1] = len(node.log)
  peer_states[2] = len(node.log)

  consistent = verify_data_consistency(node, peer_states)
  assert consistent == true

  println("✅ test_verify_data_consistency passed")
