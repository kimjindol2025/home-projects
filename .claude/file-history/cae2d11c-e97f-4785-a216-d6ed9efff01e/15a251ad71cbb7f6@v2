/// 노드 상태 헬스체크 결과
struct NodeHealthStatus {
  node_id: int,
  is_alive: bool,
  last_heartbeat: int,
  response_time: int,
  consecutive_failures: int
}

/// 노드 응답 가능 여부 확인
fn is_node_responsive(
  node_id: int,
  last_heartbeat_time: int,
  heartbeat_timeout: int
) -> bool {
  // 현재 시간과 마지막 하트비트 비교
  // 현재는 시뮬레이션이므로 간단한 로직

  time_since_heartbeat = 0  // time.now() - last_heartbeat_time

  if time_since_heartbeat > heartbeat_timeout {
    return false
  }

  return true
}

/// 노드 헬스체크
fn health_check_node(
  node_id: int,
  last_heartbeat_time: int,
  consecutive_failures: int
) -> NodeHealthStatus {
  heartbeat_timeout = 300  // 300ms 타임아웃

  is_alive = is_node_responsive(node_id, last_heartbeat_time, heartbeat_timeout)

  response_time = 50  // 평균 응답 시간 (ms)

  return NodeHealthStatus {
    node_id: node_id,
    is_alive: is_alive,
    last_heartbeat: last_heartbeat_time,
    response_time: response_time,
    consecutive_failures: consecutive_failures
  }
}

/// 노드 크래시 감지
fn detect_node_crash(status: NodeHealthStatus) -> bool {
  // 연속 실패가 3회 이상이면 크래시로 판정
  if status.consecutive_failures >= 3 {
    println("💥 Node " + to_string(status.node_id) + " crash detected")
    return true
  }

  return false
}

