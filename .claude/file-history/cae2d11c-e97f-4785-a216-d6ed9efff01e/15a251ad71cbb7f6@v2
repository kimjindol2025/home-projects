fn test_detect_data_loss() {
  peers = [1, 2]
  node = create_raft_node(0, peers)

  for i = 0; i < 10; i = i + 1 {
    node = append_log(node, "cmd" + to_string(i))
  }

  // 데이터 손실 없음
  loss = detect_data_loss(node, len(node.log))
  assert loss == false

  // 손실 시뮬레이션
  loss = detect_data_loss(node, 15)
  assert loss == true

  println("✅ test_detect_data_loss passed")
}

fn test_auto_recover_from_failure() {
