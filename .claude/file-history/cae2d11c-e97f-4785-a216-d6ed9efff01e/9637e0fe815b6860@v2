apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ include "distributed-bank.fullname" . }}-config
  namespace: {{ .Values.namespace.name }}
  labels:
    {{- include "distributed-bank.labels" . | nindent 4 }}
data:
  # 로그 설정
  RUST_LOG: {{ .Values.configMap.rustLog }}

  # TLS 설정
  TLS_ENABLED: {{ .Values.configMap.tlsEnabled | quote }}
  TLS_CERT_PATH: {{ .Values.configMap.tlsCertPath }}
  TLS_KEY_PATH: {{ .Values.configMap.tlsKeyPath }}

  # 암호화 설정
  ENCRYPTION_ENABLED: {{ .Values.configMap.encryptionEnabled | quote }}

  # 데이터베이스 설정
  DB_PATH: {{ .Values.configMap.dbPath }}
  DB_MAX_CONNECTIONS: {{ .Values.configMap.dbMaxConnections | quote }}

  # Raft 설정
  RAFT_NODE_ID: {{ .Values.configMap.raftNodeId | quote }}
  RAFT_PEERS: {{ .Values.configMap.raftPeers }}
  RAFT_SNAPSHOT_INTERVAL: {{ .Values.configMap.raftSnapshotInterval | quote }}
  RAFT_ELECTION_TIMEOUT: {{ .Values.configMap.raftElectionTimeout | quote }}
  RAFT_HEARTBEAT_INTERVAL: {{ .Values.configMap.raftHeartbeatInterval | quote }}

  # 헬스체크 스크립트
  health-check.sh: |
    #!/bin/bash
    # Pod 헬스 체크 스크립트
    set -e

    # HTTP 헬스체크
    HEALTH_STATUS=$(curl -s -o /dev/null -w "%{http_code}" http://localhost:{{ .Values.service.internal.ports.http }}/health || echo "000")

    if [ "$HEALTH_STATUS" != "200" ]; then
      echo "❌ Health check failed: HTTP $HEALTH_STATUS"
      exit 1
    fi

    echo "✅ Health check passed"
    exit 0

  # 준비 상태 체크 스크립트
  ready-check.sh: |
    #!/bin/bash
    # Pod 준비 상태 체크 스크립트
    set -e

    # HTTP 준비 상태 확인
    READY_STATUS=$(curl -s -o /dev/null -w "%{http_code}" http://localhost:{{ .Values.service.internal.ports.http }}/ready || echo "000")

    if [ "$READY_STATUS" != "200" ]; then
      echo "⏳ Pod not ready: HTTP $READY_STATUS"
      exit 1
    fi

    echo "✅ Pod is ready"
    exit 0
