// ============================================
// Part 5: 통합 저장소 인터페이스
// ============================================

/// 저장소 상태
struct StorageState {
  node_id: int,
  currentTerm: int,
  votedFor: int?,
  last_log_index: int,
  last_log_term: int,
  last_snapshot_index: int,
  snapshot_available: bool
}

/// 노드를 디스크에서 복구
fn recover_node_from_disk(node_id: int) -> RaftNode {
  println()
  println("🔄 Recovering node " + to_string(node_id) + " from disk")

  // 1. 메타데이터 로드
  metadata = load_metadata(node_id)
  if metadata != null {
    println("   ✅ Loaded metadata: term=" + to_string(metadata.currentTerm) +
            ", votedFor=" + to_string(metadata.votedFor))
  } else {
    println("   ℹ️  No metadata found (new node)")
  }

  // 2. WAL 로드
  entries = load_wal_entries(node_id)
  println("   ✅ Loaded " + to_string(len(entries)) + " log entries")

  // 3. 스냅샷 로드 (선택사항)
  snapshot = load_snapshot(node_id)
  if snapshot != null {
    println("   ✅ Loaded snapshot: lastIncludedIndex=" +
            to_string(snapshot.lastIncludedIndex))
  }

  // 4. RaftNode 생성
  peers = [1, 2, 3]  // 예: 3-node cluster
  node = create_raft_node(node_id, peers)

  // 5. 복구된 상태 적용
  if metadata != null {
    node.currentTerm = metadata.currentTerm
    node.votedFor = metadata.votedFor
  }

  node.log = entries

  println("   ✅ Recovery complete")
  println()

  return node
}

/// 노드의 현재 상태를 저장
fn save_node_state(node: RaftNode) -> bool {
  println()
  println("💿 Saving node " + to_string(node.id) + " state")

  // 1. 메타데이터 저장
  success = save_metadata(node.id, node.currentTerm, node.votedFor)
  if !success {
    println("   ❌ Failed to save metadata")
    return false
  }

  // 2. WAL 저장 (로그 파일에 모든 항목 기록)
  success = append_wal_entries(node.id, node.log)
  if !success {
    println("   ❌ Failed to save WAL")
    return false
  }

  println("   ✅ State saved successfully")
  println()

  return true
}

// ============================================
// Part 6: 저장소 통계
// ============================================

/// 저장소 상태 조회
fn get_storage_stats(node_id: int) -> StorageState {
  metadata = load_metadata(node_id)
  entries = load_wal_entries(node_id)
  snapshot = load_snapshot(node_id)

  term = 0
  voted_for = null
  if metadata != null {
    term = metadata.currentTerm
    voted_for = metadata.votedFor
  }

  last_index = len(entries)
  last_term = 0
  if last_index > 0 {
    last_term = entries[last_index - 1].term
  }

  snapshot_index = 0
  snapshot_avail = false
  if snapshot != null {
    snapshot_index = snapshot.lastIncludedIndex
    snapshot_avail = true
  }

  return StorageState {
    node_id: node_id,
    currentTerm: term,
    votedFor: voted_for,
    last_log_index: last_index,
    last_log_term: last_term,
    last_snapshot_index: snapshot_index,
    snapshot_available: snapshot_avail
  }
}

/// 저장소 통계 출력
fn print_storage_stats(stats: StorageState) {
  println()
  println("📊 Storage Stats for Node " + to_string(stats.node_id))
  println("├─ Current Term: " + to_string(stats.currentTerm))
  println("├─ Voted For: " + to_string(stats.votedFor))
  println("├─ Last Log Index: " + to_string(stats.last_log_index))
  println("├─ Last Log Term: " + to_string(stats.last_log_term))
  if stats.snapshot_available {
    println("├─ Last Snapshot Index: " + to_string(stats.last_snapshot_index))
    println("└─ Snapshot Available: ✅")
  } else {
    println("└─ Snapshot Available: ❌")
  }
}

