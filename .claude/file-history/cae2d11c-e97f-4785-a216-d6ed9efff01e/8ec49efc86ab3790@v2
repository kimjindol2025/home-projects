/// WAL 항목: 디스크에 저장되는 로그 엔트리
struct WalEntry {
  index: int,           // 로그 인덱스
  term: int,            // Term
  command: string,      // 명령
  timestamp: int        // 저장 시간 (추적용)
}

/// WAL 항목을 JSON으로 변환
fn wal_entry_to_json(entry: WalEntry) -> string {
  return json({
    index: entry.index,
    term: entry.term,
    command: entry.command,
    timestamp: entry.timestamp
  })
}

/// 로그 엔트리를 WAL로 저장 (Append-Only)
fn append_wal_entry(node_id: int, entry: LogEntry) -> bool {
  wal_file = get_log_file(node_id)

  wal_entry = WalEntry {
    index: entry.index,
    term: entry.term,
    command: entry.command,
    timestamp: 0  // time.now() 사용 가능
  }

  json_str = wal_entry_to_json(wal_entry)

  println("📝 Appending log entry to WAL: " + wal_file)
  println("   index=" + to_string(entry.index) +
          ", term=" + to_string(entry.term) +
          ", command=" + entry.command)

  // 실제 구현:
  // file = File.open(wal_file, "append")
  // file.write(json_str + "\n")
  // file.close()

  return true
}

/// 여러 로그 엔트리를 한번에 저장
fn append_wal_entries(node_id: int, entries: [LogEntry]) -> bool {
  for entry in entries {
    success = append_wal_entry(node_id, entry)
    if !success {
      return false
    }
  }

  return true
}

