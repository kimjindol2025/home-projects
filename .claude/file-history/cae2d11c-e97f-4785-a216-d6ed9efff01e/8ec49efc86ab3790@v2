/// 저장소 디렉토리 경로
fn get_storage_dir(node_id: int) -> string {
  return "./raft_storage_" + to_string(node_id)
}

/// 로그 파일 경로
fn get_log_file(node_id: int) -> string {
  return get_storage_dir(node_id) + "/log.wal"
}

/// 메타데이터 파일 경로
fn get_metadata_file(node_id: int) -> string {
  return get_storage_dir(node_id) + "/metadata.json"
}

/// 스냅샷 파일 경로
