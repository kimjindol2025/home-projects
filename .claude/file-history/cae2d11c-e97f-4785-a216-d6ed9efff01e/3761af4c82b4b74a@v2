---
# 내부 클러스터 서비스
apiVersion: v1
kind: Service
metadata:
  name: {{ include "distributed-bank.fullname" . }}
  namespace: {{ .Values.namespace.name }}
  labels:
    {{- include "distributed-bank.labels" . | nindent 4 }}
    component: service-internal
spec:
  type: {{ .Values.service.internal.type }}
  selector:
    {{- include "distributed-bank.selectorLabels" . | nindent 4 }}
  ports:
  - name: http
    port: {{ .Values.service.internal.ports.http }}
    targetPort: http
    protocol: TCP
  - name: raft
    port: {{ .Values.service.internal.ports.raft }}
    targetPort: raft
    protocol: TCP
  sessionAffinity: None

---
# 외부 로드 밸런서 서비스
apiVersion: v1
kind: Service
metadata:
  name: {{ include "distributed-bank.fullname" . }}-lb
  namespace: {{ .Values.namespace.name }}
  labels:
    {{- include "distributed-bank.labels" . | nindent 4 }}
    component: service-external
  {{- if eq .Values.service.external.type "LoadBalancer" }}
  annotations:
    service.beta.kubernetes.io/aws-load-balancer-type: "nlb"
  {{- end }}
spec:
  type: {{ .Values.service.external.type }}
  selector:
    {{- include "distributed-bank.selectorLabels" . | nindent 4 }}
  ports:
  - name: http
    port: {{ .Values.service.external.ports.http }}
    targetPort: http
    protocol: TCP
  - name: https
    port: {{ .Values.service.external.ports.https }}
    targetPort: http
    protocol: TCP
  {{- if .Values.service.external.sessionAffinity.enabled }}
  sessionAffinity: ClientIP
  sessionAffinityConfig:
    clientIP:
      timeoutSeconds: {{ .Values.service.external.sessionAffinity.timeoutSeconds }}
  {{- end }}

---
# Raft 클러스터용 헤드리스 서비스
apiVersion: v1
kind: Service
metadata:
  name: {{ include "distributed-bank.fullname" . }}-raft
  namespace: {{ .Values.namespace.name }}
  labels:
    {{- include "distributed-bank.labels" . | nindent 4 }}
    component: service-raft
spec:
  type: {{ .Values.service.raft.type }}
  {{- if .Values.service.raft.headless }}
  clusterIP: None  # 헤드리스 서비스
  {{- end }}
  selector:
    {{- include "distributed-bank.selectorLabels" . | nindent 4 }}
  ports:
  - name: raft
    port: {{ .Values.service.raft.port }}
    targetPort: raft
    protocol: TCP
  publishNotReadyAddresses: true
