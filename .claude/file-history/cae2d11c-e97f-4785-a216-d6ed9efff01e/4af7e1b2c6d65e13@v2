/**
 * File I/O 시스템 테스트
 */

import { FileHandle, Directory, FileSystem, getFileSystemStats } from './file';
import * as fs from 'fs';
import * as path from 'path';

function runTests() {
  console.log('🧪 File I/O 테스트 시작\n');

  let passed = 0;
  let failed = 0;

  // 테스트 디렉토리 생성
  const testDir = './test_output';
  if (!fs.existsSync(testDir)) {
    fs.mkdirSync(testDir, { recursive: true });
  }

  // Test 1: 파일 쓰기 및 읽기
  console.log('Test 1: 파일 쓰기 및 읽기');
  try {
    const file = new FileHandle(path.join(testDir, 'test1.txt'), 'w');
    if (file.open()) {
      const testData = 'Hello, FreeLang!';
      if (file.write(testData)) {
        file.close();

        // 읽기로 다시 열기
        const file2 = new FileHandle(path.join(testDir, 'test1.txt'), 'r');
        if (file2.open()) {
          const content = file2.read();
          if (content === testData) {
            console.log('  ✅ 통과\n');
            passed++;
          } else {
            console.log(`  ❌ 실패\n`);
            failed++;
          }
          file2.close();
        } else {
          console.log('  ❌ 실패\n');
          failed++;
        }
      } else {
        console.log('  ❌ 실패\n');
        failed++;
      }
    } else {
      console.log('  ❌ 실패\n');
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 2: 파일 추가 쓰기 (append)
  console.log('Test 2: 파일 추가 쓰기');
  try {
    const file = new FileHandle(path.join(testDir, 'test2.txt'), 'a');
    if (file.open()) {
      file.write('First line\n');
      file.append('Second line\n');
      file.append('Third line');
      file.close();

      const file2 = new FileHandle(path.join(testDir, 'test2.txt'), 'r');
      if (file2.open()) {
        const content = file2.read();
        const expected = 'First line\nSecond line\nThird line';
        if (content === expected) {
          console.log('  ✅ 통과\n');
          passed++;
        } else {
          console.log(`  ❌ 실패\n`);
          failed++;
        }
        file2.close();
      } else {
        console.log('  ❌ 실패\n');
        failed++;
      }
    } else {
      console.log('  ❌ 실패\n');
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 3: 라인 단위 읽기
  console.log('Test 3: 라인 단위 읽기');
  try {
    const file = new FileHandle(path.join(testDir, 'test3.txt'), 'w');
    if (file.open()) {
      file.write('line1\nline2\nline3');
      file.close();

      const file2 = new FileHandle(path.join(testDir, 'test3.txt'), 'r');
      if (file2.open()) {
        const lines = file2.readLines();
        if (lines.length === 3 && lines[0] === 'line1' && lines[2] === 'line3') {
          console.log('  ✅ 통과\n');
          passed++;
        } else {
          console.log(`  ❌ 실패\n`);
          failed++;
        }
        file2.close();
      } else {
        console.log('  ❌ 실패\n');
        failed++;
      }
    } else {
      console.log('  ❌ 실패\n');
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 4: 파일 정보 조회
  console.log('Test 4: 파일 정보 조회');
  try {
    const file = new FileHandle(path.join(testDir, 'test4.txt'), 'w');
    if (file.open()) {
      const data = 'test content';
      file.write(data);
      file.close();

      const file2 = new FileHandle(path.join(testDir, 'test4.txt'), 'r');
      file2.open();
      const stats = file2.stats();
      if (stats && stats.size === data.length && stats.isFile) {
        console.log('  ✅ 통과\n');
        passed++;
      } else {
        console.log(`  ❌ 실패\n`);
        failed++;
      }
      file2.close();
    } else {
      console.log('  ❌ 실패\n');
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 5: 파일 삭제
  console.log('Test 5: 파일 삭제');
  try {
    const testFile = path.join(testDir, 'test5.txt');
    const file = new FileHandle(testFile, 'w');
    if (file.open()) {
      file.write('delete me');
      file.close();

      if (file.delete() && !fs.existsSync(testFile)) {
        console.log('  ✅ 통과\n');
        passed++;
      } else {
        console.log('  ❌ 실패\n');
        failed++;
      }
    } else {
      console.log('  ❌ 실패\n');
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 6: 파일 크기 및 라인 수
  console.log('Test 6: 파일 크기 및 라인 수');
  try {
    const file = new FileHandle(path.join(testDir, 'test6.txt'), 'w');
    if (file.open()) {
      file.write('line1\nline2\nline3');
      file.close();

      const file2 = new FileHandle(path.join(testDir, 'test6.txt'), 'r');
      file2.open();
      const size = file2.size();
      const lines = file2.lineCount();

      // 파일 크기는 시스템마다 다를 수 있으므로, 라인 수만 확인
      if (size > 0 && lines === 3) {
        console.log('  ✅ 통과\n');
        passed++;
      } else {
        console.log(`  ❌ 실패\n`);
        failed++;
      }
      file2.close();
    } else {
      console.log('  ❌ 실패\n');
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 7: 파일 존재 여부
  console.log('Test 7: 파일 존재 여부');
  try {
    const testFile = path.join(testDir, 'test7.txt');
    const file = new FileHandle(testFile, 'w');

    if (file.open()) {
      file.write('test');
      file.close();

      if (file.exists()) {
        console.log('  ✅ 통과\n');
        passed++;
      } else {
        console.log('  ❌ 실패\n');
        failed++;
      }
      file.delete();
    } else {
      console.log('  ❌ 실패\n');
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 8: 디렉토리 생성 및 삭제
  console.log('Test 8: 디렉토리 생성 및 삭제');
  try {
    const testSubDir = path.join(testDir, 'subdir');
    const dir = new Directory(testSubDir);

    if (dir.create() && dir.exists()) {
      if (dir.delete() && !fs.existsSync(testSubDir)) {
        console.log('  ✅ 통과\n');
        passed++;
      } else {
        console.log('  ❌ 실패\n');
        failed++;
      }
    } else {
      console.log('  ❌ 실패\n');
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 9: 디렉토리 파일 목록
  console.log('Test 9: 디렉토리 파일 목록');
  try {
    const testSubDir = path.join(testDir, 'filelist_test');
    const dir = new Directory(testSubDir);

    if (dir.create()) {
      fs.writeFileSync(path.join(testSubDir, 'file1.txt'), 'content1');
      fs.writeFileSync(path.join(testSubDir, 'file2.txt'), 'content2');
      fs.mkdirSync(path.join(testSubDir, 'subdir1'));

      const files = dir.listFiles();
      const items = dir.list();

      if (files.length === 2 && items.length === 3) {
        console.log('  ✅ 통과\n');
        passed++;
      } else {
        console.log(`  ❌ 실패\n`);
        failed++;
      }

      dir.delete();
    } else {
      console.log('  ❌ 실패\n');
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 10: 파일 시스템 유틸리티
  console.log('Test 10: 파일 시스템 유틸리티');
  try {
    const testFile = path.join(testDir, 'test10.txt');
    fs.writeFileSync(testFile, 'test content');

    const exists = FileSystem.exists(testFile);
    const isFile = FileSystem.isFile(testFile);
    const size = FileSystem.size(testFile);
    const ext = FileSystem.extension(testFile);

    if (exists && isFile && size === 12 && ext === '.txt') {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log(`  ❌ 실패\n`);
      failed++;
    }

    fs.unlinkSync(testFile);
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 11: 파일 복사
  console.log('Test 11: 파일 복사');
  try {
    const src = path.join(testDir, 'test11_src.txt');
    const dst = path.join(testDir, 'test11_dst.txt');

    fs.writeFileSync(src, 'source content');

    if (FileSystem.copy(src, dst)) {
      const srcContent = fs.readFileSync(src, { encoding: 'utf-8' });
      const dstContent = fs.readFileSync(dst, { encoding: 'utf-8' });

      if (srcContent === dstContent) {
        console.log('  ✅ 통과\n');
        passed++;
      } else {
        console.log('  ❌ 실패\n');
        failed++;
      }
      fs.unlinkSync(src);
      fs.unlinkSync(dst);
    } else {
      console.log('  ❌ 실패\n');
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 12: 파일 이동
  console.log('Test 12: 파일 이동');
  try {
    const src = path.join(testDir, 'test12_src.txt');
    const dst = path.join(testDir, 'test12_dst.txt');

    fs.writeFileSync(src, 'move me');

    if (FileSystem.move(src, dst) && !fs.existsSync(src) && fs.existsSync(dst)) {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log('  ❌ 실패\n');
      failed++;
    }

    if (fs.existsSync(dst)) {
      fs.unlinkSync(dst);
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // 최종 결과
  console.log('='.repeat(40));
  console.log(`✅ 통과: ${passed}개`);
  console.log(`❌ 실패: ${failed}개`);
  console.log(`📊 성공률: ${((passed / (passed + failed)) * 100).toFixed(1)}%`);
  console.log('='.repeat(40));

  // 테스트 디렉토리 정리
  if (fs.existsSync(testDir)) {
    fs.rmSync(testDir, { recursive: true, force: true });
  }

  // 파일 시스템 통계 출력
  console.log('\n📊 파일 시스템 통계:');
  const stats = getFileSystemStats();
  console.log(`  버전: ${stats.version}`);
  console.log(`  기능: ${stats.features.length}가지`);
  stats.features.forEach(f => console.log(`    - ${f}`));
}

// 실행
if (require.main === module) {
  runTests();
}

export { runTests };
