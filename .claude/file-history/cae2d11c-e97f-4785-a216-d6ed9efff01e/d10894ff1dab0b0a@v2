---
# Service: 로드 밸런싱 (내부)
apiVersion: v1
kind: Service
metadata:
  name: distributed-bank
  namespace: distributed-bank
  labels:
    app: distributed-bank
  annotations:
    description: "분산 은행 시스템 서비스"

spec:
  type: ClusterIP
  selector:
    app: distributed-bank

  ports:
  - name: http
    port: 8080
    targetPort: 8080
    protocol: TCP
  - name: raft
    port: 9000
    targetPort: 9000
    protocol: TCP

  sessionAffinity: None

---
# Service: 로드 밸런싱 (외부)
apiVersion: v1
kind: Service
metadata:
  name: distributed-bank-lb
  namespace: distributed-bank
  labels:
    app: distributed-bank
  annotations:
    service.beta.kubernetes.io/aws-load-balancer-type: "nlb"

spec:
  type: LoadBalancer
  selector:
    app: distributed-bank

  ports:
  - name: http
    port: 80
    targetPort: 8080
    protocol: TCP
  - name: https
    port: 443
    targetPort: 8080
    protocol: TCP

  sessionAffinity: ClientIP
  sessionAffinityConfig:
    clientIP:
      timeoutSeconds: 3600

---
# Service: 헤드리스 서비스 (Raft 클러스터)
apiVersion: v1
kind: Service
metadata:
  name: distributed-bank-raft
  namespace: distributed-bank
  labels:
    app: distributed-bank

spec:
  type: ClusterIP
  clusterIP: None  # 헤드리스
  selector:
    app: distributed-bank

  ports:
  - name: raft
    port: 9000
    targetPort: 9000
    protocol: TCP

  publishNotReadyAddresses: true
