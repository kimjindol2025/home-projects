# min(a, b) - 최솟값
fn min(a: i32, b: i32): i32 {
  # 주석: a와 b 중 작은 값 반환
  # 예: min(3, 5) -> 3
  # 예: min(-2, 1) -> -2
  if a < b {
    return a
  } else {
    return b
  }
}

# minf(a, b) - 최솟값 (부동소수점)
fn minf(a: f64, b: f64): f64 {
  if a < b {
    return a
  } else {
    return b
  }
}

# max(a, b) - 최댓값
fn max(a: i32, b: i32): i32 {
  # 주석: a와 b 중 큰 값 반환
  # 예: max(3, 5) -> 5
  # 예: max(-2, 1) -> 1
  if a > b {
    return a
  } else {
    return b
  }
}

# maxf(a, b) - 최댓값 (부동소수점)
fn maxf(a: f64, b: f64): f64 {
  if a > b {
    return a
  } else {
    return b
  }
}

# clamp(x, min, max) - 범위 제한
fn clamp(x: i32, min: i32, max: i32): i32 {
  # 주석: x를 [min, max] 범위로 제한
  # 예: clamp(10, 0, 5) -> 5
  # 예: clamp(-1, 0, 5) -> 0
  # 예: clamp(3, 0, 5) -> 3
  if x < min {
    return min
  } else if x > max {
    return max
  } else {
    return x
  }
}

