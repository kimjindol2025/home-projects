# abs(x) - 절댓값
fn abs(x: i32): i32 {
  # 주석: 절댓값 반환
  # 예: abs(-5) -> 5
  # 예: abs(3) -> 3
  if x < 0 {
    return 0 - x
  } else {
    return x
  }
}

# absf(x) - 절댓값 (부동소수점)
fn absf(x: f64): f64 {
  # 주석: 부동소수점 절댓값
  if x < 0.0 {
    return 0.0 - x
  } else {
    return x
  }
}

# sign(x) - 부호 (-1, 0, 1)
fn sign(x: i32): i32 {
  # 주석: x의 부호 반환
  # 예: sign(-5) -> -1
  # 예: sign(0) -> 0
  # 예: sign(3) -> 1
  if x < 0 {
    return -1
  } else if x == 0 {
    return 0
  } else {
    return 1
  }
}

