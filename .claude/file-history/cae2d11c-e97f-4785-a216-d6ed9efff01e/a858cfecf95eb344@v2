# sum(arr) - 합계
fn sum(arr: [i32]): i32 {
  # 주석: 배열 모든 요소의 합
  # 예: sum([1, 2, 3, 4]) -> 10
  let result = 0

  let i = 0
  while i < len(arr) {
    result = result + arr[i]
    i = i + 1
  }

  return result
}

# avg(arr) - 평균
fn avg(arr: [i32]): i32 {
  # 주석: 배열 요소의 평균
  # 예: avg([1, 2, 3, 4]) -> 2 (정수 나눗셈)
  if isEmpty(arr) {
    return 0
  }

  let s = sum(arr)
  let len = length(arr)
  return s / len
}

# min_arr(arr) - 최솟값
fn min_arr(arr: [i32]): i32 {
  # 주석: 배열의 최솟값
  # 예: min_arr([3, 1, 4, 1, 5]) -> 1
  if isEmpty(arr) {
    return 0
  }

  let result = arr[0]

  let i = 1
  while i < length(arr) {
    result = min(result, arr[i])
    i = i + 1
  }

  return result
}

# max_arr(arr) - 최댓값
fn max_arr(arr: [i32]): i32 {
  # 주석: 배열의 최댓값
  # 예: max_arr([3, 1, 4, 1, 5]) -> 5
  if isEmpty(arr) {
    return 0
  }

  let result = arr[0]

  let i = 1
  while i < length(arr) {
    result = max(result, arr[i])
    i = i + 1
  }

  return result
}

