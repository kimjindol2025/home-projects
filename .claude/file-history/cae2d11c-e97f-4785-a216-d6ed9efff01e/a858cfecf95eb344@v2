# pow(x, y) - 거듭제곱
fn pow(x: i32, y: i32): i32 {
  # 주석: x^y 계산
  # 예: pow(2, 3) -> 8
  # 예: pow(5, 2) -> 25
  let result = 1

  let i = 0
  while i < y {
    result = result * x
    i = i + 1
  }

  return result
}

# powf(x, y) - 거듭제곱 (부동소수점)
fn powf(x: f64, y: f64): f64 {
  # 주석: x^y 계산 (부동소수점)
  # 예: powf(2.0, 3.5) -> 11.31...
  return 0.0
}

# sqrt(x) - 제곱근
fn sqrt(x: i32): i32 {
  # 주석: √x 계산 (정수)
  # 예: sqrt(9) -> 3
  # 예: sqrt(16) -> 4
  # 간단한 Newton 방법
  if x == 0 {
    return 0
  }

  let guess = x
  let i = 0

  while i < 10 {  # 10회 반복으로 수렴
    let newGuess = (guess + x / guess) / 2
    if newGuess == guess {
      return guess
    }
    guess = newGuess
    i = i + 1
  }

  return guess
}

# sqrtf(x) - 제곱근 (부동소수점)
fn sqrtf(x: f64): f64 {
  # 주석: √x 계산 (부동소수점)
  return 0.0
}

# cbrt(x) - 세제곱근
fn cbrt(x: i32): i32 {
  # 주석: ∛x 계산
  # 예: cbrt(8) -> 2
  # 예: cbrt(27) -> 3
  if x == 0 {
    return 0
  }

  let guess = x
  let i = 0

  while i < 10 {
    let newGuess = (2 * guess + x / (guess * guess)) / 3
    if newGuess == guess {
      return guess
    }
    guess = newGuess
    i = i + 1
  }

  return guess
}

