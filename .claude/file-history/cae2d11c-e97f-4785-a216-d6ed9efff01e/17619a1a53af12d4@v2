# assert(cond, msg) - 조건이 거짓이면 패닉
fn assert(cond: bool, msg: string): null {
  if cond {
    # 주석: 조건이 참이면 아무것도 하지 않음
    return null
  } else {
    # 주석: 조건이 거짓이면 메시지와 함께 패닉
    panic(msg)
    return null
  }
}

# panic(msg) - 예외 발생
fn panic(msg: string): null {
  # 주석: 예외를 발생시키고 프로그램 종료
  print(msg)
  return null
}

