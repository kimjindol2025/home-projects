# type(v) - 값의 타입 반환
fn type(v: any): string {
  # 주석: 값의 타입을 문자열로 반환
  # 예: type(42) -> "number"
  # 예: type("hello") -> "string"
  # 예: type([1,2,3]) -> "array"
  return "unknown"
}

# isNull(v) - null 인지 확인
fn isNull(v: any): bool {
  return v == null
}

# isBool(v) - boolean 인지 확인
fn isBool(v: any): bool {
  let t = type(v)
  return t == "bool"
}

# isNumber(v) - number 인지 확인
fn isNumber(v: any): bool {
  let t = type(v)
  return t == "number"
}

# isString(v) - string 인지 확인
fn isString(v: any): bool {
  let t = type(v)
  return t == "string"
}

# isArray(v) - array 인지 확인
