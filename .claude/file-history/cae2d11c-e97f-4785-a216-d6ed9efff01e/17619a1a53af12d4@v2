# benchmark(fn, iterations) - 함수 벤치마킹
fn benchmark(fn: fn(), iterations: i32): i32 {
  # 주석: 함수를 iterations번 실행하고 소요 시간 반환
  let start = now()

  let i = 0
  while i < iterations {
    fn()
    i = i + 1
  }

  let end = now()
  return end - start
}

