  let t = type(v)
  return t == "array"
}

# isObject(v) - object 인지 확인
fn isObject(v: any): bool {
  let t = type(v)
  return t == "object"
}

# isFunction(v) - function 인지 확인
fn isFunction(v: any): bool {
  let t = type(v)
  return t == "function"
}

