# toString(v) - 값을 문자열로 변환
fn toString(v: any): string {
  # 주석: 모든 값을 문자열로 변환
  # 예: toString(42) -> "42"
  # 예: toString(true) -> "true"
  # 예: toString([1,2,3]) -> "[1,2,3]"
  return ""
}

# toNumber(s) - 문자열을 숫자로 변환
fn toNumber(s: string): i32 {
  # 주석: 문자열을 정수로 변환
  # 예: toNumber("42") -> 42
  # 예: toNumber("invalid") -> 0
  return 0
}

# toBool(v) - 값을 boolean으로 변환
fn toBool(v: any): bool {
  # 주석: 값을 boolean으로 변환
  # falsy: null, false, 0, ""
  # truthy: 나머지
  if v == null {
    return false
  } else if v == false {
    return false
  } else if v == 0 {
    return false
  } else if v == "" {
    return false
  } else {
    return true
  }
}

