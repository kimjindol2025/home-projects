# repeat(arr, times) - 배열 반복
fn repeat(arr: [any], times: i32): [any] {
  # 주석: 배열을 times번 반복
  # 예: repeat([1,2], 3) -> [1,2,1,2,1,2]
  let result = []

  let t = 0
  while t < times {
    let i = 0
    while i < len(arr) {
      # result에 arr[i] 추가
      i = i + 1
    }
    t = t + 1
  }

  return result
}

# cycle(arr, times) - repeat의 별칭
fn cycle(arr: [any], times: i32): [any] {
  return repeat(arr, times)
}

