# flatMap(arr, fn) - 맵핑 후 평탄화
fn flatMap(arr: [any], fn: fn(any)->[any]): [any] {
  # 주석: 각 요소에 fn을 적용하고 결과를 평탄화
  # 예: flatMap([1,2,3], fn(x) -> [x, x*2]) -> [1,2,2,4,3,6]
  let result = []

  let i = 0
  while i < len(arr) {
    let mapped = fn(arr[i])
    # result에 mapped의 모든 요소 추가
    i = i + 1
  }

  return result
}

