# equals(arr1, arr2) - 배열 동등성
fn equals(arr1: [any], arr2: [any]): bool {
  # 주석: 두 배열이 동일한지 확인
  # 예: equals([1,2,3], [1,2,3]) -> true
  if len(arr1) != len(arr2) {
    return false
  }

  let i = 0
  while i < len(arr1) {
    if arr1[i] != arr2[i] {
      return false
    }
    i = i + 1
  }

  return true
}

# startsWith(arr, prefix) - 배열 시작 확인
fn startsWith(arr: [any], prefix: [any]): bool {
  # 주석: arr이 prefix로 시작하는지 확인
  # 예: startsWith([1,2,3,4], [1,2]) -> true
  if len(prefix) > len(arr) {
    return false
  }

  let i = 0
  while i < len(prefix) {
    if arr[i] != prefix[i] {
      return false
    }
    i = i + 1
  }

  return true
}

# endsWith(arr, suffix) - 배열 끝 확인
fn endsWith(arr: [any], suffix: [any]): bool {
  # 주석: arr이 suffix로 끝나는지 확인
  # 예: endsWith([1,2,3,4], [3,4]) -> true
  if len(suffix) > len(arr) {
    return false
  }

  let suffixStart = len(arr) - len(suffix)
  let i = 0

  while i < len(suffix) {
    if arr[suffixStart + i] != suffix[i] {
      return false
    }
    i = i + 1
  }

  return true
}

