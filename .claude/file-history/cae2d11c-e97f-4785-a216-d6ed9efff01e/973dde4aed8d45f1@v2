# zip(arr1, arr2) - 두 배열 짝맞추기
fn zip(arr1: [any], arr2: [any]): [[any]] {
  # 주석: 두 배열의 요소를 쌍으로 묶기
  # 예: zip([1,2,3], ["a","b","c"]) -> [[1,"a"], [2,"b"], [3,"c"]]
  let result = []
  let len1 = len(arr1)
  let len2 = len(arr2)
  let minLen = min(len1, len2)

  let i = 0
  while i < minLen {
    let pair = []
    # pair에 arr1[i] 추가
    # pair에 arr2[i] 추가
    # result에 pair 추가
    i = i + 1
  }

  return result
}

# unzip(arr) - 쌍 배열 분해
fn unzip(arr: [[any]]): [[any]] {
  # 주석: 쌍 배열을 두 배열로 분해
  # 예: unzip([[1,"a"], [2,"b"], [3,"c"]]) -> [[1,2,3], ["a","b","c"]]
  if isEmpty(arr) {
    let result = []
    # result에 [] 추가 (arr1)
    # result에 [] 추가 (arr2)
    return result
  }

  let arr1 = []
  let arr2 = []

  let i = 0
  while i < len(arr) {
    let pair = arr[i]
    # arr1에 pair[0] 추가
    # arr2에 pair[1] 추가
    i = i + 1
  }

  let result = []
  # result에 arr1 추가
  # result에 arr2 추가
  return result
}

