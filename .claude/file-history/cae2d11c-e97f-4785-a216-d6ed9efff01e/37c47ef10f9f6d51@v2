{{- if .Values.autoscaling.enabled }}
---
# Horizontal Pod Autoscaler (HPA) v2
apiVersion: autoscaling/v2
kind: HorizontalPodAutoscaler
metadata:
  name: {{ include "distributed-bank.fullname" . }}-hpa
  namespace: {{ .Values.namespace.name }}
  labels:
    {{- include "distributed-bank.labels" . | nindent 4 }}
    component: autoscaling
spec:
  scaleTargetRef:
    apiVersion: apps/v1
    kind: Deployment
    name: {{ include "distributed-bank.fullname" . }}

  minReplicas: {{ .Values.autoscaling.minReplicas }}
  maxReplicas: {{ .Values.autoscaling.maxReplicas }}

  metrics:
  {{- if .Values.autoscaling.metrics.cpu.enabled }}
  - type: Resource
    resource:
      name: cpu
      target:
        type: Utilization
        averageUtilization: {{ .Values.autoscaling.metrics.cpu.targetUtilization }}
  {{- end }}
  {{- if .Values.autoscaling.metrics.memory.enabled }}
  - type: Resource
    resource:
      name: memory
      target:
        type: Utilization
        averageUtilization: {{ .Values.autoscaling.metrics.memory.targetUtilization }}
  {{- end }}

  behavior:
    scaleUp:
      stabilizationWindowSeconds: {{ .Values.autoscaling.behavior.scaleUp.stabilizationWindowSeconds }}
      policies:
      {{- toYaml .Values.autoscaling.behavior.scaleUp.policies | nindent 6 }}
      selectPolicy: {{ .Values.autoscaling.behavior.scaleUp.selectPolicy }}

    scaleDown:
      stabilizationWindowSeconds: {{ .Values.autoscaling.behavior.scaleDown.stabilizationWindowSeconds }}
      policies:
      {{- toYaml .Values.autoscaling.behavior.scaleDown.policies | nindent 6 }}
      selectPolicy: {{ .Values.autoscaling.behavior.scaleDown.selectPolicy }}

---
# Pod Disruption Budget
{{- if .Values.podDisruptionBudget.enabled }}
apiVersion: policy/v1
kind: PodDisruptionBudget
metadata:
  name: {{ include "distributed-bank.fullname" . }}-pdb
  namespace: {{ .Values.namespace.name }}
  labels:
    {{- include "distributed-bank.labels" . | nindent 4 }}
    component: disruption-budget
spec:
  minAvailable: {{ .Values.podDisruptionBudget.minAvailable }}
  selector:
    matchLabels:
      {{- include "distributed-bank.selectorLabels" . | nindent 6 }}
{{- end }}
{{- end }}
