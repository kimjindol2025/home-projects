{{- if .Values.monitoring.enabled }}
---
# ServiceMonitor: Prometheus 모니터링
{{- if .Values.monitoring.serviceMonitor.enabled }}
apiVersion: monitoring.coreos.com/v1
kind: ServiceMonitor
metadata:
  name: {{ include "distributed-bank.fullname" . }}
  namespace: {{ .Values.namespace.name }}
  labels:
    {{- include "distributed-bank.labels" . | nindent 4 }}
    component: service-monitor
spec:
  selector:
    matchLabels:
      {{- include "distributed-bank.selectorLabels" . | nindent 6 }}

  endpoints:
  - port: metrics
    interval: {{ .Values.monitoring.serviceMonitor.interval }}
    path: {{ .Values.monitoring.serviceMonitor.path }}
{{- end }}

---
# PrometheusRule: 알람 규칙
{{- if .Values.monitoring.alerts.enabled }}
apiVersion: monitoring.coreos.com/v1
kind: PrometheusRule
metadata:
  name: {{ include "distributed-bank.fullname" . }}
  namespace: {{ .Values.namespace.name }}
  labels:
    {{- include "distributed-bank.labels" . | nindent 4 }}
    component: prometheus-rules
spec:
  groups:
  - name: distributed_bank.rules
    interval: 30s

    rules:

    # CPU 사용률 높음
    {{- if .Values.monitoring.alerts.rules.highCpuUsage }}
    - alert: HighCPUUsage
      expr: |
        rate(container_cpu_usage_seconds_total{pod=~"{{ include "distributed-bank.fullname" . }}-.*"}[5m]) > {{ .Values.monitoring.alerts.rules.highCpuUsage.threshold | default 80 }}/100
      for: {{ .Values.monitoring.alerts.rules.highCpuUsage.duration | default "5m" }}
      labels:
        severity: warning
        component: {{ .Chart.Name }}
      annotations:
        summary: "높은 CPU 사용률 감지"
        description: "Pod {{ $labels.pod }}의 CPU 사용률이 {{ .Values.monitoring.alerts.rules.highCpuUsage.threshold | default 80 }}%를 초과했습니다."
    {{- end }}

    # 메모리 사용률 높음
    {{- if .Values.monitoring.alerts.rules.highMemoryUsage }}
    - alert: HighMemoryUsage
      expr: |
        container_memory_usage_bytes{pod=~"{{ include "distributed-bank.fullname" . }}-.*"} /
        container_spec_memory_limit_bytes > {{ .Values.monitoring.alerts.rules.highMemoryUsage.threshold | default 85 }}/100
      for: {{ .Values.monitoring.alerts.rules.highMemoryUsage.duration | default "5m" }}
      labels:
        severity: warning
        component: {{ .Chart.Name }}
      annotations:
        summary: "높은 메모리 사용률 감지"
        description: "Pod {{ $labels.pod }}의 메모리 사용률이 {{ .Values.monitoring.alerts.rules.highMemoryUsage.threshold | default 85 }}%를 초과했습니다."
    {{- end }}

    # Pod 재시작 빈도
    {{- if .Values.monitoring.alerts.rules.highPodRestartRate }}
    - alert: HighPodRestartRate
      expr: |
        rate(kube_pod_container_status_restarts_total{pod=~"{{ include "distributed-bank.fullname" . }}-.*"}[{{ .Values.monitoring.alerts.rules.highPodRestartRate.duration | default "15m" }}]) > {{ .Values.monitoring.alerts.rules.highPodRestartRate.threshold | default 0.1 }}
      for: 5m
      labels:
        severity: critical
        component: {{ .Chart.Name }}
      annotations:
        summary: "높은 Pod 재시작 빈도"
        description: "Pod {{ $labels.pod }}이 자주 재시작되고 있습니다."
    {{- end }}

    # 요청 실패율
    {{- if .Values.monitoring.alerts.rules.highErrorRate }}
    - alert: HighErrorRate
      expr: |
        rate(http_request_duration_seconds_bucket{pod=~"{{ include "distributed-bank.fullname" . }}-.*",status=~"5.."}[5m]) > {{ .Values.monitoring.alerts.rules.highErrorRate.threshold | default 5 }}/100
      for: {{ .Values.monitoring.alerts.rules.highErrorRate.duration | default "5m" }}
      labels:
        severity: warning
        component: {{ .Chart.Name }}
      annotations:
        summary: "높은 요청 실패율"
        description: "5분 이내 실패율이 {{ .Values.monitoring.alerts.rules.highErrorRate.threshold | default 5 }}%를 초과했습니다."
    {{- end }}

    # 응답 시간 증가
    {{- if .Values.monitoring.alerts.rules.highResponseTime }}
    - alert: HighResponseTime
      expr: |
        histogram_quantile(0.99,
          rate(http_request_duration_seconds_bucket{pod=~"{{ include "distributed-bank.fullname" . }}-.*"}[5m])) > {{ .Values.monitoring.alerts.rules.highResponseTime.threshold | default 0.050 }}
      for: {{ .Values.monitoring.alerts.rules.highResponseTime.duration | default "5m" }}
      labels:
        severity: warning
        component: {{ .Chart.Name }}
      annotations:
        summary: "높은 응답 시간"
        description: "P99 응답 시간이 {{ .Values.monitoring.alerts.rules.highResponseTime.threshold | default 0.050 }}초를 초과했습니다."
    {{- end }}

    # Pod 준비 상태 실패
    {{- if .Values.monitoring.alerts.rules.podNotReady }}
    - alert: PodNotReady
      expr: |
        kube_pod_status_ready{pod=~"{{ include "distributed-bank.fullname" . }}-.*", condition="true"} == 0
      for: {{ .Values.monitoring.alerts.rules.podNotReady.duration | default "5m" }}
      labels:
        severity: critical
        component: {{ .Chart.Name }}
      annotations:
        summary: "Pod가 준비되지 않음"
        description: "Pod {{ $labels.pod }}이 준비 상태로 전환되지 않았습니다."
    {{- end }}
{{- end }}
{{- end }}
