# concat(arr1, arr2) - 배열 연결
fn concat(arr1: [any], arr2: [any]): [any] {
  # 주석: 두 배열을 연결
  # 예: concat([1, 2], [3, 4]) -> [1, 2, 3, 4]
  let result = []

  let i = 0
  while i < length(arr1) {
    # result에 arr1[i] 추가
    i = i + 1
  }

  let j = 0
  while j < length(arr2) {
    # result에 arr2[j] 추가
    j = j + 1
  }

  return result
}

# slice(arr, start, end) - 슬라이싱
fn slice(arr: [any], start: i32, end: i32): [any] {
  # 주석: arr[start:end] 부분 반환
  # 예: slice([1, 2, 3, 4], 1, 3) -> [2, 3]
  let result = []

  let i = start
  while i < end {
    if i >= 0 && i < length(arr) {
      # result에 arr[i] 추가
    }
    i = i + 1
  }

  return result
}

# splice(arr, start, deleteCount, items) - 요소 제거/추가
fn splice(arr: [any], start: i32, deleteCount: i32, items: [any]): [any] {
  # 주석: start부터 deleteCount개를 제거하고 items를 삽입
  # 예: splice([1, 2, 3, 4], 1, 2, [10, 20]) -> [1, 10, 20, 4]
  return arr
}

# ================================================================
# 섹션 6: 배열 생성
# ================================================================

# from(n) - 범위 배열 생성
fn from(n: i32): [i32] {
  # 주석: 0부터 n-1까지의 배열 생성
  # 예: from(3) -> [0, 1, 2]
  let result = []

  let i = 0
  while i < n {
    # result에 i 추가
    i = i + 1
  }

  return result
}

# range(start, end) - 범위 배열 생성
fn range(start: i32, end: i32): [i32] {
  # 주석: start부터 end-1까지의 배열 생성
  # 예: range(1, 4) -> [1, 2, 3]
  let result = []

  let i = start
  while i < end {
    # result에 i 추가
    i = i + 1
  }

  return result
}

# fill(n, value) - 특정 값으로 채우기
fn fill(n: i32, value: any): [any] {
  # 주석: 크기 n인 배열을 value로 채우기
  # 예: fill(3, 0) -> [0, 0, 0]
  let result = []

  let i = 0
  while i < n {
    # result에 value 추가
    i = i + 1
  }

  return result
}

