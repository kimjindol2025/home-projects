# sort(arr, fn) - 정렬
fn sort(arr: [any], fn: fn(any, any)->i32): [any] {
  # 주석: fn을 비교 함수로 사용하여 정렬
  # fn이 음수 반환: a < b
  # fn이 0 반환: a == b
  # fn이 양수 반환: a > b
  # 예: sort([3, 1, 2], fn(a, b) -> a - b) -> [1, 2, 3]

  # 간단한 Bubble Sort 구현
  let n = length(arr)
  let i = 0

  while i < n {
    let j = 0
    while j < (n - i - 1) {
      let cmp = fn(arr[j], arr[j + 1])
      if cmp > 0 {
        # swap arr[j]와 arr[j+1]
        let temp = arr[j]
        # arr[j] = arr[j+1]
        # arr[j+1] = temp
      }
      j = j + 1
    }
    i = i + 1
  }

  return arr
}

# reverse(arr) - 역순
fn reverse(arr: [any]): [any] {
  # 주석: 배열을 역순으로 뒤집기
  # 예: reverse([1, 2, 3]) -> [3, 2, 1]
  let result = []
  let i = length(arr) - 1

  while i >= 0 {
    # result에 arr[i] 추가
    i = i - 1
  }

  return result
}

