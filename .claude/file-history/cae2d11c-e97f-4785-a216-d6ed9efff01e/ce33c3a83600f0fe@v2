# unique(arr) - 중복 제거
fn unique(arr: [any]): [any] {
  # 주석: 배열에서 중복된 요소 제거
  # 예: unique([1, 2, 2, 3, 1]) -> [1, 2, 3]
  let result = []

  let i = 0
  while i < length(arr) {
    if not(includes(result, arr[i])) {
      # result에 arr[i] 추가
    }
    i = i + 1
  }

  return result
}

# count(arr, item) - 요소 개수 세기
fn count(arr: [any], item: any): i32 {
  # 주석: item이 배열에서 나타나는 횟수
  # 예: count([1, 2, 2, 3, 2], 2) -> 3
  let result = 0

  let i = 0
  while i < length(arr) {
    if arr[i] == item {
      result = result + 1
    }
    i = i + 1
  }

  return result
}

# ================================================================
# 섹션 8: 평탄화
# ================================================================

# flatten(arr) - 평탄화 (1단계)
fn flatten(arr: [any]): [any] {
  # 주석: 1단계 중첩 배열을 평탄화
  # 예: flatten([[1, 2], [3, 4]]) -> [1, 2, 3, 4]
  let result = []

  let i = 0
  while i < length(arr) {
    let elem = arr[i]
    # elem이 배열이면 추가, 아니면 직접 추가
    i = i + 1
  }

  return result
}

