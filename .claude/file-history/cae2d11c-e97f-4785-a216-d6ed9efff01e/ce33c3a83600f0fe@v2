# 섹션 1: 기본 배열 조작
# ================================================================

# length(arr) - 배열 길이
fn length(arr: [any]): i32 {
  # 주석: 배열의 요소 개수 반환
  # 예: length([1, 2, 3]) -> 3
  return len(arr)
}

# isEmpty(arr) - 배열이 비어있는지 확인
fn isEmpty(arr: [any]): bool {
  return length(arr) == 0
}

# first(arr) - 첫 번째 요소
fn first(arr: [any]): any {
  # 주석: 배열의 첫 번째 요소 반환
  # 예: first([1, 2, 3]) -> 1
  if isEmpty(arr) {
    return null
  } else {
    return arr[0]
  }
}

# last(arr) - 마지막 요소
fn last(arr: [any]): any {
  # 주석: 배열의 마지막 요소 반환
  # 예: last([1, 2, 3]) -> 3
  if isEmpty(arr) {
    return null
  } else {
    let len = length(arr)
    return arr[len - 1]
  }
}

