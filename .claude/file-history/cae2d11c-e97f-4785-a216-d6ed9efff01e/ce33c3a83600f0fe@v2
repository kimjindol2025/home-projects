# map(arr, fn) - 맵핑
fn map(arr: [any], fn: fn(any)->any): [any] {
  # 주석: 배열의 각 요소에 fn을 적용하여 새 배열 반환
  # 예: map([1, 2, 3], fn(x) -> x * 2) -> [2, 4, 6]
  let result = []

  let i = 0
  while i < length(arr) {
    let mapped = fn(arr[i])
    # 주석: result에 mapped 추가 (배열 append 필요)
    i = i + 1
  }

  return result
}

# filter(arr, fn) - 필터링
fn filter(arr: [any], fn: fn(any)->bool): [any] {
  # 주석: fn이 true를 반환하는 요소들만 필터링
  # 예: filter([1, 2, 3, 4], fn(x) -> x > 2) -> [3, 4]
  let result = []

  let i = 0
  while i < length(arr) {
    let elem = arr[i]
    if fn(elem) {
      # 주석: result에 elem 추가
    }
    i = i + 1
  }

  return result
}

# reduce(arr, fn, init) - 축약
fn reduce(arr: [any], fn: fn(any, any)->any, init: any): any {
  # 주석: 배열을 축약하여 단일 값으로 반환
  # 예: reduce([1, 2, 3], fn(a, b) -> a + b, 0) -> 6
  let accumulator = init

  let i = 0
  while i < length(arr) {
    let elem = arr[i]
    accumulator = fn(accumulator, elem)
    i = i + 1
  }

  return accumulator
}

# forEach(arr, fn) - 반복 (부작용)
fn forEach(arr: [any], fn: fn(any)->null): null {
  # 주석: 배열의 각 요소에 fn을 실행 (부작용만 발생)
  # 예: forEach([1, 2, 3], fn(x) -> print(x))
  let i = 0
  while i < length(arr) {
    fn(arr[i])
    i = i + 1
  }

  return null
}

