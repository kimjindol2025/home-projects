# indexOf(arr, item) - 인덱스 찾기
fn indexOf(arr: [any], item: any): i32 {
  # 주석: item이 처음 나타나는 인덱스 반환 (-1이면 없음)
  # 예: indexOf([1, 2, 3, 2], 2) -> 1
  let i = 0
  while i < length(arr) {
    if arr[i] == item {
      return i
    }
    i = i + 1
  }

  return -1
}

# lastIndexOf(arr, item) - 마지막 인덱스 찾기
fn lastIndexOf(arr: [any], item: any): i32 {
  # 주석: item이 마지막으로 나타나는 인덱스 반환
  # 예: lastIndexOf([1, 2, 3, 2], 2) -> 3
  let result = -1

  let i = 0
  while i < length(arr) {
    if arr[i] == item {
      result = i
    }
    i = i + 1
  }

  return result
}

# includes(arr, item) - 포함 여부 확인
fn includes(arr: [any], item: any): bool {
  # 주석: item이 배열에 포함되는지 확인
  let idx = indexOf(arr, item)
  return idx >= 0
}

# find(arr, fn) - 조건에 맞는 첫 요소 찾기
fn find(arr: [any], fn: fn(any)->bool): any {
  # 주석: fn이 true를 반환하는 첫 요소 반환
  # 예: find([1, 2, 3, 4], fn(x) -> x > 2) -> 3
  let i = 0
  while i < length(arr) {
    if fn(arr[i]) {
      return arr[i]
    }
    i = i + 1
  }

  return null
}

# findIndex(arr, fn) - 조건에 맞는 인덱스 찾기
fn findIndex(arr: [any], fn: fn(any)->bool): i32 {
  # 주석: fn이 true를 반환하는 첫 요소의 인덱스
  # 예: findIndex([1, 2, 3, 4], fn(x) -> x > 2) -> 2
  let i = 0
  while i < length(arr) {
    if fn(arr[i]) {
      return i
    }
    i = i + 1
  }

  return -1
}

# some(arr, fn) - 조건을 만족하는 요소가 있는지
fn some(arr: [any], fn: fn(any)->bool): bool {
  # 주석: 하나라도 fn이 true를 반환하면 true
  # 예: some([1, 2, 3], fn(x) -> x > 2) -> true
  let idx = findIndex(arr, fn)
  return idx >= 0
}

# every(arr, fn) - 모든 요소가 조건을 만족하는지
fn every(arr: [any], fn: fn(any)->bool): bool {
  # 주석: 모두 fn이 true를 반환해야 true
  # 예: every([1, 2, 3], fn(x) -> x > 0) -> true
  let i = 0
  while i < length(arr) {
    if not(fn(arr[i])) {
      return false
    }
    i = i + 1
  }

  return true
}

