// ============================================
// Part 1: Proxy 기본 구조
// ============================================

/// HTTP 요청 표현
struct HttpRequest {
  method: string,         // GET, POST, etc
  path: string,          // /api/transfer
  headers: {string: string},
  body: string,
  client_ip: string
}

/// HTTP 응답 표현
struct HttpResponse {
  status_code: int,      // 200, 404, 500, etc
  headers: {string: string},
  body: string,
  latency: int           // ms
}

/// Proxy 요청 상태
struct ProxyRequest {
  request_id: string,
  original_request: HttpRequest,
  target_backend: int?,
  retry_count: int,
  start_time: int,
  responses: [HttpResponse] = []
}

/// Proxy 설정
struct ProxyConfig {
  listen_port: int,
  backends: [int],
  timeout: int,          // ms
  max_retries: int,
  enable_logging: bool
}

/// Proxy 초기화
fn init_proxy(listen_port: int, backends: [int]) -> ProxyConfig {
  println()
  println("🌐 Reverse Proxy Initialized")
  println("├─ Listen Port: " + to_string(listen_port))
  println("├─ Backend Nodes: " + to_string(len(backends)))
  println("└─ Timeout: 5000ms")

  return ProxyConfig {
    listen_port: listen_port,
    backends: backends,
    timeout: 5000,
    max_retries: 3,
    enable_logging: true
  }
}

// ============================================
// Part 2: 요청 라우팅
// ============================================

/// 요청을 Backend로 전달
fn forward_request(
  proxy: ProxyConfig,
  request: HttpRequest,
  backend_id: int
) -> HttpResponse {
  println()
  println("📤 Forwarding request to Backend " + to_string(backend_id))
  println("├─ Method: " + request.method)
  println("├─ Path: " + request.path)
  println("└─ Client: " + request.client_ip)

  // 실제 환경에서는 네트워크 요청
  // 현재는 시뮬레이션

  latency = 10 + random(0, 40)  // 10-50ms

  response = HttpResponse {
    status_code: 200,
    headers: {
      "Content-Type": "application/json",
      "X-Backend-Node": to_string(backend_id)
    },
    body: "{\"status\": \"success\", \"message\": \"Processed by node " +
          to_string(backend_id) + "\"}",
    latency: latency
  }

  println("✅ Response received in " + to_string(latency) + "ms")

  return response
}

/// Backend 선택 (Round-Robin)
fn select_backend_round_robin(
  proxy: ProxyConfig,
  request_count: int
) -> int {
  backend_index = request_count % len(proxy.backends)
  return proxy.backends[backend_index]
}

/// Backend 선택 (Least Connections)
fn select_backend_least_connections(
  proxy: ProxyConfig,
  connection_counts: {int: int}
) -> int {
  if len(proxy.backends) == 0 {
    return -1
  }

  min_backend = proxy.backends[0]
  min_connections = 999999

  for backend_id in proxy.backends {
    count = connection_counts[backend_id]
    if count == null {
      count = 0
    }

    if count < min_connections {
      min_connections = count
      min_backend = backend_id
    }
  }

  return min_backend
}

// ============================================
// Part 3: 응답 처리
// ============================================

/// 응답 상태 확인
fn is_response_success(response: HttpResponse) -> bool {
  // 2xx 상태 코드는 성공
  return response.status_code >= 200 && response.status_code < 300
}

/// 응답 병합 (여러 응답 결합)
fn merge_responses(responses: [HttpResponse]) -> HttpResponse {
  if len(responses) == 0 {
    return HttpResponse {
      status_code: 500,
      headers: {},
      body: "{\"error\": \"No responses\"}",
      latency: 0
    }
  }

  // 첫 번째 성공 응답 반환
  for response in responses {
    if is_response_success(response) {
      return response
    }
  }

  // 모두 실패하면 마지막 응답 반환
  return responses[len(responses) - 1]
}

/// 응답 헤더 추가
fn add_proxy_headers(response: HttpResponse, latency: int) -> HttpResponse {
  response.headers["X-Response-Time"] = to_string(latency) + "ms"
  response.headers["X-Forwarded-By"] = "FreeLang-Proxy/1.0"

  return response
}

// ============================================
// Part 4: 재시도 로직
// ============================================

/// 재시도 가능 여부 판정
fn should_retry(
  response: HttpResponse,
  retry_count: int,
  max_retries: int
) -> bool {
  // 성공 응답은 재시도 불필요
  if is_response_success(response) {
    return false
  }

  // 재시도 횟수 초과
  if retry_count >= max_retries {
    return false
  }

  // 5xx 에러 또는 타임아웃은 재시도
  if response.status_code >= 500 || response.status_code == 0 {
    return true
  }

  return false
}

/// 재시도와 함께 요청 처리
fn handle_request_with_retry(
  proxy: ProxyConfig,
  proxy_request: ProxyRequest
) -> HttpResponse {
  println()
  println("🔄 Handling request with retry logic")

  current_request = proxy_request.original_request
  responses = []

  for attempt = 0; attempt <= proxy.max_retries; attempt = attempt + 1 {
    backend_id = select_backend_round_robin(proxy, attempt)

    println("   Attempt " + to_string(attempt + 1) + ": Backend " +
            to_string(backend_id))

    response = forward_request(proxy, current_request, backend_id)
    responses = responses + [response]

    if is_response_success(response) {
      println("   ✅ Success!")
      return response
    }

    if !should_retry(response, attempt, proxy.max_retries) {
      break
    }

    println("   ⚠️  Retrying...")
  }

  // 모든 재시도 실패
  final_response = merge_responses(responses)
  println("   ❌ All retries failed, returning last response")

  return final_response
}

// ============================================
// Part 5: 로깅 & 모니터링
// ============================================

/// 요청 로깅
fn log_request(
  request_id: string,
  request: HttpRequest,
  response: HttpResponse
) {
  status_str = ""
  if response.status_code >= 200 && response.status_code < 300 {
    status_str = "✅"
  } else if response.status_code >= 400 && response.status_code < 500 {
    status_str = "⚠️"
  } else {
    status_str = "❌"
  }

  println()
  println("📝 [" + request_id + "] " + status_str)
  println("├─ " + request.method + " " + request.path)
  println("├─ Status: " + to_string(response.status_code))
  println("├─ Latency: " + to_string(response.latency) + "ms")
  println("└─ Client: " + request.client_ip)
}

/// 프록시 메트릭
struct ProxyMetrics {
  total_requests: int,
  successful_requests: int,
  failed_requests: int,
  total_latency: int,
  avg_latency: int
}

/// 메트릭 계산
fn calculate_metrics(responses: [HttpResponse]) -> ProxyMetrics {
  total = len(responses)
  successful = 0
  failed = 0
  total_latency = 0

  for response in responses {
    if is_response_success(response) {
      successful = successful + 1
    } else {
      failed = failed + 1
    }
    total_latency = total_latency + response.latency
  }

  avg = total_latency / (total + 1)

  return ProxyMetrics {
    total_requests: total,
    successful_requests: successful,
    failed_requests: failed,
    total_latency: total_latency,
    avg_latency: avg
  }
}

/// 메트릭 출력
fn print_metrics(metrics: ProxyMetrics) {
  println()
  println("📊 Proxy Metrics")
  println("├─ Total Requests: " + to_string(metrics.total_requests))
  println("├─ Successful: " + to_string(metrics.successful_requests))
  println("├─ Failed: " + to_string(metrics.failed_requests))
  println("├─ Total Latency: " + to_string(metrics.total_latency) + "ms")
  println("└─ Avg Latency: " + to_string(metrics.avg_latency) + "ms")
}

