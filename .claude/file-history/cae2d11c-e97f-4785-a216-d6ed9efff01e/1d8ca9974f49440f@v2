fn test_init_proxy() {
  backends = [0, 1, 2]
  proxy = init_proxy(8080, backends)

  assert proxy.listen_port == 8080
  assert len(proxy.backends) == 3
  assert proxy.timeout == 5000

  println("✅ test_init_proxy passed")
}

fn test_forward_request() {
  backends = [0, 1, 2]
  proxy = init_proxy(8080, backends)

  request = HttpRequest {
    method: "POST",
    path: "/api/transfer",
    headers: { "Content-Type": "application/json" },
    body: "{\"amount\": 100}",
    client_ip: "192.168.1.1"
  }

  response = forward_request(proxy, request, 0)

  assert response.status_code == 200
  assert response.latency > 0

  println("✅ test_forward_request passed")
}

fn test_select_backend_round_robin() {
  backends = [0, 1, 2]
  proxy = init_proxy(8080, backends)

  backend1 = select_backend_round_robin(proxy, 0)
  backend2 = select_backend_round_robin(proxy, 1)
  backend3 = select_backend_round_robin(proxy, 2)

  assert backend1 == 0
  assert backend2 == 1
  assert backend3 == 2

  println("✅ test_select_backend_round_robin passed")
}

fn test_is_response_success() {
  success_resp = HttpResponse {
    status_code: 200,
    headers: {},
    body: "OK",
    latency: 10
  }

  fail_resp = HttpResponse {
    status_code: 500,
    headers: {},
    body: "Error",
    latency: 20
  }

  assert is_response_success(success_resp) == true
  assert is_response_success(fail_resp) == false

  println("✅ test_is_response_success passed")
}

fn test_should_retry() {
  // 성공 응답: 재시도 불필요
  success = HttpResponse {
    status_code: 200,
    headers: {},
    body: "OK",
    latency: 10
  }

  assert should_retry(success, 0, 3) == false

  // 5xx 에러: 재시도 필요
  server_error = HttpResponse {
    status_code: 500,
    headers: {},
    body: "Error",
    latency: 10
  }

  assert should_retry(server_error, 0, 3) == true

  // 재시도 횟수 초과: 재시도 불필요
  assert should_retry(server_error, 3, 3) == false

  println("✅ test_should_retry passed")
}

fn test_merge_responses() {
  responses = [
    HttpResponse { status_code: 500, headers: {}, body: "Error", latency: 10 },
    HttpResponse { status_code: 200, headers: {}, body: "OK", latency: 15 },
    HttpResponse { status_code: 500, headers: {}, body: "Error", latency: 20 }
  ]

  merged = merge_responses(responses)

  // 첫 성공 응답 선택
  assert merged.status_code == 200

  println("✅ test_merge_responses passed")
}

fn test_calculate_metrics() {
  responses = [
    HttpResponse { status_code: 200, headers: {}, body: "OK", latency: 10 },
    HttpResponse { status_code: 200, headers: {}, body: "OK", latency: 20 },
    HttpResponse { status_code: 500, headers: {}, body: "Error", latency: 30 }
  ]

  metrics = calculate_metrics(responses)

  assert metrics.total_requests == 3
  assert metrics.successful_requests == 2
  assert metrics.failed_requests == 1
  assert metrics.total_latency == 60

  println("✅ test_calculate_metrics passed")
}

fn test_handle_request_with_retry() {
  backends = [0, 1, 2]
  proxy = init_proxy(8080, backends)

  request = HttpRequest {
    method: "GET",
    path: "/api/status",
    headers: {},
    body: "",
    client_ip: "192.168.1.1"
  }

  proxy_request = ProxyRequest {
    request_id: "req_001",
    original_request: request,
    target_backend: null,
    retry_count: 0,
    start_time: 0,
    responses: []
  }

  response = handle_request_with_retry(proxy, proxy_request)

  assert response.status_code >= 200

  println("✅ test_handle_request_with_retry passed")
}

