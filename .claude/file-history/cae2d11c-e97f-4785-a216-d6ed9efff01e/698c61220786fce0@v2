// ============================================
// Part 1: 인증 기본 구조
// ============================================

/// 사용자 역할
enum UserRole {
  Anonymous,  // 미인증
  User,       // 일반 사용자
  Admin,      // 관리자
  Service     // 서비스 계정
}

/// 토큰 정보
struct Token {
  token_id: string,
  user_id: string,
  user_role: UserRole,
  issued_at: int,        // Unix timestamp
  expires_at: int,
  scope: [string]        // 권한 목록
}

/// 인증 설정
struct AuthConfig {
  token_ttl: int,        // 토큰 유효 시간 (초)
  refresh_enabled: bool,
  require_https: bool,
  allow_anonymous: bool
}

/// 인증 결과
struct AuthResult {
  is_valid: bool,
  user_id: string,
  user_role: UserRole,
  scope: [string],
  error_message: string
}

/// 인증 초기화
fn init_auth(ttl: int) -> AuthConfig {
  println()
  println("🔐 Authentication Initialized")
  println("├─ Token TTL: " + to_string(ttl) + "s")
  println("├─ Refresh Enabled: true")
  println("└─ Status: Ready")

  return AuthConfig {
    token_ttl: ttl,
    refresh_enabled: true,
    require_https: true,
    allow_anonymous: true
  }
}

// ============================================
// Part 2: 토큰 생성 및 검증
// ============================================

/// 토큰 생성
fn generate_token(
  user_id: string,
  user_role: UserRole,
  config: AuthConfig,
  current_time: int
) -> Token {
  println()
  println("🎫 Generating token for user: " + user_id)

  // 토큰 ID는 user_id + timestamp의 해시 (시뮬레이션)
  token_id = "tok_" + user_id + "_" + to_string(current_time)

  // 역할에 따른 권한 설정
  scope = []
  if user_role == UserRole.Anonymous {
    scope = ["read:public"]
  } else if user_role == UserRole.User {
    scope = ["read:own", "write:own"]
  } else if user_role == UserRole.Admin {
    scope = ["read:all", "write:all", "delete:all", "admin:access"]
  } else if user_role == UserRole.Service {
    scope = ["service:api"]
  }

  token = Token {
    token_id: token_id,
    user_id: user_id,
    user_role: user_role,
    issued_at: current_time,
    expires_at: current_time + config.token_ttl,
    scope: scope
  }

  role_str = ""
  if user_role == UserRole.User {
    role_str = "User"
  } else if user_role == UserRole.Admin {
    role_str = "Admin"
  } else if user_role == UserRole.Service {
    role_str = "Service"
  }

  println("   ✅ Token created: " + token_id)
  println("   ├─ Role: " + role_str)
  println("   ├─ Expires: " + to_string(token.expires_at))
  println("   └─ Scopes: " + to_string(len(scope)))

  return token
}

/// 토큰 유효성 검증
fn validate_token(token: Token, current_time: int) -> bool {
  // 만료 시간 확인
  if current_time > token.expires_at {
    println("   ❌ Token expired")
    return false
  }

  // 토큰 ID 유효성 (간단한 확인)
  if token.token_id == "" {
    println("   ❌ Invalid token ID")
    return false
  }

  // 사용자 ID 확인
  if token.user_id == "" {
    println("   ❌ Invalid user ID")
    return false
  }

  return true
}

// ============================================
// Part 3: 권한 검증
// ============================================

/// 특정 권한 가지고 있는지 확인
fn has_scope(token: Token, required_scope: string) -> bool {
  for scope in token.scope {
    if scope == required_scope {
      return true
    }
  }

  return false
}

/// 여러 권한 중 하나 가지고 있는지 확인 (OR)
fn has_any_scope(token: Token, required_scopes: [string]) -> bool {
  for required_scope in required_scopes {
    if has_scope(token, required_scope) {
      return true
    }
  }

  return false
}

/// 모든 권한을 가지고 있는지 확인 (AND)
fn has_all_scopes(token: Token, required_scopes: [string]) -> bool {
  for required_scope in required_scopes {
    if !has_scope(token, required_scope) {
      return false
    }
  }

  return true
}

// ============================================
// Part 4: 요청 인증
// ============================================

/// HTTP 요청에서 토큰 추출
fn extract_token_from_header(
  headers: {string: string}
) -> string {
  auth_header = headers["Authorization"]

  if auth_header == null {
    return ""
  }

  // Bearer token 형식 가정
  if len(auth_header) > 7 {
    return auth_header
  }

  return ""
}

/// 요청 인증
fn authenticate_request(
  headers: {string: string},
  token_store: {string: Token},
  current_time: int
) -> AuthResult {
  println()
  println("🔍 Authenticating request")

  token_str = extract_token_from_header(headers)

  if token_str == "" {
    println("   ⚠️  No authorization header")

    return AuthResult {
      is_valid: false,
      user_id: "",
      user_role: UserRole.Anonymous,
      scope: ["read:public"],
      error_message: "No token provided"
    }
  }

  // 토큰 스토어에서 조회
  token = token_store[token_str]

  if token == null {
    println("   ❌ Token not found")

    return AuthResult {
      is_valid: false,
      user_id: "",
      user_role: UserRole.Anonymous,
      scope: [],
      error_message: "Invalid token"
    }
  }

  // 토큰 유효성 확인
  if !validate_token(token, current_time) {
    return AuthResult {
      is_valid: false,
      user_id: token.user_id,
      user_role: token.user_role,
      scope: [],
      error_message: "Token expired"
    }
  }

  println("   ✅ Authentication successful")
  println("   ├─ User: " + token.user_id)
  println("   └─ Role: " + to_string(token.user_role))

  return AuthResult {
    is_valid: true,
    user_id: token.user_id,
    user_role: token.user_role,
    scope: token.scope,
    error_message: ""
  }
}

// ============================================
// Part 5: 세션 관리
// ============================================

/// 사용자 세션
struct UserSession {
  session_id: string,
  user_id: string,
  user_role: UserRole,
  token: Token,
  last_activity: int,
  is_active: bool
}

/// 세션 생성
fn create_session(
  user_id: string,
  user_role: UserRole,
  token: Token,
  current_time: int
) -> UserSession {
  session_id = "sess_" + user_id + "_" + to_string(current_time)

  return UserSession {
    session_id: session_id,
    user_id: user_id,
    user_role: user_role,
    token: token,
    last_activity: current_time,
    is_active: true
  }
}

/// 세션 갱신
fn refresh_session(
  session: UserSession,
  current_time: int
) -> UserSession {
  session.last_activity = current_time

  return session
}

/// 세션 만료 확인 (10분 미활동)
fn is_session_expired(session: UserSession, current_time: int) -> bool {
  inactivity_timeout = 600  // 10분

  time_since_activity = current_time - session.last_activity

  return time_since_activity > inactivity_timeout
}

// ============================================
// Part 6: 모니터링
