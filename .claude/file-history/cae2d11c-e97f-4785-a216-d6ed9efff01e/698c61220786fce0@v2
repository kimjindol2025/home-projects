/// 인증 통계
struct AuthStats {
  total_tokens: int,
  valid_tokens: int,
  expired_tokens: int,
  active_sessions: int
}

/// 권한 목록 출력
fn print_token_info(token: Token) {
  println()
  println("🎫 Token Info: " + token.token_id)
  println("├─ User: " + token.user_id)
  println("├─ Issued: " + to_string(token.issued_at))
  println("├─ Expires: " + to_string(token.expires_at))
  println("└─ Scopes: " + to_string(len(token.scope)))

  for scope in token.scope {
    println("   • " + scope)
  }
}

// ============================================
// Part 7: 테스트
// ============================================

fn test_init_auth() {
  config = init_auth(3600)

  assert config.token_ttl == 3600
  assert config.refresh_enabled == true

  println("✅ test_init_auth passed")
}

fn test_generate_token() {
  config = init_auth(3600)

  token = generate_token("user1", UserRole.User, config, 1000)

  assert token.user_id == "user1"
  assert token.expires_at == 1000 + 3600
  assert len(token.scope) > 0

  println("✅ test_generate_token passed")
}

fn test_validate_token_valid() {
  config = init_auth(3600)
  token = generate_token("user1", UserRole.User, config, 1000)

  // 토큰 유효 (현재 1000초, 만료 4600초)
  is_valid = validate_token(token, 1000)
  assert is_valid == true

  println("✅ test_validate_token_valid passed")
}

fn test_validate_token_expired() {
  config = init_auth(3600)
  token = generate_token("user1", UserRole.User, config, 1000)

  // 토큰 만료 (현재 5000초, 만료 4600초)
  is_valid = validate_token(token, 5000)
  assert is_valid == false

  println("✅ test_validate_token_expired passed")
}

fn test_has_scope() {
  config = init_auth(3600)
  token = generate_token("user1", UserRole.User, config, 1000)

  // User 역할은 "read:own" 권한 보유
  assert has_scope(token, "read:own") == true
  assert has_scope(token, "admin:access") == false

  println("✅ test_has_scope passed")
}

fn test_has_all_scopes() {
  config = init_auth(3600)
  token = generate_token("user1", UserRole.Admin, config, 1000)

  required = ["read:all", "write:all"]
  assert has_all_scopes(token, required) == true

  println("✅ test_has_all_scopes passed")
}

fn test_extract_token() {
  headers = { "Authorization": "Bearer_token_abc123" }

  token_str = extract_token_from_header(headers)
  assert token_str == "Bearer_token_abc123"

  println("✅ test_extract_token passed")
}

fn test_authenticate_request() {
  config = init_auth(3600)
  token = generate_token("user1", UserRole.User, config, 1000)

  token_store = { token.token_id: token }
  headers = { "Authorization": token.token_id }

  auth_result = authenticate_request(headers, token_store, 1000)

  assert auth_result.is_valid == true
  assert auth_result.user_id == "user1"

  println("✅ test_authenticate_request passed")
}

fn test_create_session() {
  config = init_auth(3600)
  token = generate_token("user1", UserRole.User, config, 1000)

  session = create_session("user1", UserRole.User, token, 1000)

  assert session.user_id == "user1"
  assert session.is_active == true

  println("✅ test_create_session passed")
}

fn test_session_expiration() {
  config = init_auth(3600)
  token = generate_token("user1", UserRole.User, config, 1000)

  session = create_session("user1", UserRole.User, token, 1000)

  // 미활동 5분 (300초)
  is_expired = is_session_expired(session, 1300)
  assert is_expired == false

  // 미활동 15분 (900초) - 만료
  is_expired = is_session_expired(session, 1900)
  assert is_expired == true

  println("✅ test_session_expiration passed")
}

