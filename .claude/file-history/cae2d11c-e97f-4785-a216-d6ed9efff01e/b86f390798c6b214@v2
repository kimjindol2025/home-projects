/**
 * HashMap 테스트
 */

import { HashMap, Vector } from './hashmap';

function runTests() {
  console.log('🧪 HashMap 테스트 시작\n');

  let passed = 0;
  let failed = 0;

  // Test 1: 기본 삽입 및 조회
  console.log('Test 1: 기본 삽입 및 조회');
  try {
    const map = new HashMap<string, number>();
    map.set('apple', 5);
    map.set('banana', 3);
    map.set('cherry', 8);

    if (map.get('apple') === 5 && map.get('banana') === 3) {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log('  ❌ 실패\n');
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 2: 크기 확인
  console.log('Test 2: 크기 확인');
  try {
    const map = new HashMap<string, string>();
    map.set('a', 'apple');
    map.set('b', 'banana');
    map.set('c', 'cherry');

    if (map.len() === 3) {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log(`  ❌ 실패 (기대: 3, 실제: ${map.len()})\n`);
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 3: 키 존재 확인
  console.log('Test 3: 키 존재 확인');
  try {
    const map = new HashMap<string, number>();
    map.set('x', 10);
    map.set('y', 20);

    if (map.has('x') && map.has('y') && !map.has('z')) {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log('  ❌ 실패\n');
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 4: 값 업데이트
  console.log('Test 4: 값 업데이트');
  try {
    const map = new HashMap<string, number>();
    map.set('count', 1);
    map.set('count', 2);
    map.set('count', 3);

    if (map.get('count') === 3 && map.len() === 1) {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log(`  ❌ 실패\n`);
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 5: 항목 삭제
  console.log('Test 5: 항목 삭제');
  try {
    const map = new HashMap<string, string>();
    map.set('one', 'A');
    map.set('two', 'B');
    map.set('three', 'C');

    const deleted = map.delete('two');
    if (deleted && map.len() === 2 && !map.has('two')) {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log('  ❌ 실패\n');
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 6: 모든 키 가져오기
  console.log('Test 6: 모든 키 가져오기');
  try {
    const map = new HashMap<string, number>();
    map.set('first', 1);
    map.set('second', 2);
    map.set('third', 3);

    const keys = map.keys();
    if (keys.length === 3 && keys.includes('first') && keys.includes('second')) {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log('  ❌ 실패\n');
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 7: 모든 값 가져오기
  console.log('Test 7: 모든 값 가져오기');
  try {
    const map = new HashMap<string, string>();
    map.set('a', 'alpha');
    map.set('b', 'beta');
    map.set('c', 'gamma');

    const values = map.values();
    if (values.length === 3 && values.includes('alpha')) {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log('  ❌ 실패\n');
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 8: 리사이징 (많은 항목 삽입)
  console.log('Test 8: 리사이징 (많은 항목)');
  try {
    const map = new HashMap<number, string>();
    for (let i = 0; i < 100; i++) {
      map.set(i, `value_${i}`);
    }

    if (map.len() === 100 && map.get(50) === 'value_50' && map.get(99) === 'value_99') {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log('  ❌ 실패\n');
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 9: 빈 맵 확인
  console.log('Test 9: 빈 맵 확인');
  try {
    const map = new HashMap<string, number>();
    if (map.isEmpty() && map.len() === 0) {
      map.set('x', 1);
      if (!map.isEmpty() && map.len() === 1) {
        console.log('  ✅ 통과\n');
        passed++;
      } else {
        console.log('  ❌ 실패\n');
        failed++;
      }
    } else {
      console.log('  ❌ 실패\n');
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 10: clear() 메서드
  console.log('Test 10: clear() 메서드');
  try {
    const map = new HashMap<string, number>();
    map.set('a', 1);
    map.set('b', 2);
    map.set('c', 3);
    map.clear();

    if (map.isEmpty() && map.len() === 0) {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log('  ❌ 실패\n');
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 11: Vector 기본 사용
  console.log('Test 11: Vector 기본 사용');
  try {
    const vec = new Vector<number>();
    vec.push(10);
    vec.push(20);
    vec.push(30);

    if (vec.len() === 3 && vec.get(0) === 10 && vec.get(2) === 30) {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log('  ❌ 실패\n');
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 12: Vector pop
  console.log('Test 12: Vector pop');
  try {
    const vec = new Vector<string>();
    vec.push('a');
    vec.push('b');
    vec.push('c');

    const popped = vec.pop();
    if (popped === 'c' && vec.len() === 2) {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log('  ❌ 실패\n');
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // 최종 결과
  console.log('='.repeat(40));
  console.log(`✅ 통과: ${passed}개`);
  console.log(`❌ 실패: ${failed}개`);
  console.log(`📊 성공률: ${((passed / (passed + failed)) * 100).toFixed(1)}%`);
  console.log('='.repeat(40));
}

// 실행
if (require.main === module) {
  runTests();
}

export { runTests };
