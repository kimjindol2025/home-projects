/**
 * Path 유틸리티 테스트
 */

import {
  normalize,
  split,
  join,
  isAbsolute,
  relative,
  resolve,
  basename,
  basenameWithoutExt,
  dirname,
  extname,
  parse,
  isValidPath,
  isSubpath,
  commonPath,
  clean,
  getPathStats
} from './path';

function runTests() {
  console.log('🧪 Path 유틸리티 테스트 시작\n');

  let passed = 0;
  let failed = 0;

  // Test 1: 경로 정규화
  console.log('Test 1: 경로 정규화');
  try {
    const result1 = normalize('a/./b');
    const result2 = normalize('a//b//c');
    const result3 = normalize('a/../b');

    if (result1 === 'a/b' && result2 === 'a/b/c') {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log(`  ❌ 실패 (${result1}, ${result2}, ${result3})\n`);
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 2: 경로 분해
  console.log('Test 2: 경로 분해');
  try {
    const parts1 = split('home/user/file.txt');
    const parts2 = split('/home/user/file.txt');

    if (
      parts1.length === 3 &&
      parts1[0] === 'home' &&
      parts1[2] === 'file.txt' &&
      parts2.length === 3
    ) {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log(`  ❌ 실패\n`);
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 3: 경로 합치기
  console.log('Test 3: 경로 합치기');
  try {
    const result1 = join('home', 'user', 'file.txt');
    const result2 = join('/home', 'user', 'file.txt');
    const result3 = join('a', 'b', '..', 'c');

    if (
      result1.includes('home') &&
      result1.includes('file.txt') &&
      result2.startsWith('/')
    ) {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log(`  ❌ 실패\n`);
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 4: 절대 경로 확인
  console.log('Test 4: 절대 경로 확인');
  try {
    const abs1 = isAbsolute('/home/user');
    const abs2 = isAbsolute('home/user');

    if (abs1 === true && abs2 === false) {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log(`  ❌ 실패\n`);
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 5: 파일명 추출
  console.log('Test 5: 파일명 추출');
  try {
    const base1 = basename('/home/user/file.txt');
    const base2 = basename('file.txt');

    if (base1 === 'file.txt' && base2 === 'file.txt') {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log(`  ❌ 실패 (${base1}, ${base2})\n`);
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 6: 확장자 추출
  console.log('Test 6: 확장자 추출');
  try {
    const ext1 = extname('file.txt');
    const ext2 = extname('file.tar.gz');
    const ext3 = extname('file');

    if (ext1 === '.txt' && ext2 === '.gz' && ext3 === '') {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log(`  ❌ 실패 (${ext1}, ${ext2}, ${ext3})\n`);
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 7: 디렉토리 부분 추출
  console.log('Test 7: 디렉토리 부분 추출');
  try {
    const dir1 = dirname('/home/user/file.txt');
    const dir2 = dirname('file.txt');

    if (dir1.includes('home') && (dir2 === '.' || dir2 === '')) {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log(`  ❌ 실패 (${dir1}, ${dir2})\n`);
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 8: 경로 분석
  console.log('Test 8: 경로 분석');
  try {
    const parsed = parse('/home/user/file.txt');

    if (
      parsed.dir.includes('home') &&
      parsed.base === 'file.txt' &&
      parsed.ext === '.txt' &&
      parsed.name === 'file'
    ) {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log(`  ❌ 실패\n`);
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 9: 경로 유효성 확인
  console.log('Test 9: 경로 유효성 확인');
  try {
    const valid1 = isValidPath('/home/user/file.txt');
    const valid2 = isValidPath('valid/path');
    const valid3 = isValidPath('');

    if (valid1 === true && valid2 === true && valid3 === false) {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log(`  ❌ 실패 (${valid1}, ${valid2}, ${valid3})\n`);
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 10: 경로 정리
  console.log('Test 10: 경로 정리');
  try {
    const clean1 = clean('a/./b');
    const clean2 = clean('a//b');
    const clean3 = clean('a/b/../c');

    if (
      clean1.includes('a') &&
      clean1.includes('b') &&
      clean2.includes('a') &&
      clean2.includes('b')
    ) {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log(`  ❌ 실패\n`);
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 11: 파일명 추출 (확장자 제외)
  console.log('Test 11: 파일명 추출 (확장자 제외)');
  try {
    const name1 = basenameWithoutExt('file.txt');
    const name2 = basenameWithoutExt('/home/user/document.pdf');

    if (name1 === 'file' && name2 === 'document') {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log(`  ❌ 실패 (${name1}, ${name2})\n`);
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 12: 공통 경로 찾기
  console.log('Test 12: 공통 경로 찾기');
  try {
    const common1 = commonPath(['a/b/c', 'a/b/d', 'a/b/e']);
    const common2 = commonPath(['home/user', 'home/admin', 'home/guest']);

    if (
      (common1.includes('a/b') || common1 === 'a/b') &&
      (common2.includes('home') || common2 === 'home')
    ) {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log(`  ❌ 실패 (${common1}, ${common2})\n`);
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // 최종 결과
  console.log('='.repeat(40));
  console.log(`✅ 통과: ${passed}개`);
  console.log(`❌ 실패: ${failed}개`);
  console.log(`📊 성공률: ${((passed / (passed + failed)) * 100).toFixed(1)}%`);
  console.log('='.repeat(40));

  // Path 유틸리티 통계 출력
  console.log('\n📊 Path 유틸리티 통계:');
  const stats = getPathStats();
  console.log(`  버전: ${stats.version}`);
  console.log(`  기능: ${stats.features.length}가지`);
  stats.features.forEach(f => console.log(`    - ${f}`));
}

// 실행
if (require.main === module) {
  runTests();
}

export { runTests };
