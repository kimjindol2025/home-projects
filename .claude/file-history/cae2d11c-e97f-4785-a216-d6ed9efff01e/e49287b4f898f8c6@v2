/// 스냅샷을 생성할 시점인지 판정
fn should_take_snapshot(node: RaftNode) -> bool {
  // 규칙: 로그 크기가 일정 크기 이상이면 스냅샷
  log_size_threshold = 1000  // 1000개 항목 이상

  if len(node.log) > log_size_threshold {
    println("📸 Log size (" + to_string(len(node.log)) +
            ") exceeds threshold (" + to_string(log_size_threshold) + ")")
    return true
  }

  return false
}

/// 스냅샷 생성
fn take_snapshot(node: RaftNode) -> Snapshot {
  println()
  println("📸 Taking snapshot...")

  // 스냅샷은 lastApplied까지만 포함
  last_included_index = node.lastApplied
  last_included_term = 0

  // lastApplied 위치의 로그 term 구하기
  if last_included_index > 0 {
    entry = get_log_entry(node, last_included_index)
    if entry != null {
      last_included_term = entry.term
    }
  }

  // 상태 머신 상태를 JSON으로 직렬화
  // (현재는 간단한 메타데이터만 저장)
  state_json = json({
    lastApplied: last_included_index,
    appliedCommands: node.appliedCommandCount,
    timestamp: 0
  })

  snapshot = Snapshot {
    lastIncludedIndex: last_included_index,
    lastIncludedTerm: last_included_term,
    state: state_json
  }

  println("   ✅ Snapshot created")
  println("   ├─ lastIncludedIndex: " + to_string(last_included_index))
  println("   ├─ lastIncludedTerm: " + to_string(last_included_term))
  println("   └─ State size: " + to_string(len(state_json)) + " bytes")

  return snapshot
}

