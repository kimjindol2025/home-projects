fn test_snapshot_pipeline() {
  peers = [1, 2]
  node = create_raft_node(0, peers)
  node.state = NodeState.Leader

  // 1. 로그 생성
  for i = 0; i < 10; i = i + 1 {
    node = append_log(node, "cmd" + to_string(i))
  }
  node.lastApplied = 5

  // 2. 스냅샷 생성 및 로그 압축
  (node, snapshot) = compact_logs(node)

  // 3. 검증
  assert snapshot.lastIncludedIndex == 5
  assert len(node.log) == 5

  // 4. 복구
  node = restore_from_snapshot(node, snapshot)
  assert node.lastApplied == 5

  println("✅ test_snapshot_pipeline passed")
}

