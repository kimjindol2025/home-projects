/// InstallSnapshot RPC 요청
struct InstallSnapshotRequest {
  term: int,
  leaderId: int,
  lastIncludedIndex: int,
  lastIncludedTerm: int,
  offset: int,              // 스냅샷 청크 오프셋
  data: string,             // 스냅샷 데이터 청크
  done: bool                // 마지막 청크인지?
}

/// InstallSnapshot RPC 응답
struct InstallSnapshotResponse {
  term: int
}

/// 팔로워에게 스냅샷 전송
fn send_snapshot_to_follower(
  node: RaftNode,
  follower_id: int,
  snapshot: Snapshot
) -> InstallSnapshotResponse? {
  println()
  println("📤 Sending snapshot to Follower " + to_string(follower_id))
  println("   Index: " + to_string(snapshot.lastIncludedIndex))

  // 실제 구현에서는 청크 단위로 전송
  // (현재는 전체를 한번에 전송하는 것으로 간단화)

  req = InstallSnapshotRequest {
    term: node.currentTerm,
    leaderId: node.id,
    lastIncludedIndex: snapshot.lastIncludedIndex,
    lastIncludedTerm: snapshot.lastIncludedTerm,
    offset: 0,
    data: snapshot.state,
    done: true  // 단일 청크
  }

  // 실제:
  // resp = send_install_snapshot_rpc(node, follower_id, req)

  println("   ✅ Snapshot sent")

  return null
}

/// InstallSnapshot RPC 처리
fn handle_install_snapshot(
  node: RaftNode,
  req: InstallSnapshotRequest
) -> (RaftNode, InstallSnapshotResponse) {
  println()
  println("📥 Received InstallSnapshot from Leader " + to_string(req.leaderId))

  // Term 확인
  if req.term < node.currentTerm {
    resp = InstallSnapshotResponse {
      term: node.currentTerm
    }
    return (node, resp)
  }

  // Higher term이면 업데이트
  if req.term > node.currentTerm {
    node = update_term(node, req.term)
  }

  // Follower 상태로 설정
  if node.state != NodeState.Follower {
    node.state = NodeState.Follower
  }

  // 타이머 리셋
  node.electionTimer = timer_reset(node.electionTimer)

  println("   ✅ Snapshot received and installed")
  println("   ├─ lastIncludedIndex: " + to_string(req.lastIncludedIndex))
  println("   └─ lastIncludedTerm: " + to_string(req.lastIncludedTerm))

  // lastIncludedIndex 이전의 로그 제거
  new_log = []
  for i = req.lastIncludedIndex + 1; i <= last_log_index(node); i = i + 1 {
    entry = get_log_entry(node, i)
    if entry != null {
      new_log = new_log + [entry]
    }
  }
  node.log = new_log

  // lastApplied 업데이트
  if req.lastIncludedIndex > node.lastApplied {
    node.lastApplied = req.lastIncludedIndex
  }

  resp = InstallSnapshotResponse {
    term: node.currentTerm
  }

  return (node, resp)
}

