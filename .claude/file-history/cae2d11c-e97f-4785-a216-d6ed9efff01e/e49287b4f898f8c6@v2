) -> RaftNode {
  println()
  println("🔄 Restoring from snapshot...")

  // lastApplied를 스냅샷 인덱스로 설정
  node.lastApplied = snapshot.lastIncludedIndex

  println("   ✅ Restored")
  println("   └─ lastApplied: " + to_string(node.lastApplied))

  return node
}

