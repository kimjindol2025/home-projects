/// 스냅샷 검증
fn verify_snapshot(snapshot: Snapshot) -> bool {
  if snapshot.lastIncludedIndex < 0 {
    return false
  }

  if snapshot.lastIncludedTerm < 0 {
    return false
  }

  if snapshot.state == "" {
    return false
  }

  return true
}

// ============================================
// Part 3: 로그 압축
// ============================================

/// 스냅샷 이후의 로그만 유지
fn discard_old_logs(
  node: RaftNode,
  snapshot: Snapshot
) -> RaftNode {
  println()
  println("🔪 Discarding old logs before snapshot")
  println("   Keeping logs after index " + to_string(snapshot.lastIncludedIndex))

  // 스냅샷의 lastIncludedIndex 이후의 로그만 유지
  new_log = []
  for i = snapshot.lastIncludedIndex + 1; i <= last_log_index(node); i = i + 1 {
    entry = get_log_entry(node, i)
    if entry != null {
      new_log = new_log + [entry]
    }
  }

  println("   Old log size: " + to_string(len(node.log)))
  println("   New log size: " + to_string(len(new_log)))

  // 로그 크기 감소 계산
  reduction = len(node.log) - len(new_log)
  println("   ✅ Discarded " + to_string(reduction) + " entries")

  node.log = new_log

  return node
}

/// 전체 로그 압축 (스냅샷 생성 + 로그 제거)
fn compact_logs(node: RaftNode) -> (RaftNode, Snapshot) {
  println()
  println("🗜️  Compacting logs...")

  // 1. 스냅샷 생성
  snapshot = take_snapshot(node)

  // 2. 스냅샷 검증
  if !verify_snapshot(snapshot) {
    println("❌ Invalid snapshot, skipping compaction")
    return (node, snapshot)
  }

  // 3. 디스크에 저장
  success = save_snapshot_to_disk(node.id, snapshot)
  if !success {
    println("❌ Failed to save snapshot")
    return (node, snapshot)
  }

  // 4. 오래된 로그 제거
  node = discard_old_logs(node, snapshot)

  println("   ✅ Log compaction complete")

  return (node, snapshot)
}

