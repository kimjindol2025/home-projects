fn test_should_take_snapshot() {
  peers = [1, 2]
  node = create_raft_node(0, peers)

  // 로그가 작으면 스냅샷 불필요
  should_snap = should_take_snapshot(node)
  assert should_snap == false

  // 로그를 크게 늘리면 필요
  for i = 0; i < 1001; i = i + 1 {
    node = append_log(node, "cmd" + to_string(i))
  }

  should_snap = should_take_snapshot(node)
  assert should_snap == true

  println("✅ test_should_take_snapshot passed")
}

fn test_take_snapshot() {
  peers = [1, 2]
  node = create_raft_node(0, peers)
  node.state = NodeState.Leader

  node = append_log(node, "cmd1")
  node.lastApplied = 1

  snapshot = take_snapshot(node)

  assert snapshot.lastIncludedIndex == 1
  assert snapshot.state != ""

  println("✅ test_take_snapshot passed")
}

fn test_verify_snapshot() {
  snapshot = Snapshot {
