/// 스냅샷 상태 조회
fn get_snapshot_status(node: RaftNode, snapshot: Snapshot?) -> SnapshotMetadata {
  has_snapshot = snapshot != null

  last_index = 0
  last_term = 0
  state_size = 0

  if has_snapshot {
    last_index = snapshot.lastIncludedIndex
    last_term = snapshot.lastIncludedTerm
    state_size = len(snapshot.state)
  }

  return SnapshotMetadata {
    lastIncludedIndex: last_index,
    lastIncludedTerm: last_term,
    timestamp: 0,
    state_size: state_size
  }
}

