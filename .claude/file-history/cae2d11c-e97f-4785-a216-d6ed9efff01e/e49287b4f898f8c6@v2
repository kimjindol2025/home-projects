  valid = verify_snapshot(snapshot)
  assert valid == true

  println("✅ test_verify_snapshot passed")
}

fn test_discard_old_logs() {
  peers = [1, 2]
  node = create_raft_node(0, peers)

  node = append_log(node, "cmd1")
  node = append_log(node, "cmd2")
  node = append_log(node, "cmd3")

  snapshot = Snapshot {
    lastIncludedIndex: 1,
    lastIncludedTerm: 1,
    state: "{}"
  }

  node = discard_old_logs(node, snapshot)

  // cmd1은 제거, cmd2-cmd3는 유지
  assert len(node.log) == 2

  println("✅ test_discard_old_logs passed")
}

fn test_compact_logs() {
  peers = [1, 2]
  node = create_raft_node(0, peers)
  node.state = NodeState.Leader

  for i = 0; i < 10; i = i + 1 {
    node = append_log(node, "cmd" + to_string(i))
  }
  node.lastApplied = 5

  old_size = len(node.log)

  (node, snapshot) = compact_logs(node)

  assert snapshot.lastIncludedIndex == 5
  assert len(node.log) <= old_size

  println("✅ test_compact_logs passed")
}

