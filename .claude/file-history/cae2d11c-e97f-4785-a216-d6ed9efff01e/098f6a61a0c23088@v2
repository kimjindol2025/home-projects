  console.log('Test 3-6: 전체 프로세스 - 파일 배치 작업');
  try {
    const batchDir = path.join(testDir, 'batch');
    const dir = new Directory(batchDir);
    dir.create();

    // HashMap으로 배치 작업 관리
    const jobs = new HashMap<string, string>();
    jobs.set('job_1', 'processing');
    jobs.set('job_2', 'completed');
    jobs.set('job_3', 'pending');

    // 각 작업별 파일 생성
    let created = 0;
    jobs.forEach((status, jobId) => {
      const jobPath = path.join(batchDir, `${jobId}.log`);
      const jobFile = new FileHandle(jobPath, 'w');
      if (jobFile.open()) {
        jobFile.write(`Job: ${jobId}, Status: ${status}`);
        jobFile.close();
        created++;
      }
    });

    if (created === 3) {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log('  ❌ 실패\n');
      failed++;
