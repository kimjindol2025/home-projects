  console.log('Test 3-8: 전체 프로세스 - 인덱스 생성');
  try {
    const indexDir = path.join(testDir, 'indexed_files');
    const dir = new Directory(indexDir);
    dir.create();

    // 파일 생성
    ['page1.html', 'page2.html', 'style.css'].forEach(f => {
      fs.writeFileSync(path.join(indexDir, f), `content of ${f}`);
    });

    // 인덱스 생성 (경로 → 파일명)
    const index = new HashMap<string, string>();
    new Directory(indexDir).listFiles().forEach(f => {
      const fullPath = path.join(indexDir, f);
      index.set(fullPath, basename(f));
    });

    if (index.len() === 3) {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log('  ❌ 실패\n');
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 3-9: 전체 프로세스 - 폴더 백업
  console.log('Test 3-9: 전체 프로세스 - 폴더 백업');
  try {
    const srcDir = path.join(testDir, 'backup_src');
    const backupDir = path.join(testDir, 'backup_dest');

    new Directory(srcDir).create();
    fs.writeFileSync(path.join(srcDir, 'file1.txt'), 'backup content 1');
    fs.writeFileSync(path.join(srcDir, 'file2.txt'), 'backup content 2');

    new Directory(backupDir).create();

    // 모든 파일을 백업
    let backupCount = 0;
    new Directory(srcDir).listFiles().forEach(f => {
      const src = path.join(srcDir, f);
      const dst = path.join(backupDir, f);
      if (FileSystem.copy(src, dst)) {
        backupCount++;
      }
    });

    if (backupCount === 2) {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log('  ❌ 실패\n');
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // Test 3-10: 전체 프로세스 - 통계 리포트 생성
  console.log('Test 3-10: 전체 프로세스 - 통계 리포트 생성');
  try {
    const reportDir = path.join(testDir, 'reports');
    const dir = new Directory(reportDir);
    dir.create();

    // 통계 수집 (HashMap)
    const stats = new HashMap<string, number>();
    stats.set('total_files', 0);
    stats.set('total_size', 0);
    stats.set('file_count', 0);

    new Directory(testDir).listFiles().forEach(() => {
      stats.set('file_count', (stats.get('file_count') || 0) + 1);
    });

    // 리포트 생성
    const reportFile = new FileHandle(path.join(reportDir, 'report.txt'), 'w');
    if (reportFile.open()) {
      let reportContent = 'Integration Test Report\n\n';
      stats.forEach((value, key) => {
        reportContent += `${key}: ${value}\n`;
      });
      reportFile.write(reportContent);
      reportFile.close();
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log('  ❌ 실패\n');
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

  // ════════════════════════════════════════════════════════════
