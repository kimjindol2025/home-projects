    const config = new HashMap<string, string>();
    config.set('host', 'localhost');
    config.set('port', '3000');
    config.set('env', 'development');

    // JSON으로 저장
    const configPath = path.join(configDir, 'config.json');
    const configFile = new FileHandle(configPath, 'w');
    const jsonData = JSON.stringify(
      Object.fromEntries(config.entries()),
      null,
      2
    );

    if (configFile.open() && configFile.write(jsonData)) {
      configFile.close();

      // 다시 로드해서 확인
      const loadFile = new FileHandle(configPath, 'r');
      loadFile.open();
      const loaded = JSON.parse(loadFile.read());
      if (loaded.host === 'localhost' && loaded.port === '3000') {
        console.log('  ✅ 통과\n');
        passed++;
      } else {
        console.log('  ❌ 실패\n');
        failed++;
      }
      loadFile.close();
    } else {
      console.log('  ❌ 실패\n');
      failed++;
