      fs.writeFileSync(path.join(filesDir, f), 'content');
    });

    // Vector에 파일명 수집
    const fileList = new Vector<string>();
    new Directory(filesDir).listFiles().forEach(f => fileList.push(f));

    if (fileList.len() === 3) {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log('  ❌ 실패\n');
