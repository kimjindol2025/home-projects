  console.log('Test 3-5: 전체 프로세스 - 메타데이터 수집');
  try {
    const metaDir = path.join(testDir, 'metadata');
    const dir = new Directory(metaDir);
    dir.create();

    // 파일 생성
    const testFile = path.join(metaDir, 'test.txt');
    fs.writeFileSync(testFile, 'test metadata');

    // 메타데이터를 HashMap으로 수집
    const metadata = new HashMap<string, string | number>();
    metadata.set('path', testFile);
    metadata.set('basename', basename(testFile));
    metadata.set('dirname', dirname(testFile));
    metadata.set('extname', extname(testFile));
    metadata.set('size', FileSystem.size(testFile));

    if (metadata.len() === 5) {
      console.log('  ✅ 통과\n');
      passed++;
    } else {
      console.log('  ❌ 실패\n');
      failed++;
    }
  } catch (e) {
