  // Test 3-7: 전체 프로세스 - 캐시 시스템
  console.log('Test 3-7: 전체 프로세스 - 캐시 시스템');
  try {
    const cacheDir = path.join(testDir, 'cache');
    const dir = new Directory(cacheDir);
    dir.create();

    // HashMap을 캐시로 사용
    const cache = new HashMap<string, string>();
    cache.set('key1', 'value1');
    cache.set('key2', 'value2');

    // 캐시를 파일로 영속화
    const cacheFile = new FileHandle(path.join(cacheDir, 'cache.json'), 'w');
    if (cacheFile.open()) {
      const cacheData = JSON.stringify(Object.fromEntries(cache.entries()));
      cacheFile.write(cacheData);
      cacheFile.close();

      // 캐시 로드
      const loadFile = new FileHandle(path.join(cacheDir, 'cache.json'), 'r');
      loadFile.open();
      const loaded = JSON.parse(loadFile.read());
      if (loaded.key1 === 'value1') {
        console.log('  ✅ 통과\n');
        passed++;
      } else {
        console.log('  ❌ 실패\n');
        failed++;
      }
      loadFile.close();
    } else {
      console.log('  ❌ 실패\n');
      failed++;
    }
  } catch (e) {
    console.log(`  ❌ 오류: ${e}\n`);
    failed++;
  }

