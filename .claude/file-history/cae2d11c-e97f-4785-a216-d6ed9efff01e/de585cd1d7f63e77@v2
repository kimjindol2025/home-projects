# SSH Configuration for GRIE Development
# 사용법: ssh 253 또는 ssh linux-dev 등으로 접속

# 메인 개발 서버 (253)
Host 253
    HostName 192.168.45.253
    User kimjin
    IdentityFile ~/.ssh/id_ed25519
    Port 22
    ServerAliveInterval 60
    ServerAliveCountMax 3
    StrictHostKeyChecking accept-new

# 별칭으로도 접속 가능
Host linux-dev
    HostName 192.168.45.253
    User kimjin
    IdentityFile ~/.ssh/id_ed25519
    Port 22
    ServerAliveInterval 60
    ServerAliveCountMax 3

# 모바일 SSH (포트 포워딩)
Host mobile-ssh
    HostName 123.212.111.26
    User kimjin
    IdentityFile ~/.ssh/id_ed25519
    Port 22253
    ServerAliveInterval 60
    ServerAliveCountMax 3

# GOGS 저장소 접속
Host gogs
    HostName gogs.dclub.kr
    User git
    IdentityFile ~/.ssh/id_ed25519
    Port 2222
    StrictHostKeyChecking accept-new

# 기본 설정
Host *
    AddKeysToAgent yes
    IdentitiesOnly yes
    TCPKeepAlive yes
    Compression yes
