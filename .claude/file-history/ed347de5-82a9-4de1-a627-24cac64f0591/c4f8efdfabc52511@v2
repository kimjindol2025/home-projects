// 문제 3: 제곱 합
println("\n=== 문제 3: 제곱 합 ===")
fn sum_of_squares(nums: [i32]) -> i32 {
  var total: i32 = 0
  for num in nums {
    total = total + (num * num)
  }
  total
}

println(sum_of_squares([1, 2, 3]))
println(sum_of_squares([2, 3, 4]))

