// 문제 1: 절대값 차이
println("=== 문제 1: 절대값 차이 ===")
fn abs_diff(a: i32, b: i32) -> i32 {
  let diff: i32 = a - b
  if diff < 0 { -diff } else { diff }
}

println(abs_diff(5, 3))
println(abs_diff(3, 5))
println(abs_diff(-5, 3))

