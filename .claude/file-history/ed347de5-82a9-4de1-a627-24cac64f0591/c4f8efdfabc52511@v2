// 문제 6: 거듭제곱 (재귀)
println("\n=== 문제 6: 거듭제곱 ===")
fn power(base: i32, exp: i32) -> i32 {
  if exp == 0 {
    return 1
  }
  return base * power(base, exp - 1)
}

println(power(2, 10))
println(power(3, 4))

