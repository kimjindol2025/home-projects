// 문제 8: 고차 함수
println("\n=== 문제 8: 고차 함수 ===")
fn apply_to_all(nums: [i32], f: fn(i32) -> i32) -> [i32] {
  var result: [i32] = []
  for num in nums {
    result.push(f(num))
  }
  result
}

let nums: [i32] = [1, 2, 3]
let doubled: [i32] = apply_to_all(nums, |x: i32| { x * 2 })
for n in doubled {
  print(n)
  print(" ")
}
println()

// 문제 9: 구간 내 소수
println("\n=== 문제 9: 구간 내 소수 ===")
fn is_prime(n: i32) -> bool {
  if n < 2 { false }
  else {
    var i: i32 = 2
    while i * i <= n {
      if n % i == 0 { return false }
      i = i + 1
    }
    true
  }
}

fn primes_in_range(a: i32, b: i32) -> [i32] {
  var result: [i32] = []
  for i in a..=b {
    if is_prime(i) {
      result.push(i)
    }
  }
  result
}

let primes: [i32] = primes_in_range(10, 30)
for p in primes {
  print(p)
  print(" ")
}
println()

// 문제 10: 함수 파이프라인
println("\n=== 문제 10: 함수 파이프라인 ===")
fn pipeline(x: i32) -> str {
  let squared: i32 = x * x          // 제곱
  let doubled: i32 = squared * 2    // 2배
  str(doubled)                       // 문자열 변환
}

println(pipeline(3))  // (3^2)*2 = 18
println(pipeline(5))  // (5^2)*2 = 50
