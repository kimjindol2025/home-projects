// FreeLang 은행 시스템 - 7단계: 감시/로깅
// Status: ✅ 완전히 가능 (파일 로깅)

enum LogLevel {
  DEBUG,
  INFO,
  WARN,
  ERROR,
  CRITICAL
}

enum MetricType {
  TransactionCount,
  TotalVolume,
  AverageBalance,
  ErrorRate,
  ResponseTime
}

struct LogEntry {
  timestamp: str,
  level: LogLevel,
  module: str,
  message: str,
  details: str
}

struct Metric {
  name: str,
  metric_type: MetricType,
  value: f64,
  timestamp: str
}

struct SystemMonitor {
  log_file: str,
  metrics_file: str,
  enabled: bool
}

impl SystemMonitor {
  fn new(log_dir: str) -> SystemMonitor {
    SystemMonitor {
      log_file: format!("{}/bank.log", log_dir),
      metrics_file: format!("{}/metrics.csv", log_dir),
      enabled: true
    }
  }

  // 로그 기록
  fn log(&self, level: LogLevel, module: str, message: str) {
    if !self.enabled {
      return
    }

    let level_str = match level {
      LogLevel::DEBUG => "DEBUG",
      LogLevel::INFO => "INFO",
      LogLevel::WARN => "WARN",
      LogLevel::ERROR => "ERROR",
      LogLevel::CRITICAL => "CRITICAL"
    }

    let timestamp = self.get_timestamp()
    let log_message = format!(
      "[{}] {} - {} - {}",
      timestamp,
      level_str,
      module,
      message
    )

    // 파일에 기록
    self.write_to_file(&self.log_file, &log_message)

    // 콘솔에도 출력
    match level {
      LogLevel::ERROR => println(format!("❌ {}", log_message)),
      LogLevel::CRITICAL => println(format!("🚨 {}", log_message)),
      LogLevel::WARN => println(format!("⚠️  {}", log_message)),
      _ => println(log_message)
    }
  }

  // 상세 로그 (에러 정보 포함)
  fn log_with_details(&self, level: LogLevel, module: str, message: str, details: str) {
    self.log(level, module, format!("{} [Details: {}]", message, details))
  }

  // 트랜잭션 로그
  fn log_transaction(&self, account_id: str, tx_type: str, amount: f64, success: bool) {
    let status = if success { "SUCCESS" } else { "FAILED" }
    let message = format!(
      "Transaction: {} | Account: {} | Type: {} | Amount: {}원 | Status: {}",
      self.get_timestamp(),
      account_id,
      tx_type,
      amount,
      status
    )
    self.log(LogLevel::INFO, "TRANSACTION", &message)
  }

  // 에러 로그
  fn log_error(&self, module: str, error_code: i32, message: str) {
    let error_msg = format!("Error Code: {} - {}", error_code, message)
    self.log(LogLevel::ERROR, module, &error_msg)
  }

  // 메트릭 기록
  fn record_metric(&self, metric: &Metric) {
    if !self.enabled {
      return
    }

    let csv_line = format!(
      "{},{},{},{}",
      metric.timestamp,
      metric.name,
      metric.metric_type.to_string(),
      metric.value
    )

    self.write_to_file(&self.metrics_file, &csv_line)
  }

  // 통계 생성
  fn generate_statistics(&self) -> SystemStatistics {
    SystemStatistics {
      total_transactions: 0,
      total_volume: 0.0,
      error_count: 0,
      average_response_time: 0.0,
      uptime_seconds: 0
    }
  }

  // 헬스 체크
  fn health_check(&self) -> HealthStatus {
    HealthStatus {
      status: "healthy".to_string(),
      message: "시스템 정상 운영 중".to_string(),
      timestamp: self.get_timestamp(),
      details: HealthDetails {
        disk_usage_percent: 45.0,
        memory_usage_mb: 256.0,
        connected_accounts: 1000,
        active_transactions: 25
      }
    }
  }

  // 성능 분석
  fn analyze_performance(&self) -> PerformanceAnalysis {
    PerformanceAnalysis {
      peak_hour: 14,
      average_transaction_time_ms: 125.0,
      slowest_operation: "withdraw".to_string(),
      fastest_operation: "balance_check".to_string(),
      bottleneck: "database_io".to_string()
    }
  }

  // 감시 알람 (임계값 초과)
  fn check_thresholds(&self) {
    let error_rate = self.calculate_error_rate()
    if error_rate > 0.05 { // 5% 이상
      self.log(LogLevel::CRITICAL, "ALERT",
        format!("높은 에러율 감지: {:.2}%", error_rate * 100.0))
    }

    let response_time = self.calculate_average_response_time()
    if response_time > 500.0 { // 500ms 이상
      self.log(LogLevel::WARN, "ALERT",
        format!("응답 시간 증가: {:.2}ms", response_time))
    }
  }

  // ============ 내부 헬퍼 메서드 ============

  fn get_timestamp(&self) -> str {
    "2026-03-02 10:30:00" // 실제로는 현재 시간 사용
  }

  fn write_to_file(&self, path: str, content: str) {
    // 실제로는 파일 I/O 수행
    // File::append(&content)
  }

  fn calculate_error_rate(&self) -> f64 {
    // 메트릭에서 에러율 계산
    0.02 // 2% (예시)
  }

  fn calculate_average_response_time(&self) -> f64 {
    // 메트릭에서 평균 응답 시간 계산
    125.0 // ms (예시)
  }
}

struct SystemStatistics {
  total_transactions: i32,
  total_volume: f64,
  error_count: i32,
  average_response_time: f64,
  uptime_seconds: i32
}

struct HealthStatus {
  status: str,
  message: str,
  timestamp: str,
  details: HealthDetails
}

struct HealthDetails {
  disk_usage_percent: f64,
  memory_usage_mb: f64,
  connected_accounts: i32,
  active_transactions: i32
}

struct PerformanceAnalysis {
  peak_hour: i32,
  average_transaction_time_ms: f64,
  slowest_operation: str,
  fastest_operation: str,
  bottleneck: str
}

impl MetricType {
  fn to_string(&self) -> str {
    match self {
      MetricType::TransactionCount => "transaction_count",
      MetricType::TotalVolume => "total_volume",
      MetricType::AverageBalance => "average_balance",
      MetricType::ErrorRate => "error_rate",
      MetricType::ResponseTime => "response_time"
    }
  }
}

// 테스트
fn main() {
  println("=== 감시/로깅 테스트 ===")

  var monitor = SystemMonitor::new("/logs/bank")

  println("\n--- 일반 로그 ---")
  monitor.log(LogLevel::INFO, "SYSTEM", "은행 시스템 시작")
  monitor.log(LogLevel::DEBUG, "INIT", "데이터베이스 연결")

  println("\n--- 트랜잭션 로그 ---")
  monitor.log_transaction("ACC-001", "deposit", 100000.0, true)
  monitor.log_transaction("ACC-002", "withdraw", 50000.0, true)
  monitor.log_transaction("ACC-003", "transfer", 25000.0, false)

  println("\n--- 에러 로그 ---")
  monitor.log_error("VALIDATION", 1005, "예금주 이름이 비어있습니다")
  monitor.log_error("ACCOUNT", 1003, "계좌를 찾을 수 없음: ACC-999")

  println("\n--- 메트릭 기록 ---")
  var metric1 = Metric {
    name: "transactions_per_minute",
    metric_type: MetricType::TransactionCount,
    value: 120.0,
    timestamp: "2026-03-02 10:30:00"
  }
  monitor.record_metric(&metric1)

  var metric2 = Metric {
    name: "total_transaction_volume",
    metric_type: MetricType::TotalVolume,
    value: 5000000.0,
    timestamp: "2026-03-02 10:30:00"
  }
  monitor.record_metric(&metric2)

  println("\n--- 헬스 체크 ---")
  let health = monitor.health_check()
  println(format!("상태: {}", health.status))
  println(format!("디스크 사용률: {:.1}%", health.details.disk_usage_percent))
  println(format!("메모리 사용: {:.0}MB", health.details.memory_usage_mb))
  println(format!("활성 거래: {}", health.details.active_transactions))

  println("\n--- 성능 분석 ---")
  let perf = monitor.analyze_performance()
  println(format!("피크 시간: {}시", perf.peak_hour))
  println(format!("평균 거래 시간: {:.2}ms", perf.average_transaction_time_ms))
  println(format!("병목: {}", perf.bottleneck))

  println("\n--- 통계 생성 ---")
  let stats = monitor.generate_statistics()
  println(format!("전체 거래: {} 건", stats.total_transactions))
  println(format!("총 거래액: {}원", stats.total_volume))
  println(format!("에러 건수: {} 건", stats.error_count))

  println("\n--- 임계값 확인 ---")
  monitor.check_thresholds()
}
