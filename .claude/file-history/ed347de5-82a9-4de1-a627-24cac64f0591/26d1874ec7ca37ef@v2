// 문제 6: 소수 판별
println("\n=== 문제 6: 소수 판별 ===")
fn problem6_is_prime(n: i32) -> bool {
  if n < 2 {
    return false
  }

  if n == 2 {
    return true
  }

  if n % 2 == 0 {
    return false
  }

  for i in 3..=(n / 2) {
    if n % i == 0 {
      return false
    }
  }
  return true
}

let test_primes: [i32] = [7, 12, 17, 20, 29]
for num in test_primes {
  let is_prime: bool = problem6_is_prime(num)
  if is_prime {
    printf("{}: 소수\\n", num)
  } else {
    printf("{}: 소수 아님\\n", num)
  }
}

// 문제 7: 팩토리얼 계산
println("\n=== 문제 7: 팩토리얼 ===")
fn problem7_factorial(n: i32) -> i32 {
  if n <= 1 {
    return 1
  }

  let mut result: i32 = 1
  for i in 2..=n {
    result = result * i
  }
  return result
}

for n in [1, 2, 3, 4, 5, 6] {
  let fact: i32 = problem7_factorial(n)
  printf("{}! = {}\\n", n, fact)
}

