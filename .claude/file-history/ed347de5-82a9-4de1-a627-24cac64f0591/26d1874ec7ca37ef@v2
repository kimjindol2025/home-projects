// 문제 10: 피보나치 수열
println("\n=== 문제 10: 피보나치 수열 ===")
fn problem10_fibonacci(n: i32) -> i32 {
  if n <= 1 {
    return 1
  }

  var a: i32 = 1
  var b: i32 = 1

  for i in 2..n {
    let temp: i32 = a + b
    a = b
    b = temp
  }

  return b
}

println("피보나치 수열 (1~12):")
for i in 1..=12 {
  let fib: i32 = problem10_fibonacci(i)
  printf("F({}) = {} ", i, fib)
}
