println("\n=== 문제 5: 최댓값 찾기 ===")
fn problem5_find_max(numbers: [i32]) -> i32 {
  var max: i32 = numbers[0]
  for num in numbers {
    if num > max {
      max = num
    }
  }
  return max
}

