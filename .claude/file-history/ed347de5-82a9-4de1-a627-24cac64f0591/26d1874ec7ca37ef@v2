println("\n=== 문제 8: 문자열 역순 ===")
fn problem8_reverse_string(s: str) -> str {
  let chars: [char] = s.to_chars()
  var reversed: str = ""

  // 역순 순회 (원본 문자열 길이에서 1씩 감소)
  for i in (0..chars.length()) {
    let index: i32 = (chars.length() - 1 - i) as i32
    reversed = reversed + char_to_string(chars[index as usize])
  }

  return reversed
}

let test_strings: [str] = ["hello", "FreeLang", "racecar"]
for test_str in test_strings {
  let rev: str = problem8_reverse_string(test_str)
  printf("원본: {}, 역순: {}\\n", test_str, rev)
}

