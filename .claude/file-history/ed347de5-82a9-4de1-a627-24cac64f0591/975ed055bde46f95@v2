// Level 2: 기본 예시 파일
// 조건문과 반복문 기초

// 예시 1: if-else 기본
println("=== 예시 1: if-else 기본 ===")
let age: i32 = 25
if age >= 18 {
  println("성인입니다")
} else {
  println("미성년자입니다")
}

// 예시 2: if-else if-else (학점)
println("\n=== 예시 2: 학점 판정 ===")
let score: i32 = 85
if score >= 90 {
  println("A학점 (90~100)")
} else if score >= 80 {
  println("B학점 (80~89)")
} else if score >= 70 {
  println("C학점 (70~79)")
} else {
  println("F학점 (70 미만)")
}

// 예시 3: 논리 연산자
println("\n=== 예시 3: 논리 연산자 ===")
let x: i32 = 15
if (x > 10) && (x < 20) {
  println("x는 10과 20 사이입니다")
}

if (x < 5) || (x > 30) {
  println("x는 5 미만이거나 30 초과입니다")
} else {
  println("x는 5 이상 30 이하입니다")
}

// 예시 4: match 문
println("\n=== 예시 4: match 문 ===")
let day: i32 = 3
let day_name = match day {
  1 => "월요일",
  2 => "화요일",
  3 => "수요일",
  4 => "목요일",
  5 => "금요일",
  6 => "토요일",
  7 => "일요일",
  _ => "알 수 없음"
}
println(day_name)

// 예시 5: for 루프 기본
println("\n=== 예시 5: for 루프 (범위) ===")
for i in 1..=5 {
  println(i)
}

// 예시 6: for 루프 배열
println("\n=== 예시 6: for 루프 (배열) ===")
let fruits: [str] = ["apple", "banana", "cherry", "date"]
for fruit in fruits {
  println(fruit)
}

// 예시 7: while 루프
println("\n=== 예시 7: while 루프 ===")
var count: i32 = 1
while count <= 5 {
  println(count)
  count = count + 1
}

// 예시 8: break
println("\n=== 예시 8: break ===")
for i in 1..=10 {
  if i == 6 {
    break
  }
  println(i)
}
println("루프 종료")

// 예시 9: continue
println("\n=== 예시 9: continue (짝수만) ===")
for i in 1..=10 {
  if i % 2 != 0 {
    continue  // 홀수는 건너뛰기
  }
  println(i)
}

// 예시 10: 중첩 루프 (구구단)
println("\n=== 예시 10: 3단 구구단 ===")
let dan: i32 = 3
for i in 1..=9 {
  let result: i32 = dan * i
  printf("{}×{} = {}\\n", dan, i, result)
}
