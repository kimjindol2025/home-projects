{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "lib": ["ES2021", "DOM", "WebWorker"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "noImplicitAny": false,
    "downlevelIteration": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "tests", "src/phase-18/**", "src/phase-2*/**", "src/phase-3*/**", "src/phase-4*/**", "src/lsp/**", "src/macro/**", "src/type-system/**", "src/type-checker/**"]
}
