// 예시 4: 다중 반환값
println("\n=== 예시 4: 다중 반환값 ===")
fn divide_mod(a: i32, b: i32) -> (i32, i32) {
  return (a / b, a % b)
}

let (q, r) = divide_mod(17, 5)
printf("몫: {}, 나머지: {}\\n", q, r)

