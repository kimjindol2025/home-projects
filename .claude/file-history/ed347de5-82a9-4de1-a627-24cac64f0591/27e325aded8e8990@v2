// 예시 8: 배열 처리
println("\n=== 예시 8: 배열 처리 ===")
fn array_sum(nums: [i32]) -> i32 {
  var total: i32 = 0
  for num in nums {
    total = total + num
  }
  total
}

let numbers: [i32] = [1, 2, 3, 4, 5]
println(array_sum(numbers))

