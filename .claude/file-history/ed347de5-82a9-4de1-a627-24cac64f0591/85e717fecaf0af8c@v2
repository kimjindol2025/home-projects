// 예시 5: 문자열 역순
println("\n=== 예시 5: 문자열 역순 ===")
fn reverse_string(s: str) -> str {
  let chars: [char] = s.to_chars()
  let mut reversed: str = ""

  // 뒤에서 앞으로 순회
  for i in (0..chars.length()).rev() {
    reversed = reversed + char_to_string(chars[i])
  }

  return reversed
}

let original: str = "FreeLang"
let reversed: str = reverse_string(original)
printf("원본: {}, 역순: {}\\n", original, reversed)

// 예시 6: 합계 및 평균
println("\n=== 예시 6: 합계 및 평균 ===")
fn calculate_stats(numbers: [i32]) -> (i32, f64) {
  var sum: i32 = 0

  for num in numbers {
    sum = sum + num
  }

  let average: f64 = sum as f64 / numbers.length() as f64
  return (sum, average)
}

let data: [i32] = [10, 20, 30, 40, 50]
let (total, avg) = calculate_stats(data)
printf("합계: {}, 평균: {:.2f}\\n", total, avg)

