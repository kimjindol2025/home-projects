// 예시 9: 피보나치 수열
println("\n=== 예시 9: 피보나치 (1~10) ===")
fn fibonacci(n: i32) -> i32 {
  if n <= 1 {
    return 1
  }

  var a: i32 = 1
  var b: i32 = 1

  for i in 2..n {
    let temp: i32 = a + b
    a = b
    b = temp
  }

  return b
}

for i in 1..=10 {
  let fib: i32 = fibonacci(i)
  printf("F({}) = {}, ", i, fib)
}
println()

