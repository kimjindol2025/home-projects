// 예시 1: 소수 판별
println("=== 예시 1: 소수 판별 ===")
fn is_prime(n: i32) -> bool {
  if n < 2 {
    return false
  }

  for i in 2..=(n / 2) {
    if n % i == 0 {
      return false
    }
  }
  return true
}

let test_num: i32 = 17
if is_prime(test_num) {
  println("17은 소수입니다")
} else {
  println("17은 소수가 아닙니다")
}

// 예시 2: 팩토리얼 계산
println("\n=== 예시 2: 팩토리얼 ===")
fn factorial(n: i32) -> i32 {
  if n <= 1 {
    return 1
  }

  let mut result: i32 = 1
  for i in 2..=n {
    result = result * i
  }
  return result
}

printf("5! = {}\\n", factorial(5))  // 120
printf("6! = {}\\n", factorial(6))  // 720

// 예시 3: 최댓값과 최솟값 찾기
println("\n=== 예시 3: 최댓값/최솟값 ===")
fn find_max_min(numbers: [i32]) -> (i32, i32) {
  var max: i32 = numbers[0]
  var min: i32 = numbers[0]

  for num in numbers {
    if num > max {
      max = num
    }
    if num < min {
      min = num
    }
  }

  return (max, min)
}

let nums: [i32] = [15, 23, 8, 42, 16, 3, 38]
let (maximum, minimum) = find_max_min(nums)
printf("최댓값: {}, 최솟값: {}\\n", maximum, minimum)

