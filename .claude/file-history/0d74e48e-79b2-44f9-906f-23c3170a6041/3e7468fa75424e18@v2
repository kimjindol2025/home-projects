// ============================================================================
// Benchmark 4: JSON Stringification
// ============================================================================

/// JSON 직렬화 성능 측정
pub fn bench_json_stringify() -> StdlibBenchResult {
    let iterations = 10_000u64;

    // 테스트용 객체 생성
    let obj = FlValue::Object(
        vec![
            ("name".to_string(), FlValue::Str("test".to_string())),
            ("value".to_string(), FlValue::Int(42)),
            ("active".to_string(), FlValue::Bool(true)),
        ]
        .into_iter()
        .collect(),
    );

    let start = Instant::now();

    for _ in 0..iterations {
        let _ = json::json_stringify(&obj);
    }

    let elapsed = start.elapsed().as_millis();
    StdlibBenchResult::new("json_stringify", iterations, elapsed)
}

// ============================================================================
// Benchmark 5: Array Map Operation
// ============================================================================

/// Array map 성능 측정
pub fn bench_array_map() -> StdlibBenchResult {
    let iterations = 5_000u64;

    let arr = FlValue::Array(
        (0..100)
            .map(|i| FlValue::Int(i))
            .collect(),
    );

    let start = Instant::now();

    for _ in 0..iterations {
        let _ = array::map(&arr, |v| {
            match v {
                FlValue::Int(n) => FlValue::Int(n * 2),
                _ => v,
            }
        });
    }

    let elapsed = start.elapsed().as_millis();
    StdlibBenchResult::new("array_map", iterations * 100, elapsed)
}

// ============================================================================
// Benchmark 6: Array Filter Operation
// ============================================================================

/// Array filter 성능 측정
pub fn bench_array_filter() -> StdlibBenchResult {
    let iterations = 5_000u64;

    let arr = FlValue::Array(
        (0..100)
            .map(|i| FlValue::Int(i))
            .collect(),
    );

    let start = Instant::now();

    for _ in 0..iterations {
        let _ = array::filter(&arr, |v| {
            matches!(v, FlValue::Int(n) if *n % 2 == 0)
        });
    }

    let elapsed = start.elapsed().as_millis();
    StdlibBenchResult::new("array_filter", iterations * 100, elapsed)
}

// ============================================================================
// Benchmark 7: Array Reduce Operation
// ============================================================================

/// Array reduce (합산) 성능 측정
pub fn bench_array_reduce() -> StdlibBenchResult {
    let iterations = 5_000u64;

    let arr = FlValue::Array(
        (0..100)
            .map(|i| FlValue::Int(i))
            .collect(),
    );

    let start = Instant::now();

    for _ in 0..iterations {
        let _ = array::reduce(&arr, |acc, v| {
            match (acc, v) {
                (FlValue::Int(a), FlValue::Int(b)) => FlValue::Int(a + b),
                _ => acc,
            }
        }, FlValue::Int(0));
    }

    let elapsed = start.elapsed().as_millis();
    StdlibBenchResult::new("array_reduce", iterations * 100, elapsed)
}

// ============================================================================
// Benchmark 8: Math Trigonometric Functions
// ============================================================================

/// 삼각함수 성능 측정
pub fn bench_math_trig() -> StdlibBenchResult {
    let iterations = 100_000u64;

    let start = Instant::now();

    for i in 0..iterations {
        let angle = (i as f64) * 0.01; // 0.0 ~ 1000.0
        let _ = math::sin(FlValue::Float(angle));
        let _ = math::cos(FlValue::Float(angle));
    }

    let elapsed = start.elapsed().as_millis();
    StdlibBenchResult::new("math_trig", iterations * 2, elapsed)
}

