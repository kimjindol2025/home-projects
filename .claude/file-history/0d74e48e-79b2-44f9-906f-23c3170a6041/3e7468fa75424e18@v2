// Benchmark Runner
// ============================================================================

/// 모든 stdlib 벤치마크 실행
pub fn run_all_stdlib_benchmarks() -> Vec<StdlibBenchResult> {
    println!("╔════════════════════════════════════════════════════════╗");
    println!("║  FreeLang Phase D.2 - Stdlib Module Benchmarks        ║");
    println!("╚════════════════════════════════════════════════════════╝\n");

    let mut results = vec![];

    println!("Running benchmarks...\n");

    // 1. String Split
    println!("⏱️  Benchmark 1/10: String Split");
    let result = bench_string_split();
    result.print();
    results.push(result);
    println!();

    // 2. String Join
    println!("⏱️  Benchmark 2/10: String Join");
    let result = bench_string_join();
    result.print();
    results.push(result);
    println!();

    // 3. JSON Parsing
    println!("⏱️  Benchmark 3/10: JSON Parsing");
    let result = bench_json_parsing();
    result.print();
    results.push(result);
    println!();

    // 4. JSON Stringify
    println!("⏱️  Benchmark 4/10: JSON Stringify");
    let result = bench_json_stringify();
    result.print();
    results.push(result);
    println!();

    // 5. Array Map
    println!("⏱️  Benchmark 5/10: Array Map");
    let result = bench_array_map();
    result.print();
    results.push(result);
    println!();

    // 6. Array Filter
    println!("⏱️  Benchmark 6/10: Array Filter");
    let result = bench_array_filter();
    result.print();
    results.push(result);
    println!();

    // 7. Array Reduce
    println!("⏱️  Benchmark 7/10: Array Reduce");
    let result = bench_array_reduce();
    result.print();
    results.push(result);
    println!();

    // 8. Math Trig
    println!("⏱️  Benchmark 8/10: Math Trigonometric");
    let result = bench_math_trig();
    result.print();
    results.push(result);
    println!();

    // 9. String Case Conversion
    println!("⏱️  Benchmark 9/10: String Case Conversion");
    let result = bench_string_case_conversion();
    result.print();
    results.push(result);
    println!();

    // 10. Array Sort
    println!("⏱️  Benchmark 10/10: Array Sort");
    let result = bench_array_sort();
    result.print();
    results.push(result);
    println!();

    println!("╔════════════════════════════════════════════════════════╗");
    println!("║  Summary                                               ║");
    println!("╠════════════════════════════════════════════════════════╣");

    // 성능 순위
    let mut sorted = results.clone();
    sorted.sort_by(|a, b| b.throughput.partial_cmp(&a.throughput).unwrap());

    println!("Top 3 Fastest (by throughput):");
    for (i, result) in sorted.iter().take(3).enumerate() {
        println!(
            "  {}. {} - {:.1}K ops/s",
            i + 1,
            result.name,
            result.throughput / 1_000.0
        );
    }

    println!("\nLowest Latency:");
    let mut latency_sorted = results.clone();
    latency_sorted.sort_by(|a, b| a.latency_us.partial_cmp(&b.latency_us).unwrap());

    for (i, result) in latency_sorted.iter().take(3).enumerate() {
        println!(
            "  {}. {} - {:.2}μs/op",
            i + 1,
            result.name,
            result.latency_us
        );
    }

    println!("╚════════════════════════════════════════════════════════╝\n");

    results
}

// ============================================================================
// Statistics Helper
// ============================================================================

/// 벤치마크 결과 통계 출력
pub fn print_stdlib_benchmark_stats(results: &[StdlibBenchResult]) {
    println!("Stdlib Benchmark Statistics:");
    println!("─────────────────────────────────────────────");

    let total_ops: u64 = results.iter().map(|r| r.operations).sum();
    let avg_throughput: f64 = results.iter().map(|r| r.throughput).sum::<f64>() / results.len() as f64;
    let avg_latency: f64 = results.iter().map(|r| r.latency_us).sum::<f64>() / results.len() as f64;

    println!("Total Operations: {:,}", total_ops);
    println!("Average Throughput: {:.1}K ops/s", avg_throughput / 1_000.0);
    println!("Average Latency: {:.2}μs/op", avg_latency);
    println!("─────────────────────────────────────────────");
}

