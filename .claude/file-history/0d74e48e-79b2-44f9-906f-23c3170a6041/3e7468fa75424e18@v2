// ============================================================================
// Benchmark 10: Array Sort Operation
// ============================================================================

/// Array sort 성능 측정
pub fn bench_array_sort() -> StdlibBenchResult {
    let iterations = 1_000u64;

    // 1000개 원소의 배열
    let arr = FlValue::Array(
        (0..1000)
            .rev() // 역순으로 정렬되지 않음
            .map(|i| FlValue::Int(i))
            .collect(),
    );

    let start = Instant::now();

    for _ in 0..iterations {
        let _ = array::sort(&arr);
    }

    let elapsed = start.elapsed().as_millis();
    StdlibBenchResult::new("array_sort", iterations * 1000, elapsed)
}

