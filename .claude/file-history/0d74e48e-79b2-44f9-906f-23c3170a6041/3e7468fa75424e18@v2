// ============================================================================
// BenchResult - 벤치마크 결과 구조
// ============================================================================

#[derive(Clone, Debug)]
pub struct StdlibBenchResult {
    /// 벤치마크 이름
    pub name: String,

    /// 수행 작업 수
    pub operations: u64,

    /// 소요 시간 (밀리초)
    pub elapsed_ms: u128,

    /// 초당 처리량 (ops/sec)
    pub throughput: f64,

    /// 평균 지연시간 (마이크로초)
    pub latency_us: f64,
}

impl StdlibBenchResult {
    /// 새 벤치마크 결과 생성
    pub fn new(name: &str, operations: u64, elapsed_ms: u128) -> Self {
        let throughput = if elapsed_ms > 0 {
            (operations as f64) / (elapsed_ms as f64) * 1000.0
        } else {
            0.0
        };

        let latency_us = if operations > 0 {
            (elapsed_ms as f64) * 1000.0 / (operations as f64)
        } else {
            0.0
        };

        StdlibBenchResult {
            name: name.to_string(),
            operations,
            elapsed_ms,
            throughput,
            latency_us,
        }
    }

    /// 결과를 표준 포맷으로 출력
    pub fn print(&self) {
        println!(
            "[BENCH] {}: {:,} ops in {}ms ({:.1}K ops/s, {:.2}μs/op)",
            self.name,
            self.operations,
            self.elapsed_ms,
            self.throughput / 1_000.0,
            self.latency_us
        );
    }
}

// ============================================================================
// Benchmark 1: String Split Operations
// ============================================================================

/// 문자열 split 성능 측정
pub fn bench_string_split() -> StdlibBenchResult {
    let iterations = 10_000u64;
    let text = "apple,banana,cherry,date,elderberry,fig,grape,honeydew".to_string();
    let delimiter = ",".to_string();

    let start = Instant::now();

    for _ in 0..iterations {
        let _ = string::split(&text, &delimiter);
    }

    let elapsed = start.elapsed().as_millis();
    StdlibBenchResult::new("string_split", iterations, elapsed)
}

