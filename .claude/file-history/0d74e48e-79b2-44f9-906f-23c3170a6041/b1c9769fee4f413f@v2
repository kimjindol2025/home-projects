    fn test_cli_args_parse_multiple_flags() {
        let args_vec = vec![
            "freelang".to_string(),
            "--debug".to_string(),
            "-v".to_string(),
            "--time".to_string(),
            "program.fl".to_string(),
        ];
        let args = CliArgs::parse(args_vec);
        assert!(args.debug_mode == true);
        assert!(args.verbose == true);
        assert!(args.measure_time == true);
        assert_eq!(args.input_file, Some("program.fl".to_string()));
