/// 도움말을 출력합니다
fn print_help() {
    println!("{} {} - Interactive Programming Language", PROGRAM_NAME, VERSION);
    println!();
    println!("USAGE:");
    println!("    freelang [OPTIONS] [FILE]");
    println!();
    println!("EXAMPLES:");
    println!("    freelang program.fl              # Run a file");
    println!("    freelang --eval \"1 + 1\"         # Evaluate code");
    println!("    freelang --repl                  # Start REPL");
    println!("    freelang --debug program.fl      # Run with debug output");
    println!("    freelang --check program.fl      # Parse only (no execution)");
    println!();
    println!("OPTIONS:");
    println!("    --eval <CODE>, -e <CODE>         Evaluate code directly");
    println!("    --repl                           Start interactive REPL");
    println!("    --debug                          Enable debug mode");
    println!("    --verbose, -v                    Verbose output");
    println!("    --time                           Measure execution time");
    println!("    --check                          Parse only (no execution)");
    println!("    --version                        Show version");
    println!("    --help, -h                       Show this help");
    println!();
    println!("ENVIRONMENT:");
    println!("    FREELANG_DEBUG   Set to 1 to enable debug mode");
    println!("    FREELANG_TIMEOUT Set timeout in seconds (default: 300)");
    println!();
    println!("For more information, visit: https://freelang.dev");
}

/// 버전 정보를 출력합니다
fn print_version() {
    println!("{} {}", PROGRAM_NAME, VERSION);
    println!("Author: {}", AUTHOR);
    println!("Built: 2026-03-02");
}

/// 파일을 실행합니다
fn run_file(
    path: &str,
    args: &CliArgs,
    runtime: &mut r#mod::FreeLangRuntime,
) -> ExitCode {
    if args.verbose {
        println!("📂 Loading file: {}", path);
    }

    match fs::read_to_string(path) {
        Ok(source) => {
            if args.check_only {
                if args.verbose {
                    println!("🔍 Parsing file (check mode)...");
                }
                match runtime.parse_only(&source) {
                    Ok(_) => {
                        println!("✅ Syntax check passed");
                        ExitCode::Success
                    },
                    Err(e) => {
                        eprintln!("❌ Parse error: {}", e);
                        ExitCode::ParseError
                    }
                }
            } else {
                let start = if args.measure_time { Some(Instant::now()) } else { None };

                match runtime.execute_source(&source) {
                    Ok(_) => {
                        if let Some(start_time) = start {
                            let elapsed = start_time.elapsed().as_millis();
                            println!("⏱️  Execution time: {}ms", elapsed);
                        }

                        if args.verbose {
                            println!("{}", runtime.get_statistics());
                        }

                        ExitCode::Success
                    },
                    Err(e) => {
                        eprintln!("❌ Runtime error: {}", e);
                        if args.debug_mode {
                            eprintln!("Debug info: {:?}", e);
                        }
                        ExitCode::RuntimeError
                    }
                }
            }
        },
        Err(e) => {
            eprintln!("❌ IO error: Cannot read file '{}': {}", path, e);
            ExitCode::IoError
        }
    }
}

/// 코드를 직접 실행합니다
fn run_eval(
    code: &str,
    args: &CliArgs,
    runtime: &mut r#mod::FreeLangRuntime,
) -> ExitCode {
    if args.verbose {
        println!("▶️  Evaluating code: {}", code);
    }

    if args.check_only {
        match runtime.parse_only(code) {
            Ok(_) => {
                println!("✅ Syntax check passed");
                ExitCode::Success
            },
            Err(e) => {
                eprintln!("❌ Parse error: {}", e);
                ExitCode::ParseError
            }
        }
    } else {
        let start = if args.measure_time { Some(Instant::now()) } else { None };

        match runtime.execute_source(code) {
            Ok(result) => {
                println!("→ {:?}", result);

                if let Some(start_time) = start {
                    let elapsed = start_time.elapsed().as_millis();
                    println!("⏱️  Execution time: {}ms", elapsed);
                }

                if args.verbose {
                    println!("{}", runtime.get_statistics());
                }

                ExitCode::Success
            },
            Err(e) => {
                eprintln!("❌ Runtime error: {}", e);
                ExitCode::RuntimeError
            }
        }
    }
}

/// REPL을 시작합니다
fn run_repl(args: &CliArgs, runtime: &mut r#mod::FreeLangRuntime) -> ExitCode {
    if args.verbose {
        println!("🎯 Starting FreeLang REPL v{}", VERSION);
    }

    runtime.start_repl();
    ExitCode::Success
}

/// 환경 변수에서 설정을 로드합니다
fn load_env_config(args: &mut CliArgs) {
    if env::var("FREELANG_DEBUG").is_ok() {
        args.debug_mode = true;
    }
}

// ============================================================================
// main 함수
// ============================================================================

fn main() {
    let args_vec: Vec<String> = env::args().collect();
    let mut args = CliArgs::parse(args_vec);

    // 환경 변수 설정 로드
    load_env_config(&mut args);

    // 옵션 검증
    if let Err(e) = args.validate() {
        eprintln!("❌ {}", e);
        process::exit(ExitCode::UsageError as i32);
    }

    // 특수 옵션 처리
    if args.show_help {
        print_help();
        process::exit(ExitCode::Success as i32);
    }

    if args.show_version {
        print_version();
        process::exit(ExitCode::Success as i32);
    }

    // 런타임 설정
    let config = if args.debug_mode {
        r#mod::RuntimeConfig::development()
    } else {
        r#mod::RuntimeConfig::default()
    };

    let mut runtime = r#mod::FreeLangRuntime::with_config(config);
    runtime.initialize();

    // 실행 모드 결정
    let exit_code = if let Some(code) = args.eval_code {
        // --eval 모드
        run_eval(&code, &args, &mut runtime)
    } else if let Some(file_path) = args.input_file {
        // 파일 실행 모드
        run_file(&file_path, &args, &mut runtime)
    } else if args.should_start_repl() {
        // REPL 모드
        run_repl(&args, &mut runtime)
    } else {
        // 기본값: 파일 없으면 에러
        eprintln!("❌ Error: No input file or command specified");
        eprintln!("Use 'freelang --help' for usage information");
        ExitCode::UsageError
    };

    runtime.shutdown();
    process::exit(exit_code as i32);
}

