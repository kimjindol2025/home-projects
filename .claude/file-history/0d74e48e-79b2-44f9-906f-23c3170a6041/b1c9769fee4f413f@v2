// 명령행 옵션
// ============================================================================

/// 명령행 인수로 파싱된 옵션
#[derive(Clone, Debug)]
pub struct CliArgs {
    /// 입력 파일 경로
    pub input_file: Option<String>,

    /// --eval 옵션: 직접 실행할 코드
    pub eval_code: Option<String>,

    /// --repl 옵션: REPL 모드 활성화
    pub repl_mode: bool,

    /// --debug 옵션: 디버그 모드
    pub debug_mode: bool,

    /// --verbose 옵션: 상세 출력
    pub verbose: bool,

    /// --time 옵션: 실행 시간 측정
    pub measure_time: bool,

    /// --check 옵션: 파싱만 수행
    pub check_only: bool,

    /// --version 옵션
    pub show_version: bool,

    /// --help 옵션
    pub show_help: bool,

    /// 추가 인수들
    pub extra_args: Vec<String>,
}

impl Default for CliArgs {
    fn default() -> Self {
        CliArgs {
            input_file: None,
            eval_code: None,
            repl_mode: false,
            debug_mode: false,
            verbose: false,
            measure_time: false,
            check_only: false,
            show_version: false,
            show_help: false,
            extra_args: Vec::new(),
        }
    }
}

impl CliArgs {
    /// 명령행 인수를 파싱합니다
    pub fn parse(args: Vec<String>) -> Self {
        let mut parsed = CliArgs::default();
        let mut i = 1;  // 프로그램 이름 건너뛰기

        while i < args.len() {
            let arg = &args[i];

            match arg.as_str() {
                "--repl" => parsed.repl_mode = true,
                "--debug" => parsed.debug_mode = true,
                "--verbose" | "-v" => parsed.verbose = true,
                "--time" => parsed.measure_time = true,
                "--check" => parsed.check_only = true,
                "--version" => parsed.show_version = true,
                "--help" | "-h" => parsed.show_help = true,

                "--eval" | "-e" => {
                    if i + 1 < args.len() {
                        parsed.eval_code = Some(args[i + 1].clone());
                        i += 1;
                    } else {
                        eprintln!("❌ Error: --eval requires an argument");
                        process::exit(1);
                    }
                },

                arg if arg.starts_with('-') => {
                    eprintln!("❌ Error: Unknown option: {}", arg);
                    process::exit(1);
                },

                _ => {
                    if parsed.input_file.is_none() {
                        parsed.input_file = Some(arg.clone());
                    } else {
                        parsed.extra_args.push(arg.clone());
                    }
                }
            }

            i += 1;
        }

        parsed
    }

    /// 이 옵션 조합이 유효한지 확인합니다
    pub fn validate(&self) -> Result<(), String> {
        let modes_count = [
            self.input_file.is_some(),
            self.eval_code.is_some(),
            self.repl_mode,
        ].iter().filter(|&&x| x).count();

        if modes_count > 1 {
            return Err("Error: Cannot mix file, --eval, and --repl modes".to_string());
        }

        Ok(())
    }

    /// REPL 모드인지 확인합니다
    pub fn should_start_repl(&self) -> bool {
        self.repl_mode || (
            self.input_file.is_none() &&
            self.eval_code.is_none() &&
            !self.show_version &&
            !self.show_help
        )
    }
}

// ============================================================================
// ExitCode: 종료 코드
// ============================================================================

/// 프로그램 종료 코드
#[derive(Clone, Copy, Debug)]
pub enum ExitCode {
    Success = 0,
    UsageError = 1,
    RuntimeError = 2,
    IoError = 3,
    ParseError = 4,
    Timeout = 5,
    Unknown = 99,
}

impl Into<i32> for ExitCode {
    fn into(self) -> i32 {
        self as i32
    }
}

// ============================================================================
// CLI 함수들
