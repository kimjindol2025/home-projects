    fn test_cli_args_parse_file() {
        let args_vec = vec!["freelang".to_string(), "test.fl".to_string()];
        let args = CliArgs::parse(args_vec);
        assert_eq!(args.input_file, Some("test.fl".to_string()));
    }

    #[test]
    fn test_cli_args_parse_eval() {
        let args_vec = vec![
            "freelang".to_string(),
            "--eval".to_string(),
            "1 + 1".to_string(),
        ];
        let args = CliArgs::parse(args_vec);
        assert_eq!(args.eval_code, Some("1 + 1".to_string()));
    }

    #[test]
    fn test_cli_args_parse_repl() {
        let args_vec = vec!["freelang".to_string(), "--repl".to_string()];
        let args = CliArgs::parse(args_vec);
        assert!(args.repl_mode == true);
    }

    #[test]
    fn test_cli_args_parse_debug() {
        let args_vec = vec!["freelang".to_string(), "--debug".to_string()];
        let args = CliArgs::parse(args_vec);
        assert!(args.debug_mode == true);
    }

    #[test]
    fn test_cli_args_parse_verbose() {
        let args_vec = vec!["freelang".to_string(), "-v".to_string()];
        let args = CliArgs::parse(args_vec);
        assert!(args.verbose == true);
    }

    #[test]
    fn test_cli_args_parse_time() {
        let args_vec = vec!["freelang".to_string(), "--time".to_string()];
        let args = CliArgs::parse(args_vec);
        assert!(args.measure_time == true);
    }

    #[test]
    fn test_cli_args_parse_check() {
        let args_vec = vec!["freelang".to_string(), "--check".to_string(), "test.fl".to_string()];
        let args = CliArgs::parse(args_vec);
        assert!(args.check_only == true);
    }

    #[test]
    fn test_cli_args_parse_version() {
        let args_vec = vec!["freelang".to_string(), "--version".to_string()];
        let args = CliArgs::parse(args_vec);
        assert!(args.show_version == true);
    }

    #[test]
    fn test_cli_args_parse_help() {
        let args_vec = vec!["freelang".to_string(), "--help".to_string()];
        let args = CliArgs::parse(args_vec);
        assert!(args.show_help == true);
    }

    #[test]
    fn test_cli_args_validate_multiple_modes() {
        let mut args = CliArgs::default();
        args.input_file = Some("test.fl".to_string());
        args.eval_code = Some("1 + 1".to_string());
        assert!(args.validate().is_err());
    }

