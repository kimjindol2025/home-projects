//
// 사용 방법:
// $ freelang [OPTIONS] [FILE]
//
// 명령어:
// $ freelang program.fl          # 파일 실행
// $ freelang --repl              # REPL 모드
// $ freelang --eval "1 + 1"      # 코드 직접 실행
// $ freelang --debug program.fl  # 디버그 모드로 실행
// $ freelang --version           # 버전 출력
// $ freelang --help              # 도움말 출력
//
