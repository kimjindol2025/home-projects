    fn test_cli_args_should_start_repl_with_file() {
        let mut args = CliArgs::default();
        args.input_file = Some("test.fl".to_string());
        assert!(args.should_start_repl() == false);
    }

    #[test]
    fn test_exit_code_success() {
        let code: i32 = ExitCode::Success.into();
        assert_eq!(code, 0);
    }

