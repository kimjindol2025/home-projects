#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_command_parse_help() {
        assert_eq!(ReplCommand::parse(".help"), ReplCommand::Help);
    }

    #[test]
    fn test_command_parse_exit() {
        assert_eq!(ReplCommand::parse("exit"), ReplCommand::Exit);
        assert_eq!(ReplCommand::parse("quit"), ReplCommand::Exit);
    }

    #[test]
    fn test_command_parse_load() {
        match ReplCommand::parse(".load program.fl") {
            ReplCommand::Load(path) => assert_eq!(path, "program.fl"),
            _ => panic!("Expected Load command"),
        }
    }

    #[test]
    fn test_command_parse_code() {
        match ReplCommand::parse("let x = 42") {
            ReplCommand::Code(code) => assert_eq!(code, "let x = 42"),
            _ => panic!("Expected Code command"),
        }
    }

    #[test]
    fn test_session_creation() {
        let session = ReplSession::new();
        assert_eq!(session.history.len(), 0);
        assert_eq!(session.lines_executed, 0);
        assert_eq!(session.errors_occurred, 0);
    }

    #[test]
    fn test_session_history() {
        let mut session = ReplSession::new();
        session.add_to_history("let x = 1");
        session.add_to_history("println(x)");
        assert_eq!(session.history.len(), 2);
    }

    #[test]
    fn test_session_variables() {
        let mut session = ReplSession::new();
        let val = crate::evaluator::FlValue::Int(42);
        session.set_variable("x".to_string(), val.clone());

        assert!(session.get_variable("x").is_some());
        assert!(session.get_variable("y").is_none());
    }

    #[test]
    fn test_session_statistics() {
        let mut session = ReplSession::new();
        session.record_success(crate::evaluator::FlValue::Null);
        session.record_error();
        session.set_variable("x".to_string(), crate::evaluator::FlValue::Int(1));

        let stats = session.statistics();
        assert_eq!(stats.lines_executed, 1);
        assert_eq!(stats.errors_occurred, 1);
        assert_eq!(stats.variables_count, 1);
    }

    #[test]
    fn test_repl_creation() {
        let repl = Repl::new();
        assert!(repl.running);
    }

    #[test]
    fn test_command_history() {
        assert_eq!(ReplCommand::parse(".history"), ReplCommand::History);
    }

    #[test]
    fn test_command_environment() {
        assert_eq!(ReplCommand::parse(".env"), ReplCommand::Environment);
        assert_eq!(ReplCommand::parse(".environment"), ReplCommand::Environment);
    }

    #[test]
    fn test_command_clear() {
        assert_eq!(ReplCommand::parse(".clear"), ReplCommand::Clear);
    }

    #[test]
    fn test_repl_mode() {
        let mut session = ReplSession::new();
        assert_eq!(session.mode, ReplMode::Normal);

        session.set_mode(ReplMode::Debug);
        assert_eq!(session.mode, ReplMode::Debug);

        session.set_mode(ReplMode::Trace);
        assert_eq!(session.mode, ReplMode::Trace);
    }

    #[test]
    fn test_statistics_display() {
        let stats = ReplStatistics {
            lines_executed: 42,
            errors_occurred: 2,
            variables_count: 5,
            history_count: 47,
            session_duration_secs: 120,
        };
        let display = stats.to_string();
        assert!(display.contains("42"));
        assert!(display.contains("2"));
    }
}
