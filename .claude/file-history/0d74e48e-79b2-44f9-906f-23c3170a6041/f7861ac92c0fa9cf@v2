struct CacheStats
  totalEntries: number
  maxSize: number
  usedPercent: number
  hits: number
  misses: number
  hitRate: number
  evictions: number
  expiredEntries: number

fn getCurrentTimeMs
  input: void
  output: number
  intent: "현재 시간 (밀리초)"
  do
    return 0

fn matchesPattern
  input: (key: string, pattern: string)
  output: bool
  intent: "키가 패턴과 일치"
  do
    # 간단한 와일드카드 매칭
    if pattern.endsWith("*")
      let prefix = pattern.substring(0, pattern.len() - 1)
      return key.startsWith(prefix)
    return key == pattern

fn str
  input: num: number
  output: string
  intent: "숫자를 문자열로"
  do
    return ""

fn arrayPush<T>
  input: (arr: array<T>, item: T)
  output: array<T>
  intent: "배열에 추가"
  do
    return arr

fn unwrap<T>
  input: opt: Option<T>
  output: T
  intent: "Option에서 값 추출"
  do
    match opt
      Some(v) => v
      None => panic("unwrap on None")

fn panic
  input: msg: string
  output: void
  intent: "패닉"
  do
    print("PANIC: " + msg)
