/**
 * ============================================================================
 * grpc-web/codegen.ts - Proto 파일에서 TypeScript 코드 생성
 * ============================================================================
 * Proto → TypeScript 서비스, 메시지, 타입 정의 자동 생성
 * 작성: 2026-03-02
 */

import { GrpcWebClient, GrpcService, GrpcResponse, StreamResponse } from './client';

/**
 * Proto 메시지 정의
 */
export interface ProtoMessage {
  name: string;
  fields: ProtoField[];
}

export interface ProtoField {
  name: string;
  type: string;
  isRepeated: boolean;
  isOptional: boolean;
}

/**
 * Proto 서비스 정의
 */
export interface ProtoService {
  name: string;
  methods: ProtoMethod[];
}

export interface ProtoMethod {
  name: string;
  inputType: string;
  outputType: string;
  isClientStreaming: boolean;
  isServerStreaming: boolean;
}

/**
 * 생성된 코드 출력
 */
export interface GeneratedCode {
  messages: string;
  service: string;
  typeGuards: string;
}

/**
 * Proto 메시지를 TypeScript 인터페이스로 생성
 */
export function generateMessageTypes(messages: ProtoMessage[]): string {
  let code = '// Auto-generated message types\n\n';

  for (const msg of messages) {
    code += `export interface ${msg.name} {\n`;

    for (const field of msg.fields) {
      const isOptional = field.isOptional ? '?' : '';
      const isArray = field.isRepeated ? '[]' : '';
      const tsType = protoTypeToTS(field.type);

      code += `  ${field.name}${isOptional}: ${tsType}${isArray};\n`;
    }

    code += '}\n\n';
  }

  return code;
}

/**
 * Proto 서비스를 TypeScript 클래스로 생성
 */
export function generateServiceClass(
  service: ProtoService,
  packageName: string
): string {
  let code = `// Auto-generated service class\n\n`;
  code += `export class ${service.name}Client extends GrpcService {\n`;
  code += `  private readonly serviceName = '${packageName}.${service.name}';\n\n`;

  for (const method of service.methods) {
    if (!method.isClientStreaming && !method.isServerStreaming) {
      // Unary RPC
      code += generateUnaryMethod(method);
    } else if (method.isServerStreaming && !method.isClientStreaming) {
      // Server Streaming
      code += generateServerStreamingMethod(method);
    } else if (method.isClientStreaming && !method.isServerStreaming) {
      // Client Streaming
      code += generateClientStreamingMethod(method);
    } else {
      // Bidirectional Streaming
      code += generateBidiStreamingMethod(method);
    }
    code += '\n';
  }

  code += '}\n';
  return code;
}

/**
 * Unary RPC 메서드 생성
 */
function generateUnaryMethod(method: ProtoMethod): string {
  return `  async ${formatMethodName(method.name)}(
    request: ${method.inputType}
  ): Promise<GrpcResponse<${method.outputType}>> {
    return this.client.callUnary<${method.inputType}, ${method.outputType}>(
      this.serviceName,
      '${method.name}',
      request
    );
  }\n`;
}

/**
 * Server Streaming 메서드 생성
 */
function generateServerStreamingMethod(method: ProtoMethod): string {
  return `  async ${formatMethodName(method.name)}Stream(
    request: ${method.inputType},
    onMessage: (message: ${method.outputType}) => void
  ): Promise<StreamResponse<${method.outputType}>> {
    return this.client.callServerStreaming<${method.inputType}, ${method.outputType}>(
      this.serviceName,
      '${method.name}',
      request,
      onMessage
    );
  }\n`;
}

/**
 * Client Streaming 메서드 생성
 */
function generateClientStreamingMethod(method: ProtoMethod): string {
  return `  async ${formatMethodName(method.name)}(
    requests: ${method.inputType}[]
  ): Promise<GrpcResponse<${method.outputType}>> {
    return this.client.callClientStreaming<${method.inputType}, ${method.outputType}>(
      this.serviceName,
      '${method.name}',
      requests
    );
  }\n`;
}

/**
 * Bidirectional Streaming 메서드 생성
 */
function generateBidiStreamingMethod(method: ProtoMethod): string {
  return `  async ${formatMethodName(method.name)}Bidi(
    requests: ${method.inputType}[],
    onMessage: (message: ${method.outputType}) => void
  ): Promise<StreamResponse<${method.outputType}>> {
    return this.client.callBidiStreaming<${method.inputType}, ${method.outputType}>(
      this.serviceName,
      '${method.name}',
      requests,
      onMessage
    );
  }\n`;
}

/**
 * 메서드명 포맷팅 (Snake case → camelCase)
 */
function formatMethodName(name: string): string {
  return name.charAt(0).toLowerCase() + name.slice(1);
}

/**
 * Proto 타입을 TypeScript 타입으로 변환
 */
function protoTypeToTS(protoType: string): string {
  const typeMap: { [key: string]: string } = {
    'int32': 'number',
    'int64': 'number',
    'uint32': 'number',
    'uint64': 'number',
    'float': 'number',
    'double': 'number',
    'string': 'string',
    'bytes': 'Uint8Array',
    'bool': 'boolean',
  };

  return typeMap[protoType] || protoType;
}

/**
 * 타입 가드 함수 자동 생성
 */
export function generateTypeGuards(messages: ProtoMessage[]): string {
  let code = '// Auto-generated type guards\n\n';

  for (const msg of messages) {
    code += `export function is${msg.name}(obj: any): obj is ${msg.name} {\n`;
    code += `  return (\n`;
    code += `    typeof obj === 'object' &&\n`;

    for (const field of msg.fields) {
      if (!field.isOptional && !field.isRepeated) {
        code += `    '${field.name}' in obj &&\n`;
      }
    }

    code += `    true\n`;
    code += `  );\n`;
    code += `}\n\n`;
  }

  return code;
}

/**
 * 전체 코드 생성
 */
export function generateAllCode(
  serviceName: string,
  packageName: string,
  messages: ProtoMessage[],
  services: ProtoService[]
): GeneratedCode {
  return {
    messages: generateMessageTypes(messages),
    service: services
      .map(svc => generateServiceClass(svc, packageName))
      .join('\n'),
    typeGuards: generateTypeGuards(messages),
  };
}

/**
 * 테스트 모의 객체 생성
 */
export function generateMockService(service: ProtoService): string {
  let code = `// Auto-generated mock service for testing\n\n`;
  code += `export class Mock${service.name}Client extends ${service.name}Client {\n`;
  code += `  private responses: Map<string, any> = new Map();\n\n`;

  code += `  setMockResponse(methodName: string, response: any) {\n`;
  code += `    this.responses.set(methodName, response);\n`;
  code += `  }\n\n`;

  for (const method of service.methods) {
    code += `  async ${formatMethodName(method.name)}(...args: any[]): Promise<any> {\n`;
    code += `    return this.responses.get('${method.name}') || { success: true };\n`;
    code += `  }\n\n`;
  }

  code += `}\n`;
  return code;
}
