#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_io_port_creation() {
        let port = IOPort::new(0x60, 1);
        assert_eq!(port.port_number, 0x60);
        assert_eq!(port.port_size, 1);
    }

    #[test]
    fn test_io_port_read_write() {
        let mut port = IOPort::new(0x60, 1);
        let _ = port.read();
        assert_eq!(port.read_count, 1);

        port.write(0x42).unwrap();
        assert_eq!(port.write_count, 1);
    }

    #[test]
    fn test_keyboard_controller_creation() {
        let kb = KeyboardController::new();
        assert_eq!(kb.key_count, 0);
        assert!(kb.last_key.is_none());
    }

    #[test]
    fn test_keyboard_input_key() {
        let mut kb = KeyboardController::new();
        kb.input_key(KeyCode::A).unwrap();
        assert_eq!(kb.key_count, 1);
        assert!(kb.last_key.is_some());
    }

    #[test]
    fn test_disk_sector_creation() {
        let sector = DiskSector::new(0);
        assert_eq!(sector.sector_number, 0);
        assert!(!sector.valid);
    }

    #[test]
    fn test_disk_sector_write_read() {
        let mut sector = DiskSector::new(0);
        let data = vec![0xAA; 512];
        sector.write_data(data).unwrap();
        assert!(sector.valid);

        let read_data = sector.read_data().unwrap();
        assert_eq!(read_data.len(), 512);
    }

    #[test]
    fn test_disk_controller_creation() {
        let disk = DiskController::new();
        assert_eq!(disk.read_operations, 0);
        assert_eq!(disk.write_operations, 0);
    }

    #[test]
    fn test_disk_controller_read() {
        let mut disk = DiskController::new();
        let result = disk.read_sector(0);
        assert!(result.is_ok());
        assert_eq!(disk.read_operations, 1);
    }

    #[test]
    fn test_disk_controller_write() {
        let mut disk = DiskController::new();
        let data = vec![0xFF; 512];
        let result = disk.write_sector(0, data);
        assert!(result.is_ok());
        assert_eq!(disk.write_operations, 1);
    }

    #[test]
    fn test_io_manager_creation() {
        let io_mgr = IOManager::new();
        assert!(io_mgr.total_io_operations == 0);
    }

    #[test]
    fn test_io_manager_initialize() {
        let mut io_mgr = IOManager::new();
        assert!(io_mgr.initialize().is_ok());
    }

    #[test]
    fn test_io_manager_handle_operations() {
        let mut io_mgr = IOManager::new();
        io_mgr.initialize().unwrap();

        assert!(io_mgr.handle_io_operation("read_keyboard").is_ok());
        assert!(io_mgr.handle_io_operation("read_disk").is_ok());
        assert!(io_mgr.total_io_operations >= 2);
    }
}
