#[derive(Clone, Debug)]
pub struct DiskSector {
    /// 섹터 번호 (0부터 시작)
    pub sector_number: u64,

    /// 데이터 (512 바이트)
    pub data: Vec<u8>,

    /// 데이터 유효성
    pub valid: bool,
}

impl DiskSector {
    pub fn new(sector_number: u64) -> Self {
        DiskSector {
            sector_number,
            data: vec![0; 512],  // 512 바이트 섹터
            valid: false,
        }
    }

    pub fn write_data(&mut self, data: Vec<u8>) -> Result<(), String> {
        if data.len() > 512 {
            return Err("Data too large for sector".to_string());
        }

        self.data = data;
        self.data.resize(512, 0);
        self.valid = true;

        Ok(())
    }

    pub fn read_data(&self) -> Result<Vec<u8>, String> {
        if !self.valid {
            return Err("Sector not valid".to_string());
        }

        Ok(self.data.clone())
    }

    pub fn clear(&mut self) {
        self.data = vec![0; 512];
        self.valid = false;
    }
}

pub struct DiskController {
    /// 데이터 포트 (0x1F0)
    pub data_port: IOPort,

    /// 에러 포트 (0x1F1)
    pub error_port: IOPort,

    /// 섹터 카운트 포트 (0x1F2)
    pub sector_count_port: IOPort,

    /// LBA 포트들 (0x1F3-0x1F6)
    pub lba_ports: Vec<IOPort>,

    /// 상태 포트 (0x1F7)
    pub status_port: IOPort,

    /// 로드된 섹터 (캐시)
    pub loaded_sectors: Vec<DiskSector>,

    /// 마지막 작업
    pub last_operation: Option<String>,

    /// 읽기 작업 수
    pub read_operations: u32,

    /// 쓰기 작업 수
    pub write_operations: u32,
}

impl DiskController {
    pub fn new() -> Self {
        let mut lba_ports = Vec::new();
        for i in 0..4 {
            lba_ports.push(IOPort::new(0x1F3 + i, 1));
        }

        DiskController {
            data_port: IOPort::new(0x1F0, 2),
            error_port: IOPort::new(0x1F1, 1),
            sector_count_port: IOPort::new(0x1F2, 1),
            lba_ports,
            status_port: IOPort::new(0x1F7, 1),
            loaded_sectors: Vec::new(),
            last_operation: None,
            read_operations: 0,
            write_operations: 0,
        }
    }

    pub fn read_sector(&mut self, sector_number: u64) -> Result<Vec<u8>, String> {
        // 시뮬레이션: 섹터 읽기
        let mut sector = DiskSector::new(sector_number);

        // 섹터 데이터 생성 (시뮬레이션)
        let mut data = vec![0; 512];
        for i in 0..512 {
            data[i] = ((sector_number as u8) ^ (i as u8)) & 0xFF;
        }

        sector.write_data(data)?;
        self.loaded_sectors.push(sector.clone());

        self.read_operations += 1;
        self.last_operation = Some(format!("Read sector {}", sector_number));

        println!("💾 Disk: Read sector {} (512 bytes)", sector_number);

        Ok(sector.data)
    }

    pub fn write_sector(&mut self, sector_number: u64, data: Vec<u8>) -> Result<(), String> {
        // 시뮬레이션: 섹터 쓰기
        let mut sector = DiskSector::new(sector_number);
        sector.write_data(data)?;

        // 기존 섹터 업데이트 또는 새 섹터 추가
        let mut found = false;
        for s in &mut self.loaded_sectors {
            if s.sector_number == sector_number {
                *s = sector;
                found = true;
                break;
            }
        }

        if !found {
            self.loaded_sectors.push(sector);
        }

        self.write_operations += 1;
        self.last_operation = Some(format!("Write sector {}", sector_number));

        println!("💾 Disk: Write sector {} (512 bytes)", sector_number);

        Ok(())
    }

    pub fn print_disk_status(&self) {
        println!("\n💾 Disk Controller Status:");
        println!("  Total Sectors: {}", self.loaded_sectors.len());
        println!("  Read Operations: {}", self.read_operations);
        println!("  Write Operations: {}", self.write_operations);
        println!("  Last Operation: {:?}", self.last_operation);
    }
}

// ============================================================================
// Part 4: I/O 관리자
// ============================================================================

pub struct IOManager {
    /// I/O 포트 목록
    pub ports: Vec<IOPort>,

    /// 키보드 컨트롤러
    pub keyboard: KeyboardController,

    /// 디스크 컨트롤러
    pub disk: DiskController,

    /// 총 I/O 작업 수
    pub total_io_operations: u64,
}

impl IOManager {
    pub fn new() -> Self {
        let mut ports = Vec::new();

        // 주요 I/O 포트 초기화
        ports.push(IOPort::new(0x20, 1));  // PIC
        ports.push(IOPort::new(0x21, 1));  // PIC
        ports.push(IOPort::new(0x60, 1));  // Keyboard
        ports.push(IOPort::new(0x64, 1));  // Keyboard status

        IOManager {
            ports,
            keyboard: KeyboardController::new(),
            disk: DiskController::new(),
            total_io_operations: 0,
        }
    }

    pub fn initialize(&mut self) -> Result<(), String> {
        println!("🔧 Initializing I/O Manager...");

        // 키보드 초기화
        self.keyboard.send_command(0xFF)?;  // Keyboard reset
        println!("  ✅ Keyboard initialized");

        // 디스크 초기화
        println!("  ✅ Disk controller initialized");

        println!("✅ I/O Manager ready\n");

        Ok(())
    }

    pub fn handle_io_operation(&mut self, operation: &str) -> Result<(), String> {
        self.total_io_operations += 1;

        match operation {
            "read_keyboard" => {
                self.keyboard.input_key(KeyCode::A)?;
                self.keyboard.input_key(KeyCode::B)?;
                self.keyboard.input_key(KeyCode::C)?;
                Ok(())
            },
            "read_disk" => {
                self.disk.read_sector(0)?;
                self.disk.read_sector(1)?;
                Ok(())
            },
            "write_disk" => {
                let data = vec![0xAA; 512];
                self.disk.write_sector(0, data)?;
                Ok(())
            },
            _ => Err(format!("Unknown operation: {}", operation)),
        }
    }

    pub fn print_io_status(&self) {
        println!("\n╔════════════════════════════════════════════════════════════╗");
        println!("║           I/O Manager Status Report                       ║");
        println!("╚════════════════════════════════════════════════════════════╝");

        println!("\n🔧 I/O Ports ({} ports):", self.ports.len());
        for port in &self.ports {
            port.print_port_info();
        }

        self.keyboard.print_keyboard_status();
        self.disk.print_disk_status();

        println!("\n📊 I/O Statistics:");
        println!("  Total I/O Operations: {}", self.total_io_operations);
    }
}

// ============================================================================
// Part 5: 메인 함수
// ============================================================================

pub fn main() {
    println!("╔════════════════════════════════════════════════════════════╗");
    println!("║   FreeLang OS Kernel - Phase G Week 3 I/O Control        ║");
    println!("╚════════════════════════════════════════════════════════════╝\n");

    let mut io_manager = IOManager::new();
    io_manager.initialize().unwrap();

    // 키보드 작업
    println!("⌨️  Keyboard operations...");
    io_manager.handle_io_operation("read_keyboard").unwrap();

    // 디스크 작업
    println!("\n💾 Disk operations...");
    io_manager.handle_io_operation("read_disk").unwrap();
    io_manager.handle_io_operation("write_disk").unwrap();

    // 상태 보고
    io_manager.print_io_status();

    println!("\n✨ I/O control simulation complete!\n");
}

