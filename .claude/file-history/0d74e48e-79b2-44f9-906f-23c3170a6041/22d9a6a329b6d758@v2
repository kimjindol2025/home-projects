/// I/O 포트 (x86-64)
pub struct IOPort {
    /// 포트 번호 (0x0000 ~ 0xFFFF)
    pub port_number: u16,

    /// 포트 크기 (1, 2, 4, 8 바이트)
    pub port_size: u8,

    /// 마지막 읽은 값
    pub last_read_value: u32,

    /// 마지막 쓴 값
    pub last_write_value: u32,

    /// 읽기 횟수
    pub read_count: u32,

    /// 쓰기 횟수
    pub write_count: u32,
}

impl IOPort {
    pub fn new(port_number: u16, port_size: u8) -> Self {
        IOPort {
            port_number,
            port_size,
            last_read_value: 0,
            last_write_value: 0,
            read_count: 0,
            write_count: 0,
        }
    }

    pub fn read(&mut self) -> u32 {
        // 시뮬레이션: 포트에서 값 읽기
        let value = (self.port_number as u32) ^ 0xDEADBEEF;
        self.last_read_value = value;
        self.read_count += 1;
        value
    }

    pub fn write(&mut self, value: u32) -> Result<(), String> {
        if value > 0xFFFFFFFF {
            return Err("Value too large".to_string());
        }
        self.last_write_value = value;
        self.write_count += 1;
        Ok(())
    }

    pub fn port_type(&self) -> &'static str {
        match self.port_number {
            0x20 | 0x21 => "PIC (Programmable Interrupt Controller)",
            0x60 | 0x64 => "Keyboard Controller",
            0x70 | 0x71 => "CMOS / RTC",
            0x3F6 | 0x3F7 => "IDE / ATA",
            _ => "Unknown Device",
        }
    }

    pub fn print_port_info(&self) {
        println!("  Port 0x{:04x} ({})", self.port_number, self.port_type());
        println!("    Size: {} bytes, Reads: {}, Writes: {}",
                 self.port_size, self.read_count, self.write_count);
    }
}

