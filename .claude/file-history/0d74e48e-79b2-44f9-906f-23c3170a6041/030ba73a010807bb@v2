fn getQueueHealth
  input: queue: TaskQueue
  output: string
  intent: "큐 상태 점수 (Healthy/Warning/Critical)"
  do
    let failureRate = if queue.stats.totalTasks == 0
                      0
                    else
                      (queue.stats.failedTasks * 100) / queue.stats.totalTasks

    if failureRate > 50
      return "🔴 CRITICAL (Failure rate: " + str(failureRate) + "%)"
    else if failureRate > 20
      return "🟡 WARNING (Failure rate: " + str(failureRate) + "%)"
    else
      return "🟢 HEALTHY"

