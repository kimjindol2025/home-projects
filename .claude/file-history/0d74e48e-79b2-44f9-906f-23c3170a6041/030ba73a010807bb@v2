enum TaskPriority
  HIGH = 0
  NORMAL = 1
  LOW = 2

enum TaskStatus
  PENDING = 0
  RUNNING = 1
  DONE = 2
  FAILED = 3
  RETRY = 4

struct Task
  id: string                    # UUID
  name: string
  handler: function             # () -> Result<void, string>
  priority: TaskPriority        # HIGH/NORMAL/LOW
  status: TaskStatus            # PENDING/RUNNING/DONE/FAILED/RETRY
  createdAt: number             # 밀리초
  startedAt: number
  completedAt: number
  retryCount: number
  maxRetries: number
  error: string
  metadata: map<string, string> # 커스텀 데이터

struct TaskQueue
  id: string
  name: string
  tasks: array<Task>            # FIFO 큐
  workers: array<Worker>
  maxWorkers: number
  activeWorkers: number
  retryLimit: number
  deadLetterQueue: array<Task>  # 최대 재시도 실패한 작업
  maxDeadLetterSize: number
  paused: bool
  stats: QueueStats

struct Worker
  id: string
  isActive: bool
  currentTask: Option<Task>
  processedCount: number
  totalTime: number             # 밀리초

struct QueueStats
  totalTasks: number
  pendingTasks: number
  runningTasks: number
  completedTasks: number
  failedTasks: number
  retryTasks: number
  deadLetterCount: number
  averageTime: number           # 밀리초
  throughput: number            # tasks/sec

