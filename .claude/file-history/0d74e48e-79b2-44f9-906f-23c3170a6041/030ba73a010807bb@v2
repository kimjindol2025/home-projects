fn processTask
  input: (queue: TaskQueue, task: Task)
  output: Result<void, string>
  intent: "작업 실행"
  do
    if queue.activeWorkers >= queue.maxWorkers
      return Err("No available workers")

    task.status = 1  # RUNNING
    task.startedAt = getCurrentTimestamp()
    queue.activeWorkers = queue.activeWorkers + 1
    queue.stats.runningTasks = queue.stats.runningTasks + 1

    print("▶️  Processing task: " + task.name + " (ID: " + strSubstring(task.id, 0, 8) + ")")

    # 작업 실행
    match task.handler()
      Ok(_) => {
        task.status = 2  # DONE
        task.completedAt = getCurrentTimestamp()
        queue.stats.runningTasks = queue.stats.runningTasks - 1
        queue.stats.completedTasks = queue.stats.completedTasks + 1
        queue.activeWorkers = queue.activeWorkers - 1

        let elapsed = task.completedAt - task.startedAt
        print("✅ Task completed: " + task.name + " (" + str(elapsed) + "ms)")
        return Ok(void)
      }
      Err(error) => {
        # 실패 처리: 재시도 또는 Dead Letter Queue
        if task.retryCount < task.maxRetries
          task.retryCount = task.retryCount + 1
          task.status = 4  # RETRY
          task.error = error
          queue.stats.retryTasks = queue.stats.retryTasks + 1
          print("🔄 Retrying task: " + task.name + " (Attempt " + str(task.retryCount) + "/" + str(task.maxRetries) + ")")
          return Ok(void)
        else
          task.status = 3  # FAILED
          task.error = error
          queue.stats.runningTasks = queue.stats.runningTasks - 1
          queue.stats.failedTasks = queue.stats.failedTasks + 1
          queue.activeWorkers = queue.activeWorkers - 1

          # Dead Letter Queue에 추가
          if arrayLen(queue.deadLetterQueue) < queue.maxDeadLetterSize
            queue.deadLetterQueue = arrayPush(queue.deadLetterQueue, task)
            queue.stats.deadLetterCount = queue.stats.deadLetterCount + 1

          print("❌ Task failed: " + task.name + " - " + error)
          return Err(error)
      }

