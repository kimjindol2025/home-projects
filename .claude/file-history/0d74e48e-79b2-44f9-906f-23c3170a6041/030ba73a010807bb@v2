  output: Result<string, string>
  intent: "작업을 큐에 추가"
  do
    if queue.paused
      return Err("Queue is paused")

    let task = {
      id: generateUUID(),
      name: name,
      handler: handler,
      priority: priority,
      status: 0,  # PENDING
      createdAt: getCurrentTimestamp(),
      startedAt: 0,
      completedAt: 0,
      retryCount: 0,
      maxRetries: maxRetries,
      error: "",
      metadata: {}
    }

    # 우선순위에 따라 삽입 위치 결정 (삽입 정렬)
    queue.tasks = insertTaskByPriority(queue.tasks, task)
    queue.stats.totalTasks = queue.stats.totalTasks + 1
    queue.stats.pendingTasks = queue.stats.pendingTasks + 1

    print("📥 Task enqueued: " + name + " (Priority: " + str(priority) + ")")
    return Ok(task.id)

