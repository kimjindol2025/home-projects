fn startQueue
  input: queue: TaskQueue
  output: Result<void, string>
  intent: "작업 큐 시작"
  do
    queue.paused = false
    print("🚀 Task Queue started: " + queue.name)
    print("  Max workers: " + str(queue.maxWorkers))
    print("  Retry limit: " + str(queue.retryLimit))
    return Ok(void)

fn pauseQueue
  input: queue: TaskQueue
  output: Result<void, string>
  intent: "작업 큐 일시 중지"
  do
    queue.paused = true
    print("⏸️  Task Queue paused: " + queue.name)
    return Ok(void)

fn resumeQueue
  input: queue: TaskQueue
  output: Result<void, string>
  intent: "작업 큐 재개"
  do
    queue.paused = false
    print("▶️  Task Queue resumed: " + queue.name)
    return Ok(void)

fn stopQueue
  input: queue: TaskQueue
  output: Result<number, string>
  intent: "작업 큐 중지 (미처리 작업 수)"
  do
    let pendingCount = queue.stats.pendingTasks + queue.stats.runningTasks
    queue.paused = true
    print("🛑 Task Queue stopped: " + queue.name)
    print("  Pending tasks: " + str(pendingCount))
    return Ok(pendingCount)

