/// JSON 문자열을 파싱하여 FlValue로 변환합니다.
///
/// # 지원되는 타입
/// - null, true, false (불리언)
/// - 숫자 (정수 및 실수)
/// - 문자열 (큰따옴표로 감싼)
/// - 배열 ([...])
/// - 객체 ({...})
///
/// # 예제
/// ```
/// let json = r#"{"name":"John","age":30}"#;
/// let value = json_parse(json.to_string()).unwrap();
/// match value {
///     FlValue::Object(map) => assert_eq!(map.len(), 2),
///     _ => panic!("Expected object"),
/// }
/// ```
pub fn json_parse(json: String) -> Result<FlValue, JsonError> {
    let mut parser = JsonParser::new(&json);
    parser.parse_value()
}

/// JSON 유효성을 검사합니다.
///
/// # 반환값
/// - true: 유효한 JSON
/// - false: 유효하지 않은 JSON
///
/// # 예제
/// ```
/// assert_eq!(json_validate(r#"{"key":"value"}"#.to_string()), true);
/// assert_eq!(json_validate("invalid".to_string()), false);
/// ```
pub fn json_validate(json: String) -> bool {
    match json_parse(json) {
        Ok(_) => true,
        Err(_) => false,
    }
}

/// FlValue를 포맷된 JSON 문자열로 변환합니다 (들여쓰기 포함).
///
/// # 예제
/// ```
/// let obj = FlValue::Object(...);
/// let pretty = json_pretty(obj).unwrap();
/// assert!(pretty.contains("\n"));  // 줄바꿈 포함
/// ```
pub fn json_pretty(value: FlValue) -> Result<String, JsonError> {
    let json_str = json_stringify(value)?;

    // 간단한 포맷팅: 4칸 들여쓰기
    let mut result = String::new();
    let mut indent = 0;
    let mut in_string = false;
    let mut escape_next = false;

    for ch in json_str.chars() {
        if escape_next {
            result.push(ch);
            escape_next = false;
            continue;
        }

        match ch {
            '\\' if in_string => {
                result.push(ch);
                escape_next = true;
            }
            '"' => {
                in_string = !in_string;
                result.push(ch);
            }
            '{' | '[' if !in_string => {
                result.push(ch);
                indent += 1;
                result.push('\n');
                result.push_str(&"  ".repeat(indent));
            }
            '}' | ']' if !in_string => {
                indent = indent.saturating_sub(1);
                result.push('\n');
                result.push_str(&"  ".repeat(indent));
                result.push(ch);
            }
            ',' if !in_string => {
                result.push(ch);
                result.push('\n');
                result.push_str(&"  ".repeat(indent));
            }
            ':' if !in_string => {
                result.push(ch);
                result.push(' ');
            }
            _ => result.push(ch),
        }
    }

    Ok(result)
}

/// JSON 객체에서 특정 키의 값을 가져옵니다.
///
/// # 에러
/// - 객체가 아니면: JsonError::TypeMismatch
/// - 키를 찾을 수 없으면: JsonError::KeyNotFound
///
/// # 예제
/// ```
/// let json = r#"{"name":"John","age":30}"#;
/// let obj = json_parse(json.to_string()).unwrap();
/// let value = json_get(obj, "name").unwrap();
/// ```
pub fn json_get(value: FlValue, key: String) -> Result<FlValue, JsonError> {
    match value {
        FlValue::Object(map) => {
            map.get(&key)
                .cloned()
                .ok_or_else(|| JsonError::KeyNotFound(key))
        }
        _ => Err(JsonError::TypeMismatch(
            "json_get requires object".to_string(),
        )),
    }
}

/// 두 JSON 객체를 병합합니다 (b의 값이 a를 덮어씁니다).
///
/// # 특징
/// - Shallow merge (1단계만 병합)
/// - 나중 인자의 키가 우선
///
/// # 예제
/// ```
/// let a = json_parse(r#"{"x":1,"y":2}"#.to_string()).unwrap();
/// let b = json_parse(r#"{"y":3,"z":4}"#.to_string()).unwrap();
/// let merged = json_merge(a, b).unwrap();
/// // 결과: {"x":1,"y":3,"z":4}
/// ```
pub fn json_merge(a: FlValue, b: FlValue) -> Result<FlValue, JsonError> {
    match (a, b) {
        (FlValue::Object(mut map_a), FlValue::Object(map_b)) => {
            // b의 모든 항목을 a에 추가/덮어쓰기
            for (key, value) in map_b {
                map_a.insert(key, value);
            }
            Ok(FlValue::Object(map_a))
        }
        _ => Err(JsonError::TypeMismatch(
            "json_merge requires objects".to_string(),
        )),
    }
}

// ============================================================================
// JSON Parser (내부 구현)
// ============================================================================

struct JsonParser<'a> {
    input: &'a str,
    pos: usize,
}

impl<'a> JsonParser<'a> {
    fn new(input: &'a str) -> Self {
        JsonParser { input, pos: 0 }
    }

    fn skip_whitespace(&mut self) {
        while self.pos < self.input.len() && self.input.chars().nth(self.pos).unwrap().is_whitespace() {
            self.pos += 1;
        }
    }

    fn peek(&self) -> Option<char> {
        self.input.chars().nth(self.pos)
    }

    fn consume(&mut self) -> Option<char> {
        let ch = self.peek();
        if ch.is_some() {
            self.pos += 1;
        }
        ch
    }

    fn parse_value(&mut self) -> Result<FlValue, JsonError> {
        self.skip_whitespace();

        match self.peek() {
            Some('n') => self.parse_null(),
            Some('t') | Some('f') => self.parse_bool(),
            Some('"') => self.parse_string(),
            Some('[') => self.parse_array(),
            Some('{') => self.parse_object(),
            Some('-') | Some('0'..='9') => self.parse_number(),
            Some(ch) => Err(JsonError::ParseError(format!(
                "Unexpected character: {}",
                ch
            ))),
            None => Err(JsonError::ParseError("Unexpected end of input".to_string())),
        }
    }

    fn parse_null(&mut self) -> Result<FlValue, JsonError> {
        if self.input[self.pos..].starts_with("null") {
            self.pos += 4;
            Ok(FlValue::Null)
        } else {
            Err(JsonError::ParseError("Expected 'null'".to_string()))
        }
    }

    fn parse_bool(&mut self) -> Result<FlValue, JsonError> {
        if self.input[self.pos..].starts_with("true") {
            self.pos += 4;
            Ok(FlValue::Bool(true))
        } else if self.input[self.pos..].starts_with("false") {
            self.pos += 5;
            Ok(FlValue::Bool(false))
        } else {
            Err(JsonError::ParseError("Expected 'true' or 'false'".to_string()))
        }
    }

    fn parse_string(&mut self) -> Result<FlValue, JsonError> {
        self.consume(); // opening quote

        let mut result = String::new();
        loop {
            match self.consume() {
                Some('"') => return Ok(FlValue::Str(result)),
                Some('\\') => {
                    match self.consume() {
                        Some('"') => result.push('"'),
                        Some('\\') => result.push('\\'),
                        Some('/') => result.push('/'),
                        Some('n') => result.push('\n'),
                        Some('r') => result.push('\r'),
                        Some('t') => result.push('\t'),
                        _ => result.push('\\'),
                    }
                }
                Some(ch) => result.push(ch),
                None => return Err(JsonError::ParseError("Unterminated string".to_string())),
            }
        }
    }

    fn parse_number(&mut self) -> Result<FlValue, JsonError> {
        let start = self.pos;

        // 선택적 마이너스
        if self.peek() == Some('-') {
            self.consume();
        }

        // 숫자 부분
        while matches!(self.peek(), Some('0'..='9')) {
            self.consume();
        }

        // 소수점 부분
        if self.peek() == Some('.') {
            self.consume();
            while matches!(self.peek(), Some('0'..='9')) {
                self.consume();
            }
        }

        let num_str = &self.input[start..self.pos];

        // 정수 또는 실수 파싱
        if num_str.contains('.') {
            num_str.parse::<f64>()
                .map(FlValue::Float)
                .map_err(|_| JsonError::ParseError(format!("Invalid float: {}", num_str)))
        } else {
            num_str.parse::<i64>()
                .map(FlValue::Int)
                .map_err(|_| JsonError::ParseError(format!("Invalid integer: {}", num_str)))
        }
    }

    fn parse_array(&mut self) -> Result<FlValue, JsonError> {
        self.consume(); // opening bracket
        self.skip_whitespace();

        let mut elements = Vec::new();

        if self.peek() == Some(']') {
            self.consume();
            return Ok(FlValue::Array(elements));
        }

        loop {
            elements.push(self.parse_value()?);
            self.skip_whitespace();

            match self.peek() {
                Some(',') => {
                    self.consume();
                    self.skip_whitespace();
                }
                Some(']') => {
                    self.consume();
                    return Ok(FlValue::Array(elements));
                }
                _ => return Err(JsonError::ParseError("Expected ',' or ']'".to_string())),
            }
        }
    }

    fn parse_object(&mut self) -> Result<FlValue, JsonError> {
        self.consume(); // opening brace
        self.skip_whitespace();

        let mut map = HashMap::new();

        if self.peek() == Some('}') {
            self.consume();
            return Ok(FlValue::Object(map));
        }

        loop {
            self.skip_whitespace();

            // 키는 반드시 문자열
            let key = match self.parse_string()? {
                FlValue::Str(s) => s,
                _ => return Err(JsonError::ParseError("Expected string key".to_string())),
            };

            self.skip_whitespace();

            // 콜론
            if self.consume() != Some(':') {
                return Err(JsonError::ParseError("Expected ':'".to_string()));
            }

            self.skip_whitespace();

            // 값
            let value = self.parse_value()?;
            map.insert(key, value);

            self.skip_whitespace();

            match self.peek() {
                Some(',') => {
                    self.consume();
                    self.skip_whitespace();
                }
                Some('}') => {
                    self.consume();
                    return Ok(FlValue::Object(map));
                }
                _ => return Err(JsonError::ParseError("Expected ',' or '}'".to_string())),
            }
        }
    }
}

