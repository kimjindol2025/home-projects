#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_json_stringify_null() {
        assert_eq!(json_stringify(FlValue::Null).unwrap(), "null");
    }

    #[test]
    fn test_json_stringify_bool() {
        assert_eq!(json_stringify(FlValue::Bool(true)).unwrap(), "true");
        assert_eq!(json_stringify(FlValue::Bool(false)).unwrap(), "false");
    }

    #[test]
    fn test_json_stringify_number() {
        assert_eq!(json_stringify(FlValue::Int(42)).unwrap(), "42");
        assert_eq!(json_stringify(FlValue::Float(3.14)).unwrap(), "3.14");
    }

    #[test]
    fn test_json_stringify_string() {
        assert_eq!(
            json_stringify(FlValue::Str("hello".to_string())).unwrap(),
            "\"hello\""
        );
    }

    #[test]
    fn test_json_stringify_array() {
        let arr = FlValue::Array(vec![
            FlValue::Int(1),
            FlValue::Int(2),
            FlValue::Int(3),
        ]);
        assert_eq!(json_stringify(arr).unwrap(), "[1,2,3]");
    }

    #[test]
    fn test_json_stringify_object() {
        let mut map = HashMap::new();
        map.insert("name".to_string(), FlValue::Str("John".to_string()));
        let obj = FlValue::Object(map);
        let result = json_stringify(obj).unwrap();
        assert!(result.contains("\"name\""));
        assert!(result.contains("\"John\""));
    }

    #[test]
    fn test_json_parse_null() {
        assert_eq!(json_parse("null".to_string()).unwrap(), FlValue::Null);
    }

    #[test]
    fn test_json_parse_bool() {
        assert_eq!(json_parse("true".to_string()).unwrap(), FlValue::Bool(true));
        assert_eq!(json_parse("false".to_string()).unwrap(), FlValue::Bool(false));
    }

    #[test]
    fn test_json_parse_number() {
        assert_eq!(json_parse("42".to_string()).unwrap(), FlValue::Int(42));
        assert_eq!(json_parse("3.14".to_string()).unwrap(), FlValue::Float(3.14));
    }

    #[test]
    fn test_json_parse_string() {
        match json_parse("\"hello\"".to_string()).unwrap() {
            FlValue::Str(s) => assert_eq!(s, "hello"),
            _ => panic!("Expected string"),
        }
    }

    #[test]
    fn test_json_parse_array() {
        let result = json_parse("[1,2,3]".to_string()).unwrap();
        match result {
            FlValue::Array(arr) => assert_eq!(arr.len(), 3),
            _ => panic!("Expected array"),
        }
    }

    #[test]
    fn test_json_parse_object() {
        let result = json_parse(r#"{"name":"John"}"#.to_string()).unwrap();
        match result {
            FlValue::Object(map) => {
                assert!(map.contains_key("name"));
                assert_eq!(map.len(), 1);
            }
            _ => panic!("Expected object"),
        }
    }

    #[test]
    fn test_json_validate_valid() {
        assert!(json_validate(r#"{"key":"value"}"#.to_string()));
        assert!(json_validate("[1,2,3]".to_string()));
        assert!(json_validate("null".to_string()));
    }

    #[test]
    fn test_json_validate_invalid() {
        assert!(!json_validate("invalid".to_string()));
        assert!(!json_validate("{invalid}".to_string()));
        assert!(!json_validate("[1,2,]".to_string()));
    }

    #[test]
    fn test_json_get_success() {
        let obj = json_parse(r#"{"name":"John","age":30}"#.to_string()).unwrap();
        let name = json_get(obj, "name".to_string()).unwrap();
        match name {
            FlValue::Str(s) => assert_eq!(s, "John"),
            _ => panic!("Expected string"),
        }
    }

    #[test]
    fn test_json_get_not_found() {
        let obj = json_parse(r#"{"name":"John"}"#.to_string()).unwrap();
        let result = json_get(obj, "age".to_string());
        assert!(matches!(result, Err(JsonError::KeyNotFound(_))));
    }

    #[test]
    fn test_json_merge() {
        let a = json_parse(r#"{"x":1,"y":2}"#.to_string()).unwrap();
        let b = json_parse(r#"{"y":3,"z":4}"#.to_string()).unwrap();
        let merged = json_merge(a, b).unwrap();
        match merged {
            FlValue::Object(map) => {
                assert_eq!(map.get("x").unwrap(), &FlValue::Int(1));
                assert_eq!(map.get("y").unwrap(), &FlValue::Int(3));
                assert_eq!(map.get("z").unwrap(), &FlValue::Int(4));
            }
            _ => panic!("Expected object"),
        }
    }
}

