// ============================================================================
// JsonError - JSON 처리 에러 타입
// ============================================================================

/// JSON 처리 시 발생할 수 있는 에러
#[derive(Clone, Debug, PartialEq)]
pub enum JsonError {
    /// 파싱 오류
    ParseError(String),

    /// 유효하지 않은 JSON
    InvalidJson(String),

    /// 키를 찾을 수 없음
    KeyNotFound(String),

    /// 타입 불일치
    TypeMismatch(String),
}

impl std::fmt::Display for JsonError {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            JsonError::ParseError(msg) => write!(f, "Parse error: {}", msg),
            JsonError::InvalidJson(msg) => write!(f, "Invalid JSON: {}", msg),
            JsonError::KeyNotFound(key) => write!(f, "Key not found: {}", key),
            JsonError::TypeMismatch(msg) => write!(f, "Type mismatch: {}", msg),
        }
    }
}

// ============================================================================
// JSON String Serialization
// ============================================================================

/// FlValue를 JSON 문자열로 직렬화합니다.
///
/// # 예제
/// ```
/// let obj = FlValue::Object({
///     let mut m = HashMap::new();
///     m.insert("name".to_string(), FlValue::Str("John".to_string()));
///     m
/// });
/// let json = json_stringify(obj).unwrap();
/// assert!(json.contains("\"name\""));
/// ```
pub fn json_stringify(value: FlValue) -> Result<String, JsonError> {
    match value {
        FlValue::Null => Ok("null".to_string()),
        FlValue::Bool(b) => Ok(b.to_string()),
        FlValue::Int(n) => Ok(n.to_string()),
        FlValue::Float(f) => Ok(f.to_string()),
        FlValue::Str(s) => {
            // 문자열은 따옴표로 감싸고 특수 문자 이스케이프
            let escaped = s
                .replace('\\', "\\\\")
                .replace('"', "\\\"")
                .replace('\n', "\\n")
                .replace('\r', "\\r")
                .replace('\t', "\\t");
            Ok(format!("\"{}\"", escaped))
        }
        FlValue::Array(elements) => {
            let items: Result<Vec<String>, JsonError> = elements
                .iter()
                .map(|e| json_stringify(e.clone()))
                .collect();
            let items_str = items?.join(",");
            Ok(format!("[{}]", items_str))
        }
        FlValue::Object(map) => {
            let mut items = Vec::new();
            for (key, value) in map.iter() {
                let key_str = format!("\"{}\"", key);
                let value_str = json_stringify(value.clone())?;
                items.push(format!("{}:{}", key_str, value_str));
            }
            items.sort(); // 결정적 순서
            Ok(format!("{{{}}}", items.join(",")))
        }
    }
}

