### 5.4 Data Race 감지 (ThreadSanitizer)

```freelang
// TSAN으로 자동 감지
#[test]
#[ignore = "requires TSan"]
fn test_tsan_detection() {
  let x = Arc::new(AtomicUsize::new(0))

  let x1 = Arc::clone(&x)
  let t1 = spawn(move || {
    for _ in 0..1000 {
      x1.fetch_add(1, Ordering::Relaxed)
    }
  })

  let x2 = Arc::clone(&x)
  let t2 = spawn(move || {
    for _ in 0..1000 {
      x2.fetch_add(1, Ordering::Relaxed)
    }
  })

  t1.join()
  t2.join()

  // TSAN: No races detected ✓
}
