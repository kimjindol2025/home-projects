#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_borrow_error_message() {
        let error = BorrowError::AlreadyMutablyBorrowed {
            variable: "x".to_string(),
            location: "line 10".to_string(),
        };

        let msg = error.to_string();
        assert!(msg.contains("mutable"));
    }

    #[test]
    fn test_reference_graph_new() {
        let graph = ReferenceGraph::new();
        assert!(graph.edges.is_empty());
    }

    #[test]
    fn test_reference_graph_add_variable() {
        let mut graph = ReferenceGraph::new();
        graph.add_variable("x".to_string());
        graph.add_variable("y".to_string());

        assert_eq!(graph.variables.len(), 2);
    }

    #[test]
    fn test_reference_graph_no_cycles() {
        let mut graph = ReferenceGraph::new();
        graph.add_variable("a".to_string());
        graph.add_variable("b".to_string());
        graph.add_variable("c".to_string());

        let lt = Lifetime::new(1);
        graph.add_reference("a".to_string(), "b".to_string(), RefType::Immutable(lt));
        graph.add_reference("b".to_string(), "c".to_string(), RefType::Immutable(lt));

        assert!(!graph.has_cycles());
    }

    #[test]
    fn test_reference_graph_detect_simple_cycle() {
        let mut graph = ReferenceGraph::new();
        graph.add_variable("a".to_string());
        graph.add_variable("b".to_string());

        let lt = Lifetime::new(1);
        graph.add_reference("a".to_string(), "b".to_string(), RefType::Immutable(lt));
        graph.add_reference("b".to_string(), "a".to_string(), RefType::Immutable(lt));

        assert!(graph.has_cycles());
        let cycles = graph.detect_cycles();
        assert!(!cycles.is_empty());
    }

    #[test]
    fn test_reference_graph_detect_complex_cycle() {
        let mut graph = ReferenceGraph::new();
        for var in &["a", "b", "c"] {
            graph.add_variable(var.to_string());
        }

        let lt = Lifetime::new(1);
        graph.add_reference("a".to_string(), "b".to_string(), RefType::Immutable(lt));
        graph.add_reference("b".to_string(), "c".to_string(), RefType::Immutable(lt));
        graph.add_reference("c".to_string(), "a".to_string(), RefType::Immutable(lt));

        assert!(graph.has_cycles());
    }

    #[test]
    fn test_reference_depth_linear() {
        let mut graph = ReferenceGraph::new();
        graph.add_variable("a".to_string());
        graph.add_variable("b".to_string());
        graph.add_variable("c".to_string());

        let lt = Lifetime::new(1);
        graph.add_reference("a".to_string(), "b".to_string(), RefType::Immutable(lt));
        graph.add_reference("b".to_string(), "c".to_string(), RefType::Immutable(lt));

        assert_eq!(graph.reference_depth("a"), 2);
        assert_eq!(graph.reference_depth("b"), 1);
        assert_eq!(graph.reference_depth("c"), 0);
    }

    #[test]
    fn test_borrow_checker_new() {
        let checker = BorrowChecker::new();
        assert!(checker.errors.is_empty());
    }

    #[test]
    fn test_borrow_checker_declare_variable() {
        let mut checker = BorrowChecker::new();
        checker.declare_variable("x".to_string());

        assert_eq!(checker.get_state("x"), Some(BorrowState::Unused));
    }

    #[test]
    fn test_borrow_checker_immutable_borrow() {
        let mut checker = BorrowChecker::new();
        checker.declare_variable("x".to_string());

        let result = checker.try_borrow_immutable("x", "line 1");
        assert!(result.is_ok());
        assert_eq!(checker.get_state("x"), Some(BorrowState::Shared(1)));
    }

    #[test]
    fn test_borrow_checker_multiple_immutable() {
        let mut checker = BorrowChecker::new();
        checker.declare_variable("x".to_string());

        assert!(checker.try_borrow_immutable("x", "line 1").is_ok());
        assert!(checker.try_borrow_immutable("x", "line 2").is_ok());
        assert!(checker.try_borrow_immutable("x", "line 3").is_ok());

        assert_eq!(checker.get_state("x"), Some(BorrowState::Shared(3)));
    }

    #[test]
    fn test_borrow_checker_mutable_borrow() {
        let mut checker = BorrowChecker::new();
        checker.declare_variable("x".to_string());

        let result = checker.try_borrow_mutable("x", "line 1");
        assert!(result.is_ok());
        assert_eq!(checker.get_state("x"), Some(BorrowState::Exclusive));
    }

    #[test]
    fn test_borrow_checker_immutable_then_mutable_conflict() {
        let mut checker = BorrowChecker::new();
        checker.declare_variable("x".to_string());

        assert!(checker.try_borrow_immutable("x", "line 1").is_ok());
        let result = checker.try_borrow_mutable("x", "line 2");

        assert!(result.is_err());
        assert_eq!(checker.errors().len(), 1);
    }

    #[test]
    fn test_borrow_checker_mutable_then_immutable_conflict() {
        let mut checker = BorrowChecker::new();
        checker.declare_variable("x".to_string());

        assert!(checker.try_borrow_mutable("x", "line 1").is_ok());
        let result = checker.try_borrow_immutable("x", "line 2");

        assert!(result.is_err());
        assert_eq!(checker.errors().len(), 1);
    }

    #[test]
    fn test_borrow_checker_double_mutable_conflict() {
        let mut checker = BorrowChecker::new();
        checker.declare_variable("x".to_string());

        assert!(checker.try_borrow_mutable("x", "line 1").is_ok());
        let result = checker.try_borrow_mutable("x", "line 2");

        assert!(result.is_err());
    }

    #[test]
    fn test_borrow_checker_release_immutable() {
        let mut checker = BorrowChecker::new();
        checker.declare_variable("x".to_string());

        checker.try_borrow_immutable("x", "line 1").unwrap();
        checker.try_borrow_immutable("x", "line 2").unwrap();

        assert!(checker.release_immutable("x").is_ok());
        assert_eq!(checker.get_state("x"), Some(BorrowState::Shared(1)));

        assert!(checker.release_immutable("x").is_ok());
        assert_eq!(checker.get_state("x"), Some(BorrowState::Unused));
    }

    #[test]
    fn test_borrow_checker_release_mutable() {
        let mut checker = BorrowChecker::new();
        checker.declare_variable("x".to_string());

        checker.try_borrow_mutable("x", "line 1").unwrap();
        assert!(checker.release_mutable("x").is_ok());
        assert_eq!(checker.get_state("x"), Some(BorrowState::Unused));
    }

    #[test]
    fn test_borrow_checker_add_reference() {
        let mut checker = BorrowChecker::new();
        checker.declare_variable("x".to_string());
        checker.declare_variable("y".to_string());

        let lt = Lifetime::new(1);
        checker.add_reference("x", "y", RefType::Immutable(lt));

        assert_eq!(checker.reference_depth("x"), 1);
        assert_eq!(checker.reference_depth("y"), 0);
    }

    #[test]
    fn test_borrow_checker_circular_reference_detection() {
        let mut checker = BorrowChecker::new();
        checker.declare_variable("a".to_string());
        checker.declare_variable("b".to_string());

        let lt = Lifetime::new(1);
        checker.add_reference("a", "b", RefType::Immutable(lt));
        checker.add_reference("b", "a", RefType::Immutable(lt));

        let result = checker.check_circular_references();
        assert!(result.is_err());
    }

    #[test]
    fn test_borrow_checker_complex_scenario() {
        let mut checker = BorrowChecker::new();

        // 3개 변수 선언
        checker.declare_variable("x".to_string());
        checker.declare_variable("y".to_string());
        checker.declare_variable("z".to_string());

        // x의 불변 빌림
        assert!(checker.try_borrow_immutable("x", "line 1").is_ok());
        assert!(checker.try_borrow_immutable("x", "line 2").is_ok());

        // y의 가변 빌림
        assert!(checker.try_borrow_mutable("y", "line 3").is_ok());

        // z 참조
        let lt = Lifetime::new(1);
        checker.add_reference("x", "y", RefType::Immutable(lt));
        checker.add_reference("y", "z", RefType::Mutable(lt));

        // 깊이 확인
        assert_eq!(checker.reference_depth("x"), 2);
        assert_eq!(checker.reference_depth("y"), 1);

        // 상태 확인
        assert_eq!(checker.errors().len(), 0);
    }
}

