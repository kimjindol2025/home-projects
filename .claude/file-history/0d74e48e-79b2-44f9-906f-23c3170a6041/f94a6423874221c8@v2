// ============================================================================
// Borrow Error Types
// ============================================================================

/// Borrow 규칙 위반 에러
#[derive(Clone, Debug, PartialEq, Eq)]
pub enum BorrowError {
    /// 이미 가변 빌림 중
    AlreadyMutablyBorrowed {
        variable: String,
        location: String,
    },

    /// 활성 불변 빌림이 있음
    ActiveImmutableBorrows {
        variable: String,
        count: usize,
    },

    /// Use-after-free: 변수가 drop된 후 참조 사용
    UseAfterFree {
        variable: String,
        location: String,
    },

    /// 순환 참조 감지
    CircularReference {
        variables: Vec<String>,
    },

    /// Lifetime 충돌
    LifetimeConflict {
        variable: String,
        reason: String,
    },

    /// 참조 유효 범위 초과
    ReferenceOutOfScope {
        variable: String,
        scope: u32,
    },
}

impl BorrowError {
    pub fn to_string(&self) -> String {
        match self {
            BorrowError::AlreadyMutablyBorrowed { variable, location } => {
                format!(
                    "Cannot borrow '{}' as immutable because it is already borrowed as mutable (at {})",
                    variable, location
                )
            }
            BorrowError::ActiveImmutableBorrows { variable, count } => {
                format!(
                    "Cannot borrow '{}' as mutable because {} immutable borrow(s) are still active",
                    variable, count
                )
            }
            BorrowError::UseAfterFree { variable, location } => {
                format!(
                    "Use of moved value '{}' (moved at {})",
                    variable, location
                )
            }
            BorrowError::CircularReference { variables } => {
                format!(
                    "Circular reference detected: {}",
                    variables.join(" → ")
                )
            }
            BorrowError::LifetimeConflict { variable, reason } => {
                format!(
                    "Lifetime conflict in '{}': {}",
                    variable, reason
                )
            }
            BorrowError::ReferenceOutOfScope { variable, scope } => {
                format!(
                    "Reference '{}' outlives its scope (scope #{})",
                    variable, scope
                )
            }
        }
    }
}

// ============================================================================
// Reference Graph: 참조 관계 그래프
// ============================================================================

/// 참조 관계를 추적하는 그래프
#[derive(Clone, Debug)]
pub struct ReferenceEdge {
    /// 참조하는 변수
    from: String,

    /// 참조되는 변수
    to: String,

    /// 참조 타입
    ref_type: RefType,
}

pub struct ReferenceGraph {
    edges: Vec<ReferenceEdge>,
    variables: HashSet<String>,
}

impl ReferenceGraph {
    pub fn new() -> ReferenceGraph {
        ReferenceGraph {
            edges: Vec::new(),
            variables: HashSet::new(),
        }
    }

    /// 변수를 추가합니다.
    pub fn add_variable(&mut self, name: String) {
        self.variables.insert(name);
    }

    /// 참조 엣지를 추가합니다.
    pub fn add_reference(&mut self, from: String, to: String, ref_type: RefType) {
        self.edges.push(ReferenceEdge { from, to, ref_type });
    }

    /// 순환 참조를 감지합니다.
    pub fn detect_cycles(&self) -> Vec<Vec<String>> {
        let mut cycles = Vec::new();
        let mut visited = HashSet::new();
        let mut rec_stack = HashSet::new();

        for var in &self.variables {
            if !visited.contains(var) {
                self.dfs_cycles(var, &mut visited, &mut rec_stack, &mut cycles, vec![]);
            }
        }

        cycles
    }

    fn dfs_cycles(
        &self,
        node: &str,
        visited: &mut HashSet<String>,
        rec_stack: &mut HashSet<String>,
        cycles: &mut Vec<Vec<String>>,
        path: Vec<String>,
    ) {
        visited.insert(node.to_string());
        rec_stack.insert(node.to_string());

        let mut new_path = path;
        new_path.push(node.to_string());

        // 이 노드에서 나가는 모든 엣지 찾기
        for edge in &self.edges {
            if edge.from == node {
                if !visited.contains(&edge.to) {
                    self.dfs_cycles(&edge.to, visited, rec_stack, cycles, new_path.clone());
                } else if rec_stack.contains(&edge.to) {
                    // 순환 발견!
                    let cycle_start = new_path.iter().position(|v| v == &edge.to);
                    if let Some(start_idx) = cycle_start {
                        let mut cycle = new_path[start_idx..].to_vec();
                        cycle.push(edge.to.clone());
                        cycles.push(cycle);
                    }
                }
            }
        }

        rec_stack.remove(node);
    }

    /// 순환 참조가 있는지 확인합니다.
    pub fn has_cycles(&self) -> bool {
        !self.detect_cycles().is_empty()
    }

    /// 변수의 참조 깊이를 계산합니다.
    pub fn reference_depth(&self, var: &str) -> usize {
        let mut visited = HashSet::new();
        self.calculate_depth(var, &mut visited)
    }

    fn calculate_depth(&self, var: &str, visited: &mut HashSet<String>) -> usize {
        if visited.contains(var) {
            return 0; // 순환 방지
        }

        visited.insert(var.to_string());

        let mut max_depth = 0;
        for edge in &self.edges {
            if edge.from == var {
                let depth = 1 + self.calculate_depth(&edge.to, visited);
                max_depth = max_depth.max(depth);
            }
        }

        max_depth
    }
}

// ============================================================================
// Borrow Checker: 빌림 규칙 검증 엔진
// ============================================================================

pub struct BorrowChecker {
    /// 변수의 현재 상태
    borrow_states: HashMap<String, BorrowState>,

    /// Lifetime 분석기
    lifetime_analyzer: LifetimeAnalyzer,

    /// 참조 그래프
    reference_graph: ReferenceGraph,

    /// 에러 히스토리
    errors: Vec<BorrowError>,
}

impl BorrowChecker {
    pub fn new() -> BorrowChecker {
        BorrowChecker {
            borrow_states: HashMap::new(),
            lifetime_analyzer: LifetimeAnalyzer::new(),
            reference_graph: ReferenceGraph::new(),
            errors: Vec::new(),
        }
    }

    /// 변수를 선언합니다.
    pub fn declare_variable(&mut self, name: String) {
        self.borrow_states.insert(name.clone(), BorrowState::Unused);
        self.reference_graph.add_variable(name);
    }

    /// 불변 빌림을 시도합니다.
    pub fn try_borrow_immutable(&mut self, variable: &str, location: &str) -> Result<(), BorrowError> {
        if let Some(state) = self.borrow_states.get(variable) {
            match state.try_borrow() {
                Ok(new_state) => {
                    self.borrow_states.insert(variable.to_string(), new_state);
                    Ok(())
                }
                Err(_) => {
                    let error = BorrowError::AlreadyMutablyBorrowed {
                        variable: variable.to_string(),
                        location: location.to_string(),
                    };
                    self.errors.push(error.clone());
                    Err(error)
                }
            }
        } else {
            Err(BorrowError::UseAfterFree {
                variable: variable.to_string(),
                location: location.to_string(),
            })
        }
    }

    /// 가변 빌림을 시도합니다.
    pub fn try_borrow_mutable(&mut self, variable: &str, location: &str) -> Result<(), BorrowError> {
        if let Some(state) = self.borrow_states.get(variable) {
            match state.try_borrow_mut() {
                Ok(new_state) => {
                    self.borrow_states.insert(variable.to_string(), new_state);
                    Ok(())
                }
                Err(_) => {
                    let count = state.borrow_count();
                    let error = BorrowError::ActiveImmutableBorrows {
                        variable: variable.to_string(),
                        count,
                    };
                    self.errors.push(error.clone());
                    Err(error)
                }
            }
        } else {
            Err(BorrowError::UseAfterFree {
                variable: variable.to_string(),
                location: location.to_string(),
            })
        }
    }

    /// 불변 빌림을 해제합니다.
    pub fn release_immutable(&mut self, variable: &str) -> Result<(), BorrowError> {
        if let Some(state) = self.borrow_states.get(variable) {
            if let Ok(new_state) = state.try_borrow() {
                // 빌림이 가능한 상태였으므로 해제
                let new_state = new_state.release_borrow();
                self.borrow_states.insert(variable.to_string(), new_state);
                Ok(())
            } else {
                Err(BorrowError::UseAfterFree {
                    variable: variable.to_string(),
                    location: "release".to_string(),
                })
            }
        } else {
            Err(BorrowError::UseAfterFree {
                variable: variable.to_string(),
                location: "release".to_string(),
            })
        }
    }

    /// 가변 빌림을 해제합니다.
    pub fn release_mutable(&mut self, variable: &str) -> Result<(), BorrowError> {
        if let Some(state) = self.borrow_states.get(variable) {
            if matches!(state, BorrowState::Exclusive) {
                let new_state = state.release_borrow_mut();
                self.borrow_states.insert(variable.to_string(), new_state);
                Ok(())
            } else {
                Err(BorrowError::UseAfterFree {
                    variable: variable.to_string(),
                    location: "release_mutable".to_string(),
                })
            }
        } else {
            Err(BorrowError::UseAfterFree {
                variable: variable.to_string(),
                location: "release_mutable".to_string(),
            })
        }
    }

    /// 참조 관계를 추가합니다.
    pub fn add_reference(&mut self, from: &str, to: &str, ref_type: RefType) {
        self.reference_graph.add_reference(
            from.to_string(),
            to.to_string(),
            ref_type,
        );
    }

    /// 순환 참조를 검사합니다.
    pub fn check_circular_references(&mut self) -> Result<(), BorrowError> {
        let cycles = self.reference_graph.detect_cycles();
        if !cycles.is_empty() {
            let error = BorrowError::CircularReference {
                variables: cycles[0].clone(),
            };
            self.errors.push(error.clone());
            return Err(error);
        }
        Ok(())
    }

    /// 모든 에러를 반환합니다.
    pub fn errors(&self) -> &[BorrowError] {
        &self.errors
    }

    /// 현재 상태를 반환합니다.
    pub fn get_state(&self, variable: &str) -> Option<BorrowState> {
        self.borrow_states.get(variable).copied()
    }

    /// 모든 변수의 상태를 반환합니다.
    pub fn all_states(&self) -> &HashMap<String, BorrowState> {
        &self.borrow_states
    }

    /// 참조 깊이를 계산합니다.
    pub fn reference_depth(&self, variable: &str) -> usize {
        self.reference_graph.reference_depth(variable)
    }
}

