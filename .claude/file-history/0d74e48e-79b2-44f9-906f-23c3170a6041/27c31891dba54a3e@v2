/// 통합 OS - FreeLang 플랫폼
pub struct FreeLangOS {
    /// 런타임
    pub runtime: FreeLangRuntime,

    /// 메모리 (시뮬레이션)
    pub memory: Vec<u8>,

    /// 프로세스 목록
    pub processes: Vec<String>,

    /// 현재 프로세스
    pub current_process: Option<String>,

    /// 인터럽트 카운트
    pub interrupt_count: u32,

    /// I/O 작업 수
    pub io_operations: u32,

    /// 시스템 틱
    pub ticks: u64,

    /// 자체 호스팅 여부
    pub self_hosted: bool,
}

impl FreeLangOS {
    pub fn new() -> Self {
        FreeLangOS {
            runtime: FreeLangRuntime::new(),
            memory: vec![0; 1024],  // 1KB 메모리
            processes: Vec::new(),
            current_process: None,
            interrupt_count: 0,
            io_operations: 0,
            ticks: 0,
            self_hosted: true,  // ✨ 자체 호스팅!
        }
    }

    pub fn boot(&mut self) -> Result<(), String> {
        println!("╔════════════════════════════════════════════════════════════╗");
        println!("║        FreeLang OS - Self-Hosted Execution                 ║");
        println!("╚════════════════════════════════════════════════════════════╝\n");

        println!("🔧 Booting FreeLang OS...");
        println!("   Self-Hosted: ✅ YES (Rust-independent)\n");

        // 시스템 프로세스 생성
        self.create_process("shell")?;
        self.create_process("system")?;

        println!("✅ Boot complete - System ready\n");

        Ok(())
    }

    pub fn create_process(&mut self, name: &str) -> Result<(), String> {
        self.processes.push(name.to_string());
        if self.current_process.is_none() {
            self.current_process = Some(name.to_string());
        }
        println!("  ✅ Process created: {}", name);
        Ok(())
    }

    pub fn run_freelang_program(&mut self, program: Vec<&str>) -> Result<(), String> {
        println!("🚀 Executing FreeLang Program...\n");

        for (idx, stmt) in program.iter().enumerate() {
            println!("[{}] {}", idx + 1, stmt);

            self.runtime.execute_statement(stmt)?;
            self.ticks += 1;

            // 시뮬레이션된 I/O
            if stmt.contains("print") {
                self.io_operations += 1;
            }
        }

        println!("\n✅ Program execution complete\n");
        Ok(())
    }

    pub fn interrupt(&mut self, _int_type: u8) {
        self.interrupt_count += 1;
        self.ticks += 1;
    }

    pub fn print_system_status(&self) {
        println!("╔════════════════════════════════════════════════════════════╗");
        println!("║            FreeLang OS System Status Report                ║");
        println!("╚════════════════════════════════════════════════════════════╝");

        println!("\n🖥️  System Information:");
        println!("  Self-Hosted: ✅ YES");
        println!("  Total Ticks: {}", self.ticks);
        println!("  Interrupts: {}", self.interrupt_count);
        println!("  I/O Operations: {}", self.io_operations);

        println!("\n🔄 Processes ({}):", self.processes.len());
        for (idx, proc) in self.processes.iter().enumerate() {
            let marker = if self.current_process.as_ref() == Some(proc) {
                "▶️ "
            } else {
                "⏸️ "
            };
            println!("  {} {} (Process {})", marker, proc, idx + 1);
        }

        println!("\n💾 Memory Usage:");
        println!("  Runtime Memory: {} bytes", self.runtime.memory_used);
        println!("  Total Memory: {} bytes", self.memory.len());

        self.runtime.print_status();
    }
}

