/// FreeLang 언어 런타임
pub struct FreeLangRuntime {
    /// 변수 환경
    pub variables: Vec<(String, i64)>,

    /// 실행된 명령어 수
    pub instructions_executed: u32,

    /// 실행 상태
    pub running: bool,

    /// 에러 상태
    pub last_error: Option<String>,

    /// 메모리 사용량 (바이트)
    pub memory_used: u64,
}

impl FreeLangRuntime {
    pub fn new() -> Self {
        FreeLangRuntime {
            variables: Vec::new(),
            instructions_executed: 0,
            running: true,
            last_error: None,
            memory_used: 0,
        }
    }

    /// 변수 설정
    pub fn set_variable(&mut self, name: String, value: i64) -> Result<(), String> {
        // 기존 변수 업데이트
        for (var_name, var_value) in &mut self.variables {
            if var_name == &name {
                *var_value = value;
                return Ok(());
            }
        }

        // 새 변수 추가
        self.variables.push((name, value));
        self.memory_used += 8;  // 64-bit 정수

        Ok(())
    }

    /// 변수 조회
    pub fn get_variable(&self, name: &str) -> Option<i64> {
        for (var_name, var_value) in &self.variables {
            if var_name == name {
                return Some(*var_value);
            }
        }
        None
    }

    /// 표현식 평가
    pub fn eval_expression(&mut self, expr: &str) -> Result<i64, String> {
        // 간단한 산술 평가 (시뮬레이션)
        if expr.contains("+") {
            let parts: Vec<&str> = expr.split("+").collect();
            if parts.len() == 2 {
                if let (Ok(a), Ok(b)) = (parts[0].trim().parse::<i64>(),
                                        parts[1].trim().parse::<i64>()) {
                    self.instructions_executed += 1;
                    return Ok(a + b);
                }
            }
        } else if expr.contains("-") {
            let parts: Vec<&str> = expr.split("-").collect();
            if parts.len() == 2 {
                if let (Ok(a), Ok(b)) = (parts[0].trim().parse::<i64>(),
                                        parts[1].trim().parse::<i64>()) {
                    self.instructions_executed += 1;
                    return Ok(a - b);
                }
            }
        } else if expr.contains("*") {
            let parts: Vec<&str> = expr.split("*").collect();
            if parts.len() == 2 {
                if let (Ok(a), Ok(b)) = (parts[0].trim().parse::<i64>(),
                                        parts[1].trim().parse::<i64>()) {
                    self.instructions_executed += 1;
                    return Ok(a * b);
                }
            }
        } else if let Ok(num) = expr.parse::<i64>() {
            self.instructions_executed += 1;
            return Ok(num);
        }

        self.last_error = Some(format!("Cannot evaluate: {}", expr));
        Err(self.last_error.as_ref().unwrap().clone())
    }

    /// 명령어 실행
    pub fn execute_statement(&mut self, stmt: &str) -> Result<(), String> {
        if stmt.starts_with("let ") {
            // let x = 10
            let rest = &stmt[4..];
            if let Some(eq_pos) = rest.find("=") {
                let var_name = rest[..eq_pos].trim().to_string();
                let value_str = rest[eq_pos+1..].trim();

                if let Ok(value) = value_str.parse::<i64>() {
                    self.set_variable(var_name.clone(), value)?;
                    println!("✅ Variable {} = {}", var_name, value);
                    self.instructions_executed += 1;
                    return Ok(());
                }
            }
            return Err("Invalid let statement".to_string());
        } else if stmt.starts_with("print ") {
            // print "hello" 또는 print x
            let rest = &stmt[6..].trim();
            if rest.starts_with("\"") && rest.ends_with("\"") {
                let text = &rest[1..rest.len()-1];
                println!("📝 Output: {}", text);
            } else {
                if let Some(value) = self.get_variable(rest) {
                    println!("📝 Output: {}", value);
                } else {
                    return Err(format!("Unknown variable: {}", rest));
                }
            }
            self.instructions_executed += 1;
            return Ok(());
        }

        Err(format!("Unknown statement: {}", stmt))
    }

    pub fn print_status(&self) {
        println!("\n📊 FreeLang Runtime Status:");
        println!("  Instructions: {}", self.instructions_executed);
        println!("  Variables: {}", self.variables.len());
        println!("  Memory: {} bytes", self.memory_used);
        println!("  Running: {}", self.running);

        if !self.variables.is_empty() {
            println!("\n  Variable Bindings:");
            for (name, value) in &self.variables {
                println!("    {} = {}", name, value);
            }
        }
    }
}

