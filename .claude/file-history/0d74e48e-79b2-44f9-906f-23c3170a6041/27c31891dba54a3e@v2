#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_freelang_runtime_creation() {
        let runtime = FreeLangRuntime::new();
        assert_eq!(runtime.instructions_executed, 0);
        assert!(runtime.running);
    }

    #[test]
    fn test_freelang_runtime_variable() {
        let mut runtime = FreeLangRuntime::new();
        runtime.set_variable("x".to_string(), 42).unwrap();
        assert_eq!(runtime.get_variable("x"), Some(42));
    }

    #[test]
    fn test_freelang_runtime_expression() {
        let mut runtime = FreeLangRuntime::new();
        let result = runtime.eval_expression("5 + 3").unwrap();
        assert_eq!(result, 8);
    }

    #[test]
    fn test_freelang_runtime_statement() {
        let mut runtime = FreeLangRuntime::new();
        runtime.execute_statement("let x = 10").unwrap();
        assert_eq!(runtime.get_variable("x"), Some(10));
    }

    #[test]
    fn test_freelang_os_creation() {
        let os = FreeLangOS::new();
        assert!(os.self_hosted);
        assert_eq!(os.processes.len(), 0);
    }

    #[test]
    fn test_freelang_os_boot() {
        let mut os = FreeLangOS::new();
        assert!(os.boot().is_ok());
        assert!(os.processes.len() > 0);
    }

    #[test]
    fn test_freelang_os_process_creation() {
        let mut os = FreeLangOS::new();
        assert!(os.create_process("test").is_ok());
        assert_eq!(os.processes.len(), 1);
    }

    #[test]
    fn test_freelang_os_program_execution() {
        let mut os = FreeLangOS::new();
        os.boot().unwrap();

        let program = vec!["let x = 42"];
        assert!(os.run_freelang_program(program).is_ok());
        assert_eq!(os.runtime.instructions_executed, 1);
    }

    #[test]
    fn test_self_hosting_validator() {
        let mut validator = SelfHostingValidator::new();
        assert!(validator.validate().is_ok());
        assert_eq!(validator.independence_score, 100);
    }

    #[test]
    fn test_self_hosted_independence() {
        let os = FreeLangOS::new();
        assert!(os.self_hosted);
        assert_eq!(os.runtime.memory_used, 0);
    }

    #[test]
    fn test_freelang_os_interrupt() {
        let mut os = FreeLangOS::new();
        os.interrupt(32);
        assert_eq!(os.interrupt_count, 1);
    }
}
