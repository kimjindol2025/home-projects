pub struct KernelMemoryManager {
    /// 커널 힙 시작 주소
    pub heap_start: u64,

    /// 커널 힙 끝 주소
    pub heap_end: u64,

    /// 사용 중인 메모리 크기
    pub used_size: u64,

    /// 할당된 블록 수
    pub allocated_blocks: u32,
}

impl KernelMemoryManager {
    pub fn new(heap_start: u64, heap_size: u64) -> Self {
        KernelMemoryManager {
            heap_start,
            heap_end: heap_start + heap_size,
            used_size: 0,
            allocated_blocks: 0,
        }
    }

    pub fn available_memory(&self) -> u64 {
        self.heap_end - self.heap_start - self.used_size
    }

    pub fn allocate_memory(&mut self, size: u64) -> Result<u64, String> {
        if self.used_size + size > (self.heap_end - self.heap_start) {
            return Err("Out of memory".to_string());
        }

        let addr = self.heap_start + self.used_size;
        self.used_size += size;
        self.allocated_blocks += 1;

        Ok(addr)
    }

    pub fn memory_usage_percent(&self) -> f64 {
        let total = self.heap_end - self.heap_start;
        if total == 0 {
            return 0.0;
        }
        (self.used_size as f64 / total as f64) * 100.0
    }
}

// ============================================================================
// Part 2: 프로세스 구조체
// ============================================================================

#[derive(Clone, Copy)]
pub enum ProcessState {
    Ready,
    Running,
    Blocked,
    Terminated,
}

pub struct Process {
    /// 프로세스 ID
    pub pid: u32,

    /// 프로세스 상태
    pub state: ProcessState,

    /// 프로그램 카운터 (PC)
    pub program_counter: u64,

    /// 스택 포인터 (SP)
    pub stack_pointer: u64,

    /// 페이지 테이블 기본 주소
    pub page_table_base: u64,

    /// 할당된 메모리 크기
    pub memory_size: u64,

    /// 프로세스 생성 시간 (ms)
    pub creation_time: u64,

    /// CPU 사용 시간 (ms)
    pub cpu_time: u64,
}

impl Process {
    pub fn new(pid: u32, program_counter: u64, stack_pointer: u64) -> Self {
        Process {
            pid,
            state: ProcessState::Ready,
            program_counter,
            stack_pointer,
            page_table_base: 0,
            memory_size: 0,
            creation_time: 0,
            cpu_time: 0,
        }
    }

    pub fn mark_running(&mut self) {
        self.state = ProcessState::Running;
    }

    pub fn mark_blocked(&mut self) {
        self.state = ProcessState::Blocked;
    }

    pub fn mark_ready(&mut self) {
        self.state = ProcessState::Ready;
    }

    pub fn mark_terminated(&mut self) {
        self.state = ProcessState::Terminated;
    }

    pub fn is_runnable(&self) -> bool {
        match self.state {
            ProcessState::Ready | ProcessState::Running => true,
            _ => false,
        }
    }
}

// ============================================================================
// Part 3: 인터럽트 핸들러
// ============================================================================

pub enum InterruptType {
    Timer,           // 타이머 인터럽트
    PageFault,       // 페이지 폴트
    SegmentationFault, // 세그멘테이션 폴트
    DivideByZero,    // 0으로 나누기
    InvalidOp,       // 잘못된 명령어
}

pub struct InterruptHandler {
    /// 인터럽트 타입
    pub interrupt_type: InterruptType,

    /// 인터럽트 발생 주소
    pub address: u64,

    /// 인터럽트 발생 시간 (ms)
    pub timestamp: u64,
}

impl InterruptHandler {
    pub fn new(interrupt_type: InterruptType, address: u64, timestamp: u64) -> Self {
        InterruptHandler {
            interrupt_type,
            address,
            timestamp,
        }
    }

    pub fn handle(&self) -> String {
        match self.interrupt_type {
            InterruptType::Timer => {
                format!("⏱️  Timer interrupt at 0x{:x}", self.address)
            }
            InterruptType::PageFault => {
                format!("📄 Page fault at 0x{:x}", self.address)
            }
            InterruptType::SegmentationFault => {
                format!("💥 Segmentation fault at 0x{:x}", self.address)
            }
            InterruptType::DivideByZero => {
                format!("➗ Divide by zero at 0x{:x}", self.address)
            }
            InterruptType::InvalidOp => {
                format!("⚠️  Invalid operation at 0x{:x}", self.address)
            }
        }
    }
}

// ============================================================================
// Part 4: 시스템 호출 핸들러
// ============================================================================

pub enum SyscallType {
    PrintString,     // 문자열 출력
    Allocate,        // 메모리 할당
    Deallocate,      // 메모리 해제
    CreateProcess,   // 프로세스 생성
    Exit,            // 프로세스 종료
}

pub struct SyscallHandler {
    pub syscall_type: SyscallType,
    pub arg1: u64,
    pub arg2: u64,
    pub arg3: u64,
}

impl SyscallHandler {
    pub fn new(syscall_type: SyscallType, arg1: u64, arg2: u64, arg3: u64) -> Self {
        SyscallHandler {
            syscall_type,
            arg1,
            arg2,
            arg3,
        }
    }

    pub fn execute(&self) -> Result<u64, String> {
        match self.syscall_type {
            SyscallType::PrintString => {
                println!("📝 Syscall: PrintString");
                Ok(0)
            }
            SyscallType::Allocate => {
                println!("💾 Syscall: Allocate({} bytes)", self.arg1);
                Ok(self.arg1)
            }
            SyscallType::Deallocate => {
                println!("🗑️  Syscall: Deallocate(0x{:x})", self.arg1);
                Ok(0)
            }
            SyscallType::CreateProcess => {
                println!("🔄 Syscall: CreateProcess(pc=0x{:x})", self.arg1);
                Ok(1)  // 새 프로세스 ID
            }
            SyscallType::Exit => {
                println!("🛑 Syscall: Exit({})", self.arg1);
                Ok(0)
            }
        }
    }
}

// ============================================================================
// Part 5: 커널 구조
// ============================================================================

pub struct Kernel {
    /// 메모리 관리자
    pub memory_manager: KernelMemoryManager,

    /// 프로세스 목록
    pub processes: Vec<Process>,

    /// 다음 프로세스 ID
    pub next_pid: u32,

    /// 현재 실행 중인 프로세스
    pub current_process_id: Option<u32>,

    /// 인터럽트 카운트
    pub interrupt_count: u32,

    /// 시스템 호출 카운트
    pub syscall_count: u32,

    /// 커널 부팅 시간 (ms)
    pub boot_time: u64,
}

impl Kernel {
    pub fn new() -> Self {
        Kernel {
            memory_manager: KernelMemoryManager::new(0x200000, 0x1FE00000),
            processes: Vec::new(),
            next_pid: 1,
            current_process_id: None,
            interrupt_count: 0,
            syscall_count: 0,
            boot_time: 0,
        }
    }

    pub fn create_process(&mut self, program_counter: u64) -> u32 {
        let pid = self.next_pid;
        let stack_pointer = 0x7FFFFFFF;  // 스택은 위에서 아래로

        let mut process = Process::new(pid, program_counter, stack_pointer);
        process.memory_size = 4096;  // 각 프로세스는 4KB 메모리
        process.page_table_base = pid as u64 * 0x1000;

        self.processes.push(process);
        self.next_pid += 1;

        println!("✨ Process {} created at PC=0x{:x}", pid, program_counter);
        pid
    }

    pub fn terminate_process(&mut self, pid: u32) -> bool {
        for process in &mut self.processes {
            if process.pid == pid {
                process.mark_terminated();
                return true;
            }
        }
        false
    }

    pub fn get_process(&self, pid: u32) -> Option<&Process> {
        self.processes.iter().find(|p| p.pid == pid)
    }

    pub fn get_process_mut(&mut self, pid: u32) -> Option<&mut Process> {
        self.processes.iter_mut().find(|p| p.pid == pid)
    }

    pub fn process_count(&self) -> usize {
        self.processes.len()
    }

    pub fn runnable_process_count(&self) -> usize {
        self.processes.iter().filter(|p| p.is_runnable()).count()
    }

    pub fn print_status(&self) {
        println!("\n╔════════════════════════════════════════════════════════════╗");
        println!("║             FreeLang OS Kernel Status Report               ║");
        println!("╚════════════════════════════════════════════════════════════╝");

        println!("\n📊 Memory Status:");
        println!("   Heap Start: 0x{:x}", self.memory_manager.heap_start);
        println!("   Used: {} bytes", self.memory_manager.used_size);
        println!("   Available: {} bytes", self.memory_manager.available_memory());
        println!("   Usage: {:.2}%", self.memory_manager.memory_usage_percent());

        println!("\n🔄 Process Status:");
        println!("   Total Processes: {}", self.process_count());
        println!("   Runnable Processes: {}", self.runnable_process_count());
        println!("   Current Process ID: {:?}", self.current_process_id);

        println!("\n⚡ Interrupt Status:");
        println!("   Total Interrupts: {}", self.interrupt_count);
        println!("   Total Syscalls: {}", self.syscall_count);

        if self.process_count() > 0 {
            println!("\n📋 Process List:");
            for process in &self.processes {
                println!("   PID {} - State: {:?}, PC: 0x{:x}",
                         process.pid,
                         process.state,
                         process.program_counter);
            }
        }

        println!();
    }
}

// ============================================================================
// Part 6: 메인 커널 진입점
// ============================================================================

pub fn main() {
    println!("╔════════════════════════════════════════════════════════════╗");
    println!("║      FreeLang OS Kernel - Phase G Week 1 Main Entry        ║");
    println!("╚════════════════════════════════════════════════════════════╝\n");

    // 커널 초기화
    let mut kernel = Kernel::new();
    kernel.boot_time = 0;  // 실제로는 시스템 타이머 사용

    println!("✅ Kernel initialized successfully");

    // 프로세스 생성 테스트
    println!("\n🔧 Creating test processes...");

    let pid1 = kernel.create_process(0x100000);
    let pid2 = kernel.create_process(0x110000);
    let pid3 = kernel.create_process(0x120000);

    // 프로세스 상태 변경
    if let Some(proc) = kernel.get_process_mut(pid1) {
        proc.mark_running();
    }

    kernel.current_process_id = Some(pid1);

    // 인터럽트 처리 테스트
    println!("\n⚡ Testing interrupt handling...");

    let interrupt = InterruptHandler::new(InterruptType::Timer, 0x100000, 100);
    println!("   {}", interrupt.handle());
    kernel.interrupt_count += 1;

    let interrupt = InterruptHandler::new(InterruptType::PageFault, 0x500000, 150);
    println!("   {}", interrupt.handle());
    kernel.interrupt_count += 1;

    // 시스템 호출 테스트
    println!("\n🔗 Testing system calls...");

    let syscall = SyscallHandler::new(SyscallType::Allocate, 4096, 0, 0);
    if let Ok(result) = syscall.execute() {
        println!("   ✅ Result: 0x{:x}", result);
    }
    kernel.syscall_count += 1;

    let syscall = SyscallHandler::new(SyscallType::CreateProcess, 0x130000, 0, 0);
    if let Ok(result) = syscall.execute() {
        println!("   ✅ Result: Process ID {}", result);
    }
    kernel.syscall_count += 1;

    // 커널 상태 출력
    kernel.print_status();

    // 메모리 할당 테스트
    println!("💾 Memory allocation test:");
    match kernel.memory_manager.allocate_memory(8192) {
        Ok(addr) => println!("   ✅ Allocated 8KB at 0x{:x}", addr),
        Err(e) => println!("   ❌ Error: {}", e),
    }

    println!("\n✨ Kernel operations complete!\n");
}

