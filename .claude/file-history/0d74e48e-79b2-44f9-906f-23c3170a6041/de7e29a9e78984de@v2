#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_kernel_creation() {
        let kernel = Kernel::new();
        assert_eq!(kernel.process_count(), 0);
        assert_eq!(kernel.next_pid, 1);
    }

    #[test]
    fn test_process_creation() {
        let mut kernel = Kernel::new();
        let pid1 = kernel.create_process(0x100000);
        let pid2 = kernel.create_process(0x110000);

        assert_eq!(pid1, 1);
        assert_eq!(pid2, 2);
        assert_eq!(kernel.process_count(), 2);
    }

    #[test]
    fn test_process_retrieval() {
        let mut kernel = Kernel::new();
        let pid = kernel.create_process(0x100000);

        let proc = kernel.get_process(pid);
        assert!(proc.is_some());
        assert_eq!(proc.unwrap().pid, pid);
    }

    #[test]
    fn test_process_termination() {
        let mut kernel = Kernel::new();
        let pid = kernel.create_process(0x100000);

        assert!(kernel.terminate_process(pid));
        let proc = kernel.get_process(pid).unwrap();
        assert!(matches!(proc.state, ProcessState::Terminated));
    }

    #[test]
    fn test_memory_manager() {
        let mut mm = KernelMemoryManager::new(0x1000, 0x10000);

        if let Ok(addr) = mm.allocate_memory(4096) {
            assert_eq!(addr, 0x1000);
            assert_eq!(mm.used_size, 4096);
        } else {
            panic!("Memory allocation failed");
        }
    }

    #[test]
    fn test_interrupt_handler() {
        let interrupt = InterruptHandler::new(InterruptType::Timer, 0x100000, 100);
        let msg = interrupt.handle();
        assert!(msg.contains("Timer"));
    }

    #[test]
    fn test_syscall_handler() {
        let syscall = SyscallHandler::new(SyscallType::Allocate, 4096, 0, 0);
        let result = syscall.execute();
        assert!(result.is_ok());
    }

    #[test]
    fn test_memory_usage_percent() {
        let mut mm = KernelMemoryManager::new(0x1000, 0x10000);
        mm.allocate_memory(0x8000).unwrap();  // 절반 할당

        let usage = mm.memory_usage_percent();
        assert!(usage > 49.0 && usage < 51.0);  // 약 50%
    }
}
