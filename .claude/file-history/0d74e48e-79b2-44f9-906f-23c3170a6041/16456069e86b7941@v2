fn assert
  input: (condition: bool, message: string)
  output: void
  intent: "조건을 검증하고 실패 시 메시지 출력"
  do
    if condition
      print("✓ PASS: " + message)
    else
      print("✗ FAIL: " + message)

fn assertEquals
  input: (actual: number, expected: number, message: string)
  output: void
  intent: "두 숫자가 같은지 검증"
  do
    if actual == expected
      print("✓ PASS: " + message)
    else
      print("✗ FAIL: " + message + " (expected: " + str(expected) +
           ", got: " + str(actual) + ")")

fn assertStringEquals
  input: (actual: string, expected: string, message: string)
  output: void
  intent: "두 문자열이 같은지 검증"
  do
    if actual == expected
      print("✓ PASS: " + message)
    else
      print("✗ FAIL: " + message)

