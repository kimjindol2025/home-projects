fn testInitTodoStore
  input: void
  output: void
  intent: "Todo 저장소 초기화 테스트"
  do
    let store = initTodoStore()

    assertEquals(store.nextId, 1, "nextId should be 1")
    assertEquals(storeSize(store), 0, "store should be empty")

fn testStorageSize
  input: void
  output: void
  intent: "저장소 크기 계산 테스트"
  do
    let store = initTodoStore()
    assertEquals(storeSize(store), 0, "empty store size")

    let todo = {
      id: 1,
      title: "Test",
      description: "",
      completed: false,
      createdAt: "2026-03-02T10:30:00Z",
      updatedAt: "2026-03-02T10:30:00Z"
    }

    let newStore = {
      todos: mapSet(store.todos, 1, todo),
      nextId: store.nextId
    }

    assertEquals(storeSize(newStore), 1, "store size after adding 1 todo")

