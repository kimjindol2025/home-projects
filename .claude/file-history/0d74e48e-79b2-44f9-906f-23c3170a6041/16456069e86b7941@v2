fn testErrorToStatus
  input: void
  output: void
  intent: "에러를 HTTP 상태 코드로 변환하는 테스트"
  do
    let validationError = ApiError::ValidationError("Invalid input")
    assertEquals(errorToStatus(validationError), 400, "ValidationError -> 400")

    let notFoundError = ApiError::NotFound("Not found")
    assertEquals(errorToStatus(notFoundError), 404, "NotFound -> 404")

    let conflictError = ApiError::Conflict("Conflict")
    assertEquals(errorToStatus(conflictError), 409, "Conflict -> 409")

    let serverError = ApiError::ServerError("Server error")
    assertEquals(errorToStatus(serverError), 500, "ServerError -> 500")

fn testErrorCode
  input: void
  output: void
  intent: "에러 코드 문자열 추출 테스트"
  do
    let validationError = ApiError::ValidationError("Invalid")
    assertStringEquals(errorCode(validationError), "VALIDATION_ERROR", "error code extraction")

fn testCreateErrorResponse
  input: void
  output: void
  intent: "에러를 HTTP 응답으로 변환하는 테스트"
  do
    let error = ApiError::NotFound("Resource not found")
    let response = createErrorResponse(error)

    assertEquals(response.status, 404, "error response status")
    assertStringEquals(response.headers.get("Content-Type").getOrElse(""), "application/json", "content type")

