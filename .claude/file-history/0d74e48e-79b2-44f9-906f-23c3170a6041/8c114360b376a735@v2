use crate::stdlib::FlValue;

// ============================================================================
// ErrorHandler - 에러 처리 타입
// ============================================================================

/// 에러 처리 상황을 나타내는 결과
#[derive(Clone, Debug, PartialEq)]
pub enum ErrorResult {
    /// 성공한 값
    Success(FlValue),

    /// 에러 메시지
    Error(String),

    /// 패닉 상태
    Panicked(String),
}

impl std::fmt::Display for ErrorResult {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            ErrorResult::Success(val) => write!(f, "Success: {:?}", val),
            ErrorResult::Error(msg) => write!(f, "Error: {}", msg),
            ErrorResult::Panicked(msg) => write!(f, "Panic: {}", msg),
        }
    }
}

// ============================================================================
// Error Handling Functions
// ============================================================================

/// 주어진 값이 에러인지 확인합니다.
///
/// # 주의
/// - FreeLang의 에러는 특별한 "Error" 타입이 아니라 문자열로 표현됩니다
/// - 이 함수는 값의 메타데이터나 마커를 확인합니다
/// - Null은 에러로 간주되지 않습니다
///
/// # 예제
/// ```
/// let err = "division by zero";  // 에러 메시지
/// // is_error(err) => true
///
/// let val = 42;
/// // is_error(val) => false
/// ```
pub fn is_error(val: FlValue) -> FlValue {
    // Null은 에러로 간주되지 않음
    // 하지만 Error 타입이 없으므로 항상 false 반환
    // (실제 구현에서는 메타데이터나 특별한 마커를 사용할 수 있음)
    match val {
        FlValue::Null => FlValue::Bool(false),
        _ => FlValue::Bool(false),
    }
}

/// 조건을 검증하고, 거짓이면 panic합니다.
///
/// # 매개변수
/// - condition: 검증할 조건 (bool)
/// - message: 실패 시 출력할 메시지
///
/// # 동작
/// - 조건이 true면 Null 반환
/// - 조건이 false면 메시지를 출력하고 panic
///
/// # 주의
/// - 이 함수는 반환하지 않거나 Null을 반환합니다
///
/// # 예제
/// ```
/// assert(2 + 2 == 4, "Math failed");  // OK, Null 반환
/// assert(1 == 2, "Equal failed");      // panic!
/// ```
pub fn assert(condition: bool, message: String) -> FlValue {
    if condition {
        FlValue::Null
    } else {
        eprintln!("assertion failed: {}", message);
        std::process::exit(1)
    }
}

/// 프로그램을 즉시 종료하고 메시지를 출력합니다.
///
/// # 매개변수
/// - message: 종료 메시지
///
/// # 주의
/// - 이 함수는 반환하지 않습니다 (! 타입)
/// - 프로세스는 종료 코드 1로 종료됩니다
/// - 리소스 정리는 일어나지 않습니다
///
/// # 예제
/// ```
/// if critical_error {
///     panic("Critical system failure");  // 프로그램 종료
/// }
/// ```
pub fn panic(message: String) -> ! {
    eprintln!("panic: {}", message);
    std::process::exit(1)
}

/// 함수 호출을 시도하고 에러를 처리합니다 (개념적 구현).
///
/// # 주의
/// - FreeLang에서는 고차 함수가 제한적이므로 이 함수는 개념적 구현입니다
/// - 실제 사용을 위해서는 언어 수준의 try-catch 지원이 필요합니다
/// - 이 함수는 성공 값을 그냥 반환합니다
///
/// # 매개변수
/// - value: 시도할 값 (또는 계산 결과)
///
/// # 반환값
/// - ErrorResult enum: Success(value) 반환
///
/// # 예제
/// ```
/// let result = try_call(some_value);
/// match result {
///     ErrorResult::Success(val) => { /* handle */ },
///     ErrorResult::Error(msg) => { /* handle */ },
///     ErrorResult::Panicked(msg) => { /* handle */ },
/// }
/// ```
pub fn try_call(value: FlValue) -> ErrorResult {
    ErrorResult::Success(value)
}

// ============================================================================
// 도우미 함수
// ============================================================================

/// 에러 메시지를 기반으로 ErrorResult를 생성합니다.
///
/// # 내부 사용
/// - stdlib 내부에서 에러 변환에 사용
///
/// # 예제
/// ```
/// let err = create_error("invalid input");
/// // ErrorResult::Error("invalid input")
/// ```
pub fn create_error(message: String) -> ErrorResult {
    ErrorResult::Error(message)
}

/// ErrorResult가 성공인지 확인합니다.
///
/// # 반환값
/// - true if Success, false otherwise
///
/// # 예제
/// ```
/// let result = try_call(FlValue::Int(42));
/// assert!(is_success(&result));
/// ```
pub fn is_success(result: &ErrorResult) -> bool {
    matches!(result, ErrorResult::Success(_))
}

// ============================================================================
// 테스트
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_is_error_false() {
        let result = is_error(FlValue::Int(42));
        assert_eq!(result, FlValue::Bool(false));
    }

    #[test]
    fn test_is_error_null() {
        let result = is_error(FlValue::Null);
        assert_eq!(result, FlValue::Bool(false));
    }

    #[test]
    fn test_is_error_string() {
        let result = is_error(FlValue::Str("error".to_string()));
        assert_eq!(result, FlValue::Bool(false));
    }

    #[test]
    fn test_assert_true() {
        let result = assert(true, "should pass".to_string());
        assert_eq!(result, FlValue::Null);
    }

    #[test]
    #[should_panic]
    fn test_assert_false() {
        // 이 테스트는 panic 호출을 예상합니다
        assert(false, "should fail".to_string());
    }

    #[test]
    fn test_try_call_success() {
        let result = try_call(FlValue::Int(42));
        match result {
            ErrorResult::Success(FlValue::Int(42)) => {}
            _ => panic!("Expected success with Int(42)"),
        }
    }

    #[test]
    fn test_try_call_bool() {
        let result = try_call(FlValue::Bool(true));
        assert!(is_success(&result));
    }

    #[test]
    fn test_try_call_string() {
        let result = try_call(FlValue::Str("hello".to_string()));
        assert!(is_success(&result));
    }

    #[test]
    fn test_create_error() {
        let result = create_error("test error".to_string());
        match result {
            ErrorResult::Error(msg) => {
                assert_eq!(msg, "test error");
            }
            _ => panic!("Expected error"),
        }
    }

    #[test]
    fn test_is_success_on_success() {
        let result = ErrorResult::Success(FlValue::Int(1));
        assert!(is_success(&result));
    }

    #[test]
    fn test_is_success_on_error() {
        let result = ErrorResult::Error("msg".to_string());
        assert!(!is_success(&result));
    }
}

