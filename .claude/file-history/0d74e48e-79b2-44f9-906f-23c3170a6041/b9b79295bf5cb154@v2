#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_tokenize_int() {
        let mut lexer = Lexer::new("42");
        let tokens = lexer.tokenize();
        assert_eq!(tokens[0], Token::Int(42));
    }

    #[test]
    fn test_tokenize_float() {
        let mut lexer = Lexer::new("3.14");
        let tokens = lexer.tokenize();
        assert_eq!(tokens[0], Token::Float(3.14));
    }

    #[test]
    fn test_tokenize_string() {
        let mut lexer = Lexer::new(r#""hello""#);
        let tokens = lexer.tokenize();
        assert_eq!(tokens[0], Token::Str("hello".to_string()));
    }

    #[test]
    fn test_tokenize_bool() {
        let mut lexer = Lexer::new("true false");
        let tokens = lexer.tokenize();
        assert_eq!(tokens[0], Token::Bool(true));
        assert_eq!(tokens[1], Token::Bool(false));
    }

    #[test]
    fn test_tokenize_operators() {
        let mut lexer = Lexer::new("+ - * / == != < >");
        let tokens = lexer.tokenize();
        assert_eq!(tokens[0], Token::Plus);
        assert_eq!(tokens[1], Token::Minus);
        assert_eq!(tokens[2], Token::Star);
        assert_eq!(tokens[3], Token::Slash);
        assert_eq!(tokens[4], Token::Eq);
        assert_eq!(tokens[5], Token::Neq);
    }

    #[test]
    fn test_tokenize_keywords() {
        let mut lexer = Lexer::new("let fn if else while");
        let tokens = lexer.tokenize();
        assert_eq!(tokens[0], Token::Let);
        assert_eq!(tokens[1], Token::Fn);
        assert_eq!(tokens[2], Token::If);
        assert_eq!(tokens[3], Token::Else);
        assert_eq!(tokens[4], Token::While);
    }

    #[test]
    fn test_tokenize_function_call() {
        let mut lexer = Lexer::new("println(\"hello\")");
        let tokens = lexer.tokenize();
        match &tokens[0] {
            Token::Ident(s) => assert_eq!(s, "println"),
            _ => panic!("Expected identifier"),
        }
        assert_eq!(tokens[1], Token::LParen);
    }

    #[test]
    fn test_parse_let() {
        let mut lexer = Lexer::new("let x = 42;");
        let tokens = lexer.tokenize();
        let mut parser = Parser::new(tokens);
        let prog = parser.parse().unwrap();
        assert_eq!(prog.stmts.len(), 1);
    }

    #[test]
    fn test_parse_if_expr() {
        let mut lexer = Lexer::new("if x > 0 { 42 }");
        let tokens = lexer.tokenize();
        let mut parser = Parser::new(tokens);
        let prog = parser.parse().unwrap();
        assert_eq!(prog.stmts.len(), 1);
    }

    #[test]
    fn test_parse_array() {
        let mut lexer = Lexer::new("[1, 2, 3]");
        let tokens = lexer.tokenize();
        let mut parser = Parser::new(tokens);
        let prog = parser.parse().unwrap();
        assert_eq!(prog.stmts.len(), 1);
    }

    #[test]
    fn test_parse_binop() {
        let mut lexer = Lexer::new("1 + 2 * 3");
        let tokens = lexer.tokenize();
        let mut parser = Parser::new(tokens);
        let prog = parser.parse().unwrap();
        assert_eq!(prog.stmts.len(), 1);
    }

    #[test]
    fn test_parse_function_call() {
        let mut lexer = Lexer::new("println(\"hello\")");
        let tokens = lexer.tokenize();
        let mut parser = Parser::new(tokens);
        let prog = parser.parse().unwrap();
        assert_eq!(prog.stmts.len(), 1);
    }

    #[test]
    fn test_tokenize_comments() {
        let mut lexer = Lexer::new("42 // comment\n 3.14");
        let tokens = lexer.tokenize();
        assert_eq!(tokens[0], Token::Int(42));
        assert_eq!(tokens[1], Token::Float(3.14));
    }
