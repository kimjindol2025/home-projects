}

/// fpm publish - 패키지 발행
pub fn cmd_publish(manifest_path: &str) -> CliResult {
    // freelang.toml 읽기
    println!("Reading {}...", manifest_path);

    // 패키지 검증
    println!("Validating package...");

    // GOGS에 발행
    println!("Publishing to {}...", DEFAULT_REGISTRY_URL);

    CliResult::ok("Package published successfully")
        .with_details(vec![
            format!("Registry: {}", DEFAULT_REGISTRY_URL),
            "URL: https://gogs.dclub.kr/kim/my-project".to_string(),
            "Version tagged: v1.0.0".to_string(),
        ])
}

/// fpm list - 설치된 패키지 목록
pub fn cmd_list(manifest_path: &str) -> CliResult {
    // freelang.toml 읽기
    println!("Reading {}...", manifest_path);

    let packages = vec![
        "freelang-json@1.2.3".to_string(),
        "freelang-http@2.1.0".to_string(),
        "freelang-crypto@1.0.5".to_string(),
    ];

    CliResult::ok("Installed packages")
        .with_details(packages)
}

/// fpm search - 레지스트리에서 패키지 검색
pub fn cmd_search(query: &str) -> CliResult {
    // 레지스트리 검색
    match registry::search_package(DEFAULT_REGISTRY_URL, query) {
        Ok(result) => {
            let details = result
                .packages
                .iter()
                .map(|pkg| {
                    format!(
                        "  {} ({}): {}",
                        pkg.name, pkg.version, pkg.description
                    )
                })
                .collect();

            CliResult::ok(&format!(
                "Found {} package(s) matching '{}'",
                result.total, query
            ))
            .with_details(details)
        }
        Err(e) => {
            CliResult::error(&format!("Search failed: {}", e))
        }
    }
}

