/// fpm --help
pub fn print_help() {
    println!("╔════════════════════════════════════════════════════════╗");
    println!("║         FreeLang Package Manager (FPM) v{}          ║", FPM_VERSION);
    println!("╚════════════════════════════════════════════════════════╝");
    println!();
    println!("USAGE:");
    println!("  fpm <COMMAND> [OPTIONS]");
    println!();
    println!("COMMANDS:");
    println!("  init <name> <author>     Initialize new project");
    println!("  add <package> [version]  Add dependency");
    println!("  install                  Install all dependencies");
    println!("  publish                  Publish package to registry");
    println!("  list                     List installed packages");
    println!("  search <query>           Search packages in registry");
    println!();
    println!("OPTIONS:");
    println!("  -h, --help              Show this help message");
    println!("  -v, --version           Show version");
    println!("  -r, --registry <URL>    Use custom registry (default: {})", DEFAULT_REGISTRY_URL);
    println!();
    println!("EXAMPLES:");
    println!("  fpm init my-project kim");
    println!("  fpm add freelang-json ^1.0.0");
    println!("  fpm install");
    println!("  fpm search json");
    println!("  fpm publish");
    println!();
}

/// fpm --version
pub fn print_version() {
    println!("FPM (FreeLang Package Manager) version {}", FPM_VERSION);
}

