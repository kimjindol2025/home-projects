/// fpm init - 새 FreeLang 프로젝트 초기화
pub fn cmd_init(
    project_name: &str,
    author: &str,
) -> CliResult {
    // freelang.toml 생성
    let manifest_content = format!(
        r#"[package]
name = "{}"
version = "0.1.0"
author = "{}"
description = "A FreeLang project"

[dependencies]
"#,
        project_name, author
    );

    // 파일 저장 (mock)
    println!("Creating freelang.toml...");
    println!("{}", manifest_content);

    CliResult::ok(&format!(
        "Initialized new project '{}' with author '{}'",
        project_name, author
    ))
}

/// fpm add - 의존성 추가
pub fn cmd_add(
    manifest_path: &str,
    package_name: &str,
    version_range: &str,
) -> CliResult {
    // 패키지명 검증
    if !registry::is_valid_package_name(package_name) {
        return CliResult::error(&format!(
            "Invalid package name: '{}' (must be lowercase with hyphens)",
            package_name
        ));
    }

    // 버전 범위 검증
    match resolver::parse_version_range(version_range) {
        Ok(_) => {
            CliResult::ok(&format!(
                "Added dependency '{}' with version range '{}'",
                package_name, version_range
            ))
            .with_details(vec![
                format!("Package: {}", package_name),
                format!("Version: {}", version_range),
                format!("Manifest: {}", manifest_path),
            ])
        }
        Err(e) => {
            CliResult::error(&format!(
                "Invalid version range '{}': {}",
                version_range, e
            ))
        }
    }
}

/// fpm install - 의존성 설치
pub fn cmd_install(manifest_path: &str) -> CliResult {
    // freelang.toml 읽기
    println!("Reading {}...", manifest_path);

    // 의존성 해결
    println!("Resolving dependencies...");

    // Mock: 성공 결과
    CliResult::ok("Installed all dependencies successfully")
        .with_details(vec![
            "✓ freelang-json@1.2.3".to_string(),
            "✓ freelang-http@2.1.0".to_string(),
