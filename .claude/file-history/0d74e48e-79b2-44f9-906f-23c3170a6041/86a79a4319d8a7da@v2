#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_cmd_init() {
        let result = cmd_init("my-project", "kim");
        assert!(result.success);
        assert!(result.message.contains("my-project"));
    }

    #[test]
    fn test_cmd_add_valid() {
        let result = cmd_add("freelang.toml", "freelang-json", "^1.0.0");
        assert!(result.success);
        assert!(result.details.len() > 0);
    }

    #[test]
    fn test_cmd_add_invalid_version() {
        let result = cmd_add("freelang.toml", "freelang-json", "invalid");
        assert!(!result.success);
    }

    #[test]
    fn test_cmd_install() {
        let result = cmd_install("freelang.toml");
        assert!(result.success);
        assert!(result.details.len() > 0);
    }

    #[test]
    fn test_cmd_list() {
        let result = cmd_list("freelang.toml");
        assert!(result.success);
        assert!(result.details.len() > 0);
    }

    #[test]
    fn test_cmd_search() {
        let result = cmd_search("json");
        assert!(result.success);
        assert!(result.details.len() > 0);
    }

    #[test]
    fn test_cmd_publish() {
        let result = cmd_publish("freelang.toml");
        assert!(result.success);
        assert!(result.message.contains("published"));
    }

    #[test]
    fn test_cli_result_ok() {
        let result = CliResult::ok("test message");
        assert!(result.success);
        assert_eq!(result.message, "test message");
    }

    #[test]
    fn test_cli_result_error() {
        let result = CliResult::error("error message");
        assert!(!result.success);
        assert_eq!(result.message, "error message");
    }
}

