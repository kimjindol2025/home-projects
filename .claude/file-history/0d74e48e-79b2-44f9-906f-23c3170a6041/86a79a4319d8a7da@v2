// ============================================================================
// CLI Result
// ============================================================================

#[derive(Clone, Debug)]
pub struct CliResult {
    pub success: bool,
    pub message: String,
    pub details: Vec<String>,
}

impl CliResult {
    pub fn ok(message: &str) -> Self {
        CliResult {
            success: true,
            message: message.to_string(),
            details: vec![],
        }
    }

    pub fn error(message: &str) -> Self {
        CliResult {
            success: false,
            message: message.to_string(),
            details: vec![],
        }
    }

    pub fn with_details(mut self, details: Vec<String>) -> Self {
        self.details = details;
        self
    }
}

