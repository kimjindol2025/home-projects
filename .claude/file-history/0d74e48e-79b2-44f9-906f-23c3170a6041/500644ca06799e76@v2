#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_arc_new() {
        let arc = Arc::new(42);
        assert_eq!(*arc, 42);
    }

    #[test]
    fn test_arc_clone() {
        let arc1 = Arc::new(vec![1, 2, 3]);
        let arc2 = arc1.clone();

        // 두 Arc는 같은 데이터를 가리킵니다.
        assert_eq!(arc1.get_ref(), arc2.get_ref());

        // 참조 카운트는 2입니다.
        assert_eq!(Arc::strong_count(&arc1), 2);
    }

    #[test]
    fn test_arc_reference_count() {
        let arc = Arc::new(10);
        assert_eq!(Arc::strong_count(&arc), 1);

        let _arc2 = arc.clone();
        assert_eq!(Arc::strong_count(&arc), 2);

        let _arc3 = arc.clone();
        assert_eq!(Arc::strong_count(&arc), 3);

        // _arc2가 drop되면서 카운트 감소
        drop(_arc2);
        assert_eq!(Arc::strong_count(&arc), 2);
    }

    #[test]
    fn test_arc_deref() {
        struct Point {
            x: i32,
            y: i32,
        }

        let arc = Arc::new(Point { x: 3, y: 4 });

        // Deref를 통해 필드에 접근
        assert_eq!(arc.x, 3);
        assert_eq!(arc.y, 4);
    }

    #[test]
    fn test_arc_drop() {
        let arc = Arc::new(vec![1, 2, 3]);
        let arc2 = arc.clone();

        // arc drop → 카운트 1
        drop(arc);

        // arc2는 여전히 유효
        assert_eq!(arc2.get_ref(), &vec![1, 2, 3]);
    }

    // 스레드 안전성 테스트 (컴파일 타임)
    #[test]
    fn test_arc_send_sync() {
        // Arc<i32>는 Send + Sync
        // (이것은 컴파일 타임에 검증됩니다)

        fn assert_send<T: Send>() {}
        fn assert_sync<T: Sync>() {}

        assert_send::<Arc<i32>>();
        assert_sync::<Arc<i32>>();
    }

    #[test]
    fn test_arc_multiple_owners() {
        // 여러 소유자가 같은 데이터를 공유
        let data = Arc::new(String::from("Hello"));

        let owner1 = data.clone();
        let owner2 = data.clone();
        let owner3 = data.clone();

        assert_eq!(Arc::strong_count(&data), 4);

        // 모든 소유자가 같은 데이터에 접근
        assert_eq!(*owner1, "Hello");
        assert_eq!(*owner2, "Hello");
        assert_eq!(*owner3, "Hello");
    }
}

