fn test_nested_if() -> Result<(), String> {
    let x = 20;
    let result = if x > 10 {
        if x > 15 { "very big" } else { "medium" }
    } else {
        "small"
    };
    if result != "very big" {
        return Err("Nested if failed".to_string());
    }
    Ok(())
}

