fn add(a: i32, b: i32) -> i32 {
    a + b
}

fn test_function_call() -> Result<(), String> {
    let result = add(3, 4);
    if result != 7 {
        return Err("Function call failed".to_string());
    }
    Ok(())
}

fn test_nested_function_calls() -> Result<(), String> {
    let result = add(add(1, 2), add(3, 4));
    // add(3, 7) = 10
    if result != 10 {
        return Err("Nested function calls failed".to_string());
    }
    Ok(())
}

fn test_recursive_function() -> Result<(), String> {
    fn factorial(n: i32) -> i32 {
        if n <= 1 { 1 } else { n * factorial(n - 1) }
    }

    if factorial(5) != 120 {
        return Err("Recursive function failed".to_string());
    }
    Ok(())
}

