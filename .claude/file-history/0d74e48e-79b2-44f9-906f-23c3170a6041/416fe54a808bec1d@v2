// ============================================================================
// 10. 복합 시나리오 테스트
// ============================================================================

fn test_fibonacci() -> Result<(), String> {
    fn fib(n: i32) -> i32 {
        if n <= 1 {
            n
        } else {
            fib(n - 1) + fib(n - 2)
        }
    }

    // fib(7) = 13
    if fib(7) != 13 {
        return Err("Fibonacci sequence failed".to_string());
    }
    Ok(())
}

fn test_prime_checker() -> Result<(), String> {
    fn is_prime(n: i32) -> bool {
        if n < 2 {
            return false;
        }
        for i in 2..(n / 2 + 1) {
            if n % i == 0 {
                return false;
            }
        }
        true
    }

    if !is_prime(7) || !is_prime(11) || !is_prime(13) {
        return Err("Prime checker failed".to_string());
    }

    if is_prime(1) || is_prime(4) || is_prime(6) {
        return Err("Prime checker false positives".to_string());
    }

    Ok(())
}

fn test_array_sum_and_average() -> Result<(), String> {
    let numbers = [10, 20, 30, 40, 50];
    let mut sum = 0;
    for i in 0..numbers.len() {
        sum = sum + numbers[i];
    }

    if sum != 150 {
        return Err("Array sum failed".to_string());
    }

    let average = sum / numbers.len() as i32;
    if average != 30 {
        return Err("Array average failed".to_string());
    }

    Ok(())
}

// ============================================================================
// 11. 성능 테스트
// ============================================================================

fn test_performance_simple_loop() -> Result<(), String> {
    let start = Instant::now();
    let mut sum = 0;
    for i in 0..1000 {
        sum = sum + i;
    }
    let elapsed = start.elapsed().as_millis();

    if sum != 499500 {
        return Err("Performance test calculation wrong".to_string());
    }

    if elapsed > 100 {
        // 경고만, 실패는 아님
        println!("  ⚠️  Performance warning: 1000 iterations took {}ms", elapsed);
    }

    Ok(())
}

fn test_performance_nested_loops() -> Result<(), String> {
    let start = Instant::now();
    let mut count = 0;
    for i in 0..100 {
        for j in 0..100 {
            count = count + 1;
        }
    }
    let elapsed = start.elapsed().as_millis();

    if count != 10000 {
        return Err("Nested loops count wrong".to_string());
    }

    if elapsed > 500 {
        println!("  ⚠️  Performance warning: 10000 nested iterations took {}ms", elapsed);
    }

    Ok(())
}

