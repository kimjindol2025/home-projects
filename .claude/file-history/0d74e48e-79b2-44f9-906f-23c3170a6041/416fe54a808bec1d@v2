/// 단일 테스트 결과
#[derive(Clone, Debug)]
pub struct TestResult {
    /// 테스트 이름
    pub name: String,

    /// 성공 여부
    pub passed: bool,

    /// 에러 메시지
    pub error: Option<String>,

    /// 실행 시간 (밀리초)
    pub execution_time_ms: u128,
}

impl TestResult {
    pub fn new(name: String, passed: bool, error: Option<String>, time: u128) -> Self {
        TestResult {
            name,
            passed,
            error,
            execution_time_ms: time,
        }
    }

    pub fn display(&self) {
        if self.passed {
            println!("✅ {} ({}ms)", self.name, self.execution_time_ms);
        } else {
            if let Some(err) = &self.error {
                println!("❌ {} ({}ms): {}", self.name, self.execution_time_ms, err);
            } else {
                println!("❌ {} ({}ms)", self.name, self.execution_time_ms);
            }
        }
    }
}

/// 테스트 스위트
pub struct TestSuite {
    /// 테스트 결과
    results: Vec<TestResult>,

    /// 전체 시작 시간
    start_time: Instant,
}

impl TestSuite {
    pub fn new() -> Self {
        TestSuite {
            results: Vec::new(),
            start_time: Instant::now(),
        }
    }

    pub fn add_result(&mut self, result: TestResult) {
        self.results.push(result);
    }

    pub fn run_test<F>(&mut self, name: &str, test_fn: F)
    where
        F: Fn() -> Result<(), String>,
    {
        let start = Instant::now();
        let result = test_fn();
        let elapsed = start.elapsed().as_millis();

        let test_result = match result {
            Ok(_) => TestResult::new(name.to_string(), true, None, elapsed),
            Err(e) => TestResult::new(name.to_string(), false, Some(e), elapsed),
        };

        test_result.display();
        self.add_result(test_result);
    }

    pub fn summary(&self) {
        let total = self.results.len();
        let passed = self.results.iter().filter(|r| r.passed).count();
        let failed = total - passed;
        let total_time = self.start_time.elapsed().as_millis();

        println!("\n═════════════════════════════════════════");
        println!("📊 Test Summary");
        println!("═════════════════════════════════════════");
        println!("Total:   {} tests", total);
        println!("Passed:  {} ✅", passed);
        println!("Failed:  {} ❌", failed);
        println!("Time:    {}ms", total_time);
        println!("═════════════════════════════════════════");

        if failed == 0 {
            println!("🎉 All tests passed!");
        } else {
            println!("⚠️  {} test(s) failed", failed);
        }
    }
}

// ============================================================================
// 1. 기본 연산 테스트
// ============================================================================

fn test_integer_arithmetic() -> Result<(), String> {
    // 테스트: 1 + 2 = 3
    if 1 + 2 != 3 {
        return Err("Addition failed".to_string());
    }

    // 테스트: 10 - 3 = 7
    if 10 - 3 != 7 {
        return Err("Subtraction failed".to_string());
    }

    // 테스트: 4 * 5 = 20
    if 4 * 5 != 20 {
        return Err("Multiplication failed".to_string());
    }

    // 테스트: 20 / 4 = 5
    if 20 / 4 != 5 {
        return Err("Division failed".to_string());
    }

    Ok(())
}

fn test_float_arithmetic() -> Result<(), String> {
    // 테스트: 3.14 + 2.86 ≈ 6.0
    let result = 3.14 + 2.86;
    if (result - 6.0).abs() > 0.01 {
        return Err("Float addition failed".to_string());
    }

    // 테스트: 10.0 / 2.0 = 5.0
    let result = 10.0 / 2.0;
    if (result - 5.0).abs() > 0.01 {
        return Err("Float division failed".to_string());
    }

    Ok(())
}

fn test_comparison_operators() -> Result<(), String> {
    // 테스트: 5 > 3
    if !(5 > 3) {
        return Err("Greater than failed".to_string());
    }

    // 테스트: 3 < 5
    if !(3 < 5) {
        return Err("Less than failed".to_string());
    }

    // 테스트: 5 == 5
    if !(5 == 5) {
        return Err("Equality failed".to_string());
    }

    // 테스트: 5 != 3
    if !(5 != 3) {
        return Err("Not equal failed".to_string());
    }

    Ok(())
}

fn test_logical_operators() -> Result<(), String> {
    // 테스트: true && true = true
    if !(true && true) {
        return Err("AND (true && true) failed".to_string());
    }

    // 테스트: true && false = false
    if true && false {
        return Err("AND (true && false) failed".to_string());
    }

    // 테스트: true || false = true
    if !(true || false) {
        return Err("OR (true || false) failed".to_string());
    }

    // 테스트: false || false = false
    if false || false {
        return Err("OR (false || false) failed".to_string());
    }

    // 테스트: !true = false
    if !true {
        return Err("NOT (!true) failed".to_string());
    }

    Ok(())
}

