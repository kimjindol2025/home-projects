pub fn run_integration_tests() {
    println!("\n╔════════════════════════════════════════╗");
    println!("║  FreeLang Runtime Integration Tests   ║");
    println!("║            Phase F Week 3             ║");
    println!("╚════════════════════════════════════════╝\n");

    let mut suite = TestSuite::new();

    // 기본 연산
    println!("📐 Basic Arithmetic Tests");
    suite.run_test("Integer Arithmetic", || test_integer_arithmetic());
    suite.run_test("Float Arithmetic", || test_float_arithmetic());
    suite.run_test("Comparison Operators", || test_comparison_operators());
    suite.run_test("Logical Operators", || test_logical_operators());

    // 변수
    println!("\n📝 Variable Tests");
    suite.run_test("Variable Binding", || test_variable_binding());
    suite.run_test("Variable Shadowing", || test_variable_shadowing());
    suite.run_test("Multiple Variables", || test_multiple_variables());

    // 제어 흐름
    println!("\n🔀 Control Flow Tests");
    suite.run_test("If Condition", || test_if_condition());
    suite.run_test("Nested If", || test_nested_if());
    suite.run_test("While Loop", || test_while_loop());
    suite.run_test("For Loop Range", || test_for_loop_range());

    // 배열
    println!("\n📦 Array Tests");
    suite.run_test("Array Creation", || test_array_creation());
    suite.run_test("Array Indexing", || test_array_indexing());
    suite.run_test("Array Iteration", || test_array_iteration());

    // 객체 & 문자열
    println!("\n🔤 String & Object Tests");
    suite.run_test("String Operations", || test_string_operations());

    // 함수
    println!("\n⚙️  Function Tests");
    suite.run_test("Function Call", || test_function_call());
    suite.run_test("Nested Function Calls", || test_nested_function_calls());
    suite.run_test("Recursive Function", || test_recursive_function());

    // 표준 라이브러리
    println!("\n📚 Standard Library Tests");
    suite.run_test("abs() Function", || test_abs_function());
    suite.run_test("min/max Functions", || test_min_max());

    // 메모리
    println!("\n💾 Memory Safety Tests");
    suite.run_test("Ownership Basics", || test_ownership_basics());
    suite.run_test("Reference", || test_reference());

    // 복합 시나리오
    println!("\n🎯 Complex Scenario Tests");
    suite.run_test("Fibonacci", || test_fibonacci());
    suite.run_test("Prime Checker", || test_prime_checker());
    suite.run_test("Array Sum & Average", || test_array_sum_and_average());

    // 성능
    println!("\n⚡ Performance Tests");
    suite.run_test("Simple Loop (1000 iterations)", || test_performance_simple_loop());
    suite.run_test("Nested Loops (10000 iterations)", || test_performance_nested_loops());

    // 결과 요약
    suite.summary();
}

