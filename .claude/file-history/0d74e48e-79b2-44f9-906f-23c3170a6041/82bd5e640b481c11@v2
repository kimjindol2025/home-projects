# ─────────────────────────────────────────────────────────────────────────
# 메타데이터
# ─────────────────────────────────────────────────────────────────────────

struct GrpcMethod
  name: string              # "GetTodo"
  inputType: string         # "GetTodoRequest"
  outputType: string        # "GetTodoResponse"
  isStreaming: bool         # 양방향 스트리밍

struct GrpcMetadata
  key: string
  value: string

struct GrpcContext
  method: string            # "GetTodo"
  metadata: array<GrpcMetadata>
  deadline: number          # 밀리초

# ─────────────────────────────────────────────────────────────────────────
# 에러 타입
# ─────────────────────────────────────────────────────────────────────────

enum GrpcStatus
  OK = 0
  CANCELLED = 1
  UNKNOWN = 2
  INVALID_ARGUMENT = 3
  DEADLINE_EXCEEDED = 4
  NOT_FOUND = 5
  ALREADY_EXISTS = 6
  PERMISSION_DENIED = 7
  RESOURCE_EXHAUSTED = 8
  FAILED_PRECONDITION = 9
  ABORTED = 10
  OUT_OF_RANGE = 11
  UNIMPLEMENTED = 12
  INTERNAL = 13
  UNAVAILABLE = 14
  DATA_LOSS = 15
  UNAUTHENTICATED = 16

struct GrpcError
  status: GrpcStatus
  message: string
  details: string

# ─────────────────────────────────────────────────────────────────────────
# 메시지 변환
# ─────────────────────────────────────────────────────────────────────────

fn todoToGrpc
  input: todo: Todo
  output: map<string, string>
  intent: \"Todo를 gRPC 메시지로 변환\"
  do
    return {
      \"id\": str(todo.id),
      \"title\": todo.title,
      \"description\": todo.description,
      \"completed\": boolToString(todo.completed),
      \"createdAt\": str(todo.createdAt),
      \"updatedAt\": str(todo.updatedAt)
    }

fn grpcToTodo
  input: data: map<string, string>
  output: Result<Todo, string>
  intent: \"gRPC 메시지를 Todo로 변환\"
  do
    let id = stringToNumber(data.get(\"id\").getOrElse(\"0\")).getOrElse(0)
    let completed = data.get(\"completed\").getOrElse(\"false\") == \"true\"

    Ok({
      id: id,
      title: data.get(\"title\").getOrElse(\"\"),
      description: data.get(\"description\").getOrElse(\"\"),
      completed: completed,
      createdAt: stringToNumber(data.get(\"createdAt\").getOrElse(\"0\")).getOrElse(0),
      updatedAt: stringToNumber(data.get(\"updatedAt\").getOrElse(\"0\")).getOrElse(0),
      lastLoginAt: 0
    })

# ─────────────────────────────────────────────────────────────────────────
# 헬퍼 함수
# ─────────────────────────────────────────────────────────────────────────

fn boolToString
  input: b: bool
  output: string
  intent: \"불린을 문자열로\"
  do
    if b
      return \"true\"
    else
      return \"false\"

fn stringToNumber
  input: str: string
  output: Option<number>
  intent: \"문자열을 숫자로\"
  do
    # Phase B 런타임에서 구현
    return None

fn str
  input: num: number
  output: string
  intent: \"숫자를 문자열로\"
  do
    return \"\"

fn getOrElse<T>
  input: (opt: Option<T>, default: T)
  output: T
  intent: \"Option 또는 기본값\"
  do
    match opt
      Some(v) => v
      None => default

# 도메인 모델 (참조)
struct Todo
  id: number
  title: string
  description: string
  completed: bool
  createdAt: number
  updatedAt: number
  lastLoginAt: number
