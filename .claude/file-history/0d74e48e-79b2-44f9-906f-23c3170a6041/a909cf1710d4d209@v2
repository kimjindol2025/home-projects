    eval.register_builtin("str_concat", builtin_str_concat);
    eval.register_builtin("str_split", builtin_str_split);
    eval.register_builtin("str_format", builtin_str_format);
    eval.register_builtin("str_upper", builtin_str_upper);
    eval.register_builtin("str_lower", builtin_str_lower);
    eval.register_builtin("str_trim", builtin_str_trim);
    eval.register_builtin("str_replace", builtin_str_replace);

    // ========== Array (8개) ==========
    eval.register_builtin("array_push", builtin_array_push);
    eval.register_builtin("array_pop", builtin_array_pop);
    eval.register_builtin("array_length", builtin_array_length);
    eval.register_builtin("array_map", builtin_array_map);
    eval.register_builtin("array_filter", builtin_array_filter);
    eval.register_builtin("array_reduce", builtin_array_reduce);
    eval.register_builtin("array_sort", builtin_array_sort);
    eval.register_builtin("array_reverse", builtin_array_reverse);

    // ========== Math (8개) ==========
    eval.register_builtin("sqrt", builtin_sqrt);
    eval.register_builtin("abs", builtin_abs);
    eval.register_builtin("pow", builtin_pow);
    eval.register_builtin("sin", builtin_sin);
    eval.register_builtin("cos", builtin_cos);
    eval.register_builtin("floor", builtin_floor);
    eval.register_builtin("ceil", builtin_ceil);
    eval.register_builtin("round", builtin_round);

    // ========== Types (6개) ==========
    eval.register_builtin("type_of", builtin_type_of);
    eval.register_builtin("to_int", builtin_to_int);
