fn builtin_array_map(args: Vec<FlValue>, _env: &mut Environment) -> Result<FlValue, RuntimeError> {
    if args.len() != 2 {
        return Err(RuntimeError::CallError {
            name: "array_map".to_string(),
            reason: "Expected 2 arguments".to_string(),
        });
    }

    let arr = match &args[0] {
        FlValue::Array(a) => a,
        _ => return Err(RuntimeError::TypeError {
            expected: "array".to_string(),
            got: args[0].type_name().to_string(),
            context: "array_map".to_string(),
        }),
    };

    // 간단한 map: 각 원소를 2배로
    let result: Vec<FlValue> = arr.iter()
        .map(|item| {
            match item {
                FlValue::Int(n) => FlValue::Int(n * 2),
                FlValue::Float(f) => FlValue::Float(f * 2.0),
                _ => item.clone(),
            }
        })
        .collect();

    Ok(FlValue::Array(result))
}

