        });
    }

    match &args[0] {
        FlValue::Int(n) => Ok(FlValue::Float(*n as f64)),
        FlValue::Float(f) => Ok(FlValue::Float(*f)),
        FlValue::Str(s) => {
            s.parse::<f64>()
                .map(FlValue::Float)
                .map_err(|_| RuntimeError::Other(format!("Cannot parse '{}' as float", s)))
        }
        _ => Err(RuntimeError::TypeError {
            expected: "convertible".to_string(),
            got: args[0].type_name().to_string(),
            context: "to_float".to_string(),
        }),
    }
}

