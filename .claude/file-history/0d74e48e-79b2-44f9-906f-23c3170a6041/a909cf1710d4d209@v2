fn builtin_array_reduce(args: Vec<FlValue>, _env: &mut Environment) -> Result<FlValue, RuntimeError> {
    if args.len() != 2 {
        return Err(RuntimeError::CallError {
            name: "array_reduce".to_string(),
            reason: "Expected 2 arguments".to_string(),
        });
    }

    let arr = match &args[0] {
        FlValue::Array(a) => a,
        _ => return Err(RuntimeError::TypeError {
            expected: "array".to_string(),
            got: args[0].type_name().to_string(),
            context: "array_reduce".to_string(),
        }),
    };

    let mut acc = FlValue::Int(0);
    for item in arr {
        match (&acc, item) {
            (FlValue::Int(a), FlValue::Int(b)) => acc = FlValue::Int(a + b),
            (FlValue::Float(a), FlValue::Float(b)) => acc = FlValue::Float(a + b),
            _ => {}
        }
    }

    Ok(acc)
}

fn builtin_array_sort(args: Vec<FlValue>, _env: &mut Environment) -> Result<FlValue, RuntimeError> {
    if args.len() != 1 {
        return Err(RuntimeError::CallError {
            name: "array_sort".to_string(),
            reason: "Expected 1 argument".to_string(),
        });
    }

    let mut arr = match &args[0] {
        FlValue::Array(a) => a.clone(),
        _ => return Err(RuntimeError::TypeError {
            expected: "array".to_string(),
            got: args[0].type_name().to_string(),
            context: "array_sort".to_string(),
        }),
    };

    arr.sort_by(|a, b| {
        match (a, b) {
            (FlValue::Int(x), FlValue::Int(y)) => x.cmp(y),
            (FlValue::Float(x), FlValue::Float(y)) => {
                if x < y { std::cmp::Ordering::Less }
                else if x > y { std::cmp::Ordering::Greater }
                else { std::cmp::Ordering::Equal }
            }
            (FlValue::Str(x), FlValue::Str(y)) => x.cmp(y),
            _ => std::cmp::Ordering::Equal,
        }
    });

    Ok(FlValue::Array(arr))
}

fn builtin_array_reverse(args: Vec<FlValue>, _env: &mut Environment) -> Result<FlValue, RuntimeError> {
