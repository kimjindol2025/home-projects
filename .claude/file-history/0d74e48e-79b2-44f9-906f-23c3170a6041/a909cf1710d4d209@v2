fn builtin_to_int(args: Vec<FlValue>, _env: &mut Environment) -> Result<FlValue, RuntimeError> {
    if args.len() != 1 {
        return Err(RuntimeError::CallError {
            name: "to_int".to_string(),
            reason: "Expected 1 argument".to_string(),
        });
    }

    match &args[0] {
        FlValue::Int(n) => Ok(FlValue::Int(*n)),
        FlValue::Float(f) => Ok(FlValue::Int(*f as i64)),
        FlValue::Str(s) => {
            s.parse::<i64>()
                .map(FlValue::Int)
                .map_err(|_| RuntimeError::Other(format!("Cannot parse '{}' as int", s)))
        }
        FlValue::Bool(b) => Ok(FlValue::Int(if *b { 1 } else { 0 })),
        _ => Err(RuntimeError::TypeError {
            expected: "convertible".to_string(),
            got: args[0].type_name().to_string(),
            context: "to_int".to_string(),
        }),
    }
}

