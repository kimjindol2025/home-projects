fn builtin_json_stringify(args: Vec<FlValue>, _env: &mut Environment) -> Result<FlValue, RuntimeError> {
    if args.len() != 1 {
        return Err(RuntimeError::CallError {
            name: "json_stringify".to_string(),
            reason: "Expected 1 argument".to_string(),
        });
    }

    let json_str = match &args[0] {
        FlValue::Null => "null".to_string(),
        FlValue::Bool(b) => b.to_string(),
        FlValue::Int(n) => n.to_string(),
        FlValue::Float(f) => f.to_string(),
        FlValue::Str(s) => format!("\"{}\"", s.replace("\"", "\\\"")),
        FlValue::Array(arr) => {
            let items: Vec<String> = arr.iter()
                .map(|v| match v {
                    FlValue::Str(s) => format!("\"{}\"", s.replace("\"", "\\\"")),
                    FlValue::Null => "null".to_string(),
                    FlValue::Bool(b) => b.to_string(),
                    FlValue::Int(n) => n.to_string(),
                    FlValue::Float(f) => f.to_string(),
                    _ => v.to_string_repr(),
                })
                .collect();
            format!("[{}]", items.join(","))
        }
        FlValue::Object(obj) => {
            let items: Vec<String> = obj.iter()
                .map(|(k, v)| {
                    let val_str = match v {
                        FlValue::Str(s) => format!("\"{}\"", s.replace("\"", "\\\"")),
                        _ => v.to_string_repr(),
                    };
                    format!("\"{}\":{}", k, val_str)
                })
                .collect();
            format!("{{{}}}", items.join(","))
        }
    };

    Ok(FlValue::Str(json_str))
}

fn builtin_json_parse(args: Vec<FlValue>, _env: &mut Environment) -> Result<FlValue, RuntimeError> {
    if args.len() != 1 {
        return Err(RuntimeError::CallError {
            name: "json_parse".to_string(),
            reason: "Expected 1 argument".to_string(),
        });
    }

    let json_str = match &args[0] {
        FlValue::Str(s) => s,
        _ => return Err(RuntimeError::TypeError {
            expected: "string".to_string(),
            got: args[0].type_name().to_string(),
            context: "json_parse".to_string(),
        }),
    };

    // 간단한 JSON 파서 (프로토타입)
    let trimmed = json_str.trim();

    if trimmed == "null" {
        return Ok(FlValue::Null);
    }

    if trimmed == "true" {
        return Ok(FlValue::Bool(true));
    }

    if trimmed == "false" {
        return Ok(FlValue::Bool(false));
    }

    if trimmed.starts_with('"') && trimmed.ends_with('"') {
        return Ok(FlValue::Str(trimmed[1..trimmed.len()-1].to_string()));
    }

    if let Ok(n) = trimmed.parse::<i64>() {
        return Ok(FlValue::Int(n));
    }

    if let Ok(f) = trimmed.parse::<f64>() {
        return Ok(FlValue::Float(f));
    }

    // 객체/배열 파싱 (간단한 버전)
    if trimmed.starts_with('{') && trimmed.ends_with('}') {
        let content = &trimmed[1..trimmed.len()-1];
        let mut obj = std::collections::HashMap::new();

        for pair in content.split(',') {
            if let Some(colon_pos) = pair.find(':') {
                let key = pair[..colon_pos].trim().trim_matches('"');
                let val_str = pair[colon_pos+1..].trim();

                let val = if val_str == "null" {
                    FlValue::Null
                } else if val_str.starts_with('"') {
                    FlValue::Str(val_str.trim_matches('"').to_string())
                } else if let Ok(n) = val_str.parse::<i64>() {
                    FlValue::Int(n)
                } else {
                    FlValue::Null
                };

                obj.insert(key.to_string(), val);
            }
        }

        return Ok(FlValue::Object(obj));
    }

    Err(RuntimeError::Other(format!("Invalid JSON: {}", json_str)))
}

