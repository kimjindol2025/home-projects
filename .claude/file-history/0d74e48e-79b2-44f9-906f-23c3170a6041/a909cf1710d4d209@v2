// ============================================================================
// IO Functions
// ============================================================================

fn builtin_println(args: Vec<FlValue>, _env: &mut Environment) -> Result<FlValue, RuntimeError> {
    for arg in args {
        println!("{}", arg);
    }
    Ok(FlValue::Null)
}

fn builtin_print(args: Vec<FlValue>, _env: &mut Environment) -> Result<FlValue, RuntimeError> {
    for (i, arg) in args.iter().enumerate() {
        if i > 0 {
            print!(" ");
        }
        print!("{}", arg);
    }
    Ok(FlValue::Null)
}

fn builtin_read_file(args: Vec<FlValue>, _env: &mut Environment) -> Result<FlValue, RuntimeError> {
    if args.len() != 1 {
        return Err(RuntimeError::CallError {
            name: "read_file".to_string(),
            reason: "Expected 1 argument".to_string(),
        });
    }

    let path = match &args[0] {
        FlValue::Str(s) => s,
        _ => return Err(RuntimeError::TypeError {
            expected: "string".to_string(),
            got: args[0].type_name().to_string(),
            context: "read_file".to_string(),
        }),
    };

    match std::fs::read_to_string(path) {
        Ok(content) => Ok(FlValue::Str(content)),
        Err(e) => Err(RuntimeError::Other(format!("File read error: {}", e))),
    }
}

fn builtin_write_file(args: Vec<FlValue>, _env: &mut Environment) -> Result<FlValue, RuntimeError> {
    if args.len() != 2 {
        return Err(RuntimeError::CallError {
            name: "write_file".to_string(),
            reason: "Expected 2 arguments".to_string(),
        });
    }

    let path = match &args[0] {
        FlValue::Str(s) => s.clone(),
        _ => return Err(RuntimeError::TypeError {
            expected: "string".to_string(),
            got: args[0].type_name().to_string(),
            context: "write_file".to_string(),
        }),
    };

    let content = args[1].to_string_repr();

    match std::fs::write(path, content) {
        Ok(_) => Ok(FlValue::Null),
        Err(e) => Err(RuntimeError::Other(format!("File write error: {}", e))),
    }
}

