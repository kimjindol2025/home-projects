fn builtin_str_length(args: Vec<FlValue>, _env: &mut Environment) -> Result<FlValue, RuntimeError> {
    if args.len() != 1 {
        return Err(RuntimeError::CallError {
            name: "str_length".to_string(),
            reason: "Expected 1 argument".to_string(),
        });
    }

    let len = match &args[0] {
        FlValue::Str(s) => s.len() as i64,
        _ => return Err(RuntimeError::TypeError {
            expected: "string".to_string(),
            got: args[0].type_name().to_string(),
            context: "str_length".to_string(),
        }),
    };

    Ok(FlValue::Int(len))
}

fn builtin_str_concat(args: Vec<FlValue>, _env: &mut Environment) -> Result<FlValue, RuntimeError> {
    let mut result = String::new();

    for arg in args {
        match arg {
            FlValue::Str(s) => result.push_str(&s),
            _ => result.push_str(&arg.to_string_repr()),
        }
    }

    Ok(FlValue::Str(result))
}

fn builtin_str_split(args: Vec<FlValue>, _env: &mut Environment) -> Result<FlValue, RuntimeError> {
    if args.len() != 2 {
        return Err(RuntimeError::CallError {
            name: "str_split".to_string(),
            reason: "Expected 2 arguments".to_string(),
        });
    }

    let s = match &args[0] {
        FlValue::Str(s) => s,
        _ => return Err(RuntimeError::TypeError {
            expected: "string".to_string(),
            got: args[0].type_name().to_string(),
            context: "str_split".to_string(),
        }),
    };

    let sep = match &args[1] {
        FlValue::Str(s) => s,
        _ => return Err(RuntimeError::TypeError {
            expected: "string".to_string(),
            got: args[1].type_name().to_string(),
            context: "str_split".to_string(),
        }),
    };

    let parts: Vec<FlValue> = s.split(sep.as_str())
        .map(|s| FlValue::Str(s.to_string()))
        .collect();

    Ok(FlValue::Array(parts))
}

fn builtin_str_format(args: Vec<FlValue>, _env: &mut Environment) -> Result<FlValue, RuntimeError> {
    if args.is_empty() {
        return Err(RuntimeError::CallError {
            name: "str_format".to_string(),
            reason: "Expected at least 1 argument".to_string(),
        });
    }

    let format_str = match &args[0] {
        FlValue::Str(s) => s.clone(),
        _ => return Err(RuntimeError::TypeError {
            expected: "string".to_string(),
            got: args[0].type_name().to_string(),
            context: "str_format".to_string(),
        }),
    };

    // 간단한 치환: {} 패턴을 인수로 치환
    let mut result = format_str;
    for arg in &args[1..] {
        if let Some(pos) = result.find("{}") {
            result.replace_range(pos..pos+2, &arg.to_string_repr());
        }
    }

    Ok(FlValue::Str(result))
}

