struct Batch<T>
  id: string
  items: array<T>
  batchSize: number
  partitions: array<Partition<T>>
  totalItems: number
  processedItems: number
  failedItems: number
  status: string                # PENDING/PROCESSING/COMPLETED/FAILED

struct Partition<T>
  id: number
  startIndex: number
  endIndex: number
  items: array<T>
  status: string
  completedAt: number

struct BatchProcessor
  id: string
  batchSize: number
  numWorkers: number
  activeWorkers: number
  processedCount: number
  failedCount: number
  checkpoint: Option<map<string, number>>

fn newBatchProcessor
  input: (batchSize: number, numWorkers: number)
  output: BatchProcessor
  intent: "배치 프로세서 생성"
  do
    return {
      id: generateUUID(),
      batchSize: batchSize,
      numWorkers: numWorkers,
      activeWorkers: 0,
      processedCount: 0,
      failedCount: 0,
      checkpoint: None
    }

