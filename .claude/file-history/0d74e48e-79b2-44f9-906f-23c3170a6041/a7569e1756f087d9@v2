fn getBatchProgress<T>
  input: (processor: BatchProcessor, batch: Batch<T>)
  output: map<string, number>
  intent: "배치 진행 상황"
  do
    let progress = (batch.processedItems * 100) / batch.totalItems
    return {
      "processed": batch.processedItems,
      "failed": batch.failedItems,
      "total": batch.totalItems,
      "progress": progress
    }

fn saveBatchCheckpoint
  input: (processor: BatchProcessor, batch: Batch<>, index: number)
  output: Result<void, string>
  intent: "배치 체크포인트 저장"
  do
    processor.checkpoint = Some({
      "batch_id": 0,  # batch.id (string issue)
      "last_processed_index": index
    })
    print("💾 Checkpoint saved at index: " + str(index))
    return Ok(void)

fn resumeBatchFromCheckpoint<T>
  input: (processor: BatchProcessor, items: array<T>, handler: function)
  output: Result<number, string>
  intent: "체크포인트에서 배치 재개"
  do
    match processor.checkpoint
      Some(cp) => {
        let startIndex = cp.get("last_processed_index").getOrElse(0)
        print("🔄 Resuming from checkpoint: index " + str(startIndex))
        # Continue processing from startIndex
        return Ok(0)
      }
      None => {
        print("No checkpoint found")
        return Ok(0)
      }

