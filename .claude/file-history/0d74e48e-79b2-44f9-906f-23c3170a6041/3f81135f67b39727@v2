// ============================================================================
// StringError - 문자열 처리 에러 타입
// ============================================================================

/// 문자열 처리 시 발생할 수 있는 에러
#[derive(Clone, Debug, PartialEq)]
pub enum StringError {
    /// 인덱스 범위 초과
    IndexOutOfBounds { index: i64, len: i64 },

    /// 잘못된 포맷 문자열
    InvalidFormat(String),

    /// 타입 변환 실패
    ConversionError(String),
}

impl std::fmt::Display for StringError {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            StringError::IndexOutOfBounds { index, len } => {
                write!(f, "Index {} out of bounds (length {})", index, len)
            }
            StringError::InvalidFormat(msg) => write!(f, "Invalid format: {}", msg),
            StringError::ConversionError(msg) => write!(f, "Conversion error: {}", msg),
        }
    }
}

// ============================================================================
// Basic String Functions
// ============================================================================

/// 두 문자열을 연결합니다.
///
/// # 예제
/// ```
/// assert_eq!(concat("Hello", " World"), "Hello World");
/// ```
pub fn concat(a: String, b: String) -> String {
    format!("{}{}", a, b)
}

/// 문자열의 길이를 반환합니다 (문자 개수).
///
/// # 예제
/// ```
/// assert_eq!(length("Hello"), 5);
/// assert_eq!(length("한글"), 2);
/// ```
pub fn length(s: String) -> i64 {
    s.chars().count() as i64
}

/// 문자열을 대문자로 변환합니다.
///
/// # 예제
/// ```
/// assert_eq!(uppercase("Hello"), "HELLO");
/// ```
pub fn uppercase(s: String) -> String {
    s.to_uppercase()
}

/// 문자열을 소문자로 변환합니다.
///
/// # 예제
/// ```
/// assert_eq!(lowercase("Hello"), "hello");
/// ```
pub fn lowercase(s: String) -> String {
    s.to_lowercase()
}

// ============================================================================
// Substring and Splitting
// ============================================================================

/// 문자열의 부분 문자열을 추출합니다.
///
/// # 매개변수
/// - start: 시작 위치 (포함)
/// - end: 종료 위치 (포함)
///
/// # 에러
/// - 범위 초과: StringError::IndexOutOfBounds
///
/// # 예제
/// ```
/// assert_eq!(substring("Hello", 0, 2), Ok("Hel".to_string()));
/// assert_eq!(substring("Hello", 1, 4), Ok("ello".to_string()));
/// ```
pub fn substring(s: String, start: i64, end: i64) -> Result<String, StringError> {
    let len = s.chars().count() as i64;

    if start < 0 || end < 0 || start > len || end > len || start > end {
        return Err(StringError::IndexOutOfBounds {
            index: if start < 0 || start > len { start } else { end },
            len,
        });
    }

    let result: String = s.chars()
        .skip(start as usize)
        .take((end - start + 1) as usize)
        .collect();

    Ok(result)
}

/// 문자열을 구분자로 분할하여 배열로 반환합니다.
///
/// # 예제
/// ```
/// let result = split("a,b,c", ",").unwrap();
/// assert_eq!(result, FlValue::Array(vec![
///     FlValue::Str("a".to_string()),
///     FlValue::Str("b".to_string()),
///     FlValue::Str("c".to_string()),
/// ]));
/// ```
pub fn split(s: String, delim: String) -> FlValue {
    if delim.is_empty() {
        // 빈 구분자는 각 문자별로 분할
        let chars: Vec<FlValue> = s.chars()
            .map(|c| FlValue::Str(c.to_string()))
            .collect();
        return FlValue::Array(chars);
    }

    let parts: Vec<FlValue> = s.split(&delim)
        .map(|part| FlValue::Str(part.to_string()))
        .collect();

    FlValue::Array(parts)
}

/// 배열의 요소들을 구분자로 연결하여 문자열로 반환합니다.
///
/// # 예제
/// ```
/// let arr = FlValue::Array(vec![
///     FlValue::Str("a".to_string()),
///     FlValue::Str("b".to_string()),
/// ]);
/// assert_eq!(join(arr, ","), "a,b");
/// ```
pub fn join(arr: FlValue, delim: String) -> String {
    match arr {
        FlValue::Array(elements) => {
            let strings: Vec<String> = elements.iter()
                .map(|elem| elem.to_string_repr())
                .collect();
            strings.join(&delim)
        }
        _ => String::new(),
    }
}

// ============================================================================
// Trimming and Whitespace
// ============================================================================

/// 문자열의 양쪽 공백을 제거합니다.
///
/// # 예제
/// ```
/// assert_eq!(trim("  Hello  "), "Hello");
/// ```
pub fn trim(s: String) -> String {
    s.trim().to_string()
}

/// 문자열의 왼쪽 공백을 제거합니다.
///
/// # 예제
/// ```
/// assert_eq!(trim_left("  Hello"), "Hello");
/// ```
pub fn trim_left(s: String) -> String {
    s.trim_start().to_string()
}

/// 문자열의 오른쪽 공백을 제거합니다.
///
/// # 예제
/// ```
/// assert_eq!(trim_right("Hello  "), "Hello");
/// ```
pub fn trim_right(s: String) -> String {
    s.trim_end().to_string()
}

// ============================================================================
// Search and Replace
// ============================================================================

/// 첫 번째 발생하는 부분 문자열을 대체합니다.
///
/// # 예제
/// ```
/// assert_eq!(replace("Hello World", "World", "Rust"), "Hello Rust");
/// ```
pub fn replace(s: String, old: String, new: String) -> String {
    s.replacen(&old, &new, 1)
}

/// 모든 발생하는 부분 문자열을 대체합니다.
///
/// # 예제
/// ```
/// assert_eq!(replace_all("aaa", "a", "b"), "bbb");
/// ```
pub fn replace_all(s: String, old: String, new: String) -> String {
    s.replace(&old, &new)
}

/// 부분 문자열이 처음 나타나는 위치를 반환합니다.
///
/// # 반환값
/// - 찾으면: 위치 (0부터 시작)
/// - 못 찾으면: -1
///
/// # 예제
/// ```
/// assert_eq!(index_of("Hello World", "World"), 6);
/// assert_eq!(index_of("Hello World", "xyz"), -1);
/// ```
pub fn index_of(s: String, sub: String) -> i64 {
    match s.find(&sub) {
        Some(pos) => pos as i64,
        None => -1,
    }
}

/// 문자열이 부분 문자열을 포함하는지 확인합니다.
///
/// # 예제
/// ```
/// assert_eq!(contains("Hello World", "World"), true);
/// assert_eq!(contains("Hello World", "xyz"), false);
/// ```
pub fn contains(s: String, sub: String) -> bool {
    s.contains(&sub)
}

/// 문자열이 특정 접두사로 시작하는지 확인합니다.
///
/// # 예제
/// ```
/// assert_eq!(starts_with("Hello", "He"), true);
/// assert_eq!(starts_with("Hello", "la"), false);
/// ```
pub fn starts_with(s: String, prefix: String) -> bool {
    s.starts_with(&prefix)
}

/// 문자열이 특정 접미사로 끝나는지 확인합니다.
///
/// # 예제
/// ```
/// assert_eq!(ends_with("Hello", "lo"), true);
/// assert_eq!(ends_with("Hello", "he"), false);
/// ```
pub fn ends_with(s: String, suffix: String) -> bool {
    s.ends_with(&suffix)
}

// ============================================================================
// Conversion and Formatting
// ============================================================================

/// 문자열을 정수로 변환합니다.
///
/// # 에러
/// - 파싱 실패: StringError::ConversionError
///
/// # 예제
/// ```
/// assert_eq!(str_to_int("42"), Ok(42));
/// assert_eq!(str_to_int("abc"), Err(StringError::ConversionError(_)));
/// ```
pub fn str_to_int(s: String) -> Result<i64, StringError> {
    s.trim().parse::<i64>()
        .map_err(|_| StringError::ConversionError(format!("Cannot parse '{}' as integer", s)))
}

/// 문자열을 실수로 변환합니다.
///
/// # 에러
/// - 파싱 실패: StringError::ConversionError
///
/// # 예제
/// ```
/// assert_eq!(str_to_float("3.14"), Ok(3.14));
/// ```
pub fn str_to_float(s: String) -> Result<f64, StringError> {
    s.trim().parse::<f64>()
        .map_err(|_| StringError::ConversionError(format!("Cannot parse '{}' as float", s)))
}

/// 포맷 문자열을 생성합니다.
///
/// # 포맷 규칙
/// - `{}`: 플레이스홀더 (값으로 대체)
/// - 리터럴 문자는 그대로 유지
///
/// # 매개변수
/// - fmt: 포맷 문자열
/// - args: 플레이스홀더를 대체할 FlValue 배열
///
/// # 예제
/// ```
/// let args = vec![FlValue::Int(1), FlValue::Int(2), FlValue::Int(3)];
/// assert_eq!(str_format("{} + {} = {}", args), "1 + 2 = 3");
/// ```
pub fn str_format(fmt: String, args: FlValue) -> Result<String, StringError> {
    let arg_list = match args {
        FlValue::Array(arr) => arr,
        _ => return Err(StringError::InvalidFormat("args must be array".to_string())),
    };

    let mut result = fmt.clone();
    let mut arg_index = 0;

    // 모든 {} 플레이스홀더를 순서대로 대체
    while let Some(pos) = result.find("{}") {
        if arg_index >= arg_list.len() {
            return Err(StringError::InvalidFormat(
                format!("Not enough arguments for format string"),
            ));
        }

        let arg_str = arg_list[arg_index].to_string_repr();
        result.replace_range(pos..pos + 2, &arg_str);
        arg_index += 1;
    }

    Ok(result)
}

/// 문자열이 비어있는지 확인합니다.
///
/// # 예제
/// ```
/// assert_eq!(str_is_empty(""), true);
/// assert_eq!(str_is_empty("Hello"), false);
/// ```
pub fn str_is_empty(s: String) -> bool {
    s.is_empty()
}

/// 문자열을 n번 반복합니다.
///
/// # 예제
/// ```
/// assert_eq!(repeat("ab", 3), "ababab");
/// ```
pub fn repeat(s: String, n: i64) -> String {
    if n <= 0 {
        return String::new();
    }
    s.repeat(n as usize)
}

