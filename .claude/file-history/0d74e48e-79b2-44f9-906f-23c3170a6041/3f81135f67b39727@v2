#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_concat() {
        assert_eq!(concat("Hello".to_string(), " World".to_string()), "Hello World");
        assert_eq!(concat("".to_string(), "test".to_string()), "test");
    }

    #[test]
    fn test_length() {
        assert_eq!(length("Hello".to_string()), 5);
        assert_eq!(length("".to_string()), 0);
        assert_eq!(length("한글".to_string()), 2);
    }

    #[test]
    fn test_uppercase() {
        assert_eq!(uppercase("Hello".to_string()), "HELLO");
        assert_eq!(uppercase("hello".to_string()), "HELLO");
    }

    #[test]
    fn test_lowercase() {
        assert_eq!(lowercase("Hello".to_string()), "hello");
        assert_eq!(lowercase("HELLO".to_string()), "hello");
    }

    #[test]
    fn test_substring_valid() {
        assert_eq!(substring("Hello".to_string(), 0, 2).unwrap(), "Hel");
        assert_eq!(substring("Hello".to_string(), 1, 4).unwrap(), "ello");
        assert_eq!(substring("Hello".to_string(), 0, 0).unwrap(), "H");
    }

    #[test]
    fn test_substring_invalid() {
        assert!(substring("Hello".to_string(), 0, 10).is_err());
        assert!(substring("Hello".to_string(), -1, 2).is_err());
    }

    #[test]
    fn test_split() {
        let result = split("a,b,c".to_string(), ",".to_string());
        match result {
            FlValue::Array(arr) => assert_eq!(arr.len(), 3),
            _ => panic!("Expected array"),
        }
    }

    #[test]
    fn test_split_empty_delim() {
        let result = split("abc".to_string(), "".to_string());
        match result {
            FlValue::Array(arr) => assert_eq!(arr.len(), 3),
            _ => panic!("Expected array"),
        }
    }

    #[test]
    fn test_join() {
        let arr = FlValue::Array(vec![
            FlValue::Str("a".to_string()),
            FlValue::Str("b".to_string()),
            FlValue::Str("c".to_string()),
        ]);
        assert_eq!(join(arr, ",".to_string()), "a,b,c");
    }

    #[test]
    fn test_trim() {
        assert_eq!(trim("  Hello  ".to_string()), "Hello");
        assert_eq!(trim("Hello".to_string()), "Hello");
    }

    #[test]
    fn test_trim_left() {
        assert_eq!(trim_left("  Hello".to_string()), "Hello");
    }

    #[test]
    fn test_trim_right() {
        assert_eq!(trim_right("Hello  ".to_string()), "Hello");
    }

    #[test]
    fn test_replace() {
        assert_eq!(replace("Hello World".to_string(), "World".to_string(), "Rust".to_string()),
                   "Hello Rust");
    }

    #[test]
    fn test_replace_all() {
        assert_eq!(replace_all("aaa".to_string(), "a".to_string(), "b".to_string()), "bbb");
    }

    #[test]
    fn test_index_of_found() {
        assert_eq!(index_of("Hello World".to_string(), "World".to_string()), 6);
        assert_eq!(index_of("Hello World".to_string(), "Hello".to_string()), 0);
    }

    #[test]
    fn test_index_of_not_found() {
        assert_eq!(index_of("Hello World".to_string(), "xyz".to_string()), -1);
    }

    #[test]
    fn test_contains_true() {
        assert_eq!(contains("Hello World".to_string(), "World".to_string()), true);
    }

    #[test]
    fn test_contains_false() {
        assert_eq!(contains("Hello World".to_string(), "xyz".to_string()), false);
    }

    #[test]
    fn test_starts_with() {
        assert_eq!(starts_with("Hello".to_string(), "He".to_string()), true);
        assert_eq!(starts_with("Hello".to_string(), "la".to_string()), false);
    }

    #[test]
    fn test_ends_with() {
        assert_eq!(ends_with("Hello".to_string(), "lo".to_string()), true);
        assert_eq!(ends_with("Hello".to_string(), "he".to_string()), false);
    }

    #[test]
    fn test_str_to_int_valid() {
        assert_eq!(str_to_int("42".to_string()).unwrap(), 42);
        assert_eq!(str_to_int("-100".to_string()).unwrap(), -100);
        assert_eq!(str_to_int("  123  ".to_string()).unwrap(), 123);
    }

    #[test]
    fn test_str_to_int_invalid() {
        assert!(str_to_int("abc".to_string()).is_err());
    }

    #[test]
    fn test_str_to_float_valid() {
        assert_eq!(str_to_float("3.14".to_string()).unwrap(), 3.14);
    }

    #[test]
    fn test_str_is_empty_true() {
        assert_eq!(str_is_empty("".to_string()), true);
    }

    #[test]
    fn test_str_is_empty_false() {
        assert_eq!(str_is_empty("Hello".to_string()), false);
    }

    #[test]
    fn test_repeat() {
        assert_eq!(repeat("ab".to_string(), 3), "ababab");
        assert_eq!(repeat("x".to_string(), 0), "");
        assert_eq!(repeat("x".to_string(), 1), "x");
    }

    #[test]
    fn test_str_format_simple() {
        let args = FlValue::Array(vec![
            FlValue::Int(1),
            FlValue::Int(2),
            FlValue::Int(3),
        ]);
        assert_eq!(
            str_format("{} + {} = {}".to_string(), args).unwrap(),
            "1 + 2 = 3"
        );
    }

    #[test]
    fn test_str_format_with_text() {
        let args = FlValue::Array(vec![
            FlValue::Str("world".to_string()),
        ]);
        assert_eq!(
            str_format("Hello, {}!".to_string(), args).unwrap(),
            "Hello, world!"
        );
    }

    #[test]
    fn test_str_format_insufficient_args() {
        let args = FlValue::Array(vec![FlValue::Int(1)]);
        assert!(str_format("{} + {}".to_string(), args).is_err());
    }
