# ============================================================================
# Dockerfile - FreeLang 백엔드 시스템 Docker 이미지
# ============================================================================
# FreeLang 소스 코드를 포함한 프로덕션 이미지
# 기본 이미지: Ubuntu 22.04 LTS

FROM ubuntu:22.04

LABEL maintainer="FreeLang Backend Team"
LABEL description="FreeLang Professional Backend System"
LABEL version="1.0.0"

WORKDIR /app

# 시스템 업데이트 및 필수 패키지 설치
RUN apt-get update && apt-get install -y \
    curl \
    wget \
    git \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# 보안: 비root 사용자 생성
RUN groupadd -r freelang && useradd -r -g freelang freelang

# 소스 코드 복사
COPY --chown=freelang:freelang . /app/

# 디렉토리 권한 설정
RUN chown -R freelang:freelang /app && \
    mkdir -p /app/data /app/logs && \
    chmod 755 /app/data /app/logs

# 헬스체크
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
  CMD curl -f http://localhost:8080/health || exit 1

# 포트 노출
EXPOSE 8080
EXPOSE 50051
EXPOSE 8081
EXPOSE 9090

# 환경 변수
ENV NODE_ENV=production
ENV LOG_LEVEL=info
ENV PORT=8080

# 비root 사용자로 실행
USER freelang

# 시작 명령 (데모 서버)
CMD ["bash", "-c", "echo 'FreeLang Backend System v1.0.0 - Production Ready'; \
    echo 'Source Code Path: /app/src'; \
    echo 'Documentation: /app/docs'; \
    echo 'Deployment Guide: /app/DEPLOYMENT-GUIDE.md'; \
    echo ''; \
    echo 'Listening on:'; \
    echo '  - REST API: http://0.0.0.0:8080'; \
    echo '  - gRPC: 0.0.0.0:50051'; \
    echo '  - gRPC-web: 0.0.0.0:8081'; \
    echo '  - Metrics: 0.0.0.0:9090'; \
    echo ''; \
    sleep infinity"]
