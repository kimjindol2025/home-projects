#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_os_simulator_creation() {
        let sim = OSSimulator::new();
        assert!(!sim.self_hosted);
        assert_eq!(sim.idt_entries, 0);
    }

    #[test]
    fn test_bootloader_execution() {
        let mut sim = OSSimulator::new();
        assert!(sim.run_bootloader().is_ok());
        assert!(sim.metrics.boot_time > 0);
    }

    #[test]
    fn test_kernel_initialization() {
        let mut sim = OSSimulator::new();
        assert!(sim.initialize_kernel().is_ok());
        assert_eq!(sim.idt_entries, 256);
        assert!(sim.page_tables > 0);
    }

    #[test]
    fn test_program_execution() {
        let mut sim = OSSimulator::new();
        sim.initialize_kernel().unwrap();

        let program = vec!["let x = 42"];
        assert!(sim.execute_freelang_program(program).is_ok());
        assert!(sim.metrics.instructions > 0);
    }

    #[test]
    fn test_self_hosting_validation() {
        let mut sim = OSSimulator::new();
        sim.initialize_kernel().unwrap();
        sim.execute_freelang_program(vec!["let x = 42"]).unwrap();

        assert!(sim.validate_self_hosting().is_ok());
        assert!(sim.self_hosted);
    }

    #[test]
    fn test_context_switching() {
        let mut sim = OSSimulator::new();
        sim.initialize_kernel().unwrap();

        let program = vec!["let a = 1", "let b = 2", "let c = 3", "let d = 4"];
        sim.execute_freelang_program(program).unwrap();

        assert!(sim.metrics.context_switches > 0);
    }

    #[test]
    fn test_interrupt_handling() {
        let mut sim = OSSimulator::new();
        sim.initialize_kernel().unwrap();

        let program = vec![
            "let x = 1", "let y = 2", "let z = 3", "let w = 4",
            "let a = 5", "let b = 6", "let c = 7", "let d = 8",
            "let e = 9", "let f = 10",
        ];
        sim.execute_freelang_program(program).unwrap();

        assert!(sim.metrics.interrupts_handled > 0);
    }

    #[test]
    fn test_io_operations() {
        let mut sim = OSSimulator::new();
        sim.initialize_kernel().unwrap();

        let program = vec![
            "print \"Test 1\"",
            "print \"Test 2\"",
            "print \"Test 3\"",
        ];
        sim.execute_freelang_program(program).unwrap();

        assert_eq!(sim.metrics.io_operations, 3);
    }

    #[test]
    fn test_performance_metrics() {
        let mut sim = OSSimulator::new();
        sim.initialize_kernel().unwrap();

        let program = vec!["let x = 42"];
        sim.execute_freelang_program(program).unwrap();

        assert!(sim.metrics.total_cycles > 0);
        assert!(sim.metrics.memory_used > 0);
    }

    #[test]
    fn test_complete_simulation() {
        let mut sim = OSSimulator::new();
        assert!(sim.run_bootloader().is_ok());
        assert!(sim.initialize_kernel().is_ok());

        let program = vec!["let x = 42", "print \"Hello\""];
        assert!(sim.execute_freelang_program(program).is_ok());
        assert!(sim.validate_self_hosting().is_ok());

        assert!(sim.self_hosted);
    }
}
