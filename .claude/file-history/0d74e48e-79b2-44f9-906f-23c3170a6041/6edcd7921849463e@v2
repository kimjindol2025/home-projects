/// 시스템 상태
#[derive(Clone, Copy, Debug)]
pub enum SystemState {
    PowerOff,
    BootloaderRunning,
    KernelInitializing,
    KernelRunning,
    ApplicationRunning,
    SystemCallHandling,
    ContextSwitching,
    InterruptHandling,
    Shutdown,
}

impl SystemState {
    pub fn as_str(&self) -> &'static str {
        match self {
            SystemState::PowerOff => "Power Off",
            SystemState::BootloaderRunning => "Bootloader Running",
            SystemState::KernelInitializing => "Kernel Initializing",
            SystemState::KernelRunning => "Kernel Running",
            SystemState::ApplicationRunning => "Application Running",
            SystemState::SystemCallHandling => "System Call Handling",
            SystemState::ContextSwitching => "Context Switching",
            SystemState::InterruptHandling => "Interrupt Handling",
            SystemState::Shutdown => "Shutdown",
        }
    }
}

// ============================================================================
// Part 2: 성능 메트릭
// ============================================================================

pub struct PerformanceMetrics {
    /// 총 실행 사이클 수
    pub total_cycles: u64,

    /// 메모리 사용량
    pub memory_used: u64,

    /// 컨텍스트 스위치 횟수
    pub context_switches: u32,

    /// 인터럽트 처리 횟수
    pub interrupts_handled: u32,

    /// I/O 작업 수
    pub io_operations: u32,

    /// 실행된 명령어 수
    pub instructions: u32,

    /// 부팅 시간 (ms)
    pub boot_time: u32,

    /// 평균 CPU 시간
    pub avg_cpu_time_us: u32,
}

impl PerformanceMetrics {
    pub fn new() -> Self {
        PerformanceMetrics {
            total_cycles: 0,
            memory_used: 0,
            context_switches: 0,
            interrupts_handled: 0,
            io_operations: 0,
            instructions: 0,
            boot_time: 0,
            avg_cpu_time_us: 0,
        }
    }

    pub fn calculate_cpu_time(&mut self) {
        if self.context_switches > 0 {
            self.avg_cpu_time_us = (self.total_cycles / self.context_switches as u64) as u32;
        }
    }

    pub fn print_report(&self) {
        println!("\n╔════════════════════════════════════════════════════════════╗");
        println!("║            Performance Metrics Report                      ║");
        println!("╚════════════════════════════════════════════════════════════╝");

        println!("\n📊 Execution Statistics:");
        println!("  Total Cycles: {}", self.total_cycles);
        println!("  Instructions: {}", self.instructions);
        println!("  Boot Time: {} ms", self.boot_time);
        println!("  Avg CPU Time: {} µs", self.avg_cpu_time_us);

        println!("\n🔄 Process Management:");
        println!("  Context Switches: {}", self.context_switches);
        println!("  Time per Switch: ~1 µs (estimated)");

        println!("\n💾 Memory:");
        println!("  Used: {} bytes", self.memory_used);
        println!("  Efficiency: {:.2}%", (self.memory_used as f64 / 1024.0) * 100.0);

        println!("\n⚡ Interrupts & I/O:");
        println!("  Interrupts Handled: {}", self.interrupts_handled);
        println!("  I/O Operations: {}", self.io_operations);
        println!("  I/O Efficiency: {:.2} ops/sec",
                 (self.io_operations as f64 * 1000.0) / self.boot_time as f64);
    }
}

