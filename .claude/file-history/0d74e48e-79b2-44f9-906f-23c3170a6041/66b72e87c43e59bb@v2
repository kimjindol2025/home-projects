use std::collections::HashMap;

/// 패키지 메타데이터
#[derive(Clone, Debug, PartialEq)]
pub struct PackageMetadata {
    /// 패키지 이름 (lowercase, kebab-case)
    pub name: String,

    /// 버전 (SemVer: major.minor.patch)
    pub version: String,

    /// 저자
    pub author: String,

    /// 설명
    pub description: String,

    /// 저장소 URL
    pub repository: Option<String>,

    /// 라이선스
    pub license: Option<String>,
}

/// 패키지 의존성 항목
#[derive(Clone, Debug, PartialEq)]
pub struct Dependency {
    /// 패키지 이름
    pub name: String,

    /// 버전 범위 (예: "^1.0.0", "~2.1.0", "=1.2.3")
    pub version_range: String,

    /// 선택적 의존성 여부
    pub optional: bool,
}

/// freelang.toml 파일의 전체 구조
#[derive(Clone, Debug)]
pub struct Manifest {
    /// 패키지 메타데이터
    pub package: PackageMetadata,

    /// 일반 의존성
    pub dependencies: Vec<Dependency>,

    /// 개발 의존성
    pub dev_dependencies: Vec<Dependency>,

    /// 빌드 의존성
    pub build_dependencies: Vec<Dependency>,
}

/// 의존성 해결 결과
#[derive(Clone, Debug)]
pub struct ResolutionResult {
    /// 해결된 패키지 목록 (name -> version)
    pub resolved: HashMap<String, String>,

    /// 의존성 그래프 (name -> dependencies)
    pub graph: HashMap<String, Vec<String>>,

    /// 충돌 목록 (있으면 해결 실패)
    pub conflicts: Vec<String>,

    /// 성공 여부
    pub success: bool,
}

/// 버전 정보
#[derive(Clone, Debug, PartialEq, Eq)]
pub struct Version {
    pub major: u32,
    pub minor: u32,
    pub patch: u32,
}

impl Version {
    /// SemVer 문자열에서 Version 파싱
    pub fn parse(version_str: &str) -> Option<Self> {
        let parts: Vec<&str> = version_str.split('.').collect();
        if parts.len() != 3 {
            return None;
        }

        let major = parts[0].parse::<u32>().ok()?;
        let minor = parts[1].parse::<u32>().ok()?;
        let patch = parts[2].parse::<u32>().ok()?;

        Some(Version { major, minor, patch })
    }

    /// Version을 SemVer 문자열로 변환
    pub fn to_string(&self) -> String {
        format!("{}.{}.{}", self.major, self.minor, self.patch)
    }

    /// 버전 비교
    pub fn compare(&self, other: &Version) -> std::cmp::Ordering {
        use std::cmp::Ordering;

        match self.major.cmp(&other.major) {
            Ordering::Equal => match self.minor.cmp(&other.minor) {
                Ordering::Equal => self.patch.cmp(&other.patch),
                ord => ord,
            }
            ord => ord,
        }
    }
}

/// FPM 에러 타입
#[derive(Clone, Debug, PartialEq)]
pub enum FpmError {
    /// 파일을 찾을 수 없음
    NotFound(String),

    /// 파싱 에러
    ParseError(String),

    /// 버전 범위 불일치
    VersionConflict(String),

    /// 패키지를 찾을 수 없음
    PackageNotFound(String),

    /// 레지스트리 연결 실패
    RegistryError(String),

    /// 기타 에러
    Other(String),
}

impl std::fmt::Display for FpmError {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            FpmError::NotFound(msg) => write!(f, "Not found: {}", msg),
            FpmError::ParseError(msg) => write!(f, "Parse error: {}", msg),
            FpmError::VersionConflict(msg) => write!(f, "Version conflict: {}", msg),
            FpmError::PackageNotFound(msg) => write!(f, "Package not found: {}", msg),
            FpmError::RegistryError(msg) => write!(f, "Registry error: {}", msg),
            FpmError::Other(msg) => write!(f, "Error: {}", msg),
        }
    }
}

