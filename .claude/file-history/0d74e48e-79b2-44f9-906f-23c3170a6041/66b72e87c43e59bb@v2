#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_version_parse() {
        let v = Version::parse("1.2.3").unwrap();
        assert_eq!(v.major, 1);
        assert_eq!(v.minor, 2);
        assert_eq!(v.patch, 3);
    }

    #[test]
    fn test_version_to_string() {
        let v = Version { major: 2, minor: 1, patch: 0 };
        assert_eq!(v.to_string(), "2.1.0");
    }

    #[test]
    fn test_version_compare() {
        use std::cmp::Ordering;

        let v1 = Version { major: 1, minor: 2, patch: 3 };
        let v2 = Version { major: 1, minor: 2, patch: 4 };
        let v3 = Version { major: 1, minor: 2, patch: 3 };

        assert_eq!(v1.compare(&v2), Ordering::Less);
        assert_eq!(v2.compare(&v1), Ordering::Greater);
        assert_eq!(v1.compare(&v3), Ordering::Equal);
    }

    #[test]
    fn test_package_metadata_creation() {
        let pkg = PackageMetadata {
            name: "my-project".to_string(),
            version: "1.0.0".to_string(),
            author: "Kim".to_string(),
            description: "A test project".to_string(),
            repository: Some("https://gogs.dclub.kr/kim/my-project".to_string()),
            license: Some("MIT".to_string()),
        };

        assert_eq!(pkg.name, "my-project");
        assert_eq!(pkg.version, "1.0.0");
    }

    #[test]
    fn test_dependency_creation() {
        let dep = Dependency {
            name: "freelang-json".to_string(),
            version_range: "^1.0.0".to_string(),
            optional: false,
        };

        assert_eq!(dep.name, "freelang-json");
        assert!(!dep.optional);
    }

    #[test]
    fn test_fpm_error_display() {
        let err = FpmError::NotFound("freelang.toml".to_string());
        assert!(format!("{}", err).contains("Not found"));
    }

    #[test]
    fn test_manifest_creation() {
        let pkg = PackageMetadata {
            name: "test".to_string(),
            version: "1.0.0".to_string(),
            author: "test".to_string(),
            description: "test".to_string(),
            repository: None,
            license: None,
        };

        let manifest = Manifest {
            package: pkg,
            dependencies: vec![],
            dev_dependencies: vec![],
            build_dependencies: vec![],
        };

        assert_eq!(manifest.dependencies.len(), 0);
    }
}

