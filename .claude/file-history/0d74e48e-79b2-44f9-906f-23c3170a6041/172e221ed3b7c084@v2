// ============================================================================
// FreeLang Borrow State - 동적 빌림 상태 관리
// ============================================================================
//
// RefCell의 내부 빌림 상태를 추적합니다.
//
// 규칙:
// - 불변 빌림: 0개 이상 동시 가능
// - 가변 빌림: 0 또는 1 (배타적)
// - 불변 + 가변: 불가능
//
// 작성일: 2026-03-02
// 단계: Phase B.3 (Week 5-8)

use std::cell::Cell;

// ============================================================================
// Borrow 상태 열거형
// ============================================================================

/// 동적 빌림의 현재 상태
#[derive(Clone, Copy, Debug, PartialEq, Eq)]
pub enum BorrowState {
    /// 아무도 빌리지 않음
    Unused,

    /// n개의 불변 빌림 (Shared)
    /// 0 < n
    Shared(usize),

    /// 1개의 가변 빌림 (Exclusive)
    Exclusive,

    /// 빌림 규칙 위반 상태 (panic 후)
    Poisoned,
}

// ============================================================================
// BorrowState 구현
// ============================================================================

impl BorrowState {
    /// 새로운 미사용 상태를 생성합니다.
    pub fn new() -> BorrowState {
        BorrowState::Unused
    }

    /// 현재 상태를 문자열로 표현합니다.
    pub fn to_string(&self) -> &'static str {
        match self {
            BorrowState::Unused => "Unused",
            BorrowState::Shared(n) => {
                if *n == 1 {
                    "Shared(1)"
                } else if *n == 2 {
                    "Shared(2)"
                } else if *n <= 5 {
                    "Shared(3-5)"
                } else {
                    "Shared(5+)"
                }
            }
            BorrowState::Exclusive => "Exclusive",
            BorrowState::Poisoned => "Poisoned",
        }
    }

    /// 불변 빌림을 시도합니다.
    ///
    /// # 성공 조건
    /// - 현재 상태가 Unused 또는 Shared
    /// - Exclusive 중이면 실패
    ///
    /// # 반환값
    /// - Ok(new_state): 새 불변 빌림 추가됨
    /// - Err(old_state): 빌림 불가능 (이미 가변 빌림 중)
    pub fn try_borrow(&self) -> Result<BorrowState, BorrowState> {
        match self {
            BorrowState::Unused => Ok(BorrowState::Shared(1)),
            BorrowState::Shared(n) => Ok(BorrowState::Shared(n + 1)),
            BorrowState::Exclusive => Err(*self),
            BorrowState::Poisoned => Err(*self),
        }
    }

    /// 가변 빌림을 시도합니다.
    ///
    /// # 성공 조건
    /// - 현재 상태가 Unused
    /// - Shared 또는 Exclusive이면 실패
    ///
    /// # 반환값
    /// - Ok(new_state): 가변 빌림 획득
    /// - Err(old_state): 빌림 불가능
    pub fn try_borrow_mut(&self) -> Result<BorrowState, BorrowState> {
        match self {
            BorrowState::Unused => Ok(BorrowState::Exclusive),
            BorrowState::Shared(_) => Err(*self),
            BorrowState::Exclusive => Err(*self),
            BorrowState::Poisoned => Err(*self),
        }
    }

    /// 불변 빌림을 반환합니다.
    ///
    /// # 패닉
    /// - 현재 상태가 Shared이 아니면 panic
    pub fn release_borrow(&self) -> BorrowState {
        match self {
            BorrowState::Shared(n) => {
                if *n > 1 {
                    BorrowState::Shared(n - 1)
                } else {
                    BorrowState::Unused
                }
            }
            _ => panic!("release_borrow: state is not Shared"),
        }
    }

    /// 가변 빌림을 반환합니다.
    ///
    /// # 패닉
    /// - 현재 상태가 Exclusive이 아니면 panic
    pub fn release_borrow_mut(&self) -> BorrowState {
        match self {
            BorrowState::Exclusive => BorrowState::Unused,
            _ => panic!("release_borrow_mut: state is not Exclusive"),
        }
    }

    /// 현재 상태에서 불변 빌림이 가능한지 검사합니다.
    pub fn can_borrow(&self) -> bool {
        matches!(self, BorrowState::Unused | BorrowState::Shared(_))
    }

    /// 현재 상태에서 가변 빌림이 가능한지 검사합니다.
    pub fn can_borrow_mut(&self) -> bool {
        matches!(self, BorrowState::Unused)
    }

    /// 현재 빌림 개수를 반환합니다.
    pub fn borrow_count(&self) -> usize {
        match self {
            BorrowState::Unused => 0,
            BorrowState::Shared(n) => *n,
            BorrowState::Exclusive => 1,
            BorrowState::Poisoned => 0, // 또는 panic?
        }
    }

    /// 상태를 Poisoned로 변경합니다.
    pub fn poison(&mut self) {
        *self = BorrowState::Poisoned;
    }

    /// Poisoned 상태인지 확인합니다.
    pub fn is_poisoned(&self) -> bool {
        matches!(self, BorrowState::Poisoned)
    }
}

// ============================================================================
// StatefulBorrow: Cell<BorrowState>를 감싼 구조
// ============================================================================

/// Borrow 상태를 내부 가변성으로 추적합니다.
pub struct StatefulBorrow {
    state: Cell<BorrowState>,
}

impl StatefulBorrow {
    /// 새로운 StatefulBorrow를 생성합니다.
    pub fn new() -> StatefulBorrow {
        StatefulBorrow {
            state: Cell::new(BorrowState::Unused),
        }
    }

    /// 현재 상태를 읽습니다 (복사됨).
    pub fn current_state(&self) -> BorrowState {
        self.state.get()
    }

    /// 현재 상태를 설정합니다.
    pub fn set_state(&self, new_state: BorrowState) {
        self.state.set(new_state);
    }

    /// 불변 빌림을 시도하고, 성공하면 상태를 업데이트합니다.
    ///
    /// # 패닉
    /// - 가변 빌림 중이거나 Poisoned 상태면 panic
    pub fn acquire_borrow(&self) {
        let current = self.state.get();
        match current.try_borrow() {
            Ok(new_state) => self.state.set(new_state),
            Err(old_state) => {
                panic!(
                    "borrow() called on a RefCell that is already mutably borrowed ({})",
                    old_state.to_string()
                );
            }
        }
    }

    /// 가변 빌림을 시도하고, 성공하면 상태를 업데이트합니다.
    ///
    /// # 패닉
    /// - 불변 빌림 중이거나 이미 가변 빌림 중이면 panic
    pub fn acquire_borrow_mut(&self) {
        let current = self.state.get();
        match current.try_borrow_mut() {
            Ok(new_state) => self.state.set(new_state),
            Err(old_state) => {
                panic!(
                    "borrow_mut() called on a RefCell with active borrows ({})",
                    old_state.to_string()
                );
            }
        }
    }

    /// 불변 빌림을 해제합니다.
    pub fn release_borrow(&self) {
        let current = self.state.get();
        match current {
            BorrowState::Shared(_) => {
                let new_state = current.release_borrow();
                self.state.set(new_state);
            }
            _ => panic!("release_borrow() called but not in Shared state"),
        }
    }

    /// 가변 빌림을 해제합니다.
    pub fn release_borrow_mut(&self) {
        let current = self.state.get();
        match current {
            BorrowState::Exclusive => {
                let new_state = current.release_borrow_mut();
                self.state.set(new_state);
            }
            _ => panic!("release_borrow_mut() called but not in Exclusive state"),
        }
    }

    /// 불변 빌림 개수를 반환합니다.
    pub fn active_borrow_count(&self) -> usize {
        self.state.get().borrow_count()
    }
}

