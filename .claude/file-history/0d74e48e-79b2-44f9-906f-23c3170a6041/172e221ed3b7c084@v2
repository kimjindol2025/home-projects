#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_borrow_state_new() {
        let state = BorrowState::new();
        assert_eq!(state, BorrowState::Unused);
    }

    #[test]
    fn test_try_borrow_from_unused() {
        let state = BorrowState::Unused;
        let result = state.try_borrow();
        assert!(result.is_ok());
        assert_eq!(result.unwrap(), BorrowState::Shared(1));
    }

    #[test]
    fn test_try_borrow_from_shared() {
        let state = BorrowState::Shared(2);
        let result = state.try_borrow();
        assert!(result.is_ok());
        assert_eq!(result.unwrap(), BorrowState::Shared(3));
    }

    #[test]
    fn test_try_borrow_from_exclusive_fails() {
        let state = BorrowState::Exclusive;
        let result = state.try_borrow();
        assert!(result.is_err());
    }

    #[test]
    fn test_try_borrow_mut_from_unused() {
        let state = BorrowState::Unused;
        let result = state.try_borrow_mut();
        assert!(result.is_ok());
        assert_eq!(result.unwrap(), BorrowState::Exclusive);
    }

    #[test]
    fn test_try_borrow_mut_from_shared_fails() {
        let state = BorrowState::Shared(2);
        let result = state.try_borrow_mut();
        assert!(result.is_err());
    }

    #[test]
    fn test_try_borrow_mut_from_exclusive_fails() {
        let state = BorrowState::Exclusive;
        let result = state.try_borrow_mut();
        assert!(result.is_err());
    }

    #[test]
    fn test_release_borrow() {
        let state = BorrowState::Shared(3);
        let new_state = state.release_borrow();
        assert_eq!(new_state, BorrowState::Shared(2));

        let state = BorrowState::Shared(1);
        let new_state = state.release_borrow();
        assert_eq!(new_state, BorrowState::Unused);
    }

    #[test]
    fn test_release_borrow_mut() {
        let state = BorrowState::Exclusive;
        let new_state = state.release_borrow_mut();
        assert_eq!(new_state, BorrowState::Unused);
    }

    #[test]
    fn test_can_borrow() {
        assert!(BorrowState::Unused.can_borrow());
        assert!(BorrowState::Shared(5).can_borrow());
        assert!(!BorrowState::Exclusive.can_borrow());
        assert!(!BorrowState::Poisoned.can_borrow());
    }

    #[test]
    fn test_can_borrow_mut() {
        assert!(BorrowState::Unused.can_borrow_mut());
        assert!(!BorrowState::Shared(1).can_borrow_mut());
        assert!(!BorrowState::Exclusive.can_borrow_mut());
        assert!(!BorrowState::Poisoned.can_borrow_mut());
    }

    #[test]
    fn test_borrow_count() {
        assert_eq!(BorrowState::Unused.borrow_count(), 0);
        assert_eq!(BorrowState::Shared(5).borrow_count(), 5);
        assert_eq!(BorrowState::Exclusive.borrow_count(), 1);
    }

    #[test]
    fn test_stateful_borrow_new() {
        let sb = StatefulBorrow::new();
        assert_eq!(sb.current_state(), BorrowState::Unused);
    }

    #[test]
    fn test_stateful_borrow_acquire_release() {
        let sb = StatefulBorrow::new();

        sb.acquire_borrow();
        assert_eq!(sb.active_borrow_count(), 1);

        sb.acquire_borrow();
        assert_eq!(sb.active_borrow_count(), 2);

        sb.release_borrow();
        assert_eq!(sb.active_borrow_count(), 1);

        sb.release_borrow();
        assert_eq!(sb.active_borrow_count(), 0);
    }

    #[test]
    fn test_stateful_borrow_mut_acquire_release() {
        let sb = StatefulBorrow::new();

        sb.acquire_borrow_mut();
        assert_eq!(sb.active_borrow_count(), 1);

        sb.release_borrow_mut();
        assert_eq!(sb.active_borrow_count(), 0);
    }

    #[test]
    #[should_panic(expected = "borrow_mut() called on a RefCell with active borrows")]
    fn test_stateful_borrow_conflict() {
        let sb = StatefulBorrow::new();

        sb.acquire_borrow();
        sb.acquire_borrow_mut(); // panic!
    }

    #[test]
    #[should_panic(expected = "borrow() called on a RefCell that is already mutably borrowed")]
    fn test_stateful_borrow_mut_conflict() {
        let sb = StatefulBorrow::new();

        sb.acquire_borrow_mut();
        sb.acquire_borrow(); // panic!
    }

    #[test]
    fn test_poison_state() {
        let mut state = BorrowState::Unused;
        assert!(!state.is_poisoned());

        state.poison();
        assert!(state.is_poisoned());
        assert!(!state.can_borrow());
        assert!(!state.can_borrow_mut());
    }
}

