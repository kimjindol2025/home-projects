# ============================================================================
# Dockerfile - FreeLang 백엔드 시스템 Docker 이미지
# ============================================================================
# 멀티 스테이지 빌드: 빌드 → 런타임
# 기본 이미지: Node.js 20 LTS (Alpine)

# Stage 1: 빌드
FROM node:20-alpine AS builder

LABEL maintainer="FreeLang Backend Team"
LABEL description="FreeLang Professional Backend System"
LABEL version="1.0.0"

WORKDIR /build

# 의존성 설치
COPY package*.json ./
RUN npm ci --only=production

# 소스 코드 복사
COPY . .

# TypeScript 컴파일 (gRPC-web)
RUN npm run build 2>/dev/null || true

# Stage 2: 런타임
FROM node:20-alpine

WORKDIR /app

# 보안: 비root 사용자 생성
RUN addgroup -g 1001 -S nodejs && \
    adduser -S nodejs -u 1001

# Stage 1에서 빌드 결과 복사
COPY --from=builder --chown=nodejs:nodejs /build/node_modules ./node_modules
COPY --from=builder --chown=nodejs:nodejs /build . .

# 헬스체크
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
  CMD node -e "require('http').get('http://localhost:8080/health', (r) => {if (r.statusCode !== 200) throw new Error(r.statusCode)})" || exit 1

# 포트 노출
EXPOSE 8080   # REST API
EXPOSE 50051  # gRPC
EXPOSE 8081   # gRPC-web
EXPOSE 9090   # 모니터링

# 환경 변수
ENV NODE_ENV=production
ENV LOG_LEVEL=info
ENV PORT=8080

# 비root 사용자로 실행
USER nodejs

# 시작 명령
CMD ["npm", "start"]
