fn buildTodoJson
  input: todo: Todo
  output: string
  intent: "Todo를 JSON으로 변환"
  do
    return "{\"id\":" + str(todo.id) +
           ",\"title\":\"" + todo.title +
           "\",\"description\":\"" + todo.description +
           "\",\"completed\":" + boolToString(todo.completed) +
           ",\"createdAt\":\"" + todo.createdAt +
           "\",\"updatedAt\":\"" + todo.updatedAt + "\"}"

fn buildTodoListJson
  input: (todos: array<Todo>, page: number, pageSize: number, total: number, totalPages: number)
  output: string
  intent: "Todo 목록을 JSON으로 변환"
  do
    let todoJsons = todoArrayToJsonArray(todos)
    let todoString = joinJsonArray(todoJsons)

    return "{\"items\":[" + todoString +
           "],\"pagination\":{\"page\":" + str(page) +
           ",\"pageSize\":" + str(pageSize) +
           ",\"total\":" + str(total) +
           ",\"totalPages\":" + str(totalPages) + "}}"

fn buildSuccessResponse
  input: dataJson: string
  output: string
  intent: "성공 응답을 JSON으로 생성"
  do
    let now = getCurrentTime()
    return "{\"success\":true,\"data\":" + dataJson +
           ",\"timestamp\":\"" + now + "\"}"

