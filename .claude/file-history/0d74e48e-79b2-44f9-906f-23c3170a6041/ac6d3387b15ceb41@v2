fn extractJsonField
  input: (json: string, field: string)
  output: Option<string>
  intent: "JSON 문자열에서 필드 추출"
  do
    # 간단한 JSON 파싱 (Phase B에서 proper JSON 라이브러리 사용)
    # \"title\":\"value\" 패턴 찾기
    let key = "\"" + field + "\":\""
    let index = findString(json, key)

    if index < 0
      return None

    let startIndex = index + stringLen(key)
    let endIndex = findStringFrom(json, "\"", startIndex)

    if endIndex < 0
      return None

    let value = subString(json, startIndex, endIndex)
    return Some(value)

