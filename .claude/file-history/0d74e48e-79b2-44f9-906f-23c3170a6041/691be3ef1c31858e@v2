# ============================================================================
# scheduling/scheduler.fl - 작업 스케줄러 (Scheduling)
# ============================================================================
# Cron 표현식 + One-time/Recurring + Timezone
# 작성: 2026-03-02
# 책임: 시간 기반 작업 스케줄링, Cron 파싱

enum ScheduleType
  ONCE = 0
  INTERVAL = 1
  CRON = 2

struct ScheduledTask
  id: string
  name: string
  type: ScheduleType
  handler: function               # () -> Result<void, string>
  scheduleTime: number            # ONCE: 절대시간, INTERVAL: 간격(ms)
  cronExpression: Option<string>  # Cron 표현식
  timezone: string                # UTC, Asia/Seoul 등
  nextRun: number                 # 다음 실행 시간 (밀리초)
  lastRun: number
  isActive: bool
  executedCount: number
  failedCount: number
  lastError: string

struct Scheduler
  id: string
  tasks: array<ScheduledTask>
  isRunning: bool
  stats: SchedulerStats

struct SchedulerStats
  totalTasks: number
  activeTasks: number
  totalExecutions: number
  totalFailures: number
  averageExecutionTime: number

struct CronExpression
  minute: array<number>           # 0-59
  hour: array<number>             # 0-23
  dayOfMonth: array<number>       # 1-31
  month: array<number>            # 1-12
  dayOfWeek: array<number>        # 0-6 (0=Sunday)

fn newScheduler
  input: void
  output: Scheduler
  intent: "스케줄러 생성"
  do
    return {
      id: generateUUID(),
      tasks: [],
      isRunning: false,
      stats: {
        totalTasks: 0,
        activeTasks: 0,
        totalExecutions: 0,
        totalFailures: 0,
        averageExecutionTime: 0
      }
    }

fn startScheduler
  input: scheduler: Scheduler
  output: Result<void, string>
  intent: "스케줄러 시작"
  do
    scheduler.isRunning = true
    print("🚀 Scheduler started")
    return Ok(void)

fn stopScheduler
  input: scheduler: Scheduler
  output: Result<void, string>
  intent: "스케줄러 중지"
  do
    scheduler.isRunning = false
    print("🛑 Scheduler stopped")
    return Ok(void)

# ─────────────────────────────────────────────────────────────────────────
# 작업 스케줄링
# ─────────────────────────────────────────────────────────────────────────

fn scheduleOnce
  input: (scheduler: Scheduler, name: string, time: number, handler: function)
  output: Result<string, string>
  intent: "일회성 작업 스케줄"
  do
    let task = {
      id: generateUUID(),
      name: name,
      type: 0,  # ONCE
      handler: handler,
      scheduleTime: time,
      cronExpression: None,
      timezone: "UTC",
      nextRun: time,
      lastRun: 0,
      isActive: true,
      executedCount: 0,
      failedCount: 0,
      lastError: ""
    }

    scheduler.tasks = arrayPush(scheduler.tasks, task)
    scheduler.stats.totalTasks = scheduler.stats.totalTasks + 1
    scheduler.stats.activeTasks = scheduler.stats.activeTasks + 1

    print("📅 Scheduled once: " + name)
    return Ok(task.id)

fn scheduleInterval
  input: (scheduler: Scheduler, name: string, intervalMs: number, handler: function)
  output: Result<string, string>
  intent: "반복 작업 스케줄 (간격)"
  do
    let task = {
      id: generateUUID(),
      name: name,
      type: 1,  # INTERVAL
      handler: handler,
      scheduleTime: intervalMs,
      cronExpression: None,
      timezone: "UTC",
      nextRun: getCurrentTimestamp() + intervalMs,
      lastRun: 0,
      isActive: true,
      executedCount: 0,
      failedCount: 0,
      lastError: ""
    }

    scheduler.tasks = arrayPush(scheduler.tasks, task)
    scheduler.stats.totalTasks = scheduler.stats.totalTasks + 1
    scheduler.stats.activeTasks = scheduler.stats.activeTasks + 1

    print("⏰ Scheduled interval: " + name + " (every " + str(intervalMs) + "ms)")
    return Ok(task.id)

fn scheduleCron
  input: (scheduler: Scheduler, name: string, cronExpr: string, handler: function)
  output: Result<string, string>
  intent: "반복 작업 스케줄 (Cron)"
  do
    match parseCronExpression(cronExpr)
      Ok(parsed) => {
        let nextRunTime = calculateNextRun(parsed)
        let task = {
          id: generateUUID(),
          name: name,
          type: 2,  # CRON
          handler: handler,
          scheduleTime: 0,
          cronExpression: Some(cronExpr),
          timezone: "UTC",
          nextRun: nextRunTime,
          lastRun: 0,
          isActive: true,
          executedCount: 0,
          failedCount: 0,
          lastError: ""
        }

        scheduler.tasks = arrayPush(scheduler.tasks, task)
        scheduler.stats.totalTasks = scheduler.stats.totalTasks + 1
        scheduler.stats.activeTasks = scheduler.stats.activeTasks + 1

        print("🕐 Scheduled cron: " + name + " (" + cronExpr + ")")
        return Ok(task.id)
      }
      Err(e) => Err("Invalid cron expression: " + e)

