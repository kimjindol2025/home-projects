fn executeTask
  input: (scheduler: Scheduler, task: ScheduledTask)
  output: Result<void, string>
  intent: "스케줄된 작업 실행"
  do
    task.lastRun = getCurrentTimestamp()
    task.executedCount = task.executedCount + 1

    match task.handler()
      Ok(_) => {
        print("✅ Task executed: " + task.name)
        # 다음 실행 시간 계산
        match task.type
          0 => {  # ONCE
            task.isActive = false
          }
          1 => {  # INTERVAL
            task.nextRun = getCurrentTimestamp() + task.scheduleTime
          }
          2 => {  # CRON
            # 다음 Cron 시간 계산
            task.nextRun = calculateNextRun({})
          }
          _ => {}
        return Ok(void)
      }
      Err(error) => {
        task.failedCount = task.failedCount + 1
        task.lastError = error
        print("❌ Task failed: " + task.name + " - " + error)
        return Err(error)
      }

