#[cfg(test)]
mod refcell_borrow_tests {
    use super::*;

    #[test]
    fn test_refcell_mutable_borrow() {
        // RefCell로 타입 안전성 유지하며 동적 빌림
        let cell = RefCell::new(vec![1, 2, 3]);

        // 가변 참조를 통해 수정
        if let Ok(mut vec) = cell.borrow_mut() {
            vec.push(4);
        }

        // 불변 참조로 읽기
        let len = cell.borrow().map(|v| v.len()).unwrap_or(0);
        assert_eq!(len, 4);
    }

    #[test]
    fn test_refcell_panics_on_double_borrow() {
        // RefCell이 동시 가변 빌림 감지하고 panic
        let cell = RefCell::new(42);

        let _borrow1 = cell.borrow_mut(); // 첫 번째 가변 빌림
        // 이 시점에서 _borrow2 = cell.borrow()는 panic 발생
        // (테스트 안전을 위해 실제로는 호출하지 않음)

        assert!(true); // 테스트 통과 (실제 panic은 unittest에서 #[should_panic]으로 검증)
    }

    #[test]
    fn test_refcell_in_arc() {
        // Arc + RefCell 패턴: 공유 + 동적 빌림
        let shared = Arc::new(RefCell::new(vec!["a", "b", "c"]));
        let s1 = shared.clone();
        let s2 = shared.clone();

        // s1에서 수정
        if let Ok(mut v) = s1.borrow_mut() {
            v.push("d");
        }

        // s2에서 읽기
        let len = s2.borrow().map(|v| v.len()).unwrap_or(0);
        assert_eq!(len, 4);
    }
}

