#[derive(Clone)]
pub struct SharedCounter {
    /// Arc + Mutex로 안전하게 공유된 카운터
    count: Arc<Mutex<i64>>,
}

impl SharedCounter {
    pub fn new(initial: i64) -> Self {
        SharedCounter {
            count: Arc::new(Mutex::new(initial)),
        }
    }

    pub fn increment(&self) {
        if let Ok(mut c) = self.count.lock() {
            *c += 1;
        }
    }

    pub fn get(&self) -> i64 {
        self.count.lock().map(|c| *c).unwrap_or(0)
    }
}

