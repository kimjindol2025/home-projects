// Test Suite 2: Channel + ThreadPool 작업 분산
// ============================================================================

#[cfg(test)]
mod channel_threadpool_tests {
    use super::*;

    #[test]
    fn test_channel_message_passing() {
        // Channel로 메시지 전달
        let (tx, rx) = Channel::new();

        // 메시지 3개 전송
        tx.send(10).ok();
        tx.send(20).ok();
        tx.send(30).ok();

        // 메시지 수신 및 합산
        let mut sum = 0;
        while let Ok(msg) = rx.try_recv() {
            sum += msg;
        }

        // 10 + 20 + 30 = 60
        assert_eq!(sum, 60);
    }

    #[test]
    fn test_threadpool_work_distribution() {
        // ThreadPool이 작업을 워커에 분산
        let pool = ThreadPool::new(4);
        let counter = Arc::new(AtomicUsize::new(0));

        // 10개 작업 제출
        for _ in 0..10 {
            let c = counter.clone();
            pool.execute(move || {
                c.fetch_add(1, Ordering::SeqCst);
            });
        }

        // 워커가 모든 작업 처리할 때까지 대기 (간단한 시간 기반 대기)
        std::thread::sleep(std::time::Duration::from_millis(100));

        // 모든 10개 작업이 실행되었는지 확인
        let completed = counter.load(Ordering::SeqCst);
        assert_eq!(completed, 10);
    }

    #[test]
    fn test_channel_threadpool_pipeline() {
        // Channel을 통해 ThreadPool 작업 분배
        let (tx, rx) = Channel::new();
        let pool = ThreadPool::new(4);
        let result = Arc::new(Mutex::new(Vec::new()));

        // 채널에 5개 값 전송
        for i in 1..=5 {
            tx.send(i).ok();
        }

        // 채널의 메시지를 ThreadPool에서 처리
        for _ in 0..5 {
            if let Ok(msg) = rx.try_recv() {
                let res = result.clone();
                pool.execute(move || {
                    if let Ok(mut v) = res.lock() {
                        v.push(msg * 2);
                    }
                });
            }
        }

        std::thread::sleep(std::time::Duration::from_millis(100));

        // 결과 확인: 2, 4, 6, 8, 10 (순서는 보장 안함)
        let final_result = result.lock().map(|v| v.len()).unwrap_or(0);
        assert_eq!(final_result, 5);
    }
}

