#[cfg(test)]
mod race_detector_tests {
    use super::*;

    #[test]
    fn test_atomic_happens_before() {
        // AtomicUsize로 HappensBefore 보장
        let flag = Arc::new(AtomicUsize::new(0));
        let data = Arc::new(Mutex::new(0));

        let f1 = flag.clone();
        let d1 = data.clone();

        // 쓰레드 1: 데이터 쓰기 후 플래그 설정
        std::thread::spawn(move || {
            if let Ok(mut d) = d1.lock() {
                *d = 42;
            }
            f1.store(1, Ordering::Release); // Release 순서 사용
        });

        std::thread::sleep(std::time::Duration::from_millis(10));

        // 메인: 플래그 확인 후 데이터 읽기
        if flag.load(Ordering::Acquire) == 1 {
            // Acquire 순서 사용 - Release와 동기화
            let val = data.lock().map(|d| *d).unwrap_or(0);
            assert_eq!(val, 42); // 42가 보장됨 (HappensBefore)
        }
    }

    #[test]
    fn test_race_detector_pattern() {
        // RaceDetector 패턴: 안전하지 않은 동시 접근 감지
        let detector = RaceDetector::new();
        let counter = Arc::new(AtomicUsize::new(0));

        let c1 = counter.clone();
        let c2 = counter.clone();

        // 두 스레드가 동일한 메모리 위치 접근
        std::thread::spawn(move || {
            c1.fetch_add(1, Ordering::SeqCst);
        });

        std::thread::spawn(move || {
            c2.fetch_add(1, Ordering::SeqCst);
        });

        std::thread::sleep(std::time::Duration::from_millis(10));

        // SeqCst 순서를 사용하면 race 없음
        let final_val = counter.load(Ordering::SeqCst);
        assert!(final_val == 2);
    }

    #[test]
    fn test_sequential_consistency() {
        // SeqCst 순서로 전체 연산 순서 보장
        let a = Arc::new(AtomicUsize::new(0));
        let b = Arc::new(AtomicUsize::new(0));

        let a1 = a.clone();
        let b1 = b.clone();

        std::thread::spawn(move || {
            a1.store(1, Ordering::SeqCst);
            let b_val = b1.load(Ordering::SeqCst);
            assert_ne!(b_val, 2); // 관찰된 순서 일관성
        });

        let a2 = a.clone();
        let b2 = b.clone();

        std::thread::spawn(move || {
            b2.store(2, Ordering::SeqCst);
            let a_val = a2.load(Ordering::SeqCst);
        });

        std::thread::sleep(std::time::Duration::from_millis(10));

        // 전체 연산의 일관된 순서 보장
        assert!(true);
    }
}

