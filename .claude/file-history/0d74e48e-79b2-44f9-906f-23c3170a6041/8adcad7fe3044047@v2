// Test Suite 5: CondVar 생산자-소비자 패턴
// ============================================================================

#[cfg(test)]
mod condvar_tests {
    use super::*;

    #[test]
    fn test_condvar_wait_notify() {
        // CondVar로 스레드 간 신호 전달
        let data = Arc::new(Mutex::new(false));
        let cvar = Arc::new(CondVar::new());

        let d1 = data.clone();
        let c1 = cvar.clone();

        // 생산자 스레드
        std::thread::spawn(move || {
            std::thread::sleep(std::time::Duration::from_millis(10));
            if let Ok(mut flag) = d1.lock() {
                *flag = true;
                c1.notify_one(); // 대기 중인 스레드 깨우기
            }
        });

        // 소비자 (메인)
        let d2 = data.clone();
        let c2 = cvar.clone();

        if let Ok(mut flag) = d2.lock() {
            while !*flag {
                // CondVar::wait (실제 구현)
                c2.wait(&mut flag).ok();
            }
            assert_eq!(*flag, true);
        }
    }

    #[test]
    fn test_condvar_broadcast() {
        // CondVar로 여러 스레드에 신호 전달
        let data = Arc::new(Mutex::new(false));
        let cvar = Arc::new(CondVar::new());

        let d1 = data.clone();
        let c1 = cvar.clone();

        // 생산자
        std::thread::spawn(move || {
            std::thread::sleep(std::time::Duration::from_millis(10));
            if let Ok(mut flag) = d1.lock() {
                *flag = true;
                c1.notify_all(); // 모든 대기 스레드 깨우기
            }
        });

        // 소비자 (모두 동시에 깨어남)
        let d2 = data.clone();
        let c2 = cvar.clone();

        if let Ok(mut flag) = d2.lock() {
            while !*flag {
                c2.wait(&mut flag).ok();
            }
            assert_eq!(*flag, true);
        }
    }
}

