#[cfg(test)]
mod arc_mutex_tests {
    use super::*;

    #[test]
    fn test_arc_mutex_shared_access() {
        // 3개 스레드가 동일한 Mutex를 공유
        let counter = SharedCounter::new(0);
        let c1 = counter.clone();
        let c2 = counter.clone();
        let c3 = counter.clone();

        // 각 스레드에서 10번씩 증가 (총 30 예상)
        for _ in 0..10 {
            c1.increment();
        }
        for _ in 0..10 {
            c2.increment();
        }
        for _ in 0..10 {
            c3.increment();
        }

        assert_eq!(counter.get(), 30);
    }

    #[test]
    fn test_arc_clone_reference_count() {
        // Arc 클론 시 참조 카운트 증가
        let arc_val = Arc::new(Mutex::new(42));
        let clone1 = arc_val.clone();
        let clone2 = arc_val.clone();

        // 3개 Arc 인스턴스가 동일 값 공유
        let original = arc_val.lock().map(|v| *v).unwrap_or(0);
        let c1 = clone1.lock().map(|v| *v).unwrap_or(0);
        let c2 = clone2.lock().map(|v| *v).unwrap_or(0);

        assert_eq!(original, 42);
        assert_eq!(c1, 42);
        assert_eq!(c2, 42);
    }

    #[test]
    fn test_mutex_mutual_exclusion() {
        // Mutex가 동시 접근을 직렬화
        let mutex = Arc::new(Mutex::new(vec![1, 2, 3]));
        let m1 = mutex.clone();
        let m2 = mutex.clone();

        // 두 개의 "동시" 수정이 순서대로 적용되어야 함
        if let Ok(mut vec) = m1.lock() {
            vec.push(4);
        }
        if let Ok(mut vec) = m2.lock() {
            vec.push(5);
        }

        let final_vec = mutex.lock().map(|v| v.clone()).unwrap_or_default();
        assert_eq!(final_vec.len(), 5);
        assert!(final_vec.contains(&4) && final_vec.contains(&5));
    }
}

