#[cfg(test)]
mod complex_integration_tests {
    use super::*;

    #[test]
    fn test_worker_pool_with_shared_state() {
        // ThreadPool + Arc<Mutex<T>>: 스레드 풀이 공유 상태 수정
        let results = Arc::new(Mutex::new(Vec::new()));
        let pool = ThreadPool::new(4);

        // 20개 작업 제출
        for i in 0..20 {
            let res = results.clone();
            pool.execute(move || {
                if let Ok(mut vec) = res.lock() {
                    vec.push(i * i); // 제곱수 저장
                }
            });
        }

        std::thread::sleep(std::time::Duration::from_millis(200));

        let final_results = results.lock().map(|v| v.len()).unwrap_or(0);
        assert_eq!(final_results, 20);
    }

    #[test]
    fn test_channel_with_mutex_payload() {
        // Channel의 페이로드로 Arc<Mutex<T>> 전달
        let (tx, rx) = Channel::new();

        for i in 0..5 {
            let data = Arc::new(Mutex::new(i));
            tx.send(data).ok();
        }

        let mut received = 0;
        while let Ok(arc_mutex) = rx.try_recv() {
            let val = arc_mutex.lock().map(|v| *v).unwrap_or(0);
            received += 1;
        }

        assert_eq!(received, 5);
    }

    #[test]
    fn test_multi_stage_pipeline() {
        // 다단계 파이프라인: Source → ProcessA → ProcessB → Sink
        let (tx_a, rx_a) = Channel::new();
        let (tx_b, rx_b) = Channel::new();
        let sink = Arc::new(Mutex::new(Vec::new()));

        // Stage 1: 1~5 생성
        for i in 1..=5 {
            tx_a.send(i).ok();
        }

        // Stage 2: x2 변환 (별도 스레드)
        let pool = ThreadPool::new(2);
        std::thread::spawn(move || {
            while let Ok(val) = rx_a.try_recv() {
                tx_b.send(val * 2).ok();
            }
        });

        // Stage 3: 결과 수집
        std::thread::sleep(std::time::Duration::from_millis(50));
        while let Ok(val) = rx_b.try_recv() {
            if let Ok(mut vec) = sink.lock() {
                vec.push(val);
            }
        }

        let result_len = sink.lock().map(|v| v.len()).unwrap_or(0);
        assert!(result_len > 0); // 최소 일부 처리됨
    }
}

