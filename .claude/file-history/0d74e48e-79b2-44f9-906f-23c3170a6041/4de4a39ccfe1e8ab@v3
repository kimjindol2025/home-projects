version: '3.8'

services:
  # ============================================================================
  # FreeLang Backend 서비스
  # ============================================================================
  backend:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: freelang-backend
    ports:
      - "8080:8080"    # REST API
      - "50051:50051"  # gRPC
      - "8081:8081"    # gRPC-web
      - "9090:9090"    # Metrics/Health
    environment:
      NODE_ENV: production
      LOG_LEVEL: info
      DATABASE_URL: sqlite:///data/freelang.db
      JWT_SECRET: ${JWT_SECRET:-your-secret-key-change-in-production}
      REDIS_URL: redis://redis:6379
      GRPC_LISTEN_ADDR: 0.0.0.0:50051
      REST_LISTEN_ADDR: 0.0.0.0:8080
    volumes:
      - ./data:/app/data
      - ./logs:/app/logs
    depends_on:
      redis:
        condition: service_healthy
      postgres:
        condition: service_healthy
    restart: unless-stopped
    networks:
      - freelang-network
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8080/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

  # ============================================================================
  # Redis 캐시 서비스
  # ============================================================================
  redis:
    image: redis:7-alpine
    container_name: freelang-redis
    ports:
      - "6379:6379"
    command: >
      redis-server
      --maxmemory 512mb
      --maxmemory-policy allkeys-lru
      --appendonly yes
    volumes:
      - redis-data:/data
    restart: unless-stopped
    networks:
      - freelang-network
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5

  # ============================================================================
  # PostgreSQL 데이터베이스 (선택사항)
  # ============================================================================
  postgres:
    image: postgres:15-alpine
    container_name: freelang-postgres
    environment:
      POSTGRES_DB: freelang
      POSTGRES_USER: freelang_user
      POSTGRES_PASSWORD: ${DB_PASSWORD:-change-me}
      PGDATA: /var/lib/postgresql/data/pgdata
    ports:
      - "5432:5432"
    volumes:
      - postgres-data:/var/lib/postgresql/data
    restart: unless-stopped
    networks:
      - freelang-network
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U freelang_user"]
      interval: 10s
      timeout: 5s
      retries: 5

  # ============================================================================
  # Prometheus 모니터링
  # ============================================================================
  prometheus:
    image: prom/prometheus:latest
    container_name: freelang-prometheus
    ports:
      - "9091:9090"
    volumes:
      - prometheus-data:/prometheus
    command:
      - '--storage.tsdb.path=/prometheus'
    restart: unless-stopped
    networks:
      - freelang-network

  # ============================================================================
  # Grafana 시각화
  # ============================================================================
  grafana:
    image: grafana/grafana:latest
    container_name: freelang-grafana
    ports:
      - "3000:3000"
    environment:
      GF_SECURITY_ADMIN_PASSWORD: ${GRAFANA_PASSWORD:-admin}
      GF_SECURITY_ADMIN_USER: admin
    volumes:
      - grafana-data:/var/lib/grafana
    restart: unless-stopped
    networks:
      - freelang-network
    depends_on:
      - prometheus

  # ============================================================================
  # Nginx 리버스 프록시
  # ============================================================================
  nginx:
    image: nginx:alpine
    container_name: freelang-nginx
    ports:
      - "80:80"
      - "443:443"
    depends_on:
      - backend
    restart: unless-stopped
    networks:
      - freelang-network

volumes:
  redis-data:
    driver: local
  postgres-data:
    driver: local
  prometheus-data:
    driver: local
  grafana-data:
    driver: local

networks:
  freelang-network:
    driver: bridge
