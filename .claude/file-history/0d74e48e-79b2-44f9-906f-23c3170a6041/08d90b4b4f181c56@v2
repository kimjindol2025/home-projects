/// 배열을 문자열로 연결합니다.
///
/// # 예제
/// ```
/// let arr = vec![FlValue::Int(1), FlValue::Int(2), FlValue::Int(3)];
/// assert_eq!(array_join(arr, ","), "1,2,3");
/// ```
pub fn array_join(arr: FlValue, delim: String) -> String {
    match arr {
        FlValue::Array(elements) => {
            let strings: Vec<String> = elements.iter()
                .map(|elem| elem.to_string_repr())
                .collect();
            strings.join(&delim)
        }
        _ => String::new(),
    }
}

/// 두 배열을 연결합니다.
///
/// # 예제
/// ```
/// let arr1 = vec![FlValue::Int(1), FlValue::Int(2)];
/// let arr2 = vec![FlValue::Int(3), FlValue::Int(4)];
/// let result = array_concat(arr1, arr2);
/// ```
pub fn array_concat(arr1: FlValue, arr2: FlValue) -> Result<FlValue, ArrayError> {
    match (arr1, arr2) {
        (FlValue::Array(mut elements1), FlValue::Array(elements2)) => {
            elements1.extend(elements2);
            Ok(FlValue::Array(elements1))
        }
        _ => Err(ArrayError::TypeMismatch("Expected arrays".to_string())),
    }
}

