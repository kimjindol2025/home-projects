#[cfg(test)]
mod tests {
    use super::*;

    fn make_int_array(nums: Vec<i64>) -> FlValue {
        FlValue::Array(nums.into_iter().map(FlValue::Int).collect())
    }

    #[test]
    fn test_array_length() {
        let arr = make_int_array(vec![1, 2, 3]);
        assert_eq!(array_length(arr).unwrap(), 3);
    }

    #[test]
    fn test_array_length_empty() {
        let arr = FlValue::Array(vec![]);
        assert_eq!(array_length(arr).unwrap(), 0);
    }

    #[test]
    fn test_get_valid() {
        let arr = make_int_array(vec![10, 20, 30]);
        assert_eq!(get(arr, 1).unwrap(), FlValue::Int(20));
    }

    #[test]
    fn test_get_out_of_bounds() {
        let arr = make_int_array(vec![10, 20]);
        assert!(get(arr, 10).is_err());
    }

    #[test]
    fn test_slice() {
        let arr = make_int_array(vec![1, 2, 3, 4, 5]);
        let result = slice(arr, 1, 3).unwrap();
        match result {
            FlValue::Array(elements) => assert_eq!(elements.len(), 3),
            _ => panic!("Expected array"),
        }
    }

    #[test]
    fn test_sort_integers() {
        let arr = make_int_array(vec![3, 1, 4, 1, 5]);
        let result = sort(arr).unwrap();
        match result {
            FlValue::Array(elements) => {
                assert_eq!(elements[0], FlValue::Int(1));
                assert_eq!(elements[4], FlValue::Int(5));
            }
            _ => panic!("Expected array"),
        }
    }

    #[test]
    fn test_array_reverse() {
        let arr = make_int_array(vec![1, 2, 3]);
        let result = array_reverse(arr).unwrap();
        match result {
            FlValue::Array(elements) => {
                assert_eq!(elements[0], FlValue::Int(3));
                assert_eq!(elements[2], FlValue::Int(1));
            }
            _ => panic!("Expected array"),
        }
    }

    #[test]
    fn test_map() {
        let arr = make_int_array(vec![1, 2, 3]);
        let result = map(arr, |x| {
            match x {
                FlValue::Int(n) => FlValue::Int(n * 2),
                _ => x,
            }
        }).unwrap();

        match result {
            FlValue::Array(elements) => {
                assert_eq!(elements[0], FlValue::Int(2));
                assert_eq!(elements[2], FlValue::Int(6));
            }
            _ => panic!("Expected array"),
        }
    }

    #[test]
    fn test_filter() {
        let arr = make_int_array(vec![1, 2, 3, 4, 5]);
        let result = filter(arr, |x| {
            match x {
                FlValue::Int(n) => n > &2,
                _ => false,
            }
        }).unwrap();

        match result {
            FlValue::Array(elements) => assert_eq!(elements.len(), 3),
            _ => panic!("Expected array"),
        }
    }

    #[test]
    fn test_reduce_sum() {
        let arr = make_int_array(vec![1, 2, 3, 4]);
        let result = reduce(arr, |acc, x| {
            match (acc, x) {
                (FlValue::Int(a), FlValue::Int(b)) => FlValue::Int(a + b),
                _ => acc,
            }
        }, FlValue::Int(0)).unwrap();

        assert_eq!(result, FlValue::Int(10));
    }

    #[test]
    fn test_array_contains_true() {
        let arr = make_int_array(vec![1, 2, 3]);
        assert_eq!(array_contains(arr, FlValue::Int(2)), true);
    }

    #[test]
    fn test_array_contains_false() {
        let arr = make_int_array(vec![1, 2, 3]);
        assert_eq!(array_contains(arr, FlValue::Int(99)), false);
    }

    #[test]
    fn test_array_index_of_found() {
        let arr = make_int_array(vec![10, 20, 30]);
        assert_eq!(array_index_of(arr, FlValue::Int(20)), 1);
    }

    #[test]
    fn test_array_index_of_not_found() {
        let arr = make_int_array(vec![10, 20, 30]);
        assert_eq!(array_index_of(arr, FlValue::Int(99)), -1);
    }

    #[test]
    fn test_flat() {
        let arr = FlValue::Array(vec![
            FlValue::Array(vec![FlValue::Int(1), FlValue::Int(2)]),
            FlValue::Array(vec![FlValue::Int(3), FlValue::Int(4)]),
        ]);
        let result = flat(arr).unwrap();
        match result {
            FlValue::Array(elements) => assert_eq!(elements.len(), 4),
            _ => panic!("Expected array"),
        }
    }

    #[test]
    fn test_unique() {
        let arr = make_int_array(vec![1, 2, 1, 3, 2]);
        let result = unique(arr).unwrap();
        match result {
            FlValue::Array(elements) => {
                // unique는 HashSet 기반이라 순서는 보장 안 함
                assert!(elements.len() <= 3);
                assert!(elements.len() > 0);
            }
            _ => panic!("Expected array"),
        }
    }

    #[test]
    fn test_zip() {
        let arr1 = make_int_array(vec![1, 2]);
        let arr2 = FlValue::Array(vec![
            FlValue::Str("a".to_string()),
            FlValue::Str("b".to_string()),
        ]);
        let result = zip(arr1, arr2).unwrap();
        match result {
            FlValue::Array(pairs) => assert_eq!(pairs.len(), 2),
            _ => panic!("Expected array"),
        }
    }

    #[test]
    fn test_array_join() {
        let arr = make_int_array(vec![1, 2, 3]);
        assert_eq!(array_join(arr, ",".to_string()), "1,2,3");
    }

    #[test]
    fn test_array_concat() {
        let arr1 = make_int_array(vec![1, 2]);
        let arr2 = make_int_array(vec![3, 4]);
        let result = array_concat(arr1, arr2).unwrap();
        match result {
            FlValue::Array(elements) => assert_eq!(elements.len(), 4),
            _ => panic!("Expected array"),
        }
    }
}

