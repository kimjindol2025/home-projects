// ============================================================================
// ArrayError - 배열 처리 에러 타입
// ============================================================================

/// 배열 처리 시 발생할 수 있는 에러
#[derive(Clone, Debug, PartialEq)]
pub enum ArrayError {
    /// 인덱스 범위 초과
    IndexOutOfBounds { index: i64, len: i64 },

    /// 빈 배열에서 pop 시도
    EmptyArray,

    /// 타입 불일치
    TypeMismatch(String),
}

impl std::fmt::Display for ArrayError {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            ArrayError::IndexOutOfBounds { index, len } => {
                write!(f, "Index {} out of bounds (length {})", index, len)
            }
            ArrayError::EmptyArray => write!(f, "Cannot pop from empty array"),
            ArrayError::TypeMismatch(msg) => write!(f, "Type mismatch: {}", msg),
        }
    }
}

// ============================================================================
// Basic Array Functions (CRUD)
// ============================================================================

/// 배열의 길이를 반환합니다.
///
/// # 예제
/// ```
/// let arr = FlValue::Array(vec![FlValue::Int(1), FlValue::Int(2)]);
/// assert_eq!(array_length(arr), 2);
/// ```
pub fn array_length(arr: FlValue) -> Result<i64, ArrayError> {
    match arr {
        FlValue::Array(elements) => Ok(elements.len() as i64),
        _ => Err(ArrayError::TypeMismatch("Expected array".to_string())),
    }
}

/// 배열에 요소를 추가합니다 (뒤에 추가).
///
/// # 예제
/// ```
/// let mut arr = vec![FlValue::Int(1), FlValue::Int(2)];
/// push(&mut arr, FlValue::Int(3));
/// assert_eq!(arr.len(), 3);
/// ```
pub fn push(arr: &mut Vec<FlValue>, item: FlValue) {
    arr.push(item);
}

/// 배열의 마지막 요소를 제거하고 반환합니다.
///
/// # 에러
/// - 빈 배열: ArrayError::EmptyArray
///
/// # 예제
/// ```
/// let mut arr = vec![FlValue::Int(1), FlValue::Int(2)];
/// assert_eq!(pop(&mut arr).unwrap(), FlValue::Int(2));
/// ```
pub fn pop(arr: &mut Vec<FlValue>) -> Result<FlValue, ArrayError> {
    arr.pop().ok_or(ArrayError::EmptyArray)
}

/// 배열의 특정 인덱스에 있는 요소를 반환합니다.
///
/// # 에러
/// - 범위 초과: ArrayError::IndexOutOfBounds
///
/// # 예제
/// ```
/// let arr = vec![FlValue::Int(10), FlValue::Int(20), FlValue::Int(30)];
/// assert_eq!(get(arr, 1).unwrap(), FlValue::Int(20));
/// ```
pub fn get(arr: FlValue, index: i64) -> Result<FlValue, ArrayError> {
    match arr {
        FlValue::Array(elements) => {
            if index < 0 || index >= elements.len() as i64 {
                return Err(ArrayError::IndexOutOfBounds {
                    index,
                    len: elements.len() as i64,
                });
            }
            Ok(elements[index as usize].clone())
        }
        _ => Err(ArrayError::TypeMismatch("Expected array".to_string())),
    }
}

/// 배열의 특정 인덱스의 요소를 설정합니다.
///
/// # 에러
/// - 범위 초과: ArrayError::IndexOutOfBounds
///
/// # 예제
/// ```
/// let mut arr = vec![FlValue::Int(1), FlValue::Int(2)];
/// set(&mut arr, 0, FlValue::Int(10)).unwrap();
/// ```
pub fn set(arr: &mut Vec<FlValue>, index: i64, value: FlValue) -> Result<(), ArrayError> {
    if index < 0 || index >= arr.len() as i64 {
        return Err(ArrayError::IndexOutOfBounds {
            index,
            len: arr.len() as i64,
        });
    }
    arr[index as usize] = value;
    Ok(())
}

