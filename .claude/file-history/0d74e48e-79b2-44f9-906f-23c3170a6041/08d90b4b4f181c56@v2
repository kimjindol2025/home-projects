/// 배열의 각 요소에 함수를 적용하여 새 배열을 반환합니다.
///
/// # 매개변수
/// - arr: 배열
/// - f: 각 요소에 적용할 함수 (FlValue -> FlValue)
///
/// # 예제
/// ```
/// let arr = vec![FlValue::Int(1), FlValue::Int(2), FlValue::Int(3)];
/// let result = map(FlValue::Array(arr), |x| {
///     match x {
///         FlValue::Int(n) => FlValue::Int(n * 2),
///         _ => x,
///     }
/// }).unwrap();
/// ```
pub fn map<F>(arr: FlValue, f: F) -> Result<FlValue, ArrayError>
where
    F: Fn(FlValue) -> FlValue,
{
    match arr {
        FlValue::Array(elements) => {
            let mapped: Vec<FlValue> = elements.iter()
                .map(|elem| f(elem.clone()))
                .collect();
            Ok(FlValue::Array(mapped))
        }
        _ => Err(ArrayError::TypeMismatch("Expected array".to_string())),
    }
}

/// 조건을 만족하는 요소들만 필터링하여 새 배열을 반환합니다.
///
/// # 매개변수
/// - arr: 배열
/// - f: 각 요소를 평가할 함수 (FlValue -> bool)
///
/// # 예제
/// ```
/// let arr = vec![FlValue::Int(1), FlValue::Int(2), FlValue::Int(3)];
/// let result = filter(FlValue::Array(arr), |x| {
///     match x {
///         FlValue::Int(n) => n > 1,
///         _ => false,
///     }
/// }).unwrap();
/// ```
pub fn filter<F>(arr: FlValue, f: F) -> Result<FlValue, ArrayError>
where
    F: Fn(&FlValue) -> bool,
{
    match arr {
        FlValue::Array(elements) => {
            let filtered: Vec<FlValue> = elements.iter()
                .filter(|elem| f(elem))
                .cloned()
                .collect();
            Ok(FlValue::Array(filtered))
        }
        _ => Err(ArrayError::TypeMismatch("Expected array".to_string())),
    }
}

/// 배열의 요소들을 순회하면서 축적(reduce)합니다.
///
/// # 매개변수
/// - arr: 배열
/// - f: 축적 함수 ((accumulator, current) -> new_accumulator)
/// - init: 초기값
///
/// # 예제
/// ```
/// let arr = vec![FlValue::Int(1), FlValue::Int(2), FlValue::Int(3)];
/// let result = reduce(FlValue::Array(arr), |acc, x| {
///     match (acc, x) {
///         (FlValue::Int(a), FlValue::Int(b)) => FlValue::Int(a + b),
///         _ => acc,
///     }
/// }, FlValue::Int(0)).unwrap();
/// assert_eq!(result, FlValue::Int(6));
/// ```
pub fn reduce<F>(arr: FlValue, f: F, init: FlValue) -> Result<FlValue, ArrayError>
where
    F: Fn(FlValue, FlValue) -> FlValue,
{
    match arr {
        FlValue::Array(elements) => {
            let result = elements.iter()
                .fold(init, |acc, elem| f(acc, elem.clone()));
            Ok(result)
        }
        _ => Err(ArrayError::TypeMismatch("Expected array".to_string())),
    }
}

