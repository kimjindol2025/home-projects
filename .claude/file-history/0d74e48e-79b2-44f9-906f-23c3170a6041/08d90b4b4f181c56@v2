/// 배열의 부분 배열을 추출합니다.
///
/// # 매개변수
/// - start: 시작 인덱스 (포함)
/// - end: 종료 인덱스 (포함)
///
/// # 에러
/// - 범위 초과: ArrayError::IndexOutOfBounds
///
/// # 예제
/// ```
/// let arr = vec![1, 2, 3, 4, 5];
/// assert_eq!(slice(arr, 1, 3), vec![2, 3, 4]);
/// ```
pub fn slice(arr: FlValue, start: i64, end: i64) -> Result<FlValue, ArrayError> {
    match arr {
        FlValue::Array(elements) => {
            let len = elements.len() as i64;
            if start < 0 || end < 0 || start > len || end > len || start > end {
                return Err(ArrayError::IndexOutOfBounds {
                    index: if start < 0 || start > len { start } else { end },
                    len,
                });
            }

            let sliced: Vec<FlValue> = elements.iter()
                .skip(start as usize)
                .take((end - start + 1) as usize)
                .cloned()
                .collect();

            Ok(FlValue::Array(sliced))
        }
        _ => Err(ArrayError::TypeMismatch("Expected array".to_string())),
    }
}

/// 배열을 정렬합니다 (숫자는 오름차순, 문자열은 사전순).
///
/// # 주의
/// - 다른 타입이 섞여 있으면 정렬 순서는 정의되지 않음
///
/// # 예제
/// ```
/// let arr = vec![FlValue::Int(3), FlValue::Int(1), FlValue::Int(2)];
/// assert_eq!(sort(arr).unwrap()[0], FlValue::Int(1));
/// ```
pub fn sort(arr: FlValue) -> Result<FlValue, ArrayError> {
    match arr {
        FlValue::Array(mut elements) => {
            elements.sort_by(|a, b| {
                match (a, b) {
                    (FlValue::Int(x), FlValue::Int(y)) => x.cmp(y),
                    (FlValue::Float(x), FlValue::Float(y)) => {
                        x.partial_cmp(y).unwrap_or(std::cmp::Ordering::Equal)
                    }
                    (FlValue::Str(x), FlValue::Str(y)) => x.cmp(y),
                    (FlValue::Bool(x), FlValue::Bool(y)) => x.cmp(y),
                    _ => std::cmp::Ordering::Equal,
                }
            });
            Ok(FlValue::Array(elements))
        }
        _ => Err(ArrayError::TypeMismatch("Expected array".to_string())),
    }
}

/// 배열의 요소들을 역순으로 정렬합니다.
///
/// # 예제
/// ```
/// let arr = vec![FlValue::Int(1), FlValue::Int(2), FlValue::Int(3)];
/// assert_eq!(array_reverse(arr).unwrap()[0], FlValue::Int(3));
/// ```
pub fn array_reverse(arr: FlValue) -> Result<FlValue, ArrayError> {
    match arr {
        FlValue::Array(mut elements) => {
            elements.reverse();
            Ok(FlValue::Array(elements))
        }
        _ => Err(ArrayError::TypeMismatch("Expected array".to_string())),
    }
}

