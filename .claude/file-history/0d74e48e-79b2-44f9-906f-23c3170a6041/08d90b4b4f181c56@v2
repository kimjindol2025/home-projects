/// 중첩 배열을 한 단계 펼칩니다.
///
/// # 예제
/// ```
/// let arr = vec![
///     FlValue::Array(vec![FlValue::Int(1), FlValue::Int(2)]),
///     FlValue::Array(vec![FlValue::Int(3), FlValue::Int(4)]),
/// ];
/// assert_eq!(flat(FlValue::Array(arr)).unwrap().len(), 4);
/// ```
pub fn flat(arr: FlValue) -> Result<FlValue, ArrayError> {
    match arr {
        FlValue::Array(elements) => {
            let mut flattened = Vec::new();
            for elem in elements {
                match elem {
                    FlValue::Array(inner) => {
                        flattened.extend(inner);
                    }
                    other => {
                        flattened.push(other);
                    }
                }
            }
            Ok(FlValue::Array(flattened))
        }
        _ => Err(ArrayError::TypeMismatch("Expected array".to_string())),
    }
}

/// 배열의 중복 요소를 제거합니다.
///
/// # 주의
/// - 순서는 보장되지 않음 (HashSet 기반)
///
/// # 예제
/// ```
/// let arr = vec![FlValue::Int(1), FlValue::Int(2), FlValue::Int(1), FlValue::Int(3)];
/// let result = unique(FlValue::Array(arr)).unwrap();
/// ```
pub fn unique(arr: FlValue) -> Result<FlValue, ArrayError> {
    match arr {
        FlValue::Array(elements) => {
            let mut seen = std::collections::HashSet::new();
            let mut unique_vec = Vec::new();

            for elem in elements {
                let key = elem.to_string_repr();
                if seen.insert(key) {
                    unique_vec.push(elem);
                }
            }

            Ok(FlValue::Array(unique_vec))
        }
        _ => Err(ArrayError::TypeMismatch("Expected array".to_string())),
    }
}

/// 두 배열의 요소를 쌍으로 묶습니다.
///
/// # 반환값
/// - 더 짧은 배열의 길이만큼 쌍을 생성
///
/// # 예제
/// ```
/// let arr1 = vec![FlValue::Int(1), FlValue::Int(2)];
/// let arr2 = vec![FlValue::Str("a".to_string()), FlValue::Str("b".to_string())];
/// let result = zip(FlValue::Array(arr1), FlValue::Array(arr2)).unwrap();
/// ```
pub fn zip(arr1: FlValue, arr2: FlValue) -> Result<FlValue, ArrayError> {
    match (arr1, arr2) {
        (FlValue::Array(elements1), FlValue::Array(elements2)) => {
            let min_len = elements1.len().min(elements2.len());
            let mut pairs = Vec::new();

            for i in 0..min_len {
                let pair = FlValue::Array(vec![
                    elements1[i].clone(),
                    elements2[i].clone(),
                ]);
                pairs.push(pair);
            }

            Ok(FlValue::Array(pairs))
        }
        _ => Err(ArrayError::TypeMismatch("Expected arrays".to_string())),
    }
}

