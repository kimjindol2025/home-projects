/// 배열이 특정 요소를 포함하는지 확인합니다.
///
/// # 예제
/// ```
/// let arr = vec![FlValue::Int(1), FlValue::Int(2), FlValue::Int(3)];
/// assert_eq!(array_contains(arr, FlValue::Int(2)), true);
/// assert_eq!(array_contains(arr, FlValue::Int(5)), false);
/// ```
pub fn array_contains(arr: FlValue, item: FlValue) -> bool {
    match arr {
        FlValue::Array(elements) => elements.iter().any(|elem| elem == &item),
        _ => false,
    }
}

/// 배열에서 요소의 인덱스를 반환합니다.
///
/// # 반환값
/// - 찾으면: 인덱스 (0부터 시작)
/// - 못 찾으면: -1
///
/// # 예제
/// ```
/// let arr = vec![FlValue::Int(10), FlValue::Int(20), FlValue::Int(30)];
/// assert_eq!(array_index_of(arr, FlValue::Int(20)), 1);
/// assert_eq!(array_index_of(arr, FlValue::Int(99)), -1);
/// ```
pub fn array_index_of(arr: FlValue, item: FlValue) -> i64 {
    match arr {
        FlValue::Array(elements) => {
            for (i, elem) in elements.iter().enumerate() {
                if elem == &item {
                    return i as i64;
                }
            }
            -1
        }
        _ => -1,
    }
}

