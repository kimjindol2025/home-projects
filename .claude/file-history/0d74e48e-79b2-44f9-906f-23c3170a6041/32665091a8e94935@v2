# ─────────────────────────────────────────────────────────────────────────
# 경로 추출 함수
# ─────────────────────────────────────────────────────────────────────────

fn extractIdFromPath
  input: path: string
  output: Option<number>
  intent: "URL 경로에서 ID 추출 (e.g. /todos/123 → 123)"
  do
    # 간단한 구현: 마지막 부분이 숫자인지 확인
    let parts = splitPath(path)

    if parts.len() < 3
      return None

    let lastPart = parts[parts.len() - 1]
    return stringToNumber(lastPart)

fn splitPath
  input: path: string
  output: array<string>
  intent: "경로를 '/'로 분할"
  do
    # 간단한 구현
    # ""/todos/123" → ["", "todos", "123"]
    let result = []
    let current = ""

    for i in 0..path.len()
      let char = getChar(path, i)
      if char == "/"
        result.push(current)
        current = ""
      else
        current = current + char

    if current != ""
      result.push(current)

    return result

fn getChar
  input: (str: string, index: number)
  output: string
  intent: "문자열의 특정 위치 문자 반환"
