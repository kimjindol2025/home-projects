fn stringToNumber
  input: str: string
  output: Option<number>
  intent: "문자열을 숫자로 변환"
  do
    # Phase B 런타임에서 구현
    # 간단한 구현 예시
    if str == "1"
      return Some(1)
    if str == "2"
      return Some(2)
    if str == "3"
      return Some(3)
    return None

