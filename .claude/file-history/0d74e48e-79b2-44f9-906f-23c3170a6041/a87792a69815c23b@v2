use crate::sync::ordering::Ordering;
use std::sync::atomic::{AtomicUsize, AtomicBool, AtomicPtr};
use std::sync::atomic::Ordering as StdOrdering;

// ============================================================================
// AtomicUsize - 원자적 부호 없는 정수
// ============================================================================

/// AtomicUsize: 원자적으로 접근 가능한 usize 값
///
/// 여러 스레드에서 동시에 접근해도 안전합니다.
pub struct AtomicUsize {
    // 내부 구현: Rust의 std::sync::atomic::AtomicUsize 사용
    // (실제 구현에서는 LLVM IR의 atomic operation 사용)
    inner: AtomicUsize,
}

impl AtomicUsize {
    /// 새로운 AtomicUsize를 생성합니다.
    ///
    /// # 예제
    /// ```
    /// let counter = AtomicUsize::new(0);
    /// ```
    pub fn new(value: usize) -> AtomicUsize {
        AtomicUsize {
            inner: AtomicUsize::new(value),
        }
    }

    /// 현재 값을 읽습니다.
    ///
    /// 지정된 메모리 순서를 준수합니다.
    ///
    /// # 예제
    /// ```
    /// let counter = AtomicUsize::new(42);
    /// assert_eq!(counter.load(Ordering::SeqCst), 42);
    /// ```
    pub fn load(&self, order: Ordering) -> usize {
        let std_order = convert_ordering(order);
        self.inner.load(std_order)
    }

    /// 값을 쓰고 반환하지 않습니다.
    ///
    /// 지정된 메모리 순서를 준수합니다.
    ///
    /// # 예제
    /// ```
    /// let counter = AtomicUsize::new(0);
    /// counter.store(42, Ordering::SeqCst);
    /// assert_eq!(counter.load(Ordering::SeqCst), 42);
    /// ```
    pub fn store(&self, value: usize, order: Ordering) {
        let std_order = convert_ordering(order);
        self.inner.store(value, std_order)
    }

    /// 값을 더하고 이전 값을 반환합니다.
    ///
    /// # 예제
    /// ```
    /// let counter = AtomicUsize::new(0);
    /// let old = counter.fetch_add(1, Ordering::SeqCst);
    /// assert_eq!(old, 0);
    /// assert_eq!(counter.load(Ordering::SeqCst), 1);
    /// ```
    pub fn fetch_add(&self, delta: usize, order: Ordering) -> usize {
        let std_order = convert_ordering(order);
        self.inner.fetch_add(delta, std_order)
    }

    /// 값을 빼고 이전 값을 반환합니다.
    ///
    /// # 예제
    /// ```
    /// let counter = AtomicUsize::new(10);
    /// let old = counter.fetch_sub(1, Ordering::SeqCst);
    /// assert_eq!(old, 10);
    /// assert_eq!(counter.load(Ordering::SeqCst), 9);
    /// ```
    pub fn fetch_sub(&self, delta: usize, order: Ordering) -> usize {
        let std_order = convert_ordering(order);
        self.inner.fetch_sub(delta, std_order)
    }

    /// Compare-and-swap: 값이 expected이면 new로 바꾸고, 이전 값을 반환합니다.
    ///
    /// 이 연산은 lock-free 업데이트의 기초입니다.
    ///
    /// # 예제
    /// ```
    /// let counter = AtomicUsize::new(0);
    ///
    /// // 성공
    /// let old = counter.compare_and_swap(0, 1, Ordering::SeqCst);
    /// assert_eq!(old, 0);
    /// assert_eq!(counter.load(Ordering::SeqCst), 1);
    ///
    /// // 실패
    /// let old = counter.compare_and_swap(0, 2, Ordering::SeqCst);
    /// assert_eq!(old, 1);  // 변경 안 됨
    /// assert_eq!(counter.load(Ordering::SeqCst), 1);
    /// ```
    pub fn compare_and_swap(&self, expected: usize, new: usize, order: Ordering) -> usize {
        let std_order = convert_ordering(order);
        self.inner.compare_and_swap(expected, new, std_order)
    }

    /// 원자적으로 값을 읽고 수정합니다.
    ///
    /// # 예제
    /// ```
    /// let counter = AtomicUsize::new(5);
    /// counter.fetch_update(Ordering::SeqCst, |x| Some(x * 2));
    /// assert_eq!(counter.load(Ordering::SeqCst), 10);
    /// ```
    pub fn fetch_update<F>(&self, order: Ordering, f: F) -> Result<usize, usize>
    where
        F: Fn(usize) -> Option<usize>,
    {
        let std_order = convert_ordering(order);
        self.inner.compare_exchange_weak(
            self.load(order),
            {
                let current = self.load(order);
                f(current).unwrap_or(current)
            },
            std_order,
            std_order,
        )
    }
}

// ============================================================================
// AtomicBool - 원자적 불린 값
// ============================================================================

/// AtomicBool: 원자적으로 접근 가능한 bool 값
pub struct AtomicBool {
    // 내부 구현: Rust의 std::sync::atomic::AtomicBool 사용
    inner: AtomicBool,
}

impl AtomicBool {
    /// 새로운 AtomicBool을 생성합니다.
    pub fn new(value: bool) -> AtomicBool {
        AtomicBool {
            inner: AtomicBool::new(value),
        }
    }

    /// 현재 값을 읽습니다.
    pub fn load(&self, order: Ordering) -> bool {
        let std_order = convert_ordering(order);
        self.inner.load(std_order)
    }

    /// 값을 씁니다.
    pub fn store(&self, value: bool, order: Ordering) {
        let std_order = convert_ordering(order);
        self.inner.store(value, std_order)
    }

    /// 값을 반전시키고 이전 값을 반환합니다.
    ///
    /// # 예제
    /// ```
    /// let flag = AtomicBool::new(false);
    /// assert_eq!(flag.fetch_not(Ordering::SeqCst), false);
    /// assert_eq!(flag.load(Ordering::SeqCst), true);
    /// ```
    pub fn fetch_not(&self, order: Ordering) -> bool {
        let std_order = convert_ordering(order);
        self.inner.fetch_nand(true, std_order)
    }

    /// Compare-and-swap: 값이 expected이면 new로 바꿉니다.
    pub fn compare_and_swap(&self, expected: bool, new: bool, order: Ordering) -> bool {
        let std_order = convert_ordering(order);
        self.inner.compare_and_swap(expected, new, std_order)
    }
}

// ============================================================================
// AtomicPtr - 원자적 포인터
// ============================================================================

/// AtomicPtr<T>: 원자적으로 접근 가능한 포인터
pub struct AtomicPtr<T> {
    // 내부 구현: T의 포인터를 원자적으로 저장
    inner: AtomicPtr<T>,
}

impl<T> AtomicPtr<T> {
    /// 새로운 AtomicPtr을 생성합니다.
    pub fn new(ptr: *mut T) -> AtomicPtr<T> {
        AtomicPtr {
            inner: AtomicPtr::new(ptr),
        }
    }

    /// 현재 포인터를 읽습니다.
    pub fn load(&self, order: Ordering) -> *mut T {
        let std_order = convert_ordering(order);
        self.inner.load(std_order)
    }

    /// 포인터를 씁니다.
    pub fn store(&self, ptr: *mut T, order: Ordering) {
        let std_order = convert_ordering(order);
        self.inner.store(ptr, std_order)
    }

    /// Compare-and-swap: 포인터를 원자적으로 업데이트합니다.
    pub fn compare_and_swap(&self, expected: *mut T, new: *mut T, order: Ordering) -> *mut T {
        let std_order = convert_ordering(order);
        self.inner.compare_and_swap(expected, new, std_order)
    }
}

// ============================================================================
// Ordering 변환 헬퍼
// ============================================================================

/// FreeLang의 Ordering을 Rust 표준 라이브러리의 Ordering으로 변환합니다.
fn convert_ordering(order: Ordering) -> StdOrdering {
    match order {
        Ordering::Relaxed => StdOrdering::Relaxed,
        Ordering::Release => StdOrdering::Release,
        Ordering::Acquire => StdOrdering::Acquire,
        Ordering::AcqRel => StdOrdering::AcqRel,
        Ordering::SeqCst => StdOrdering::SeqCst,
    }
}

