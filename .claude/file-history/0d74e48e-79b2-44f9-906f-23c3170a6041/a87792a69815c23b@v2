#[cfg(test)]
mod tests {
    use super::*;

    // ========== AtomicUsize 테스트 ==========

    #[test]
    fn test_atomic_usize_new() {
        let counter = AtomicUsize::new(42);
        assert_eq!(counter.load(Ordering::SeqCst), 42);
    }

    #[test]
    fn test_atomic_usize_load_store() {
        let counter = AtomicUsize::new(0);

        counter.store(100, Ordering::SeqCst);
        assert_eq!(counter.load(Ordering::SeqCst), 100);

        counter.store(200, Ordering::SeqCst);
        assert_eq!(counter.load(Ordering::SeqCst), 200);
    }

    #[test]
    fn test_atomic_usize_fetch_add() {
        let counter = AtomicUsize::new(0);

        let old1 = counter.fetch_add(1, Ordering::SeqCst);
        assert_eq!(old1, 0);
        assert_eq!(counter.load(Ordering::SeqCst), 1);

        let old2 = counter.fetch_add(5, Ordering::SeqCst);
        assert_eq!(old2, 1);
        assert_eq!(counter.load(Ordering::SeqCst), 6);
    }

    #[test]
    fn test_atomic_usize_fetch_sub() {
        let counter = AtomicUsize::new(10);

        let old1 = counter.fetch_sub(1, Ordering::SeqCst);
        assert_eq!(old1, 10);
        assert_eq!(counter.load(Ordering::SeqCst), 9);

        let old2 = counter.fetch_sub(3, Ordering::SeqCst);
        assert_eq!(old2, 9);
        assert_eq!(counter.load(Ordering::SeqCst), 6);
    }

    #[test]
    fn test_atomic_usize_compare_and_swap_success() {
        let counter = AtomicUsize::new(0);

        // 성공: 0 → 1
        let old = counter.compare_and_swap(0, 1, Ordering::SeqCst);
        assert_eq!(old, 0);
        assert_eq!(counter.load(Ordering::SeqCst), 1);

        // 성공: 1 → 2
        let old = counter.compare_and_swap(1, 2, Ordering::SeqCst);
        assert_eq!(old, 1);
        assert_eq!(counter.load(Ordering::SeqCst), 2);
    }

    #[test]
    fn test_atomic_usize_compare_and_swap_failure() {
        let counter = AtomicUsize::new(0);

        // 실패: expected가 맞지 않음
        let old = counter.compare_and_swap(1, 2, Ordering::SeqCst);
        assert_eq!(old, 0);  // 변경 안 됨
        assert_eq!(counter.load(Ordering::SeqCst), 0);
    }

    #[test]
    fn test_atomic_usize_relaxed_ordering() {
        let counter = AtomicUsize::new(0);

        // Relaxed: 순서 보장 없음
        counter.store(42, Ordering::Relaxed);
        let value = counter.load(Ordering::Relaxed);
        assert_eq!(value, 42);
    }

    #[test]
    fn test_atomic_usize_sequential_operations() {
        let counter = AtomicUsize::new(0);

        // 순차적 연산
        counter.fetch_add(5, Ordering::SeqCst);
        counter.fetch_add(3, Ordering::SeqCst);
        counter.fetch_sub(2, Ordering::SeqCst);

        assert_eq!(counter.load(Ordering::SeqCst), 6);
    }

    // ========== AtomicBool 테스트 ==========

    #[test]
    fn test_atomic_bool_new() {
        let flag = AtomicBool::new(true);
        assert!(flag.load(Ordering::SeqCst));
    }

    #[test]
    fn test_atomic_bool_load_store() {
        let flag = AtomicBool::new(false);

        flag.store(true, Ordering::SeqCst);
        assert!(flag.load(Ordering::SeqCst));

        flag.store(false, Ordering::SeqCst);
        assert!(!flag.load(Ordering::SeqCst));
    }

    #[test]
    fn test_atomic_bool_compare_and_swap_success() {
        let flag = AtomicBool::new(false);

        // 성공: false → true
        let old = flag.compare_and_swap(false, true, Ordering::SeqCst);
        assert!(!old);
        assert!(flag.load(Ordering::SeqCst));
    }

    #[test]
    fn test_atomic_bool_compare_and_swap_failure() {
        let flag = AtomicBool::new(false);

        // 실패: expected가 맞지 않음
        let old = flag.compare_and_swap(true, false, Ordering::SeqCst);
        assert!(!old);  // 아, 이건 false를 반환하므로 (!old) != true
        // 다시 수정:
        assert_eq!(old, false);  // expected가 아니므로 현재값 반환
        assert!(!flag.load(Ordering::SeqCst));  // 변경 안 됨
    }

    #[test]
    fn test_atomic_bool_fetch_not() {
        let flag = AtomicBool::new(false);

        let old = flag.fetch_not(Ordering::SeqCst);
        assert!(!old);
        assert!(flag.load(Ordering::SeqCst));

        let old = flag.fetch_not(Ordering::SeqCst);
        assert!(old);
        assert!(!flag.load(Ordering::SeqCst));
    }

    // ========== AtomicPtr 테스트 ==========

    #[test]
    fn test_atomic_ptr_new() {
        let value = 42;
        let ptr = AtomicPtr::<i32>::new(&value as *const i32 as *mut i32);

        let loaded = ptr.load(Ordering::SeqCst);
        unsafe {
            assert_eq!(*loaded, 42);
        }
    }

    #[test]
    fn test_atomic_ptr_store_load() {
        let v1 = 10;
        let v2 = 20;

        let ptr = AtomicPtr::new(&v1 as *const i32 as *mut i32);

        ptr.store(&v2 as *const i32 as *mut i32, Ordering::SeqCst);
        let loaded = ptr.load(Ordering::SeqCst);

        unsafe {
            assert_eq!(*loaded, 20);
        }
    }

    #[test]
    fn test_atomic_ptr_compare_and_swap() {
        let v1 = 10;
        let v2 = 20;

        let p1 = &v1 as *const i32 as *mut i32;
        let p2 = &v2 as *const i32 as *mut i32;

        let ptr = AtomicPtr::new(p1);

        // 성공
        let old = ptr.compare_and_swap(p1, p2, Ordering::SeqCst);
        assert_eq!(old, p1);

        let loaded = ptr.load(Ordering::SeqCst);
        assert_eq!(loaded, p2);
    }

    // ========== 메모리 순서 테스트 ==========

    #[test]
    fn test_memory_ordering_with_release_acquire() {
        let data = AtomicUsize::new(0);
        let flag = AtomicBool::new(false);

        // Writer thread
        data.store(42, Ordering::Release);
        flag.store(true, Ordering::Release);

        // Reader thread
        if flag.load(Ordering::Acquire) {
            let value = data.load(Ordering::Acquire);
            assert_eq!(value, 42);
        }
    }

    #[test]
    fn test_sequential_consistency() {
        let counter = AtomicUsize::new(0);

        counter.store(1, Ordering::SeqCst);
        assert_eq!(counter.load(Ordering::SeqCst), 1);

        counter.store(2, Ordering::SeqCst);
        assert_eq!(counter.load(Ordering::SeqCst), 2);

        // SeqCst는 모든 스레드에서 같은 순서를 봄
        counter.fetch_add(3, Ordering::SeqCst);
        assert_eq!(counter.load(Ordering::SeqCst), 5);
    }

    // ========== 동시성 시나리오 테스트 ==========

    #[test]
    fn test_atomic_counter_increment() {
        // 여러 스레드가 동시에 증가
        let counter = std::sync::Arc::new(AtomicUsize::new(0));

        let mut handles = vec![];

        for _ in 0..5 {
            let c = counter.clone();
            let handle = std::thread::spawn(move || {
                for _ in 0..100 {
                    c.fetch_add(1, Ordering::SeqCst);
                }
            });
            handles.push(handle);
        }

        for handle in handles {
            handle.join().unwrap();
        }

        assert_eq!(counter.load(Ordering::SeqCst), 500);
    }

    #[test]
    fn test_atomic_flag_synchronization() {
        let flag = std::sync::Arc::new(AtomicBool::new(false));
        let data = std::sync::Arc::new(AtomicUsize::new(0));

        let flag_clone = flag.clone();
        let data_clone = data.clone();

        let producer = std::thread::spawn(move || {
            data_clone.store(42, Ordering::Release);
            flag_clone.store(true, Ordering::Release);
        });

        let flag_clone2 = flag.clone();
        let data_clone2 = data.clone();

        let consumer = std::thread::spawn(move || {
            while !flag_clone2.load(Ordering::Acquire) {
                std::thread::yield_now();
            }
            data_clone2.load(Ordering::Acquire)
        });

        producer.join().unwrap();
        let result = consumer.join().unwrap();

        assert_eq!(result, 42);
    }

    #[test]
    fn test_lock_free_stack_push() {
        // Lock-free 스택: Head 포인터 업데이트
        let head = AtomicPtr::new(std::ptr::null_mut());

        let v1 = 10;
        let v2 = 20;

        let p1 = &v1 as *const i32 as *mut i32;
        let p2 = &v2 as *const i32 as *mut i32;

        head.store(p1, Ordering::Release);
        let loaded = head.load(Ordering::Acquire);

        unsafe {
            assert_eq!(*loaded, 10);
        }
    }

    // ========== 에러 처리 테스트 ==========

    #[test]
    fn test_overflow_behavior() {
        let counter = AtomicUsize::new(usize::MAX);

        // usize::MAX + 1 = 0 (wrapping)
        let old = counter.fetch_add(1, Ordering::SeqCst);
        assert_eq!(old, usize::MAX);
        assert_eq!(counter.load(Ordering::SeqCst), 0);
    }

    #[test]
    fn test_underflow_behavior() {
        let counter = AtomicUsize::new(0);

        // 0 - 1 = usize::MAX (wrapping)
        let old = counter.fetch_sub(1, Ordering::SeqCst);
        assert_eq!(old, 0);
        assert_eq!(counter.load(Ordering::SeqCst), usize::MAX);
    }
}

