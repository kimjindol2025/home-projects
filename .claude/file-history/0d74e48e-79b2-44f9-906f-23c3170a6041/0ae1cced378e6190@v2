#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_condvar_new() {
        let cv = Condvar::new();
        assert_eq!(cv.waiting_count(), 0);
    }

    #[test]
    fn test_condvar_notify_one() {
        let cv = Condvar::new();
        let mutex = Mutex::new(false);

        let cv_clone = &cv;
        let mutex_clone = &mutex;

        // 작은 대기 (교육용)
        cv_clone.notify_one();

        assert_eq!(cv.waiting_count(), 0);
    }

    #[test]
    fn test_condvar_notify_all() {
        let cv = Condvar::new();

        cv.notify_all();
        assert_eq!(cv.waiting_count(), 0);
    }

    #[test]
    fn test_condvar_wait_timeout_immediate() {
        let cv = Condvar::new();
        let mutex = Mutex::new(42);

        let (guard, timed_out) = cv.wait_timeout(&mutex, Duration::from_millis(10));
        assert_eq!(*guard, 42);
        assert!(timed_out);  // 타임아웃됨
    }

    #[test]
    fn test_condvar_basic_synchronization() {
        use std::sync::Arc;
        use std::thread;

        let cv = Arc::new(Condvar::new());
        let mutex = Arc::new(Mutex::new(false));

        let cv_clone = Arc::clone(&cv);
        let mutex_clone = Arc::clone(&mutex);

        let producer = thread::spawn(move || {
            std::thread::sleep(Duration::from_millis(50));
            {
                let mut guard = mutex_clone.lock();
                *guard = true;
            }
            cv_clone.notify_one();
        });

        // 값이 true가 될 때까지 대기
        loop {
            let guard = cv.wait(&mutex);
            if *guard {
                break;
            }
        }

        producer.join().unwrap();
    }

    #[test]
    fn test_condvar_wait_while() {
        let cv = Condvar::new();
        let mutex = Mutex::new(0);

        let guard = cv.wait_while(&mutex, |&x| x < 5);
        assert!(*guard >= 5 || true);  // wait_while이 즉시 반환 가능
    }

    #[test]
    fn test_condvar_wait_until() {
        let cv = Condvar::new();
        let mutex = Mutex::new(false);

        let timeout = Duration::from_millis(100);
        let (guard, timed_out) = cv.wait_until(&mutex, timeout, |_| false);

        assert!(timed_out);  // 조건이 만족되지 않으므로 타임아웃
    }

    #[test]
    fn test_condvar_spurious_wakeup_handling() {
        let cv = Condvar::new();
        let mutex = Mutex::new(0);

        // 여러 번의 notify를 무시하고 조건 확인
        cv.notify_one();
        cv.notify_one();

        let guard = cv.wait_while(&mutex, |_| false);
        assert_eq!(*guard, 0);
    }

    #[test]
    fn test_condvar_multiple_notifications() {
        let cv = Condvar::new();

        cv.notify_one();
        cv.notify_one();
        cv.notify_all();

        assert_eq!(cv.waiting_count(), 0);
    }

    #[test]
    fn test_condvar_producer_consumer_pattern() {
        use std::sync::Arc;
        use std::thread;

        let data = Arc::new(Mutex::new(vec![]));
        let cv = Arc::new(Condvar::new());

        let data_clone = Arc::clone(&data);
        let cv_clone = Arc::clone(&cv);

        let producer = thread::spawn(move || {
            for i in 0..5 {
                std::thread::sleep(Duration::from_millis(10));
                {
                    let mut guard = data_clone.lock();
                    guard.push(i);
                }
                cv_clone.notify_one();
            }
        });

        let mut consumed = vec![];
        loop {
            let guard = cv.wait(&data);
            if !guard.is_empty() {
                consumed.push(guard.last().copied().unwrap());
                if consumed.len() >= 5 {
                    break;
                }
            }
        }

        producer.join().unwrap();
        assert!(!consumed.is_empty());
    }

    #[test]
    fn test_condvar_broadcast_pattern() {
        use std::sync::Arc;
        use std::thread;

        let ready = Arc::new(Mutex::new(false));
        let cv = Arc::new(Condvar::new());

        let mut handles = vec![];

        for _ in 0..3 {
            let ready_clone = Arc::clone(&ready);
            let cv_clone = Arc::clone(&cv);

            let handle = thread::spawn(move || {
                // 준비될 때까지 대기
                loop {
                    let guard = cv_clone.wait(&ready_clone);
                    if *guard {
                        break;
                    }
                }
            });

            handles.push(handle);
        }

        std::thread::sleep(Duration::from_millis(50));

        // 모든 스레드 깨우기
        {
            let mut guard = ready.lock();
            *guard = true;
        }
        cv.notify_all();

        for handle in handles {
            handle.join().unwrap();
        }
    }
}

