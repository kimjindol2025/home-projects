use crate::sync::mutex::Mutex;
use std::time::Duration;

// ============================================================================
// Condition Variable
// ============================================================================

/// Condition Variable: 특정 조건을 기다리는 스레드를 깨운다.
pub struct Condvar {
    /// 깨어날 준비가 된 스레드 ID
    waiting_threads: std::sync::Mutex<Vec<std::thread::ThreadId>>,

    /// Spurious wakeup 감지
    wakeup_count: std::sync::atomic::AtomicUsize,
}

impl Condvar {
    /// 새로운 Condvar을 생성합니다.
    pub fn new() -> Condvar {
        Condvar {
            waiting_threads: std::sync::Mutex::new(Vec::new()),
            wakeup_count: std::sync::atomic::AtomicUsize::new(0),
        }
    }

    /// Lock을 보유한 상태에서 조건을 기다립니다.
    ///
    /// # 사용 패턴
    /// ```
    /// let mutex = Mutex::new(data);
    /// let condvar = Condvar::new();
    ///
    /// loop {
    ///     let guard = mutex.lock();
    ///     if condition_met(&guard) {
    ///         break;
    ///     }
    ///     condvar.wait(&mutex);
    ///     // Lock 자동 재획득
    /// }
    /// ```
    pub fn wait<'a, T>(&self, mutex: &'a Mutex<T>) -> std::sync::MutexGuard<'a, T> {
        let current_thread = std::thread::current().id();
        let mut waiting = self.waiting_threads.lock().unwrap();
        waiting.push(current_thread);
        drop(waiting);

        // 실제 구현에서는 OS 조건 변수 또는 futex 사용
        // 여기서는 spin-wait 사용 (교육용)
        loop {
            let wakeup = self.wakeup_count.load(std::sync::atomic::Ordering::SeqCst);

            let waiting = self.waiting_threads.lock().unwrap();
            if !waiting.contains(&current_thread) {
                // 깨어났음
                drop(waiting);
                break;
            }
            drop(waiting);

            std::thread::sleep(Duration::from_micros(10));
        }

        mutex.lock()
    }

    /// 타임아웃과 함께 조건을 기다립니다.
    pub fn wait_timeout<'a, T>(
        &self,
        mutex: &'a Mutex<T>,
        timeout: Duration,
    ) -> (std::sync::MutexGuard<'a, T>, bool) {
        let current_thread = std::thread::current().id();
        let mut waiting = self.waiting_threads.lock().unwrap();
        waiting.push(current_thread);
        drop(waiting);

        let start = std::time::Instant::now();

        loop {
            let elapsed = start.elapsed();
            if elapsed > timeout {
                // 타임아웃: 대기 목록에서 제거
                let mut waiting = self.waiting_threads.lock().unwrap();
                waiting.retain(|&t| t != current_thread);
                return (mutex.lock(), true);  // timeout = true
            }

            let waiting = self.waiting_threads.lock().unwrap();
            if !waiting.contains(&current_thread) {
                // 깨어났음
                drop(waiting);
                return (mutex.lock(), false);  // timeout = false
            }
            drop(waiting);

            std::thread::sleep(Duration::from_micros(10));
        }
    }

    /// 하나의 대기 중인 스레드를 깨웁니다.
    pub fn notify_one(&self) {
        let mut waiting = self.waiting_threads.lock().unwrap();
        if !waiting.is_empty() {
            waiting.remove(0);
            self.wakeup_count
                .fetch_add(1, std::sync::atomic::Ordering::SeqCst);
        }
    }

    /// 모든 대기 중인 스레드를 깨웁니다.
    pub fn notify_all(&self) {
        let mut waiting = self.waiting_threads.lock().unwrap();
        let count = waiting.len();
        waiting.clear();
        self.wakeup_count
            .fetch_add(count, std::sync::atomic::Ordering::SeqCst);
    }

    /// 현재 대기 중인 스레드 개수를 반환합니다 (디버깅용).
    pub fn waiting_count(&self) -> usize {
        self.waiting_threads.lock().unwrap().len()
    }
}

// ============================================================================
// Predicate-based Wait
// ============================================================================

/// Predicate 기반 대기를 지원합니다.
pub trait WaitPredicate<T> {
    fn is_satisfied(&self, guard: &T) -> bool;
}

/// Condvar을 확장한 predicate 기반 대기
impl Condvar {
    /// Predicate가 만족될 때까지 대기합니다.
    pub fn wait_while<'a, T, F>(&self, mutex: &'a Mutex<T>, mut condition: F) -> std::sync::MutexGuard<'a, T>
    where
        F: FnMut(&T) -> bool,
    {
        loop {
            let guard = self.wait(mutex);
            if !condition(&guard) {
                return guard;
            }
        }
    }

    /// Predicate가 만족될 때까지 대기 (타임아웃).
    pub fn wait_until<'a, T, F>(
        &self,
        mutex: &'a Mutex<T>,
        timeout: Duration,
        mut condition: F,
    ) -> (std::sync::MutexGuard<'a, T>, bool)
    where
        F: FnMut(&T) -> bool,
    {
        let start = std::time::Instant::now();

        loop {
            let elapsed = start.elapsed();
            let remaining = if elapsed > timeout {
                Duration::from_secs(0)
            } else {
                timeout - elapsed
            };

            let (guard, timed_out) = self.wait_timeout(mutex, remaining);

            if !condition(&guard) {
                return (guard, false);
            }

            if timed_out {
                return (guard, true);
            }
        }
    }
}

