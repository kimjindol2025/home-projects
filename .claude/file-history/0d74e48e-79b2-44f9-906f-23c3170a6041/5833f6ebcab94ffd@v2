#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_barrier_creation() {
        let barrier = Barrier::new(BarrierType::FullBarrier, 10);
        assert_eq!(barrier.barrier_type(), BarrierType::FullBarrier);
        assert_eq!(barrier.location(), 10);
    }

    #[test]
    fn test_barrier_acquire() {
        let acquire = Barrier::new(BarrierType::Acquire, 5);
        assert!(acquire.is_acquire());
        assert!(!acquire.is_release());
        assert!(!acquire.is_full());
    }

    #[test]
    fn test_barrier_release() {
        let release = Barrier::new(BarrierType::Release, 5);
        assert!(!release.is_acquire());
        assert!(release.is_release());
        assert!(!release.is_full());
    }

    #[test]
    fn test_barrier_full() {
        let full = Barrier::new(BarrierType::FullBarrier, 5);
        assert!(full.is_acquire());
        assert!(full.is_release());
        assert!(full.is_full());
    }

    #[test]
    fn test_barrier_synchronization_valid() {
        let release = Barrier::new(BarrierType::Release, 1);
        let acquire = Barrier::new(BarrierType::Acquire, 2);

        let sync = BarrierSynchronization::new(release, acquire);
        assert!(sync.is_synchronized());
    }

    #[test]
    fn test_barrier_synchronization_invalid() {
        let b1 = Barrier::new(BarrierType::Release, 1);
        let b2 = Barrier::new(BarrierType::Release, 2);

        let sync = BarrierSynchronization::new(b1, b2);
        assert!(!sync.is_synchronized());
    }

    #[test]
    fn test_analyzer_new() {
        let analyzer = BarrierAnalyzer::new();
        assert_eq!(analyzer.barriers().len(), 0);
    }

    #[test]
    fn test_analyzer_add_barrier() {
        let mut analyzer = BarrierAnalyzer::new();
        let barrier = Barrier::new(BarrierType::FullBarrier, 1);

        analyzer.add_barrier(barrier);
        assert_eq!(analyzer.barriers().len(), 1);
    }

    #[test]
    fn test_analyzer_are_synchronized() {
        let mut analyzer = BarrierAnalyzer::new();
        let release = Barrier::new(BarrierType::Release, 1);
        let acquire = Barrier::new(BarrierType::Acquire, 2);

        assert!(analyzer.are_synchronized(release, acquire));
    }

    #[test]
    fn test_analyzer_ordering_to_barrier() {
        assert_eq!(
            BarrierAnalyzer::ordering_to_barrier(Ordering::Relaxed),
            BarrierType::ReadBarrier
        );
        assert_eq!(
            BarrierAnalyzer::ordering_to_barrier(Ordering::Release),
            BarrierType::Release
        );
        assert_eq!(
            BarrierAnalyzer::ordering_to_barrier(Ordering::Acquire),
            BarrierType::Acquire
        );
        assert_eq!(
            BarrierAnalyzer::ordering_to_barrier(Ordering::SeqCst),
            BarrierType::FullBarrier
        );
    }

    #[test]
    fn test_analyzer_performance_cost() {
        let analyzer = BarrierAnalyzer::new();
        let full = Barrier::new(BarrierType::FullBarrier, 1);
        let acquire = Barrier::new(BarrierType::Acquire, 2);

        assert_eq!(analyzer.performance_cost(full), 20);
        assert_eq!(analyzer.performance_cost(acquire), 5);
    }

    #[test]
    fn test_analyzer_total_cost() {
        let mut analyzer = BarrierAnalyzer::new();
        analyzer.add_barrier(Barrier::new(BarrierType::Acquire, 1));
        analyzer.add_barrier(Barrier::new(BarrierType::Release, 2));
        analyzer.add_barrier(Barrier::new(BarrierType::FullBarrier, 3));

        let cost = analyzer.total_performance_cost();
        assert_eq!(cost, 5 + 5 + 20);  // 30
    }

    #[test]
    fn test_analyzer_efficiency_analysis() {
        let mut analyzer = BarrierAnalyzer::new();
        let release = Barrier::new(BarrierType::Release, 1);
        let acquire = Barrier::new(BarrierType::Acquire, 2);

        analyzer.add_barrier(release);
        analyzer.add_barrier(acquire);
        analyzer.add_synchronization(release, acquire);

        let efficiency = analyzer.efficiency_analysis();
        assert_eq!(efficiency.total_barriers, 2);
        assert_eq!(efficiency.acquire_release_pairs, 1);
        assert!(efficiency.efficiency_score > 40.0);  // 50%
    }

    #[test]
    fn test_analyzer_insufficient_barriers() {
        let mut analyzer = BarrierAnalyzer::new();
        let release = Barrier::new(BarrierType::Release, 1);
        let release2 = Barrier::new(BarrierType::Release, 2);

        analyzer.add_barrier(release);
        analyzer.add_barrier(release2);

        let insufficient = analyzer.detect_insufficient_barriers();
        assert_eq!(insufficient.len(), 1);
    }

    #[test]
    fn test_analyzer_unnecessary_full_barriers() {
        let mut analyzer = BarrierAnalyzer::new();
        let full = Barrier::new(BarrierType::FullBarrier, 1);

        analyzer.add_barrier(full);

        let unnecessary = analyzer.detect_unnecessary_full_barriers();
        // Full barrier가 동기화에 사용되지 않으면 불필요
        assert!(unnecessary.len() > 0);
    }

    #[test]
    fn test_analyzer_synchronization_collection() {
        let mut analyzer = BarrierAnalyzer::new();
        let release = Barrier::new(BarrierType::Release, 1);
        let acquire = Barrier::new(BarrierType::Acquire, 2);

        analyzer.add_synchronization(release, acquire);
        assert_eq!(analyzer.synchronizations().len(), 1);
    }
}

