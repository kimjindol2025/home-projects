use std::time::{SystemTime, UNIX_EPOCH};
use std::env;
use std::num::Wrapping;
use crate::stdlib::FlValue;

// ============================================================================
// SystemError - 시스템 호출 에러 타입
// ============================================================================

/// 시스템 호출 시 발생할 수 있는 에러
#[derive(Clone, Debug, PartialEq)]
pub enum SystemError {
    /// 환경변수를 찾을 수 없음
    EnvNotFound(String),

    /// 환경변수 설정 실패
    EnvSetError(String),

    /// 시스템 정보 조회 실패
    SystemInfoError(String),
}

impl std::fmt::Display for SystemError {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            SystemError::EnvNotFound(key) => write!(f, "Environment variable not found: {}", key),
            SystemError::EnvSetError(key) => write!(f, "Failed to set environment variable: {}", key),
            SystemError::SystemInfoError(msg) => write!(f, "System info error: {}", msg),
        }
    }
}

// ============================================================================
// Process Control Functions
// ============================================================================

/// 지정된 밀리초 동안 현재 스레드를 대기합니다.
///
/// # 예제
/// ```
/// sleep(1000);  // 1초 대기
/// ```
pub fn sleep(ms: i64) -> FlValue {
    let duration = std::time::Duration::from_millis(ms as u64);
    std::thread::sleep(duration);
    FlValue::Null
}

/// 프로세스를 종료합니다.
///
/// # 주의
/// - 이 함수는 반환하지 않습니다
/// - 테스트에서는 호출하지 않는 것이 좋습니다
///
/// # 예제
/// ```
/// exit(0);  // 성공으로 종료
/// ```
pub fn exit(code: i64) -> ! {
    std::process::exit(code as i32)
}

// ============================================================================
// Environment Functions
// ============================================================================

/// 환경변수를 읽습니다.
///
/// # 에러
/// - 환경변수가 없으면 SystemError::EnvNotFound
///
/// # 예제
/// ```
/// let path = getenv("PATH").unwrap();
/// ```
pub fn getenv(key: String) -> Result<String, SystemError> {
    env::var(&key)
        .map_err(|_| SystemError::EnvNotFound(key))
}

/// 환경변수를 설정합니다.
///
/// # 주의
/// - Rust에서는 std::env::set_var를 사용하지만 unsafe입니다
/// - 대신 현재 프로세스 내에서만 적용됩니다
///
/// # 예제
/// ```
/// setenv("MY_VAR", "value").unwrap();
/// ```
pub fn setenv(key: String, value: String) -> Result<(), SystemError> {
    // Rust의 set_var는 안전하지 않으므로 직접 설정
    env::set_var(&key, &value);
    Ok(())
}

// ============================================================================
// Time Function
// ============================================================================

/// 현재 시간을 밀리초 단위로 반환합니다.
///
/// # 반환값
/// - Unix epoch(1970-01-01 00:00:00 UTC) 이후의 밀리초
///
/// # 주의
/// - time.fl의 now_ms()와 동일
///
/// # 예제
/// ```
/// let ms = time_ms().unwrap();
/// assert!(ms > 0);
/// ```
pub fn time_ms() -> Result<i64, SystemError> {
    match SystemTime::now().duration_since(UNIX_EPOCH) {
        Ok(duration) => Ok(duration.as_millis() as i64),
        Err(_) => Err(SystemError::SystemInfoError("Time before UNIX_EPOCH".to_string())),
    }
}

// ============================================================================
// Random Number Generation
// ============================================================================

/// 0.0 ~ 1.0 범위의 난수를 생성합니다.
///
/// # 주의
/// - 암호학적으로 안전하지 않습니다
/// - 간단한 선형 합동 생성기 (Linear Congruential Generator) 사용
///
/// # 예제
/// ```
/// let r = random();
/// assert!(r >= 0.0 && r <= 1.0);
/// ```
pub fn random() -> f64 {
    // 간단한 LCG (Linear Congruential Generator)
    // 매우 기본적인 구현
    let seed = match SystemTime::now().duration_since(UNIX_EPOCH) {
        Ok(dur) => dur.as_nanos() as u64,
        Err(_) => 12345u64,
    };

    // LCG 파라미터: glibc의 표준값
    let a = 1103515245u64;
    let c = 12345u64;
    let m = 2u64.pow(31);

    let next = (Wrapping(a) * Wrapping(seed) + Wrapping(c)).0 % m;
    (next as f64) / (m as f64)
}

// ============================================================================
// System Information Functions
// ============================================================================

/// 시스템의 CPU 코어 수를 반환합니다.
///
/// # 반환값
/// - 논리 CPU 코어 수
///
/// # 예제
/// ```
/// let cores = cpu_count().unwrap();
/// assert!(cores > 0);
/// ```
pub fn cpu_count() -> Result<i64, SystemError> {
    match num_cpus::get() {
        count if count > 0 => Ok(count as i64),
        _ => Err(SystemError::SystemInfoError("Cannot determine CPU count".to_string())),
    }
}

/// 간단한 CPU 코어 수 반환 (num_cpus 없이)
fn cpu_count_simple() -> i64 {
    // 대체 구현: 환경변수 또는 기본값
    if let Ok(count_str) = env::var("RAYON_NUM_THREADS") {
        if let Ok(count) = count_str.parse::<i64>() {
            return count;
        }
    }
    // 기본값: 4 (대부분의 시스템)
    4
}

/// 프로세스 시작 시 전달된 인자들을 배열로 반환합니다.
///
/// # 반환값
/// - 첫 번째 요소는 실행 파일 경로
/// - 나머지는 명령행 인자
///
/// # 예제
/// ```
/// let args = args().unwrap();
/// match args {
///     FlValue::Array(argv) => {
///         // argv[0] = 프로그램 이름
///         // argv[1..] = 인자들
///     }
///     _ => {}
/// }
/// ```
pub fn args() -> Result<FlValue, SystemError> {
    let argv: Vec<FlValue> = std::env::args()
        .map(|arg| FlValue::Str(arg))
        .collect();

    if argv.is_empty() {
        Ok(FlValue::Array(vec![FlValue::Str("unknown".to_string())]))
    } else {
        Ok(FlValue::Array(argv))
    }
}

