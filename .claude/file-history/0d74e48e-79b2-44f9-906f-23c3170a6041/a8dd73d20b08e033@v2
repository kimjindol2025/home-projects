#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_sleep_returns_null() {
        let result = sleep(1);
        assert_eq!(result, FlValue::Null);
    }

    #[test]
    fn test_sleep_actually_waits() {
        let start = std::time::Instant::now();
        sleep(50);
        let elapsed = start.elapsed();
        assert!(elapsed.as_millis() >= 40); // 약 50ms 대기
    }

    #[test]
    fn test_getenv_path() {
        // PATH는 대부분 존재
        let result = getenv("PATH".to_string());
        assert!(result.is_ok());
    }

    #[test]
    fn test_getenv_nonexistent() {
        let result = getenv("NONEXISTENT_VAR_XYZ_12345".to_string());
        assert!(matches!(result, Err(SystemError::EnvNotFound(_))));
    }

    #[test]
    fn test_setenv_and_getenv() {
        let key = "TEST_VAR_FOR_FREELANG".to_string();
        let value = "test_value_123".to_string();

        setenv(key.clone(), value.clone()).unwrap();
        let retrieved = getenv(key).unwrap();
        assert_eq!(retrieved, value);
    }

    #[test]
    fn test_time_ms_positive() {
        let result = time_ms().unwrap();
        assert!(result > 0);
        // 2000-01-01 이후
        assert!(result > 946684800000i64);
    }

    #[test]
    fn test_time_ms_increasing() {
        let t1 = time_ms().unwrap();
        std::thread::sleep(std::time::Duration::from_millis(5));
        let t2 = time_ms().unwrap();
        assert!(t2 >= t1);
    }

    #[test]
    fn test_random_range() {
        let r = random();
        assert!(r >= 0.0 && r <= 1.0);
    }

    #[test]
    fn test_random_variation() {
        let r1 = random();
        let r2 = random();
        // 연속된 난수가 다를 가능성 높음
        // (완벽한 테스트는 아니지만 기본 검증)
        assert!(r1 >= 0.0 && r2 >= 0.0);
    }

    #[test]
    fn test_cpu_count_simple() {
        let count = cpu_count_simple();
        assert!(count > 0);
        assert!(count <= 1024); // 합리적인 범위
    }

    #[test]
    fn test_args_not_empty() {
        let result = args().unwrap();
        match result {
            FlValue::Array(argv) => {
                assert!(!argv.is_empty());
                // 첫 번째 요소가 문자열이어야 함
                assert!(matches!(argv[0], FlValue::Str(_)));
            }
            _ => panic!("Expected array"),
        }
    }

    #[test]
    fn test_args_contains_strings() {
        let result = args().unwrap();
        match result {
            FlValue::Array(argv) => {
                for arg in argv {
                    assert!(matches!(arg, FlValue::Str(_)));
                }
            }
            _ => panic!("Expected array"),
        }
    }
}

