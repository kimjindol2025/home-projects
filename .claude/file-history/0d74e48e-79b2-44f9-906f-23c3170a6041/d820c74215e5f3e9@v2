//
// 런타임 평가 중 발생하는 모든 에러 타입을 정의합니다.
//
// 에러 분류:
// - TypeError: 타입 불일치 에러
// - UndefinedVariable: 정의되지 않은 변수
// - IndexOutOfBounds: 배열/객체 인덱싱 오류
// - CallError: 함수 호출 에러
// - DivisionByZero: 0으로 나누기
// - ParseError: 파싱 에러
// - LockError: 동시성 락 에러
// - ChannelError: 채널 에러
//
// 구현 일시: 2026-03-02
// 단계: Phase E Week 4

use std::fmt;
use std::error::Error;

// ============================================================================
// RuntimeError: 모든 런타임 에러의 상위 타입
// ============================================================================

/// 런타임 실행 중 발생하는 에러
#[derive(Clone, Debug)]
pub enum RuntimeError {
    /// 타입 불일치 에러
    ///
    /// 예: `"hello" + 42` (String + Int는 불가)
    TypeError {
        expected: String,
        got: String,
        context: String,
    },

    /// 정의되지 않은 변수에 접근
    ///
    /// 예: `println(x)` (x가 선언되지 않음)
    UndefinedVariable {
        name: String,
        line: usize,
        column: usize,
    },

    /// 배열/객체 인덱싱 범위 초과
    ///
    /// 예: `[1,2,3][10]` (범위 초과)
    IndexOutOfBounds {
        index: i64,
        length: usize,
        context: String,
    },

    /// 함수 호출 에러
    ///
    /// 예: `sqrt("hello")` (타입 오류)
    /// 또는: `unknown_func()` (존재하지 않음)
    CallError {
        function: String,
        reason: String,
        arg_count: Option<usize>,
    },

    /// 0으로 나누기
    ///
    /// 예: `42 / 0`
    DivisionByZero {
        left: String,
        context: String,
    },

    /// 파싱 에러
    ///
    /// 예: `let x = + + +` (문법 오류)
    ParseError {
        message: String,
        line: usize,
        column: usize,
        token: Option<String>,
    },

    /// 동시성 락 에러
    ///
    /// 예: `arc_get(arc)` (Arc 락 획득 실패)
    LockError {
        object_type: String,
        operation: String,
        reason: String,
    },

    /// 채널 에러
    ///
    /// 예: `channel_recv(rx)` (채널 폐쇄)
    ChannelError {
        operation: String,
        reason: String,
    },

    /// RefCell 빌림 에러
    ///
    /// 예: `refcell_borrow()` (가변 빌림 중)
    BorrowError {
        object_type: String,
        current_state: String,
        attempted_operation: String,
    },

    /// 범위 에러
    ///
    /// 예: `range(5, 2)` (start > end)
    RangeError {
        start: i64,
        end: i64,
        reason: String,
    },

    /// 메모리 할당 실패
    ///
    /// 예: 매우 큰 배열 생성
    AllocationError {
        size: usize,
        reason: String,
    },

    /// 파일 I/O 에러
    ///
    /// 예: `read_file("/nonexistent.txt")`
    IoError {
        operation: String,
        path: Option<String>,
        reason: String,
    },

    /// 시간 초과 에러
    ///
    /// 예: 무한 루프 또는 대기
    TimeoutError {
        operation: String,
        timeout_ms: u64,
    },

    /// 스택 오버플로우
    ///
    /// 예: 무한 재귀
    StackOverflow {
        depth: usize,
        max_depth: usize,
    },

    /// 일반 런타임 에러
    Runtime(String),
}

impl RuntimeError {
    /// 에러 심각도를 반환합니다
    pub fn severity(&self) -> ErrorSeverity {
        match self {
            RuntimeError::StackOverflow { .. } => ErrorSeverity::Critical,
            RuntimeError::AllocationError { .. } => ErrorSeverity::Critical,
            RuntimeError::DivisionByZero { .. } => ErrorSeverity::High,
            RuntimeError::UndefinedVariable { .. } => ErrorSeverity::High,
            RuntimeError::ParseError { .. } => ErrorSeverity::High,
            RuntimeError::TypeError { .. } => ErrorSeverity::High,
            RuntimeError::IndexOutOfBounds { .. } => ErrorSeverity::Medium,
            RuntimeError::CallError { .. } => ErrorSeverity::Medium,
            RuntimeError::LockError { .. } => ErrorSeverity::Medium,
            RuntimeError::ChannelError { .. } => ErrorSeverity::Medium,
            RuntimeError::BorrowError { .. } => ErrorSeverity::Medium,
            RuntimeError::RangeError { .. } => ErrorSeverity::Low,
            RuntimeError::IoError { .. } => ErrorSeverity::Medium,
            RuntimeError::TimeoutError { .. } => ErrorSeverity::High,
            RuntimeError::Runtime(_) => ErrorSeverity::Medium,
        }
    }

    /// 에러 코드를 반환합니다
    pub fn error_code(&self) -> &'static str {
        match self {
            RuntimeError::TypeError { .. } => "E0001",
            RuntimeError::UndefinedVariable { .. } => "E0002",
            RuntimeError::IndexOutOfBounds { .. } => "E0003",
            RuntimeError::CallError { .. } => "E0004",
            RuntimeError::DivisionByZero { .. } => "E0005",
            RuntimeError::ParseError { .. } => "E0006",
            RuntimeError::LockError { .. } => "E0007",
            RuntimeError::ChannelError { .. } => "E0008",
            RuntimeError::BorrowError { .. } => "E0009",
            RuntimeError::RangeError { .. } => "E0010",
            RuntimeError::AllocationError { .. } => "E0011",
            RuntimeError::IoError { .. } => "E0012",
            RuntimeError::TimeoutError { .. } => "E0013",
            RuntimeError::StackOverflow { .. } => "E0014",
            RuntimeError::Runtime(_) => "E9999",
        }
    }

    /// 사용자 친화적 메시지를 반환합니다
    pub fn user_message(&self) -> String {
        match self {
            RuntimeError::TypeError { expected, got, context } => {
                format!("Type error in {}: expected {}, got {}", context, expected, got)
            },
            RuntimeError::UndefinedVariable { name, line, column } => {
                format!("Undefined variable '{}' at line {}:{}", name, line, column)
            },
            RuntimeError::IndexOutOfBounds { index, length, context } => {
                format!("Index {} out of bounds (length {}) in {}", index, length, context)
            },
            RuntimeError::CallError { function, reason, arg_count } => {
                if let Some(count) = arg_count {
                    format!("Error calling {}() with {} arguments: {}", function, count, reason)
                } else {
                    format!("Error calling {}: {}", function, reason)
                }
            },
            RuntimeError::DivisionByZero { left, context } => {
                format!("Division by zero: {} / 0 in {}", left, context)
            },
            RuntimeError::ParseError { message, line, column, token } => {
                if let Some(t) = token {
                    format!("Parse error at line {}:{}: {} (token: {})", line, column, message, t)
                } else {
                    format!("Parse error at line {}:{}: {}", line, column, message)
                }
            },
            RuntimeError::LockError { object_type, operation, reason } => {
                format!("Lock error on {}: {} ({})", object_type, operation, reason)
            },
            RuntimeError::ChannelError { operation, reason } => {
                format!("Channel error during {}: {}", operation, reason)
            },
            RuntimeError::BorrowError { object_type, current_state, attempted_operation } => {
                format!("Borrow error on {}: {} (state: {})",
                    object_type, attempted_operation, current_state)
            },
            RuntimeError::RangeError { start, end, reason } => {
                format!("Invalid range {}..{}: {}", start, end, reason)
            },
            RuntimeError::AllocationError { size, reason } => {
                format!("Memory allocation failed for {} bytes: {}", size, reason)
            },
            RuntimeError::IoError { operation, path, reason } => {
                if let Some(p) = path {
                    format!("I/O error during {} on '{}': {}", operation, p, reason)
                } else {
                    format!("I/O error during {}: {}", operation, reason)
                }
            },
            RuntimeError::TimeoutError { operation, timeout_ms } => {
                format!("Operation timeout ({} ms) in {}", timeout_ms, operation)
            },
            RuntimeError::StackOverflow { depth, max_depth } => {
                format!("Stack overflow at depth {} (max: {})", depth, max_depth)
            },
            RuntimeError::Runtime(msg) => msg.clone(),
        }
    }

    /// 디버그 메시지 (개발자용)를 반환합니다
    pub fn debug_message(&self) -> String {
        format!("{:?}", self)
    }
}

impl fmt::Display for RuntimeError {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        write!(f, "{} [{}]: {}",
            self.severity().display_emoji(),
            self.error_code(),
            self.user_message()
        )
    }
}

impl Error for RuntimeError {}

// ============================================================================
// ErrorSeverity: 에러 심각도
// ============================================================================

/// 에러의 심각도 수준
#[derive(Clone, Copy, Debug, PartialEq, Eq, PartialOrd, Ord)]
pub enum ErrorSeverity {
    /// 정보성 경고
    Info = 0,

    /// 낮은 심각도 (계속 실행 가능)
    Low = 1,

    /// 중간 심각도 (로직 오류)
    Medium = 2,

    /// 높은 심각도 (실행 불가능)
    High = 3,

    /// 치명적 (시스템 장애)
    Critical = 4,
}

impl ErrorSeverity {
    /// 심각도를 표시하는 이모지를 반환합니다
    pub fn display_emoji(&self) -> &'static str {
        match self {
            ErrorSeverity::Info => "ℹ️ ",
            ErrorSeverity::Low => "⚠️ ",
            ErrorSeverity::Medium => "❌",
            ErrorSeverity::High => "🚫",
            ErrorSeverity::Critical => "💥",
        }
    }

    /// 심각도를 텍스트로 반환합니다
    pub fn name(&self) -> &'static str {
        match self {
            ErrorSeverity::Info => "INFO",
            ErrorSeverity::Low => "WARNING",
            ErrorSeverity::Medium => "ERROR",
            ErrorSeverity::High => "FATAL",
            ErrorSeverity::Critical => "CRITICAL",
        }
    }
}

impl fmt::Display for ErrorSeverity {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        write!(f, "{}", self.name())
    }
}

// ============================================================================
// ErrorContext: 에러 발생 컨텍스트
// ============================================================================

/// 에러 발생 시점의 컨텍스트 정보
#[derive(Clone, Debug)]
pub struct ErrorContext {
    /// 소스 파일 경로
    pub file: Option<String>,

    /// 줄 번호 (1-indexed)
    pub line: usize,

    /// 열 번호 (1-indexed)
    pub column: usize,

    /// 함수명
    pub function: Option<String>,

    /// 추가 정보
    pub hint: Option<String>,
}

impl ErrorContext {
    pub fn new(line: usize, column: usize) -> Self {
        ErrorContext {
            file: None,
            line,
            column,
            function: None,
            hint: None,
        }
    }

    pub fn with_file(mut self, file: String) -> Self {
        self.file = Some(file);
        self
    }

    pub fn with_function(mut self, func: String) -> Self {
        self.function = Some(func);
        self
    }

    pub fn with_hint(mut self, hint: String) -> Self {
        self.hint = Some(hint);
        self
    }
}

impl fmt::Display for ErrorContext {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        if let Some(file) = &self.file {
            write!(f, "{}:{}:{}", file, self.line, self.column)?;
        } else {
            write!(f, "{}:{}", self.line, self.column)?;
        }

        if let Some(func) = &self.function {
            write!(f, " in {}", func)?;
        }

        if let Some(hint) = &self.hint {
            write!(f, "\n  hint: {}", hint)?;
        }

        Ok(())
    }
}

// ============================================================================
// ErrorRecovery: 에러 복구 전략
// ============================================================================

/// 에러 복구 방법
#[derive(Clone, Debug)]
pub enum ErrorRecovery {
    /// 복구 불가능 (프로그램 종료)
    Fatal,

    /// 기본값으로 계속 실행
    UseDefault(crate::evaluator::FlValue),

    /// 재시도
    Retry {
        max_attempts: usize,
        backoff_ms: u64,
    },

    /// 다른 경로로 실행
    FallbackFunction(String),

    /// 사용자 상호작용 대기
    PromptUser,

    /// 로그만 남기고 계속
    Log,
}

