#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_type_error() {
        let err = RuntimeError::TypeError {
            expected: "Int".to_string(),
            got: "String".to_string(),
            context: "addition".to_string(),
        };
        assert_eq!(err.error_code(), "E0001");
        assert_eq!(err.severity(), ErrorSeverity::High);
    }

    #[test]
    fn test_undefined_variable() {
        let err = RuntimeError::UndefinedVariable {
            name: "x".to_string(),
            line: 5,
            column: 10,
        };
        assert_eq!(err.error_code(), "E0002");
        let msg = err.user_message();
        assert!(msg.contains("x"));
    }

    #[test]
    fn test_index_out_of_bounds() {
        let err = RuntimeError::IndexOutOfBounds {
            index: 10,
            length: 5,
            context: "array access".to_string(),
        };
        assert_eq!(err.error_code(), "E0003");
        assert_eq!(err.severity(), ErrorSeverity::Medium);
    }

    #[test]
    fn test_division_by_zero() {
        let err = RuntimeError::DivisionByZero {
            left: "42".to_string(),
            context: "arithmetic".to_string(),
        };
        assert_eq!(err.error_code(), "E0005");
        assert_eq!(err.severity(), ErrorSeverity::High);
    }

    #[test]
    fn test_call_error() {
        let err = RuntimeError::CallError {
            function: "sqrt".to_string(),
            reason: "expected number".to_string(),
            arg_count: Some(1),
        };
        assert_eq!(err.error_code(), "E0004");
        let msg = err.user_message();
        assert!(msg.contains("sqrt"));
    }

    #[test]
    fn test_parse_error() {
        let err = RuntimeError::ParseError {
            message: "unexpected token".to_string(),
            line: 3,
            column: 7,
            token: Some("+".to_string()),
        };
        assert_eq!(err.error_code(), "E0006");
        let msg = err.user_message();
        assert!(msg.contains("3:7"));
    }

    #[test]
    fn test_lock_error() {
        let err = RuntimeError::LockError {
            object_type: "Mutex".to_string(),
            operation: "lock".to_string(),
            reason: "poisoned".to_string(),
        };
        assert_eq!(err.error_code(), "E0007");
        assert_eq!(err.severity(), ErrorSeverity::Medium);
    }

    #[test]
    fn test_stack_overflow() {
        let err = RuntimeError::StackOverflow {
            depth: 10000,
            max_depth: 8000,
        };
        assert_eq!(err.error_code(), "E0014");
        assert_eq!(err.severity(), ErrorSeverity::Critical);
    }

    #[test]
    fn test_error_severity_ordering() {
        assert!(ErrorSeverity::Critical > ErrorSeverity::High);
        assert!(ErrorSeverity::High > ErrorSeverity::Medium);
        assert!(ErrorSeverity::Medium > ErrorSeverity::Low);
    }

    #[test]
    fn test_error_context() {
        let ctx = ErrorContext::new(10, 5)
            .with_file("main.fl".to_string())
            .with_function("calculate".to_string())
            .with_hint("use parentheses".to_string());

        let s = ctx.to_string();
        assert!(s.contains("main.fl"));
        assert!(s.contains("10:5"));
        assert!(s.contains("calculate"));
        assert!(s.contains("parentheses"));
    }

    #[test]
    fn test_error_display() {
        let err = RuntimeError::TypeError {
            expected: "Number".to_string(),
            got: "String".to_string(),
            context: "mul".to_string(),
        };
        let display_str = err.to_string();
        assert!(display_str.contains("E0001"));
        assert!(display_str.contains("Type error"));
    }

    #[test]
    fn test_io_error() {
        let err = RuntimeError::IoError {
            operation: "read".to_string(),
            path: Some("data.txt".to_string()),
            reason: "not found".to_string(),
        };
        assert_eq!(err.error_code(), "E0012");
        let msg = err.user_message();
        assert!(msg.contains("data.txt"));
    }
}
