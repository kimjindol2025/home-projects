# Option 헬퍼
fn isSome<T>
  input: opt: Option<T>
  output: bool
  intent: "Option이 Some인지 확인"
  do
    match opt
      Some(_) => true
      None => false

fn isNone<T>
  input: opt: Option<T>
  output: bool
  intent: "Option이 None인지 확인"
  do
    match opt
      Some(_) => false
      None => true

fn unwrap<T>
  input: opt: Option<T>
  output: T
  intent: "Option에서 값 추출 (Some인 경우만)"
  do
    match opt
      Some(value) => value
      None => panic("Called unwrap on None")

fn getOrElse<T>
  input: (opt: Option<T>, default: T)
  output: T
  intent: "Option의 값 또는 기본값 반환"
  do
    match opt
      Some(value) => value
      None => default

fn panic
  input: msg: string
  output: void
  intent: "프로그램 중단 (에러)"
  do
    print("PANIC: " + msg)
