## 8. 예제: 완전한 멀티스레드 프로그램

```freelang
use std::sync::{Arc, Mutex, Condvar, mpsc::channel};
use std::thread;
use std::time::Duration;

struct Worker {
    id: usize,
    total_work: Arc<Mutex<u64>>,
}

fn main() {
    let total_work = Arc::new(Mutex::new(0u64));
    let (tx, rx) = channel();

    // 3개 워커 스레드
    for worker_id in 1..=3 {
        let work_clone = Arc::clone(&total_work);
        let tx_clone = tx.clone();

        thread::spawn(move || {
            for task in 1..=100 {
                let work_ms = task * 10;
                thread::sleep(Duration::from_millis(work_ms as u64));

                let mut count = work_clone.lock().unwrap();
                *count += work_ms;

                tx_clone.send((worker_id, task)).unwrap();
            }
        });
    }

    drop(tx);

    // 메인 스레드: 진행률 모니터링
    let mut completed = 0;
    for (worker_id, task_id) in rx {
        completed += 1;
        println!("[{:3}%] Worker {} completed task {}",
                 (completed * 100) / 300,
                 worker_id,
                 task_id);
    }

    let total = *total_work.lock().unwrap();
    println!("\nTotal work time: {}ms", total);
}
