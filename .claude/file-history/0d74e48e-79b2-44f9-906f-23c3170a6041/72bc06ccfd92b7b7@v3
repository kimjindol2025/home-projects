/// 모든 스레드 안전 타입의 시작점
///
/// # 예제
///
/// ```
/// use freelang::sync::{Arc, Mutex};
/// use freelang::thread;
///
/// let data = Arc::new(Mutex::new(0));
/// let data_clone = data.clone();
///
/// thread::spawn(move || {
///     let mut guard = data_clone.lock();
///     *guard += 1;
/// });
/// ```

