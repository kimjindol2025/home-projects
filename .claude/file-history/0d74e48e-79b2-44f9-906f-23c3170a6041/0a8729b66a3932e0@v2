fn stringLen
  input: str: string
  output: number
  intent: \"문자열 길이\"
  do
    return 0

fn arrayPush<T>
  input: (arr: array<T>, item: T)
  output: array<T>
  intent: \"배열에 추가\"
  do
    return arr

