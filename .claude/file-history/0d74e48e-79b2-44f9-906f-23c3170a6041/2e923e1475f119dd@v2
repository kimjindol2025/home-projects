#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_interrupt_type_vector() {
        assert_eq!(InterruptType::DivideError.to_vector(), 0);
        assert_eq!(InterruptType::PageFault.to_vector(), 14);
        assert_eq!(InterruptType::SystemCall.to_vector(), 128);
    }

    #[test]
    fn test_interrupt_type_exception() {
        assert!(InterruptType::DivideError.is_exception());
        assert!(!InterruptType::HardwareInterrupt { irq: 0 }.is_exception());
    }

    #[test]
    fn test_interrupt_type_fault() {
        assert!(InterruptType::DivideError.is_fault());
        assert!(InterruptType::PageFault.is_fault());
        assert!(!InterruptType::Breakpoint.is_fault());
    }

    #[test]
    fn test_interrupt_frame_creation() {
        let frame = InterruptFrame::new(14, 0x500000, 0x100000);
        assert_eq!(frame.vector, 14);
        assert_eq!(frame.error_code, 0x500000);
        assert_eq!(frame.rip, 0x100000);
    }

    #[test]
    fn test_idt_entry_creation() {
        let entry = IDTEntry::new(0, 0x100000, 0);
        assert_eq!(entry.vector, 0);
        assert_eq!(entry.offset, 0x100000);
        assert!(entry.present);
    }

    #[test]
    fn test_idt_creation() {
        let idt = IDT::new();
        assert!(!idt.entries.is_empty());
        assert!(!idt.loaded);
    }

    #[test]
    fn test_idt_load() {
        let mut idt = IDT::new();
        assert!(idt.load().is_ok());
        assert!(idt.loaded);
    }

    #[test]
    fn test_idt_register_handler() {
        let mut idt = IDT::new();
        idt.load().unwrap();
        assert!(idt.register_handler(32, 100).is_ok());
    }

    #[test]
    fn test_interrupt_handler_creation() {
        let handler = InterruptHandler::new();
        assert_eq!(handler.handled_count, 0);
    }

    #[test]
    fn test_interrupt_handler_handle() {
        let mut handler = InterruptHandler::new();
        let frame = InterruptFrame::new(32, 0, 0x100000);
        let result = handler.handle_interrupt(
            InterruptType::HardwareInterrupt { irq: 0 },
            frame
        );
        assert!(result.is_ok());
    }

    #[test]
    fn test_interrupt_handler_statistics() {
        let mut handler = InterruptHandler::new();
        for i in 0..3 {
            let frame = InterruptFrame::new(32, 0, 0x100000);
            handler.handle_interrupt(
                InterruptType::HardwareInterrupt { irq: i as u8 },
                frame
            ).ok();
        }
        assert_eq!(handler.handled_count, 3);
    }

    #[test]
    fn test_interrupt_handler_exception() {
        let mut handler = InterruptHandler::new();
        let frame = InterruptFrame::new(0, 0, 0x100000);
        let result = handler.handle_interrupt(InterruptType::DivideError, frame);
        assert!(result.is_err());
    }
}
