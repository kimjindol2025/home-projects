#[cfg(test)]
mod file_json_workflow {
    use super::*;

    #[test]
    fn test_write_json_to_file() {
        // JSON 객체 생성 → 직렬화 → 파일 저장
        let obj = create_test_object();
        let json_str = json::json_stringify(&obj);
        let filename = "/tmp/test_freelang.json".to_string();

        match io::write_file(&filename, &json_str) {
            Ok(_) => {
                // 파일이 생성되었는지 확인
                match io::file_exists(&filename) {
                    Ok(FlValue::Bool(true)) => {
                        // 파일 크기 확인
                        let _ = io::file_size(&filename);
                        // 파일 삭제
                        let _ = io::delete_file(&filename);
                    }
                    _ => panic!("file_exists failed"),
                }
            }
            _ => panic!("write_file failed"),
        }
    }

    #[test]
    fn test_read_json_from_file() {
        // 파일 저장 → 읽기 → JSON 파싱
        let json_str = r#"{"test":123}"#.to_string();
        let filename = "/tmp/test_read_freelang.json".to_string();

        // 1. 파일 저장
        let _ = io::write_file(&filename, &json_str);

        // 2. 파일 읽기
        match io::read_file(&filename) {
            Ok(content) => {
                // 3. JSON 파싱
                match json::json_parse(&content) {
                    Ok(FlValue::Object(obj)) => {
                        assert!(obj.contains_key("test"));
                    }
                    _ => panic!("json_parse failed"),
                }
            }
            _ => panic!("read_file failed"),
        }

        // 정리
        let _ = io::delete_file(&filename);
    }

    #[test]
    fn test_append_json_logs() {
        // 로그 파일에 JSON 항목 추가
        let logfile = "/tmp/test_log_freelang.log".to_string();
        let timestamp = time::now_ms().unwrap_or(0);

        // JSON 로그 항목 생성
        let mut log_obj = HashMap::new();
        log_obj.insert("timestamp".to_string(), FlValue::Int(timestamp));
        log_obj.insert("message".to_string(), FlValue::Str("test".to_string()));
        let log_entry = json::json_stringify(&FlValue::Object(log_obj));

        // 로그 파일에 추가
        let _ = io::append_file(&logfile, &log_entry);
        let _ = io::append_file(&logfile, &"\n".to_string());

        // 정리
        let _ = io::delete_file(&logfile);
    }
}

