#[cfg(test)]
mod array_functional_pipeline {
    use super::*;

    #[test]
    fn test_array_map_transformation() {
        // 배열 생성 → map으로 변환
        let arr = FlValue::Array(vec![
            FlValue::Int(1),
            FlValue::Int(2),
            FlValue::Int(3),
        ]);

        // map: x → x * 2
        match array::map(&arr, |v: FlValue| {
            match v {
                FlValue::Int(n) => FlValue::Int(n * 2),
                _ => v,
            }
        }) {
            Ok(FlValue::Array(result)) => {
                assert_eq!(result.len(), 3);
                // 2, 4, 6 확인 (정렬 순서는 보장 안함)
                let has_2 = result.contains(&FlValue::Int(2));
                let has_4 = result.contains(&FlValue::Int(4));
                let has_6 = result.contains(&FlValue::Int(6));
                assert!(has_2 && has_4 && has_6);
            }
            _ => panic!("map failed"),
        }
    }

    #[test]
    fn test_array_filter_selection() {
        // 배열 생성 → filter로 선택
        let arr = FlValue::Array(vec![
            FlValue::Int(1),
            FlValue::Int(2),
            FlValue::Int(3),
            FlValue::Int(4),
            FlValue::Int(5),
        ]);

        // filter: x > 3
        match array::filter(&arr, |v: &FlValue| {
            matches!(v, FlValue::Int(n) if *n > 3)
        }) {
            Ok(FlValue::Array(result)) => {
                assert_eq!(result.len(), 2); // 4, 5만 통과
            }
            _ => panic!("filter failed"),
        }
    }

    #[test]
    fn test_array_reduce_aggregation() {
        // 배열 생성 → reduce로 집계
        let arr = FlValue::Array(vec![
            FlValue::Int(1),
            FlValue::Int(2),
            FlValue::Int(3),
            FlValue::Int(4),
        ]);

        // reduce: 합산 (init = 0)
        match array::reduce(&arr, |acc: FlValue, v: FlValue| {
            match (acc, v) {
                (FlValue::Int(a), FlValue::Int(b)) => FlValue::Int(a + b),
                _ => acc,
            }
        }, FlValue::Int(0)) {
            Ok(FlValue::Int(sum)) => {
                assert_eq!(sum, 10); // 1+2+3+4
            }
            _ => panic!("reduce failed"),
        }
    }

    #[test]
    fn test_array_chained_operations() {
        // map → filter → reduce 체인
        let arr = FlValue::Array(vec![
            FlValue::Int(1),
            FlValue::Int(2),
            FlValue::Int(3),
            FlValue::Int(4),
        ]);

        // Step 1: map (x2)
        let mapped = array::map(&arr, |v| {
            match v {
                FlValue::Int(n) => FlValue::Int(n * 2),
                _ => v,
            }
        }).unwrap_or(FlValue::Null);

        // Step 2: filter (> 3)
        let filtered = array::filter(&mapped, |v| {
            matches!(v, FlValue::Int(n) if *n > 3)
        }).unwrap_or(FlValue::Null);

        // Step 3: reduce (합산)
        let result = array::reduce(&filtered, |acc, v| {
            match (acc, v) {
                (FlValue::Int(a), FlValue::Int(b)) => FlValue::Int(a + b),
                _ => acc,
            }
        }, FlValue::Int(0)).unwrap_or(FlValue::Null);

        // (1*2=2, 2*2=4, 3*2=6, 4*2=8) → filter(>3) → (4, 6, 8) → sum=18
        match result {
            FlValue::Int(sum) => assert!(sum >= 18), // 정렬 순서 변동 고려
            _ => panic!("Expected Int result"),
        }
    }
}

