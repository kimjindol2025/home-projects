#[cfg(test)]
mod type_system_tests {
    use super::*;

    #[test]
    fn test_type_of_function() {
        // type_of로 값의 타입 확인
        let int_val = FlValue::Int(42);
        let float_val = FlValue::Float(3.14);
        let str_val = FlValue::Str("hello".to_string());
        let bool_val = FlValue::Bool(true);
        let null_val = FlValue::Null;

        assert_eq!(types::type_of(&int_val), "int".to_string());
        assert_eq!(types::type_of(&float_val), "float".to_string());
        assert_eq!(types::type_of(&str_val), "string".to_string());
        assert_eq!(types::type_of(&bool_val), "bool".to_string());
        assert_eq!(types::type_of(&null_val), "null".to_string());
    }

    #[test]
    fn test_type_conversion_chain() {
        // 타입 변환 체인
        let int_val = FlValue::Int(42);

        // Int → String
        match types::to_string(int_val.clone()) {
            Ok(FlValue::Str(s)) => {
                assert_eq!(s, "42");

                // String → Int
                match string::str_to_int(&s) {
                    Ok(FlValue::Int(n)) => assert_eq!(n, 42),
                    _ => panic!("str_to_int failed"),
                }
            }
            _ => panic!("to_string failed"),
        }
    }

    #[test]
    fn test_is_null_check() {
        let null_val = FlValue::Null;
        let non_null_val = FlValue::Int(0); // 0이지만 null이 아님

        match types::is_null(&null_val) {
            Ok(FlValue::Bool(true)) => {}
            _ => panic!("is_null(Null) should be true"),
        }

        match types::is_null(&non_null_val) {
            Ok(FlValue::Bool(false)) => {}
            _ => panic!("is_null(Int) should be false"),
        }
    }
}

