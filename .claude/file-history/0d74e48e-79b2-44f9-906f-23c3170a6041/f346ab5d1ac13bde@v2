/// 테스트용 JSON 객체 생성
fn create_test_object() -> FlValue {
    let mut map = HashMap::new();
    map.insert("name".to_string(), FlValue::Str("test".to_string()));
    map.insert("value".to_string(), FlValue::Int(42));
    map.insert("active".to_string(), FlValue::Bool(true));
    FlValue::Object(map)
}

/// 테스트용 배열 생성
fn create_test_array() -> FlValue {
    FlValue::Array(vec![
        FlValue::Int(1),
        FlValue::Int(2),
        FlValue::Int(3),
        FlValue::Int(4),
        FlValue::Int(5),
    ])
}

