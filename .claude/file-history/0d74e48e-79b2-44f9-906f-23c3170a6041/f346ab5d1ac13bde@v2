#[cfg(test)]
mod json_object_pipeline {
    use super::*;

    #[test]
    fn test_json_parse_to_object_access() {
        // JSON 문자열 파싱 → 객체 접근
        let json_str = r#"{"user":"kim","age":30,"active":true}"#.to_string();

        match json::json_parse(&json_str) {
            Ok(FlValue::Object(obj)) => {
                // 객체에서 각 필드 추출
                assert_eq!(obj.get("user"), Some(&FlValue::Str("kim".to_string())));
                assert_eq!(obj.get("age"), Some(&FlValue::Int(30)));
                assert_eq!(obj.get("active"), Some(&FlValue::Bool(true)));
            }
            _ => panic!("Expected JSON object"),
        }
    }

    #[test]
    fn test_json_to_string_conversion() {
        // JSON 파싱 → FlValue → 문자열 변환
        let json_str = r#"{"message":"hello"}"#.to_string();

        match json::json_parse(&json_str) {
            Ok(obj) => {
                let obj_str = obj.to_string_repr();
                assert!(obj_str.contains("object")); // "[object]" 표현
            }
            _ => panic!("Parse failed"),
        }
    }

    #[test]
    fn test_object_keys_values_iteration() {
        // 객체 생성 → keys/values 추출 → 반복
        let obj = create_test_object();

        match object::keys(obj.clone()) {
            Ok(FlValue::Array(keys)) => {
                assert_eq!(keys.len(), 3); // name, value, active
            }
            _ => panic!("keys() failed"),
        }

        match object::values(obj) {
            Ok(FlValue::Array(values)) => {
                assert_eq!(values.len(), 3);
                // 값에 Int, Str, Bool 포함
                let has_int = values.iter().any(|v| matches!(v, FlValue::Int(_)));
                let has_str = values.iter().any(|v| matches!(v, FlValue::Str(_)));
                let has_bool = values.iter().any(|v| matches!(v, FlValue::Bool(_)));
                assert!(has_int && has_str && has_bool);
            }
            _ => panic!("values() failed"),
        }
    }

    #[test]
    fn test_json_merge_workflow() {
        // JSON 파싱 → merge → 직렬화
        let json1 = r#"{"a":1,"b":2}"#.to_string();
        let json2 = r#"{"b":20,"c":3}"#.to_string();

        let obj1 = json::json_parse(&json1).unwrap_or(FlValue::Null);
        let obj2 = json::json_parse(&json2).unwrap_or(FlValue::Null);

        match object::merge(obj1, obj2) {
            Ok(merged) => {
                // merged = {"a":1, "b":20, "c":3}
                let result_str = json::json_stringify(&merged);
                assert!(result_str.contains("\"a\":1") || result_str.contains("\"a\": 1"));
                assert!(result_str.contains("\"b\":20") || result_str.contains("\"b\": 20"));
                assert!(result_str.contains("\"c\":3") || result_str.contains("\"c\": 3"));
            }
            _ => panic!("merge failed"),
        }
    }
}

