#[cfg(test)]
mod math_type_conversion {
    use super::*;

    #[test]
    fn test_math_operations_with_conversion() {
        // 문자열 → 숫자 변환 → 수학 연산 → 다시 문자열
        let num_str = "16".to_string();

        // 1. 문자열 → 정수
        match string::str_to_int(&num_str) {
            Ok(FlValue::Int(n)) => {
                // 2. 수학 연산: sqrt(16) = 4
                let sqrt_result = math::sqrt(FlValue::Float(n as f64));

                // 3. 결과 확인
                match sqrt_result {
                    FlValue::Float(f) => {
                        assert!((f - 4.0).abs() < 0.001); // 약 4
                    }
                    _ => panic!("Expected Float"),
                }
            }
            _ => panic!("str_to_int failed"),
        }
    }

    #[test]
    fn test_trigonometric_calculations() {
        // 삼각함수 계산
        let pi = std::f64::consts::PI;

        // sin(π/2) ≈ 1
        let sin_result = math::sin(FlValue::Float(pi / 2.0));
        match sin_result {
            FlValue::Float(f) => assert!((f - 1.0).abs() < 0.001),
            _ => panic!("sin failed"),
        }

        // cos(π) ≈ -1
        let cos_result = math::cos(FlValue::Float(pi));
        match cos_result {
            FlValue::Float(f) => assert!((f + 1.0).abs() < 0.001),
            _ => panic!("cos failed"),
        }
    }

    #[test]
    fn test_logarithmic_operations() {
        // 로그 연산: log10(100) = 2
        let log_result = math::log10(FlValue::Float(100.0));
        match log_result {
            FlValue::Float(f) => assert!((f - 2.0).abs() < 0.001),
            _ => panic!("log10 failed"),
        }
    }

    #[test]
    fn test_min_max_clamp() {
        // min/max/clamp 유틸
        let a = FlValue::Int(10);
        let b = FlValue::Int(20);

        let min_result = math::min(a.clone(), b.clone());
        match min_result {
            FlValue::Int(n) => assert_eq!(n, 10),
            _ => panic!("min failed"),
        }

        let max_result = math::max(a, b);
        match max_result {
            FlValue::Int(n) => assert_eq!(n, 20),
            _ => panic!("max failed"),
        }

        // clamp: value in [min, max]
        let clamped = math::clamp(FlValue::Int(15), FlValue::Int(5), FlValue::Int(10));
        match clamped {
            FlValue::Int(n) => assert_eq!(n, 10), // max로 제한됨
            _ => panic!("clamp failed"),
        }
    }
}

