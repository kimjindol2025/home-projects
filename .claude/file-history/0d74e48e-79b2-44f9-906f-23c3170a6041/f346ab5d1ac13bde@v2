#[cfg(test)]
mod time_system_integration {
    use super::*;

    #[test]
    fn test_time_measurements() {
        // 시간 측정: elapsed time 계산
        let t1 = time::now_ms().unwrap_or(0);

        // 간단한 지연
        std::thread::sleep(std::time::Duration::from_millis(10));

        let t2 = time::now_ms().unwrap_or(0);
        let elapsed = t2 - t1;

        // 최소 10ms 이상 경과했어야 함
        assert!(elapsed >= 9); // 약간의 오차 허용
    }

    #[test]
    fn test_time_formatting() {
        // 타임스탬프 포맷팅
        let timestamp = 1234567890i64 * 1000; // 2009-02-13

        match time::format_time(timestamp, "ISO".to_string()) {
            Ok(formatted) => {
                // ISO 형식 확인
                assert!(formatted.contains("2009"));
                assert!(formatted.contains("UTC"));
            }
            _ => panic!("format_time failed"),
        }
    }

    #[test]
    fn test_system_info_retrieval() {
        // 시스템 정보 조회
        let args = system::args().unwrap_or(FlValue::Null);

        match args {
            FlValue::Array(argv) => {
                // argv[0]은 프로그램 이름
                assert!(!argv.is_empty());
                assert!(matches!(argv[0], FlValue::Str(_)));
            }
            _ => panic!("args() should return array"),
        }
    }

    #[test]
    fn test_environment_variables() {
        // 환경변수 설정 → 읽기
        let key = "FREELANG_TEST_VAR".to_string();
        let value = "test_value_123".to_string();

        // 설정
        let _ = system::setenv(key.clone(), value.clone());

        // 읽기
        match system::getenv(key) {
            Ok(retrieved) => {
                assert_eq!(retrieved, value);
            }
            _ => panic!("getenv failed"),
        }
    }
}

