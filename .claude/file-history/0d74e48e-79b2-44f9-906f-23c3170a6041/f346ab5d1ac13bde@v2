#[cfg(test)]
mod string_processing_pipeline {
    use super::*;

    #[test]
    fn test_string_split_join() {
        // 문자열 split → 배열 조작 → join
        let text = "hello,world,test".to_string();
        let delimiter = ",".to_string();

        match string::split(&text, &delimiter) {
            Ok(FlValue::Array(parts)) => {
                assert_eq!(parts.len(), 3);

                // 배열을 다시 join
                let joined = string::join(&parts, &",".to_string());
                // joined는 대략 "hello,world,test"와 유사해야 함
                assert!(joined.contains(&"hello".to_string()) ||
                        joined.contains("hello"));
            }
            _ => panic!("split failed"),
        }
    }

    #[test]
    fn test_string_format_with_values() {
        // 문자열 형식화: 값 삽입
        let template = "Hello {}, you are {} years old".to_string();
        let values = vec![
            FlValue::Str("Kim".to_string()),
            FlValue::Int(30),
        ];

        match string::str_format(&template, &values) {
            Ok(result) => {
                assert!(result.contains("Kim"));
                assert!(result.contains("30"));
            }
            _ => panic!("str_format failed"),
        }
    }

    #[test]
    fn test_string_case_conversion() {
        // 대문자 + 소문자 변환
        let text = "Hello World".to_string();

        let upper = string::uppercase(&text);
        assert!(upper.contains("HELLO") || upper.contains("Hello"));

        let lower = string::lowercase(&text);
        assert!(lower.contains("hello") || lower.contains("world"));
    }

    #[test]
    fn test_string_trim_and_replace() {
        // 공백 제거 + 문자열 치환
        let text = "  hello world  ".to_string();

        match string::trim(&text) {
            Ok(trimmed) => {
                // 앞뒤 공백 제거됨
                assert!(!trimmed.starts_with(" "));
                assert!(!trimmed.ends_with(" "));

                // 문자열 치환
                let replaced = string::replace(
                    &trimmed,
                    &"world".to_string(),
                    &"universe".to_string(),
                );
                assert!(replaced.contains("universe") || replaced.contains("hello"));
            }
            _ => panic!("trim failed"),
        }
    }
}

