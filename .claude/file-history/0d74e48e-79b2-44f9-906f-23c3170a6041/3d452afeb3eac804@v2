#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_channel_create() {
        let (tx, rx) = channel::<i32>();
        // 채널 생성 성공
        drop(tx);
        drop(rx);
    }

    #[test]
    fn test_channel_send_recv() {
        let (tx, rx) = channel::<i32>();

        tx.send(42).unwrap();
        let msg = rx.recv().unwrap();
        assert_eq!(msg, 42);
    }

    #[test]
    fn test_channel_multiple_sends() {
        let (tx, rx) = channel::<String>();

        tx.send("hello".to_string()).unwrap();
        tx.send("world".to_string()).unwrap();

        assert_eq!(rx.recv().unwrap(), "hello");
        assert_eq!(rx.recv().unwrap(), "world");
    }

    #[test]
    fn test_channel_sender_clone() {
        let (tx, rx) = channel::<i32>();
        let tx2 = tx.clone();

        tx.send(1).unwrap();
        tx2.send(2).unwrap();

        assert_eq!(rx.recv().unwrap(), 1);
        assert_eq!(rx.recv().unwrap(), 2);
    }

    #[test]
    fn test_channel_try_recv_empty() {
        let (tx, rx) = channel::<i32>();

        match rx.try_recv() {
            Err(RecvError::SenderDropped) => {},
            _ => panic!("Expected SenderDropped"),
        }

        drop(tx);
    }

    #[test]
    fn test_channel_try_recv_disconnected() {
        let (tx, rx) = channel::<i32>();
        drop(tx);

        match rx.try_recv() {
            Err(RecvError::Disconnected) => {},
            _ => panic!("Expected Disconnected"),
        }
    }

    #[test]
    fn test_channel_pending() {
        let (tx, rx) = channel::<i32>();

        assert_eq!(rx.pending(), 0);

        tx.send(1).unwrap();
        assert_eq!(rx.pending(), 1);

        tx.send(2).unwrap();
        assert_eq!(rx.pending(), 2);

        rx.recv().unwrap();
        assert_eq!(rx.pending(), 1);
    }

    #[test]
    fn test_channel_is_closed() {
        let (tx, rx) = channel::<i32>();

        assert!(!rx.is_closed());

        drop(tx);

        assert!(rx.is_closed());
    }

    #[test]
    fn test_channel_multiple_producers() {
        let (tx, rx) = channel::<i32>();
        let tx2 = tx.clone();
        let tx3 = tx.clone();

        std::thread::spawn(move || {
            tx.send(1).unwrap();
        });

        std::thread::spawn(move || {
            tx2.send(2).unwrap();
        });

        std::thread::spawn(move || {
            tx3.send(3).unwrap();
        });

        let mut results = Vec::new();
        for _ in 0..3 {
            if let Ok(msg) = rx.try_recv() {
                results.push(msg);
            }
        }

        // 모든 메시지가 수신되어야 함
        assert!(results.len() > 0);
    }

    #[test]
    fn test_channel_recv_timeout() {
        let (tx, rx) = channel::<i32>();

        let timeout = Duration::from_millis(100);

        // 타임아웃: 메시지 없음
        match rx.recv_timeout(timeout) {
            Err(RecvError::Timeout) | Err(RecvError::SenderDropped) => {},
            _ => panic!("Expected timeout or sender dropped"),
        }

        drop(tx);
    }

    #[test]
    fn test_channel_send_after_sender_drop() {
        let (tx, rx) = channel::<i32>();
        drop(tx);

        // 모든 송신자가 drop됨
        assert!(rx.is_closed());
    }

    #[test]
    fn test_channel_disconnected_error() {
        let (tx, _rx) = channel::<i32>();
        drop(_rx);

        match tx.send(42) {
            Err(SendError::Disconnected(42)) => {},
            _ => panic!("Expected Disconnected"),
        }
    }

    #[test]
    fn test_channel_large_messages() {
        let (tx, rx) = channel::<Vec<i32>>();

        let large_vec = vec![1, 2, 3, 4, 5];
        tx.send(large_vec.clone()).unwrap();

        let received = rx.recv().unwrap();
        assert_eq!(received, large_vec);
    }

    #[test]
    fn test_channel_string_messages() {
        let (tx, rx) = channel::<String>();

        tx.send("Hello, World!".to_string()).unwrap();
        assert_eq!(rx.recv().unwrap(), "Hello, World!");
    }

    #[test]
    fn test_channel_sequential() {
        let (tx, rx) = channel::<i32>();

        for i in 0..10 {
            tx.send(i).unwrap();
        }

        for i in 0..10 {
            assert_eq!(rx.recv().unwrap(), i);
        }
    }
}

