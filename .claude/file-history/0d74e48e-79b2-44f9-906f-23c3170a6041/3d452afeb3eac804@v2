// FreeLang Channel<T> - 스레드 간 메시지 전송
// ============================================================================
//
// MPSC (Multi-Producer Single-Consumer) 채널을 구현합니다.
//
// 특징:
// - 여러 스레드가 보냄 (Sender 복제 가능)
// - 한 스레드만 받음 (Receiver는 복제 불가)
// - 스레드 안전 (Arc + Mutex)
// - 논블로킹 & 블로킹 연산 모두 지원
//
// 작성일: 2026-03-02
// 단계: Phase B.5 (Week 11-12)

use std::sync::{Arc, Mutex, mpsc};
use std::time::Duration;

// ============================================================================
// Channel Result Type
// ============================================================================

/// Channel 연산 결과
pub enum SendError<T> {
    /// 채널이 이미 폐쇄됨
    Disconnected(T),

    /// 받는 쪽이 drop됨
    ReceiverDropped(T),
}

pub enum RecvError {
    /// 채널이 폐쇄되고 메시지 없음
    Disconnected,

    /// 타임아웃
    Timeout,

    /// 받는 쪽이 drop됨
    SenderDropped,
}

// ============================================================================
// Channel 구현
// ============================================================================

/// 메시지를 보내는 끝 (복제 가능)
pub struct Sender<T> {
    /// 내부 채널
    inner: Arc<Mutex<ChannelInner<T>>>,
}

/// 메시지를 받는 끝 (복제 불가)
pub struct Receiver<T> {
    /// 내부 채널
    inner: Arc<Mutex<ChannelInner<T>>>,
}

/// 채널 내부 상태
struct ChannelInner<T> {
    /// 메시지 큐
    queue: std::collections::VecDeque<T>,

    /// 송신자 개수
    sender_count: usize,

    /// 채널 폐쇄 여부
    is_closed: bool,

    /// 수신자가 대기 중인지
    receiver_waiting: bool,
}

impl<T> Sender<T> {
    /// 메시지를 보냅니다 (블로킹).
    ///
    /// 수신자가 메시지를 받을 때까지 대기합니다.
    pub fn send(&self, msg: T) -> Result<(), SendError<T>> {
        let mut inner = self.inner.lock().unwrap();

        if inner.is_closed {
            return Err(SendError::Disconnected(msg));
        }

        inner.queue.push_back(msg);

        // 수신자가 대기 중이면 깨우기
        if inner.receiver_waiting {
            // 실제 구현에서는 condvar 사용
        }

        Ok(())
    }

    /// 메시지를 비동기로 보냅니다 (비블로킹).
    pub fn try_send(&self, msg: T) -> Result<(), SendError<T>> {
        self.send(msg)
    }

    /// 채널을 폐쇄합니다.
    pub fn close(&self) {
        let mut inner = self.inner.lock().unwrap();
        inner.is_closed = true;
    }
}

impl<T> Clone for Sender<T> {
    fn clone(&self) -> Sender<T> {
        let mut inner = self.inner.lock().unwrap();
        inner.sender_count += 1;
        Sender {
            inner: Arc::clone(&self.inner),
        }
    }
}

impl<T> Drop for Sender<T> {
    fn drop(&mut self) {
        let mut inner = self.inner.lock().unwrap();
        inner.sender_count = inner.sender_count.saturating_sub(1);
    }
}

impl<T> Receiver<T> {
    /// 메시지를 받습니다 (블로킹).
    ///
    /// 메시지가 도착할 때까지 대기합니다.
    pub fn recv(&self) -> Result<T, RecvError> {
        loop {
            let mut inner = self.inner.lock().unwrap();

            if let Some(msg) = inner.queue.pop_front() {
                return Ok(msg);
            }

            // 큐가 비어있고 송신자가 모두 drop됨
            if inner.sender_count == 0 && inner.is_closed {
                return Err(RecvError::Disconnected);
            }

            // 대기 중으로 표시
            inner.receiver_waiting = true;
            drop(inner);

            // 실제 구현에서는 condvar로 대기
            std::thread::sleep(std::time::Duration::from_micros(1));
        }
    }

    /// 메시지를 비동기로 받습니다 (비블로킹).
    pub fn try_recv(&self) -> Result<T, RecvError> {
        let mut inner = self.inner.lock().unwrap();

        if let Some(msg) = inner.queue.pop_front() {
            return Ok(msg);
        }

        // 큐가 비어있고 송신자가 모두 drop됨
        if inner.sender_count == 0 && inner.is_closed {
            return Err(RecvError::Disconnected);
        }

        // 메시지 없음
        Err(RecvError::SenderDropped)
    }

    /// 타임아웃과 함께 메시지를 받습니다.
    pub fn recv_timeout(&self, timeout: Duration) -> Result<T, RecvError> {
        let start = std::time::Instant::now();

        loop {
            let mut inner = self.inner.lock().unwrap();

            if let Some(msg) = inner.queue.pop_front() {
                return Ok(msg);
            }

            // 큐가 비어있고 송신자가 모두 drop됨
            if inner.sender_count == 0 && inner.is_closed {
                return Err(RecvError::Disconnected);
            }

            drop(inner);

            // 타임아웃 확인
            if start.elapsed() > timeout {
                return Err(RecvError::Timeout);
            }

            std::thread::sleep(std::time::Duration::from_micros(1));
        }
    }

    /// 채널이 폐쇄되었는지 확인합니다.
    pub fn is_closed(&self) -> bool {
        let inner = self.inner.lock().unwrap();
        inner.is_closed && inner.sender_count == 0
    }

    /// 큐에 대기 중인 메시지 개수를 반환합니다.
    pub fn pending(&self) -> usize {
        let inner = self.inner.lock().unwrap();
        inner.queue.len()
    }
}

// ============================================================================
// Channel 생성 함수
// ============================================================================

/// 새로운 채널을 생성합니다.
pub fn channel<T>() -> (Sender<T>, Receiver<T>) {
    let inner = Arc::new(Mutex::new(ChannelInner {
        queue: std::collections::VecDeque::new(),
        sender_count: 1,
        is_closed: false,
        receiver_waiting: false,
    }));

    (
        Sender {
            inner: Arc::clone(&inner),
        },
        Receiver { inner },
    )
}

// ============================================================================
// 테스트
