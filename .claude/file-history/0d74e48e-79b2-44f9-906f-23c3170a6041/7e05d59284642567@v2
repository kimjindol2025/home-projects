fn testAdminRole
  input: void
  output: bool
  intent: \"관리자 역할 권한 테스트\"
  do
    let adminUser = {
      id: 1,
      email: \"admin@example.com\",
      passwordHash: \"\",
      name: \"Admin\",
      role: \"admin\",
      isActive: true,
      createdAt: 0,
      updatedAt: 0,
      lastLoginAt: 0
    }

    return hasPermission(adminUser, \"ADMIN\") &&
           hasPermission(adminUser, \"DELETE\") &&
           hasPermission(adminUser, \"CREATE\")

fn testUserRole
  input: void
  output: bool
  intent: \"일반 사용자 역할 권한 테스트\"
  do
    let regularUser = {
      id: 2,
      email: \"user@example.com\",
      passwordHash: \"\",
      name: \"User\",
      role: \"user\",
      isActive: true,
      createdAt: 0,
      updatedAt: 0,
      lastLoginAt: 0
    }

    return hasPermission(regularUser, \"CREATE\") &&
           hasPermission(regularUser, \"UPDATE\") &&
           !hasPermission(regularUser, \"ADMIN\")

