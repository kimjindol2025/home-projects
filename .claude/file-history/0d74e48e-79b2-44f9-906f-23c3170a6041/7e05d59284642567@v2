  intent: \"권한 거부 테스트\"
  do
    let guestUser = {
      id: 3,
      email: \"guest@example.com\",
      passwordHash: \"\",
      name: \"Guest\",
      role: \"guest\",
      isActive: true,
      createdAt: 0,
