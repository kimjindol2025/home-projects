struct ProtoSchema
  name: string
  fields: array<ProtoField>

struct ProtoField
  fieldNumber: number           # 1-536870911
  name: string
  fieldType: string             # "int32", "int64", "string", "bytes", "bool", "message"
  fieldLabel: string            # "optional", "repeated", "required"
  defaultValue: string

struct ProtoMessage
  fieldNumber: number
  data: array<number>           # 바이트 배열

struct ProtoDecoder
  bytes: array<number>
  index: number                 # 현재 읽는 위치

# Wire Type 정의
# 0: Varint          (int32, int64, uint32, uint64, sint32, sint64, bool, enum)
# 1: 64-bit fixed    (double, sfixed64)
# 2: Length-delimited (string, bytes, embedded messages, packed repeated fields)
# 3: Start group     (deprecated)
# 4: End group       (deprecated)
# 5: 32-bit fixed    (float, sfixed32)

# ─────────────────────────────────────────────────────────────────────────
# Varint 인코딩 (가변 길이 정수)
# ─────────────────────────────────────────────────────────────────────────

fn encodeVarint
  input: num: number
  output: array<number>
  intent: "숫자를 Varint로 인코딩"
  do
    let bytes = []
    let value = num

    while value > 127
      # 하위 7비트 추출 + continuation bit (bit 7)
      let byte = (value % 128) + 128
      bytes = arrayPush(bytes, byte)
      value = value / 128

    # 마지막 바이트 (continuation bit 없음)
    bytes = arrayPush(bytes, value % 128)

    return bytes

fn decodeVarint
  input: (bytes: array<number>, startIndex: number)
  output: (number, number)  # (value, nextIndex)
  intent: "Varint 디코딩"
  do
    let value = 0
    let shift = 0
    let index = startIndex

    # 각 바이트 처리
    # for byte in bytes from startIndex
    #   value = value + ((byte % 128) * (2 ^ shift))
    #   shift = shift + 7
    #   if byte < 128: break  # continuation bit 확인
    #   index = index + 1

    return (value, index)

# ─────────────────────────────────────────────────────────────────────────
# Zigzag 인코딩 (음수 처리)
# ─────────────────────────────────────────────────────────────────────────

fn encodeZigzag
  input: num: number
  output: number
  intent: "정수를 Zigzag으로 인코딩 (음수 처리)"
  do
    # Zigzag: n -> (n << 1) ^ (n >> 31)
    # FreeLang에서 간단하게:
    if num >= 0
      return num * 2
    else
      return (num * 2) - 1

fn decodeZigzag
  input: num: number
  output: number
  intent: "Zigzag 디코딩"
  do
    # Zigzag 복원: (n >> 1) ^ (-(n & 1))
    if num % 2 == 0
      return num / 2
    else
      return -(num / 2) - 1

# ─────────────────────────────────────────────────────────────────────────
# 필드 키 (Field Tag)
# ─────────────────────────────────────────────────────────────────────────

fn encodeFieldTag
  input: (fieldNumber: number, wireType: number)
  output: array<number>
  intent: "필드 태그 (field number + wire type) 인코딩"
  do
    # tag = (fieldNumber << 3) | wireType
    let tag = (fieldNumber * 8) + wireType
    return encodeVarint(tag)

fn decodeFieldTag
  input: tag: number
  output: (number, number)  # (fieldNumber, wireType)
  intent: "필드 태그 디코딩"
  do
    let fieldNumber = tag / 8
    let wireType = tag % 8
    return (fieldNumber, wireType)

# ─────────────────────────────────────────────────────────────────────────
# Wire Type 매핑
# ─────────────────────────────────────────────────────────────────────────

fn getWireType
  input: fieldType: string
  output: number
  intent: "필드 타입에 해당하는 Wire type 결정"
  do
    match fieldType
      "int32" => 0      # Varint
      "int64" => 0      # Varint
      "uint32" => 0     # Varint
      "uint64" => 0     # Varint
      "sint32" => 0     # Varint (Zigzag)
      "sint64" => 0     # Varint (Zigzag)
      "bool" => 0       # Varint
      "enum" => 0       # Varint
      "double" => 1     # 64-bit fixed
      "sfixed64" => 1   # 64-bit fixed
      "float" => 5      # 32-bit fixed
      "sfixed32" => 5   # 32-bit fixed
      "string" => 2     # Length-delimited
      "bytes" => 2      # Length-delimited
      "message" => 2    # Length-delimited
      _ => 2            # Default: Length-delimited

