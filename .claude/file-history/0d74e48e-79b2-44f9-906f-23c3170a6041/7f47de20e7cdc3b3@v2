fn encodeField
  input: (field: ProtoField, value: string)
  output: array<number>
  intent: "필드 값 인코딩"
  do
    let fieldBytes = []

    # 필드 태그 인코딩
    let wireType = getWireType(field.fieldType)
    let tagBytes = encodeFieldTag(field.fieldNumber, wireType)
    fieldBytes = appendBytes(fieldBytes, tagBytes)

    # 값 인코딩
    match field.fieldType
      "int32" => {
        # Varint 인코딩
        # let numValue = stringToNumber(value)
        # let valueBytes = encodeVarint(numValue)
        # fieldBytes = appendBytes(fieldBytes, valueBytes)
      }
      "string" => {
        # Length-delimited: 길이 + 데이터
        let length = stringLen(value)
        let lengthBytes = encodeVarint(length)
        fieldBytes = appendBytes(fieldBytes, lengthBytes)
        # fieldBytes = appendString(fieldBytes, value)
      }
      "bytes" => {
        # Length-delimited
        let length = arrayLen(value)
        let lengthBytes = encodeVarint(length)
        fieldBytes = appendBytes(fieldBytes, lengthBytes)
      }
      _ => {}

    return fieldBytes

