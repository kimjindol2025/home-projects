fn createUser
  input: (email: string, password: string, name: string)
  output: Result<User, string>
  intent: \"새 사용자 생성\"
  do
    # 입력 검증
    match validateEmail(email)
      Err(e) => return Err(e)
      Ok(_) => {}

    match validatePassword(password)
      Err(e) => return Err(e)
      Ok(_) => {}

    match validateName(name)
      Err(e) => return Err(e)
      Ok(_) => {}

    # 중복 이메일 확인
    # match findUserByEmail(email)
    #   Some(_) => return Err(\"Email already exists\")
    #   None => {}

    # 비밀번호 해싱
    match hashPassword(password, 10)
      Ok(hash) => {
        let now = getCurrentTimestamp()
        let user = {
          id: 0,                  # DB에서 할당
          email: email,
          passwordHash: hash,
          name: name,
          role: \"user\",          # 기본값
          isActive: true,
          createdAt: now,
          updatedAt: now,
          lastLoginAt: 0
        }
        Ok(user)
      }
      Err(e) => Err(\"Failed to hash password: \" + e)

fn createAdmin
  input: (email: string, password: string, name: string)
  output: Result<User, string>
  intent: \"관리자 사용자 생성\"
  do
    match createUser(email, password, name)
      Ok(user) => {
        let admin = user
        admin.role = \"admin\"
        Ok(admin)
      }
      Err(e) => Err(e)

