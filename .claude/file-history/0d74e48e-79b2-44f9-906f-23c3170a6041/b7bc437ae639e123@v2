/// FreeLang 런타임의 메인 진입점
///
/// 소스코드를 실행하기 위한 모든 기능을 제공합니다:
/// - 파일 실행
/// - REPL 모드
/// - 스크립트 실행
/// - 에러 처리
pub struct FreeLangRuntime {
    /// 메인 평가기
    evaluator: Evaluator,

    /// 실행 옵션
    config: RuntimeConfig,

    /// 실행 통계
    statistics: RuntimeStatistics,

    /// 에러 히스토리
    errors: Vec<RuntimeError>,
}

/// 런타임 설정
#[derive(Clone, Debug)]
pub struct RuntimeConfig {
    /// 디버그 모드 활성화
    pub debug: bool,

    /// 최대 스택 깊이
    pub max_stack_depth: usize,

    /// 최대 메모리 (MB)
    pub max_memory_mb: usize,

    /// 타임아웃 (초)
    pub timeout_secs: u64,

    /// 색상 출력 지원
    pub color_output: bool,
}

impl Default for RuntimeConfig {
    fn default() -> Self {
        RuntimeConfig {
            debug: false,
            max_stack_depth: 10000,
            max_memory_mb: 512,
            timeout_secs: 300,
            color_output: true,
        }
    }
}

/// 런타임 실행 통계
#[derive(Clone, Debug, Default)]
pub struct RuntimeStatistics {
    /// 실행된 코드 라인 수
    pub lines_executed: usize,

    /// 발생한 에러 수
    pub errors_count: usize,

    /// 경고 수
    pub warnings_count: usize,

    /// 정의된 함수 수
    pub functions_count: usize,

    /// 정의된 변수 수
    pub variables_count: usize,

    /// 실행 시간 (밀리초)
    pub execution_time_ms: u128,
}

impl std::fmt::Display for RuntimeStatistics {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        write!(f,
            "📊 Runtime Statistics:\n  Lines: {}\n  Errors: {}\n  Warnings: {}\n  Functions: {}\n  Variables: {}\n  Time: {}ms",
            self.lines_executed,
            self.errors_count,
            self.warnings_count,
            self.functions_count,
            self.variables_count,
            self.execution_time_ms
        )
    }
}

impl FreeLangRuntime {
    /// 새로운 런타임을 생성합니다
    pub fn new() -> Self {
        FreeLangRuntime::with_config(RuntimeConfig::default())
    }

    /// 사용자 정의 설정으로 런타임을 생성합니다
    pub fn with_config(config: RuntimeConfig) -> Self {
        FreeLangRuntime {
            evaluator: Evaluator::new(),
            config,
            statistics: RuntimeStatistics::default(),
            errors: Vec::new(),
        }
    }

    // ========================================================================
    // 메인 실행 인터페이스
    // ========================================================================

    /// 소스코드를 실행합니다
    ///
    /// # 예제
    /// ```
    /// let mut runtime = FreeLangRuntime::new();
    /// let result = runtime.execute_source("let x = 42");
    /// assert!(result.is_ok());
    /// ```
    pub fn execute_source(&mut self, source: &str) -> Result<FlValue, RuntimeError> {
        let start_time = std::time::Instant::now();

        // Lexer → Parser → Evaluator 파이프라인
        match self.evaluator.eval_program(source) {
            Ok(result) => {
                self.statistics.lines_executed += source.lines().count();
                self.statistics.execution_time_ms = start_time.elapsed().as_millis();
                Ok(result)
            },
            Err(e) => {
                self.errors.push(e.clone());
                self.statistics.errors_count += 1;
                Err(e)
            }
        }
    }

    /// 파일을 실행합니다
    ///
    /// # 예제
    /// ```
    /// let mut runtime = FreeLangRuntime::new();
    /// let result = runtime.execute_file("program.fl");
    /// ```
    pub fn execute_file<P: AsRef<Path>>(&mut self, path: P) -> Result<FlValue, RuntimeError> {
        let content = fs::read_to_string(&path)
            .map_err(|e| RuntimeError::Runtime(
                format!("Failed to read file: {}", e)
            ))?;

        self.execute_source(&content)
    }

    /// 여러 소스코드를 순차 실행합니다
    pub fn execute_batch(&mut self, sources: Vec<&str>) -> Vec<Result<FlValue, RuntimeError>> {
        sources.into_iter()
            .map(|src| self.execute_source(src))
            .collect()
    }

    /// REPL 모드를 시작합니다
    pub fn start_repl(&mut self) {
        let mut repl = Repl::new();
        repl.start();
    }

    // ========================================================================
    // 환경 조회 & 관리
    // ========================================================================

    /// 변수의 값을 조회합니다
    pub fn get_variable(&self, name: &str) -> Option<FlValue> {
        self.evaluator.get_variable(name)
    }

    /// 변수를 설정합니다
    pub fn set_variable(&mut self, name: String, value: FlValue) {
        self.evaluator.set_variable(name, value);
    }

    /// 모든 정의된 변수를 반환합니다
    pub fn get_all_variables(&self) -> HashMap<String, FlValue> {
        self.evaluator.get_all_variables()
    }

    /// 환경을 초기화합니다
    pub fn reset_environment(&mut self) {
        self.evaluator.reset_environment();
        self.statistics = RuntimeStatistics::default();
        self.errors.clear();
    }

    // ========================================================================
    // 통계 & 진단
    // ========================================================================

    /// 런타임 통계를 반환합니다
    pub fn get_statistics(&self) -> RuntimeStatistics {
        self.statistics.clone()
    }

    /// 에러 히스토리를 반환합니다
    pub fn get_errors(&self) -> Vec<RuntimeError> {
        self.errors.clone()
    }

    /// 마지막 에러를 반환합니다
    pub fn last_error(&self) -> Option<RuntimeError> {
        self.errors.last().cloned()
    }

    /// 런타임 설정을 반환합니다
    pub fn config(&self) -> &RuntimeConfig {
        &self.config
    }

    /// 런타임 설정을 변경합니다
    pub fn set_config(&mut self, config: RuntimeConfig) {
        self.config = config;
    }

    /// 현재 상태 정보를 출력합니다
    pub fn print_status(&self) {
        println!("📊 FreeLang Runtime Status");
        println!("  Lines executed: {}", self.statistics.lines_executed);
        println!("  Errors: {}", self.statistics.errors_count);
        println!("  Variables: {}", self.statistics.variables_count);
        println!("  Execution time: {}ms", self.statistics.execution_time_ms);
    }

    // ========================================================================
    // 유틸리티 함수
    // ========================================================================

    /// 소스코드를 파싱하여 AST를 반환합니다 (평가하지 않음)
    pub fn parse_only(&self, source: &str) -> Result<(), RuntimeError> {
        self.evaluator.parse_only(source)
    }

    /// 현재 환경의 메모리 크기를 추정합니다 (바이트)
    pub fn estimated_memory_usage(&self) -> usize {
        self.evaluator.estimated_memory_usage()
    }

    /// 런타임을 초기화합니다
    pub fn initialize(&mut self) {
        // 표준 라이브러리 로드 (자동)
        // sync 모듈 로드 (자동)
