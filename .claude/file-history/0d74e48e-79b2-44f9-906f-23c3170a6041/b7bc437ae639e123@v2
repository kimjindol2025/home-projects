// ExecutionContext: 실행 컨텍스트
// ============================================================================

/// 현재 실행 상태를 나타냅니다
#[derive(Clone, Debug)]
pub struct ExecutionContext {
    /// 현재 실행 중인 파일
    pub current_file: Option<String>,

    /// 현재 라인 번호
    pub current_line: usize,

    /// 현재 컬럼 번호
    pub current_column: usize,

    /// 콜 스택
    pub call_stack: Vec<String>,

    /// 로컬 변수
    pub local_variables: HashMap<String, FlValue>,
}

impl ExecutionContext {
    pub fn new() -> Self {
        ExecutionContext {
            current_file: None,
            current_line: 0,
            current_column: 0,
            call_stack: Vec::new(),
            local_variables: HashMap::new(),
        }
    }

    pub fn push_call(&mut self, function_name: String) {
        self.call_stack.push(function_name);
    }

    pub fn pop_call(&mut self) -> Option<String> {
        self.call_stack.pop()
    }

    pub fn call_stack_depth(&self) -> usize {
        self.call_stack.len()
    }
}

