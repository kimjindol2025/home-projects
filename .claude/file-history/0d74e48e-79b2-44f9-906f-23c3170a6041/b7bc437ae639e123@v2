/// 소스코드를 즉시 실행합니다 (RuntimeConfig 불필요)
pub fn run(source: &str) -> Result<FlValue, RuntimeError> {
    let mut runtime = FreeLangRuntime::new();
    runtime.execute_source(source)
}

/// 파일을 즉시 실행합니다
pub fn run_file<P: AsRef<Path>>(path: P) -> Result<FlValue, RuntimeError> {
    let mut runtime = FreeLangRuntime::new();
    runtime.execute_file(path)
}

