#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_runtime_creation() {
        let runtime = FreeLangRuntime::new();
        assert!(runtime.config.debug == false);
    }

    #[test]
    fn test_runtime_with_config() {
        let config = RuntimeConfig::development();
        let runtime = FreeLangRuntime::with_config(config);
        assert!(runtime.config.debug == true);
    }

    #[test]
    fn test_execute_simple_integer() {
        let mut runtime = FreeLangRuntime::new();
        let result = runtime.execute_source("42");
        assert!(result.is_ok());
    }

    #[test]
    fn test_execute_string() {
        let mut runtime = FreeLangRuntime::new();
        let result = runtime.execute_source("\"hello\"");
        assert!(result.is_ok());
    }

    #[test]
    fn test_execute_variable_binding() {
        let mut runtime = FreeLangRuntime::new();
        let result = runtime.execute_source("let x = 42");
        assert!(result.is_ok());
    }

    #[test]
    fn test_execute_arithmetic() {
        let mut runtime = FreeLangRuntime::new();
        let result = runtime.execute_source("5 + 3");
        assert!(result.is_ok());
    }

    #[test]
    fn test_multiple_statements() {
        let mut runtime = FreeLangRuntime::new();
        let code = "let x = 10\nlet y = 20\nx + y";
        let result = runtime.execute_source(code);
        assert!(result.is_ok());
    }

    #[test]
    fn test_runtime_statistics() {
        let mut runtime = FreeLangRuntime::new();
        let _result = runtime.execute_source("1 + 1");
        assert!(runtime.statistics.lines_executed > 0);
    }

    #[test]
    fn test_error_recording() {
        let mut runtime = FreeLangRuntime::new();
        let result = runtime.execute_source("1 / 0");
        assert!(result.is_err());
        assert!(runtime.errors.len() > 0);
    }

    #[test]
    fn test_variable_get_set() {
        let mut runtime = FreeLangRuntime::new();
        runtime.set_variable("x".to_string(), FlValue::Int(42));
        let val = runtime.get_variable("x");
        assert!(val.is_some());
    }

    #[test]
    fn test_reset_environment() {
        let mut runtime = FreeLangRuntime::new();
        runtime.set_variable("x".to_string(), FlValue::Int(42));
        runtime.reset_environment();
        assert!(runtime.get_variable("x").is_none());
    }

    #[test]
    fn test_config_presets() {
        let minimal = RuntimeConfig::minimal();
        let dev = RuntimeConfig::development();
        let prod = RuntimeConfig::production();

        assert!(minimal.max_memory_mb < dev.max_memory_mb);
        assert!(dev.debug == true);
        assert!(prod.debug == false);
    }

    #[test]
    fn test_execution_context() {
        let mut ctx = ExecutionContext::new();
        ctx.push_call("foo".to_string());
        ctx.push_call("bar".to_string());
        assert_eq!(ctx.call_stack_depth(), 2);

        ctx.pop_call();
        assert_eq!(ctx.call_stack_depth(), 1);
    }

    #[test]
    fn test_statistics_display() {
        let stats = RuntimeStatistics {
            lines_executed: 10,
            errors_count: 1,
            warnings_count: 0,
            functions_count: 5,
            variables_count: 3,
            execution_time_ms: 100,
        };
        let display = stats.to_string();
        assert!(display.contains("10"));
        assert!(display.contains("1"));
    }

    #[test]
    fn test_batch_execution() {
        let mut runtime = FreeLangRuntime::new();
        let sources = vec!["let x = 1", "let y = 2", "x + y"];
        let results = runtime.execute_batch(sources);
        assert_eq!(results.len(), 3);
    }

    #[test]
    fn test_last_error() {
        let mut runtime = FreeLangRuntime::new();
        let _result = runtime.execute_source("1 / 0");
        assert!(runtime.last_error().is_some());
    }
}
