#[cfg(test)]
mod tests {
    use super::*;
    use std::collections::HashMap;

    fn make_object(pairs: &[(&str, i64)]) -> FlValue {
        let mut map = HashMap::new();
        for (k, v) in pairs {
            map.insert(k.to_string(), FlValue::Int(*v));
        }
        FlValue::Object(map)
    }

    #[test]
    fn test_keys_basic() {
        let obj = make_object(&[("a", 1), ("b", 2)]);
        let result = keys(obj).unwrap();
        match result {
            FlValue::Array(arr) => {
                assert_eq!(arr.len(), 2);
                // 순서는 HashMap이므로 보장되지 않음, 단지 길이만 확인
            }
            _ => panic!("Expected array"),
        }
    }

    #[test]
    fn test_keys_non_object() {
        let result = keys(FlValue::Int(42));
        assert!(matches!(result, Err(ObjectError::NotAnObject(_))));
    }

    #[test]
    fn test_values_basic() {
        let obj = make_object(&[("a", 1), ("b", 2)]);
        let result = values(obj).unwrap();
        match result {
            FlValue::Array(arr) => {
                assert_eq!(arr.len(), 2);
                // 값 확인
                let has_1 = arr.iter().any(|v| *v == FlValue::Int(1));
                let has_2 = arr.iter().any(|v| *v == FlValue::Int(2));
                assert!(has_1 && has_2);
            }
            _ => panic!("Expected array"),
        }
    }

    #[test]
    fn test_values_non_object() {
        let result = values(FlValue::Str("hello".to_string()));
        assert!(matches!(result, Err(ObjectError::NotAnObject(_))));
    }

    #[test]
    fn test_entries_basic() {
        let obj = make_object(&[("a", 1), ("b", 2)]);
        let result = entries(obj).unwrap();
        match result {
            FlValue::Array(arr) => {
                assert_eq!(arr.len(), 2);
                // 각 항목이 [key, value] 형태인지 확인
                for entry in arr {
                    match entry {
                        FlValue::Array(pair) => {
                            assert_eq!(pair.len(), 2);
                            assert!(matches!(pair[0], FlValue::Str(_)));
                            assert!(matches!(pair[1], FlValue::Int(_)));
                        }
                        _ => panic!("Expected array of arrays"),
                    }
                }
            }
            _ => panic!("Expected array"),
        }
    }

    #[test]
    fn test_entries_non_object() {
        let result = entries(FlValue::Bool(true));
        assert!(matches!(result, Err(ObjectError::NotAnObject(_))));
    }

    #[test]
    fn test_has_key_exists() {
        let obj = make_object(&[("a", 1), ("b", 2)]);
        let result = has_key(obj, "a".to_string()).unwrap();
        assert_eq!(result, FlValue::Bool(true));
    }

    #[test]
    fn test_has_key_not_exists() {
        let obj = make_object(&[("a", 1)]);
        let result = has_key(obj, "z".to_string()).unwrap();
        assert_eq!(result, FlValue::Bool(false));
    }

    #[test]
    fn test_has_key_non_object() {
        let result = has_key(FlValue::Null, "key".to_string());
        assert!(matches!(result, Err(ObjectError::NotAnObject(_))));
    }

    #[test]
    fn test_merge_basic() {
        let obj1 = make_object(&[("a", 1), ("b", 2)]);
        let obj2 = make_object(&[("b", 20), ("c", 3)]);
        let result = merge(obj1, obj2).unwrap();

        match result {
            FlValue::Object(map) => {
                assert_eq!(map.len(), 3);
                assert_eq!(map.get("a"), Some(&FlValue::Int(1)));
                assert_eq!(map.get("b"), Some(&FlValue::Int(20))); // obj2가 덮어씀
                assert_eq!(map.get("c"), Some(&FlValue::Int(3)));
            }
            _ => panic!("Expected object"),
        }
    }

    #[test]
    fn test_merge_non_object() {
        let obj = make_object(&[("a", 1)]);
        let result = merge(obj, FlValue::Int(42));
        assert!(matches!(result, Err(ObjectError::NotAnObject(_))));
    }
}

