use std::collections::HashMap;
use crate::stdlib::FlValue;

// ============================================================================
// ObjectError - 객체 처리 에러 타입
// ============================================================================

/// 객체 처리 시 발생할 수 있는 에러
#[derive(Clone, Debug, PartialEq)]
pub enum ObjectError {
    /// 키를 찾을 수 없음
    KeyNotFound(String),

    /// 값이 객체가 아님
    NotAnObject(String),

    /// 타입 불일치
    TypeMismatch(String),
}

impl std::fmt::Display for ObjectError {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            ObjectError::KeyNotFound(key) => write!(f, "Key not found: {}", key),
            ObjectError::NotAnObject(msg) => write!(f, "Not an object: {}", msg),
            ObjectError::TypeMismatch(msg) => write!(f, "Type mismatch: {}", msg),
        }
    }
}

// ============================================================================
// Object Manipulation Functions
// ============================================================================

/// 객체의 모든 키를 배열로 반환합니다.
///
/// # 매개변수
/// - obj: 검사할 객체 (FlValue::Object)
///
/// # 반환값
/// - 키들의 배열 (FlValue::Array)
/// - 비 객체인 경우 에러
///
/// # 예제
/// ```
/// let obj = FlValue::Object(map! {"a": FlValue::Int(1), "b": FlValue::Int(2)});
/// let keys = keys(obj).unwrap();  // ["a", "b"]
/// ```
pub fn keys(obj: FlValue) -> Result<FlValue, ObjectError> {
    match obj {
        FlValue::Object(map) => {
            let key_array: Vec<FlValue> = map
                .keys()
                .map(|k| FlValue::Str(k.clone()))
                .collect();
            Ok(FlValue::Array(key_array))
        }
        _ => Err(ObjectError::NotAnObject(
            "keys() requires an object (HashMap)".to_string(),
        )),
    }
}

/// 객체의 모든 값을 배열로 반환합니다.
///
/// # 매개변수
/// - obj: 검사할 객체 (FlValue::Object)
///
/// # 반환값
/// - 값들의 배열 (FlValue::Array)
/// - 비 객체인 경우 에러
///
/// # 예제
/// ```
/// let obj = FlValue::Object(map! {"a": FlValue::Int(1), "b": FlValue::Int(2)});
/// let vals = values(obj).unwrap();  // [1, 2]
/// ```
pub fn values(obj: FlValue) -> Result<FlValue, ObjectError> {
    match obj {
        FlValue::Object(map) => {
            let value_array: Vec<FlValue> = map.values().cloned().collect();
            Ok(FlValue::Array(value_array))
        }
        _ => Err(ObjectError::NotAnObject(
            "values() requires an object (HashMap)".to_string(),
        )),
    }
}

/// 객체의 [키, 값] 쌍을 배열로 반환합니다.
///
/// # 매개변수
/// - obj: 검사할 객체 (FlValue::Object)
///
/// # 반환값
/// - [키, 값] 쌍들의 배열 (각 쌍은 FlValue::Array(2))
/// - 비 객체인 경우 에러
///
/// # 예제
/// ```
/// let obj = FlValue::Object(map! {"a": FlValue::Int(1), "b": FlValue::Int(2)});
/// let entries = entries(obj).unwrap();  // [["a", 1], ["b", 2]]
/// ```
pub fn entries(obj: FlValue) -> Result<FlValue, ObjectError> {
    match obj {
        FlValue::Object(map) => {
            let entry_array: Vec<FlValue> = map
                .iter()
                .map(|(k, v)| {
                    FlValue::Array(vec![FlValue::Str(k.clone()), v.clone()])
                })
                .collect();
            Ok(FlValue::Array(entry_array))
        }
        _ => Err(ObjectError::NotAnObject(
            "entries() requires an object (HashMap)".to_string(),
        )),
    }
}

/// 객체에 주어진 키가 존재하는지 확인합니다.
///
/// # 매개변수
/// - obj: 검사할 객체 (FlValue::Object)
/// - key: 찾을 키 (문자열)
///
/// # 반환값
/// - 키 존재 여부 (FlValue::Bool)
///
/// # 예제
/// ```
/// let obj = FlValue::Object(map! {"a": FlValue::Int(1)});
/// assert_eq!(has_key(obj.clone(), "a").unwrap(), FlValue::Bool(true));
/// assert_eq!(has_key(obj, "b").unwrap(), FlValue::Bool(false));
/// ```
pub fn has_key(obj: FlValue, key: String) -> Result<FlValue, ObjectError> {
    match obj {
        FlValue::Object(map) => Ok(FlValue::Bool(map.contains_key(&key))),
        _ => Err(ObjectError::NotAnObject(
            "has_key() requires an object (HashMap)".to_string(),
        )),
    }
}

/// 두 개의 객체를 병합합니다 (얕은 병합).
///
/// # 매개변수
/// - obj1: 첫 번째 객체
/// - obj2: 두 번째 객체 (덮어쓸 값)
///
/// # 반환값
/// - 병합된 객체
/// - obj2의 키가 obj1의 키를 덮어씁니다
/// - 비 객체인 경우 에러
///
/// # 예제
/// ```
/// let obj1 = FlValue::Object(map! {"a": FlValue::Int(1), "b": FlValue::Int(2)});
/// let obj2 = FlValue::Object(map! {"b": FlValue::Int(20), "c": FlValue::Int(3)});
/// let merged = merge(obj1, obj2).unwrap();
/// // {"a": 1, "b": 20, "c": 3}
/// ```
pub fn merge(obj1: FlValue, obj2: FlValue) -> Result<FlValue, ObjectError> {
    match (obj1, obj2) {
        (FlValue::Object(mut map1), FlValue::Object(map2)) => {
            for (k, v) in map2.iter() {
                map1.insert(k.clone(), v.clone());
            }
            Ok(FlValue::Object(map1))
        }
        (FlValue::Object(_), _) => Err(ObjectError::NotAnObject(
            "merge() requires both arguments to be objects".to_string(),
        )),
        _ => Err(ObjectError::NotAnObject(
            "merge() requires both arguments to be objects".to_string(),
        )),
    }
}

