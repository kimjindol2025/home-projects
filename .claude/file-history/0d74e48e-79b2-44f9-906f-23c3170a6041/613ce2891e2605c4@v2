struct Logger
  enabled: bool
  level: string               # "DEBUG", "INFO", "WARN", "ERROR"

fn logInfo
  input: (logger: Logger, message: string)
  output: void
  intent: "정보 로그 출력"
  do
    if logger.enabled
      print("[INFO] " + message)

fn logWarning
  input: (logger: Logger, message: string)
  output: void
  intent: "경고 로그 출력"
  do
    if logger.enabled
      print("[WARN] " + message)

fn logError
  input: (logger: Logger, message: string)
  output: void
  intent: "에러 로그 출력"
  do
    if logger.enabled
      print("[ERROR] " + message)

fn logDebug
  input: (logger: Logger, message: string)
  output: void
  intent: "디버그 로그 출력"
  do
    if logger.enabled && logger.level == "DEBUG"
      print("[DEBUG] " + message)

fn newLogger
  input: (enabled: bool, level: string)
  output: Logger
  intent: "로거 생성"
  do
    return {
      enabled: enabled,
      level: level
    }

