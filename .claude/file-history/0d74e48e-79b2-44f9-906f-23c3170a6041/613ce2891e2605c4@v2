fn isSome<T>
  input: opt: Option<T>
  output: bool
  intent: "Option이 Some인지"
  do
    match opt
      Some(_) => true
      None => false

fn unwrap<T>
  input: opt: Option<T>
  output: T
  intent: "Option에서 값 추출"
  do
    match opt
      Some(v) => v
      None => panic("unwrap on None")

fn panic
  input: msg: string
  output: void
  intent: "패닉"
  do
    print("PANIC: " + msg)
