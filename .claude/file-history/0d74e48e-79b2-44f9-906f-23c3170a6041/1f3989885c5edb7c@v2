/// 스케줄러 큐의 노드
pub struct ReadyQueueNode {
    /// 프로세스 ID
    pub pid: u32,

    /// 프로세스 컨텍스트
    pub context: ProcessContext,

    /// 타임 슬라이스 (밀리초)
    pub time_slice_ms: u32,

    /// 사용된 시간 (밀리초)
    pub used_time_ms: u32,
}

impl ReadyQueueNode {
    pub fn new(pid: u32, context: ProcessContext, time_slice_ms: u32) -> Self {
        ReadyQueueNode {
            pid,
            context,
            time_slice_ms,
            used_time_ms: 0,
        }
    }

    pub fn has_time_remaining(&self) -> bool {
        self.used_time_ms < self.time_slice_ms
    }

    pub fn consume_time(&mut self, duration_ms: u32) {
        self.used_time_ms += duration_ms;
    }

    pub fn reset_time(&mut self) {
        self.used_time_ms = 0;
    }

    pub fn time_remaining(&self) -> u32 {
        if self.used_time_ms < self.time_slice_ms {
            self.time_slice_ms - self.used_time_ms
        } else {
            0
        }
    }
}

/// 라운드-로빈 스케줄러
pub struct RoundRobinScheduler {
    /// Ready 큐 (FIFO)
    pub ready_queue: Vec<ReadyQueueNode>,

    /// 현재 실행 중인 프로세스 인덱스
    pub current_index: Option<usize>,

    /// 기본 타임 슬라이스 (4ms)
    pub default_time_slice_ms: u32,

    /// 스케줄러 틱 카운트
    pub tick_count: u32,

    /// 컨텍스트 전환 횟수
    pub context_switch_count: u32,
}

impl RoundRobinScheduler {
    pub fn new() -> Self {
        RoundRobinScheduler {
            ready_queue: Vec::new(),
            current_index: None,
            default_time_slice_ms: 4,  // 4ms 타임 슬라이스
            tick_count: 0,
            context_switch_count: 0,
        }
    }

    pub fn add_process(&mut self, pid: u32, context: ProcessContext) {
        let node = ReadyQueueNode::new(pid, context, self.default_time_slice_ms);
        self.ready_queue.push(node);

        // 첫 프로세스면 현재 실행 중인 것으로 설정
        if self.current_index.is_none() {
            self.current_index = Some(0);
        }
    }

    pub fn schedule_next(&mut self) -> Option<(u32, ProcessContext)> {
        if self.ready_queue.is_empty() {
            return None;
        }

        // 현재 프로세스의 타임 슬라이스가 끝났으면 다음 프로세스로 전환
        if let Some(current) = self.current_index {
            let queue_len = self.ready_queue.len();

            // 현재 프로세스의 시간 초기화
            self.ready_queue[current].reset_time();

            // 다음 프로세스로 이동
            let next_index = (current + 1) % queue_len;
            self.current_index = Some(next_index);
            self.context_switch_count += 1;

            let node = &self.ready_queue[next_index];
            let context = node.context.clone();
            return Some((node.pid, context));
        }

        None
    }

    pub fn get_current_process(&self) -> Option<(u32, &ProcessContext)> {
        if let Some(index) = self.current_index {
            if index < self.ready_queue.len() {
                let node = &self.ready_queue[index];
                return Some((node.pid, &node.context));
            }
        }
        None
    }

    pub fn consume_time(&mut self, duration_ms: u32) {
        if let Some(index) = self.current_index {
            self.ready_queue[index].consume_time(duration_ms);
        }
        self.tick_count += 1;
    }

    pub fn queue_length(&self) -> usize {
        self.ready_queue.len()
    }

    pub fn print_queue_status(&self) {
        println!("\n📊 Ready Queue Status:");
        println!("  Total Processes: {}", self.ready_queue.len());
        println!("  Context Switches: {}", self.context_switch_count);
        println!("  Total Ticks: {}", self.tick_count);
        println!("\n  Queue Contents:");

        for (idx, node) in self.ready_queue.iter().enumerate() {
            let status = if self.current_index == Some(idx) {
                "▶️ RUNNING"
            } else {
                "⏸️  WAITING"
            };

            println!("    [{}] PID {} - {} (Time: {}/{}ms)",
                     idx, node.pid, status,
                     node.used_time_ms, node.time_slice_ms);
        }
    }
}

