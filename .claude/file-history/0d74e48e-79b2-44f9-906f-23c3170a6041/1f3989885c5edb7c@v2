/// 프로세스의 완전한 CPU 상태 (컨텍스트)
pub struct ProcessContext {
    /// 일반 목적 레지스터
    pub registers: GeneralPurposeRegisters,

    /// 프로그램 카운터 (RIP)
    pub instruction_pointer: u64,

    /// CPU 플래그
    pub flags: CPUFlags,

    /// 컨텍스트 ID (고유 식별자)
    pub context_id: u32,

    /// 컨텍스트 생성 시간
    pub created_at: u64,

    /// 컨텍스트 전환 횟수
    pub switch_count: u32,
}

impl ProcessContext {
    pub fn new(context_id: u32, instruction_pointer: u64, stack_addr: u64) -> Self {
        ProcessContext {
            registers: GeneralPurposeRegisters::initialize_for_process(stack_addr),
            instruction_pointer,
            flags: CPUFlags::new(),
            context_id,
            created_at: 0,
            switch_count: 0,
        }
    }

    pub fn save_state(&mut self, rax: u64, rbx: u64, rcx: u64, rdx: u64,
                      rsi: u64, rdi: u64, rbp: u64, rsp: u64) {
        self.registers.rax = rax;
        self.registers.rbx = rbx;
        self.registers.rcx = rcx;
        self.registers.rdx = rdx;
        self.registers.rsi = rsi;
        self.registers.rdi = rdi;
        self.registers.rbp = rbp;
        self.registers.rsp = rsp;
    }

    pub fn restore_state(&self) -> [u64; 8] {
        self.registers.get_all_registers()
    }

    pub fn record_switch(&mut self) {
        self.switch_count += 1;
    }

    pub fn print_context(&self) {
        println!("\n📋 Process Context #{}:", self.context_id);
        println!("  RIP (Instruction Pointer): 0x{:016x}", self.instruction_pointer);
        println!("  Flags: {:?}", self.flags.to_u64());
        println!("  Context Switches: {}", self.switch_count);
        println!("  Registers:");
        self.registers.print_registers();
    }
}

