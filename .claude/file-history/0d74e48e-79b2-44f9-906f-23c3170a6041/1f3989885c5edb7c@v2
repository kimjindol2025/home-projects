/// x86-64 일반 목적 레지스터
pub struct GeneralPurposeRegisters {
    /// RAX: 누적기
    pub rax: u64,
    /// RBX: 기본
    pub rbx: u64,
    /// RCX: 카운터
    pub rcx: u64,
    /// RDX: 데이터
    pub rdx: u64,
    /// RSI: 소스 인덱스
    pub rsi: u64,
    /// RDI: 목적지 인덱스
    pub rdi: u64,
    /// RBP: 베이스 포인터
    pub rbp: u64,
    /// RSP: 스택 포인터
    pub rsp: u64,
}

impl GeneralPurposeRegisters {
    pub fn new() -> Self {
        GeneralPurposeRegisters {
            rax: 0,
            rbx: 0,
            rcx: 0,
            rdx: 0,
            rsi: 0,
            rdi: 0,
            rbp: 0,
            rsp: 0,
        }
    }

    pub fn initialize_for_process(stack_addr: u64) -> Self {
        let mut regs = GeneralPurposeRegisters::new();
        regs.rsp = stack_addr;  // 스택 포인터 초기화
        regs.rbp = stack_addr;  // 베이스 포인터 초기화
        regs
    }

    pub fn get_all_registers(&self) -> [u64; 8] {
        [
            self.rax, self.rbx, self.rcx, self.rdx,
            self.rsi, self.rdi, self.rbp, self.rsp,
        ]
    }

    pub fn set_all_registers(&mut self, values: [u64; 8]) {
        self.rax = values[0];
        self.rbx = values[1];
        self.rcx = values[2];
        self.rdx = values[3];
        self.rsi = values[4];
        self.rdi = values[5];
        self.rbp = values[6];
        self.rsp = values[7];
    }

    pub fn print_registers(&self) {
        println!("RAX: 0x{:016x} | RBX: 0x{:016x}", self.rax, self.rbx);
        println!("RCX: 0x{:016x} | RDX: 0x{:016x}", self.rcx, self.rdx);
        println!("RSI: 0x{:016x} | RDI: 0x{:016x}", self.rsi, self.rdi);
        println!("RBP: 0x{:016x} | RSP: 0x{:016x}", self.rbp, self.rsp);
    }
}

/// CPU 플래그 (RFLAGS)
pub struct CPUFlags {
    /// Carry Flag
    pub carry: bool,
    /// Zero Flag
    pub zero: bool,
    /// Sign Flag
    pub sign: bool,
    /// Overflow Flag
    pub overflow: bool,
    /// Interrupt Enable Flag
    pub interrupt_enable: bool,
}

impl CPUFlags {
    pub fn new() -> Self {
        CPUFlags {
            carry: false,
            zero: false,
            sign: false,
            overflow: false,
            interrupt_enable: true,
        }
    }

    pub fn to_u64(&self) -> u64 {
        let mut flags: u64 = 0;
        if self.carry { flags |= 1 << 0; }
        if self.zero { flags |= 1 << 6; }
        if self.sign { flags |= 1 << 7; }
        if self.overflow { flags |= 1 << 11; }
        if self.interrupt_enable { flags |= 1 << 9; }
        flags
    }

    pub fn from_u64(flags: u64) -> Self {
        CPUFlags {
            carry: (flags & (1 << 0)) != 0,
            zero: (flags & (1 << 6)) != 0,
            sign: (flags & (1 << 7)) != 0,
            overflow: (flags & (1 << 11)) != 0,
            interrupt_enable: (flags & (1 << 9)) != 0,
        }
    }
}

