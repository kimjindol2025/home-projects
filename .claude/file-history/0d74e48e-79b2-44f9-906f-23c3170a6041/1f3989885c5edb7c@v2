impl Clone for GeneralPurposeRegisters {
    fn clone(&self) -> Self {
        GeneralPurposeRegisters {
            rax: self.rax,
            rbx: self.rbx,
            rcx: self.rcx,
            rdx: self.rdx,
            rsi: self.rsi,
            rdi: self.rdi,
            rbp: self.rbp,
            rsp: self.rsp,
        }
    }
}

impl Clone for CPUFlags {
    fn clone(&self) -> Self {
        CPUFlags {
            carry: self.carry,
            zero: self.zero,
            sign: self.sign,
            overflow: self.overflow,
            interrupt_enable: self.interrupt_enable,
        }
    }
}

impl Clone for ProcessContext {
    fn clone(&self) -> Self {
        ProcessContext {
            registers: self.registers.clone(),
            instruction_pointer: self.instruction_pointer,
            flags: self.flags.clone(),
            context_id: self.context_id,
            created_at: self.created_at,
            switch_count: self.switch_count,
        }
    }
}

// ============================================================================
// Part 6: 메인 스케줄러 테스트
// ============================================================================

pub fn main() {
    println!("╔════════════════════════════════════════════════════════════╗");
    println!("║  FreeLang OS Kernel - Phase G Week 2 Context Switching     ║");
    println!("╚════════════════════════════════════════════════════════════╝\n");

    // 스케줄러 생성
    let mut scheduler = RoundRobinScheduler::new();
    let mut switcher = ContextSwitcher::new();

    println!("✅ Scheduler initialized");
    println!("   Default Time Slice: {}ms\n", scheduler.default_time_slice_ms);

    // 프로세스 생성 및 추가
    println!("🔄 Creating processes...");

    let mut ctx1 = ProcessContext::new(1, 0x100000, 0x7FFFF000);
    ctx1.registers.rax = 42;
    scheduler.add_process(1, ctx1);
    println!("   ✅ Process 1 added");

    let mut ctx2 = ProcessContext::new(2, 0x110000, 0x7FFFE000);
    ctx2.registers.rax = 100;
    scheduler.add_process(2, ctx2);
    println!("   ✅ Process 2 added");

    let mut ctx3 = ProcessContext::new(3, 0x120000, 0x7FFFCD000);
    ctx3.registers.rax = 200;
    scheduler.add_process(3, ctx3);
    println!("   ✅ Process 3 added");

    // 스케줄링 시뮬레이션
    println!("\n⏱️  Scheduling simulation (5 time slices)...\n");

    for round in 0..5 {
        println!("Round {}:", round + 1);

        if let Some((pid, context)) = scheduler.get_current_process() {
            println!("  ▶️  Running Process {}", pid);
            println!("     RIP: 0x{:x}, RAX: {}", context.instruction_pointer, context.registers.rax);
        }

        // 타임 슬라이스 사용
        scheduler.consume_time(4);

        // 다음 프로세스로 전환
        if let Some((next_pid, next_context)) = scheduler.schedule_next() {
            if let Some((prev_pid, _)) = scheduler.get_current_process() {
                println!("  ⏸️  Switching {} → {}", prev_pid, next_pid);
                switcher.switch_context(prev_pid, next_context.clone(), next_pid, next_context, 1);
            }
        }

        println!();
    }

    // 상태 출력
    scheduler.print_queue_status();
    switcher.print_statistics();

    println!("\n✨ Scheduling simulation complete!\n");
}

