// Part 4: 컨텍스트 스위처 (Context Switcher)
// ============================================================================

/// 컨텍스트 전환 정보
pub struct ContextSwitchInfo {
    /// 이전 프로세스 ID
    pub prev_pid: u32,

    /// 다음 프로세스 ID
    pub next_pid: u32,

    /// 전환 시간 (ms)
    pub switch_time_ms: u32,

    /// 이전 프로세스의 컨텍스트
    pub prev_context: ProcessContext,

    /// 다음 프로세스의 컨텍스트
    pub next_context: ProcessContext,
}

pub struct ContextSwitcher {
    /// 마지막 컨텍스트 전환 정보
    pub last_switch: Option<ContextSwitchInfo>,

    /// 총 컨텍스트 전환 횟수
    pub total_switches: u64,

    /// 컨텍스트 전환 누적 시간 (ns)
    pub total_switch_time_ns: u64,
}

impl ContextSwitcher {
    pub fn new() -> Self {
        ContextSwitcher {
            last_switch: None,
            total_switches: 0,
            total_switch_time_ns: 0,
        }
    }

    pub fn switch_context(&mut self, prev_pid: u32, prev_context: ProcessContext,
                          next_pid: u32, mut next_context: ProcessContext,
                          switch_time_ms: u32) {
        // 이전 프로세스 컨텍스트 저장
        // (실제로는 메모리에 저장하지만, 여기서는 시뮬레이션)

        // 다음 프로세스 컨텍스트 복원
        next_context.record_switch();

        let switch_info = ContextSwitchInfo {
            prev_pid,
            next_pid,
            switch_time_ms,
            prev_context,
            next_context,
        };

        self.last_switch = Some(switch_info);
        self.total_switches += 1;
        self.total_switch_time_ns += switch_time_ms as u64 * 1_000_000;  // ms → ns
    }

    pub fn get_last_switch(&self) -> Option<&ContextSwitchInfo> {
        self.last_switch.as_ref()
    }

    pub fn average_switch_time_us(&self) -> f64 {
        if self.total_switches == 0 {
            return 0.0;
        }
        (self.total_switch_time_ns as f64) / (self.total_switches as f64) / 1000.0
    }

    pub fn print_statistics(&self) {
        println!("\n⚡ Context Switch Statistics:");
        println!("  Total Switches: {}", self.total_switches);
        println!("  Total Time: {} ns", self.total_switch_time_ns);
        println!("  Average Switch Time: {:.2} µs", self.average_switch_time_us());

        if let Some(last_switch) = &self.last_switch {
            println!("\n  Last Context Switch:");
            println!("    {} → {}", last_switch.prev_pid, last_switch.next_pid);
            println!("    Switch Time: {}ms", last_switch.switch_time_ms);
        }
    }
}

