#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_general_purpose_registers() {
        let regs = GeneralPurposeRegisters::new();
        assert_eq!(regs.rax, 0);
        assert_eq!(regs.rsp, 0);
    }

    #[test]
    fn test_registers_initialize_for_process() {
        let regs = GeneralPurposeRegisters::initialize_for_process(0x7FFF0000);
        assert_eq!(regs.rsp, 0x7FFF0000);
        assert_eq!(regs.rbp, 0x7FFF0000);
    }

    #[test]
    fn test_cpu_flags() {
        let flags = CPUFlags::new();
        assert_eq!(flags.carry, false);
        assert_eq!(flags.interrupt_enable, true);

        let flags_u64 = flags.to_u64();
        let flags_restored = CPUFlags::from_u64(flags_u64);
        assert_eq!(flags_restored.interrupt_enable, true);
    }

    #[test]
    fn test_process_context_creation() {
        let ctx = ProcessContext::new(1, 0x100000, 0x7FFF0000);
        assert_eq!(ctx.context_id, 1);
        assert_eq!(ctx.instruction_pointer, 0x100000);
        assert_eq!(ctx.registers.rsp, 0x7FFF0000);
    }

    #[test]
    fn test_process_context_save_restore() {
        let mut ctx = ProcessContext::new(1, 0x100000, 0x7FFF0000);
        ctx.save_state(42, 100, 200, 300, 400, 500, 600, 700);

        let state = ctx.restore_state();
        assert_eq!(state[0], 42);   // rax
        assert_eq!(state[1], 100);  // rbx
        assert_eq!(state[7], 700);  // rsp
    }

    #[test]
    fn test_ready_queue_node() {
        let ctx = ProcessContext::new(1, 0x100000, 0x7FFF0000);
        let mut node = ReadyQueueNode::new(1, ctx, 4);

        assert!(node.has_time_remaining());
        assert_eq!(node.time_remaining(), 4);

        node.consume_time(2);
        assert_eq!(node.time_remaining(), 2);

        node.reset_time();
        assert_eq!(node.used_time_ms, 0);
    }

    #[test]
    fn test_round_robin_scheduler_creation() {
        let scheduler = RoundRobinScheduler::new();
        assert_eq!(scheduler.queue_length(), 0);
        assert_eq!(scheduler.default_time_slice_ms, 4);
    }

    #[test]
    fn test_round_robin_scheduler_add_process() {
        let mut scheduler = RoundRobinScheduler::new();
        let ctx = ProcessContext::new(1, 0x100000, 0x7FFF0000);

        scheduler.add_process(1, ctx);
        assert_eq!(scheduler.queue_length(), 1);
        assert_eq!(scheduler.current_index, Some(0));
    }

    #[test]
    fn test_round_robin_scheduler_next() {
        let mut scheduler = RoundRobinScheduler::new();

        let ctx1 = ProcessContext::new(1, 0x100000, 0x7FFF0000);
        let ctx2 = ProcessContext::new(2, 0x110000, 0x7FFEE000);

        scheduler.add_process(1, ctx1);
        scheduler.add_process(2, ctx2);

        if let Some((pid, _)) = scheduler.schedule_next() {
            assert_eq!(pid, 2);
        }
    }

    #[test]
    fn test_context_switcher() {
        let mut switcher = ContextSwitcher::new();

        let ctx1 = ProcessContext::new(1, 0x100000, 0x7FFF0000);
        let ctx2 = ProcessContext::new(2, 0x110000, 0x7FFEE000);

        switcher.switch_context(1, ctx1, 2, ctx2, 1);

        assert_eq!(switcher.total_switches, 1);
        assert!(switcher.last_switch.is_some());
    }

    #[test]
    fn test_context_switcher_average_time() {
        let mut switcher = ContextSwitcher::new();

        let ctx1 = ProcessContext::new(1, 0x100000, 0x7FFF0000);
        let ctx2 = ProcessContext::new(2, 0x110000, 0x7FFEE000);

        switcher.switch_context(1, ctx1.clone(), 2, ctx2.clone(), 2);
        switcher.switch_context(2, ctx2.clone(), 1, ctx1, 2);

        assert_eq!(switcher.total_switches, 2);
        let avg = switcher.average_switch_time_us();
        assert!(avg > 0.0);
    }

    #[test]
    fn test_scheduling_simulation() {
        let mut scheduler = RoundRobinScheduler::new();

        let ctx1 = ProcessContext::new(1, 0x100000, 0x7FFF0000);
        let ctx2 = ProcessContext::new(2, 0x110000, 0x7FFEE000);

        scheduler.add_process(1, ctx1);
        scheduler.add_process(2, ctx2);

        for _ in 0..4 {
            scheduler.consume_time(4);
            scheduler.schedule_next();
        }

        assert!(scheduler.tick_count > 0);
        assert!(scheduler.context_switch_count > 0);
    }
}
