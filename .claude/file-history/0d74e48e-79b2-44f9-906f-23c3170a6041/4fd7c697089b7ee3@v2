/// channel_new() -> (Sender, Receiver)
///
/// 새로운 채널을 생성합니다.
/// MPSC (Multi-Producer Single-Consumer) 채널입니다.
///
/// 예제:
/// ```
/// let (tx, rx) = channel_new()
/// channel_send(tx, 42)
/// let value = channel_recv(rx)
/// ```
pub fn builtin_channel_new(
    _args: Vec<crate::evaluator::FlValue>,
) -> Result<crate::evaluator::FlValue, String> {
    let (tx, rx) = mpsc::channel();

    // Sender와 Receiver를 배열로 반환
    Ok(crate::evaluator::FlValue::Array(vec![
        crate::evaluator::FlValue::Object({
            let mut obj = std::collections::HashMap::new();
            obj.insert("__type".to_string(), crate::evaluator::FlValue::Str("Sender".to_string()));
            obj.insert("__tx_ptr".to_string(), crate::evaluator::FlValue::Str("tx_ptr".to_string()));
            obj
        }),
        crate::evaluator::FlValue::Object({
            let mut obj = std::collections::HashMap::new();
            obj.insert("__type".to_string(), crate::evaluator::FlValue::Str("Receiver".to_string()));
            obj.insert("__rx_ptr".to_string(), crate::evaluator::FlValue::Str("rx_ptr".to_string()));
            obj
        }),
    ]))
}

