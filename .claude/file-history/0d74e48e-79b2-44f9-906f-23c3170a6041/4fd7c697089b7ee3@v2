/// refcell_borrow(cell) -> value (불변 빌림)
///
/// RefCell에서 불변 빌림을 획득합니다.
/// 여러 스레드가 동시에 불변 빌림할 수 있습니다.
///
/// 예제:
/// ```
/// let cell = refcell_new(42)
/// let ref = refcell_borrow(cell)
/// ```
pub fn builtin_refcell_borrow(
    args: Vec<crate::evaluator::FlValue>,
) -> Result<crate::evaluator::FlValue, String> {
    if args.len() != 1 {
        return Err(format!("refcell_borrow expects 1 argument, got {}", args.len()));
    }

    match &args[0] {
        crate::evaluator::FlValue::Object(obj) => {
            if let Some(crate::evaluator::FlValue::Str(type_name)) = obj.get("__type") {
                if type_name == "RefCell" {
                    return Ok(crate::evaluator::FlValue::Object({
                        let mut borrow_obj = std::collections::HashMap::new();
                        borrow_obj.insert("__type".to_string(), crate::evaluator::FlValue::Str("Ref".to_string()));
                        borrow_obj.insert("__data".to_string(), crate::evaluator::FlValue::Null);
                        borrow_obj
                    }));
                }
            }
            Err("refcell_borrow failed: invalid RefCell".to_string())
        },
        _ => Err("refcell_borrow requires RefCell argument".to_string()),
    }
}

/// refcell_borrow_mut(cell) -> value (가변 빌림)
///
/// RefCell에서 가변 빌림을 획득합니다.
