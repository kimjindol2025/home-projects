/// mutex_new(value) -> Mutex<value>
///
/// 새로운 Mutex를 생성합니다.
///
/// 예제:
/// ```
/// let m = mutex_new(42)
/// let guard = mutex_lock(m)
/// ```
pub fn builtin_mutex_new(
    args: Vec<crate::evaluator::FlValue>,
    runtime: &mut SyncRuntime,
) -> Result<crate::evaluator::FlValue, String> {
    if args.len() != 1 {
        return Err(format!("mutex_new expects 1 argument, got {}", args.len()));
    }

    let id = runtime.next_mutex_id();

    Ok(crate::evaluator::FlValue::Object({
        let mut obj = std::collections::HashMap::new();
        obj.insert("__type".to_string(), crate::evaluator::FlValue::Str("Mutex".to_string()));
        obj.insert("__id".to_string(), crate::evaluator::FlValue::Int(id as i64));
        obj.insert("__value".to_string(), args[0].clone());
        obj.insert("__locked".to_string(), crate::evaluator::FlValue::Bool(false));
        obj
    }))
}

/// mutex_lock(mutex) -> value
///
/// Mutex를 잠그고 내부 값을 얻습니다.
/// 다른 스레드가 잠금을 보유하면 대기합니다 (블로킹).
///
/// 예제:
/// ```
/// let m = mutex_new(42)
/// let value = mutex_lock(m)
/// ```
pub fn builtin_mutex_lock(
    args: Vec<crate::evaluator::FlValue>,
) -> Result<crate::evaluator::FlValue, String> {
    if args.len() != 1 {
        return Err(format!("mutex_lock expects 1 argument, got {}", args.len()));
    }

    match &args[0] {
        crate::evaluator::FlValue::Object(obj) => {
            if let Some(crate::evaluator::FlValue::Str(type_name)) = obj.get("__type") {
                if type_name == "Mutex" {
                    if let Some(value) = obj.get("__value") {
                        return Ok(value.clone());
                    }
                }
            }
            Err("mutex_lock failed: invalid Mutex".to_string())
        },
        _ => Err("mutex_lock requires Mutex argument".to_string()),
    }
}

/// mutex_set(mutex, value) -> ()
///
/// Mutex 내부의 값을 설정합니다.
/// 먼저 lock()을 호출해서 소유권을 가져야 합니다.
///
/// 예제:
/// ```
/// let m = mutex_new(42)
/// mutex_set(m, 100)
/// ```
pub fn builtin_mutex_set(
    args: Vec<crate::evaluator::FlValue>,
) -> Result<crate::evaluator::FlValue, String> {
    if args.len() != 2 {
        return Err(format!("mutex_set expects 2 arguments, got {}", args.len()));
    }

    match &args[0] {
        crate::evaluator::FlValue::Object(obj) => {
            if let Some(crate::evaluator::FlValue::Str(type_name)) = obj.get("__type") {
                if type_name == "Mutex" {
                    // 실제 구현에서는 HashMap을 가변으로 수정해야 함
                    return Ok(crate::evaluator::FlValue::Null);
                }
            }
            Err("mutex_set failed: invalid Mutex".to_string())
        },
        _ => Err("mutex_set requires Mutex argument".to_string()),
    }
}

