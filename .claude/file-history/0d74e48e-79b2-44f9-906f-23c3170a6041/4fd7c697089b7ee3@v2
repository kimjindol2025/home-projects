/// threadpool_new(size) -> ThreadPool
///
/// 새로운 스레드 풀을 생성합니다.
/// size는 워커 스레드의 개수입니다.
///
/// 예제:
/// ```
/// let pool = threadpool_new(4)
/// ```
pub fn builtin_threadpool_new(
    args: Vec<crate::evaluator::FlValue>,
    runtime: &mut SyncRuntime,
) -> Result<crate::evaluator::FlValue, String> {
    if args.len() != 1 {
        return Err(format!("threadpool_new expects 1 argument, got {}", args.len()));
    }

    let size = match &args[0] {
        crate::evaluator::FlValue::Int(n) => *n as usize,
        _ => return Err("threadpool_new requires integer size".to_string()),
    };

    if size == 0 {
        return Err("threadpool_new size must be > 0".to_string());
    }

    let id = runtime.next_threadpool_id();

    Ok(crate::evaluator::FlValue::Object({
        let mut obj = std::collections::HashMap::new();
        obj.insert("__type".to_string(), crate::evaluator::FlValue::Str("ThreadPool".to_string()));
        obj.insert("__id".to_string(), crate::evaluator::FlValue::Int(id as i64));
        obj.insert("__size".to_string(), crate::evaluator::FlValue::Int(size as i64));
        obj.insert("__active".to_string(), crate::evaluator::FlValue::Bool(true));
        obj
    }))
}

/// threadpool_execute(pool, closure) -> ()
///
/// 스레드 풀에서 작업을 실행합니다.
/// closure는 함수 이름과 인수로 표현됩니다.
///
/// 예제:
/// ```
/// let pool = threadpool_new(4)
/// threadpool_execute(pool, fn(x) println(to_string(x)))
/// ```
pub fn builtin_threadpool_execute(
    args: Vec<crate::evaluator::FlValue>,
) -> Result<crate::evaluator::FlValue, String> {
    if args.len() != 2 {
        return Err(format!("threadpool_execute expects 2 arguments, got {}", args.len()));
    }

    match &args[0] {
        crate::evaluator::FlValue::Object(obj) => {
            if let Some(crate::evaluator::FlValue::Str(type_name)) = obj.get("__type") {
                if type_name == "ThreadPool" {
                    return Ok(crate::evaluator::FlValue::Null);
                }
            }
            Err("threadpool_execute failed: invalid ThreadPool".to_string())
        },
        _ => Err("threadpool_execute requires ThreadPool argument".to_string()),
    }
}

