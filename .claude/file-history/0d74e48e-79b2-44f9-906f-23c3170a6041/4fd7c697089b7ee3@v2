/// arc_new(value) -> Arc<value>
///
/// 새로운 Arc 포인터를 생성합니다.
///
/// 예제:
/// ```
/// let arc = arc_new(42)
/// println(to_string(arc))  // <Arc:1>
/// ```
pub fn builtin_arc_new(
    args: Vec<crate::evaluator::FlValue>,
    runtime: &mut SyncRuntime,
) -> Result<crate::evaluator::FlValue, String> {
    if args.len() != 1 {
        return Err(format!("arc_new expects 1 argument, got {}", args.len()));
    }

    let id = runtime.next_arc_id();
    let data = Arc::new(Mutex::new(args[0].clone()));
    runtime.arcs.insert(id, Arc::clone(&data));

    Ok(crate::evaluator::FlValue::Object({
        let mut obj = std::collections::HashMap::new();
        obj.insert("__type".to_string(), crate::evaluator::FlValue::Str("Arc".to_string()));
        obj.insert("__id".to_string(), crate::evaluator::FlValue::Int(id as i64));
        obj
    }))
}

/// arc_clone(arc) -> Arc<T> (동일 데이터, 참조 카운트 증가)
///
/// Arc를 복제합니다. 같은 데이터를 가리키지만, 별도의 소유권을 가집니다.
///
/// 예제:
/// ```
/// let arc1 = arc_new(42)
/// let arc2 = arc_clone(arc1)
/// // arc1과 arc2는 같은 데이터 공유
/// ```
pub fn builtin_arc_clone(
    args: Vec<crate::evaluator::FlValue>,
) -> Result<crate::evaluator::FlValue, String> {
    if args.len() != 1 {
        return Err(format!("arc_clone expects 1 argument, got {}", args.len()));
    }

    match &args[0] {
        crate::evaluator::FlValue::Object(obj) => {
            if let Some(crate::evaluator::FlValue::Str(type_name)) = obj.get("__type") {
                if type_name == "Arc" {
                    return Ok(args[0].clone());
                }
            }
            Err("arc_clone requires Arc argument".to_string())
        },
        _ => Err("arc_clone requires Arc argument".to_string()),
    }
}

/// arc_get(arc) -> value
///
/// Arc 내부의 값을 가져옵니다.
///
/// 예제:
/// ```
/// let arc = arc_new(42)
/// let value = arc_get(arc)
/// println(to_string(value))  // 42
/// ```
pub fn builtin_arc_get(
    args: Vec<crate::evaluator::FlValue>,
    runtime: &SyncRuntime,
) -> Result<crate::evaluator::FlValue, String> {
    if args.len() != 1 {
        return Err(format!("arc_get expects 1 argument, got {}", args.len()));
    }

    match &args[0] {
        crate::evaluator::FlValue::Object(obj) => {
            if let Some(crate::evaluator::FlValue::Int(id)) = obj.get("__id") {
                if let Some(data) = runtime.arcs.get(&(*id as usize)) {
                    match data.lock() {
                        Ok(guard) => Ok(guard.clone()),
                        Err(_) => Err("Failed to acquire Arc lock".to_string()),
                    }
                } else {
                    Err(format!("Arc not found: {}", id))
                }
            } else {
                Err("Arc missing __id field".to_string())
            }
        },
        _ => Err("arc_get requires Arc argument".to_string()),
    }
}

