/// thread_spawn(closure) -> ThreadHandle
///
/// 새로운 스레드를 생성합니다.
///
/// 예제:
/// ```
/// let handle = thread_spawn(fn() println("Hello from thread"))
/// ```
pub fn builtin_thread_spawn(
    args: Vec<crate::evaluator::FlValue>,
) -> Result<crate::evaluator::FlValue, String> {
    if args.len() != 1 {
        return Err(format!("thread_spawn expects 1 argument, got {}", args.len()));
    }

    // 간단한 구현: 스레드 ID 반환
    thread::spawn(|| {
        // Closure 실행
    });

    Ok(crate::evaluator::FlValue::Object({
        let mut obj = std::collections::HashMap::new();
        obj.insert("__type".to_string(), crate::evaluator::FlValue::Str("ThreadHandle".to_string()));
        obj
    }))
}

/// thread_sleep(milliseconds) -> ()
///
/// 현재 스레드를 대기합니다.
///
/// 예제:
/// ```
/// thread_sleep(1000)  // 1초 대기
/// ```
pub fn builtin_thread_sleep(
    args: Vec<crate::evaluator::FlValue>,
) -> Result<crate::evaluator::FlValue, String> {
    if args.len() != 1 {
        return Err(format!("thread_sleep expects 1 argument, got {}", args.len()));
    }

    let ms = match &args[0] {
        crate::evaluator::FlValue::Int(n) => *n as u64,
        crate::evaluator::FlValue::Float(f) => *f as u64,
        _ => return Err("thread_sleep requires numeric argument".to_string()),
    };

    thread::sleep(Duration::from_millis(ms));

    Ok(crate::evaluator::FlValue::Null)
}

