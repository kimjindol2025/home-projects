use std::sync::{Arc, Mutex, mpsc};
use std::thread;
use std::time::Duration;
use std::collections::HashMap;

// ============================================================================
// SyncValue: 동시성 구조를 FlValue로 표현
// ============================================================================

/// 동시성 구조를 런타임 값으로 표현합니다.
pub enum SyncValue {
    /// Arc<Mutex<FlValue>>: 공유 가능한 뮤텍스 보호 값
    Arc {
        id: usize,
        data: Arc<Mutex<crate::evaluator::FlValue>>,
    },

    /// Mutex<FlValue>: 뮤텍스 보호 값
    Mutex {
        id: usize,
        data: Mutex<crate::evaluator::FlValue>,
    },

    /// Sender<FlValue>: 채널 송신자
    Sender {
        id: usize,
        tx: mpsc::Sender<crate::evaluator::FlValue>,
    },

    /// Receiver<FlValue>: 채널 수신자
    Receiver {
        id: usize,
        rx: mpsc::Receiver<crate::evaluator::FlValue>,
    },

    /// ThreadPool: 스레드 풀
    ThreadPool {
        id: usize,
        size: usize,
        active: bool,
    },

    /// CondVar: 조건 변수
    CondVar {
        id: usize,
        waiting: Arc<Mutex<Vec<thread::ThreadId>>>,
    },

    /// RefCell<T>: 동적 빌림 검사
    RefCell {
        id: usize,
        data: Arc<Mutex<crate::evaluator::FlValue>>,
    },
}

impl Clone for SyncValue {
    fn clone(&self) -> Self {
        match self {
            SyncValue::Arc { id, data } => SyncValue::Arc {
                id: *id,
                data: Arc::clone(data),
            },
            SyncValue::Mutex { id, .. } => {
                // Mutex는 clone 불가, 새로운 ID 할당
                SyncValue::Mutex {
                    id: *id,
                    data: Mutex::new(crate::evaluator::FlValue::Null),
                }
            },
            SyncValue::Sender { id, tx } => SyncValue::Sender {
                id: *id,
                tx: mpsc::Sender::clone(tx),
            },
            SyncValue::Receiver { id, .. } => {
                // Receiver는 clone 불가
                panic!("Cannot clone Receiver")
            },
            SyncValue::ThreadPool { id, size, active } => SyncValue::ThreadPool {
                id: *id,
                size: *size,
                active: *active,
            },
            SyncValue::CondVar { id, waiting } => SyncValue::CondVar {
                id: *id,
                waiting: Arc::clone(waiting),
            },
            SyncValue::RefCell { id, data } => SyncValue::RefCell {
                id: *id,
                data: Arc::clone(data),
            },
        }
    }
}

// ============================================================================
// SyncRuntime: 동시성 구조 관리
// ============================================================================

pub struct SyncRuntime {
    /// Arc ID 카운터
    arc_counter: usize,

    /// 생성된 Arc 목록
    arcs: HashMap<usize, Arc<Mutex<crate::evaluator::FlValue>>>,

    /// Mutex ID 카운터
    mutex_counter: usize,

    /// ThreadPool ID 카운터
    threadpool_counter: usize,

    /// CondVar ID 카운터
    condvar_counter: usize,

    /// RefCell ID 카운터
    refcell_counter: usize,
}

impl SyncRuntime {
    pub fn new() -> Self {
        SyncRuntime {
            arc_counter: 0,
            arcs: HashMap::new(),
            mutex_counter: 0,
            threadpool_counter: 0,
            condvar_counter: 0,
            refcell_counter: 0,
        }
    }

    fn next_arc_id(&mut self) -> usize {
        self.arc_counter += 1;
        self.arc_counter
    }

    fn next_mutex_id(&mut self) -> usize {
        self.mutex_counter += 1;
        self.mutex_counter
    }

    fn next_threadpool_id(&mut self) -> usize {
        self.threadpool_counter += 1;
        self.threadpool_counter
    }

    fn next_condvar_id(&mut self) -> usize {
        self.condvar_counter += 1;
        self.condvar_counter
    }

    fn next_refcell_id(&mut self) -> usize {
        self.refcell_counter += 1;
        self.refcell_counter
    }
}

