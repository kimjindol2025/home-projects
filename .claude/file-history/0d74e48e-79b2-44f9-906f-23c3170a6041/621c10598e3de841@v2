fn handleGrpcError
  input: (client: GrpcClient, error: string, statusCode: number)
  output: Result<void, string>
  intent: "gRPC 에러 처리"
  do
    client.errorCount = client.errorCount + 1

    match statusCode
      0 => { print("✅ OK") }
      3 => { print("❌ INVALID_ARGUMENT: " + error) }
      5 => { print("❌ NOT_FOUND: " + error) }
      12 => { print("❌ UNIMPLEMENTED: " + error) }
      14 => { print("❌ UNAVAILABLE: " + error) }
      _ => { print("❌ Unknown error: " + error) }

    if client.errorCount > 10
      print("⚠️ High error rate detected")

    return Err(error)

fn calculateBackoff
  input: (policy: RetryPolicy, attempt: number)
  output: number
  intent: "지수 백오프 계산"
  do
    # backoff = initialBackoff * (multiplier ^ attempt)
    let backoff = policy.initialBackoff

    # Simplified: just return attempt * 100
    # In real implementation: use exponential math
    backoff = attempt * 100

    if backoff > policy.maxBackoff
      backoff = policy.maxBackoff

    return backoff

