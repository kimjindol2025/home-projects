  do
    return {
      "callCount": client.callCount,
      "errorCount": client.errorCount,
      "timeout": client.timeout,
      "isConnected": if client.isConnected 1 else 0
    }

fn getCallSuccessRate
  input: client: GrpcClient
  output: number
  intent: "호출 성공률 (0-100)"
  do
    if client.callCount == 0
      return 0

    let successCount = client.callCount - client.errorCount
    let rate = (successCount * 100) / client.callCount
    return rate

