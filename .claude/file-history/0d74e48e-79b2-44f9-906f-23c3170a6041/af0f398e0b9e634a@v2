#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_refcell_new() {
        let cell = RefCell::new(42);
        assert_eq!(cell.borrow_count(), 0);
    }

    #[test]
    fn test_refcell_borrow_once() {
        let cell = RefCell::new(vec![1, 2, 3]);
        let guard = cell.borrow();
        assert_eq!(guard.len(), 3);
        assert_eq!(cell.borrow_count(), 1);
    }

    #[test]
    fn test_refcell_borrow_multiple() {
        let cell = RefCell::new(42);
        let _g1 = cell.borrow();
        let _g2 = cell.borrow();
        let _g3 = cell.borrow();

        assert_eq!(cell.borrow_count(), 3);

        drop(_g1);
        assert_eq!(cell.borrow_count(), 2);

        drop(_g2);
        assert_eq!(cell.borrow_count(), 1);

        drop(_g3);
        assert_eq!(cell.borrow_count(), 0);
    }

    #[test]
    fn test_refcell_borrow_mut_once() {
        let cell = RefCell::new(vec![]);
        {
            let mut guard = cell.borrow_mut();
            guard.push(1);
            guard.push(2);
        }

        let guard = cell.borrow();
        assert_eq!(guard.len(), 2);
    }

    #[test]
    fn test_refcell_deref() {
        let cell = RefCell::new(String::from("hello"));
        let guard = cell.borrow();
        assert_eq!(guard.as_str(), "hello");
    }

    #[test]
    fn test_refcell_deref_mut() {
        let cell = RefCell::new(String::from("hello"));
        {
            let mut guard = cell.borrow_mut();
            guard.push_str(" world");
        }

        let guard = cell.borrow();
        assert_eq!(guard.as_str(), "hello world");
    }

    #[test]
    #[should_panic(expected = "RefCell::borrow() called while mutably borrowed")]
    fn test_refcell_immutable_after_mutable_panic() {
        let cell = RefCell::new(42);
        let _mut_guard = cell.borrow_mut();
        let _immut_guard = cell.borrow();  // panic!
    }

    #[test]
    #[should_panic(expected = "RefCell::borrow_mut() called with active borrows")]
    fn test_refcell_mutable_after_immutable_panic() {
        let cell = RefCell::new(42);
        let _immut_guard = cell.borrow();
        let _mut_guard = cell.borrow_mut();  // panic!
    }

    #[test]
    #[should_panic(expected = "RefCell::borrow_mut() called with active borrows")]
    fn test_refcell_double_mutable_panic() {
        let cell = RefCell::new(42);
        let _mut_guard1 = cell.borrow_mut();
        let _mut_guard2 = cell.borrow_mut();  // panic!
    }

    #[test]
    fn test_refcell_try_borrow_success() {
        let cell = RefCell::new(42);
        match cell.try_borrow() {
            Ok(guard) => assert_eq!(*guard, 42),
            Err(_) => panic!("try_borrow should succeed"),
        }
    }

    #[test]
    fn test_refcell_try_borrow_failure() {
        let cell = RefCell::new(42);
        let _mut_guard = cell.borrow_mut();
        match cell.try_borrow() {
            Ok(_) => panic!("try_borrow should fail"),
            Err(_) => {} // expected
        }
    }

    #[test]
    fn test_refcell_try_borrow_mut_success() {
        let cell = RefCell::new(42);
        match cell.try_borrow_mut() {
            Ok(mut guard) => {
                *guard = 100;
                assert_eq!(*guard, 100);
            }
            Err(_) => panic!("try_borrow_mut should succeed"),
        }
    }

    #[test]
    fn test_refcell_try_borrow_mut_failure() {
        let cell = RefCell::new(42);
        let _guard = cell.borrow();
        match cell.try_borrow_mut() {
            Ok(_) => panic!("try_borrow_mut should fail"),
            Err(_) => {} // expected
        }
    }

    #[test]
    fn test_refcell_into_inner() {
        let cell = RefCell::new(String::from("hello"));
        let inner = cell.into_inner();
        assert_eq!(inner, "hello");
    }

    #[test]
    fn test_refcell_nested_structure() {
        struct Counter {
            value: RefCell<i32>,
        }

        let counter = Counter {
            value: RefCell::new(0),
        };

        {
            let mut guard = counter.value.borrow_mut();
            *guard += 1;
        }

        {
            let guard = counter.value.borrow();
            assert_eq!(*guard, 1);
        }
    }

    #[test]
    fn test_refcell_complex_type() {
        #[derive(Clone, Debug, PartialEq)]
        struct Point {
            x: i32,
            y: i32,
        }

        let cell = RefCell::new(Point { x: 3, y: 4 });

        {
            let mut guard = cell.borrow_mut();
            guard.x = 5;
            guard.y = 12;
        }

        let guard = cell.borrow();
        assert_eq!(guard.x, 5);
        assert_eq!(guard.y, 12);
    }

    #[test]
    fn test_refcell_sequential_operations() {
        let cell = RefCell::new(vec![]);

        // Scope 1: 불변 빌림
        {
            let guard = cell.borrow();
            assert_eq!(guard.len(), 0);
        }

        // Scope 2: 가변 빌림 (이제 가능)
        {
            let mut guard = cell.borrow_mut();
            guard.push(1);
            guard.push(2);
        }

        // Scope 3: 다시 불변 빌림
        {
            let guard = cell.borrow();
            assert_eq!(guard.len(), 2);
        }
    }
}

