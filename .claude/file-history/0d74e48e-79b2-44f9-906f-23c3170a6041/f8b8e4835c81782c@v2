#[cfg(test)]
mod tests {
    use super::*;
    use crate::sync::happens_before::SynchronizationReason;

    #[test]
    fn test_data_race_creation() {
        let e1 = EventId::new(1, 0);
        let e2 = EventId::new(2, 0);
        let race = DataRace::new("x".to_string(), e1, e2, RaceType::WriteWrite, true);

        assert_eq!(race.variable(), "x");
        assert_eq!(race.access1(), e1);
        assert_eq!(race.access2(), e2);
        assert_eq!(race.race_type(), RaceType::WriteWrite);
        assert!(race.is_concurrent());
    }

    #[test]
    fn test_thread_access_pattern() {
        let mut pattern = ThreadAccessPattern::new(1);
        let e1 = EventId::new(1, 0);
        let e2 = EventId::new(1, 1);

        pattern.add_access(e1);
        pattern.add_access(e2);

        assert_eq!(pattern.accesses.len(), 2);
        assert!(!pattern.is_protected_by_lock("lock1"));
    }

    #[test]
    fn test_thread_access_pattern_lock() {
        let mut pattern = ThreadAccessPattern::new(1);

        pattern.acquire_lock("lock1".to_string());
        assert!(pattern.is_protected_by_lock("lock1"));

        pattern.release_lock();
        assert!(!pattern.is_protected_by_lock("lock1"));
    }

    #[test]
    fn test_race_detector_new() {
        let detector = RaceDetector::new();
        assert!(detector.races().is_empty());
        assert!(!detector.has_races());
    }

    #[test]
    fn test_race_detector_add_event() {
        let mut detector = RaceDetector::new();
        let e1 = EventId::new(1, 0);
        let event = MemoryEvent::new(e1, "x".to_string(), AccessType::Write, 0);

        detector.add_event(event);
        assert_eq!(detector.variable_accesses.len(), 1);
    }

    #[test]
    fn test_race_detector_simple_race() {
        let mut detector = RaceDetector::new();

        // Thread 1: Write to x
        let e1 = EventId::new(1, 0);
        let event1 = MemoryEvent::new(e1, "x".to_string(), AccessType::Write, 0);
        detector.add_event(event1);

        // Thread 2: Read from x (동시에, synchronization 없음)
        let e2 = EventId::new(2, 0);
        let event2 = MemoryEvent::new(e2, "x".to_string(), AccessType::Read, 0);
        detector.add_event(event2);

        detector.detect_races();
        assert!(detector.has_races());
        assert_eq!(detector.races().len(), 1);
    }

    #[test]
    fn test_race_detector_no_race_with_sync() {
        let mut detector = RaceDetector::new();

        // Thread 1: Write to x
        let e1 = EventId::new(1, 0);
        let event1 = MemoryEvent::new(e1, "x".to_string(), AccessType::Write, 0);
        detector.add_event(event1);

        // Thread 2: Read from x
        let e2 = EventId::new(2, 0);
        let event2 = MemoryEvent::new(e2, "x".to_string(), AccessType::Read, 1);
        detector.add_event(event2);

        // Synchronization: e1 happens-before e2
        detector.add_synchronization(e1, e2);

        detector.detect_races();
        assert!(!detector.has_races());
    }

    #[test]
    fn test_race_detector_write_write_race() {
        let mut detector = RaceDetector::new();

        let e1 = EventId::new(1, 0);
        let event1 = MemoryEvent::new(e1, "x".to_string(), AccessType::Write, 0);
        detector.add_event(event1);

        let e2 = EventId::new(2, 0);
        let event2 = MemoryEvent::new(e2, "x".to_string(), AccessType::Write, 0);
        detector.add_event(event2);

        detector.detect_races();
        assert!(detector.has_races());

        let race = &detector.races()[0];
        assert_eq!(race.race_type(), RaceType::WriteWrite);
    }

    #[test]
    fn test_race_detector_multiple_races() {
        let mut detector = RaceDetector::new();

        // Variable x: race
        let e1 = EventId::new(1, 0);
        let event1 = MemoryEvent::new(e1, "x".to_string(), AccessType::Write, 0);
        detector.add_event(event1);

        let e2 = EventId::new(2, 0);
        let event2 = MemoryEvent::new(e2, "x".to_string(), AccessType::Read, 0);
        detector.add_event(event2);

        // Variable y: no race
        let e3 = EventId::new(1, 1);
        let event3 = MemoryEvent::new(e3, "y".to_string(), AccessType::Write, 1);
        detector.add_event(event3);

        let e4 = EventId::new(2, 1);
        let event4 = MemoryEvent::new(e4, "y".to_string(), AccessType::Write, 1);
        detector.add_event(event4);

        // Sync for y
        detector.add_synchronization(e3, e4);

        detector.detect_races();
        assert_eq!(detector.races().len(), 1);
        assert_eq!(detector.races()[0].variable(), "x");
    }

    #[test]
    fn test_race_detector_same_thread() {
        let mut detector = RaceDetector::new();

        // 같은 스레드에서의 접근은 race가 아님
        let e1 = EventId::new(1, 0);
        let event1 = MemoryEvent::new(e1, "x".to_string(), AccessType::Write, 0);
        detector.add_event(event1);

        let e2 = EventId::new(1, 1);
        let event2 = MemoryEvent::new(e2, "x".to_string(), AccessType::Read, 1);
        detector.add_event(event2);

        detector.detect_races();
        assert!(!detector.has_races());
    }

    #[test]
    fn test_race_detector_races_on_variable() {
        let mut detector = RaceDetector::new();

        // x에 2개 race
        let e1 = EventId::new(1, 0);
        detector.add_event(MemoryEvent::new(e1, "x".to_string(), AccessType::Write, 0));

        let e2 = EventId::new(2, 0);
        detector.add_event(MemoryEvent::new(e2, "x".to_string(), AccessType::Read, 0));

        let e3 = EventId::new(3, 0);
        detector.add_event(MemoryEvent::new(e3, "x".to_string(), AccessType::Write, 0));

        // y에 race 없음
        let e4 = EventId::new(1, 1);
        detector.add_event(MemoryEvent::new(e4, "y".to_string(), AccessType::Write, 1));

        detector.detect_races();

        let x_races = detector.races_on_variable("x");
        assert!(x_races.len() > 0);

        let y_races = detector.races_on_variable("y");
        assert!(y_races.is_empty());
    }

    #[test]
    fn test_race_detector_statistics() {
        let mut detector = RaceDetector::new();

        // Write-Write race
        detector.add_event(MemoryEvent::new(EventId::new(1, 0), "x".to_string(), AccessType::Write, 0));
        detector.add_event(MemoryEvent::new(EventId::new(2, 0), "x".to_string(), AccessType::Write, 0));

        // Read-Write race
        detector.add_event(MemoryEvent::new(EventId::new(1, 1), "y".to_string(), AccessType::Read, 1));
        detector.add_event(MemoryEvent::new(EventId::new(2, 1), "y".to_string(), AccessType::Write, 1));

        detector.detect_races();

        let stats = detector.statistics();
        assert_eq!(stats.write_write, 1);
        assert_eq!(stats.read_write, 1);
        assert_eq!(stats.total_races, 2);
    }
}

