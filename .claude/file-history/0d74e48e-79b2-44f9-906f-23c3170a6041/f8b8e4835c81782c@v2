// ============================================================================
// FreeLang Race Detector - Data Race 감지
// ============================================================================
//
// 여러 스레드의 메모리 접근이 race condition을 유발하는지 감지합니다.
//
// Race condition:
// - 두 개 이상의 접근이 같은 변수에
// - 하나 이상은 쓰기
// - Synchronization이 없음
//
// 작성일: 2026-03-02
// 단계: Phase B.4 (Week 9-10)

use crate::sync::happens_before::{EventId, MemoryEvent, HappensBeforeAnalyzer, AccessType};
use std::collections::{HashMap, HashSet};

// ============================================================================
// Race Condition Types
// ============================================================================

/// Data race의 종류
#[derive(Clone, Copy, Debug, PartialEq, Eq)]
pub enum RaceType {
    /// Write-Write race: 두 스레드가 동시에 쓰기
    WriteWrite,

    /// Read-Write race: 하나는 읽고 다른 하나는 쓰기
    ReadWrite,

    /// Write-Read race: 하나는 쓰고 다른 하나는 읽기
    WriteRead,
}

/// Data race 정보
#[derive(Clone, Debug)]
pub struct DataRace {
    /// 변수명
    variable: String,

    /// 첫 번째 접근
    access1: EventId,

    /// 두 번째 접근
    access2: EventId,

    /// Race 종류
    race_type: RaceType,

    /// 동시성 여부 (happens-before 없음)
    concurrent: bool,
}

impl DataRace {
    pub fn new(
        variable: String,
        access1: EventId,
        access2: EventId,
        race_type: RaceType,
        concurrent: bool,
    ) -> DataRace {
        DataRace {
            variable,
            access1,
            access2,
            race_type,
            concurrent,
        }
    }

    pub fn variable(&self) -> &str {
        &self.variable
    }

    pub fn access1(&self) -> EventId {
        self.access1
    }

    pub fn access2(&self) -> EventId {
        self.access2
    }

    pub fn race_type(&self) -> RaceType {
        self.race_type
    }

    pub fn is_concurrent(&self) -> bool {
        self.concurrent
    }

    pub fn to_string(&self) -> String {
        let race_name = match self.race_type {
            RaceType::WriteWrite => "Write-Write",
            RaceType::ReadWrite => "Read-Write",
            RaceType::WriteRead => "Write-Read",
        };

        let status = if self.concurrent {
            "RACE DETECTED"
        } else {
            "SAFE (ordered)"
        };

        format!(
            "{} race on '{}': Thread {} Event {} vs Thread {} Event {} [{}]",
            race_name,
            self.variable,
            self.access1.thread_id(),
            self.access1.event_index(),
            self.access2.thread_id(),
            self.access2.event_index(),
            status
        )
    }
}

// ============================================================================
// Thread Access Pattern
// ============================================================================

/// 각 스레드의 접근 패턴
#[derive(Clone, Debug)]
pub struct ThreadAccessPattern {
    thread_id: u32,
    accesses: Vec<EventId>,
    lock_held: Option<String>,
}

impl ThreadAccessPattern {
    pub fn new(thread_id: u32) -> ThreadAccessPattern {
        ThreadAccessPattern {
            thread_id,
            accesses: Vec::new(),
            lock_held: None,
        }
    }

    pub fn add_access(&mut self, access: EventId) {
        self.accesses.push(access);
    }

    pub fn acquire_lock(&mut self, lock_name: String) {
        self.lock_held = Some(lock_name);
    }

    pub fn release_lock(&mut self) {
        self.lock_held = None;
    }

    pub fn is_protected_by_lock(&self, lock_name: &str) -> bool {
        match &self.lock_held {
            Some(name) => name == lock_name,
            None => false,
        }
    }
}

// ============================================================================
// Race Detector
// ============================================================================

pub struct RaceDetector {
    /// Happens-before 분석기
    hb_analyzer: HappensBeforeAnalyzer,

    /// 변수별 접근 목록
    variable_accesses: HashMap<String, Vec<EventId>>,

    /// 스레드별 접근 패턴
    thread_patterns: HashMap<u32, ThreadAccessPattern>,

    /// 감지된 races
    races: Vec<DataRace>,

    /// 보호된 변수 (lock으로 보호됨)
    protected_variables: HashMap<String, HashSet<String>>,
}

impl RaceDetector {
    pub fn new() -> RaceDetector {
        RaceDetector {
            hb_analyzer: HappensBeforeAnalyzer::new(),
            variable_accesses: HashMap::new(),
            thread_patterns: HashMap::new(),
            races: Vec::new(),
            protected_variables: HashMap::new(),
        }
    }

    /// 이벤트를 추가합니다.
    pub fn add_event(&mut self, event: MemoryEvent) {
        let thread_id = event.id().thread_id();
        let variable = event.variable().to_string();

        // Happens-before 분석기에 추가
        self.hb_analyzer.add_event(event.clone());

        // 변수별 접근 기록
        self.variable_accesses
            .entry(variable)
            .or_insert_with(Vec::new)
            .push(event.id());

        // 스레드별 접근 기록
        self.thread_patterns
            .entry(thread_id)
            .or_insert_with(|| ThreadAccessPattern::new(thread_id))
            .add_access(event.id());
    }

    /// Happens-before 에지를 추가합니다.
    pub fn add_synchronization(&mut self, e1: EventId, e2: EventId) {
        use crate::sync::happens_before::{HappensBeforeEdge, SynchronizationReason};
        let edge = HappensBeforeEdge::new(e1, e2, SynchronizationReason::ReleaseAcquire);
        self.hb_analyzer.add_edge(edge);
    }

    /// 변수가 lock으로 보호됨을 명시합니다.
    pub fn protect_variable(&mut self, variable: String, lock_name: String) {
        self.protected_variables
            .entry(lock_name)
            .or_insert_with(HashSet::new)
            .insert(variable);
    }

    /// Race를 감지합니다.
    pub fn detect_races(&mut self) {
        self.races.clear();

        for (variable, accesses) in &self.variable_accesses {
            if accesses.len() < 2 {
                continue;
            }

            // 모든 쌍 확인
            for i in 0..accesses.len() {
                for j in (i + 1)..accesses.len() {
                    let access1 = accesses[i];
                    let access2 = accesses[j];

                    // 같은 스레드면 race 아님
                    if access1.thread_id() == access2.thread_id() {
                        continue;
                    }

                    // 접근 타입 확인
                    let event1 = self.get_event(access1).unwrap();
                    let event2 = self.get_event(access2).unwrap();

                    let race_type = match (event1.is_write(), event2.is_write()) {
                        (true, true) => RaceType::WriteWrite,
                        (true, false) => RaceType::WriteRead,
                        (false, true) => RaceType::ReadWrite,
                        (false, false) => continue,  // 둘 다 읽기면 race 없음
                    };

                    // Happens-before 관계 확인
                    let concurrent = !self.hb_analyzer.happens_before(access1, access2)
                        && !self.hb_analyzer.happens_before(access2, access1);

                    if concurrent {
                        let race = DataRace::new(
                            variable.clone(),
                            access1,
                            access2,
                            race_type,
                            concurrent,
                        );
                        self.races.push(race);
                    }
                }
            }
        }
    }

    fn get_event(&self, id: EventId) -> Option<&MemoryEvent> {
        self.hb_analyzer
            .events()
            .iter()
            .find(|e| e.id() == id)
    }

    /// 감지된 모든 races를 반환합니다.
    pub fn races(&self) -> &[DataRace] {
        &self.races
    }

    /// Race가 있는지 확인합니다.
    pub fn has_races(&self) -> bool {
        !self.races.is_empty()
    }

    /// 특정 변수의 races를 반환합니다.
    pub fn races_on_variable(&self, variable: &str) -> Vec<&DataRace> {
        self.races
            .iter()
            .filter(|r| r.variable == variable)
            .collect()
    }

    /// False positive 감지 (보호된 변수에 대한 race 무시)
    pub fn filter_protected_races(&self) -> Vec<&DataRace> {
        self.races
            .iter()
            .filter(|race| {
                // 이 변수가 어떤 lock으로 보호되는가?
                for (lock_name, protected_vars) in &self.protected_variables {
                    if protected_vars.contains(race.variable()) {
                        // 이 변수는 보호됨
                        return false;
                    }
                }
                true  // 보호되지 않음
            })
            .collect()
    }

    /// Race 통계를 반환합니다.
    pub fn statistics(&self) -> RaceStatistics {
        let total_races = self.races.len();
        let write_write = self.races.iter().filter(|r| r.race_type == RaceType::WriteWrite).count();
        let read_write = self.races.iter().filter(|r| r.race_type == RaceType::ReadWrite).count();
        let write_read = self.races.iter().filter(|r| r.race_type == RaceType::WriteRead).count();

        RaceStatistics {
            total_races,
            write_write,
            read_write,
            write_read,
        }
    }
}

/// Race 통계
#[derive(Clone, Debug)]
pub struct RaceStatistics {
    pub total_races: usize,
    pub write_write: usize,
    pub read_write: usize,
    pub write_read: usize,
}

