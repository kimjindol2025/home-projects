use crate::stdlib::FlValue;

// ============================================================================
// TypeError - 타입 변환 에러 타입
// ============================================================================

/// 타입 변환 시 발생할 수 있는 에러
#[derive(Clone, Debug, PartialEq)]
pub enum TypeError {
    /// 문자열 파싱 실패
    ParseError(String),

    /// 지원되지 않는 타입 변환
    UnsupportedConversion { from: String, to: String },
}

impl std::fmt::Display for TypeError {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            TypeError::ParseError(s) => write!(f, "ParseError: {}", s),
            TypeError::UnsupportedConversion { from, to } => {
                write!(f, "Cannot convert {} to {}", from, to)
            }
        }
    }
}

// ============================================================================
// Type Conversion Functions
// ============================================================================

/// 값을 정수로 변환합니다.
///
/// # 규칙
/// - Int: 그대로 반환
/// - Float: 소수점 버림
/// - String: 파싱 시도 (실패 시 에러)
/// - Bool: true → 1, false → 0
/// - Null: 0
/// - Array/Object: 에러
///
/// # 예제
/// ```
/// assert_eq!(to_int(FlValue::Int(42)), Ok(42));
/// assert_eq!(to_int(FlValue::Float(3.7)), Ok(3));
/// assert_eq!(to_int(FlValue::Bool(true)), Ok(1));
/// assert_eq!(to_int(FlValue::Str("42".to_string())), Ok(42));
/// ```
pub fn to_int(value: FlValue) -> Result<i64, TypeError> {
    match value {
        FlValue::Int(n) => Ok(n),
        FlValue::Float(f) => Ok(f as i64),
        FlValue::Str(s) => s.trim()
            .parse::<i64>()
            .map_err(|_| TypeError::ParseError(s)),
        FlValue::Bool(b) => Ok(if b { 1 } else { 0 }),
        FlValue::Null => Ok(0),
        other => Err(TypeError::UnsupportedConversion {
            from: other.type_name().to_string(),
            to: "int".to_string(),
        }),
    }
}

/// 값을 부동소수점으로 변환합니다.
///
/// # 규칙
/// - Float: 그대로 반환
/// - Int: 정수로 변환
/// - String: 파싱 시도
/// - Bool: true → 1.0, false → 0.0
/// - Null: 0.0
/// - Array/Object: 에러
///
/// # 예제
/// ```
/// assert_eq!(to_float(FlValue::Float(3.14)), Ok(3.14));
/// assert_eq!(to_float(FlValue::Int(42)), Ok(42.0));
/// ```
pub fn to_float(value: FlValue) -> Result<f64, TypeError> {
    match value {
        FlValue::Float(f) => Ok(f),
        FlValue::Int(n) => Ok(n as f64),
        FlValue::Str(s) => s.trim()
            .parse::<f64>()
            .map_err(|_| TypeError::ParseError(s)),
        FlValue::Bool(b) => Ok(if b { 1.0 } else { 0.0 }),
        FlValue::Null => Ok(0.0),
        other => Err(TypeError::UnsupportedConversion {
            from: other.type_name().to_string(),
            to: "float".to_string(),
        }),
    }
}

/// 값을 문자열로 변환합니다.
///
/// # 규칙
/// - Str: 그대로 반환
/// - Int/Float/Bool: 문자열로 변환
/// - Null: "null" 반환
/// - Array: "[array]" 반환
/// - Object: "[object]" 반환
///
/// # 예제
/// ```
/// assert_eq!(to_string(FlValue::Int(42)), "42");
/// assert_eq!(to_string(FlValue::Bool(true)), "true");
/// assert_eq!(to_string(FlValue::Null), "null");
/// ```
pub fn to_string(value: FlValue) -> String {
    value.to_string_repr()
}

/// 값을 불리언으로 변환합니다 (Truthy evaluation).
///
/// # 규칙 (Falsy 값)
/// - Null: false
/// - Bool(false): false
/// - Int(0): false
/// - Float(0.0): false
/// - Str(""): false (빈 문자열)
/// - Array([]): false (빈 배열)
/// - Object({}): false (빈 객체)
///
/// # 나머지는 모두 true
///
/// # 예제
/// ```
/// assert_eq!(to_bool(FlValue::Int(0)), false);
/// assert_eq!(to_bool(FlValue::Int(1)), true);
/// assert_eq!(to_bool(FlValue::Str("hello".to_string())), true);
/// assert_eq!(to_bool(FlValue::Str("".to_string())), false);
/// ```
pub fn to_bool(value: FlValue) -> bool {
    value.is_truthy()
}

/// 값의 타입명을 문자열로 반환합니다.
///
/// # 반환값
/// - Int: "int"
/// - Float: "float"
/// - Bool: "bool"
/// - String: "string"
/// - Array: "array"
/// - Object: "object"
/// - Null: "null"
///
/// # 예제
/// ```
/// assert_eq!(type_of(FlValue::Int(42)), "int");
/// assert_eq!(type_of(FlValue::Null), "null");
/// ```
pub fn type_of(value: FlValue) -> &'static str {
    value.type_name()
}

/// 값이 null인지 확인합니다.
///
/// # 예제
/// ```
/// assert_eq!(is_null(FlValue::Null), true);
/// assert_eq!(is_null(FlValue::Int(0)), false);
/// ```
pub fn is_null(value: FlValue) -> bool {
    value.is_null()
}

