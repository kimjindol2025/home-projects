#[cfg(test)]
mod tests {
    use super::*;

    // to_int 테스트
    #[test]
    fn test_to_int_from_int() {
        assert_eq!(to_int(FlValue::Int(42)), Ok(42));
        assert_eq!(to_int(FlValue::Int(-100)), Ok(-100));
        assert_eq!(to_int(FlValue::Int(0)), Ok(0));
    }

    #[test]
    fn test_to_int_from_float() {
        assert_eq!(to_int(FlValue::Float(3.7)), Ok(3));
        assert_eq!(to_int(FlValue::Float(-2.9)), Ok(-2));
        assert_eq!(to_int(FlValue::Float(0.5)), Ok(0));
    }

    #[test]
    fn test_to_int_from_bool() {
        assert_eq!(to_int(FlValue::Bool(true)), Ok(1));
        assert_eq!(to_int(FlValue::Bool(false)), Ok(0));
    }

    #[test]
    fn test_to_int_from_string() {
        assert_eq!(to_int(FlValue::Str("42".to_string())), Ok(42));
        assert_eq!(to_int(FlValue::Str("-100".to_string())), Ok(-100));
        assert_eq!(to_int(FlValue::Str("  123  ".to_string())), Ok(123));
    }

    #[test]
    fn test_to_int_from_string_invalid() {
        let result = to_int(FlValue::Str("abc".to_string()));
        assert!(matches!(result, Err(TypeError::ParseError(_))));
    }

    #[test]
    fn test_to_int_from_null() {
        assert_eq!(to_int(FlValue::Null), Ok(0));
    }

    #[test]
    fn test_to_int_from_array_error() {
        let result = to_int(FlValue::Array(vec![]));
        assert!(matches!(result, Err(TypeError::UnsupportedConversion { .. })));
    }

    // to_float 테스트
    #[test]
    fn test_to_float_from_float() {
        assert_eq!(to_float(FlValue::Float(3.14)), Ok(3.14));
        assert_eq!(to_float(FlValue::Float(0.0)), Ok(0.0));
    }

    #[test]
    fn test_to_float_from_int() {
        assert_eq!(to_float(FlValue::Int(42)), Ok(42.0));
        assert_eq!(to_float(FlValue::Int(0)), Ok(0.0));
    }

    #[test]
    fn test_to_float_from_bool() {
        assert_eq!(to_float(FlValue::Bool(true)), Ok(1.0));
        assert_eq!(to_float(FlValue::Bool(false)), Ok(0.0));
    }

    #[test]
    fn test_to_float_from_string() {
        assert_eq!(to_float(FlValue::Str("3.14".to_string())), Ok(3.14));
        assert_eq!(to_float(FlValue::Str("-2.5".to_string())), Ok(-2.5));
    }

    #[test]
    fn test_to_float_from_null() {
        assert_eq!(to_float(FlValue::Null), Ok(0.0));
    }

    // to_string 테스트
    #[test]
    fn test_to_string_from_string() {
        assert_eq!(to_string(FlValue::Str("hello".to_string())), "hello");
    }

    #[test]
    fn test_to_string_from_int() {
        assert_eq!(to_string(FlValue::Int(42)), "42");
        assert_eq!(to_string(FlValue::Int(-100)), "-100");
    }

    #[test]
    fn test_to_string_from_float() {
        assert_eq!(to_string(FlValue::Float(3.14)), "3.14");
    }

    #[test]
    fn test_to_string_from_bool() {
        assert_eq!(to_string(FlValue::Bool(true)), "true");
        assert_eq!(to_string(FlValue::Bool(false)), "false");
    }

    #[test]
    fn test_to_string_from_null() {
        assert_eq!(to_string(FlValue::Null), "null");
    }

    // to_bool 테스트 (Truthy evaluation)
    #[test]
    fn test_to_bool_falsy() {
        assert_eq!(to_bool(FlValue::Null), false);
        assert_eq!(to_bool(FlValue::Bool(false)), false);
        assert_eq!(to_bool(FlValue::Int(0)), false);
        assert_eq!(to_bool(FlValue::Float(0.0)), false);
        assert_eq!(to_bool(FlValue::Str("".to_string())), false);
        assert_eq!(to_bool(FlValue::Array(vec![])), false);
    }

    #[test]
    fn test_to_bool_truthy() {
        assert_eq!(to_bool(FlValue::Bool(true)), true);
        assert_eq!(to_bool(FlValue::Int(1)), true);
        assert_eq!(to_bool(FlValue::Int(-1)), true);
        assert_eq!(to_bool(FlValue::Float(1.0)), true);
        assert_eq!(to_bool(FlValue::Str("hello".to_string())), true);
        assert_eq!(to_bool(FlValue::Array(vec![FlValue::Int(1)])), true);
    }

    // type_of 테스트
    #[test]
    fn test_type_of_all_types() {
        assert_eq!(type_of(FlValue::Int(42)), "int");
        assert_eq!(type_of(FlValue::Float(3.14)), "float");
        assert_eq!(type_of(FlValue::Bool(true)), "bool");
        assert_eq!(type_of(FlValue::Str("hello".to_string())), "string");
        assert_eq!(type_of(FlValue::Array(vec![])), "array");
        assert_eq!(type_of(FlValue::Object(std::collections::HashMap::new())), "object");
        assert_eq!(type_of(FlValue::Null), "null");
    }

    // is_null 테스트
    #[test]
    fn test_is_null_true() {
        assert_eq!(is_null(FlValue::Null), true);
    }

    #[test]
    fn test_is_null_false() {
        assert_eq!(is_null(FlValue::Int(0)), false);
        assert_eq!(is_null(FlValue::Bool(false)), false);
        assert_eq!(is_null(FlValue::Str("".to_string())), false);
    }
}

