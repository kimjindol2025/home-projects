/// 프로세스가 실행할 작업
pub enum TaskType {
    /// CPU 집약적 작업
    ComputeIntensive { iterations: u32 },

    /// I/O 대기 작업
    IOWait { wait_time_ms: u32 },

    /// 메모리 접근 작업
    MemoryAccess { addresses: u32 },

    /// 혼합 작업
    Mixed { compute: u32, io_wait: u32 },
}

pub struct Task {
    /// 작업 타입
    pub task_type: TaskType,

    /// 완료된 작업량
    pub completed: u32,

    /// 총 필요한 작업량
    pub total: u32,

    /// 작업 시작 시간 (시뮬레이션 틱)
    pub start_tick: u32,

    /// 작업 완료 시간
    pub end_tick: Option<u32>,
}

impl Task {
    pub fn new(task_type: TaskType) -> Self {
        let total = match &task_type {
            TaskType::ComputeIntensive { iterations } => *iterations,
            TaskType::IOWait { wait_time_ms } => *wait_time_ms,
            TaskType::MemoryAccess { addresses } => *addresses,
            TaskType::Mixed { compute, io_wait } => compute + io_wait,
        };

        Task {
            task_type,
            completed: 0,
            total,
            start_tick: 0,
            end_tick: None,
        }
    }

    pub fn execute(&mut self, work_units: u32) -> bool {
        if self.completed < self.total {
            self.completed += work_units;
            if self.completed >= self.total {
                return true;  // 작업 완료
            }
        }
        false  // 아직 실행 중
    }

    pub fn progress_percent(&self) -> u32 {
        if self.total == 0 {
            return 100;
        }
        (self.completed * 100) / self.total
    }

    pub fn is_completed(&self) -> bool {
        self.completed >= self.total
    }
}

// ============================================================================
// Part 2: 프로세스 상태 추적
// ============================================================================

/// 프로세스의 성능 메트릭
pub struct ProcessMetrics {
    /// 프로세스 ID
    pub pid: u32,

    /// 총 실행 시간 (틱)
    pub total_time: u32,

    /// CPU 사용 시간 (틱)
    pub cpu_time: u32,

    /// I/O 대기 시간 (틱)
    pub io_wait_time: u32,

    /// 컨텍스트 스위치 횟수
    pub context_switches: u32,

    /// 실행 횟수
    pub execution_count: u32,

    /// 완료된 작업 수
    pub completed_tasks: u32,
}

impl ProcessMetrics {
    pub fn new(pid: u32) -> Self {
        ProcessMetrics {
            pid,
            total_time: 0,
            cpu_time: 0,
            io_wait_time: 0,
            context_switches: 0,
            execution_count: 0,
            completed_tasks: 0,
        }
    }

    pub fn cpu_utilization(&self) -> f64 {
        if self.total_time == 0 {
            return 0.0;
        }
        (self.cpu_time as f64 / self.total_time as f64) * 100.0
    }

    pub fn io_utilization(&self) -> f64 {
        if self.total_time == 0 {
            return 0.0;
        }
        (self.io_wait_time as f64 / self.total_time as f64) * 100.0
    }

    pub fn record_execution(&mut self, cpu_time: u32, io_time: u32) {
        self.cpu_time += cpu_time;
        self.io_wait_time += io_time;
        self.total_time += cpu_time + io_time;
        self.execution_count += 1;
    }

    pub fn record_context_switch(&mut self) {
        self.context_switches += 1;
    }

    pub fn record_task_completion(&mut self) {
        self.completed_tasks += 1;
    }

    pub fn print_metrics(&self) {
        println!("\n📊 Process {} Metrics:", self.pid);
        println!("  Total Time: {} ticks", self.total_time);
        println!("  CPU Time: {} ticks ({:.2}%)", self.cpu_time, self.cpu_utilization());
        println!("  I/O Wait: {} ticks ({:.2}%)", self.io_wait_time, self.io_utilization());
        println!("  Context Switches: {}", self.context_switches);
        println!("  Executions: {}", self.execution_count);
        println!("  Completed Tasks: {}", self.completed_tasks);
    }
}

// ============================================================================
// Part 3: 멀티태스킹 시스템
// ============================================================================

/// 프로세스 항목
pub struct ProcessEntry {
    /// 프로세스 ID
    pub pid: u32,

    /// 현재 작업
    pub current_task: Task,

    /// 메트릭
    pub metrics: ProcessMetrics,

    /// 우선순위 (0-10, 10이 가장 높음)
    pub priority: u8,

    /// 상태 (Ready/Running/Blocked)
    pub state: String,
}

impl ProcessEntry {
    pub fn new(pid: u32, task: Task, priority: u8) -> Self {
        ProcessEntry {
            pid,
            current_task: task,
            metrics: ProcessMetrics::new(pid),
            priority,
            state: "Ready".to_string(),
        }
    }
}

/// 멀티태스킹 시스템
pub struct MultitaskingSystem {
    /// 프로세스들
    pub processes: Vec<ProcessEntry>,

    /// 현재 실행 중인 프로세스 인덱스
    pub current_process: Option<usize>,

    /// 전체 시스템 틱
    pub total_ticks: u32,

    /// 컨텍스트 스위치 횟수
    pub context_switch_count: u32,

    /// 완료된 작업 수
    pub completed_tasks: u32,
}

impl MultitaskingSystem {
    pub fn new() -> Self {
        MultitaskingSystem {
            processes: Vec::new(),
            current_process: None,
            total_ticks: 0,
            context_switch_count: 0,
            completed_tasks: 0,
        }
    }

    pub fn add_process(&mut self, pid: u32, task: Task, priority: u8) {
        let entry = ProcessEntry::new(pid, task, priority);
        self.processes.push(entry);

        if self.current_process.is_none() {
            self.current_process = Some(0);
        }
    }

    pub fn execute_round(&mut self) -> Option<(u32, String)> {
        if self.processes.is_empty() {
            return None;
        }

        // 현재 프로세스 실행
        let idx = self.current_process?;
        let process = &mut self.processes[idx];

        if !process.current_task.is_completed() {
            process.state = "Running".to_string();

            // 작업 실행 (1 틱 = 일정 작업량)
            let work_completed = process.current_task.execute(1);
            process.metrics.record_execution(1, 0);

            if work_completed {
                process.metrics.record_task_completion();
                self.completed_tasks += 1;
                println!("  ✅ Process {} task completed ({} completed total)",
                         process.pid, self.completed_tasks);
            }

            let status = format!("PID {} - {}% complete",
                                process.pid,
                                process.current_task.progress_percent());

            // 다음 프로세스로 전환
            let next_idx = (idx + 1) % self.processes.len();
            if next_idx != idx {
                self.processes[idx].metrics.record_context_switch();
                self.processes[next_idx].metrics.record_context_switch();
                self.context_switch_count += 1;
                process.state = "Ready".to_string();
                self.current_process = Some(next_idx);
            }

            self.total_ticks += 1;
            return Some((process.pid, status));
        }

        // 다음 프로세스로 전환
        let next_idx = (idx + 1) % self.processes.len();
        self.current_process = Some(next_idx);
        self.context_switch_count += 1;

        self.execute_round()  // 다음 프로세스 실행
    }

    pub fn execute_for_time(&mut self, time_ticks: u32) {
        for _ in 0..time_ticks {
            if self.execute_round().is_none() {
                break;
            }
        }
    }

    pub fn all_tasks_completed(&self) -> bool {
        self.processes.iter().all(|p| p.current_task.is_completed())
    }

    pub fn print_system_status(&self) {
        println!("\n╔════════════════════════════════════════════════════════════╗");
        println!("║         Multitasking System Status Report                  ║");
        println!("╚════════════════════════════════════════════════════════════╝");

        println!("\n🔄 System Metrics:");
        println!("  Total Ticks: {}", self.total_ticks);
        println!("  Context Switches: {}", self.context_switch_count);
        println!("  Completed Tasks: {}", self.completed_tasks);
        println!("  Total Processes: {}", self.processes.len());

        println!("\n📋 Process Status:");
        for process in &self.processes {
            let progress = process.current_task.progress_percent();
            let bar = "█".repeat((progress / 10) as usize) +
                     "░".repeat((10 - (progress / 10)) as usize);

            println!("  PID {}: [{}] {}% - {}",
                     process.pid, bar, progress, process.state);
        }

        println!("\n📊 Per-Process Metrics:");
        for process in &self.processes {
            process.metrics.print_metrics();
        }
    }
}

// ============================================================================
// Part 4: 멀티태스킹 시뮬레이션
// ============================================================================

pub fn main() {
    println!("╔════════════════════════════════════════════════════════════╗");
    println!("║    FreeLang OS Kernel - Phase G Week 2 Multitasking       ║");
    println!("╚════════════════════════════════════════════════════════════╝\n");

    let mut system = MultitaskingSystem::new();

    // 프로세스 추가
    println!("🔄 Creating processes...");

    let task1 = Task::new(TaskType::ComputeIntensive { iterations: 30 });
    system.add_process(1, task1, 5);
    println!("   ✅ Process 1: Compute-intensive (30 iterations)");

    let task2 = Task::new(TaskType::ComputeIntensive { iterations: 40 });
    system.add_process(2, task2, 5);
    println!("   ✅ Process 2: Compute-intensive (40 iterations)");

    let task3 = Task::new(TaskType::ComputeIntensive { iterations: 25 });
    system.add_process(3, task3, 5);
    println!("   ✅ Process 3: Compute-intensive (25 iterations)");

    // 멀티태스킹 실행
    println!("\n⏱️  Executing multitasking (50 ticks)...\n");

    system.execute_for_time(50);

    // 상태 출력
    system.print_system_status();

    println!("\n✨ Multitasking simulation complete!");
    println!("   All tasks completed: {}", system.all_tasks_completed());
    println!();
}

