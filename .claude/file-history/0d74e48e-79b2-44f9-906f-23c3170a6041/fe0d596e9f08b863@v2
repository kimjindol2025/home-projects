#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_task_creation() {
        let task = Task::new(TaskType::ComputeIntensive { iterations: 100 });
        assert_eq!(task.total, 100);
        assert_eq!(task.completed, 0);
        assert_eq!(task.progress_percent(), 0);
    }

    #[test]
    fn test_task_execution() {
        let mut task = Task::new(TaskType::ComputeIntensive { iterations: 10 });
        let completed = task.execute(5);
        assert_eq!(task.completed, 5);
        assert!(!completed);

        task.execute(5);
        assert_eq!(task.completed, 10);
        assert!(task.is_completed());
    }

    #[test]
    fn test_task_progress() {
        let mut task = Task::new(TaskType::ComputeIntensive { iterations: 100 });
        task.execute(25);
        assert_eq!(task.progress_percent(), 25);

        task.execute(50);
        assert_eq!(task.progress_percent(), 75);
    }

    #[test]
    fn test_process_metrics() {
        let mut metrics = ProcessMetrics::new(1);
        metrics.record_execution(10, 5);
        assert_eq!(metrics.total_time, 15);
        assert_eq!(metrics.cpu_time, 10);
        assert_eq!(metrics.io_wait_time, 5);
    }

    #[test]
    fn test_multitasking_system_creation() {
        let system = MultitaskingSystem::new();
        assert_eq!(system.processes.len(), 0);
        assert_eq!(system.total_ticks, 0);
    }

    #[test]
    fn test_multitasking_system_add_process() {
        let mut system = MultitaskingSystem::new();
        let task = Task::new(TaskType::ComputeIntensive { iterations: 10 });
        system.add_process(1, task, 5);

        assert_eq!(system.processes.len(), 1);
        assert_eq!(system.current_process, Some(0));
    }

    #[test]
    fn test_multitasking_system_execute() {
        let mut system = MultitaskingSystem::new();

        let task1 = Task::new(TaskType::ComputeIntensive { iterations: 10 });
        system.add_process(1, task1, 5);

        let task2 = Task::new(TaskType::ComputeIntensive { iterations: 10 });
        system.add_process(2, task2, 5);

        system.execute_for_time(10);

        assert!(system.total_ticks > 0);
        assert!(system.context_switch_count > 0);
    }

    #[test]
    fn test_multitasking_completion() {
        let mut system = MultitaskingSystem::new();

        let task = Task::new(TaskType::ComputeIntensive { iterations: 5 });
        system.add_process(1, task, 5);

        system.execute_for_time(10);

        assert!(system.all_tasks_completed());
        assert_eq!(system.completed_tasks, 1);
    }

    #[test]
    fn test_process_metrics_cpu_utilization() {
        let mut metrics = ProcessMetrics::new(1);
        metrics.record_execution(50, 50);

        let cpu_util = metrics.cpu_utilization();
        assert!(cpu_util > 49.0 && cpu_util < 51.0);
    }

    #[test]
    fn test_multitasking_three_processes() {
        let mut system = MultitaskingSystem::new();

        let task1 = Task::new(TaskType::ComputeIntensive { iterations: 20 });
        system.add_process(1, task1, 5);

        let task2 = Task::new(TaskType::ComputeIntensive { iterations: 30 });
        system.add_process(2, task2, 5);

        let task3 = Task::new(TaskType::ComputeIntensive { iterations: 25 });
        system.add_process(3, task3, 5);

        system.execute_for_time(100);

        assert_eq!(system.completed_tasks, 3);
        assert!(system.all_tasks_completed());
    }

    #[test]
    fn test_context_switches_multiple_processes() {
        let mut system = MultitaskingSystem::new();

        let task1 = Task::new(TaskType::ComputeIntensive { iterations: 10 });
        system.add_process(1, task1, 5);

        let task2 = Task::new(TaskType::ComputeIntensive { iterations: 10 });
        system.add_process(2, task2, 5);

        let task3 = Task::new(TaskType::ComputeIntensive { iterations: 10 });
        system.add_process(3, task3, 5);

        system.execute_for_time(30);

        // 3개 프로세스에서 라운드로빈이므로 많은 컨텍스트 스위치 발생
        assert!(system.context_switch_count > 0);
    }
}
