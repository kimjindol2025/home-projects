use std::collections::HashMap;

// ============================================================================
// Lifetime 표현
// ============================================================================

/// Lifetime: 참조의 유효 기간을 나타냅니다.
///
/// Rust에서 'a, 'b, 'static 같은 식별자입니다.
#[derive(Clone, Copy, Debug, PartialEq, Eq, Hash)]
pub struct Lifetime {
    id: u32,
}

impl Lifetime {
    /// 새로운 Lifetime을 생성합니다.
    pub fn new(id: u32) -> Lifetime {
        Lifetime { id }
    }

    /// 'static lifetime을 반환합니다.
    pub fn static_lifetime() -> Lifetime {
        Lifetime { id: u32::MAX }
    }

    /// 'static 인지 확인합니다.
    pub fn is_static(&self) -> bool {
        self.id == u32::MAX
    }

    pub fn to_string(&self) -> String {
        if self.is_static() {
            "'static".to_string()
        } else {
            format!("'{}", self.id)
        }
    }
}

// ============================================================================
// Scope: 코드 블록
// ============================================================================

/// Scope: 중괄호로 둘러싸인 코드 영역
#[derive(Clone, Copy, Debug, PartialEq, Eq, Hash)]
pub struct ScopeId {
    id: u32,
}

impl ScopeId {
    pub fn new(id: u32) -> ScopeId {
        ScopeId { id }
    }

    pub fn global() -> ScopeId {
        ScopeId { id: 0 }
    }
}

// ============================================================================
// Reference Type: 참조 타입
// ============================================================================

/// 참조 타입: &T (불변) 또는 &mut T (가변)
#[derive(Clone, Copy, Debug, PartialEq, Eq)]
pub enum RefType {
    /// 불변 참조 &'a T
    Immutable(Lifetime),

    /// 가변 참조 &'a mut T
    Mutable(Lifetime),
}

impl RefType {
    /// 참조의 Lifetime을 얻습니다.
    pub fn lifetime(&self) -> Lifetime {
        match self {
            RefType::Immutable(lt) => *lt,
            RefType::Mutable(lt) => *lt,
        }
    }

    /// 불변 참조인지 확인합니다.
    pub fn is_immutable(&self) -> bool {
        matches!(self, RefType::Immutable(_))
    }

    /// 가변 참조인지 확인합니다.
    pub fn is_mutable(&self) -> bool {
        matches!(self, RefType::Mutable(_))
    }

    pub fn to_string(&self) -> String {
        match self {
            RefType::Immutable(lt) => format!("&{}", lt.to_string()),
            RefType::Mutable(lt) => format!("&{} mut", lt.to_string()),
        }
    }
}

// ============================================================================
// Lifetime Constraint: Lifetime 간 제약
// ============================================================================

/// Lifetime 간 제약: 'a: 'b (a outlives b)
#[derive(Clone, Copy, Debug, PartialEq, Eq)]
pub struct LifetimeConstraint {
    /// Outliver: 더 오래 유지되는 lifetime
    outliver: Lifetime,

    /// Outlived: 더 짧게 유지되는 lifetime
    outlived: Lifetime,
}

impl LifetimeConstraint {
    /// 새로운 제약을 생성합니다: 'a: 'b
    pub fn new(outliver: Lifetime, outlived: Lifetime) -> LifetimeConstraint {
        LifetimeConstraint { outliver, outlived }
    }

    pub fn to_string(&self) -> String {
        format!("{}: {}", self.outliver.to_string(), self.outlived.to_string())
    }
}

// ============================================================================
// Lifetime Analyzer
// ============================================================================

/// Lifetime 분석 엔진
pub struct LifetimeAnalyzer {
    // Lifetime 간 제약 관계
    constraints: Vec<LifetimeConstraint>,

    // 각 변수의 Scope
    variable_scopes: HashMap<String, ScopeId>,

    // 각 Scope의 부모 Scope
    scope_hierarchy: HashMap<ScopeId, ScopeId>,

    // 각 Scope의 생성 순서 (더 큰 ID = 더 깊은 scope)
    scope_counter: u32,
}

impl LifetimeAnalyzer {
    /// 새로운 분석기를 생성합니다.
    pub fn new() -> LifetimeAnalyzer {
        let mut analyzer = LifetimeAnalyzer {
            constraints: Vec::new(),
            variable_scopes: HashMap::new(),
            scope_hierarchy: HashMap::new(),
            scope_counter: 0,
        };

        // Global scope 초기화
        analyzer.scope_hierarchy.insert(ScopeId::global(), ScopeId::global());
        analyzer.scope_counter = 1;

        analyzer
    }

    /// 새로운 Scope을 생성합니다.
    pub fn enter_scope(&mut self, parent: ScopeId) -> ScopeId {
        let scope_id = ScopeId::new(self.scope_counter);
        self.scope_counter += 1;
        self.scope_hierarchy.insert(scope_id, parent);
        scope_id
    }

    /// 변수를 선언합니다.
    pub fn declare_variable(&mut self, name: String, scope: ScopeId) {
        self.variable_scopes.insert(name, scope);
    }

    /// Lifetime 제약을 추가합니다: 'a: 'b
    pub fn add_constraint(&mut self, constraint: LifetimeConstraint) {
        self.constraints.push(constraint);
    }

    /// 'a가 'b보다 오래 유지되는지 확인합니다.
    pub fn outlives(&self, a: Lifetime, b: Lifetime) -> bool {
        // 'static은 모든 lifetime을 outlive
        if a.is_static() {
            return true;
        }
        if b.is_static() && !a.is_static() {
            return false;
        }

        // 제약 확인
        for constraint in &self.constraints {
            if constraint.outliver == a && constraint.outlived == b {
                return true;
            }
        }

        // 이행성 확인 (transitivity)
        for constraint in &self.constraints {
            if constraint.outliver == a {
                if self.outlives(constraint.outlived, b) {
                    return true;
                }
            }
        }

        false
    }

    /// 두 Lifetime의 생명주기가 겹치는지 확인합니다.
    pub fn overlaps(&self, lt1: Lifetime, lt2: Lifetime) -> bool {
        // 'static은 모든 것과 겹침
        if lt1.is_static() || lt2.is_static() {
            return true;
        }

        // 같은 lifetime이면 겹침
        if lt1 == lt2 {
            return true;
        }

        // 제약이 없으면 겹칠 수 있음
        !self.outlives(lt1, lt2) && !self.outlives(lt2, lt1)
    }

    /// 변수가 선언된 Scope을 반환합니다.
    pub fn get_variable_scope(&self, name: &str) -> Option<ScopeId> {
        self.variable_scopes.get(name).copied()
    }

    /// Scope이 다른 Scope을 포함하는지 확인합니다.
    pub fn scope_contains(&self, parent: ScopeId, child: ScopeId) -> bool {
        let mut current = child;
        loop {
            if current == parent {
                return true;
            }
            if current == ScopeId::global() {
                return false;
            }
            match self.scope_hierarchy.get(&current) {
                Some(&p) => current = p,
                None => return false,
            }
        }
    }

    /// 모든 제약을 반환합니다.
    pub fn constraints(&self) -> &[LifetimeConstraint] {
        &self.constraints
    }
}

