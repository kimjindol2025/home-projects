#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_lifetime_static() {
        let lt = Lifetime::static_lifetime();
        assert!(lt.is_static());
    }

    #[test]
    fn test_lifetime_equality() {
        let lt1 = Lifetime::new(1);
        let lt2 = Lifetime::new(1);
        let lt3 = Lifetime::new(2);

        assert_eq!(lt1, lt2);
        assert_ne!(lt1, lt3);
    }

    #[test]
    fn test_ref_type_immutable() {
        let lt = Lifetime::new(1);
        let ref_type = RefType::Immutable(lt);

        assert!(ref_type.is_immutable());
        assert!(!ref_type.is_mutable());
        assert_eq!(ref_type.lifetime(), lt);
    }

    #[test]
    fn test_ref_type_mutable() {
        let lt = Lifetime::new(2);
        let ref_type = RefType::Mutable(lt);

        assert!(!ref_type.is_immutable());
        assert!(ref_type.is_mutable());
        assert_eq!(ref_type.lifetime(), lt);
    }

    #[test]
    fn test_lifetime_constraint_creation() {
        let lt_a = Lifetime::new(1);
        let lt_b = Lifetime::new(2);
        let constraint = LifetimeConstraint::new(lt_a, lt_b);

        assert_eq!(constraint.outliver, lt_a);
        assert_eq!(constraint.outlived, lt_b);
    }

    #[test]
    fn test_analyzer_new() {
        let analyzer = LifetimeAnalyzer::new();
        assert_eq!(analyzer.constraints.len(), 0);
    }

    #[test]
    fn test_analyzer_enter_scope() {
        let mut analyzer = LifetimeAnalyzer::new();

        let scope1 = analyzer.enter_scope(ScopeId::global());
        let scope2 = analyzer.enter_scope(scope1);

        assert_ne!(scope1, scope2);
    }

    #[test]
    fn test_analyzer_declare_variable() {
        let mut analyzer = LifetimeAnalyzer::new();
        let scope = ScopeId::global();

        analyzer.declare_variable("x".to_string(), scope);
        assert_eq!(analyzer.get_variable_scope("x"), Some(scope));
        assert_eq!(analyzer.get_variable_scope("y"), None);
    }

    #[test]
    fn test_analyzer_add_constraint() {
        let mut analyzer = LifetimeAnalyzer::new();
        let lt_a = Lifetime::new(1);
        let lt_b = Lifetime::new(2);
        let constraint = LifetimeConstraint::new(lt_a, lt_b);

        analyzer.add_constraint(constraint);
        assert_eq!(analyzer.constraints.len(), 1);
    }

    #[test]
    fn test_analyzer_outlives_direct() {
        let mut analyzer = LifetimeAnalyzer::new();
        let lt_a = Lifetime::new(1);
        let lt_b = Lifetime::new(2);

        analyzer.add_constraint(LifetimeConstraint::new(lt_a, lt_b));
        assert!(analyzer.outlives(lt_a, lt_b));
        assert!(!analyzer.outlives(lt_b, lt_a));
    }

    #[test]
    fn test_analyzer_outlives_static() {
        let analyzer = LifetimeAnalyzer::new();
        let lt_static = Lifetime::static_lifetime();
        let lt_other = Lifetime::new(1);

        assert!(analyzer.outlives(lt_static, lt_other));
        assert!(!analyzer.outlives(lt_other, lt_static));
    }

    #[test]
    fn test_analyzer_outlives_transitive() {
        let mut analyzer = LifetimeAnalyzer::new();
        let lt_a = Lifetime::new(1);
        let lt_b = Lifetime::new(2);
        let lt_c = Lifetime::new(3);

        analyzer.add_constraint(LifetimeConstraint::new(lt_a, lt_b));
        analyzer.add_constraint(LifetimeConstraint::new(lt_b, lt_c));

        // 이행성: a: b, b: c => a: c
        assert!(analyzer.outlives(lt_a, lt_b));
        assert!(analyzer.outlives(lt_b, lt_c));
        assert!(analyzer.outlives(lt_a, lt_c));
    }

    #[test]
    fn test_analyzer_overlaps() {
        let mut analyzer = LifetimeAnalyzer::new();
        let lt_a = Lifetime::new(1);
        let lt_b = Lifetime::new(2);

        // 제약 없이 겹침
        assert!(analyzer.overlaps(lt_a, lt_b));

        // 제약 추가 후
        analyzer.add_constraint(LifetimeConstraint::new(lt_a, lt_b));
        assert!(!analyzer.overlaps(lt_a, lt_b));
    }

    #[test]
    fn test_analyzer_scope_contains() {
        let mut analyzer = LifetimeAnalyzer::new();
        let global = ScopeId::global();
        let scope1 = analyzer.enter_scope(global);
        let scope2 = analyzer.enter_scope(scope1);

        assert!(analyzer.scope_contains(global, scope1));
        assert!(analyzer.scope_contains(global, scope2));
        assert!(analyzer.scope_contains(scope1, scope2));
        assert!(!analyzer.scope_contains(scope2, scope1));
    }

    #[test]
    fn test_analyzer_complex_hierarchy() {
        let mut analyzer = LifetimeAnalyzer::new();
        let global = ScopeId::global();

        // Global scope
        //   └─ scope_a
        //        └─ scope_b
        //        └─ scope_c

        let scope_a = analyzer.enter_scope(global);
        let scope_b = analyzer.enter_scope(scope_a);
        let scope_c = analyzer.enter_scope(scope_a);

        analyzer.declare_variable("x".to_string(), scope_a);
        analyzer.declare_variable("y".to_string(), scope_b);
        analyzer.declare_variable("z".to_string(), scope_c);

        assert_eq!(analyzer.get_variable_scope("x"), Some(scope_a));
        assert_eq!(analyzer.get_variable_scope("y"), Some(scope_b));
        assert_eq!(analyzer.get_variable_scope("z"), Some(scope_c));

        assert!(analyzer.scope_contains(global, scope_b));
        assert!(analyzer.scope_contains(scope_a, scope_b));
        assert!(!analyzer.scope_contains(scope_b, scope_c));
    }
}

