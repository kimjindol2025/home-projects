/// 표준출력에 텍스트를 출력합니다 (줄바꿈 없음).
///
/// # 예제
/// ```
/// print("Hello");  // "Hello" 출력
/// ```
pub fn print(text: String) -> FlValue {
    std::print!("{}", text);
    let _ = std::io::stdout().flush();
    FlValue::Null
}

/// 표준출력에 텍스트를 출력합니다 (줄바꿈 포함).
///
/// # 예제
/// ```
/// println("Hello");  // "Hello\n" 출력
/// ```
pub fn println(text: String) -> FlValue {
    std::println!("{}", text);
    FlValue::Null
}

/// 표준에러에 텍스트를 출력합니다 (줄바꿈 없음).
///
/// # 예제
/// ```
/// eprint("Error");  // stderr에 "Error" 출력
/// ```
pub fn eprint(text: String) -> FlValue {
    std::eprint!("{}", text);
    let _ = std::io::stderr().flush();
    FlValue::Null
}

/// 표준에러에 텍스트를 출력합니다 (줄바꿈 포함).
///
/// # 예제
/// ```
/// eprintln("Error");  // stderr에 "Error\n" 출력
/// ```
pub fn eprintln(text: String) -> FlValue {
    std::eprintln!("{}", text);
    FlValue::Null
}

// ============================================================================
// File Input/Output Functions
// ============================================================================

/// 파일을 읽어 문자열로 반환합니다.
///
/// # 에러
/// - 파일이 없으면 IoError::NotFound
/// - 읽기 권한이 없으면 IoError::PermissionDenied
///
/// # 예제
/// ```
/// let content = read_file("test.txt").unwrap();
/// assert_eq!(content, FlValue::Str("...".to_string()));
/// ```
pub fn read_file(path: String) -> Result<FlValue, IoError> {
    let mut file = File::open(&path)
        .map_err(|e| {
            if e.kind() == io::ErrorKind::NotFound {
                IoError::NotFound(path)
            } else if e.kind() == io::ErrorKind::PermissionDenied {
                IoError::PermissionDenied(path)
            } else {
                IoError::ReadError(path)
            }
        })?;

    let mut contents = String::new();
    file.read_to_string(&mut contents)
        .map_err(|_| IoError::ReadError(path))?;

    Ok(FlValue::Str(contents))
}

/// 파일에 텍스트를 씁니다 (기존 내용 덮어쓰기).
///
/// # 에러
/// - 쓰기 권한이 없으면 IoError::PermissionDenied
///
/// # 예제
/// ```
/// write_file("test.txt", "Hello").unwrap();
/// ```
pub fn write_file(path: String, content: String) -> Result<FlValue, IoError> {
    let mut file = OpenOptions::new()
        .create(true)
        .write(true)
        .truncate(true)
        .open(&path)
        .map_err(|e| {
            if e.kind() == io::ErrorKind::PermissionDenied {
                IoError::PermissionDenied(path)
            } else {
                IoError::WriteError(path)
            }
        })?;

    file.write_all(content.as_bytes())
        .map_err(|_| IoError::WriteError(path))?;

    Ok(FlValue::Null)
}

/// 파일에 텍스트를 추가합니다 (기존 내용 보존).
///
/// # 예제
/// ```
/// append_file("test.txt", "\nMore text").unwrap();
/// ```
pub fn append_file(path: String, content: String) -> Result<FlValue, IoError> {
    let mut file = OpenOptions::new()
        .create(true)
        .append(true)
        .open(&path)
        .map_err(|e| {
            if e.kind() == io::ErrorKind::PermissionDenied {
                IoError::PermissionDenied(path)
            } else {
                IoError::WriteError(path)
            }
        })?;

    file.write_all(content.as_bytes())
        .map_err(|_| IoError::WriteError(path))?;

    Ok(FlValue::Null)
}

// ============================================================================
// File Information Functions
// ============================================================================

/// 파일 또는 디렉토리가 존재하는지 확인합니다.
///
/// # 예제
/// ```
/// assert_eq!(file_exists("test.txt"), FlValue::Bool(true));
/// assert_eq!(file_exists("nonexistent.txt"), FlValue::Bool(false));
/// ```
pub fn file_exists(path: String) -> FlValue {
    FlValue::Bool(Path::new(&path).exists())
}

/// 파일의 크기를 바이트 단위로 반환합니다.
///
/// # 에러
/// - 파일이 없으면 IoError::NotFound
///
/// # 예제
/// ```
/// let size = file_size("test.txt").unwrap();
/// assert_eq!(size, FlValue::Int(1024));
/// ```
pub fn file_size(path: String) -> Result<FlValue, IoError> {
    let metadata = fs::metadata(&path)
        .map_err(|_| IoError::NotFound(path))?;

    Ok(FlValue::Int(metadata.len() as i64))
}

/// 파일을 삭제합니다.
///
/// # 에러
/// - 파일이 없으면 IoError::NotFound
/// - 권한이 없으면 IoError::PermissionDenied
///
/// # 예제
/// ```
/// delete_file("test.txt").unwrap();
/// ```
pub fn delete_file(path: String) -> Result<FlValue, IoError> {
    fs::remove_file(&path)
        .map_err(|e| {
            if e.kind() == io::ErrorKind::NotFound {
                IoError::NotFound(path)
            } else if e.kind() == io::ErrorKind::PermissionDenied {
                IoError::PermissionDenied(path)
            } else {
                IoError::DeleteError(path)
            }
        })?;

    Ok(FlValue::Null)
}

// ============================================================================
// Directory Functions
// ============================================================================

/// 디렉토리의 모든 파일을 배열로 반환합니다.
///
/// # 에러
/// - 디렉토리가 없으면 IoError::NotFound
///
/// # 예제
/// ```
/// let files = list_dir(".").unwrap();
/// ```
pub fn list_dir(path: String) -> Result<FlValue, IoError> {
    let entries = fs::read_dir(&path)
        .map_err(|_| IoError::NotFound(path))?;

    let mut files = Vec::new();
    for entry in entries {
        if let Ok(entry) = entry {
            if let Some(name) = entry.file_name().into_string().ok() {
                files.push(FlValue::Str(name));
            }
        }
    }

    Ok(FlValue::Array(files))
}

/// 디렉토리를 생성합니다.
///
/// # 에러
/// - 권한이 없으면 IoError::PermissionDenied
///
/// # 예제
/// ```
/// mkdir("mydir").unwrap();
/// ```
pub fn mkdir(path: String) -> Result<FlValue, IoError> {
    fs::create_dir(&path)
        .map_err(|e| {
            if e.kind() == io::ErrorKind::PermissionDenied {
                IoError::PermissionDenied(path)
            } else {
                IoError::CreateDirError(path)
            }
        })?;

    Ok(FlValue::Null)
}

// ============================================================================
// Standard Input
// ============================================================================

/// 표준입력에서 한 줄을 읽습니다.
///
/// # 예제
/// ```
/// let input = read_stdin().unwrap();  // 사용자 입력 대기
/// ```
pub fn read_stdin() -> Result<FlValue, IoError> {
    let mut line = String::new();
    io::stdin().read_line(&mut line)
        .map_err(|_| IoError::ReadError("stdin".to_string()))?;

    // 줄바꿈 제거
    if line.ends_with('\n') {
        line.pop();
        if line.ends_with('\r') {
            line.pop();
        }
    }

    Ok(FlValue::Str(line))
}

