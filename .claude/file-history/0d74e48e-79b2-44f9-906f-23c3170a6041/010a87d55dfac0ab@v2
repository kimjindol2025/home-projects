// Advanced File Operations
// ============================================================================

/// 파일을 복사합니다.
///
/// # 예제
/// ```
/// file_copy("source.txt", "dest.txt").unwrap();
/// ```
pub fn file_copy(src: String, dst: String) -> Result<FlValue, IoError> {
    fs::copy(&src, &dst)
        .map_err(|e| {
            if e.kind() == io::ErrorKind::NotFound {
                IoError::NotFound(src)
            } else if e.kind() == io::ErrorKind::PermissionDenied {
                IoError::PermissionDenied(src)
            } else {
                IoError::IoError(format!("Failed to copy {} to {}", src, dst))
            }
        })?;

    Ok(FlValue::Null)
}

/// 파일을 이동합니다.
///
/// # 예제
/// ```
/// file_move("old.txt", "new.txt").unwrap();
/// ```
pub fn file_move(src: String, dst: String) -> Result<FlValue, IoError> {
    fs::rename(&src, &dst)
        .map_err(|e| {
            if e.kind() == io::ErrorKind::NotFound {
                IoError::NotFound(src)
            } else if e.kind() == io::ErrorKind::PermissionDenied {
                IoError::PermissionDenied(src)
            } else {
                IoError::IoError(format!("Failed to move {} to {}", src, dst))
            }
        })?;

    Ok(FlValue::Null)
}

