#[cfg(test)]
mod tests {
    use super::*;
    use std::fs;
    use std::path::Path;

    // 테스트용 임시 파일명
    fn temp_file() -> String {
        "/tmp/freelang_test_io.txt".to_string()
    }

    fn cleanup() {
        let _ = fs::remove_file(temp_file());
    }

    #[test]
    fn test_print_simple() {
        print("test".to_string());
        // 출력 확인은 실행 시 시각적으로 확인
    }

    #[test]
    fn test_println_simple() {
        println("test".to_string());
    }

    #[test]
    fn test_eprint_simple() {
        eprint("test".to_string());
    }

    #[test]
    fn test_eprintln_simple() {
        eprintln("test".to_string());
    }

    #[test]
    fn test_write_and_read_file() {
        cleanup();

        let path = temp_file();
        let content = "Hello, World!".to_string();

        write_file(path.clone(), content.clone()).unwrap();
        let result = read_file(path).unwrap();

        assert_eq!(result, FlValue::Str(content));
        cleanup();
    }

    #[test]
    fn test_file_exists_true() {
        cleanup();

        let path = temp_file();
        write_file(path.clone(), "test".to_string()).unwrap();

        let result = file_exists(path.clone());
        assert_eq!(result, FlValue::Bool(true));

        cleanup();
    }

    #[test]
    fn test_file_exists_false() {
        let result = file_exists("/tmp/nonexistent_freelang_test.txt".to_string());
        assert_eq!(result, FlValue::Bool(false));
    }

    #[test]
    fn test_append_file() {
        cleanup();

        let path = temp_file();
        write_file(path.clone(), "Hello".to_string()).unwrap();
        append_file(path.clone(), " World".to_string()).unwrap();

        let result = read_file(path).unwrap();
        assert_eq!(result, FlValue::Str("Hello World".to_string()));

        cleanup();
    }

    #[test]
    fn test_file_size() {
        cleanup();

        let path = temp_file();
        write_file(path.clone(), "Hello".to_string()).unwrap();

        let result = file_size(path).unwrap();
        assert_eq!(result, FlValue::Int(5));

        cleanup();
    }

    #[test]
    fn test_delete_file() {
        cleanup();

        let path = temp_file();
        write_file(path.clone(), "test".to_string()).unwrap();
        assert_eq!(file_exists(path.clone()), FlValue::Bool(true));

        delete_file(path.clone()).unwrap();
        assert_eq!(file_exists(path), FlValue::Bool(false));
    }

    #[test]
    fn test_mkdir_and_list_dir() {
        let test_dir = "/tmp/freelang_test_dir";
        let _ = fs::remove_dir_all(test_dir);

        mkdir(test_dir.to_string()).unwrap();
        assert_eq!(file_exists(test_dir.to_string()), FlValue::Bool(true));

        let result = list_dir(test_dir.to_string()).unwrap();
        match result {
            FlValue::Array(_) => {},
            _ => panic!("Expected array"),
        }

        let _ = fs::remove_dir_all(test_dir);
    }

    #[test]
    fn test_file_copy() {
        cleanup();

        let src = temp_file();
        let dst = "/tmp/freelang_test_copy.txt".to_string();
        let _ = fs::remove_file(&dst);

        write_file(src.clone(), "test content".to_string()).unwrap();
        file_copy(src, dst.clone()).unwrap();

        let result = read_file(dst.clone()).unwrap();
        assert_eq!(result, FlValue::Str("test content".to_string()));

        let _ = fs::remove_file(&dst);
        cleanup();
    }

    #[test]
    fn test_file_move() {
        cleanup();

        let src = temp_file();
        let dst = "/tmp/freelang_test_move.txt".to_string();
        let _ = fs::remove_file(&dst);

        write_file(src.clone(), "test content".to_string()).unwrap();
        file_move(src.clone(), dst.clone()).unwrap();

        assert_eq!(file_exists(src), FlValue::Bool(false));
        assert_eq!(file_exists(dst.clone()), FlValue::Bool(true));

        let _ = fs::remove_file(&dst);
    }

    #[test]
    fn test_read_file_not_found() {
        let result = read_file("/tmp/nonexistent_freelang_test.txt".to_string());
        assert!(matches!(result, Err(IoError::NotFound(_))));
    }
}

