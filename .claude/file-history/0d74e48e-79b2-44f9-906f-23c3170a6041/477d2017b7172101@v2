/// 물리 메모리 페이지 표현
pub struct PhysicalPage {
    /// 페이지 번호 (0부터 시작)
    pub page_number: u64,

    /// 페이지 크기 (일반적으로 4KB = 4096)
    pub page_size: u64,

    /// 물리 주소
    pub phys_addr: u64,

    /// 할당 상태
    pub allocated: bool,
}

impl PhysicalPage {
    pub fn new(page_number: u64) -> Self {
        PhysicalPage {
            page_number,
            page_size: 4096,  // 4KB 페이지
            phys_addr: page_number * 4096,
            allocated: false,
        }
    }

    pub fn allocate(&mut self) {
        self.allocated = true;
    }

    pub fn deallocate(&mut self) {
        self.allocated = false;
    }

    pub fn is_free(&self) -> bool {
        !self.allocated
    }
}

// ============================================================================
// Part 2: 페이징 시스템 (Paging System)
// ============================================================================

/// 페이지 테이블 항목
pub struct PageTableEntry {
    /// 물리 페이지 주소
    pub physical_addr: u64,

    /// 존재 플래그
    pub present: bool,

    /// 쓰기 허용 플래그
    pub writable: bool,

    /// 사용자 모드 접근 플래그
    pub user_accessible: bool,

    /// 액세스 플래그
    pub accessed: bool,

    /// 더티 플래그
    pub dirty: bool,
}

impl PageTableEntry {
    pub fn new(physical_addr: u64) -> Self {
        PageTableEntry {
            physical_addr,
            present: false,
            writable: false,
            user_accessible: false,
            accessed: false,
            dirty: false,
        }
    }

    pub fn mark_present(&mut self) {
        self.present = true;
    }

    pub fn mark_writable(&mut self) {
        self.writable = true;
    }

    pub fn mark_accessed(&mut self) {
        self.accessed = true;
    }

    pub fn mark_dirty(&mut self) {
        self.dirty = true;
    }
}

/// 페이지 테이블 (1024개 항목)
pub struct PageTable {
    /// 페이지 테이블 항목들
    pub entries: Vec<PageTableEntry>,

    /// 이 테이블을 소유한 프로세스 ID
    pub process_id: u32,
}

impl PageTable {
    pub fn new(process_id: u32) -> Self {
        let mut entries = Vec::new();

        // 512개의 항목으로 시작
        for i in 0..512 {
            entries.push(PageTableEntry::new(i as u64 * 4096));
        }

        PageTable {
            entries,
            process_id,
        }
    }

    pub fn map_page(&mut self, virtual_addr: u64, physical_addr: u64) -> bool {
        let index = (virtual_addr / 4096) % 512;

        if index < self.entries.len() as u64 {
            let mut entry = &mut self.entries[index as usize];
            entry.physical_addr = physical_addr;
            entry.mark_present();
            return true;
        }

        false
    }

    pub fn unmap_page(&mut self, virtual_addr: u64) -> bool {
        let index = (virtual_addr / 4096) % 512;

        if index < self.entries.len() as u64 {
            let mut entry = &mut self.entries[index as usize];
            entry.present = false;
            return true;
        }

        false
    }

    pub fn translate_virtual_address(&self, virtual_addr: u64) -> Option<u64> {
        let index = (virtual_addr / 4096) % 512;

        if index < self.entries.len() as u64 {
            let entry = &self.entries[index as usize];

            if entry.present {
                let offset = virtual_addr % 4096;
                return Some(entry.physical_addr + offset);
            }
        }

        None
    }
}

// ============================================================================
// Part 3: 메모리 할당자 (Memory Allocator)
// ============================================================================

/// 메모리 할당 정보
pub struct MemoryBlock {
    /// 시작 주소
    pub start_addr: u64,

    /// 크기 (바이트)
    pub size: u64,

    /// 할당 상태
    pub allocated: bool,
}

impl MemoryBlock {
    pub fn new(start_addr: u64, size: u64) -> Self {
        MemoryBlock {
            start_addr,
            size,
            allocated: false,
        }
    }

    pub fn allocate(&mut self, requested_size: u64) -> Option<u64> {
        if !self.allocated && self.size >= requested_size {
            self.allocated = true;
            return Some(self.start_addr);
        }
        None
    }

    pub fn deallocate(&mut self) {
        self.allocated = false;
    }
}

/// 힙 할당자
pub struct HeapAllocator {
    /// 메모리 블록들
    pub blocks: Vec<MemoryBlock>,

    /// 총 할당 가능한 크기
    pub total_size: u64,

    /// 할당된 크기
    pub allocated_size: u64,
}

impl HeapAllocator {
    pub fn new(start_addr: u64, total_size: u64) -> Self {
        let mut blocks = Vec::new();
        blocks.push(MemoryBlock::new(start_addr, total_size));

        HeapAllocator {
            blocks,
            total_size,
            allocated_size: 0,
        }
    }

    pub fn allocate(&mut self, size: u64) -> Option<u64> {
        for block in &mut self.blocks {
            if let Some(addr) = block.allocate(size) {
                self.allocated_size += size;
                return Some(addr);
            }
        }
        None
    }

    pub fn deallocate(&mut self, addr: u64) -> bool {
        for block in &mut self.blocks {
            if block.start_addr == addr && block.allocated {
                self.allocated_size -= block.size;
                block.deallocate();
                return true;
            }
        }
        false
    }

    pub fn fragmentation_ratio(&self) -> f64 {
        if self.total_size == 0 {
            return 0.0;
        }

        let mut free_blocks = 0;
        for block in &self.blocks {
            if !block.allocated {
                free_blocks += 1;
            }
        }

        (free_blocks as f64) / (self.blocks.len() as f64)
    }
}

// ============================================================================
// Part 4: 부트로더 (Bootloader)
// ============================================================================

/// 부트 정보
pub struct BootInfo {
    /// 총 물리 메모리 (MB)
    pub total_memory_mb: u64,

    /// 커널 로드 주소
    pub kernel_load_addr: u64,

    /// 커널 크기 (바이트)
    pub kernel_size: u64,

    /// 사용 가능한 메모리 시작 주소
    pub available_memory_start: u64,

    /// 사용 가능한 메모리 끝 주소
    pub available_memory_end: u64,
}

impl BootInfo {
    pub fn new() -> Self {
        BootInfo {
            total_memory_mb: 512,  // 512 MB 메모리 가정
            kernel_load_addr: 0x100000,  // 1MB에서 시작
            kernel_size: 0x100000,  // 1MB 크기
            available_memory_start: 0x200000,  // 2MB부터 사용 가능
            available_memory_end: 0x20000000,  // 512MB까지
        }
    }

    pub fn total_available_memory(&self) -> u64 {
        self.available_memory_end - self.available_memory_start
    }
}

// ============================================================================
// Part 5: 초기화 함수들
// ============================================================================

/// 부트로더 초기화
pub fn init_bootloader() -> BootInfo {
    println!("🔧 Initializing FreeLang OS Bootloader...");

    let boot_info = BootInfo::new();
    println!("✅ Boot info created:");
    println!("   Total Memory: {} MB", boot_info.total_memory_mb);
    println!("   Kernel Load Addr: 0x{:x}", boot_info.kernel_load_addr);
    println!("   Available Memory: 0x{:x} - 0x{:x}",
             boot_info.available_memory_start,
             boot_info.available_memory_end);

    boot_info
}

/// 페이징 시스템 초기화
pub fn init_paging() -> PageTable {
    println!("\n📄 Initializing Paging System...");

    let mut page_table = PageTable::new(0);  // Kernel process ID = 0

    // 커널 메모리 영역 매핑 (0x100000 ~ 0x200000)
    for i in 0..256 {
        let virtual_addr = 0x100000 + (i * 4096);
        let physical_addr = 0x100000 + (i * 4096);
        page_table.map_page(virtual_addr, physical_addr);
    }

    println!("✅ Paging initialized with {} page table entries", page_table.entries.len());
    page_table
}

/// 힙 할당자 초기화
pub fn init_heap_allocator(boot_info: &BootInfo) -> HeapAllocator {
    println!("\n💾 Initializing Heap Allocator...");

    let heap_start = boot_info.available_memory_start;
    let heap_size = boot_info.total_available_memory();

    let allocator = HeapAllocator::new(heap_start, heap_size);
    println!("✅ Heap allocated: 0x{:x}, Size: {} MB",
             heap_start, heap_size / 1024 / 1024);

    allocator
}

// ============================================================================
// Part 6: 메인 부트로더 진입점
// ============================================================================

pub fn main() {
    println!("╔════════════════════════════════════════════════════════════╗");
    println!("║     FreeLang OS Kernel - Phase G Week 1 Bootloader        ║");
    println!("╚════════════════════════════════════════════════════════════╝\n");

    // Step 1: 부트 정보 초기화
    let boot_info = init_bootloader();

    // Step 2: 페이징 시스템 초기화
    let page_table = init_paging();

    // Step 3: 힙 할당자 초기화
    let mut heap_allocator = init_heap_allocator(&boot_info);

    // Step 4: 메모리 할당 테스트
    println!("\n🧪 Testing Memory Allocation...");

    if let Some(addr1) = heap_allocator.allocate(4096) {
        println!("✅ Allocated 4KB block at 0x{:x}", addr1);
    }

    if let Some(addr2) = heap_allocator.allocate(8192) {
        println!("✅ Allocated 8KB block at 0x{:x}", addr2);
    }

    println!("   Total allocated: {} bytes", heap_allocator.allocated_size);
    println!("   Fragmentation ratio: {:.2}%",
             heap_allocator.fragmentation_ratio() * 100.0);

    // Step 5: 가상 주소 변환 테스트
    println!("\n🔍 Testing Virtual Address Translation...");

    let test_vaddr = 0x100000;
    if let Some(paddr) = page_table.translate_virtual_address(test_vaddr) {
        println!("✅ Virtual 0x{:x} → Physical 0x{:x}", test_vaddr, paddr);
    } else {
        println!("❌ Translation failed for 0x{:x}", test_vaddr);
    }

    println!("\n✨ Bootloader initialization complete!");
    println!("Ready to load kernel...\n");
}

