#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_physical_page_creation() {
        let page = PhysicalPage::new(0);
        assert_eq!(page.page_number, 0);
        assert_eq!(page.phys_addr, 0);
        assert_eq!(page.is_free(), true);
    }

    #[test]
    fn test_page_allocation() {
        let mut page = PhysicalPage::new(1);
        page.allocate();
        assert_eq!(page.is_free(), false);
        page.deallocate();
        assert_eq!(page.is_free(), true);
    }

    #[test]
    fn test_page_table_mapping() {
        let mut pt = PageTable::new(0);
        pt.map_page(0x1000, 0x2000);

        if let Some(phys) = pt.translate_virtual_address(0x1000) {
            assert_eq!(phys, 0x2000);
        } else {
            panic!("Virtual address translation failed");
        }
    }

    #[test]
    fn test_page_table_unmapping() {
        let mut pt = PageTable::new(0);
        pt.map_page(0x1000, 0x2000);
        pt.unmap_page(0x1000);

        assert_eq!(pt.translate_virtual_address(0x1000), None);
    }

    #[test]
    fn test_heap_allocator() {
        let mut allocator = HeapAllocator::new(0x1000, 0x10000);

        if let Some(addr1) = allocator.allocate(4096) {
            assert_eq!(addr1, 0x1000);
            assert_eq!(allocator.allocated_size, 4096);
        } else {
            panic!("Allocation failed");
        }
    }

    #[test]
    fn test_heap_deallocator() {
        let mut allocator = HeapAllocator::new(0x1000, 0x10000);

        if let Some(addr) = allocator.allocate(4096) {
            assert!(allocator.deallocate(addr));
            assert_eq!(allocator.allocated_size, 0);
        }
    }

    #[test]
    fn test_boot_info() {
        let boot_info = BootInfo::new();
        assert_eq!(boot_info.total_memory_mb, 512);
        assert!(boot_info.total_available_memory() > 0);
    }
}
