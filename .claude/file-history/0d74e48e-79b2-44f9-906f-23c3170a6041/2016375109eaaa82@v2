#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_now_ms_positive() {
        let result = now_ms().unwrap();
        // 2000-01-01 이후이므로 946684800000 이상
        assert!(result > 946684800000i64);
    }

    #[test]
    fn test_now_ms_increasing() {
        let t1 = now_ms().unwrap();
        std::thread::sleep(std::time::Duration::from_millis(10));
        let t2 = now_ms().unwrap();
        assert!(t2 >= t1);
    }

    #[test]
    fn test_now_ns_positive() {
        let result = now_ns().unwrap();
        assert!(result > 0);
    }

    #[test]
    fn test_now_ns_increasing() {
        let t1 = now_ns().unwrap();
        std::thread::sleep(std::time::Duration::from_millis(1));
        let t2 = now_ns().unwrap();
        assert!(t2 >= t1);
    }

    #[test]
    fn test_format_time_iso() {
        // 2009-02-13 23:31:30 UTC = 1234567890 seconds
        let timestamp_ms = 1234567890i64 * 1000;
        let result = format_time(timestamp_ms, "ISO".to_string()).unwrap();
        assert!(result.contains("2009"));
        assert!(result.contains("UTC"));
    }

    #[test]
    fn test_format_time_unix() {
        let timestamp_ms = 1234567890i64 * 1000;
        let result = format_time(timestamp_ms, "UNIX".to_string()).unwrap();
        assert_eq!(result, "1234567890");
    }

    #[test]
    fn test_format_time_default() {
        let timestamp_ms = 1234567890i64 * 1000;
        let result = format_time(timestamp_ms, "".to_string()).unwrap();
        assert!(result.contains("UTC"));
    }

    #[test]
    fn test_format_time_invalid_format() {
        let result = format_time(1000, "INVALID".to_string());
        assert!(result.is_err());
    }

    #[test]
    fn test_parse_time_unix() {
        let result = parse_time("1234567890".to_string(), "UNIX".to_string()).unwrap();
        assert_eq!(result, 1234567890i64 * 1000);
    }

    #[test]
    fn test_parse_time_unix_with_whitespace() {
        let result = parse_time("  1234567890  ".to_string(), "UNIX".to_string()).unwrap();
        assert_eq!(result, 1234567890i64 * 1000);
    }

    #[test]
    fn test_parse_time_iso() {
        let result = parse_time("2009-02-13".to_string(), "ISO".to_string()).unwrap();
        assert!(result > 0);
    }

    #[test]
    fn test_parse_time_invalid() {
        let result = parse_time("not-a-number".to_string(), "UNIX".to_string());
        assert!(result.is_err());
    }

    #[test]
    fn test_duration_since_past() {
        let past = now_ms().unwrap() - 1000; // 1초 전
        let elapsed = duration_since(past).unwrap();
        assert!(elapsed >= 900 && elapsed <= 1100); // 약 1초
    }

    #[test]
    fn test_duration_since_zero() {
        let now = now_ms().unwrap();
        let elapsed = duration_since(now).unwrap();
        assert!(elapsed >= 0 && elapsed <= 100); // 거의 0
    }
}

