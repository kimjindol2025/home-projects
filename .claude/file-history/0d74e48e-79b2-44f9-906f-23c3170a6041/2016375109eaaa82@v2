use std::time::{SystemTime, UNIX_EPOCH, Duration};
use crate::stdlib::FlValue;

// ============================================================================
// TimeError - 시간 처리 에러 타입
// ============================================================================

/// 시간 처리 시 발생할 수 있는 에러
#[derive(Clone, Debug, PartialEq)]
pub enum TimeError {
    /// 타임스탬프 범위 초과
    TimestampError(String),

    /// 포맷 문자열 오류
    FormatError(String),

    /// 시간 파싱 실패
    ParseError(String),
}

impl std::fmt::Display for TimeError {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            TimeError::TimestampError(msg) => write!(f, "Timestamp error: {}", msg),
            TimeError::FormatError(msg) => write!(f, "Format error: {}", msg),
            TimeError::ParseError(msg) => write!(f, "Parse error: {}", msg),
        }
    }
}

// ============================================================================
// Time Retrieval Functions
// ============================================================================

/// 현재 시간을 밀리초 단위로 반환합니다 (Unix 타임스탬프 * 1000).
///
/// # 반환값
/// - Unix epoch(1970-01-01 00:00:00 UTC) 이후의 밀리초
///
/// # 예제
/// ```
/// let ms = now_ms().unwrap();
/// assert!(ms > 0);
/// ```
pub fn now_ms() -> Result<i64, TimeError> {
    match SystemTime::now().duration_since(UNIX_EPOCH) {
        Ok(duration) => Ok(duration.as_millis() as i64),
        Err(_) => Err(TimeError::TimestampError("SystemTime before UNIX_EPOCH".to_string())),
    }
}

/// 현재 시간을 나노초 단위로 반환합니다.
///
/// # 반환값
/// - Unix epoch 이후의 나노초
///
/// # 예제
/// ```
/// let ns = now_ns().unwrap();
/// assert!(ns > 0);
/// ```
pub fn now_ns() -> Result<i64, TimeError> {
    match SystemTime::now().duration_since(UNIX_EPOCH) {
        Ok(duration) => Ok(duration.as_nanos() as i64),
        Err(_) => Err(TimeError::TimestampError("SystemTime before UNIX_EPOCH".to_string())),
    }
}

// ============================================================================
// Time Formatting Functions
// ============================================================================

/// 타임스탬프를 포맷된 문자열로 변환합니다.
///
/// # 매개변수
/// - timestamp_ms: Unix 타임스탬프 (밀리초)
/// - format: 포맷 문자열 (간단한 버전)
///   - "ISO": ISO 8601 형식 (YYYY-MM-DD HH:MM:SS UTC)
///   - "UNIX": Unix 타임스탐프 문자열 반환
///   - 기본: ISO 형식
///
/// # 예제
/// ```
/// let ts = 1234567890000i64;  // 2009-02-13 23:31:30 UTC
/// let formatted = format_time(ts, "ISO").unwrap();
/// assert!(formatted.contains("2009"));
/// ```
pub fn format_time(timestamp_ms: i64, format: String) -> Result<String, TimeError> {
    // 밀리초를 초로 변환
    let secs = timestamp_ms / 1000;
    let nanos = ((timestamp_ms % 1000) * 1_000_000) as u32;

    // Duration으로 변환
    let duration = Duration::new(secs as u64, nanos);
    let system_time = UNIX_EPOCH + duration;

    match format.as_str() {
        "ISO" | "" => {
            // 간단한 ISO 포맷: YYYY-MM-DD HH:MM:SS UTC
            // 실제로는 chrono 크레이트를 사용하지만, 여기서는 기본 계산
            // 대략적인 변환 (정확하지 않을 수 있음)
            let total_secs = secs;

            // Days since epoch (1970-01-01)
            const SECS_PER_DAY: i64 = 86400;
            const DAYS_PER_YEAR: i64 = 365;
            const DAYS_IN_4YEARS: i64 = 1461; // 365*4 + 1 (leap year)

            let days_since_epoch = total_secs / SECS_PER_DAY;
            let secs_today = total_secs % SECS_PER_DAY;

            let hours = secs_today / 3600;
            let mins = (secs_today % 3600) / 60;
            let secs_final = secs_today % 60;

            // 매우 간단한 연도 계산 (정확하지 않음, 교육용)
            let years_since_epoch = days_since_epoch / DAYS_PER_YEAR;
            let year = 1970 + years_since_epoch;

            // 월/일 계산 (매우 단순화됨)
            let remaining_days = days_since_epoch % DAYS_PER_YEAR;
            let month = (remaining_days / 30).min(11) + 1;
            let day = (remaining_days % 30) + 1;

            Ok(format!(
                "{:04}-{:02}-{:02} {:02}:{:02}:{:02} UTC",
                year, month, day, hours, mins, secs_final
            ))
        }
        "UNIX" => {
            Ok(secs.to_string())
        }
        _ => {
            Err(TimeError::FormatError(format!(
                "Unknown format: {}. Use 'ISO' or 'UNIX'",
                format
            )))
        }
    }
}

/// 포맷된 문자열을 타임스탬프로 파싱합니다 (기본 구현).
///
/// # 매개변수
/// - time_str: 시간 문자열
/// - format: 포맷 지정자
///   - "UNIX": Unix 타임스탬프 문자열 (초 단위)
///   - "ISO": ISO 8601 형식 (제한적 지원)
///
/// # 반환값
/// - 밀리초 단위 타임스탐프
///
/// # 예제
/// ```
/// let ts = parse_time("1234567890", "UNIX").unwrap();
/// assert_eq!(ts, 1234567890000);  // 밀리초로 변환됨
/// ```
pub fn parse_time(time_str: String, format: String) -> Result<i64, TimeError> {
    match format.as_str() {
        "UNIX" => {
            time_str.trim()
                .parse::<i64>()
                .map(|secs| secs * 1000) // 밀리초로 변환
                .map_err(|_| TimeError::ParseError(format!(
                    "Cannot parse '{}' as Unix timestamp",
                    time_str
                )))
        }
        "ISO" => {
            // 매우 간단한 ISO 파싱 (YYYY-MM-DD 형식만)
            let parts: Vec<&str> = time_str.split('-').collect();
            if parts.len() < 3 {
                return Err(TimeError::ParseError(
                    "Invalid ISO format. Use YYYY-MM-DD".to_string()
                ));
            }

            let year = parts[0].parse::<i64>()
                .map_err(|_| TimeError::ParseError("Invalid year".to_string()))?;
            let month = parts[1].parse::<i64>()
                .map_err(|_| TimeError::ParseError("Invalid month".to_string()))?;
            let day = parts[2].split(' ').next().unwrap_or("1")
                .parse::<i64>()
                .map_err(|_| TimeError::ParseError("Invalid day".to_string()))?;

            // 매우 간단한 계산 (윤년 미고려, 교육용)
            let days_since_epoch = (year - 1970) * 365 + (month - 1) * 30 + (day - 1);
            let secs = days_since_epoch * 86400;

            Ok(secs * 1000) // 밀리초로 변환
        }
        _ => {
            Err(TimeError::FormatError(format!(
                "Unknown format: {}. Use 'UNIX' or 'ISO'",
                format
            )))
        }
    }
}

// ============================================================================
// Time Difference Functions
// ============================================================================

/// 주어진 타임스탐프 이후 경과한 시간을 반환합니다 (밀리초).
///
/// # 매개변수
/// - timestamp_ms: 비교 대상 타임스탐프 (밀리초)
///
/// # 반환값
/// - 현재 시간 - 주어진 시간 (밀리초)
/// - 음수인 경우 미래 시점
///
/// # 예제
/// ```
/// let past = now_ms().unwrap() - 5000;  // 5초 전
/// let elapsed = duration_since(past).unwrap();
/// assert!(elapsed >= 4900 && elapsed <= 5100);  // 약 5초
/// ```
pub fn duration_since(timestamp_ms: i64) -> Result<i64, TimeError> {
    match now_ms() {
        Ok(current) => Ok(current - timestamp_ms),
        Err(e) => Err(e),
    }
}

