#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_event_id_creation() {
        let eid = EventId::new(1, 5);
        assert_eq!(eid.thread_id(), 1);
        assert_eq!(eid.event_index(), 5);
    }

    #[test]
    fn test_access_type_read_write() {
        assert!(AccessType::Read.eq(&AccessType::Read));
        assert!(!AccessType::Read.eq(&AccessType::Write));
    }

    #[test]
    fn test_memory_event_creation() {
        let eid = EventId::new(1, 0);
        let event = MemoryEvent::new(eid, "x".to_string(), AccessType::Write, 0);

        assert_eq!(event.id(), eid);
        assert_eq!(event.variable(), "x");
        assert!(event.is_write());
        assert!(!event.is_read());
    }

    #[test]
    fn test_memory_event_atomic() {
        let eid = EventId::new(1, 0);
        let event = MemoryEvent::new(eid, "x".to_string(), AccessType::AtomicLoad(Ordering::SeqCst), 0);

        assert!(event.is_atomic());
        assert!(event.is_read());
    }

    #[test]
    fn test_memory_event_synchronization() {
        let eid = EventId::new(1, 0);
        let event = MemoryEvent::new(eid, "x".to_string(), AccessType::Acquire, 0);

        assert!(event.is_synchronization());
        assert!(event.is_write());  // Release이므로
    }

    #[test]
    fn test_happens_before_edge() {
        let e1 = EventId::new(1, 0);
        let e2 = EventId::new(1, 1);
        let edge = HappensBeforeEdge::new(e1, e2, SynchronizationReason::ProgramOrder);

        assert_eq!(edge.before(), e1);
        assert_eq!(edge.after(), e2);
        assert_eq!(edge.reason(), SynchronizationReason::ProgramOrder);
    }

    #[test]
    fn test_analyzer_new() {
        let analyzer = HappensBeforeAnalyzer::new();
        assert_eq!(analyzer.events().len(), 0);
        assert_eq!(analyzer.edges().len(), 0);
    }

    #[test]
    fn test_analyzer_add_event() {
        let mut analyzer = HappensBeforeAnalyzer::new();
        let eid = EventId::new(1, 0);
        let event = MemoryEvent::new(eid, "x".to_string(), AccessType::Write, 0);

        analyzer.add_event(event);
        assert_eq!(analyzer.events().len(), 1);
    }

    #[test]
    fn test_analyzer_direct_happens_before() {
        let mut analyzer = HappensBeforeAnalyzer::new();
        let e1 = EventId::new(1, 0);
        let e2 = EventId::new(1, 1);

        analyzer.add_edge(HappensBeforeEdge::new(e1, e2, SynchronizationReason::ProgramOrder));

        assert!(analyzer.happens_before(e1, e2));
        assert!(!analyzer.happens_before(e2, e1));
    }

    #[test]
    fn test_analyzer_transitive_happens_before() {
        let mut analyzer = HappensBeforeAnalyzer::new();
        let e1 = EventId::new(1, 0);
        let e2 = EventId::new(1, 1);
        let e3 = EventId::new(1, 2);

        analyzer.add_edge(HappensBeforeEdge::new(e1, e2, SynchronizationReason::ProgramOrder));
        analyzer.add_edge(HappensBeforeEdge::new(e2, e3, SynchronizationReason::ProgramOrder));

        // 이행성: e1 → e2 → e3 ⟹ e1 → e3
        assert!(analyzer.happens_before(e1, e2));
        assert!(analyzer.happens_before(e2, e3));
        assert!(analyzer.happens_before(e1, e3));
    }

    #[test]
    fn test_analyzer_program_order() {
        let mut analyzer = HappensBeforeAnalyzer::new();

        // Thread 1: e1, e2, e3
        for i in 0..3 {
            let eid = EventId::new(1, i);
            let event = MemoryEvent::new(eid, "x".to_string(), AccessType::Read, i as u64);
            analyzer.add_event(event);
        }

        analyzer.add_program_order(1);

        let e1 = EventId::new(1, 0);
        let e2 = EventId::new(1, 1);
        let e3 = EventId::new(1, 2);

        assert!(analyzer.happens_before(e1, e2));
        assert!(analyzer.happens_before(e2, e3));
        assert!(analyzer.happens_before(e1, e3));
    }

    #[test]
    fn test_analyzer_release_acquire() {
        let mut analyzer = HappensBeforeAnalyzer::new();

        let release = EventId::new(1, 0);
        let acquire = EventId::new(2, 0);

        analyzer.add_release_acquire_sync(release, acquire);

        assert!(analyzer.happens_before(release, acquire));
    }

    #[test]
    fn test_analyzer_accesses_to_variable() {
        let mut analyzer = HappensBeforeAnalyzer::new();

        let e1 = EventId::new(1, 0);
        let e2 = EventId::new(1, 1);
        let e3 = EventId::new(2, 0);

        analyzer.add_event(MemoryEvent::new(e1, "x".to_string(), AccessType::Write, 0));
        analyzer.add_event(MemoryEvent::new(e2, "y".to_string(), AccessType::Read, 1));
        analyzer.add_event(MemoryEvent::new(e3, "x".to_string(), AccessType::Read, 2));

        let x_accesses = analyzer.accesses_to_variable("x");
        assert_eq!(x_accesses.len(), 2);

        let y_accesses = analyzer.accesses_to_variable("y");
        assert_eq!(y_accesses.len(), 1);
    }

    #[test]
    fn test_analyzer_cache() {
        let mut analyzer = HappensBeforeAnalyzer::new();
        let e1 = EventId::new(1, 0);
        let e2 = EventId::new(1, 1);

        analyzer.add_edge(HappensBeforeEdge::new(e1, e2, SynchronizationReason::ProgramOrder));

        // 첫 번째 호출: 계산
        assert!(analyzer.happens_before(e1, e2));
        // 두 번째 호출: 캐시에서 (검증 어려움, 성능 개선만 확인)
        assert!(analyzer.happens_before(e1, e2));
    }

    #[test]
    fn test_analyzer_find_path() {
        let mut analyzer = HappensBeforeAnalyzer::new();
        let e1 = EventId::new(1, 0);
        let e2 = EventId::new(1, 1);
        let e3 = EventId::new(1, 2);

        analyzer.add_edge(HappensBeforeEdge::new(e1, e2, SynchronizationReason::ProgramOrder));
        analyzer.add_edge(HappensBeforeEdge::new(e2, e3, SynchronizationReason::ReleaseAcquire));

        let path = analyzer.find_path_between(e1, e3);
        assert!(path.is_some());

        let path = path.unwrap();
        assert_eq!(path.len(), 2);
        assert_eq!(path[0], SynchronizationReason::ProgramOrder);
        assert_eq!(path[1], SynchronizationReason::ReleaseAcquire);
    }

    #[test]
    fn test_analyzer_no_path() {
        let mut analyzer = HappensBeforeAnalyzer::new();
        let e1 = EventId::new(1, 0);
        let e2 = EventId::new(2, 0);

        let path = analyzer.find_path_between(e1, e2);
        assert!(path.is_none());
    }
}

