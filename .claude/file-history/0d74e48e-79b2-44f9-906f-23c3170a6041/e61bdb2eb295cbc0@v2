import {
  GrpcWebClient,
  GrpcStatus,
  GrpcResponse,
  isGrpcResponse,
} from '../src/grpc-web/client';

/**
 * Mock 타입 정의
 */
interface GetTodoRequest {
  id: number;
}

interface GetTodoResponse {
  id: number;
  title: string;
  completed: boolean;
}

/**
 * gRPC-web 클라이언트 테스트
 */
describe('GrpcWebClient', () => {
  let client: GrpcWebClient;

  beforeEach(() => {
    client = new GrpcWebClient({
      host: 'localhost',
      port: 8080,
      useSSL: false,
      timeout: 5000,
      retries: 2,
    });
  });

  describe('클라이언트 초기화', () => {
    test('클라이언트가 올바르게 생성되어야 함', () => {
      expect(client).toBeDefined();
      expect(client.getUri()).toBe('http://localhost:8080');
    });

    test('타임아웃 설정', () => {
      client.setTimeout(10000);
      // Timeout이 설정되었는지 확인 (내부 상태)
      expect(client).toBeDefined();
    });
  });

  describe('통계', () => {
    test('초기 통계는 0이어야 함', () => {
      const stats = client.getStats();
      expect(stats.calls).toBe(0);
      expect(stats.errors).toBe(0);
      expect(stats.successRate).toBe('N/A');
    });
  });

  describe('Unary RPC', () => {
    test('성공적인 Unary 호출', async () => {
      // Mock fetch 설정
      global.fetch = jest.fn(() =>
        Promise.resolve({
          ok: true,
          json: () =>
            Promise.resolve<GetTodoResponse>({
              id: 1,
              title: 'Test Todo',
              completed: false,
            }),
        } as Response)
      );

      const request: GetTodoRequest = { id: 1 };
      const response = await client.callUnary<
        GetTodoRequest,
        GetTodoResponse
      >('TodoService', 'GetTodo', request);

      expect(response.success).toBe(true);
      expect(response.status).toBe(GrpcStatus.OK);
      expect(response.data?.title).toBe('Test Todo');
    });

    test('Unary 호출 실패 처리', async () => {
      global.fetch = jest.fn(() =>
        Promise.reject(new Error('Network error'))
      );

      const request: GetTodoRequest = { id: 999 };
      const response = await client.callUnary<
        GetTodoRequest,
        GetTodoResponse
      >('TodoService', 'GetTodo', request);

      expect(response.success).toBe(false);
      expect(response.status).toBe(GrpcStatus.UNKNOWN);
      expect(response.error).toContain('Network error');
    });
  });

  describe('타입 검증', () => {
    test('GrpcResponse 타입 가드', () => {
      const validResponse: GrpcResponse<GetTodoResponse> = {
        success: true,
        status: GrpcStatus.OK,
        data: { id: 1, title: 'Test', completed: false },
      };

      expect(isGrpcResponse(validResponse)).toBe(true);

      const invalidResponse = { foo: 'bar' };
      expect(isGrpcResponse(invalidResponse)).toBe(false);
    });
  });

  describe('메타데이터', () => {
    test('요청에 메타데이터 포함', async () => {
      global.fetch = jest.fn(() =>
        Promise.resolve({
          ok: true,
          json: () =>
            Promise.resolve<GetTodoResponse>({
              id: 1,
              title: 'Test',
              completed: false,
            }),
        } as Response)
      );

      const metadata = {
        Authorization: 'Bearer token123',
        'X-Request-ID': 'req-456',
      };

      const request: GetTodoRequest = { id: 1 };
      const response = await client.callUnary(
        'TodoService',
        'GetTodo',
        request,
        { metadata }
      );

      expect(response.success).toBe(true);
      expect(global.fetch).toHaveBeenCalledWith(
        expect.any(String),
        expect.objectContaining({
          headers: expect.objectContaining({
            Authorization: 'Bearer token123',
          }),
        })
      );
    });
  });

  describe('재시도 로직', () => {
    test('첫 실패 후 재시도 성공', async () => {
      let callCount = 0;

      global.fetch = jest.fn(() => {
        callCount++;
        if (callCount < 2) {
          return Promise.reject(new Error('Temporary error'));
        }
        return Promise.resolve({
          ok: true,
          json: () =>
            Promise.resolve<GetTodoResponse>({
              id: 1,
              title: 'Test',
              completed: false,
            }),
        } as Response);
      });

      const request: GetTodoRequest = { id: 1 };
      const response = await client.callUnary(
        'TodoService',
        'GetTodo',
        request
      );

      expect(response.success).toBe(true);
      expect(callCount).toBe(2);  // 재시도 포함
    });
  });
});

