/**
 * 성능 테스트
 */
describe('성능', () => {
  test('1000개 호출 처리', async () => {
    const client = new GrpcWebClient({
      host: 'localhost',
      port: 8080,
      useSSL: false,
    });

    global.fetch = jest.fn(() =>
      Promise.resolve({
        ok: true,
        json: () =>
          Promise.resolve({
            id: 1,
            title: 'Test',
            completed: false,
          }),
      } as Response)
    );

    const startTime = Date.now();

    for (let i = 0; i < 100; i++) {
      const request: GetTodoRequest = { id: i };
      await client.callUnary(
        'TodoService',
        'GetTodo',
        request
      );
    }

    const endTime = Date.now();
    const duration = endTime - startTime;

    console.log(`100 calls completed in ${duration}ms`);
    expect(duration).toBeLessThan(10000);  // 10초 이내
  });
});

/**
 * 통합 예제 코드 (문서용)
 */
describe('통합 예제', () => {
  test('Todo 생성 및 조회 흐름', async () => {
    const client = new GrpcWebClient({
      host: 'api.example.com',
      port: 443,
      useSSL: true,
      timeout: 30000,
    });

    // CreateTodo 호출
    const createResponse = await client.callUnary(
      'TodoService',
      'CreateTodo',
      { title: 'Learn gRPC-web', description: 'Study the basics' }
    );

    expect(createResponse.success).toBe(true);

    // GetTodo 호출
    const todoId = (createResponse.data as any)?.id || 1;
    const getResponse = await client.callUnary<
      GetTodoRequest,
      GetTodoResponse
    >('TodoService', 'GetTodo', { id: todoId });

    expect(getResponse.success).toBe(true);
    expect(getResponse.data?.title).toBe('Learn gRPC-web');
  });

  test('Server Streaming 예제', async () => {
    const client = new GrpcWebClient({
      host: 'localhost',
      port: 8080,
      useSSL: false,
    });

    const receivedMessages: GetTodoResponse[] = [];

    const onMessage = (message: GetTodoResponse) => {
      receivedMessages.push(message);
      console.log(`Received: ${message.title}`);
    };

    // ListTodos 스트리밍
    const response = await client.callServerStreaming(
      'TodoService',
      'ListTodos',
      {},
      onMessage
    );

    expect(response.status).toBe(GrpcStatus.OK);
  });

  test('에러 처리 예제', async () => {
    const client = new GrpcWebClient({
      host: 'localhost',
      port: 8080,
      useSSL: false,
      retries: 3,
    });

    const response = await client.callUnary<
      GetTodoRequest,
      GetTodoResponse
    >('TodoService', 'GetTodo', { id: 999 });

    if (!response.success) {
      console.error(`Error: ${response.error}`);
      console.error(`Status: ${response.status}`);
      // 사용자 정의 에러 처리
    }

    expect(response.success).toBe(false);
  });
});
