/// 패키지 이름이 유효한지 확인
pub fn is_valid_package_name(name: &str) -> bool {
    // lowercase, hyphen, digits만 허용
    name.chars().all(|c| c.is_lowercase() || c == '-' || c.is_numeric())
        && !name.is_empty()
        && !name.starts_with('-')
}

/// GOGS 저장소 URL 생성
pub fn build_repo_url(registry_url: &str, author: &str, package: &str) -> String {
    format!("{}/{}/{}", registry_url, author, package)
}

// ============================================================================
// Test Suite
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_search_package() {
        let result = search_package(DEFAULT_REGISTRY_URL, "json").unwrap();
        assert!(result.packages.len() > 0);
        assert!(result.packages[0].name.contains("json"));
    }

    #[test]
    fn test_fetch_metadata() {
        let metadata = fetch_metadata(DEFAULT_REGISTRY_URL, "freelang-json").unwrap();
        assert_eq!(metadata.name, "freelang-json");
        assert_eq!(metadata.version, "1.2.3");
    }

    #[test]
    fn test_fetch_metadata_not_found() {
        let result = fetch_metadata(DEFAULT_REGISTRY_URL, "nonexistent-package");
        assert!(result.is_err());
    }

    #[test]
    fn test_list_versions() {
        let versions = list_versions(DEFAULT_REGISTRY_URL, "freelang-json").unwrap();
        assert!(versions.len() > 0);
        assert_eq!(versions[0].version, "1.2.3");
    }

    #[test]
    fn test_download_package() {
        let result = download_package(
            DEFAULT_REGISTRY_URL,
            "freelang-json",
            "1.2.3",
            "./packages",
        );
        assert!(result.is_ok());
    }

    #[test]
    fn test_publish_package() {
        let manifest = "[package]\nname = \"test\"\n";
        let result = publish_package(DEFAULT_REGISTRY_URL, "test-pkg", manifest);
        assert!(result.is_ok());
    }

    #[test]
    fn test_valid_package_name() {
        assert!(is_valid_package_name("my-package"));
        assert!(is_valid_package_name("freelang-json"));
        assert!(is_valid_package_name("pkg123"));
        assert!(!is_valid_package_name("MyPackage")); // 대문자
        assert!(!is_valid_package_name("-invalid")); // 시작 하이픈
    }

    #[test]
    fn test_build_repo_url() {
        let url = build_repo_url(DEFAULT_REGISTRY_URL, "kim", "freelang-json");
        assert!(url.contains("kim"));
        assert!(url.contains("freelang-json"));
    }
}

