/// GOGS 저장소 정보
#[derive(Clone, Debug)]
pub struct GogsRepository {
    pub id: u64,
    pub name: String,
    pub full_name: String,
    pub description: String,
    pub html_url: String,
    pub clone_url: String,
}

/// 패키지 버전 정보
