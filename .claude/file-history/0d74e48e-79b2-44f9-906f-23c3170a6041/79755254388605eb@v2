/// GOGS 레지스트리에서 패키지 검색
pub fn search_package(
    registry_url: &str,
    query: &str,
) -> Result<SearchResult, FpmError> {
    // 실제 구현: GOGS API 쿼리
    // GET /api/v1/repos/search?q=<query>

    // Mock 구현: 검색 결과 시뮬레이션
    let mut packages = vec![];

    // 쿼리가 패키지 이름을 포함하면 결과 반환
    if query.contains("json") {
        packages.push(PackageMetadata {
            name: "freelang-json".to_string(),
            version: "1.2.3".to_string(),
            author: "kim".to_string(),
            description: "JSON parser for FreeLang".to_string(),
            repository: Some(format!("{}/kim/freelang-json", registry_url)),
            license: Some("MIT".to_string()),
        });
    }

    if query.contains("http") || query.is_empty() {
        packages.push(PackageMetadata {
            name: "freelang-http".to_string(),
            version: "2.1.0".to_string(),
            author: "kim".to_string(),
            description: "HTTP client/server for FreeLang".to_string(),
            repository: Some(format!("{}/kim/freelang-http", registry_url)),
            license: Some("MIT".to_string()),
        });
    }

    Ok(SearchResult {
        packages,
        total: packages.len() as u64,
        page: 1,
    })
}

/// GOGS에서 패키지 메타데이터 조회
pub fn fetch_metadata(
    registry_url: &str,
    package_name: &str,
) -> Result<PackageMetadata, FpmError> {
    // 실제 구현: GOGS API 쿼리
    // GET /api/v1/repos/{owner}/{repo}

    // Mock 구현: 알려진 패키지 목록
    let known_packages: HashMap<&str, PackageMetadata> = vec![
        (
            "freelang-json",
            PackageMetadata {
                name: "freelang-json".to_string(),
                version: "1.2.3".to_string(),
                author: "kim".to_string(),
                description: "JSON parser and serializer".to_string(),
                repository: Some(format!("{}/kim/freelang-json", registry_url)),
                license: Some("MIT".to_string()),
            },
        ),
        (
            "freelang-http",
            PackageMetadata {
                name: "freelang-http".to_string(),
                version: "2.1.0".to_string(),
                author: "kim".to_string(),
                description: "HTTP networking library".to_string(),
                repository: Some(format!("{}/kim/freelang-http", registry_url)),
                license: Some("MIT".to_string()),
            },
        ),
        (
            "freelang-crypto",
            PackageMetadata {
                name: "freelang-crypto".to_string(),
                version: "1.0.5".to_string(),
                author: "kim".to_string(),
                description: "Cryptography utilities".to_string(),
                repository: Some(format!("{}/kim/freelang-crypto", registry_url)),
                license: Some("Apache-2.0".to_string()),
            },
        ),
    ]
    .into_iter()
    .collect();

    known_packages
        .get(package_name)
        .cloned()
        .ok_or_else(|| FpmError::PackageNotFound(
            format!("Package '{}' not found in registry", package_name),
        ))
}

/// GOGS에서 패키지 다운로드
pub fn download_package(
    registry_url: &str,
    package_name: &str,
    version: &str,
    dest_dir: &str,
) -> Result<(), FpmError> {
    // 실제 구현: git clone 또는 ZIP 다운로드
    // git clone {registry_url}/{owner}/{package_name}.git

    // Mock 구현: 다운로드 시뮬레이션
    let clone_url = format!(
        "{}/{}.git",
        registry_url, package_name
    );

    // 태그 체크아웃 (버전)
    // git checkout tags/{version}

    println!(
        "Would clone from: {} (version: {})",
        clone_url, version
    );

    // 실제로는 파일이 생성되어야 함
    // 여기서는 성공으로 반환
    Ok(())
}

/// GOGS에 패키지 발행 (배포)
pub fn publish_package(
    registry_url: &str,
    package_name: &str,
    manifest_content: &str,
) -> Result<(), FpmError> {
    // 실제 구현:
    // 1. freelang.toml 포함 git 저장소 생성
    // 2. GOGS에 push
    // 3. 버전 태그 생성 (git tag v1.0.0)
    // 4. GOGS API로 릴리스 생성

    // Mock 구현: 발행 시뮬레이션
    let repo_url = format!(
        "{}/{}/{}",
        registry_url,
        "kim", // 저자 (실제로는 config에서 가져와야 함)
        package_name
    );

    println!(
        "Publishing package '{}' to {}",
        package_name, repo_url
    );

    // freelang.toml 내용 로깅
    println!("Manifest content:");
    println!("{}", manifest_content);

    Ok(())
}

/// 레지스트리에서 패키지 버전 목록 조회
pub fn list_versions(
    registry_url: &str,
    package_name: &str,
) -> Result<Vec<PackageVersion>, FpmError> {
    // 실제 구현: GOGS API /repos/{owner}/{repo}/tags
    // 또는 /repos/{owner}/{repo}/releases

    // Mock 구현: 버전 목록 반환
    let versions = match package_name {
        "freelang-json" => vec![
            PackageVersion {
                version: "1.2.3".to_string(),
                published_at: "2026-04-01".to_string(),
                size: 125000,
            },
            PackageVersion {
                version: "1.2.2".to_string(),
                published_at: "2026-03-15".to_string(),
                size: 120000,
            },
            PackageVersion {
                version: "1.2.1".to_string(),
                published_at: "2026-03-01".to_string(),
                size: 115000,
            },
        ],
        "freelang-http" => vec![
            PackageVersion {
                version: "2.1.0".to_string(),
                published_at: "2026-03-20".to_string(),
                size: 250000,
            },
            PackageVersion {
                version: "2.0.0".to_string(),
                published_at: "2026-02-20".to_string(),
                size: 240000,
            },
        ],
        _ => vec![],
    };

    if versions.is_empty() {
        return Err(FpmError::PackageNotFound(
            format!("No versions found for '{}'", package_name),
        ));
    }

    Ok(versions)
}

