#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_abs_int() {
        assert_eq!(abs(FlValue::Int(-42)).unwrap(), FlValue::Int(42));
        assert_eq!(abs(FlValue::Int(42)).unwrap(), FlValue::Int(42));
        assert_eq!(abs(FlValue::Int(0)).unwrap(), FlValue::Int(0));
    }

    #[test]
    fn test_abs_float() {
        assert_eq!(abs(FlValue::Float(-3.14)).unwrap(), FlValue::Float(3.14));
    }

    #[test]
    fn test_sqrt_positive() {
        assert_eq!(sqrt(FlValue::Int(4)).unwrap(), FlValue::Float(2.0));
        assert_eq!(sqrt(FlValue::Int(9)).unwrap(), FlValue::Float(3.0));
    }

    #[test]
    fn test_sqrt_negative_error() {
        assert!(matches!(sqrt(FlValue::Int(-1)), Err(MathError::NegativeSqrt)));
        assert!(matches!(sqrt(FlValue::Float(-1.0)), Err(MathError::NegativeSqrt)));
    }

    #[test]
    fn test_pow() {
        assert_eq!(pow(FlValue::Int(2), FlValue::Int(3)).unwrap(), FlValue::Float(8.0));
        assert_eq!(pow(FlValue::Int(2), FlValue::Int(0)).unwrap(), FlValue::Float(1.0));
    }

    #[test]
    fn test_floor() {
        assert_eq!(floor(FlValue::Float(3.7)).unwrap(), FlValue::Int(3));
        assert_eq!(floor(FlValue::Float(-2.3)).unwrap(), FlValue::Int(-3));
