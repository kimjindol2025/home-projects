// ============================================================================
// Min/Max/Clamp Functions
// ============================================================================

/// 두 값 중 작은 값을 반환합니다.
///
/// # 예제
/// ```
/// assert_eq!(min(FlValue::Int(3), FlValue::Int(5)), FlValue::Int(3));
/// ```
pub fn min(a: FlValue, b: FlValue) -> Result<FlValue, MathError> {
    match (a.clone(), b.clone()) {
        (FlValue::Int(n1), FlValue::Int(n2)) => Ok(FlValue::Int(n1.min(n2))),
        (FlValue::Float(f1), FlValue::Float(f2)) => Ok(FlValue::Float(f1.min(f2))),
        (FlValue::Int(n), FlValue::Float(f)) => {
            let f1 = n as f64;
            Ok(FlValue::Float(f1.min(f)))
        }
        (FlValue::Float(f), FlValue::Int(n)) => {
            let f2 = n as f64;
            Ok(FlValue::Float(f.min(f2)))
        }
        _ => Err(MathError::DomainError("min requires numeric values".to_string())),
    }
}

/// 두 값 중 큰 값을 반환합니다.
///
/// # 예제
/// ```
/// assert_eq!(max(FlValue::Int(3), FlValue::Int(5)), FlValue::Int(5));
/// ```
pub fn max(a: FlValue, b: FlValue) -> Result<FlValue, MathError> {
    match (a.clone(), b.clone()) {
        (FlValue::Int(n1), FlValue::Int(n2)) => Ok(FlValue::Int(n1.max(n2))),
        (FlValue::Float(f1), FlValue::Float(f2)) => Ok(FlValue::Float(f1.max(f2))),
        (FlValue::Int(n), FlValue::Float(f)) => {
            let f1 = n as f64;
            Ok(FlValue::Float(f1.max(f)))
        }
        (FlValue::Float(f), FlValue::Int(n)) => {
            let f2 = n as f64;
            Ok(FlValue::Float(f.max(f2)))
        }
        _ => Err(MathError::DomainError("max requires numeric values".to_string())),
    }
}

/// 값을 범위 내로 제한합니다 (min <= n <= max).
///
/// # 예제
/// ```
/// assert_eq!(clamp(FlValue::Int(5), FlValue::Int(1), FlValue::Int(10)), FlValue::Int(5));
/// assert_eq!(clamp(FlValue::Int(15), FlValue::Int(1), FlValue::Int(10)), FlValue::Int(10));
/// assert_eq!(clamp(FlValue::Int(-5), FlValue::Int(1), FlValue::Int(10)), FlValue::Int(1));
/// ```
pub fn clamp(value: FlValue, min: FlValue, max: FlValue) -> Result<FlValue, MathError> {
    match (value, min, max) {
        (FlValue::Int(n), FlValue::Int(min_n), FlValue::Int(max_n)) => {
            Ok(FlValue::Int(n.max(min_n).min(max_n)))
        }
        (FlValue::Float(f), FlValue::Float(min_f), FlValue::Float(max_f)) => {
            Ok(FlValue::Float(f.max(min_f).min(max_f)))
        }
        _ => Err(MathError::DomainError("clamp requires numeric values".to_string())),
    }
}

