    }

    #[test]
    fn test_cos() {
        assert_eq!(cos(FlValue::Float(0.0)).unwrap(), FlValue::Float(1.0));
    }

    #[test]
    fn test_tan() {
        assert_eq!(tan(FlValue::Float(0.0)).unwrap(), FlValue::Float(0.0));
    }

    #[test]
    fn test_asin_valid() {
