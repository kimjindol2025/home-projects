// ============================================================================
// MathError - 수학 연산 에러 타입
// ============================================================================

/// 수학 연산 시 발생할 수 있는 에러
#[derive(Clone, Debug, PartialEq)]
pub enum MathError {
    /// 0으로 나누기
    DivideByZero,

    /// 음수에 대한 제곱근
    NegativeSqrt,

    /// 범위 밖의 값 (예: log(0), asin(2))
    DomainError(String),
}

impl std::fmt::Display for MathError {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            MathError::DivideByZero => write!(f, "Division by zero"),
            MathError::NegativeSqrt => write!(f, "Square root of negative number"),
            MathError::DomainError(msg) => write!(f, "Domain error: {}", msg),
        }
    }
}

// ============================================================================
// Basic Math Functions
