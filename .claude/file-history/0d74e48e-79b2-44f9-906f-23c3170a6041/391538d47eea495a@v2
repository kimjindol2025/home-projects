/// 역사인(asin)을 반환합니다 (라디안 반환).
///
/// # 에러
/// - 범위 밖: MathError::DomainError
///
/// # 예제
/// ```
/// assert_eq!(asin(FlValue::Float(0.0)), Ok(FlValue::Float(0.0)));
/// assert_eq!(asin(FlValue::Float(2.0)), Err(MathError::DomainError(_)));
/// ```
pub fn asin(value: FlValue) -> Result<FlValue, MathError> {
    match value {
        FlValue::Int(n) => {
            let f = n as f64;
            if f < -1.0 || f > 1.0 {
                Err(MathError::DomainError("asin domain: [-1, 1]".to_string()))
            } else {
                Ok(FlValue::Float(f.asin()))
            }
        }
        FlValue::Float(f) => {
            if f < -1.0 || f > 1.0 {
                Err(MathError::DomainError("asin domain: [-1, 1]".to_string()))
            } else {
                Ok(FlValue::Float(f.asin()))
            }
        }
        _ => Err(MathError::DomainError("asin requires numeric value".to_string())),
    }
}

