/// 자연로그(ln)를 반환합니다.
///
/// # 에러
/// - 0 이하: MathError::DomainError
///
/// # 예제
/// ```
/// assert_eq!(ln(FlValue::Float(1.0)), Ok(FlValue::Float(0.0)));
/// ```
pub fn ln(value: FlValue) -> Result<FlValue, MathError> {
    match value {
        FlValue::Int(n) => {
            if n <= 0 {
                Err(MathError::DomainError("ln domain: (0, ∞)".to_string()))
            } else {
                Ok(FlValue::Float((n as f64).ln()))
            }
        }
        FlValue::Float(f) => {
            if f <= 0.0 {
                Err(MathError::DomainError("ln domain: (0, ∞)".to_string()))
            } else {
                Ok(FlValue::Float(f.ln()))
            }
        }
        _ => Err(MathError::DomainError("ln requires numeric value".to_string())),
    }
}

