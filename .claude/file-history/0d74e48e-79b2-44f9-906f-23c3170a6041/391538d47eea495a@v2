/// 절댓값을 반환합니다.
///
/// # 예제
/// ```
/// assert_eq!(abs(FlValue::Int(-42)), FlValue::Int(42));
/// assert_eq!(abs(FlValue::Float(-3.14)), FlValue::Float(3.14));
/// ```
pub fn abs(value: FlValue) -> Result<FlValue, MathError> {
    match value {
        FlValue::Int(n) => Ok(FlValue::Int(n.abs())),
        FlValue::Float(f) => Ok(FlValue::Float(f.abs())),
        _ => Err(MathError::DomainError("abs requires numeric value".to_string())),
    }
}

/// 제곱근을 반환합니다.
///
/// # 에러
/// - 음수: MathError::NegativeSqrt
///
/// # 예제
/// ```
/// assert_eq!(sqrt(FlValue::Int(4)), Ok(FlValue::Float(2.0)));
/// assert_eq!(sqrt(FlValue::Float(2.0)), Ok(FlValue::Float(1.414...)));
/// ```
pub fn sqrt(value: FlValue) -> Result<FlValue, MathError> {
    match value {
        FlValue::Int(n) => {
            if n < 0 {
                Err(MathError::NegativeSqrt)
            } else {
                Ok(FlValue::Float((n as f64).sqrt()))
            }
        }
        FlValue::Float(f) => {
            if f < 0.0 {
                Err(MathError::NegativeSqrt)
            } else {
                Ok(FlValue::Float(f.sqrt()))
            }
        }
        _ => Err(MathError::DomainError("sqrt requires numeric value".to_string())),
    }
}

/// 거듭제곱을 반환합니다 (base^exponent).
///
/// # 예제
/// ```
/// assert_eq!(pow(FlValue::Int(2), FlValue::Int(3)), Ok(FlValue::Float(8.0)));
/// assert_eq!(pow(FlValue::Float(2.5), FlValue::Float(2.0)), Ok(FlValue::Float(6.25)));
/// ```
pub fn pow(base: FlValue, exponent: FlValue) -> Result<FlValue, MathError> {
    let base_f = match base {
        FlValue::Int(n) => n as f64,
        FlValue::Float(f) => f,
        _ => return Err(MathError::DomainError("pow base must be numeric".to_string())),
    };

    let exp_f = match exponent {
        FlValue::Int(n) => n as f64,
        FlValue::Float(f) => f,
        _ => return Err(MathError::DomainError("pow exponent must be numeric".to_string())),
    };

    Ok(FlValue::Float(base_f.powf(exp_f)))
}

/// 내림(floor)을 반환합니다.
///
/// # 예제
/// ```
/// assert_eq!(floor(FlValue::Float(3.7)), FlValue::Int(3));
/// assert_eq!(floor(FlValue::Float(-2.3)), FlValue::Int(-3));
/// ```
pub fn floor(value: FlValue) -> Result<FlValue, MathError> {
    match value {
        FlValue::Int(n) => Ok(FlValue::Int(n)),
        FlValue::Float(f) => Ok(FlValue::Int(f.floor() as i64)),
        _ => Err(MathError::DomainError("floor requires numeric value".to_string())),
    }
}

