/// 두 인자의 역탄젠트(atan2)를 반환합니다 (y, x 순서, 라디안 반환).
///
/// # 예제
/// ```
/// assert_eq!(atan2(FlValue::Int(0), FlValue::Int(1)), Ok(FlValue::Float(0.0)));
/// ```
pub fn atan2(y: FlValue, x: FlValue) -> Result<FlValue, MathError> {
    let y_f = match y {
        FlValue::Int(n) => n as f64,
        FlValue::Float(f) => f,
        _ => return Err(MathError::DomainError("atan2 y must be numeric".to_string())),
    };

    let x_f = match x {
        FlValue::Int(n) => n as f64,
        FlValue::Float(f) => f,
        _ => return Err(MathError::DomainError("atan2 x must be numeric".to_string())),
    };

    Ok(FlValue::Float(y_f.atan2(x_f)))
}

