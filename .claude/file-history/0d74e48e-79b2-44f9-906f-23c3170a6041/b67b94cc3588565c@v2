#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_parse_compatible_range() {
        let constraint = parse_version_range("^1.2.3").unwrap();
        match constraint {
            VersionConstraint::Compatible(_) => {}
            _ => panic!("Expected Compatible"),
        }
    }

    #[test]
    fn test_parse_patch_range() {
        let constraint = parse_version_range("~2.1.0").unwrap();
        match constraint {
            VersionConstraint::Patch(_) => {}
            _ => panic!("Expected Patch"),
        }
    }

    #[test]
    fn test_satisfies_compatible() {
        let base = Version { major: 1, minor: 0, patch: 0 };
        let constraint = VersionConstraint::Compatible(base);

        let v1 = Version { major: 1, minor: 2, patch: 3 };
        let v2 = Version { major: 2, minor: 0, patch: 0 };

        assert!(satisfies_constraint(&v1, &constraint));
        assert!(!satisfies_constraint(&v2, &constraint));
    }

    #[test]
    fn test_satisfies_patch() {
        let base = Version { major: 1, minor: 2, patch: 0 };
        let constraint = VersionConstraint::Patch(base);

        let v1 = Version { major: 1, minor: 2, patch: 3 };
        let v2 = Version { major: 1, minor: 3, patch: 0 };

        assert!(satisfies_constraint(&v1, &constraint));
        assert!(!satisfies_constraint(&v2, &constraint));
    }

    #[test]
    fn test_semver_compare() {
        let ord = semver_compare("1.2.3", "1.2.4").unwrap();
        assert_eq!(ord, std::cmp::Ordering::Less);

        let ord = semver_compare("2.0.0", "1.9.9").unwrap();
        assert_eq!(ord, std::cmp::Ordering::Greater);
    }

    #[test]
    fn test_detect_conflicts() {
        let c1 = VersionConstraint::Compatible(Version { major: 1, minor: 0, patch: 0 });
        let c2 = VersionConstraint::Compatible(Version { major: 2, minor: 0, patch: 0 });

        // 1.x와 2.x는 충돌
        assert!(detect_conflicts(&c1, &c2));
    }

    #[test]
    fn test_topological_sort() {
        let mut graph = HashMap::new();
        graph.insert("a".to_string(), vec!["b".to_string(), "c".to_string()]);
        graph.insert("b".to_string(), vec!["d".to_string()]);
        graph.insert("c".to_string(), vec![]);
        graph.insert("d".to_string(), vec![]);

        let sorted = topological_sort(&graph).unwrap();
        assert_eq!(sorted.len(), 4);
    }

    #[test]
    fn test_circular_dependency() {
        let mut graph = HashMap::new();
        graph.insert("a".to_string(), vec!["b".to_string()]);
        graph.insert("b".to_string(), vec!["a".to_string()]);

        let result = topological_sort(&graph);
        assert!(result.is_err());
    }

    #[test]
    fn test_resolve_simple() {
        let manifest = Manifest {
            package: crate::fpm::PackageMetadata {
                name: "test".to_string(),
                version: "1.0.0".to_string(),
                author: "test".to_string(),
                description: "test".to_string(),
                repository: None,
                license: None,
            },
            dependencies: vec![],
            dev_dependencies: vec![],
            build_dependencies: vec![],
        };

        let result = resolve_deps(&manifest).unwrap();
        assert!(result.success);
        assert!(result.conflicts.is_empty());
    }
}

