/// 버전 범위 제약
#[derive(Clone, Debug)]
pub enum VersionConstraint {
    /// ^X.Y.Z - 호환 버전 (>=X.Y.Z, <(X+1).0.0)
    Compatible(Version),

    /// ~X.Y.Z - 패치 버전 (>=X.Y.Z, <X.(Y+1).0)
    Patch(Version),

    /// =X.Y.Z - 정확한 버전
    Exact(Version),

    /// X.Y.Z - 기본값 (정확한 버전)
    Default(Version),
}

/// 의존성 그래프 노드
#[derive(Clone, Debug)]
pub struct DepNode {
    pub name: String,
    pub version: String,
    pub dependencies: Vec<String>,
}

// ============================================================================
// Core Resolver Functions
// ============================================================================

/// 버전 범위 파싱 (^, ~, =, plain)
pub fn parse_version_range(range_str: &str) -> Result<VersionConstraint, FpmError> {
    let trimmed = range_str.trim();

    if trimmed.starts_with('^') {
        let version_str = &trimmed[1..];
        let version = Version::parse(version_str)
            .ok_or_else(|| FpmError::ParseError("Invalid version".to_string()))?;
        Ok(VersionConstraint::Compatible(version))
    } else if trimmed.starts_with('~') {
        let version_str = &trimmed[1..];
        let version = Version::parse(version_str)
            .ok_or_else(|| FpmError::ParseError("Invalid version".to_string()))?;
        Ok(VersionConstraint::Patch(version))
    } else if trimmed.starts_with('=') {
        let version_str = &trimmed[1..];
        let version = Version::parse(version_str)
            .ok_or_else(|| FpmError::ParseError("Invalid version".to_string()))?;
        Ok(VersionConstraint::Exact(version))
    } else {
        let version = Version::parse(trimmed)
            .ok_or_else(|| FpmError::ParseError("Invalid version".to_string()))?;
        Ok(VersionConstraint::Default(version))
    }
}

/// 버전이 제약을 만족하는지 확인
pub fn satisfies_constraint(
    version: &Version,
    constraint: &VersionConstraint,
) -> bool {
    match constraint {
        VersionConstraint::Compatible(base) => {
            // >=base, <(base.major+1).0.0
            version.major == base.major &&
            (version.minor > base.minor ||
             (version.minor == base.minor && version.patch >= base.patch))
        }

        VersionConstraint::Patch(base) => {
            // >=base, <base.major.(base.minor+1).0
            version.major == base.major &&
            version.minor == base.minor &&
            version.patch >= base.patch
        }

        VersionConstraint::Exact(base) | VersionConstraint::Default(base) => {
            // 정확히 일치
            version.major == base.major &&
            version.minor == base.minor &&
            version.patch == base.patch
        }
    }
}

/// 두 버전 비교
pub fn semver_compare(v1: &str, v2: &str) -> Result<std::cmp::Ordering, FpmError> {
    let ver1 = Version::parse(v1)
        .ok_or_else(|| FpmError::ParseError(format!("Invalid version: {}", v1)))?;
    let ver2 = Version::parse(v2)
        .ok_or_else(|| FpmError::ParseError(format!("Invalid version: {}", v2)))?;

    Ok(ver1.compare(&ver2))
}

/// 충돌 감지: 두 제약이 동시에 만족 가능한지 확인
pub fn detect_conflicts(
    constraint1: &VersionConstraint,
    constraint2: &VersionConstraint,
) -> bool {
    // 두 제약의 교집합이 공집합인지 확인
    // 예: ^1.0.0과 ^2.0.0은 충돌

    let get_range = |c: &VersionConstraint| -> (u32, u32) {
        match c {
            VersionConstraint::Compatible(v) => {
                // [v.major, (v.major+1))
                (v.major, v.major + 1)
            }
            VersionConstraint::Patch(v) => {
                // [v.major.v.minor, v.major.(v.minor+1))
                (v.major * 1000 + v.minor, v.major * 1000 + v.minor + 1)
            }
            VersionConstraint::Exact(v) | VersionConstraint::Default(v) => {
                // [v, v]
                let val = v.major * 1000 + v.minor * 100 + v.patch;
                (val, val + 1)
            }
        }
    };

    let (min1, max1) = get_range(constraint1);
    let (min2, max2) = get_range(constraint2);

    // 범위 교집합 확인
    !(max1 <= min2 || max2 <= min1)
}

/// 의존성 그래프 구성
pub fn build_dep_graph(
    manifest: &Manifest,
) -> Result<HashMap<String, Vec<String>>, FpmError> {
    let mut graph: HashMap<String, Vec<String>> = HashMap::new();

    let root_name = manifest.package.name.clone();
    let mut deps = vec![];

    // 모든 의존성 수집
    for dep in &manifest.dependencies {
        deps.push(dep.name.clone());
    }

    graph.insert(root_name, deps);
    Ok(graph)
}

/// 위상 정렬 (DFS)
pub fn topological_sort(
    graph: &HashMap<String, Vec<String>>,
) -> Result<Vec<String>, FpmError> {
    let mut visited = std::collections::HashSet::new();
    let mut stack = vec![];

    fn dfs(
        node: &str,
        graph: &HashMap<String, Vec<String>>,
        visited: &mut std::collections::HashSet<String>,
        stack: &mut Vec<String>,
        path: &mut std::collections::HashSet<String>,
    ) -> Result<(), String> {
        if path.contains(node) {
            return Err(format!("Circular dependency detected: {}", node));
        }

        if visited.contains(node) {
            return Ok(());
        }

        path.insert(node.to_string());

        if let Some(deps) = graph.get(node) {
            for dep in deps {
                dfs(dep, graph, visited, stack, path)?;
            }
        }

        path.remove(node);
        visited.insert(node.to_string());
        stack.push(node.to_string());
        Ok(())
    }

    for node in graph.keys() {
        let mut path = std::collections::HashSet::new();
        dfs(node, graph, &mut visited, &mut stack, &mut path)
            .map_err(|e| FpmError::Other(e))?;
    }

    stack.reverse();
    Ok(stack)
}

/// 호환 버전 찾기 (레지스트리에서 조회 필요)
pub fn find_compatible_version(
    package_name: &str,
    constraint: &VersionConstraint,
) -> Result<String, FpmError> {
    // 실제 구현에서는 레지스트리에 쿼리해야 함
    // 여기서는 목(mock) 구현: 제약을 만족하는 버전 반환

    let base_version = match constraint {
        VersionConstraint::Compatible(v) | VersionConstraint::Patch(v) |
        VersionConstraint::Exact(v) | VersionConstraint::Default(v) => v,
    };

    Ok(base_version.to_string())
}

/// 전체 의존성 해결
pub fn resolve_deps(
    manifest: &Manifest,
) -> Result<ResolutionResult, FpmError> {
    let mut resolved = HashMap::new();
    let mut conflicts = vec![];

    // 루트 패키지 추가
    resolved.insert(
        manifest.package.name.clone(),
        manifest.package.version.clone(),
    );

    // 각 의존성 해결 시도
    for dep in &manifest.dependencies {
        match parse_version_range(&dep.version_range) {
            Ok(constraint) => {
                // 호환 버전 찾기
                match find_compatible_version(&dep.name, &constraint) {
                    Ok(version) => {
                        resolved.insert(dep.name.clone(), version);
                    }
                    Err(e) => {
                        conflicts.push(format!("{}: {}", dep.name, e));
                    }
                }
            }
            Err(e) => {
                conflicts.push(format!("{}: {}", dep.name, e));
            }
        }
    }

    // 의존성 그래프 구성
    let graph = build_dep_graph(manifest).unwrap_or_default();

    let success = conflicts.is_empty();

    Ok(ResolutionResult {
        resolved,
        graph,
        conflicts,
        success,
    })
}

