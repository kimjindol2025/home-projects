#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_eval_int() {
        let mut eval = Evaluator::new();
        let result = eval.eval_src("42").unwrap();
        assert_eq!(result, FlValue::Int(42));
    }

    #[test]
    fn test_eval_string() {
        let mut eval = Evaluator::new();
        let result = eval.eval_src("\"hello\"").unwrap();
        assert_eq!(result, FlValue::Str("hello".to_string()));
    }

    #[test]
    fn test_eval_binop_add() {
        let mut eval = Evaluator::new();
        let result = eval.eval_src("1 + 2").unwrap();
        assert_eq!(result, FlValue::Int(3));
    }

    #[test]
    fn test_eval_binop_mul_precedence() {
        let mut eval = Evaluator::new();
        let result = eval.eval_src("1 + 2 * 3").unwrap();
        assert_eq!(result, FlValue::Int(7));
    }

    #[test]
    fn test_eval_let() {
        let mut eval = Evaluator::new();
        eval.eval_src("let x = 42;").unwrap();
        let result = eval.eval_src("x").unwrap();
        assert_eq!(result, FlValue::Int(42));
    }

    #[test]
    fn test_eval_string_concat() {
        let mut eval = Evaluator::new();
        let result = eval.eval_src("\"hello\" + \" \" + \"world\"").unwrap();
        assert_eq!(result, FlValue::Str("hello world".to_string()));
    }

    #[test]
    fn test_eval_array() {
        let mut eval = Evaluator::new();
        let result = eval.eval_src("[1, 2, 3]").unwrap();
        match result {
            FlValue::Array(arr) => {
                assert_eq!(arr.len(), 3);
                assert_eq!(arr[0], FlValue::Int(1));
            }
            _ => panic!("Expected array"),
        }
    }

    #[test]
    fn test_eval_array_index() {
        let mut eval = Evaluator::new();
        let result = eval.eval_src("let a = [10, 20, 30]; a[1]").unwrap();
        assert_eq!(result, FlValue::Int(20));
    }

    #[test]
    fn test_eval_if() {
        let mut eval = Evaluator::new();
        let result = eval.eval_src("if true { 42 } else { 0 }").unwrap();
        assert_eq!(result, FlValue::Int(42));
    }

    #[test]
    fn test_eval_comparison() {
        let mut eval = Evaluator::new();
        let result = eval.eval_src("5 > 3").unwrap();
        assert_eq!(result, FlValue::Bool(true));
    }
}

// ============================================================================
// 정리
// ============================================================================
//
// evaluator.fl 구현 완료:
// ✅ FlValue enum: 모든 FreeLang 값 타입 표현
// ✅ Environment: 변수 스코프 관리 (lexical scoping)
// ✅ Evaluator: AST 노드 평가
// ✅ eval_expr: 모든 표현식 평가 (10개 규칙)
// ✅ eval_stmt: 모든 문장 실행 (5개 규칙)
// ✅ eval_binop: 이항 연산 (모든 타입 지원)
// ✅ eval_unaryop: 단항 연산 (!, -)
// ✅ eval_index: 배열/객체/문자열 인덱싱
// ✅ 10개 테스트
//
// 특징:
// ✓ 타입 안전성 (TypeScript 스타일 검사)
// ✓ 자동 타입 캐스팅 (Int → Float)
// ✓ 문자열 연결 (+ 연산자)
// ✓ Lexical scoping (환경 체인)
// ✓ 에러 처리 (RuntimeError enum)
//
// 다음: stdlib_bindings.fl (내장 함수 등록)
//
