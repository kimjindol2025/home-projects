// ============================================================================
// FlValue 정의 (Phase C stdlib와 동일)
// ============================================================================

#[derive(Clone, Debug, PartialEq)]
pub enum FlValue {
    Int(i64),
    Float(f64),
    Bool(bool),
    Str(String),
    Array(Vec<FlValue>),
    Object(HashMap<String, FlValue>),
    Null,
}

impl FlValue {
    pub fn type_name(&self) -> &'static str {
        match self {
            FlValue::Int(_) => "int",
            FlValue::Float(_) => "float",
            FlValue::Bool(_) => "bool",
            FlValue::Str(_) => "string",
            FlValue::Array(_) => "array",
            FlValue::Object(_) => "object",
            FlValue::Null => "null",
        }
    }

    pub fn is_truthy(&self) -> bool {
        match self {
            FlValue::Null => false,
            FlValue::Bool(b) => *b,
            FlValue::Int(n) => *n != 0,
            FlValue::Float(f) => *f != 0.0 && !f.is_nan(),
            FlValue::Str(s) => !s.is_empty(),
            FlValue::Array(arr) => !arr.is_empty(),
            FlValue::Object(obj) => !obj.is_empty(),
        }
    }

    pub fn is_null(&self) -> bool {
        matches!(self, FlValue::Null)
    }

    pub fn to_string_repr(&self) -> String {
        match self {
            FlValue::Int(n) => n.to_string(),
            FlValue::Float(f) => {
                if f.fract() == 0.0 {
                    format!("{:.1}", f)
                } else {
                    f.to_string()
                }
            }
            FlValue::Bool(b) => b.to_string(),
            FlValue::Str(s) => s.clone(),
            FlValue::Array(arr) => {
                let items: Vec<String> = arr.iter()
                    .map(|v| v.to_string_repr())
                    .collect();
                format!("[{}]", items.join(", "))
            }
            FlValue::Object(obj) => {
                let items: Vec<String> = obj.iter()
                    .map(|(k, v)| format!("\"{}\": {}", k, v.to_string_repr()))
                    .collect();
                format!("{{{}}}", items.join(", "))
            }
            FlValue::Null => "null".to_string(),
        }
    }
}

impl std::fmt::Display for FlValue {
    fn fmt(&self, f: &mut std::fmt::Formatter) -> std::fmt::Result {
        write!(f, "{}", self.to_string_repr())
    }
}

// ============================================================================
// 런타임 에러
// ============================================================================

#[derive(Clone, Debug)]
pub enum RuntimeError {
    TypeError {
        expected: String,
        got: String,
        context: String,
    },
    UndefinedVariable(String),
    IndexOutOfBounds {
        index: i64,
        length: usize,
    },
    CallError {
        name: String,
        reason: String,
    },
    DivisionByZero,
    InvalidOperation(String),
    Other(String),
}

impl std::fmt::Display for RuntimeError {
    fn fmt(&self, f: &mut std::fmt::Formatter) -> std::fmt::Result {
        match self {
            RuntimeError::TypeError { expected, got, context } => {
                write!(f, "TypeError: expected {}, got {} ({})", expected, got, context)
            }
            RuntimeError::UndefinedVariable(name) => {
                write!(f, "UndefinedVariable: {}", name)
            }
            RuntimeError::IndexOutOfBounds { index, length } => {
                write!(f, "IndexOutOfBounds: index {} out of range [0, {})", index, length)
            }
            RuntimeError::CallError { name, reason } => {
                write!(f, "CallError in {}: {}", name, reason)
            }
            RuntimeError::DivisionByZero => {
                write!(f, "DivisionByZero")
            }
            RuntimeError::InvalidOperation(msg) => {
                write!(f, "InvalidOperation: {}", msg)
            }
            RuntimeError::Other(msg) => {
                write!(f, "RuntimeError: {}", msg)
            }
        }
    }
}

// ============================================================================
// 환경 (변수 스코프)
// ============================================================================

#[derive(Clone, Debug)]
pub struct Environment {
    vars: HashMap<String, FlValue>,
    parent: Option<Box<Environment>>,
}

impl Environment {
    pub fn new() -> Self {
        Environment {
            vars: HashMap::new(),
            parent: None,
        }
    }

    pub fn with_parent(parent: Environment) -> Self {
        Environment {
            vars: HashMap::new(),
            parent: Some(Box::new(parent)),
        }
    }

    pub fn get(&self, name: &str) -> Option<FlValue> {
        if let Some(val) = self.vars.get(name) {
            Some(val.clone())
        } else if let Some(parent) = &self.parent {
            parent.get(name)
        } else {
            None
        }
    }

    pub fn set(&mut self, name: String, value: FlValue) {
        self.vars.insert(name, value);
    }

    pub fn define(&mut self, name: String, value: FlValue) {
        self.vars.insert(name, value);
    }
}

// ============================================================================
// 평가기 (Evaluator)
// ============================================================================

pub type BuiltinFn = fn(Vec<FlValue>, &mut Environment) -> Result<FlValue, RuntimeError>;

pub struct Evaluator {
    env: Environment,
    builtins: HashMap<String, BuiltinFn>,
}

impl Evaluator {
    pub fn new() -> Self {
        Evaluator {
            env: Environment::new(),
            builtins: HashMap::new(),
        }
    }

    pub fn register_builtin(&mut self, name: &str, func: BuiltinFn) {
        self.builtins.insert(name.to_string(), func);
    }

    pub fn eval_src(&mut self, src: &str) -> Result<FlValue, RuntimeError> {
        let mut lexer = Lexer::new(src);
        let tokens = lexer.tokenize();
        let mut parser = Parser::new(tokens);

        let program = parser.parse()
            .map_err(|e| RuntimeError::Other(e))?;

        self.eval_program(&program)
    }

    pub fn eval_program(&mut self, prog: &Program) -> Result<FlValue, RuntimeError> {
        let mut last_val = FlValue::Null;

        for stmt in &prog.stmts {
            last_val = self.eval_stmt(stmt)?;

            // Return 문에서 나가기
            if matches!(stmt, Stmt::Return(_)) {
                return Ok(last_val);
            }
        }

        Ok(last_val)
    }

    pub fn eval_stmt(&mut self, stmt: &Stmt) -> Result<FlValue, RuntimeError> {
        match stmt {
            Stmt::Let { name, value } => {
                let val = self.eval_expr(value)?;
                self.env.set(name.clone(), val.clone());
                Ok(val)
            }
            Stmt::Return(expr) => {
                self.eval_expr(expr)
            }
            Stmt::Expr(expr) => {
                self.eval_expr(expr)
            }
            Stmt::While { cond, body } => {
                let mut last_val = FlValue::Null;

                loop {
                    let cond_val = self.eval_expr(cond)?;
                    if !cond_val.is_truthy() {
                        break;
                    }

                    for stmt in body {
                        last_val = self.eval_stmt(stmt)?;
                    }
                }

                Ok(last_val)
            }
            Stmt::For { var, iter, body } => {
                let iter_val = self.eval_expr(iter)?;
                let mut last_val = FlValue::Null;

                match iter_val {
                    FlValue::Array(arr) => {
                        for item in arr {
                            self.env.set(var.clone(), item);

                            for stmt in body {
                                last_val = self.eval_stmt(stmt)?;
                            }
                        }
                    }
                    _ => {
                        return Err(RuntimeError::InvalidOperation(
                            format!("Cannot iterate over {}", iter_val.type_name())
                        ));
                    }
                }

                Ok(last_val)
            }
        }
    }

    pub fn eval_expr(&mut self, expr: &Expr) -> Result<FlValue, RuntimeError> {
        match expr {
            Expr::Int(n) => Ok(FlValue::Int(*n)),
            Expr::Float(f) => Ok(FlValue::Float(*f)),
            Expr::Bool(b) => Ok(FlValue::Bool(*b)),
            Expr::Str(s) => Ok(FlValue::Str(s.clone())),
            Expr::Null => Ok(FlValue::Null),

            Expr::Ident(name) => {
                self.env.get(name)
                    .ok_or_else(|| RuntimeError::UndefinedVariable(name.clone()))
            }

            Expr::BinOp { left, op, right } => {
                let left_val = self.eval_expr(left)?;
                let right_val = self.eval_expr(right)?;
                self.eval_binop(&left_val, op, &right_val)
            }

            Expr::UnaryOp { op, operand } => {
                let val = self.eval_expr(operand)?;
                self.eval_unaryop(op, &val)
            }

            Expr::Call { func, args } => {
                let arg_vals: Result<Vec<_>, _> = args.iter()
                    .map(|arg| self.eval_expr(arg))
                    .collect();

                let arg_vals = arg_vals?;

                // 내장 함수 확인
                if let Some(builtin) = self.builtins.get(func).cloned() {
                    builtin(arg_vals, &mut self.env)
                } else {
                    Err(RuntimeError::CallError {
                        name: func.clone(),
                        reason: "Function not found".to_string(),
                    })
                }
            }

            Expr::Index { obj, index } => {
                let obj_val = self.eval_expr(obj)?;
                let index_val = self.eval_expr(index)?;
                self.eval_index(&obj_val, &index_val)
            }

            Expr::Array(items) => {
                let vals: Result<Vec<_>, _> = items.iter()
                    .map(|item| self.eval_expr(item))
                    .collect();

                Ok(FlValue::Array(vals?))
            }

            Expr::Object(pairs) => {
                let mut obj = HashMap::new();

                for (key, expr) in pairs {
                    let val = self.eval_expr(expr)?;
                    obj.insert(key.clone(), val);
                }

                Ok(FlValue::Object(obj))
            }

            Expr::If { cond, then_block, else_block } => {
                let cond_val = self.eval_expr(cond)?;

                let block = if cond_val.is_truthy() {
                    then_block
                } else if let Some(else_b) = else_block {
                    else_b
                } else {
                    return Ok(FlValue::Null);
                };

                let mut last_val = FlValue::Null;
                for stmt in block {
                    last_val = self.eval_stmt(stmt)?;
                }

                Ok(last_val)
            }
        }
    }

    fn eval_binop(&self, left: &FlValue, op: &BinOpKind, right: &FlValue) -> Result<FlValue, RuntimeError> {
        match (left, right) {
            // 정수 연산
            (FlValue::Int(l), FlValue::Int(r)) => {
                match op {
                    BinOpKind::Add => Ok(FlValue::Int(l + r)),
                    BinOpKind::Sub => Ok(FlValue::Int(l - r)),
                    BinOpKind::Mul => Ok(FlValue::Int(l * r)),
                    BinOpKind::Div => {
                        if *r == 0 {
                            Err(RuntimeError::DivisionByZero)
                        } else {
                            Ok(FlValue::Int(l / r))
                        }
                    }
                    BinOpKind::Mod => {
                        if *r == 0 {
                            Err(RuntimeError::DivisionByZero)
                        } else {
                            Ok(FlValue::Int(l % r))
                        }
                    }
                    BinOpKind::Eq => Ok(FlValue::Bool(l == r)),
                    BinOpKind::Neq => Ok(FlValue::Bool(l != r)),
                    BinOpKind::Lt => Ok(FlValue::Bool(l < r)),
                    BinOpKind::Gt => Ok(FlValue::Bool(l > r)),
                    BinOpKind::Le => Ok(FlValue::Bool(l <= r)),
                    BinOpKind::Ge => Ok(FlValue::Bool(l >= r)),
                    _ => Err(RuntimeError::InvalidOperation(format!("Invalid operation for integers")))
                }
            }

            // 실수 연산
            (FlValue::Float(l), FlValue::Float(r)) => {
                match op {
                    BinOpKind::Add => Ok(FlValue::Float(l + r)),
                    BinOpKind::Sub => Ok(FlValue::Float(l - r)),
                    BinOpKind::Mul => Ok(FlValue::Float(l * r)),
                    BinOpKind::Div => {
                        if *r == 0.0 {
                            Err(RuntimeError::DivisionByZero)
                        } else {
                            Ok(FlValue::Float(l / r))
                        }
                    }
                    BinOpKind::Eq => Ok(FlValue::Bool((l - r).abs() < 1e-10)),
                    BinOpKind::Neq => Ok(FlValue::Bool((l - r).abs() >= 1e-10)),
                    BinOpKind::Lt => Ok(FlValue::Bool(l < r)),
                    BinOpKind::Gt => Ok(FlValue::Bool(l > r)),
                    BinOpKind::Le => Ok(FlValue::Bool(l <= r)),
                    BinOpKind::Ge => Ok(FlValue::Bool(l >= r)),
                    _ => Err(RuntimeError::InvalidOperation(format!("Invalid operation for floats")))
                }
            }

            // 정수 + 실수 (자동 캐스팅)
            (FlValue::Int(l), FlValue::Float(r)) => {
                let l_float = *l as f64;
                match op {
                    BinOpKind::Add => Ok(FlValue::Float(l_float + r)),
                    BinOpKind::Sub => Ok(FlValue::Float(l_float - r)),
                    BinOpKind::Mul => Ok(FlValue::Float(l_float * r)),
                    BinOpKind::Div => {
                        if *r == 0.0 {
                            Err(RuntimeError::DivisionByZero)
                        } else {
                            Ok(FlValue::Float(l_float / r))
                        }
                    }
                    _ => Err(RuntimeError::InvalidOperation(format!("Invalid mixed operation")))
                }
            }

            (FlValue::Float(l), FlValue::Int(r)) => {
                let r_float = *r as f64;
                match op {
                    BinOpKind::Add => Ok(FlValue::Float(l + r_float)),
                    BinOpKind::Sub => Ok(FlValue::Float(l - r_float)),
                    BinOpKind::Mul => Ok(FlValue::Float(l * r_float)),
                    BinOpKind::Div => {
                        if r_float == 0.0 {
                            Err(RuntimeError::DivisionByZero)
                        } else {
                            Ok(FlValue::Float(l / r_float))
                        }
                    }
                    _ => Err(RuntimeError::InvalidOperation(format!("Invalid mixed operation")))
                }
            }

            // 문자열 연산
            (FlValue::Str(l), FlValue::Str(r)) => {
                match op {
                    BinOpKind::Add => Ok(FlValue::Str(format!("{}{}", l, r))),
                    BinOpKind::Eq => Ok(FlValue::Bool(l == r)),
                    BinOpKind::Neq => Ok(FlValue::Bool(l != r)),
                    _ => Err(RuntimeError::InvalidOperation(format!("Invalid operation for strings")))
                }
            }

            // 문자열 + 다른 타입 (자동 변환)
            (FlValue::Str(l), r) => {
                match op {
                    BinOpKind::Add => Ok(FlValue::Str(format!("{}{}", l, r.to_string_repr()))),
                    _ => Err(RuntimeError::InvalidOperation(format!("Invalid operation")))
                }
            }

            (l, FlValue::Str(r)) => {
                match op {
                    BinOpKind::Add => Ok(FlValue::Str(format!("{}{}", l.to_string_repr(), r))),
                    _ => Err(RuntimeError::InvalidOperation(format!("Invalid operation")))
                }
            }

            // 부울 연산
            (FlValue::Bool(l), FlValue::Bool(r)) => {
                match op {
                    BinOpKind::And => Ok(FlValue::Bool(*l && *r)),
                    BinOpKind::Or => Ok(FlValue::Bool(*l || *r)),
                    BinOpKind::Eq => Ok(FlValue::Bool(l == r)),
                    BinOpKind::Neq => Ok(FlValue::Bool(l != r)),
                    _ => Err(RuntimeError::InvalidOperation(format!("Invalid operation for booleans")))
                }
            }

            // 배열 연산
            (FlValue::Array(l), FlValue::Array(r)) => {
                match op {
                    BinOpKind::Add => {
                        let mut result = l.clone();
                        result.extend(r.clone());
                        Ok(FlValue::Array(result))
                    }
                    BinOpKind::Eq => Ok(FlValue::Bool(l == r)),
                    BinOpKind::Neq => Ok(FlValue::Bool(l != r)),
                    _ => Err(RuntimeError::InvalidOperation(format!("Invalid operation for arrays")))
                }
            }

            _ => Err(RuntimeError::InvalidOperation(
                format!("Cannot apply {:?} to {} and {}", op, left.type_name(), right.type_name())
            ))
        }
    }

    fn eval_unaryop(&self, op: &UnaryOpKind, operand: &FlValue) -> Result<FlValue, RuntimeError> {
        match op {
            UnaryOpKind::Not => {
                Ok(FlValue::Bool(!operand.is_truthy()))
            }
            UnaryOpKind::Neg => {
                match operand {
                    FlValue::Int(n) => Ok(FlValue::Int(-n)),
                    FlValue::Float(f) => Ok(FlValue::Float(-f)),
                    _ => Err(RuntimeError::InvalidOperation(
                        format!("Cannot negate {}", operand.type_name())
                    ))
                }
            }
        }
    }

    fn eval_index(&self, obj: &FlValue, index: &FlValue) -> Result<FlValue, RuntimeError> {
        match (obj, index) {
            // 배열 인덱싱
            (FlValue::Array(arr), FlValue::Int(idx)) => {
                if *idx < 0 || *idx as usize >= arr.len() {
                    Err(RuntimeError::IndexOutOfBounds {
                        index: *idx,
                        length: arr.len(),
                    })
                } else {
                    Ok(arr[*idx as usize].clone())
                }
            }

            // 객체 인덱싱
            (FlValue::Object(obj), FlValue::Str(key)) => {
                Ok(obj.get(key)
                    .cloned()
                    .unwrap_or(FlValue::Null))
            }

            // 문자열 인덱싱
            (FlValue::Str(s), FlValue::Int(idx)) => {
                let chars: Vec<char> = s.chars().collect();
                if *idx < 0 || *idx as usize >= chars.len() {
                    Err(RuntimeError::IndexOutOfBounds {
                        index: *idx,
                        length: chars.len(),
                    })
                } else {
                    Ok(FlValue::Str(chars[*idx as usize].to_string()))
                }
            }

            _ => Err(RuntimeError::InvalidOperation(
                format!("Cannot index {} with {}", obj.type_name(), index.type_name())
            ))
        }
    }
}

