use crate::sync::{Arc, Mutex, Channel, ThreadPool, AtomicUsize};
use std::sync::atomic::Ordering;
use std::time::Instant;

// ============================================================================
// BenchResult - 벤치마크 결과 구조
// ============================================================================

#[derive(Clone, Debug)]
pub struct BenchResult {
    /// 벤치마크 이름
    pub name: String,

    /// 수행 작업 수
    pub operations: u64,

    /// 소요 시간 (밀리초)
    pub elapsed_ms: u128,

    /// 초당 처리량 (ops/sec)
    pub throughput: f64,

    /// 평균 지연시간 (마이크로초)
    pub latency_us: f64,
}

impl BenchResult {
    /// 새 벤치마크 결과 생성
    pub fn new(name: &str, operations: u64, elapsed_ms: u128) -> Self {
        let throughput = if elapsed_ms > 0 {
            (operations as f64) / (elapsed_ms as f64) * 1000.0
        } else {
            0.0
        };

        let latency_us = if operations > 0 {
            (elapsed_ms as f64) * 1000.0 / (operations as f64)
        } else {
            0.0
        };

        BenchResult {
            name: name.to_string(),
            operations,
            elapsed_ms,
            throughput,
            latency_us,
        }
    }

    /// 결과를 표준 포맷으로 출력
    pub fn print(&self) {
        println!(
            "[BENCH] {}: {:,} ops in {}ms ({:.1}M ops/s, {:.2}μs/op)",
            self.name,
            self.operations,
            self.elapsed_ms,
            self.throughput / 1_000_000.0,
            self.latency_us
        );
    }
}

// ============================================================================
// Benchmark 1: Arc Clone Throughput
// ============================================================================

/// Arc 클론 작업의 처리량 측정
pub fn bench_arc_clone() -> BenchResult {
    let arc_val = Arc::new(Mutex::new(42i64));
    let iterations = 1_000_000u64;

    let start = Instant::now();

    for _ in 0..iterations {
        let _ = arc_val.clone();
    }

    let elapsed = start.elapsed().as_millis();
    BenchResult::new("arc_clone_throughput", iterations, elapsed)
}

// ============================================================================
// Benchmark 2: Mutex Lock Contention
// ============================================================================

/// Mutex 경합 (8개 스레드가 동일 Mutex 접근)
pub fn bench_mutex_contention() -> BenchResult {
    let mutex = Arc::new(Mutex::new(0i64));
    let iterations = 100_000u64;
    let thread_count = 8;
    let ops_per_thread = iterations / thread_count as u64;

    let start = Instant::now();

    let mut handles = vec![];

    for _ in 0..thread_count {
        let m = mutex.clone();
        let handle = std::thread::spawn(move || {
            for _ in 0..ops_per_thread {
                if let Ok(mut val) = m.lock() {
                    *val += 1;
                }
            }
        });
        handles.push(handle);
    }

    for handle in handles {
        handle.join().ok();
    }

    let elapsed = start.elapsed().as_millis();
    BenchResult::new("mutex_contention", iterations, elapsed)
}

// ============================================================================
// Benchmark 3: Channel Throughput
// ============================================================================

/// Channel 메시지 처리량 측정
pub fn bench_channel_throughput() -> BenchResult {
    let (tx, rx) = Channel::new();
    let message_count = 100_000u64;

    let start = Instant::now();

    // 메시지 전송
    for i in 0..message_count {
        tx.send(i as i64).ok();
    }

    // 메시지 수신
    let mut received = 0u64;
    while let Ok(_) = rx.try_recv() {
        received += 1;
        if received >= message_count {
            break;
        }
    }

    let elapsed = start.elapsed().as_millis();
    BenchResult::new("channel_throughput", message_count, elapsed)
}

// ============================================================================
// Benchmark 4: ThreadPool Work Distribution
// ============================================================================

/// ThreadPool 작업 분산 처리량
pub fn bench_threadpool_distribution() -> BenchResult {
    let pool = ThreadPool::new(4);
    let counter = Arc::new(std::sync::atomic::AtomicU64::new(0));
    let total_tasks = 100_000u64;

    let start = Instant::now();

    for _ in 0..total_tasks {
        let c = counter.clone();
        pool.execute(move || {
            c.fetch_add(1, Ordering::SeqCst);
        });
    }

    // 모든 작업 완료 대기
    std::thread::sleep(std::time::Duration::from_millis(500));

    let elapsed = start.elapsed().as_millis();
    BenchResult::new("threadpool_distribution", total_tasks, elapsed)
}

// ============================================================================
// Benchmark 5: Arc + Mutex Combined
// ============================================================================

/// Arc + Mutex 조합 (공유 + 안전 접근)
pub fn bench_arc_mutex_combined() -> BenchResult {
    let shared = Arc::new(Mutex::new(Vec::new()));
    let iterations = 50_000u64;

    let start = Instant::now();

    for i in 0..iterations {
        let s = shared.clone();
        if let Ok(mut vec) = s.lock() {
            vec.push(i);
            if vec.len() > 100 {
                vec.clear();
            }
        }
    }

    let elapsed = start.elapsed().as_millis();
    BenchResult::new("arc_mutex_combined", iterations, elapsed)
}

// ============================================================================
// Benchmark 6: Atomic Operations
// ============================================================================

/// 원자적 연산 처리량 (AtomicUsize)
pub fn bench_atomic_operations() -> BenchResult {
    let atomic = Arc::new(AtomicUsize::new(0));
    let iterations = 1_000_000u64;

    let start = Instant::now();

    for _ in 0..iterations {
        atomic.fetch_add(1, Ordering::SeqCst);
    }

    let elapsed = start.elapsed().as_millis();
    BenchResult::new("atomic_operations", iterations, elapsed)
}

// ============================================================================
// Benchmark 7: Multi-threaded Arc Clone
// ============================================================================

/// 멀티스레드 환경에서 Arc 클론
pub fn bench_arc_clone_multithreaded() -> BenchResult {
    let arc_val = Arc::new(42i64);
    let thread_count = 4;
    let clones_per_thread = 100_000u64;
    let total_clones = (thread_count as u64) * clones_per_thread;

    let start = Instant::now();

    let mut handles = vec![];

    for _ in 0..thread_count {
        let arc = arc_val.clone();
        let handle = std::thread::spawn(move || {
            for _ in 0..clones_per_thread {
                let _ = arc.clone();
            }
        });
        handles.push(handle);
    }

    for handle in handles {
        handle.join().ok();
    }

    let elapsed = start.elapsed().as_millis();
    BenchResult::new("arc_clone_multithreaded", total_clones, elapsed)
}

// ============================================================================
// Benchmark 8: Channel + ThreadPool Pipeline
// ============================================================================

/// Channel과 ThreadPool을 결합한 파이프라인
pub fn bench_channel_threadpool_pipeline() -> BenchResult {
    let (tx, rx) = Channel::new();
    let pool = ThreadPool::new(4);
    let result = Arc::new(Mutex::new(0u64));
    let pipeline_items = 10_000u64;

    let start = Instant::now();

    // 아이템 전송
    for i in 0..pipeline_items {
        tx.send(i).ok();
    }

    // 워커에서 처리
    for _ in 0..pipeline_items {
        if let Ok(_) = rx.try_recv() {
            let res = result.clone();
            pool.execute(move || {
                if let Ok(mut count) = res.lock() {
                    *count += 1;
                }
            });
        }
    }

    // 완료 대기
    std::thread::sleep(std::time::Duration::from_millis(300));

    let elapsed = start.elapsed().as_millis();
    BenchResult::new("channel_threadpool_pipeline", pipeline_items, elapsed)
}

