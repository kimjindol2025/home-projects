// Benchmark Runner
// ============================================================================

/// 모든 벤치마크 실행
pub fn run_all_benchmarks() -> Vec<BenchResult> {
    println!("╔════════════════════════════════════════════════════════╗");
    println!("║  FreeLang Phase D.2 - Sync Module Benchmarks          ║");
    println!("╚════════════════════════════════════════════════════════╝\n");

    let mut results = vec![];

    println!("Running benchmarks...\n");

    // 1. Arc Clone
    println!("⏱️  Benchmark 1/8: Arc Clone Throughput");
    let result = bench_arc_clone();
    result.print();
    results.push(result);
    println!();

    // 2. Mutex Contention
    println!("⏱️  Benchmark 2/8: Mutex Lock Contention");
    let result = bench_mutex_contention();
    result.print();
    results.push(result);
    println!();

    // 3. Channel Throughput
    println!("⏱️  Benchmark 3/8: Channel Message Throughput");
    let result = bench_channel_throughput();
    result.print();
    results.push(result);
    println!();

    // 4. ThreadPool Distribution
    println!("⏱️  Benchmark 4/8: ThreadPool Work Distribution");
    let result = bench_threadpool_distribution();
    result.print();
    results.push(result);
    println!();

    // 5. Arc + Mutex Combined
    println!("⏱️  Benchmark 5/8: Arc + Mutex Combined");
    let result = bench_arc_mutex_combined();
    result.print();
    results.push(result);
    println!();

    // 6. Atomic Operations
    println!("⏱️  Benchmark 6/8: Atomic Operations");
    let result = bench_atomic_operations();
    result.print();
    results.push(result);
    println!();

    // 7. Multi-threaded Arc Clone
    println!("⏱️  Benchmark 7/8: Multi-threaded Arc Clone");
    let result = bench_arc_clone_multithreaded();
    result.print();
    results.push(result);
    println!();

    // 8. Channel + ThreadPool Pipeline
    println!("⏱️  Benchmark 8/8: Channel + ThreadPool Pipeline");
    let result = bench_channel_threadpool_pipeline();
    result.print();
    results.push(result);
    println!();

    println!("╔════════════════════════════════════════════════════════╗");
    println!("║  Summary                                               ║");
    println!("╠════════════════════════════════════════════════════════╣");

    // 성능 순위
    let mut sorted = results.clone();
    sorted.sort_by(|a, b| b.throughput.partial_cmp(&a.throughput).unwrap());

    println!("Top 3 Fastest (by throughput):");
    for (i, result) in sorted.iter().take(3).enumerate() {
        println!(
            "  {}. {} - {:.1}M ops/s",
            i + 1,
            result.name,
            result.throughput / 1_000_000.0
        );
    }

    println!("\nLowest Latency:");
    let mut latency_sorted = results.clone();
    latency_sorted.sort_by(|a, b| a.latency_us.partial_cmp(&b.latency_us).unwrap());

    for (i, result) in latency_sorted.iter().take(3).enumerate() {
        println!(
            "  {}. {} - {:.2}μs/op",
            i + 1,
            result.name,
            result.latency_us
        );
    }

    println!("╚════════════════════════════════════════════════════════╝\n");

    results
}

// ============================================================================
// Statistics Helper
// ============================================================================

/// 벤치마크 결과 통계 출력
pub fn print_benchmark_stats(results: &[BenchResult]) {
    println!("Benchmark Statistics:");
    println!("─────────────────────────────────────────────");

    let total_ops: u64 = results.iter().map(|r| r.operations).sum();
    let avg_throughput: f64 = results.iter().map(|r| r.throughput).sum::<f64>() / results.len() as f64;
    let avg_latency: f64 = results.iter().map(|r| r.latency_us).sum::<f64>() / results.len() as f64;

    println!("Total Operations: {:,}", total_ops);
    println!("Average Throughput: {:.1}M ops/s", avg_throughput / 1_000_000.0);
    println!("Average Latency: {:.2}μs/op", avg_latency);
    println!("─────────────────────────────────────────────");
}

