//
// Rust의 Send/Sync 트레이트를 FreeLang으로 재현
// 목표: 스레드 간 안전한 타입 전달 및 공유를 컴파일 타임에 검증
//
// Send: 소유권을 스레드 간 안전하게 이동 가능
// Sync: 참조를 스레드 간 안전하게 공유 가능
//
// 작성일: 2026-03-02
// 커밋: Phase B.1 (Week 1-2)

/// Send 트레이트
///
/// T가 Send를 구현하면, T 값을 스레드 간에 안전하게 이동할 수 있습니다.
/// 즉, thread::spawn(move || { ... })에서 T 타입 값을 안전하게 전달할 수 있습니다.
///
/// 기본 규칙:
/// - 모든 필드가 Send이면, 복합 타입도 Send
/// - 스레드 간 소유권 이전 시 데이터 경합 불가능
pub trait Send {
    // 마커 트레이트: 구현 메서드 없음
    // Send라는 것을 선언하는 것만으로 충분
}

/// Sync 트레이트
///
/// T가 Sync를 구현하면, &T (불변 참조)를 스레드 간에 안전하게 공유할 수 있습니다.
///
/// 기본 규칙:
/// - 모든 필드가 Sync이면, 복합 타입도 Sync
/// - &T를 여러 스레드에서 동시에 접근 가능
pub trait Sync {
    // 마커 트레이트
}

