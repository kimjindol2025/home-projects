// ============================================================================
// Vec<T>에 대한 조건부 Send/Sync 구현
// ============================================================================

/// Vec<T>는 T가 Send이면 Send
pub struct Vec<T> {
    data: *mut T,
    len: usize,
    capacity: usize,
}

// Vec<T>: Send if T: Send
impl<T> Send for Vec<T> where T: Send { }

// Vec<T>: Sync if T: Sync
impl<T> Sync for Vec<T> where T: Sync { }

// ============================================================================
// Option<T>에 대한 조건부 Send/Sync 구현
// ============================================================================

pub enum Option<T> {
    Some(T),
    None,
}

// Option<T>: Send if T: Send
impl<T> Send for Option<T> where T: Send { }

// Option<T>: Sync if T: Sync
impl<T> Sync for Option<T> where T: Sync { }

// ============================================================================
// Result<T, E>에 대한 조건부 Send/Sync 구현
// ============================================================================

pub enum Result<T, E> {
    Ok(T),
    Err(E),
}

// Result<T, E>: Send if T: Send and E: Send
impl<T, E> Send for Result<T, E> where T: Send, E: Send { }

// Result<T, E>: Sync if T: Sync and E: Sync
impl<T, E> Sync for Result<T, E> where T: Sync, E: Sync { }

// ============================================================================
// Arc<T>: 원자적 참조 카운팅 (Atomic Reference Counting)
// ============================================================================

/// Arc<T>는 여러 소유자가 같은 데이터를 공유하되,
/// 모든 소유자가 제거될 때까지 메모리를 유지합니다.
pub struct Arc<T> {
    ptr: *mut ArcInner<T>,
}

struct ArcInner<T> {
    strong: u32,     // 강한 참조 카운트
    weak: u32,       // 약한 참조 카운트
    data: T,
}

// Arc<T>: Send if T: Send + Sync
// 설명: Arc는 여러 스레드에서 공유되므로, T는 Send이면서 동시에
//      스레드 간에 안전하게 공유될 수 있어야 합니다.
impl<T> Send for Arc<T> where T: Send + Sync { }

// Arc<T>: Sync if T: Send + Sync
// 설명: Arc의 &을 여러 스레드에서 공유할 수 있으려면,
//      T는 Send이면서 Sync여야 합니다.
impl<T> Sync for Arc<T> where T: Send + Sync { }

// ============================================================================
// Mutex<T>: 상호 배제 락 (Mutual Exclusion Lock)
// ============================================================================

/// Mutex<T>는 내부 가변성(Interior Mutability)을 제공하면서
/// 동시에 스레드 안전성을 보장하는 동기화 프리미티브입니다.
pub struct Mutex<T> {
    lock: bool,  // 간단한 락 구현 (실제로는 futex/platform mutex 사용)
    data: T,
}

// Mutex<T>: Send if T: Send
// 설명: Mutex<T>의 소유권을 다른 스레드로 이동할 수 있으려면,
//      T가 Send여야 합니다.
impl<T> Send for Mutex<T> where T: Send { }

// Mutex<T>: Sync
// 설명: Mutex<T>는 &Mutex<T>를 여러 스레드에서 공유할 수 있습니다.
//      왜냐하면 lock()은 불변 참조로 호출되고, 내부적으로는
//      배타성을 보장하기 때문입니다.
impl<T> Sync for Mutex<T> where T: Send { }

// ============================================================================
// Rc<T>: 참조 카운팅 (Reference Counting, 단일 스레드용)
// ============================================================================

/// Rc<T>는 단일 스레드 전용 참조 카운팅입니다.
/// 여러 스레드에서 사용하면 안전하지 않습니다.
pub struct Rc<T> {
    ptr: *mut RcInner<T>,
}

struct RcInner<T> {
    strong: u32,  // 스레드 안전하지 않은 카운트
    data: T,
}

// Rc<T>: !Send (절대로 Send가 아님)
// 이것은 컴파일러에게 Rc<T>를 thread::spawn으로 전달할 수 없다는 것을 알립니다.
// Rc의 refcount는 원자적이지 않기 때문입니다.
pub trait RcSendBlock {}

// ============================================================================
// RefCell<T>: 동적 빌림 검사 (Dynamic Borrow Checking)
// ============================================================================

/// RefCell<T>는 런타임에 빌림 규칙을 검사합니다.
/// 규칙 위반 시 panic()을 발생시킵니다.
pub struct RefCell<T> {
    borrow_count: i32,  // 양수: 불변 빌림 카운트, -1: 가변 빌림 중
    data: T,
}

// RefCell<T>: !Sync (절대로 Sync가 아님)
// 설명: RefCell의 borrow_count는 비원자적이므로,
//      여러 스레드에서 동시에 접근하면 데이터 경합이 발생할 수 있습니다.
pub trait RefCellSyncBlock {}

// ============================================================================
// 스레드 안전성 검증 함수들
// ============================================================================

/// 주어진 타입 T가 Send를 구현하는지 검증합니다.
/// 컴파일 시에만 실행되며, 런타임 비용이 없습니다.
fn assert_send<T: Send>() { }

/// 주어진 타입 T가 Sync를 구현하는지 검증합니다.
fn assert_sync<T: Sync>() { }

/// 주어진 타입 T가 Send와 Sync 모두 구현하는지 검증합니다.
fn assert_send_sync<T: Send + Sync>() { }

