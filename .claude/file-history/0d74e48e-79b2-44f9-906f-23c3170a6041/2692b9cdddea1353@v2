#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_primitive_send() {
        // 모든 원시 타입은 Send여야 합니다.
        // 이 함수들은 컴파일 타임에 검증되고,
        // 컴파일 성공 = 테스트 통과
        assert_send::<i32>();
        assert_send::<f64>();
        assert_send::<bool>();
        assert_send::<str>();
    }

    #[test]
    fn test_primitive_sync() {
        // 모든 원시 타입은 Sync여야 합니다.
        assert_sync::<i32>();
        assert_sync::<f64>();
        assert_sync::<bool>();
        assert_sync::<str>();
    }

    #[test]
    fn test_vec_send_with_send_element() {
        // Vec<i32>는 i32가 Send이므로 Send여야 합니다.
        assert_send::<Vec<i32>>();
    }

    #[test]
    fn test_vec_sync_with_sync_element() {
        // Vec<i32>는 i32가 Sync이므로 Sync여야 합니다.
        assert_sync::<Vec<i32>>();
    }

    #[test]
    fn test_option_send_with_send_element() {
        // Option<i32>는 i32가 Send이므로 Send여야 합니다.
        assert_send::<Option<i32>>();
    }

    #[test]
    fn test_result_send_with_send_elements() {
        // Result<i32, String>는 두 타입 모두 Send이므로 Send여야 합니다.
        assert_send::<Result<i32, i32>>();
    }

    #[test]
    fn test_arc_send_with_send_sync_element() {
        // Arc<i32>는 i32가 Send+Sync이므로 Send여야 합니다.
        assert_send::<Arc<i32>>();
    }

    #[test]
    fn test_arc_sync_with_send_sync_element() {
        // Arc<i32>는 i32가 Send+Sync이므로 Sync여야 합니다.
        assert_sync::<Arc<i32>>();
    }

    #[test]
    fn test_mutex_send_with_send_element() {
        // Mutex<i32>는 i32가 Send이므로 Send여야 합니다.
        assert_send::<Mutex<i32>>();
    }

    #[test]
    fn test_mutex_sync_with_send_element() {
        // Mutex<i32>는 내부적으로 배타성을 보장하므로 Sync여야 합니다.
        assert_sync::<Mutex<i32>>();
    }

