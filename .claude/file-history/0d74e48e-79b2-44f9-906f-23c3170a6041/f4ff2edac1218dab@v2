fn getPercentile
  input: (arr: array<number>, p: number)
  output: number
  intent: \"백분위수 계산\"
  do
    let index = (p * arrayLen(arr)) / 100
    return arrayGet(arr, index)

fn calculateAvg
  input: arr: array<number>
  output: number
  intent: \"평균 계산\"
  do
    let sum = 0
    for i in 0..arrayLen(arr)
      sum = sum + arrayGet(arr, i)
    return sum / arrayLen(arr)

