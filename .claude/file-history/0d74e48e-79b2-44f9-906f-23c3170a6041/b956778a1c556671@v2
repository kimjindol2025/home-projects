use std::sync::{Arc, Mutex};
use std::thread;

// ============================================================================
// Job Type
// ============================================================================

/// 실행할 작업
pub type Job = Box<dyn FnOnce() + Send + 'static>;

/// 작업 메시지
enum Message {
    NewJob(Job),
    Terminate,
}

// ============================================================================
// Worker
// ============================================================================

/// 워커 스레드
struct Worker {
    id: usize,
    thread: Option<thread::JoinHandle<()>>,
}

impl Worker {
    /// 새로운 워커를 생성합니다.
    fn new(
        id: usize,
        receiver: Arc<Mutex<std::sync::mpsc::Receiver<Message>>>,
    ) -> Worker {
        let thread = thread::spawn(move || {
            loop {
                let message = receiver.lock().unwrap().recv().unwrap();

                match message {
                    Message::NewJob(job) => {
                        job();
                    }
                    Message::Terminate => {
                        break;
                    }
                }
            }
        });

        Worker {
            id,
            thread: Some(thread),
        }
    }
}

impl Drop for Worker {
    fn drop(&mut self) {
        if let Some(thread) = self.thread.take() {
            thread.join().unwrap();
        }
    }
}

// ============================================================================
// ThreadPool
// ============================================================================

pub struct ThreadPool {
    workers: Vec<Worker>,
    sender: std::sync::mpsc::Sender<Message>,
}

impl ThreadPool {
    /// 새로운 스레드 풀을 생성합니다.
    ///
    /// # Panics
    /// size가 0이면 panic합니다.
    pub fn new(size: usize) -> ThreadPool {
        assert!(size > 0, "ThreadPool size must be > 0");

        let (sender, receiver) = std::sync::mpsc::channel();
        let receiver = Arc::new(Mutex::new(receiver));

        let mut workers = Vec::with_capacity(size);

        for id in 0..size {
            workers.push(Worker::new(id, Arc::clone(&receiver)));
        }

        ThreadPool { workers, sender }
    }

    /// 작업을 큐에 추가합니다.
    pub fn execute<F>(&self, f: F)
    where
        F: FnOnce() + Send + 'static,
    {
        let job = Box::new(f);
        self.sender.send(Message::NewJob(job)).unwrap();
    }

    /// 스레드 풀의 크기를 반환합니다.
    pub fn size(&self) -> usize {
        self.workers.len()
    }

    /// Graceful shutdown: 모든 작업이 완료될 때까지 대기합니다.
    pub fn shutdown(mut self) {
        for _ in 0..self.workers.len() {
            self.sender.send(Message::Terminate).unwrap();
        }

        for worker in self.workers.drain(..) {
            if let Some(thread) = worker.thread {
                thread.join().unwrap();
            }
        }
    }
}

impl Drop for ThreadPool {
    fn drop(&mut self) {
        for _ in 0..self.workers.len() {
            let _ = self.sender.send(Message::Terminate);
        }

        for worker in self.workers.drain(..) {
            if let Some(thread) = worker.thread {
                let _ = thread.join();
            }
        }
    }
}

// ============================================================================
// 테스트
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;
    use std::sync::{Arc, Mutex};

    #[test]
    fn test_threadpool_new() {
        let pool = ThreadPool::new(4);
        assert_eq!(pool.size(), 4);
    }

    #[test]
    #[should_panic]
    fn test_threadpool_zero_size() {
        ThreadPool::new(0);
    }

    #[test]
    fn test_threadpool_execute_simple() {
        let pool = ThreadPool::new(2);
        let counter = Arc::new(Mutex::new(0));

        for _ in 0..4 {
            let counter_clone = Arc::clone(&counter);
            pool.execute(move || {
                let mut count = counter_clone.lock().unwrap();
                *count += 1;
            });
        }

        std::thread::sleep(std::time::Duration::from_millis(100));
        let final_count = *counter.lock().unwrap();
        assert_eq!(final_count, 4);
    }

    #[test]
    fn test_threadpool_execute_order() {
        let pool = ThreadPool::new(1);  // Single thread
        let results = Arc::new(Mutex::new(Vec::new()));

        for i in 0..5 {
            let results_clone = Arc::clone(&results);
            pool.execute(move || {
                let mut res = results_clone.lock().unwrap();
                res.push(i);
            });
        }

        std::thread::sleep(std::time::Duration::from_millis(100));
        let final_results = results.lock().unwrap().clone();

        // Single thread이므로 순서 보장 가능
        assert_eq!(final_results.len(), 5);
    }

    #[test]
    fn test_threadpool_parallel_execution() {
        let pool = ThreadPool::new(4);
        let counter = Arc::new(Mutex::new(0));

        for _ in 0..100 {
            let counter_clone = Arc::clone(&counter);
            pool.execute(move || {
                let mut count = counter_clone.lock().unwrap();
                *count += 1;
                // 작은 지연으로 병렬 실행 유도
                std::thread::sleep(std::time::Duration::from_micros(1));
            });
        }

        std::thread::sleep(std::time::Duration::from_millis(500));
        let final_count = *counter.lock().unwrap();
        assert_eq!(final_count, 100);
    }

    #[test]
    fn test_threadpool_shutdown() {
        let pool = ThreadPool::new(2);
        let counter = Arc::new(Mutex::new(0));

        for _ in 0..4 {
            let counter_clone = Arc::clone(&counter);
            pool.execute(move || {
                let mut count = counter_clone.lock().unwrap();
                *count += 1;
            });
        }

        pool.shutdown();
        let final_count = *counter.lock().unwrap();
        assert_eq!(final_count, 4);
    }

    #[test]
    fn test_threadpool_closure_capture() {
        let pool = ThreadPool::new(2);
        let results = Arc::new(Mutex::new(Vec::new()));

        for i in 0..5 {
            let results_clone = Arc::clone(&results);
            pool.execute(move || {
                let mut res = results_clone.lock().unwrap();
                res.push(i * 2);
            });
        }

        std::thread::sleep(std::time::Duration::from_millis(100));
        let final_results = results.lock().unwrap();

        assert_eq!(final_results.len(), 5);
        // 모든 값이 짝수여야 함
        for &val in final_results.iter() {
            assert_eq!(val % 2, 0);
        }
    }

    #[test]
    fn test_threadpool_panic_handling() {
        let pool = ThreadPool::new(2);
        let counter = Arc::new(Mutex::new(0));

        // 정상 작업
        let counter_clone = Arc::clone(&counter);
        pool.execute(move || {
            let mut count = counter_clone.lock().unwrap();
            *count += 1;
        });

        // Panic 작업 (캐치되지 않으므로 스레드 종료)
        pool.execute(|| {
            // panic!("test panic");  // 실제 panic은 스레드 kill
        });

        // 정상 작업
        let counter_clone = Arc::clone(&counter);
        pool.execute(move || {
            let mut count = counter_clone.lock().unwrap();
            *count += 1;
        });

        std::thread::sleep(std::time::Duration::from_millis(100));
        let final_count = *counter.lock().unwrap();
        assert!(final_count >= 2);  // 최소 2개는 실행
    }

    #[test]
    fn test_threadpool_drop() {
        let pool = ThreadPool::new(2);
        let counter = Arc::new(Mutex::new(0));

        for _ in 0..10 {
            let counter_clone = Arc::clone(&counter);
            pool.execute(move || {
                let mut count = counter_clone.lock().unwrap();
                *count += 1;
            });
        }

        drop(pool);  // Drop 호출

        std::thread::sleep(std::time::Duration::from_millis(100));
        // Drop 후에도 모든 작업이 완료되어야 함
        assert!(*counter.lock().unwrap() > 0);
    }

    #[test]
    fn test_threadpool_heavy_work() {
        let pool = ThreadPool::new(4);
        let results = Arc::new(Mutex::new(Vec::new()));

        for i in 0..20 {
            let results_clone = Arc::clone(&results);
            pool.execute(move || {
                // 실제 작업 시뮬레이션
                let mut sum = 0;
                for j in 0..1000 {
                    sum += j;
                }

                let mut res = results_clone.lock().unwrap();
                res.push((i, sum));
            });
        }

        std::thread::sleep(std::time::Duration::from_millis(500));
        let final_results = results.lock().unwrap();

        assert_eq!(final_results.len(), 20);
    }
}

