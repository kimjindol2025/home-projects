// ============================================================================
// FlValue Type - 모든 stdlib 함수가 사용하는 통일된 값 타입
// ============================================================================

/// FreeLang 값의 통일된 표현
#[derive(Clone, Debug, PartialEq)]
pub enum FlValue {
    /// 정수 (i64)
    Int(i64),

    /// 부동소수점 (f64)
    Float(f64),

    /// 불리언
    Bool(bool),

    /// 문자열
    Str(String),

    /// 배열
    Array(Vec<FlValue>),

    /// 객체/맵 (키-값 쌍)
    Object(std::collections::HashMap<String, FlValue>),

    /// null 값
    Null,
}

impl FlValue {
    /// 값의 타입명을 반환합니다.
    pub fn type_name(&self) -> &'static str {
        match self {
            FlValue::Int(_) => "int",
            FlValue::Float(_) => "float",
            FlValue::Bool(_) => "bool",
            FlValue::Str(_) => "string",
            FlValue::Array(_) => "array",
            FlValue::Object(_) => "object",
            FlValue::Null => "null",
        }
    }

    /// 값이 "참"인지 확인합니다 (Truthy evaluation).
    pub fn is_truthy(&self) -> bool {
        match self {
            FlValue::Null => false,
            FlValue::Bool(b) => *b,
            FlValue::Int(n) => *n != 0,
            FlValue::Float(f) => *f != 0.0,
            FlValue::Str(s) => !s.is_empty(),
            FlValue::Array(arr) => !arr.is_empty(),
            FlValue::Object(obj) => !obj.is_empty(),
        }
    }

    /// 값이 null인지 확인합니다.
    pub fn is_null(&self) -> bool {
        matches!(self, FlValue::Null)
    }

    /// 값의 문자열 표현을 반환합니다.
    pub fn to_string_repr(&self) -> String {
        match self {
            FlValue::Null => "null".to_string(),
            FlValue::Bool(b) => b.to_string(),
            FlValue::Int(n) => n.to_string(),
            FlValue::Float(f) => f.to_string(),
            FlValue::Str(s) => s.clone(),
            FlValue::Array(_) => format!("[array]"),
            FlValue::Object(_) => format!("[object]"),
        }
    }
}

/// 표준 라이브러리 정보를 반환합니다.
