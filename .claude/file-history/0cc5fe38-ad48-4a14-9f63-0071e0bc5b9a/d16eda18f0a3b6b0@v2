        println!("[시연 6-2] 슬라이스 범위와 메모리 레이아웃");

        let original = String::from("v4.3 Architecture");
        let first_part = &original[0..4];    // "v4.3"
        let second_part = &original[5..];    // "Architecture"

        println!("  원본: {}", original);
        println!("  슬라이스1 [0..4]:  '{}'", first_part);
        println!("  슬라이스2 [5..]:   '{}'", second_part);

        println!("\n  【메모리 구조】");
