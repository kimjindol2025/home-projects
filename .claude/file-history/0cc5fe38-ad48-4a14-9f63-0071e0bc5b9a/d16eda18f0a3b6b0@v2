        println!("  [1..4]:       {:?}  (중간 3개)", middle);
        println!("  각 슬라이스는 독립적으로 처리 가능합니다.\n");
    }

    // 시연 2-3: 슬라이스 길이와 반복
    {
        println!("[시연 2-3] 슬라이스 길이와 반복");
        let readings = [100, 200, 300, 400, 500];
        let partial = &readings[1..4];

        println!("  부분 슬라이스: {:?}", partial);
        println!("  길이: {}", partial.len());
        println!("  반복 처리:");
        for (i, &value) in partial.iter().enumerate() {
            println!("    [{}] = {}", i, value);
        }
        println!();
    }

    // ────────────────────────────────────────────────────────────────────────
