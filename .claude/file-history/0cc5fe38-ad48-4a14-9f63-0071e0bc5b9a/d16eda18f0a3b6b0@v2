fn main() {
    println!("🔪 ═══════════════════════════════════════════════════════════════");
    println!("   v4.3: 슬라이스와 데이터의 부분 참조");
    println!("   「정밀한 부분 제어」");
    println!("🔪 ═══════════════════════════════════════════════════════════════\n");

    // ────────────────────────────────────────────────────────────────────────
    // [섹션 1] 문자열 슬라이스 기초: &str의 정체
    // ────────────────────────────────────────────────────────────────────────
    println!("【섹션 1】문자열 슬라이스 기초: &str의 정체");
    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n");

    // 시연 1-1: 문자열 전체 슬라이스
    {
        println!("[시연 1-1] 문자열 전체 슬라이스");
        let system_command = String::from("REBOOT SYSTEM_CORE_01");

        // 전체 문자열을 슬라이스로 (0부터 끝까지)
        let entire_slice = &system_command[..];

        println!("  원본: {}", system_command);
        println!("  슬라이스 [..]: {}", entire_slice);
        println!("  메모리 복사: 없음! (주소와 길이만 전달)");

        // 메모리 구조 설명
        println!("\n  【메모리 구조】");
        println!("  String (소유권 가짐):");
        println!("    ptr: 0x12345678 ──┐");
        println!("    len: 22           │");
        println!("    capacity: 24      │");
        println!("                      │");
        println!("  &str (슬라이스 - 빌림):");
        println!("    ptr: 0x12345678 ──┘ (같은 주소)");
        println!("    len: 22             (길이만 가짐)\n");
    }

    // 시연 1-2: 부분 슬라이스 생성
    {
        println!("[시연 1-2] 부분 슬라이스 생성");
        let system_command = String::from("REBOOT SYSTEM_CORE_01");

        // [start..end]: start부터 end 직전까지
        let command_only = &system_command[0..6];      // "REBOOT"
        let space = &system_command[6..7];              // " "
        let target_only = &system_command[7..];         // "SYSTEM_CORE_01"

        println!("  원본: {}", system_command);
        println!("  [0..6]:  '{}'", command_only);
        println!("  [6..7]:  '{}'", space);
        println!("  [7..]:   '{}'", target_only);
        println!("  각 부분이 독립적인 뷰(View)처럼 작동합니다.\n");
    }

    // 시연 1-3: 슬라이스 범위의 유연성
    {
        println!("[시연 1-3] 슬라이스 범위의 유연성");
        let message = String::from("Hello World");

        println!("  원본: {}", message);
        println!("  [..5]:     '{}'  (처음 5글자)", &message[..5]);
        println!("  [6..]:     '{}'  (6번째부터 끝까지)", &message[6..]);
        println!("  [0..11]:   '{}'  (전체)", &message[0..11]);
        println!("  [..]:      '{}'  (전체 (생략형))", &message[..]);
        println!("  범위를 생략하면 자동으로 처음 또는 끝으로 확장됩니다.\n");
    }

    // ────────────────────────────────────────────────────────────────────────
    // [섹션 2] 배열 슬라이스: 숫자 배열의 일부
    // ────────────────────────────────────────────────────────────────────────
    println!("【섹션 2】배열 슬라이스: 숫자 배열의 일부");
    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n");

    // 시연 2-1: 배열 슬라이스 기초
    {
        println!("[시연 2-1] 배열 슬라이스 기초");
        let sensor_values = [10, 20, 30, 40, 50];

        println!("  원본 배열: {:?}", sensor_values);
        println!("  배열 길이: {}", sensor_values.len());

        // 배열 전체를 슬라이스로
        let all_values: &[i32] = &sensor_values[..];
        println!("  [..]:      {:?}", all_values);

        println!("  타입: &[i32] (슬라이스는 배열 요소의 참조)\n");
    }

    // 시연 2-2: 배열의 일부만 추출
    {
        println!("[시연 2-2] 배열의 일부만 추출");
        let sensor_values = [10, 20, 30, 40, 50];

        let first_three = &sensor_values[0..3];    // [10, 20, 30]
        let last_two = &sensor_values[3..5];       // [40, 50]
        let middle = &sensor_values[1..4];         // [20, 30, 40]

        println!("  원본:         {:?}", sensor_values);
        println!("  [0..3]:       {:?}  (처음 3개)", first_three);
