    // ────────────────────────────────────────────────────────────────────────
    println!("【섹션 3】Fat Pointer: 포인터와 길이의 조합");
    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n");

    // 시연 3-1: Fat Pointer의 구조
    {
        println!("[시연 3-1] Fat Pointer의 구조");
        let data = String::from("Rust Language");
        let slice = &data[0..4];  // "Rust"

        println!("  원본 문자열: {}", data);
        println!("  슬라이스: {}", slice);

        println!("\n  【내부 구조】");
        println!("  일반 포인터 (*const T):");
        println!("    크기: 8바이트 (주소만)");
        println!();
        println!("  Fat Pointer (&str 또는 &[T]):");
        println!("    크기: 16바이트 (주소 8 + 길이 8)");
        println!("    ┌─────────────────────┐");
        println!("    │ 주소: 0x12345678    │  ← 문자열의 시작 위치");
        println!("    │ 길이: 4             │  ← 몇 개 요소인가?");
        println!("    └─────────────────────┘");
        println!();
    }

    // 시연 3-2: 슬라이스 정보 추출
    {
        println!("[시연 3-2] 슬라이스 정보 추출");
        let text = String::from("Learning");
        let slice = &text[0..8];

        println!("  텍스트: {}", text);
        println!("  슬라이스: {}", slice);
        println!("  길이: {}", slice.len());
        println!("  is_empty: {}", slice.is_empty());
        println!("  첫 글자: {}", slice.chars().next().unwrap());
        println!("  마지막 글자: {}", slice.chars().last().unwrap());
        println!();
    }

    // 시연 3-3: 배열 슬라이스의 Fat Pointer
    {
        println!("[시연 3-3] 배열 슬라이스의 Fat Pointer");
        let array = [1, 2, 3, 4, 5];
        let slice = &array[1..4];

        println!("  배열: {:?}", array);
        println!("  슬라이스 [1..4]: {:?}", slice);
        println!("  슬라이스 길이: {}", slice.len());
        println!("  각 요소에 접근:");
        for (i, &val) in slice.iter().enumerate() {
            println!("    [{}] = {}", i, val);
        }
        println!();
    }

    // ────────────────────────────────────────────────────────────────────────
    // [섹션 4] 범위 안전성: 유효하지 않은 범위 차단
