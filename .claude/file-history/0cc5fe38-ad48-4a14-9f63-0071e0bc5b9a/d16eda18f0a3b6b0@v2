    // 시연 4-1: 유효한 범위와 무효한 범위
    {
        println!("[시연 4-1] 유효한 범위와 무효한 범위");
        let safe_string = String::from("Safe");

        // 유효한 범위들
        let valid1 = &safe_string[0..4];    // "Safe" (전체)
        let valid2 = &safe_string[0..2];    // "Sa"
        let valid3 = &safe_string[2..4];    // "fe"

        println!("  원본: {}", safe_string);
        println!("  유효한 범위:");
        println!("    [0..4]: '{}'", valid1);
        println!("    [0..2]: '{}'", valid2);
        println!("    [2..4]: '{}'", valid3);
        println!();

        // 무효한 범위 (컴파일 에러 또는 런타임 패닉)
        println!("  무효한 범위 (컴파일러가 차단하거나 런타임 패닉 발생):");
        println!("    [0..10]:  범위 초과 ❌");
        println!("    [5..8]:   시작점 초과 ❌");
        println!("    [3..2]:   범위 역순 ❌");
        println!("    [0..5]:   UTF-8 경계 위반 ❌");
        println!("  이러한 경우는 런타임에 panic을 발생시킵니다.\n");
    }

    // 시연 4-2: 범위 검증의 중요성
    {
        println!("[시연 4-2] 범위 검증의 중요성");
        let text = String::from("Network");
        let len = text.len();

        println!("  문자열: {}", text);
        println!("  길이: {}", len);
        println!();
        println!("  범위 검증 (안전한 방식):");
        println!("    len = {}", len);

        for end in 0..=len {
            let slice = &text[0..end];
            println!("    [0..{}]: '{}'", end, slice);
        }
        println!();
    }

    // 시연 4-3: 슬라이스 유효성 자동 검증
    {
        println!("[시연 4-3] 슬라이스 유효성 자동 검증");
        let data = [10, 20, 30, 40, 50];

        println!("  배열: {:?}", data);
        println!("  길이: {}", data.len());
        println!("  슬라이스 생성:");

        // 유효한 범위
        for start in 0..=data.len() {
            for end in start..=data.len() {
                let slice = &data[start..end];
                println!("    [{}..{}]: {:?}", start, end, slice);
            }
        }
        println!();
    }

    // ────────────────────────────────────────────────────────────────────────
    // [섹션 5] 함수 매개변수 설계: 슬라이스의 유연성
    // ────────────────────────────────────────────────────────────────────────
    println!("【섹션 5】함수 매개변수 설계: 슬라이스의 유연성");
    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n");

    // 시연 5-1: String vs &str 매개변수
    {
        println!("[시연 5-1] String vs &str 매개변수");

        fn process_string_full(s: String) {
            println!("  (String 받음) 처리: {}", s);
        }

        fn process_string_slice(s: &str) {
            println!("  (&str 받음) 처리: {}", s);
        }

        let my_string = String::from("Hello");
        let my_literal = "World";

        println!("  String 버전 (&str은 불가):");
        process_string_full(my_string.clone());
        // process_string_full(my_literal);  // ❌ 타입 불일치

        println!("\n  &str 버전 (String과 리터럴 모두 가능):");
        process_string_slice(&my_string);
        process_string_slice(my_literal);
        println!();
    }

    // 시연 5-2: 배열 슬라이스 매개변수
    {
        println!("[시연 5-2] 배열 슬라이스 매개변수");

        fn analyze_array(data: &[i32]) {
            println!("    데이터: {:?}, 길이: {}, 합: {}",
                data,
                data.len(),
                data.iter().sum::<i32>());
        }

        let array = [1, 2, 3, 4, 5];
        let vec = vec![10, 20, 30];
        let partial = &array[1..4];

        println!("  배열 전체:");
        analyze_array(&array);

        println!("  Vec 전체:");
        analyze_array(&vec);

        println!("  배열 일부:");
        analyze_array(partial);
        println!();
    }

    // 시연 5-3: 유연한 API 설계
    {
        println!("[시연 5-3] 유연한 API 설계");

        fn find_in_slice(haystack: &str, needle: char) -> Option<usize> {
            for (i, c) in haystack.chars().enumerate() {
                if c == needle {
                    return Some(i);
                }
            }
            None
        }

        let full_string = String::from("Programming");
        let literal = "Design";
        let partial = &"Architecture"[0..7];  // "Archite"

        println!("  전체 String에서 'P' 찾기: {:?}",
            find_in_slice(&full_string, 'P'));
        println!("  리터럴에서 'e' 찾기: {:?}",
            find_in_slice(literal, 'e'));
        println!("  부분 슬라이스에서 'c' 찾기: {:?}",
            find_in_slice(partial, 'c'));
        println!();
    }

    // ────────────────────────────────────────────────────────────────────────
    // [섹션 6] 슬라이스와 소유권 동기화: 빌림 규칙의 확장
    // ────────────────────────────────────────────────────────────────────────
    println!("【섹션 6】슬라이스와 소유권 동기화: 빌림 규칙의 확장");
    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n");

