// ============================================================================
// gogs-lang-control-flow: 제어 흐름 라이브러리
// ============================================================================
// if/else 조건문과 while 반복문을 지원하는 평가기입니다.

pub mod ast;
pub mod environment;
pub mod evaluator;

pub use ast::{Block, Expression, Program, Statement};
pub use environment::Environment;
pub use evaluator::{Evaluator, GogsObject};

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_basic_if() {
        let mut env = Environment::global();
        let program = Program::new(vec![
            Statement::let_statement(
                "x".to_string(),
                Expression::IntegerLiteral(5),
            ),
            Statement::expression(Expression::If {
                condition: Box::new(Expression::Infix(
                    ">".to_string(),
                    Box::new(Expression::Identifier("x".to_string())),
                    Box::new(Expression::IntegerLiteral(3)),
                )),
                consequence: Block::new(vec![Statement::expression(
                    Expression::IntegerLiteral(100),
                )]),
                alternative: Some(Block::new(vec![Statement::expression(
                    Expression::IntegerLiteral(0),
                )])),
            }),
        ]);

        let result = Evaluator::eval_program(&program, &mut env);
        assert_eq!(result, GogsObject::Integer(100));
    }

    #[test]
    fn test_basic_while() {
        let mut env = Environment::global();

        // 조건이 거짓이므로 루프 본체가 실행되지 않음
        let program = Program::new(vec![
            Statement::expression(Expression::While {
                condition: Box::new(Expression::BooleanLiteral(false)),
                body: Block::new(vec![Statement::expression(Expression::IntegerLiteral(1))]),
            }),
        ]);

        let result = Evaluator::eval_program(&program, &mut env);
        // 루프가 실행되지 않으므로 null 반환
        assert_eq!(result, GogsObject::Null);
    }
}
