// ============================================================================
// AST (Abstract Syntax Tree) 정의: 평가기가 처리할 구문 구조
// ============================================================================
// Parser가 생성한 트리 구조를 Evaluator가 순회하며 평가합니다.

use std::collections::HashMap;

/// 문장 (Statement): 독립적으로 실행되는 단위
#[derive(Debug, Clone, PartialEq)]
pub enum Statement {
    /// Let 바인딩: let x = 5;
    Let {
        name: String,
        value: Expression,
    },
    /// 표현식 문장: 5 + 10;
    Expression(Expression),
    /// Return 문: return 10;
    Return(Expression),
    /// 블록: { ... }
    Block(Vec<Statement>),
}

/// 표현식 (Expression): 값을 반환하는 단위
#[derive(Debug, Clone, PartialEq)]
pub enum Expression {
    /// 정수 리터럴: 42, 0, -100
    IntegerLiteral(i64),

    /// 불리언 리터럴: true, false
    BooleanLiteral(bool),

    /// 문자열 리터럴: "hello"
    StringLiteral(String),

    /// 식별자: x, foo, myVar
    Identifier(String),

    /// 단항 연산: -5, !true
    Prefix {
        operator: PrefixOp,
        operand: Box<Expression>,
    },

    /// 이항 연산: 5 + 10, x > y
    Infix {
        left: Box<Expression>,
        operator: InfixOp,
        right: Box<Expression>,
    },

    /// 조건식: if x > 5 { ... } else { ... }
    If {
        condition: Box<Expression>,
        consequence: Box<Statement>,
        alternative: Option<Box<Statement>>,
    },

    /// 함수 리터럴: fn(x, y) { x + y }
    FunctionLiteral {
        parameters: Vec<String>,
        body: Box<Statement>,
    },

    /// 함수 호출: add(1, 2)
    Call {
        function: Box<Expression>,
        arguments: Vec<Expression>,
    },

    /// 배열 리터럴: [1, 2, 3, 4, 5]
    ArrayLiteral(Vec<Expression>),

    /// 배열 인덱싱: arr[0]
    Index {
        left: Box<Expression>,
        index: Box<Expression>,
    },

    /// 해시 맵 리터럴: {"name": "Alice", "age": 30}
    HashLiteral(HashMap<String, Expression>),

    /// Null: null
    Null,
}

/// 단항 연산자
#[derive(Debug, Clone, PartialEq)]
pub enum PrefixOp {
    /// 논리 부정: !
    Bang,
    /// 음수: -
    Minus,
}

/// 이항 연산자
#[derive(Debug, Clone, PartialEq)]
pub enum InfixOp {
    /// 산술: +, -, *, /
    Plus,
    Minus,
    Asterisk,
    Slash,
    Modulo,

    /// 비교: <, >, <=, >=, ==, !=
    Less,
    Greater,
    LessEqual,
    GreaterEqual,
    Equal,
    NotEqual,

    /// 논리: &&, ||
    And,
    Or,
}

impl std::fmt::Display for InfixOp {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            InfixOp::Plus => write!(f, "+"),
            InfixOp::Minus => write!(f, "-"),
            InfixOp::Asterisk => write!(f, "*"),
            InfixOp::Slash => write!(f, "/"),
            InfixOp::Modulo => write!(f, "%"),
            InfixOp::Less => write!(f, "<"),
            InfixOp::Greater => write!(f, ">"),
            InfixOp::LessEqual => write!(f, "<="),
            InfixOp::GreaterEqual => write!(f, ">="),
            InfixOp::Equal => write!(f, "=="),
            InfixOp::NotEqual => write!(f, "!="),
            InfixOp::And => write!(f, "&&"),
            InfixOp::Or => write!(f, "||"),
        }
    }
}

impl std::fmt::Display for PrefixOp {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            PrefixOp::Bang => write!(f, "!"),
            PrefixOp::Minus => write!(f, "-"),
        }
    }
}

/// 프로그램: 여러 문장의 집합
pub struct Program {
    pub statements: Vec<Statement>,
}

impl Program {
    pub fn new(statements: Vec<Statement>) -> Self {
        Program { statements }
    }
}
