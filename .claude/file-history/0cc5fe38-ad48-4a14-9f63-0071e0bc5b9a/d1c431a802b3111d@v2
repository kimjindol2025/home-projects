// ============================================================================
// 객체 시스템: 런타임 값의 표현
// ============================================================================
// 평가기가 생성하고 조작하는 모든 런타임 값을 이 enum으로 표현합니다.

use std::rc::Rc;
use std::cell::RefCell;
use crate::ast::Statement;

/// 런타임 값의 기본 타입
#[derive(Debug, Clone)]
pub enum GogsObject {
    /// 정수 타입: 42, -100, 0
    Integer(i64),

    /// 불리언 타입: true, false
    Boolean(bool),

    /// 문자열 타입: "hello", "world"
    String(String),

    /// Null 타입: 아무 값도 없음
    Null,

    /// 배열 타입: [1, 2, 3, 4, 5]
    Array(Vec<GogsObject>),

    /// 해시 맵 타입: {"name": "Alice", "age": 30}
    HashMap(Rc<RefCell<std::collections::HashMap<String, GogsObject>>>),

    /// 함수 타입: fn(x, y) { x + y }
    Function {
        /// 함수의 매개변수 이름들
        parameters: Vec<String>,
        /// 함수의 본체 (Statement)
        body: Box<Statement>,
        /// 함수가 정의된 당시의 환경 (클로저)
        env: Rc<RefCell<crate::environment::Environment>>,
    },

    /// 반환값을 래핑: return 문의 결과를 특별 처리
    ReturnValue(Box<GogsObject>),

    /// 에러 메시지: 타입 불일치 등
    Error(String),
}

impl GogsObject {
    /// 객체를 불리언으로 평가 (truthy/falsy)
    pub fn is_truthy(&self) -> bool {
        match self {
            GogsObject::Null => false,
            GogsObject::Boolean(b) => *b,
            GogsObject::Integer(n) => *n != 0,
            _ => true,
        }
    }

    /// 객체의 타입 이름을 반환
    pub fn type_name(&self) -> &'static str {
        match self {
            GogsObject::Integer(_) => "INTEGER",
            GogsObject::Boolean(_) => "BOOLEAN",
            GogsObject::String(_) => "STRING",
            GogsObject::Null => "NULL",
            GogsObject::Array(_) => "ARRAY",
            GogsObject::HashMap(_) => "HASH",
            GogsObject::Function { .. } => "FUNCTION",
            GogsObject::ReturnValue(_) => "RETURN_VALUE",
            GogsObject::Error(_) => "ERROR",
        }
    }

    /// 에러인지 확인
    pub fn is_error(&self) -> bool {
        matches!(self, GogsObject::Error(_))
    }

    /// 반환값을 언래핑
    pub fn unwrap_return_value(&self) -> Self {
        match self {
            GogsObject::ReturnValue(obj) => (**obj).clone(),
            obj => obj.clone(),
        }
    }
}

impl PartialEq for GogsObject {
    fn eq(&self, other: &Self) -> bool {
        match (self, other) {
            (GogsObject::Integer(a), GogsObject::Integer(b)) => a == b,
            (GogsObject::Boolean(a), GogsObject::Boolean(b)) => a == b,
            (GogsObject::String(a), GogsObject::String(b)) => a == b,
            (GogsObject::Null, GogsObject::Null) => true,
            _ => false,
        }
    }
}

impl std::fmt::Display for GogsObject {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            GogsObject::Integer(n) => write!(f, "{}", n),
            GogsObject::Boolean(b) => write!(f, "{}", b),
            GogsObject::String(s) => write!(f, "{}", s),
            GogsObject::Null => write!(f, "null"),
            GogsObject::Array(arr) => {
                let elements: Vec<String> = arr.iter().map(|o| o.to_string()).collect();
                write!(f, "[{}]", elements.join(", "))
            }
            GogsObject::HashMap(_) => write!(f, "{{...}}"),
            GogsObject::Function { parameters, .. } => {
                write!(f, "fn({}) {{ ... }}", parameters.join(", "))
            }
            GogsObject::ReturnValue(obj) => write!(f, "{}", obj),
            GogsObject::Error(msg) => write!(f, "ERROR: {}", msg),
        }
    }
}

/// 진리값 상수
pub const TRUE: GogsObject = GogsObject::Boolean(true);
pub const FALSE: GogsObject = GogsObject::Boolean(false);
pub const NULL: GogsObject = GogsObject::Null;

/// 정수를 객체로 변환하는 헬퍼
pub fn make_integer(value: i64) -> GogsObject {
    GogsObject::Integer(value)
}

/// 불리언을 객체로 변환하는 헬퍼
pub fn make_boolean(value: bool) -> GogsObject {
    GogsObject::Boolean(value)
}

/// 문자열을 객체로 변환하는 헬퍼
pub fn make_string(value: String) -> GogsObject {
    GogsObject::String(value)
}

/// 에러를 생성하는 헬퍼
pub fn make_error(msg: String) -> GogsObject {
    GogsObject::Error(msg)
}
