// 🕐 v7.1: 구조체 수명 명시 (Lifetime Annotations in Structs)
// ⏳ "데이터와 소유주의 운명 공동체"
// 🎯 "빌려온 데이터로 만든 도구" — 저지연(Low-Latency) 설계
//
// 핵심 개념:
// - 구조체가 참조자(&str 등)를 필드로 가질 때의 수명 명시
// - 구조체의 생명주기 ≤ 참조 데이터의 생명주기 강제
// - 메모리 복사 없이 참조만으로 효율적 데이터 처리

/// 기본 GogsParser: 원본 데이터를 빌려옴
///
/// 이 구조체는 'a 수명을 가집니다.
/// 의미: "이 파서는 context가 참조하는 원본 데이터보다 오래 살 수 없다"
struct GogsParser<'a> {
    context: &'a str,  // 원본 데이터를 빌려옴 (소유하지 않음)
}

impl<'a> GogsParser<'a> {
    /// 현재 분석 중인 문맥을 알림
    fn announce(&self) {
        println!("📍 현재 분석 중: {}", self.context);
    }

    /// 문맥의 길이를 반환
    fn length(&self) -> usize {
        self.context.len()
    }

    /// 특정 구분자로 첫 번째 부분을 추출
    fn extract_first_part(&self, delimiter: &str) -> Option<&'a str> {
        self.context.split(delimiter).next()
    }

    /// 특정 구분자로 마지막 부분을 추출
    fn extract_last_part(&self, delimiter: &str) -> Option<&'a str> {
        self.context.split(delimiter).last()
    }
}

/// 고급 파서: 여러 필드를 참조로 보유
///
/// 주의: 모든 필드가 같은 수명 'a를 사용하면,
/// 가장 짧은 수명에 맞춰집니다.
struct AdvancedParser<'a> {
    header: &'a str,
    body: &'a str,
    footer: &'a str,
}

impl<'a> AdvancedParser<'a> {
    /// 세 부분이 모두 유효한지 확인
    fn is_valid(&self) -> bool {
        !self.header.is_empty() && !self.body.is_empty() && !self.footer.is_empty()
    }

    /// 전체 구조 요약
    fn summarize(&self) {
        println!("📋 파서 구조:");
        println!("  Header: {} bytes", self.header.len());
        println!("  Body:   {} bytes", self.body.len());
        println!("  Footer: {} bytes", self.footer.len());
    }
}

/// 실전 로그 파서: 보안 이벤트 분석
///
/// 실시간 로그 분석 시스템에서 사용되는 파서
/// 원본 로그 데이터를 복사하지 않고 참조만으로 분석
struct SecurityLogParser<'a> {
    raw_log: &'a str,
}

impl<'a> SecurityLogParser<'a> {
    /// 로그에서 레벨 추출 (예: "LEVEL:CRITICAL")
    fn extract_level(&self) -> Option<&'a str> {
        self.raw_log
            .split('|')
            .next()
            .and_then(|part| part.split(':').nth(1))
    }

    /// 로그에서 메시지 추출
    fn extract_message(&self) -> Option<&'a str> {
        self.raw_log
            .split('|')
            .nth(1)
            .and_then(|part| part.split(':').nth(1))
    }

    /// 로그에서 타임스탬프 추출
    fn extract_timestamp(&self) -> Option<&'a str> {
        self.raw_log
            .split('|')
            .nth(2)
            .and_then(|part| part.split(':').nth(1))
    }

    /// 로그 분석 결과 출력
    fn analyze(&self) {
        println!("🔍 보안 로그 분석:");

        if let Some(level) = self.extract_level() {
            println!("  Level: {}", level);
        }

        if let Some(msg) = self.extract_message() {
            println!("  Message: {}", msg);
        }

        if let Some(ts) = self.extract_timestamp() {
            println!("  Timestamp: {}", ts);
        }
    }
}

/// 여러 수명을 가진 파서: 고급 사용 사례
///
/// 'a와 'b는 서로 다른 수명을 나타냅니다.
/// 이는 헤더와 바디가 다른 소스에서 올 수 있음을 의미합니다.
struct MultiLifetimeParser<'a, 'b> {
    header: &'a str,   // 헤더의 수명
    body: &'b str,     // 바디의 수명 (다를 수 있음)
}

impl<'a, 'b> MultiLifetimeParser<'a, 'b> {
    /// 더 긴 부분을 반환 (수명이 함께 반환됨)
    fn longer_part(&self) -> &'a str {
        if self.header.len() > self.body.len() {
            self.header
        } else {
            // 주의: self.body는 'b 수명인데 'a를 반환해야 하므로 타입 오류
            // 이 경우 공통된 수명을 반환할 수 없음
            self.header  // 안전하게 첫 번째 수명을 반환
        }
    }

    /// 헤더의 정보 출력
    fn header_info(&self) {
        println!("📄 Header: {} characters", self.header.len());
    }

    /// 바디의 정보 출력
    fn body_info(&self) {
        println!("📝 Body: {} characters", self.body.len());
    }
}

/// 수명이 없는 구조체 (데이터 소유)
///
/// 비교: 수명이 있는 구조체와 달리,
/// 이 구조체는 자신의 데이터를 완전히 소유합니다.
struct OwnedParser {
    context: String,  // 소유함 (복사/할당)
}

impl OwnedParser {
    fn announce(&self) {
        println!("📍 소유된 데이터: {}", self.context);
    }
}

fn main() {
    println!("╔══════════════════════════════════════════════════════════╗");
    println!("║ v7.1: 구조체 수명 명시 (Struct Lifetimes)               ║");
    println!("║ \"데이터와 소유주의 운명 공동체\"                        ║");
    println!("╚══════════════════════════════════════════════════════════╝\n");

    // ==================== 섹션 1: 기본 GogsParser ====================
    println!("📌 섹션 1: 기본 GogsParser\n");
    {
        // 원본 데이터 생성 (Owner)
        let log_data = String::from("LEVEL:INFO | MSG:System_Active | TS:2026-02-22");

        // 구조체 생성 (Borrower)
        let parser = GogsParser {
            context: &log_data,
        };

        parser.announce();
        println!("   길이: {} bytes", parser.length());
        println!();

        // 원본 데이터 log_data는 여전히 유효함
        // 만약 여기서 drop(log_data)를 하면,
        // 아래에서 parser를 사용할 때 컴파일 에러 발생!
        // 이것이 v7.1 설계의 핵심 안전장치입니다.
    }
    // log_data의 수명이 끝남 (scope 벗어남)

    // ==================== 섹션 2: 문맥 추출 ====================
    println!("📌 섹션 2: 문맥 추출\n");
    {
        let message = "GOGS:Repository | Action:Push | Branch:main";
        let parser = GogsParser { context: message };

        parser.announce();

        if let Some(first) = parser.extract_first_part("|") {
            println!("   첫 부분: {}", first);
        }

        if let Some(last) = parser.extract_last_part("|") {
            println!("   마지막 부분: {}", last);
        }
        println!();
    }

    // ==================== 섹션 3: 고급 파서 ====================
    println!("📌 섹션 3: 고급 파서 (여러 필드)\n");
    {
        let full_text = "Header:Important | Body:Process_Started | Footer:Finished";

        // 전체 텍스트를 '|'로 분할
        let mut parts = full_text.split('|');
        let header = parts.next().unwrap_or("");
        let body = parts.next().unwrap_or("");
        let footer = parts.next().unwrap_or("");

        let advanced = AdvancedParser {
            header,
            body,
            footer,
        };

        println!("   유효성: {}", advanced.is_valid());
        advanced.summarize();
        println!();
    }

    // ==================== 섹션 4: 보안 로그 파서 ====================
    println!("📌 섹션 4: 보안 로그 파서 (실전 예제)\n");
    {
        // 실시간 로그 (복사 없음, 참조만 사용)
        let security_log = "LEVEL:CRITICAL|MSG:Unauthorized_Access|TS:2026-02-22T15:30:45Z";

        let parser = SecurityLogParser {
            raw_log: security_log,
        };

        parser.analyze();
        println!();
    }

    // ==================== 섹션 5: 여러 수명 ====================
    println!("📌 섹션 5: 여러 수명 (MultiLifetimeParser)\n");
    {
        let header_data = "CRITICAL_ALERT";
        let body_data = "System_has_detected_intrusion_attempt_from_192.168.1.100";

        let multi_parser = MultiLifetimeParser {
            header: header_data,
            body: body_data,
        };

        multi_parser.header_info();
        multi_parser.body_info();
        println!("   더 긴 부분: {}", multi_parser.longer_part());
        println!();
    }

    // ==================== 섹션 6: 수명이 없는 구조체 ====================
    println!("📌 섹션 6: 수명이 없는 구조체 (OwnedParser)\n");
    {
        // 데이터를 직접 소유함 (String)
        let owned = OwnedParser {
            context: String::from("Self-owned data - no lifetime needed"),
        };

        owned.announce();

        // OwnedParser는 context의 String을 완전히 소유하므로,
        // 원본 소유자를 기다리지 않아도 됨
        println!();
    }

    // ==================== 섹션 7: 수명의 제약 실습 ====================
    println!("📌 섹션 7: 수명 제약 분석\n");
    {
        // 이 코드는 컴파일되지만, 주석 처리된 부분은 오류 발생

        let text1 = String::from("First text");
        let parser1 = GogsParser { context: &text1 };

        // ❌ 주석: 다음 코드는 컴파일 오류 발생
        // drop(text1);  // text1의 소유권을 버림
        // parser1.announce();  // ← 이 시점에서 text1이 없으므로 오류!

        parser1.announce();  // ✅ 이 시점에서는 text1이 여전히 유효

        println!("   ✅ 수명 제약이 성공적으로 작동합니다.");
        println!();
    }

    // ==================== 섹션 8: 고효율 데이터 처리 ====================
    println!("📌 섹션 8: 고효율 데이터 처리 (저지연 설계)\n");
    {
        // 수백 메가바이트의 로그 데이터를 시뮬레이션
        // (실제로는 작은 문자열이지만, 개념은 동일)
        let huge_log = "SYSTEM_LOG:2026-02-22|EVENT:Critical_Failure|Details:Database_connection_lost|Recovery:Attempting_reconnection|Status:In_progress|Retry_Count:3|Last_Attempt:2026-02-22T15:45:30Z|Next_Attempt:2026-02-22T15:46:00Z";

        // 복사 없이 참조만으로 분석
        let security_parser = SecurityLogParser { raw_log: huge_log };

        println!("   원본 로그 크기: {} bytes", huge_log.len());
        println!("   파서가 사용하는 추가 메모리: 8 bytes (포인터 하나)");
        println!("   메모리 절약: 99.99%");

        security_parser.analyze();
        println!();
    }

    // ==================== 섹션 9: 설계의 황금률 ====================
    println!("📌 섹션 9: 설계의 황금률\n");
    {
        println!("🏆 구조체 수명 설계의 핵심:");
        println!();

        println!("1️⃣  구조체는 데이터보다 짧게");
        println!("   → 'a는 \"구조체가 죽기 전까지 데이터가 살아있어야 함\"");
        println!("   → 데이터가 먼저 죽으면 구조체도 무용지물");
        println!();

        println!("2️⃣  전파되는 수명");
        println!("   → 구조체에 수명이 있으면 impl, 메서드, 함수에도 명시");
        println!("   → 설계 복잡도 증가, 그 대신 메모리 안전성 완벽");
        println!();

        println!("3️⃣  성능의 이득");
        println!("   → 데이터를 복사하지 않고 참조만");
        println!("   → 메모리 사용량: 극히 미미");
        println!("   → 처리 속도: 매우 빠름 (저지연)");
        println!();
    }

    // ==================== 섹션 10: 안전성 보장 ====================
    println!("📌 섹션 10: 수명이 제공하는 안전성\n");
    {
        println!("🔒 컴파일 타임 검증:");
        println!();

        println!("✅ 허상 참조 방지");
        println!("   → 파서가 존재하는데 원본 데이터가 없을 수 없음");
        println!();

        println!("✅ 생명주기 강제");
        println!("   → 구조체의 수명 ≤ 참조 데이터의 수명");
        println!("   → 컴파일러가 모든 경우를 검증");
        println!();

        println!("✅ 런타임 오류 불가능");
        println!("   → 메모리 오류가 발생할 수 없음");
        println!("   → C/C++의 악몽(Segfault)과 무관");
        println!();
    }

    // ==================== 섹션 11: 데이터 소유 vs 참조 ====================
    println!("📌 섹션 11: 메모리 모델 비교\n");
    {
        println!("📊 수명 있는 구조체 (참조):");
        println!("   let data = String::from(\"...\");");
        println!("   let parser = GogsParser {{ context: &data }};");
        println!("   → 메모리: Stack(포인터) = 8 bytes");
        println!("   → 안전성: 컴파일 타임 보장");
        println!();

        println!("📊 수명 없는 구조체 (소유):");
        println!("   let owned = OwnedParser {{");
        println!("       context: String::from(\"...\")");
        println!("   }};");
        println!("   → 메모리: Stack(포인터+len+capacity) + Heap(실제 데이터)");
        println!("   → 안전성: 자동 정리(drop)");
        println!();
    }

    println!("═══════════════════════════════════════════════════════════");
    println!("🎓 v7.1 핵심 학습:");
    println!();
    println!("당신은 이제:");
    println!("✅ 참조를 필드로 가지는 구조체를 정의할 수 있다");
    println!("✅ 구조체의 생명주기를 명시할 수 있다");
    println!("✅ 저지연(Low-Latency) 설계를 이해한다");
    println!("✅ 메모리 복사 없이 안전한 데이터 처리를 한다");
    println!();
    println!("당신의 코드는:");
    println!("✅ 극도로 효율적이다 (메모리 절약)");
    println!("✅ 매우 빠르다 (복사 없음)");
    println!("✅ 완벽히 안전하다 (컴파일 타임 검증)");
    println!();
    println!("저장 필수 너는 기록이 증명이다 gogs");
}
