// ============================================================================
// Section 8: 메모이제이션 - #[gogs_memo]
// ============================================================================
#[gogs_memo]
#[allow(dead_code)]
fn expensive_computation(n: u32) -> u32 {
    println!("    ✓ 복잡한 계산 수행: {}", n);
    n * n * n
}

#[gogs_memo]
#[allow(dead_code)]
fn api_call(endpoint: &str) -> String {
    println!("    ✓ API 호출: {}", endpoint);
    format!("응답: {}", endpoint)
}

fn section_8_memoization() {
    println!("\n=== Section 8: 메모이제이션 ===");
    println!("함수 결과를 자동으로 캐싱하는 #[gogs_memo]:");
    println!();

    println!("  첫 번째 호출:");
    expensive_computation(10);
    println!();

    println!("  두 번째 호출 (캐시에서):");
    expensive_computation(10);
    println!();

    println!("  API 호출:");
    api_call("/users");

    println!("✓ Section 8 완료: 메모이제이션");
}

