// ============================================================================
// Section 6: 상태 머신 설계 - gogs_state_machine!
// ============================================================================
fn section_6_state_machine() {
    println!("\n=== Section 6: 상태 머신 설계 ===");
    println!("gogs_state_machine! 매크로가 상태 전이를 검증:");
    println!();

    println!("  설계: 프로세스 상태 머신");
    gogs_state_machine! {
        Idle -> Running,
        Running -> [Paused, Stopped],
        Paused -> Running,
        Stopped -> Idle
    }
    println!();

    println!("  설계: 네트워크 연결 상태");
    gogs_state_machine! {
        Disconnected -> Connecting,
        Connecting -> Connected,
        Connected -> [Idle, Error],
        Error -> Disconnected
    }
    println!();

    println!("✓ Section 6 완료: 상태 머신");
}

