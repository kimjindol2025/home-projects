## 📊 실전 예제: 안전한 데이터 추출

```rust
#[derive(Debug)]
struct User {
    id: u32,
    name: String,
    age: u32,
}

// 데이터베이스 시뮬레이션
fn query_user(id: u32) -> Option<User> {
    let users = vec![
        User { id: 1, name: String::from("Alice"), age: 25 },
        User { id: 2, name: String::from("Bob"), age: 30 },
    ];
    users.into_iter().find(|u| u.id == id)
}

// 검증 함수
fn validate_user(user: &User) -> Result<(), String> {
    if user.age < 18 {
        Err(String::from("미성년자입니다"))
    } else {
        Ok(())
    }
}

// 종합 처리
fn safe_get_user(id: u32) -> Result<User, String> {
    let user = query_user(id).ok_or(String::from("사용자 없음"))?;
    validate_user(&user)?;
    Ok(user)
}

// 사용
match safe_get_user(1) {
    Ok(user) => println!("사용자: {} (나이: {})", user.name, user.age),
    Err(e) => println!("오류: {}", e),
}
```

