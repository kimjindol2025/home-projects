fn section_1_integer_evaluation() {
    println!("가장 단순한 정수를 평가:");
    println!();

    let program = Program::new(vec![
        Statement::Expression(Expression::IntegerLiteral(42)),
    ]);

    println!("  입력: 42");
    println!("  평가: IntegerLiteral(42) → Integer(42)");
    let result = eval(program);
    println!("  결과: {}", result);
    println!("✓ Section 1 완료: 정수 평가");
}

fn section_2_boolean_evaluation() {
    println!("불리언 값 평가:");
    println!();

    let program_true = Program::new(vec![
        Statement::Expression(Expression::BooleanLiteral(true)),
    ]);

    let program_false = Program::new(vec![
        Statement::Expression(Expression::BooleanLiteral(false)),
    ]);

    println!("  경우 1: true");
    let result_true = eval(program_true);
    println!("    결과: {}", result_true);
    println!();

    println!("  경우 2: false");
    let result_false = eval(program_false);
    println!("    결과: {}", result_false);
    println!();

    println!("  진리값 판정 (truthy/falsy):");
    println!("    true는 truthy, false는 falsy");
    println!("    null은 falsy, 0은 falsy, 다른 정수는 truthy");
    println!("✓ Section 2 완료: 불리언 평가");
}

fn section_3_prefix_operations() {
    println!("단항 연산 평가:");
    println!();

    let program_bang = Program::new(vec![
        Statement::Expression(Expression::Prefix {
            operator: PrefixOp::Bang,
            operand: Box::new(Expression::BooleanLiteral(true)),
        }),
    ]);

    println!("  경우 1: !true");
    let result = eval(program_bang);
    println!("    결과: {}", result);
    println!();

    let program_minus = Program::new(vec![
        Statement::Expression(Expression::Prefix {
            operator: PrefixOp::Minus,
            operand: Box::new(Expression::IntegerLiteral(5)),
        }),
    ]);

    println!("  경우 2: -5");
    let result = eval(program_minus);
    println!("    결과: {}", result);
    println!("✓ Section 3 완료: 단항 연산");
}

fn section_4_infix_arithmetic() {
    println!("산술 연산 평가:");
    println!();

    let program_add = Program::new(vec![
        Statement::Expression(Expression::Infix {
            left: Box::new(Expression::IntegerLiteral(5)),
            operator: InfixOp::Plus,
            right: Box::new(Expression::IntegerLiteral(10)),
        }),
    ]);

    println!("  5 + 10 = ");
    let result = eval(program_add);
    println!("    {}", result);
    println!();

    let program_mul = Program::new(vec![
        Statement::Expression(Expression::Infix {
            left: Box::new(Expression::IntegerLiteral(3)),
            operator: InfixOp::Asterisk,
            right: Box::new(Expression::IntegerLiteral(4)),
        }),
    ]);

    println!("  3 * 4 = ");
    let result = eval(program_mul);
    println!("    {}", result);
    println!("✓ Section 4 완료: 산술 연산");
}

