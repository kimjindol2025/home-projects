fn section_6_conditional_evaluation() {
    println!("조건식(if/else) 평가:");
    println!();

    let program = Program::new(vec![
        Statement::Expression(Expression::If {
            condition: Box::new(Expression::BooleanLiteral(true)),
            consequence: Box::new(Statement::Block(vec![
                Statement::Expression(Expression::IntegerLiteral(10)),
            ])),
            alternative: Some(Box::new(Statement::Block(vec![
                Statement::Expression(Expression::IntegerLiteral(20)),
            ]))),
        }),
    ]);

    println!("  if true {{ 10 }} else {{ 20 }}");
    let result = eval(program);
    println!("  결과: {}", result);
    println!("✓ Section 6 완료: 조건식 평가");
}

fn section_7_functions() {
    println!("함수 정의와 호출:");
    println!();

    let program = Program::new(vec![
        Statement::Let {
            name: "add_two".to_string(),
            value: Expression::FunctionLiteral {
                parameters: vec!["x".to_string()],
                body: Box::new(Statement::Block(vec![
                    Statement::Expression(Expression::Infix {
                        left: Box::new(Expression::Identifier("x".to_string())),
                        operator: InfixOp::Plus,
                        right: Box::new(Expression::IntegerLiteral(2)),
                    }),
                ])),
            },
        },
        Statement::Expression(Expression::Call {
            function: Box::new(Expression::Identifier("add_two".to_string())),
            arguments: vec![Expression::IntegerLiteral(5)],
        }),
    ]);

    println!("  정의: let add_two = fn(x) {{ x + 2 }}");
    println!("  호출: add_two(5)");
    println!();
    println!("  평가:");
    println!("    1. 함수 정의 저장");
    println!("    2. add_two(5) 호출");
    println!("    3. 새 환경에서 x = 5 바인딩");
    println!("    4. x + 2 평가 = 7");

    let result = eval(program);
    println!();
    println!("  결과: {}", result);
    println!("✓ Section 7 완료: 함수 정의 & 호출");
}

fn section_8_recursive_functions() {
    println!("재귀 함수 개념:");
    println!();

    println!("  재귀의 구조:");
    println!("    fn count(n) {{");
    println!("      if n <= 0 {{ return 0 }}");
    println!("      else {{ return n + count(n - 1) }}");
    println!("    }}");
    println!();

    println!("  호출: count(5)");
    println!();
    println!("  스택 추적:");
    println!("    count(5)");
    println!("      → 5 + count(4)");
    println!("        → 5 + 4 + count(3)");
    println!("          → 5 + 4 + 3 + count(2)");
    println!("            → 5 + 4 + 3 + 2 + count(1)");
    println!("              → 5 + 4 + 3 + 2 + 1 + count(0)");
    println!("                → 5 + 4 + 3 + 2 + 1 + 0 = 15");
    println!();

    let simple_program = Program::new(vec![
        Statement::Expression(Expression::IntegerLiteral(15)),
    ]);

    let result = eval(simple_program);
    println!("  결과: {}", result);
    println!();
    println!("  재귀의 핵심:");
    println!("    ✓ 기저 사례: n <= 0이면 0");
    println!("    ✓ 재귀 사례: n + f(n-1)");
    println!("    ✓ 스택: 각 호출이 환경을 쌓음");
    println!("    ✓ 되돌이: 기저 사례부터 역순 계산");
    println!("✓ Section 8 완료: 재귀 함수 개념");
}

fn section_9_variable_binding() {
    println!("변수 바인딩 (심볼 테이블):");
    println!();

    let program = Program::new(vec![
        Statement::Let {
            name: "x".to_string(),
            value: Expression::IntegerLiteral(5),
        },
        Statement::Let {
            name: "y".to_string(),
            value: Expression::IntegerLiteral(10),
        },
        Statement::Expression(Expression::Infix {
            left: Box::new(Expression::Identifier("x".to_string())),
            operator: InfixOp::Plus,
            right: Box::new(Expression::Identifier("y".to_string())),
        }),
    ]);

    println!("  프로그램:");
    println!("    let x = 5;");
    println!("    let y = 10;");
    println!("    x + y");
    println!();
    println!("  환경 변화:");
    println!("    1. let x = 5; → {{x: 5}}");
    println!("    2. let y = 10; → {{x: 5, y: 10}}");
    println!("    3. x + y:");
    println!("       - x 조회 → 5");
    println!("       - y 조회 → 10");
    println!("       - 5 + 10 = 15");

    let result = eval(program);
    println!();
    println!("  결과: {}", result);
    println!("✓ Section 9 완료: 변수 바인딩");
}

