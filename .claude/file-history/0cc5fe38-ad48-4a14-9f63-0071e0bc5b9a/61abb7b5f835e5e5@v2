### 2단계: 뉴타입 메서드

```rust
struct Distance(f64);

impl Distance {
    fn new(meters: f64) -> Self {
        Distance(meters)
    }

    fn meters(&self) -> f64 {
        self.0
    }

    fn kilometers(&self) -> f64 {
        self.0 / 1000.0
    }

    fn is_far(&self) -> bool {
        self.0 > 5000.0
    }
}

// 사용
let d = Distance::new(7500.0);
println!("거리: {}m = {:.2}km", d.meters(), d.kilometers());
println!("먼 거리? {}", d.is_far());  // true
