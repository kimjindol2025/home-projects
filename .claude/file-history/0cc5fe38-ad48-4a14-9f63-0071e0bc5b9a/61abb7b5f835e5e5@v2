### 패턴 2: 물리량 시스템

```rust
use std::ops::{Add, Div};

#[derive(Clone, Copy)]
struct Meter(f64);

#[derive(Clone, Copy)]
struct Second(f64);

#[derive(Clone, Copy)]
struct MeterPerSecond(f64);

impl Div<Second> for Meter {
    type Output = MeterPerSecond;

    fn div(self, time: Second) -> MeterPerSecond {
        MeterPerSecond(self.0 / time.0)
    }
}

// 사용
let distance = Meter(100.0);
let time = Second(10.0);
let speed = distance / time;
println!("속도: {:.1} m/s", speed.0);
```

### 패턴 3: 상태 추적

```rust
struct Count(u32);

impl Count {
    fn new() -> Self {
        Count(0)
    }

    fn increment(&mut self) {
        self.0 += 1;
    }

    fn value(&self) -> u32 {
        self.0
    }
}

type CountHistory = Vec<(u64, Count)>;

fn track_events() {
    let mut history: CountHistory = Vec::new();
    let mut count = Count::new();

    for i in 0..5 {
        count.increment();
        history.push((i as u64, count));
    }

    for (timestamp, cnt) in history {
        println!("시점: {}, 개수: {}", timestamp, cnt.value());
    }
}
```

### 패턴 4: 검증된 문자열

```rust
struct Email(String);

impl Email {
    fn new(email: &str) -> Result<Self, String> {
        if email.contains("@") && email.contains(".") {
            Ok(Email(email.to_string()))
        } else {
            Err("유효하지 않은 이메일 형식".to_string())
        }
    }

    fn domain(&self) -> Option<&str> {
        self.0.split("@").nth(1)
    }
}

struct PhoneNumber(String);

impl PhoneNumber {
    fn new(phone: &str) -> Result<Self, String> {
        let digits: String = phone.chars().filter(|c| c.is_numeric()).collect();
        if digits.len() >= 10 {
            Ok(PhoneNumber(phone.to_string()))
        } else {
            Err("유효하지 않은 전화번호".to_string())
        }
    }
}

// 사용
match Email::new("user@example.com") {
    Ok(email) => println!("도메인: {:?}", email.domain()),
    Err(e) => println!("오류: {}", e),
}
```

