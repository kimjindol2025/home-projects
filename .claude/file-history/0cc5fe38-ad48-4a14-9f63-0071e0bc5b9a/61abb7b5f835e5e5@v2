## 📦 Core Concepts

### 1. 뉴타입의 특징 (Newtype Characteristics)

```rust
// 튜플 구조체: 한 개 필드만 가짐
struct Celsius(f64);
struct Fahrenheit(f64);

// 특징 1: 새로운 타입 생성
let c = Celsius(37.0);
let f = Fahrenheit(98.6);
// let mixed = c + f;  ← 컴파일 불가능! 서로 다른 타입

// 특징 2: .0으로 내부 값 접근
println!("온도: {}°C", c.0);

// 특징 3: Zero-Cost (런타임 비용 없음)
// mem::size_of::<Celsius>() == mem::size_of::<f64>()

// 특징 4: impl로 메서드 추가 가능
impl Celsius {
    fn to_fahrenheit(&self) -> Fahrenheit {
        Fahrenheit(self.0 * 9.0 / 5.0 + 32.0)
    }
}

let f_converted = c.to_fahrenheit();
println!("화씨: {}°F", f_converted.0);
```

