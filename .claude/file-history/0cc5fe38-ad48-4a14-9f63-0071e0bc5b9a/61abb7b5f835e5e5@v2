### 4. 도메인 타입 설계 패턴 (Domain Type Pattern)

```rust
// 금융 도메인
struct Amount(f64);
struct Percentage(f64);

impl Amount {
    fn new(amount: f64) -> Result<Self, String> {
        if amount >= 0.0 {
            Ok(Amount(amount))
        } else {
            Err("금액은 음수가 될 수 없음".to_string())
        }
    }

    fn apply_discount(&self, discount: Percentage) -> Amount {
        Amount(self.0 * (1.0 - discount.0))
    }
}

impl Percentage {
    fn new(percent: f64) -> Result<Self, String> {
        if percent >= 0.0 && percent <= 1.0 {
            Ok(Percentage(percent))
        } else {
            Err("퍼센트는 0~1 사이여야 함".to_string())
        }
    }
}

// 사용
let price = Amount::new(100.0)?;
let discount = Percentage::new(0.2)?;  // 20%
let final_price = price.apply_discount(discount);
```

