## ⚠️ v3.7의 한계와 주의점

### 실수 1: 상태 전이 누락

```rust
// ❌ 모든 상태-명령 조합을 고려하지 않음
match (state, command) {
    (State::Idle, "START") => State::Running,
    (State::Running, "STOP") => State::Idle,
    // Error 상태에서의 처리를 빠뜨림!
}

// ✅ 모든 조합을 명시적으로 처리
match (state, command) {
    (State::Idle, "START") => State::Running,
    (State::Running, "STOP") => State::Idle,
    (State::Error(_), "RECOVER") => State::Idle,
    (_, _) => state, // 기본값
}
```

### 실수 2: 불가능한 상태 생성

```rust
// ❌ Running인데 power가 없음 (잘못된 상태)
if is_running && power == 0 {
    // 이런 상태는 존재하면 안 됨
}

// ✅ Running은 항상 power를 가짐
SystemState::Running(0) // power는 필수
```

### 실수 3: 상태 데이터 누락

```rust
// ❌ 상태를 변경하면서 데이터를 버림
current_state = SystemState::Idle;
// 이전의 power 정보가 사라짐

// ✅ 필요하면 데이터를 먼저 저장
if let SystemState::Running(power) = current_state {
    save_power(power);
    current_state = SystemState::Idle;
}
```

