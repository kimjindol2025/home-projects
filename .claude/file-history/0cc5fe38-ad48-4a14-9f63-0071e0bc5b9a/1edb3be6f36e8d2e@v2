// 1학년 1학기: 변수와 데이터 타입 마스터
// [저장 필수] 기록이 증명이다 gogs: 프로젝트 시작 로그

fn main() {
    println!("--- Gogs Project Level 1: Initialization ---");
    println!("📚 1학년 1학기: 러스트 시스템 프로그래밍의 기초\n");

    // ==========================================
    // [1.1] 불변 변수 (기본)
    // ==========================================
    let version: &str = "1.0.0";
    let student_name: &str = "Claude Code";

    println!("✅ 학생: {}", student_name);
    println!("✅ 프로젝트 버전: {}\n", version);

    // ==========================================
    // [1.2] 가변 변수 (mut 키워드 사용)
    // ==========================================
    let mut progress_level: i32 = 1;
    const MAX_LEVEL: i32 = 10;

    println!("📊 학습 진도 현황");
    println!("  현재 레벨: {}/{}", progress_level, MAX_LEVEL);

    // 레벨 업 시뮬레이션
    progress_level += 1;
    println!("  레벨 업 성공! 다음 목표 레벨: {}\n", progress_level);

    // ==========================================
    // [1.3] 실습 과제: study_hours 변수
    // ==========================================
    println!("📖 1학기 첫 번째 실습 과제: 학습 시간 추적");
    println!("─────────────────────────────────────────\n");

    let mut study_hours: u32 = 0;
    println!("시작: 학습 시간 = {} 시간", study_hours);

    // 1시간이 지나감
    study_hours += 1;
    println!("1시간 경과 후: {} 시간 ✓", study_hours);

    // 2시간이 지나감
    study_hours += 1;
    println!("2시간 경과 후: {} 시간 ✓", study_hours);

    // 3시간이 지나감
    study_hours += 1;
    println!("3시간 경과 후: {} 시간 ✓", study_hours);

    // 4시간이 지나감
    study_hours += 1;
    println!("4시간 경과 후: {} 시간 ✓", study_hours);

    // 5시간이 지나감
    study_hours += 1;
    println!("5시간 경과 후: {} 시간 ✓\n", study_hours);

    // ==========================================
    // [1.4] Gogs 코딩 표준 검증
    // ==========================================
    println!("🔍 Gogs 코딩 표준 검증");
    println!("─────────────────────────────────────────");
    println!("✅ Strict Typing: 모든 변수에 타입 명시");
    println!("   - version: &str");
    println!("   - progress_level: i32");
    println!("   - MAX_LEVEL: i32");
    println!("   - study_hours: u32");
    println!("");
    println!("✅ Naming Convention: snake_case & SCREAMING_SNAKE_CASE");
    println!("   - student_name (snake_case)");
    println!("   - progress_level (snake_case)");
    println!("   - MAX_LEVEL (SCREAMING_SNAKE_CASE)");
    println!("");
    println!("✅ Documentation: 함수 위에 /// 주석 작성");
    println!("   (다음 과제에서 구현)\n");

    // ==========================================
    // [1.5] 최종 결과 출력
    // ==========================================
    println!("═══════════════════════════════════════════");
    println!("🎓 1학년 1학기 첫 번째 실습 완료!");
    println!("═══════════════════════════════════════════");
    println!("총 학습 시간: {} 시간", study_hours);
    println!("현재 진도: Level {}/{}", progress_level, MAX_LEVEL);
    println!("");
    println!("저장 필수, 너는 기록이 증명이다 gogs 🔥");
    println!("═══════════════════════════════════════════\n");
}
