// ============================================================================
// 함수(Function): 일급 객체로서의 함수
// ============================================================================

use crate::environment::Environment;
use std::fmt;

/// 함수를 나타내는 일급 객체
pub struct GogsFunction {
    /// 함수의 매개변수 이름들
    pub parameters: Vec<String>,

    /// 함수의 본체 (클로저로 표현)
    /// 함수가 평가될 때 호출되는 로직
    pub body: Box<dyn Fn(&Environment, &[i64]) -> Result<i64, String> + Send + Sync>,

    /// 함수가 정의된 시점의 환경 (클로저의 핵심)
    pub closure_env: Environment,

    /// 함수의 이름 (디버깅용)
    pub name: String,
}

impl GogsFunction {
    /// 새로운 함수 생성
    pub fn new(
        parameters: Vec<String>,
        body: Box<dyn Fn(&Environment, &[i64]) -> Result<i64, String> + Send + Sync>,
    ) -> Self {
        GogsFunction {
            parameters,
            body,
            closure_env: Environment::global(),
            name: "anonymous".to_string(),
        }
    }

    /// 이름이 있는 함수 생성
    pub fn named(
        name: String,
        parameters: Vec<String>,
        body: Box<dyn Fn(&Environment, &[i64]) -> Result<i64, String> + Send + Sync>,
    ) -> Self {
        GogsFunction {
            parameters,
            body,
            closure_env: Environment::global(),
            name,
        }
    }

    /// 클로저 환경을 설정
    pub fn with_closure_env(mut self, env: Environment) -> Self {
        self.closure_env = env;
        self
    }

    /// 함수 평가 (실행)
    pub fn evaluate(&self, env: &Environment) -> Result<i64, String> {
        (self.body)(env, &[])
    }

    /// 함수 호출 (인자 포함)
    pub fn call(&self, args: &[i64]) -> Result<i64, String> {
        // 1. 함수의 클로저 환경을 부모로 하는 새로운 로컬 환경 생성
        let mut local_env = Environment::extend(&self.closure_env);

        // 2. 매개변수 검증
        if args.len() != self.parameters.len() {
            return Err(format!(
                "Function '{}' expects {} arguments, got {}",
                self.name,
                self.parameters.len(),
                args.len()
            ));
        }

        // 3. 인자를 매개변수에 바인딩
        for (param, arg) in self.parameters.iter().zip(args.iter()) {
            local_env.set(param.clone(), *arg);
        }

        // 4. 함수 본체 실행 (새로운 환경에서)
        (self.body)(&local_env, args)
    }

    /// 함수 시그니처 반환
    pub fn signature(&self) -> String {
        format!(
            "fn {}({})",
            self.name,
            self.parameters.join(", ")
        )
    }

    /// 함수 정보 출력
    pub fn info(&self) {
        println!("Function: {}", self.signature());
        println!("  Parameters: {:?}", self.parameters);
        println!("  Closure: {:?}", self.closure_env);
    }
}

impl fmt::Debug for GogsFunction {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        f.debug_struct("GogsFunction")
            .field("name", &self.name)
            .field("parameters", &self.parameters)
            .field("closure_env", &self.closure_env)
            .finish()
    }
}

impl fmt::Display for GogsFunction {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        write!(f, "{}", self.signature())
    }
}

/// 함수 특성 분석
pub struct FunctionAnalysis {
    pub is_pure: bool,           // 외부 상태를 건드리지 않음
    pub is_recursive: bool,      // 자기 자신을 호출
    pub arity: usize,            // 매개변수 개수
    pub is_closure: bool,        // 외부 변수 캡처
}

impl FunctionAnalysis {
    pub fn analyze(func: &GogsFunction) -> Self {
        FunctionAnalysis {
            is_pure: true,        // 단순히 가정 (실제로는 분석 필요)
            is_recursive: false,  // 단순히 가정
            arity: func.parameters.len(),
            is_closure: !func.closure_env.bindings.is_empty(),
        }
    }
}
