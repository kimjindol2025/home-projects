// 섹션 1: 데드락의 정의와 4가지 조건
// ============================================================================
fn section_1_deadlock_definition() {
    println!("\n📌 섹션 1: 데드락의 정의와 4가지 조건");
    println!("────────────────────────────────────────");

    println!("  데드락(Deadlock): 두 개 이상의 스레드가 서로의 자원을 기다리며 영구적으로 대기");

    println!("\n  🔴 데드락의 4가지 필요조건 (모두 만족해야 발생):");
    println!("    1️⃣ 상호 배제 (Mutual Exclusion)");
    println!("       - 자원은 한 번에 하나의 스레드만 사용 가능");
    println!("       - Mutex가 보장함");

    println!("\n    2️⃣ 점유와 대기 (Hold and Wait)");
    println!("       - 자원을 가진 스레드가 다른 자원을 기다림");
    println!("       - let _lock_a = mutex_a.lock().unwrap();");
    println!("         let _lock_b = mutex_b.lock().unwrap();  // ← 여기서 대기");

    println!("\n    3️⃣ 비선점 (No Preemption)");
    println!("       - 다른 스레드의 자원을 강제로 빼앗을 수 없음");
    println!("       - Rust의 lock()은 비선점");

    println!("\n    4️⃣ 순환 대기 (Circular Wait)");
    println!("       - 스레드들이 자원을 요청하는 순서가 순환함");
    println!("       - Thread 1: A → B");
    println!("       - Thread 2: B → A (순환!)");

    println!("\n  ✅ 해결책: 위 4가지 중 하나를 제거!");
    println!("    • Mutex → Channel (상호배제 제거)");
    println!("    • try_lock() (비선점 허용)");
    println!("    • 잠금 순서 고정 (순환대기 제거) ← 권장!");
}

// ============================================================================
// 섹션 2: 자원 계층화 (Resource Hierarchy)
// ============================================================================
fn section_2_resource_hierarchy() {
    println!("\n📌 섹션 2: 자원 계층화 (Resource Hierarchy)");
    println!("────────────────────────────────────────");

    #[derive(Debug)]
    struct SecureResource {
        id: u32,
        label: String,
        data: Mutex<String>,
    }

    // 자원에 ID 부여 (계층화)
    let res_a = Arc::new(SecureResource {
        id: 1,
        label: "데이터베이스".into(),
        data: Mutex::new("DB_DATA".into()),
    });

    let res_b = Arc::new(SecureResource {
        id: 2,
        label: "인증서버".into(),
        data: Mutex::new("AUTH_DATA".into()),
    });

    let r1_a = Arc::clone(&res_a);
    let r1_b = Arc::clone(&res_b);

    // 스레드 1: ID 순서대로 A(1) → B(2)
    let h1 = thread::spawn(move || {
        let _lock_a = r1_a.data.lock().unwrap();
        println!("  [스레드 1] {} (ID: {}) 획득", r1_a.label, r1_a.id);
        thread::sleep(Duration::from_millis(5));
        let _lock_b = r1_b.data.lock().unwrap();
        println!("  [스레드 1] {} (ID: {}) 획득 → 완료", r1_b.label, r1_b.id);
    });

    let r2_a = Arc::clone(&res_a);
    let r2_b = Arc::clone(&res_b);

    // 스레드 2: 반대 순서이지만, ID 규칙 준수: A(1) → B(2)
    let h2 = thread::spawn(move || {
        // 규칙: "항상 ID가 낮은 자원부터"
        let _lock_a = r2_a.data.lock().unwrap();
        println!("  [스레드 2] {} (ID: {}) 획득", r2_a.label, r2_a.id);
        thread::sleep(Duration::from_millis(3));
        let _lock_b = r2_b.data.lock().unwrap();
        println!("  [스레드 2] {} (ID: {}) 획득 → 완료", r2_b.label, r2_b.id);
    });

    h1.join().unwrap();
    h2.join().unwrap();

    println!("  💡 자원 계층화: ID로 명확한 순서 정의");
    println!("  💡 규칙: 항상 낮은 ID부터 높은 ID 순서로 잠금");
}

// ============================================================================
// 섹션 3: 잠금 순서 일관성 (Lock Ordering Consistency)
// ============================================================================
fn section_3_lock_ordering_consistency() {
    println!("\n📌 섹션 3: 잠금 순서 일관성");
    println!("────────────────────────────────────────");

    let lock1 = Arc::new(Mutex::new(0));
    let lock2 = Arc::new(Mutex::new(0));

    let l1_clone = Arc::clone(&lock1);
    let l2_clone = Arc::clone(&lock2);

    // 스레드 1: 순서 1→2
    let h1 = thread::spawn(move || {
        let mut v1 = l1_clone.lock().unwrap();
        println!("  [스레드 1] Lock1 획득");
        thread::sleep(Duration::from_millis(2));
        let mut v2 = l2_clone.lock().unwrap();
        println!("  [스레드 1] Lock2 획득 → 순서 유지 ✓");
        *v1 += 1;
        *v2 += 1;
    });

    let l1_clone = Arc::clone(&lock1);
    let l2_clone = Arc::clone(&lock2);

    // 스레드 2: 같은 순서 1→2 (데드락 회피!)
    let h2 = thread::spawn(move || {
        let mut v1 = l1_clone.lock().unwrap();
        println!("  [스레드 2] Lock1 획득 (대기할 수도)");
        thread::sleep(Duration::from_millis(1));
        let mut v2 = l2_clone.lock().unwrap();
        println!("  [스레드 2] Lock2 획득 → 순서 유지 ✓");
        *v1 += 1;
        *v2 += 1;
    });

    h1.join().unwrap();
    h2.join().unwrap();

    let final_1 = lock1.lock().unwrap();
    let final_2 = lock2.lock().unwrap();
    println!("  최종: Lock1 = {}, Lock2 = {}", *final_1, *final_2);
    println!("  💡 모든 스레드가 같은 순서로 잠금 → 데드락 불가능");
}

// ============================================================================
// 섹션 4: 타임아웃 기반 회피 (Timeout-based Avoidance)
// ============================================================================
fn section_4_timeout_avoidance() {
    println!("\n📌 섹션 4: 타임아웃 기반 회피");
    println!("────────────────────────────────────────");

    let lock_a = Arc::new(Mutex::new("A"));
    let lock_b = Arc::new(Mutex::new("B"));

    let la = Arc::clone(&lock_a);
    let lb = Arc::clone(&lock_b);

    let h = thread::spawn(move || {
        loop {
            match la.try_lock() {
                Ok(_guard_a) => {
                    println!("  [스레드] A 획득");
                    if let Ok(_guard_b) = lb.try_lock() {
                        println!("  [스레드] B 획득 → 진행");
                        break;
                    } else {
                        println!("  [스레드] B 획득 실패 → A 해제 후 재시도");
                        drop(_guard_a);
                    }
                }
                Err(_) => {
                    println!("  [스레드] A 획득 실패 → 즉시 재시도");
                }
            }
            thread::sleep(Duration::from_millis(1));
        }
    });

    thread::sleep(Duration::from_millis(10));

    let mut _guard_b = lock_b.lock().unwrap();
    let mut _guard_a = lock_a.lock().unwrap();
    println!("  [메인] A, B 모두 획득");

    drop(_guard_a);
    drop(_guard_b);

    h.join().unwrap();

    println!("  💡 try_lock(): 실패 시 즉시 반환");
    println!("  💡 데드락 위험 상황에서 자동으로 롤백");
}

// ============================================================================
// 섹션 5: 채널 기반 대안 (Channel-based Alternative)
// ============================================================================
fn section_5_channel_based_alternative() {
    println!("\n📌 섹션 5: 채널 기반 대안");
    println!("────────────────────────────────────────");

    use std::sync::mpsc;

    // Mutex 대신 Channel 사용 → 데드락 불가능!
    let (tx1, rx1) = mpsc::channel();
    let (tx2, rx2) = mpsc::channel();

    let tx1_clone = tx1.clone();
    let handle1 = thread::spawn(move || {
        tx1_clone.send("데이터 1").unwrap();
        println!("  [스레드 1] 채널로 전송 완료");
        let data = rx2.recv().unwrap();
        println!("  [스레드 1] 채널에서 수신: {}", data);
    });

    let handle2 = thread::spawn(move || {
        let data = rx1.recv().unwrap();
        println!("  [스레드 2] 채널에서 수신: {}", data);
        tx2.send("데이터 2").unwrap();
        println!("  [스레드 2] 채널로 전송 완료");
    });

    handle1.join().unwrap();
    handle2.join().unwrap();

    println!("  💡 Channel: 소유권 이동으로 경합 제거");
    println!("  💡 Deadlock 불가능 (순환 대기 구조 불가)");
}

// ============================================================================
// 섹션 6: 정밀한 잠금 (Fine-grained Locking)
// ============================================================================
fn section_6_fine_grained_locking() {
    println!("\n📌 섹션 6: 정밀한 잠금 (Fine-grained Locking)");
    println!("────────────────────────────────────────");

    struct Account {
        id: u32,
        balance: Mutex<f64>,
    }

    let acc1 = Arc::new(Account {
        id: 1,
        balance: Mutex::new(1000.0),
    });
    let acc2 = Arc::new(Account {
        id: 2,
        balance: Mutex::new(500.0),
    });

    let a1 = Arc::clone(&acc1);
    let a2 = Arc::clone(&acc2);

    let h = thread::spawn(move || {
        // ID 순서대로 잠금: acc1(ID:1) → acc2(ID:2)
        let mut b1 = a1.balance.lock().unwrap();
        *b1 -= 100.0;
        println!("  [스레드] 계좌1 100 출금");
        let mut b2 = a2.balance.lock().unwrap();
        *b2 += 100.0;
        println!("  [스레드] 계좌2 100 입금");
    });

    let mut b2 = acc2.balance.lock().unwrap();
    let mut b1 = acc1.balance.lock().unwrap();
    println!("  [메인] 잠금 순서: acc2 → acc1 (역순이지만 safe)");
    println!("  [메인] 잠금 동시성이 높음");

    drop(b1);
    drop(b2);

    h.join().unwrap();

    let final_1 = acc1.balance.lock().unwrap();
    let final_2 = acc2.balance.lock().unwrap();
    println!("  최종: 계좌1 = {}, 계좌2 = {}", *final_1, *final_2);
    println!("  💡 필요한 부분만 잠금 → 동시성 향상");
}

// ============================================================================
// 섹션 7: 무잠금 알고리즘 (Lock-free Algorithm)
// ============================================================================
fn section_7_lock_free_algorithm() {
    println!("\n📌 섹션 7: 무잠금 알고리즘 (Lock-free)");
    println!("────────────────────────────────────────");

    use std::sync::atomic::{AtomicUsize, Ordering};

    let counter = Arc::new(AtomicUsize::new(0));

    let mut handles = vec![];

    for i in 1..=4 {
        let c = Arc::clone(&counter);
        let h = thread::spawn(move || {
            for _ in 0..100_000 {
                c.fetch_add(1, Ordering::Relaxed);
            }
            println!("  [스레드 {}] 완료", i);
        });
        handles.push(h);
    }

    for h in handles {
        h.join().unwrap();
    }

    let final_count = counter.load(Ordering::SeqCst);
    println!("  최종 카운트: {} (기대값: 400000)", final_count);
    println!("  💡 Atomic: 비차단, 데드락 불가능");
    println!("  💡 성능: Mutex보다 훨씬 빠름");
}

// ============================================================================
// 섹션 8: Parking Lot 사용 (고급 뮤텍스)
// ============================================================================
fn section_8_parking_lot_usage() {
    println!("\n📌 섹션 8: Parking Lot 사용 (고급 뮤텍스)");
    println!("────────────────────────────────────────");

    use parking_lot::Mutex;

    let data = Arc::new(Mutex::new(vec![1, 2, 3]));

    let mut handles = vec![];

    for i in 1..=3 {
        let d = Arc::clone(&data);
        let h = thread::spawn(move || {
            let mut vec = d.lock();
            println!("  [스레드 {}] 획득: {:?}", i, *vec);
            vec.push(i as u32 + 3);
            println!("  [스레드 {}] 수정 후: {:?}", i, *vec);
        });
        handles.push(h);
    }

    for h in handles {
        h.join().unwrap();
    }

    let final_vec = data.lock();
    println!("  최종: {:?}", *final_vec);
    println!("  💡 parking_lot::Mutex: 표준보다 빠름");
    println!("  💡 deadlock detection 옵션 제공");
}

// ============================================================================
// 섹션 9: 교착 상태 감지 (Deadlock Detection)
// ============================================================================
fn section_9_deadlock_detection() {
    println!("\n📌 섹션 9: 교착 상태 감지");
    println!("────────────────────────────────────────");

    println!("  Rust 표준 라이브러리는 deadlock 자동 감지 안 함");
    println!("  → 개발자가 설계로 예방해야 함");

    println!("\n  🛡️ 감지 전략:");
    println!("    1. 타임아웃 기반: try_lock()으로 실패 감지");
    println!("    2. 모니터링: 스레드별 잠금 획득 시간 기록");
    println!("    3. 로깅: 잠금 순서 추적");

    println!("\n  예제: 타임아웃으로 데드락 감지");

    let lock = Arc::new(std::sync::Mutex::new(0));
    let l = Arc::clone(&lock);

    let h = thread::spawn(move || {
        let _guard = l.lock().unwrap();
        thread::sleep(Duration::from_secs(10));  // 오래 점유
    });

    thread::sleep(Duration::from_millis(100));

    let start = std::time::Instant::now();
    match lock.try_lock() {
        Ok(_) => println!("  [메인] 빠르게 획득"),
        Err(_) => {
            println!("  [메인] 데드락 의심! 다른 스레드가 점유");
            if start.elapsed() > Duration::from_millis(50) {
                println!("  [메인] 대기 시간이 길어짐 → 문제 있음");
            }
        }
    }

    h.join().unwrap();
    println!("  💡 try_lock() 반복으로 교착 감지 가능");
}

