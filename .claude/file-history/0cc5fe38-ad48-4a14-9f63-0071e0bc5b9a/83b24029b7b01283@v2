// 섹션 10: 실전 패턴 - 다중 자원 관리
// ============================================================================
fn section_10_practical_multiple_resources() {
    println!("\n📌 섹션 10: 실전 패턴 - 다중 자원 관리");
    println!("────────────────────────────────────────");

    struct Transaction {
        from_id: u32,
        to_id: u32,
        amount: f64,
    }

    // 자원 계층화
    let accounts = vec![
        Arc::new(Mutex::new(1000.0)),  // ID 0
        Arc::new(Mutex::new(500.0)),   // ID 1
        Arc::new(Mutex::new(750.0)),   // ID 2
    ];

    let txn = Transaction {
        from_id: 2,
        to_id: 0,
        amount: 100.0,
    };

    let mut from_idx = txn.from_id as usize;
    let mut to_idx = txn.to_id as usize;

    // 규칙: 항상 작은 ID부터 잠금
    if from_idx > to_idx {
        std::mem::swap(&mut from_idx, &mut to_idx);
    }

    let from = Arc::clone(&accounts[from_idx]);
    let to = Arc::clone(&accounts[to_idx]);

    let h = thread::spawn(move || {
        let mut from_bal = from.lock().unwrap();
        let mut to_bal = to.lock().unwrap();
        *from_bal -= txn.amount;
        *to_bal += txn.amount;
        println!("  [거래] 이체 완료: {} 이동", txn.amount);
    });

    h.join().unwrap();

    for (i, acc) in accounts.iter().enumerate() {
        let bal = acc.lock().unwrap();
        println!("  계좌 {}: {}", i, *bal);
    }

    println!("  💡 다중 자원: 항상 ID로 정렬 후 잠금");
}

