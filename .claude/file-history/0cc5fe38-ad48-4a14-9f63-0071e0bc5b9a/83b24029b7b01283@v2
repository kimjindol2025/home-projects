// 섹션 11: 실전 패턴 - 계층적 설계
// ============================================================================
fn section_11_practical_hierarchical_design() {
    println!("\n📌 섹션 11: 실전 패턴 - 계층적 설계");
    println!("────────────────────────────────────────");

    #[derive(Clone)]
    struct Service {
        id: u32,
        name: String,
        state: Arc<Mutex<String>>,
    }

    let auth_svc = Service {
        id: 1,
        name: "인증".into(),
        state: Arc::new(Mutex::new("ready".into())),
    };

    let db_svc = Service {
        id: 2,
        name: "데이터베이스".into(),
        state: Arc::new(Mutex::new("ready".into())),
    };

    let cache_svc = Service {
        id: 3,
        name: "캐시".into(),
        state: Arc::new(Mutex::new("ready".into())),
    };

    // 계층: Auth(1) → DB(2) → Cache(3)
    let auth = auth_svc.clone();
    let db = db_svc.clone();
    let cache = cache_svc.clone();

    let h = thread::spawn(move || {
        // ID 순서대로: 1 → 2 → 3
        let mut auth_state = auth.state.lock().unwrap();
        *auth_state = "processing".into();
        println!("  [스레드] {} 처리", auth.name);

        let mut db_state = db.state.lock().unwrap();
        *db_state = "processing".into();
        println!("  [스레드] {} 처리", db.name);

        let mut cache_state = cache.state.lock().unwrap();
        *cache_state = "processing".into();
        println!("  [스레드] {} 처리", cache.name);
    });

    h.join().unwrap();

    println!("  💡 서비스 계층화: 의존성 순서로 잠금");
    println!("  💡 명확한 구조 → 데드락 회피");
}

