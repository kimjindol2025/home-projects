// 제5장: 트레이트의 마스터 (v6.0) — 6~7단계
// ===================================================================
//
// 철학: "엄격한 자격 요건을 통한 안정성 확보"
//
// [6단계] 트레이트 경계(Trait Bounds)
//         - 함수가 특정 트레이트를 구현한 타입만 받도록 제한
//         - fn process<T: Summary>(item: &T)
//
// [7단계] 다중 경계 설계(Multiple Bounds)
//         - 여러 트레이트를 동시에 만족하는 타입만 허용
//         - fn process<T: Summary + SecurityLevel>(item: &T)
//
// ===================================================================

// ===================================================================
// [준비 단계] 세 가지 핵심 트레이트 정의
// ===================================================================

/// 요약 기능: 데이터의 핵심 정보를 문자열로 표현
///
/// 이 트레이트를 구현한 타입은 "설명할 수 있다"는 능력을 가집니다.
trait Summary {
    fn summarize(&self) -> String;
}

/// 보안 수준: 데이터의 민감도를 0~10 범위로 표현
///
/// 이 트레이트를 구현한 타입은 "보안 등급을 가진다"는 능력을 가집니다.
trait SecurityLevel {
    fn level(&self) -> u8;
}

/// 상태 표시: 데이터의 현재 상태를 표현
///
/// 이 트레이트를 구현한 타입은 "상태를 표현할 수 있다"는 능력을 가집니다.
trait DisplayStatus {
    fn status(&self) -> String;
}

// ===================================================================
// [구현체 1] 보안 로그
// ===================================================================

struct SecurityLog {
    id: u32,
    code: String,
    clearance: u8,
}

impl SecurityLog {
    fn new(id: u32, code: &str, clearance: u8) -> Self {
        SecurityLog {
            id,
            code: code.to_string(),
            clearance,
        }
    }
}

impl Summary for SecurityLog {
    fn summarize(&self) -> String {
        format!("Log#{}: [{}]", self.id, self.code)
    }
}

impl SecurityLevel for SecurityLog {
    fn level(&self) -> u8 {
        self.clearance
    }
}

impl DisplayStatus for SecurityLog {
    fn status(&self) -> String {
        format!("Status: ID={}, Clearance Level={}", self.id, self.clearance)
    }
}

// ===================================================================
// [구현체 2] 감시 로그
// ===================================================================

struct AuditLog {
    timestamp: String,
    action: String,
    risk: u8,
}

impl AuditLog {
    fn new(timestamp: &str, action: &str, risk: u8) -> Self {
        AuditLog {
            timestamp: timestamp.to_string(),
            action: action.to_string(),
            risk,
        }
    }
}

impl Summary for AuditLog {
    fn summarize(&self) -> String {
        format!("[{}] Action: {}", self.timestamp, self.action)
    }
}

impl SecurityLevel for AuditLog {
    fn level(&self) -> u8 {
        self.risk
    }
}

impl DisplayStatus for AuditLog {
    fn status(&self) -> String {
        match self.risk {
            0..=2 => "Status: 낮음 (정상)".to_string(),
            3..=5 => "Status: 중간 (주의)".to_string(),
            6..=8 => "Status: 높음 (위험)".to_string(),
            _ => "Status: 긴급 (즉시 대응)".to_string(),
        }
    }
}

// ===================================================================
// [구현체 3] 시스템 알람
// ===================================================================

struct SystemAlert {
    alert_id: u32,
    message: String,
    severity: u8,
    resolved: bool,
}

impl SystemAlert {
    fn new(alert_id: u32, message: &str, severity: u8) -> Self {
        SystemAlert {
            alert_id,
            message: message.to_string(),
            severity,
            resolved: false,
        }
    }
}

impl Summary for SystemAlert {
    fn summarize(&self) -> String {
        format!("Alert#{}: {}", self.alert_id, self.message)
    }
}

impl SecurityLevel for SystemAlert {
    fn level(&self) -> u8 {
        self.severity
    }
}

impl DisplayStatus for SystemAlert {
    fn status(&self) -> String {
        if self.resolved {
            "Status: 해결됨".to_string()
        } else {
            "Status: 진행 중".to_string()
        }
    }
}

// ===================================================================
// [Step 6] 단일 경계: 하나의 트레이트만 요구
// ===================================================================

/// 요약만 필요한 함수
/// "Summary를 구현한 타입이라면, 그게 뭐든 환영한다"
fn describe<T: Summary>(item: &T) {
    println!("  📝 {}", item.summarize());
}

/// 보안 수준만 필요한 함수
/// "SecurityLevel을 구현한 타입이라면, 그게 뭐든 환영한다"
fn check_risk<T: SecurityLevel>(item: &T) {
    let level = item.level();
    if level > 5 {
        println!("  🚨 위험: 심각도 {}/10 (높음)", level);
    } else {
        println!("  ✅ 안전: 심각도 {}/10 (정상)", level);
    }
}

/// 상태 표시만 필요한 함수
fn show_status<T: DisplayStatus>(item: &T) {
    println!("  📊 {}", item.status());
}

// ===================================================================
// [Step 7] 다중 경계: 두 개 이상의 트레이트 필요
// ===================================================================

/// 다중 경계 [1]: Summary + SecurityLevel
/// "요약도 할 수 있고, 보안 수준도 가진 타입만 이 함수를 호출할 수 있다"
fn monitor_system<T: Summary + SecurityLevel>(item: &T) {
    println!("🔍 시스템 모니터링:");
    println!("  내용: {}", item.summarize());

    let level = item.level();
    if level > 7 {
        println!("  [ALERT] ⚠️  고위험 데이터 감지! (심각도: {})", level);
    } else if level > 5 {
        println!("  [CAUTION] 주의: 중위험 (심각도: {})", level);
    } else {
        println!("  [OK] 정상 (심각도: {})", level);
    }
}

/// 다중 경계 [2]: Summary + DisplayStatus
/// "요약도 할 수 있고, 상태도 표시할 수 있는 타입만"
fn report<T: Summary + DisplayStatus>(item: &T) {
    println!("📋 상세 보고서:");
    println!("  내용: {}", item.summarize());
    println!("  {}", item.status());
}

/// 다중 경계 [3]: Summary + SecurityLevel + DisplayStatus
/// "세 가지 능력을 모두 가진 타입만 이 함수를 호출할 수 있다"
/// 이것이 '깐깐한 전문가'의 출입 통제 시스템이다!
fn full_audit<T: Summary + SecurityLevel + DisplayStatus>(item: &T) {
    println!("🔐 전체 감사 보고서:");
    println!("  ├─ 내용: {}", item.summarize());
    println!("  ├─ 보안 수준: {}/10", item.level());
    println!("  └─ {}", item.status());
}

// ===================================================================
// [고급 활용] 여러 아이템을 일괄 처리하는 다중 경계 함수
// ===================================================================

/// 컬렉션을 받아서 일괄 모니터링
/// "Summary + SecurityLevel을 만족하는 모든 아이템"
fn batch_monitor<T: Summary + SecurityLevel>(items: &[T]) {
    println!("📌 배치 모니터링: {} 개 항목", items.len());

    let mut high_risk_count = 0;

    for (idx, item) in items.iter().enumerate() {
        print!("  [{}] {} → ", idx + 1, item.summarize());
        if item.level() > 5 {
            println!("🚨 위험");
            high_risk_count += 1;
        } else {
            println!("✅ 안전");
        }
    }

    println!("  📊 결과: 총 {} 개 중 {} 개 위험", items.len(), high_risk_count);
}

// ===================================================================
// [트레이트 경계의 확장] where절과의 조합
// ===================================================================

/// where절을 사용한 더 가독성 좋은 다중 경계
/// 함수 시그니처가 복잡할 때 유용합니다
fn comprehensive_check<T>(item: &T)
where
    T: Summary + SecurityLevel + DisplayStatus,
{
    println!("✨ 종합 점검:");
    println!("  {}", item.summarize());

    if item.level() > 8 {
        println!("  🚨 긴급 상황: 즉시 관리자 호출!");
    } else if item.level() > 5 {
        println!("  ⚠️  위험 상황: 모니터링 강화");
    } else {
        println!("  ✅ 정상: 계속 모니터링");
    }

    println!("  {}", item.status());
}

