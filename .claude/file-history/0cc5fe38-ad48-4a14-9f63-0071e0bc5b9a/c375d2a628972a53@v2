    // SecurityLevel도 있고, 암호화도 지원하는 것들만
}

fn enter_top_secret_area<T: SecurityLevel + EncryptionEnabled + AuditLog>(item: &T) {
    // 세 가지 능력을 모두 가진 것들만 최고 기밀 구역 진입 가능
}

이것이 **"엄격한 전문가"**의 설계입니다.

*/
