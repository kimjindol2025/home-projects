// 🕐 v7.4: 통합 수명 설계 (Integration: The Trinity)
// ⏳ "제네릭, 트레이트, 수명의 삼위일체"
// 🎯 "어떤 타입이든, 어떤 행동을 하든, 언제까지 살든 완벽하게 제어"
//
// 핵심 개념:
// - 구조체<'a, T>: 참조 수명 'a와 제네릭 타입 T의 결합
// - T: 'a: "T는 적어도 'a 수명만큼은 살아있어야 한다" (수명 하한선)
// - where T: Display + 'a: 트레이트 바운드와 수명의 동시 지정
// - 제약 조건의 오케스트레이션: 완벽한 캡슐화

use std::fmt::{self, Display};

// ==================== 기본 구조: 삼위일체 ====================

/// [설계] 범용 보안 감사 엔진
///
/// 'a: 외부 참조 데이터의 수명 (로그 헤더, 분석 컨텍스트)
/// T: 분석할 데이터의 제네릭 타입 (String, 구조체, etc)
/// T: Display + 'a: T는 Display를 구현하고, 'a 수명을 따름
struct GogsAuditor<'a, T>
where
    T: Display + 'a,
{
    target: &'a T,      // 분석 대상 (참조)
    prefix: &'a str,    // 로그 접두어 (참조)
    severity: usize,    // 심각도 (소유권)
}

impl<'a, T> GogsAuditor<'a, T>
where
    T: Display + 'a,
{
    /// 새 감사 엔진 생성
    fn new(target: &'a T, prefix: &'a str, severity: usize) -> Self {
        GogsAuditor {
            target,
            prefix,
            severity,
        }
    }

    /// 기본 감사 실행
    fn audit(&self) {
        println!("[{}] {}: {}", self.severity, self.prefix, self.target);
    }

    /// 상세 감사 실행
    fn audit_detailed(&self) {
        println!("┌─ 감사 기록 ─────────────────────────────┐");
        println!("│ 심각도: {}", self.severity);
        println!("│ 헤더:   {}", self.prefix);
        println!("│ 내용:   {}", self.target);
        println!("└─────────────────────────────────────────┘");
    }
}

// ==================== 다양한 T 타입 ====================

/// 커스텀 감사 대상
#[derive(Debug)]
struct SecurityEvent {
    event_type: String,
    timestamp: u64,
}

impl Display for SecurityEvent {
    fn fmt(&self, f: &mut fmt::Formatter) -> fmt::Result {
        write!(f, "{}@{}", self.event_type, self.timestamp)
    }
}

/// 감사 설정
#[derive(Debug)]
struct AuditConfig {
    max_retries: u32,
    timeout_ms: u64,
}

impl Display for AuditConfig {
    fn fmt(&self, f: &mut fmt::Formatter) -> fmt::Result {
        write!(f, "Config(retries={}, timeout={})", self.max_retries, self.timeout_ms)
    }
}

// ==================== 규칙 1: T: 'a의 의미 ====================

/// T: 'a는 무엇인가?
/// "T는 적어도 'a 수명만큼은 살아있어야 한다"
///
/// 만약 T가 내부적으로 참조자를 가진다면,
/// T 안의 모든 참조자들도 'a보다 오래 살아야 함을 의미한다.

struct DataContainer<'a> {
    name: &'a str,
    values: Vec<&'a i32>,
}

// T: 'a 없이는 불가능한 경우
fn process_container<'a, T>(container: &DataContainer<'a>, data: &'a T)
where
    T: Display + 'a,  // T: 'a가 필수!
{
    println!("컨테이너: {}", container.name);
    println!("데이터:   {}", data);
}

// ==================== 규칙 2: 여러 제네릭 + 여러 수명 ====================

/// 두 가지 제네릭 타입과 두 가지 수명
struct BiAuditor<'a, 'b, T, U>
where
    T: Display + 'a,
    U: Display + 'b,
{
    first: &'a T,
    second: &'b U,
}

impl<'a, 'b, T, U> BiAuditor<'a, 'b, T, U>
where
    T: Display + 'a,
    U: Display + 'b,
{
    fn compare(&self) {
        println!("첫 번째: {}", self.first);
        println!("두 번째: {}", self.second);
    }
}

// ==================== 규칙 3: 함수 제네릭 + 수명 ====================

/// 함수 레벨 제네릭과 수명
fn audit_generic<'a, T>(target: &'a T, label: &'a str)
where
    T: Display + 'a,
{
    println!("[감사] {}: {}", label, target);
}

/// 반환값에도 수명을 지정
fn create_auditor<'a, T>(target: &'a T, label: &'a str) -> GogsAuditor<'a, T>
where
    T: Display + 'a,
{
    GogsAuditor::new(target, label, 1)
}

// ==================== 규칙 4: 트레이트 객체 + 수명 ====================

/// 동적 디스패치와 수명
trait Auditable<'a> {
    fn perform_audit(&self);
}

impl<'a, T> Auditable<'a> for GogsAuditor<'a, T>
where
    T: Display + 'a,
{
    fn perform_audit(&self) {
        self.audit();
    }
}

fn audit_dynamic<'a>(auditor: &dyn Auditable<'a>) {
    auditor.perform_audit();
}

// ==================== 규칙 5: 소유권 vs 참조 ====================

/// 소유권을 가진 경우 (단순함)
struct OwnedAuditor<T: Display> {
    data: T,
}

impl<T: Display> OwnedAuditor<T> {
    fn audit(&self) {
        println!("소유권: {}", self.data);
    }
}

/// 참조를 가진 경우 (복잡함, 강력함)
struct RefAuditor<'a, T: Display + 'a> {
    data: &'a T,
}

impl<'a, T: Display + 'a> RefAuditor<'a, T> {
    fn audit(&self) {
        println!("참조: {}", self.data);
    }
}

// ==================== 규칙 6: 복잡한 제약 조건 ====================

/// where 절을 활용한 복잡한 제약 조건
fn complex_audit<'a, T, U>(first: &'a T, second: &'a U) -> String
where
    T: Display + Clone + 'a,
    U: Display + 'a,
{
    format!("{} and {}", first, second)
}

// ==================== 섹션: 실전 시나리오 ====================

/// 보안 감사 시스템
struct SecurityAuditSystem<'a> {
    name: &'a str,
}

impl<'a> SecurityAuditSystem<'a> {
    fn new(name: &'a str) -> Self {
        SecurityAuditSystem { name }
    }

    fn audit_event<T>(&self, event: &'a T)
    where
        T: Display + 'a,
    {
        println!("[{}] 감사: {}", self.name, event);
    }
}

