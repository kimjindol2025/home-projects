// 🧠 v10.1: 채널과 메시지 패싱 (Channels and Message Passing)
// 📬 "스레드 간의 안전한 정보 흐름"
// 🎯 "메모리를 공유하지 말고, 통신하라"
//
// 핵심 개념:
// - mpsc (Multiple Producer, Single Consumer): 다중 송신, 단일 수신
// - Sender (tx): 메시지를 보내는 끝단
// - Receiver (rx): 메시지를 받는 끝단
// - send(): 소유권 이동으로 안전한 전송
// - recv(): 메시지 대기
// - 파이프라인: 단계별 처리
// - 소유권 전이: 데이터 경합 원천 차단

use std::sync::mpsc;
use std::thread;
use std::time::Duration;

fn main() {
    println!("╔══════════════════════════════════════════════════════════╗");
    println!("║ v10.1: 채널과 메시지 패싱                                ║");
    println!("║ \"스레드 간의 안전한 정보 흐름\"                            ║");
    println!("╚══════════════════════════════════════════════════════════╝\n");

    // ==================== 섹션 1: mpsc 채널 개념 ====================
    println!("📌 섹션 1: mpsc 채널 개념\n");
    {
        println!("mpsc (Multiple Producer, Single Consumer):");
        println!("  여러 개의 송신자 (Producer)");
        println!("  ↓");
        println!("  채널 (데이터 통로)");
        println!("  ↓");
        println!("  하나의 수신자 (Consumer)");
        println!();

        println!("메모리 구조:");
        println!("  Sender (tx)");
        println!("    │");
        println!("    ├─ 메시지 → [채널 버퍼] → Receiver (rx)");
        println!("    │");
        println!("  Sender (tx.clone())");
        println!();

        println!("핵심 특징:");
        println!("  ✅ 여러 스레드가 동시에 데이터 전송");
        println!("  ✅ 하나의 수신자가 모든 메시지 처리");
        println!("  ✅ 소유권 이동으로 경합 차단");
        println!("  ✅ 비동기 통신");
        println!();
    }

    // ==================== 섹션 2: 기본 채널 생성과 사용 ====================
    println!("📌 섹션 2: 기본 채널 생성과 사용\n");
    {
        println!("채널 생성과 메시지 전송:");
        println!();

        let (tx, rx) = mpsc::channel();

        thread::spawn(move || {
            let val = "안녕, 나는 워커야!";
            println!("  [워커] 메시지 전송: {}", val);
            tx.send(val).unwrap();
        });

        let received = rx.recv().unwrap();
        println!("  [메인] 수신: {}", received);
        println!();

        println!("send()의 의미:");
        println!("  ✅ 메시지를 채널로 전송");
        println!("  ✅ 소유권을 수신자에게 이전");
        println!("  ✅ 송신자는 더 이상 사용 불가");
        println!();
    }

    // ==================== 섹션 3: 여러 송신자 ====================
    println!("📌 섹션 3: 여러 송신자 (tx.clone())\n");
    {
        println!("여러 스레드에서 메시지 전송:");
        println!();

        let (tx, rx) = mpsc::channel();

        let tx1 = tx.clone();
        thread::spawn(move || {
            for i in 1..=3 {
                println!("  [스레드 1] 메시지 {}", i);
                tx1.send(format!("스레드 1: {}", i)).unwrap();
                thread::sleep(Duration::from_millis(100));
            }
        });

        let tx2 = tx.clone();
        thread::spawn(move || {
            for i in 1..=3 {
                println!("  [스레드 2] 메시지 {}", i);
                tx2.send(format!("스레드 2: {}", i)).unwrap();
                thread::sleep(Duration::from_millis(150));
            }
        });

        drop(tx);  // 원본 tx는 더 이상 필요 없으면 드롭

        println!("  [메인] 메시지 수신 시작...");
        for received in rx {
            println!("  [메인] 수신: {}", received);
        }
        println!();
    }

    // ==================== 섹션 4: 메시지 수신 방식 ====================
    println!("📌 섹션 4: 메시지 수신 방식\n");
    {
        println!("방법 1: recv() - 블로킹 대기");
        {
            let (tx, rx) = mpsc::channel();
            thread::spawn(move || {
                thread::sleep(Duration::from_millis(200));
                tx.send("도착했어!").unwrap();
            });

            println!("  [메인] 메시지 기다리는 중...");
            let msg = rx.recv().unwrap();
            println!("  [메인] 수신: {}", msg);
        }
        println!();

        println!("방법 2: try_recv() - 즉시 확인");
        {
            let (tx, rx) = mpsc::channel();
            thread::spawn(move || {
                thread::sleep(Duration::from_millis(200));
                tx.send("조금 뒤에 도착").unwrap();
            });

            println!("  [메인] 메시지 확인");
            match rx.try_recv() {
                Ok(msg) => println!("  [메인] 수신: {}", msg),
                Err(_) => println!("  [메인] 아직 메시지 없음 (계속 작업)"),
            }
        }
        println!();

        println!("recv() vs try_recv():");
        println!("  recv(): 메시지 올 때까지 기다림");
        println!("  try_recv(): 기다리지 않고 즉시 확인");
        println!();
    }

    // ==================== 섹션 5: 로그 수집 시스템 ====================
    println!("📌 섹션 5: 로그 수집 시스템 (멀티 소스)\n");
    {
        let (tx, rx) = mpsc::channel();

        // 감시팀
        let tx1 = tx.clone();
        thread::spawn(move || {
            let logs = vec![
                "[감시팀] 침입 시도 감지",
                "[감시팀] 의심스러운 패킷",
                "[감시팀] 방화벽 작동",
            ];
            for log in logs {
                tx1.send(log).unwrap();
                thread::sleep(Duration::from_millis(300));
            }
        });

        // 인증팀
        let tx2 = tx.clone();
        thread::spawn(move || {
            let logs = vec![
                "[인증팀] 관리자 로그인",
                "[인증팀] 세션 만료",
                "[인증팀] 비밀번호 변경",
            ];
            for log in logs {
                tx2.send(log).unwrap();
                thread::sleep(Duration::from_millis(400));
            }
        });

        // 시스템팀
        let tx3 = tx.clone();
        thread::spawn(move || {
            let logs = vec![
                "[시스템팀] CPU 사용률 높음",
                "[시스템팀] 메모리 부족",
            ];
            for log in logs {
                tx3.send(log).unwrap();
                thread::sleep(Duration::from_millis(500));
            }
        });

        drop(tx);  // 원본 tx 드롭

        println!("  [중앙 제어소] 로그 수집 시작...\n");
        let mut count = 0;
        for log in rx {
            count += 1;
            println!("  📩 [{}] {}", count, log);
        }
        println!();
    }

    // ==================== 섹션 6: 작업 큐 패턴 ====================
    println!("📌 섹션 6: 작업 큐 패턴\n");
    {
        let (tx, rx) = mpsc::channel();

        // 작업 생성자
        thread::spawn(move || {
            for i in 1..=5 {
                println!("  [생성자] 작업 {} 생성", i);
                tx.send(format!("작업 {}", i)).unwrap();
                thread::sleep(Duration::from_millis(100));
            }
        });

        // 작업 처리자
        println!("  [처리자] 작업 처리 시작...");
        for task in rx {
            println!("  [처리자] {} 완료 (1초 소요)", task);
            thread::sleep(Duration::from_millis(1000));
        }
        println!();
    }

    // ==================== 섹션 7: 파이프라인 아키텍처 ====================
    println!("📌 섹션 7: 파이프라인 아키텍처\n");
    {
        println!("단계 1: 생성 → [채널] → 처리");
        println!("단계 2: 처리 → [채널] → 저장");
        println!();

        let (tx1, rx1) = mpsc::channel();
        let (tx2, rx2) = mpsc::channel();

        // 단계 1: 데이터 생성
        thread::spawn(move || {
            for i in 1..=3 {
                let data = format!("데이터 {}", i);
                println!("  [단계 1] 생성: {}", data);
                tx1.send(data).unwrap();
                thread::sleep(Duration::from_millis(200));
            }
        });

        // 단계 2: 데이터 처리
        thread::spawn(move || {
            for data in rx1 {
                let processed = format!("{}[처리됨]", data);
                println!("  [단계 2] 처리: {}", processed);
                tx2.send(processed).unwrap();
                thread::sleep(Duration::from_millis(300));
            }
        });

        // 단계 3: 데이터 저장
        println!("  [단계 3] 저장 시작...");
        for data in rx2 {
            println!("  [단계 3] 저장: {}", data);
        }
        println!();
    }

    // ==================== 섹션 8: 채널 닫힘과 종료 신호 ====================
    println!("📌 섹션 8: 채널 닫힘과 종료 신호\n");
    {
        println!("채널 닫힘의 자동화:");
        println!("  1. 모든 Sender (tx) 드롭");
        println!("  2. 채널 자동 종료");
        println!("  3. Receiver (rx) 반복문 자동 종료");
        println!();

        let (tx, rx) = mpsc::channel();

        thread::spawn(move || {
            for i in 1..=3 {
                tx.send(i).unwrap();
                thread::sleep(Duration::from_millis(100));
            }
            println!("  [워커] 송신 완료, tx 드롭됨");
            // tx가 스코프를 벗어나면서 드롭됨
        });

        println!("  [메인] 메시지 수신:");
        let mut count = 0;
        for msg in rx {
            count += 1;
            println!("    메시지 {}: {}", count, msg);
        }
        println!("  [메인] 채널 닫힘, 반복문 종료");
        println!();
    }

    // ==================== 섹션 9: 성능 측정 ====================
    println!("📌 섹션 9: 성능 측정\n");
    {
        println!("채널 전송 성능:");
        println!();

        let (tx, rx) = mpsc::channel();

        let start = std::time::Instant::now();
        thread::spawn(move || {
            for i in 0..10000 {
                tx.send(i).unwrap();
            }
        });

        let mut count = 0;
        for _ in rx {
            count += 1;
        }
        let elapsed = start.elapsed();

        println!("  송신: 10,000개 메시지");
        println!("  수신: {}개 메시지", count);
        println!("  시간: {:.3}ms", elapsed.as_secs_f64() * 1000.0);
        println!("  처리율: {:.0} msg/sec", 10000.0 / elapsed.as_secs_f64());
        println!();

        println!("특징:");
        println!("  ✅ 매우 빠른 처리");
        println!("  ✅ 메모리 안전");
        println!("  ✅ 소유권 추적");
        println!();
    }

    // ==================== 섹션 10: sync_channel (백프레셔) ====================
    println!("📌 섹션 10: sync_channel (백프레셔)\n");
    {
        println!("일반 channel: 무제한 버퍼");
        println!("sync_channel: 제한된 버퍼");
        println!();

        println!("sync_channel의 역할:");
        println!("  ✅ 버퍼 크기 제한");
        println!("  ✅ 송신자 속도 조절 (백프레셔)");
        println!("  ✅ 메모리 사용 제어");
        println!();

        let (tx, rx) = mpsc::sync_channel(2);  // 버퍼 크기 2

        thread::spawn(move || {
            println!("  [빠른 송신자] 메시지 보내는 중...");
            for i in 1..=5 {
                println!("    메시지 {} 전송", i);
                tx.send(i).unwrap();
            }
        });

        thread::sleep(Duration::from_millis(500));
        println!("  [느린 수신자] 메시지 처리 시작");
        for msg in rx {
            println!("    메시지 {} 처리", msg);
            thread::sleep(Duration::from_millis(200));
        }
        println!();

        println!("백프레셔 (Backpressure):");
        println!("  버퍼가 가득 차면 송신자가 대기");
        println!("  → 메모리 폭발 방지");
        println!("  → 시스템 안정화");
        println!();
    }

    // ==================== 섹션 11: 실무 패턴 ====================
    println!("📌 섹션 11: 실무 패턴 - 이벤트 기반 처리\n");
    {
        println!("이벤트 제너레이터 (여러 개):");
        println!("  ↓");
        println!("이벤트 채널");
        println!("  ↓");
        println!("이벤트 핸들러 (하나)");
        println!();

        #[derive(Debug, Clone)]
        enum Event {
            Click(String),
            KeyPress(char),
            Scroll(i32),
        }

        let (tx, rx) = mpsc::channel();

        // 마우스 이벤트
        let tx1 = tx.clone();
        thread::spawn(move || {
            tx1.send(Event::Click("버튼".to_string())).unwrap();
            thread::sleep(Duration::from_millis(100));
            tx1.send(Event::Click("메뉴".to_string())).unwrap();
        });

        // 키보드 이벤트
        let tx2 = tx.clone();
        thread::spawn(move || {
            tx2.send(Event::KeyPress('A')).unwrap();
            thread::sleep(Duration::from_millis(150));
            tx2.send(Event::KeyPress('B')).unwrap();
        });

        drop(tx);

        println!("  [UI 루프] 이벤트 처리:");
        for event in rx {
            match event {
                Event::Click(btn) => println!("    클릭: {}", btn),
                Event::KeyPress(key) => println!("    키: {}", key),
                Event::Scroll(delta) => println!("    스크롤: {}", delta),
            }
        }
        println!();
    }

    // ==================== 섹션 12: 설계자 관점과 다음 단계 ====================
    println!("📌 섹션 12: 설계자 관점과 다음 단계\n");
    {
        println!("설계자 관점: \"파이프라인 아키텍처\"");
        println!();

        println!("1️⃣  메모리 공유 vs 통신");
        println!("   \"메모리를 공유함으로써 통신하지 말고,");
        println!("    통신함으로써 메모리를 공유하라\"");
        println!();

        println!("2️⃣  소유권 전이");
        println!("   send()로 소유권이 완전히 이전");
        println!("   → 경합 불가능");
        println!("   → 안전함 (컴파일러 검증)");
        println!();

        println!("3️⃣  느슨한 결합");
        println!("   각 스레드가 독립적");
        println!("   채널로만 통신");
        println!("   → 부하 조절 가능");
        println!("   → 스케일 가능");
        println!();

        println!("v10 동시성 시리즈:");
        println!("  v10.0: 스레드 (격리)");
        println!("  v10.1: 채널 (통신) ✅");
        println!("  v10.2: 뮤텍스 (공유)");
        println!("  v10.3: 원자 연산 (고성능)");
        println!();

        println!("다음 단계: v10.2 뮤텍스");
        println!("  \"공유 상태의 안전한 접근\"");
        println!("  메시지 대신 직접 공유");
        println!("  Mutex로 상호 배제");
        println!("  Arc로 멀티 스레드 공유");
        println!();
    }

    // ==================== 최종 선언 ====================
    println!("╔══════════════════════════════════════════════════════════╗");
    println!("║ 스레드 간 안전한 통신 (Message Passing) 완성            ║");
    println!("╚══════════════════════════════════════════════════════════╝\n");

    println!("✅ 당신이 이제 할 수 있는 것:");
    println!("   • mpsc 채널 생성");
    println!("   • 여러 송신자 관리");
    println!("   • 메시지 수신 (블로킹/논블로킹)");
    println!("   • 파이프라인 아키텍처 설계");
    println!("   • 백프레셔 구현");
    println!();

    println!("✅ 러스트의 강점:");
    println!("   • 소유권으로 경합 차단");
    println!("   • 채널 자동 관리");
    println!("   • 타입 안전 메시징");
    println!("   • 높은 성능 (msg/sec)");
    println!();

    println!("🏆 당신의 시스템은 이제 협력하는 '오케스트라'입니다.");
    println!("   각 악기(스레드)가 안전하게 조화를 이룹니다. 🎼");
    println!();
}
