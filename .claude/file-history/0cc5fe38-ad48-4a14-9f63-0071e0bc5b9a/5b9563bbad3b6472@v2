## 📊 실전 패턴 3: 신호 처리

```rust
enum SystemSignal {
    Reset,
    UpdateVersion(f32),
    ErrorMessage(String),
    ChangeColor(u8, u8, u8),
}

impl SystemSignal {
    fn handle(&self) -> String {
        match self {
            SystemSignal::Reset => "초기화".to_string(),
            SystemSignal::UpdateVersion(v) => format!("v{}로 업데이트", v),
            SystemSignal::ErrorMessage(msg) => format!("오류: {}", msg),
            SystemSignal::ChangeColor(r, g, b) => {
                format!("색 변경: R{}, G{}, B{}", r, g, b)
            }
        }
    }
}
```

