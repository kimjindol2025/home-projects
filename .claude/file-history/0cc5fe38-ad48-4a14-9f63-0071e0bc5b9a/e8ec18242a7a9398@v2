### 3단계: 모듈 구조 설계

```rust
// src/main.rs
mod models;
mod database;
mod api;

use crate::models::Todo;
use crate::database::Database;

fn main() {
    let mut db = Database::new();

    // 새 TODO 생성
    let todo = Todo::new("Learn v4.5".to_string());
    db.add(todo);

    // 모든 TODO 출력
    for todo in db.list() {
        println!("{}", todo);
    }
}
```

```rust
// src/models.rs
use serde::{Serialize, Deserialize};
use uuid::Uuid;
use chrono::{DateTime, Utc};

#[derive(Serialize, Deserialize, Clone)]
pub struct Todo {
    pub id: String,
    pub title: String,
    pub completed: bool,
    pub created_at: String,
}

impl Todo {
    pub fn new(title: String) -> Self {
        Todo {
            id: Uuid::new_v4().to_string(),
            title,
            completed: false,
            created_at: Utc::now().to_rfc3339(),
        }
    }
}
```

```rust
// src/database.rs
use crate::models::Todo;

pub struct Database {
    todos: Vec<Todo>,
}

impl Database {
    pub fn new() -> Self {
        Database {
            todos: Vec::new(),
        }
    }

    pub fn add(&mut self, todo: Todo) {
        self.todos.push(todo);
    }

    pub fn list(&self) -> &Vec<Todo> {
        &self.todos
    }
}
```

