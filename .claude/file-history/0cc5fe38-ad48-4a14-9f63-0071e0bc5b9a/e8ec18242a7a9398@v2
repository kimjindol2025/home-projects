## 🔧 Cargo 시스템 마스터하기

### Cargo.toml의 구조

```toml
[package]
name = "my_project"
version = "0.1.0"
edition = "2021"
authors = ["Your Name <email@example.com>"]
description = "A great project"

[dependencies]
rand = "0.8"                                    # 기본 방식
chrono = "0.4"
serde = { version = "1.0", features = ["derive"] }  # 기능 지정
tokio = { version = "1", optional = true }    # 선택적 의존성

[dev-dependencies]
criterion = "0.5"  # 테스트/벤치마크 전용

[features]
default = []
async = ["tokio"]  # 기능 플래그

[profile.release]
opt-level = 3
lto = true
```

### Cargo 명령어 체크리스트

```bash
# 기본 작업
cargo new PROJECT_NAME          # 새 프로젝트 생성
cargo init                      # 기존 디렉토리 초기화
cargo build                     # 컴파일
cargo run                       # 실행
cargo test                      # 테스트 실행

# 의존성 관리
cargo add CRATE_NAME            # 의존성 추가
cargo remove CRATE_NAME         # 의존성 제거
cargo update                    # 의존성 업데이트
cargo tree                      # 의존성 트리 보기
cargo tree --duplicates         # 중복된 의존성 감지

# 배포 및 배포
cargo publish                   # Crates.io에 배포
cargo search KEYWORD            # 크레이트 검색
cargo doc --open                # 문서 생성 및 열기

# 성능 분석
cargo bench                     # 벤치마크 실행
cargo clippy                    # 성능 개선 제안
cargo fmt                       # 코드 포맷팅
```

