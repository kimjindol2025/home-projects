    println!("📊 학습 진도 현황");
    println!("  현재 레벨: {}/{}", progress_level, MAX_LEVEL);

    // 레벨 업 시뮬레이션
    progress_level += 1;
    println!("  레벨 업 성공! 다음 목표 레벨: {}\n", progress_level);

    // ==========================================
    // [1.3] 실습 과제: study_hours 변수
    // ==========================================
    println!("📖 1학기 첫 번째 실습 과제: 학습 시간 추적");
    println!("─────────────────────────────────────────\n");

    let mut study_hours: u32 = 0;
    println!("시작: 학습 시간 = {} 시간", study_hours);

    // 1시간이 지나감
    study_hours += 1;
    println!("1시간 경과 후: {} 시간 ✓", study_hours);

    // 2시간이 지나감
    study_hours += 1;
    println!("2시간 경과 후: {} 시간 ✓", study_hours);

    // 3시간이 지나감
    study_hours += 1;
    println!("3시간 경과 후: {} 시간 ✓", study_hours);

    // 4시간이 지나감
    study_hours += 1;
    println!("4시간 경과 후: {} 시간 ✓", study_hours);

    // 5시간이 지나감
    study_hours += 1;
    println!("5시간 경과 후: {} 시간 ✓\n", study_hours);

    // ==========================================
    // [1.4] Gogs 코딩 표준 검증
    // ==========================================
    println!("🔍 Gogs 코딩 표준 검증");
    println!("─────────────────────────────────────────");
    println!("✅ Strict Typing: 모든 변수에 타입 명시");
    println!("   - version: &str");
    println!("   - progress_level: i32");
    println!("   - MAX_LEVEL: i32");
    println!("   - study_hours: u32");
    println!("");
    println!("✅ Naming Convention: snake_case & SCREAMING_SNAKE_CASE");
    println!("   - student_name (snake_case)");
    println!("   - progress_level (snake_case)");
    println!("   - MAX_LEVEL (SCREAMING_SNAKE_CASE)");
    println!("");
    println!("✅ Documentation: 함수 위에 /// 주석 작성");
    println!("   (다음 과제에서 구현)\n");

    // ==========================================
    // [1.5] 최종 결과 출력
    // ==========================================
    println!("═══════════════════════════════════════════");
    println!("🎓 1학년 1학기 첫 번째 실습 완료!");
    println!("═══════════════════════════════════════════\n");

    // ==========================================
    // [2단계] 제어 흐름 (Control Flow)
    // ==========================================
    println!("🚦 2단계: 제어 흐름 - 시스템의 의사결정\n");

    let current_stage: i32 = 2;
    let is_senior_path: bool = true;

    // [2.1] 조건문: 경로 확인
    println!("📌 [2.1] 조건문 (if/else)");
    println!("────────────────────────────");
    if is_senior_path {
        println!("✅ 시니어 등급을 향한 올바른 경로에 있습니다.");
    } else {
        println!("❌ 경로를 재설정해야 합니다.");
    }
    println!();

    // [2.2] match: 현재 단계별 목표 설정
    println!("📌 [2.2] 패턴 매칭 (match)");
    println!("────────────────────────────");
    let goal: &str = match current_stage {
        1 => "기초 변수 확립",
        2 => "논리 구조 설계",
        3 => "소유권 개념 파악",
        _ => "미지의 영역 탐험",
    };
    println!("현재 단계({}의 목표: {}", current_stage, goal);
    println!();

    // [2.3] for 루프: 1단계부터 현재 단계까지 복습
    println!("📌 [2.3] 반복문 (for loop)");
    println!("────────────────────────────");
    println!("학습 로그 기록 중...");
    for level in 1..=current_stage {
        println!("  ✓ Step {} 완료 기록됨", level);
    }
    println!();

    // [2.4] core.rs의 check_gogs_status 함수 호출
    println!("📌 [2.4] 함수 호출 및 match 활용");
    println!("────────────────────────────");

