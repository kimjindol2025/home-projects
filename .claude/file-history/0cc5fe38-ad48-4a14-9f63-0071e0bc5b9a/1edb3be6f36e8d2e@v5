        let status: &str = core::check_gogs_status(value);
        println!("  value = {} → {}", value, status);
    }
    println!();

    // ==========================================
    // [3단계] 소유권 (Ownership)
    // ==========================================
    println!("💎 3단계: 소유권 (Ownership) - 메모리의 지배자\n");

    // [3.1] 소유권의 이동 (Move)
    println!("📌 [3.1] 소유권의 이동 (Move)");
    println!("────────────────────────────");

    let s1: String = String::from("Gogs Data");
    println!("s1 생성: \"{}\"", s1);

    let s2: String = s1;  // s1의 소유권이 s2로 이동
    println!("s2에 소유권 이동: \"{}\"", s2);
    // println!("s1: {}", s1);  // ❌ 에러! s1은 더 이상 소유권이 없음
    println!("✓ s1의 소유권은 s2로 완전히 이전됨\n");

    // [3.2] 빌려주기 (Borrowing)
    println!("📌 [3.2] 빌려주기 (Borrowing)");
    println!("────────────────────────────");

    let s3: String = String::from("Gogs Learning");
    println!("s3 생성: \"{}\"", s3);

    let len: usize = core::calculate_length(&s3);  // & 기호로 빌려줌
    println!("s3의 길이: {} (참조를 통해 빌림)", len);
    println!("s3은 여전히 소유권 보유: \"{}\" ✓\n", s3);

    // [3.3] 가변 참조 (Mutable Reference)
    println!("📌 [3.3] 가변 참조 (Mutable Reference)");
    println!("────────────────────────────");

    let mut s4: String = String::from("Phase 3");
    println!("s4 생성: \"{}\"", s4);

    core::add_suffix(&mut s4);  // &mut을 사용해 수정 가능하게 빌려줌
    println!("s4 수정 후: \"{}\" ✓\n", s4);

    // [3.4] get_longer 함수 테스트
    println!("📌 [3.4] get_longer 함수 - 더 긴 문자열의 소유권");
    println!("────────────────────────────");

    let str1: String = String::from("Rust");
    let str2: String = String::from("Ownership");

    let longer: String = core::get_longer(&str1, &str2);
    println!("str1: \"{}\"", str1);
    println!("str2: \"{}\"", str2);
    println!("더 긴 문자열: \"{}\" (소유권 반환)", longer);
    println!();

    // ==========================================
    // [4단계] 구조체와 열거형
    // ==========================================
    println!("🏗️ 4단계: 구조체와 열거형 - 데이터 설계\n");

    // [4.1] 구조체 인스턴스 생성
    println!("📌 [4.1] 구조체 (Structs)");
    println!("────────────────────────────");

    let mut student: Developer = Developer {
        name: String::from("Claude Code"),
        level: 3,
        status: ProjectStatus::Active,
    };

    student.display_status();
    student.celebrate_level_up();
    println!();

    // [4.2] 열거형과 패턴 매칭
    println!("📌 [4.2] 열거형 (Enums) & 패턴 매칭");
    println!("────────────────────────────");

    match &student.status {
        ProjectStatus::Active => println!("✅ 현재 프로젝트가 활성화 상태입니다."),
        ProjectStatus::Inactive => println!("⏸️ 프로젝트가 비활성 상태입니다."),
        ProjectStatus::Archived(reason) => {
            println!("📦 보관된 프로젝트입니다. 사유: {}", reason);
        }
    }
    println!();

    // [4.3] core.rs의 Language 구조체 테스트
    println!("📌 [4.3] Language 구조체 & Feature 열거형");
    println!("────────────────────────────");

    let rust_lang: core::Language = core::Language {
        name: String::from("Rust"),
        versatility: 95,
        feature: core::Feature::Safety,
    };

