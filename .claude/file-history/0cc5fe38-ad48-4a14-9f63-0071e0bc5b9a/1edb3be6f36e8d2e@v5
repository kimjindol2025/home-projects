// 러스트 시스템 프로그래밍의 기초
// Phase 1 ~ 4 진행 중
// [저장 필수] 기록이 증명이다 gogs: 프로젝트 진화 로그

mod core;  // core 모듈 임포트

// ==========================================
// [4단계] 구조체와 열거형
// ==========================================

/// 프로젝트의 상태를 나타내는 열거형
#[derive(Debug, Clone)]
enum ProjectStatus {
    Active,
    Inactive,
    Archived(String),  // 보관 사유를 함께 저장
}

/// 개발자 정보를 담는 구조체
#[derive(Debug)]
struct Developer {
    name: String,
    level: u32,
    status: ProjectStatus,
}

/// Developer 구조체의 메서드 정의
impl Developer {
    /// 레벨업을 축하하는 메서드
    fn celebrate_level_up(&mut self) {
        self.level += 1;
        println!("🎉 축하합니다! {}님의 레벨이 {}가 되었습니다.", self.name, self.level);
    }

    /// 현재 상태를 출력하는 메서드
    fn display_status(&self) {
        println!("개발자: {}", self.name);
        println!("레벨: {}", self.level);
    }
}

fn main() {
    println!("╔════════════════════════════════════════╗");
    println!("║ Gogs Project Level 4: Structs & Enums ║");
    println!("║   데이터 설계와 분류                   ║");
    println!("╚════════════════════════════════════════╝\n");

    // ==========================================
    // [1.1] 불변 변수 (기본)
    // ==========================================
    let version: &str = "1.0.0";
    let student_name: &str = "Claude Code";

    println!("✅ 학생: {}", student_name);
    println!("✅ 프로젝트 버전: {}\n", version);

