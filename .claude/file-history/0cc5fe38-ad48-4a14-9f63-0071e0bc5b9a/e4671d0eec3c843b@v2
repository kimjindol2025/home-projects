## 🎯 실전 예제: Language 구조체

```rust
#[derive(Debug)]
pub struct Language {
    pub name: String,
    pub versatility: u8,
    pub feature: Feature,
}

#[derive(Debug, Clone, Copy, PartialEq)]
pub enum Feature {
    Safety,      // Rust, Go
    Speed,       // C, C++
    Simplicity,  // Python
}

impl Language {
    pub fn new(name: &str, versatility: u8, feature: Feature) -> Language {
        Language {
            name: String::from(name),
            versatility,
            feature,
        }
    }

    pub fn display_info(&self) {
        println!("언어: {}", self.name);
        println!("다목적성: {}%", self.versatility);
        println!("특징: {:?}", self.feature);
    }

    pub fn evaluate_versatility(&self) -> &'static str {
        match self.versatility {
            0..=30 => "특수 목적",
            31..=60 => "범용",
            61..=85 => "매우 범용적",
            86..=100 => "거의 모든 분야",
            _ => "불명",
        }
    }
}

// 사용
let rust = Language::new("Rust", 95, Feature::Safety);
rust.display_info();
println!("평가: {}", rust.evaluate_versatility());
```

