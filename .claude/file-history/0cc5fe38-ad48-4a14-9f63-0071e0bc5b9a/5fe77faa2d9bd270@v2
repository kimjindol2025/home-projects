// ────────────────────────────────────────────────────────────────────────
// [섹션 5] 모듈의 공개 범위 계층화: 다층 접근 제어
// ────────────────────────────────────────────────────────────────────────

mod database {
    // 공개 구조
    pub struct Connection {
        pub host: String,
        connected: bool,  // 비공개 필드
    }

    impl Connection {
        // 공개 생성자
        pub fn new(host: String) -> Self {
            Connection {
                host,
                connected: false,
            }
        }

        // 공개 메서드
        pub fn connect(&mut self) {
            println!("  🗄️  [DB] {}에 연결 중...", self.host);
            self.connected = true;
            validate_connection();
        }

        // 공개 메서드
        pub fn query(&self, sql: &str) -> String {
            if self.connected {
                println!("  🗄️  [DB] 쿼리 실행: {}", sql);
                execute_query(sql)
            } else {
                "Connection failed".to_string()
            }
        }

        // 공개 메서드: 비공개 필드 조회
        pub fn is_connected(&self) -> bool {
            self.connected
        }

        // 비공개 메서드: 내부용
        fn disconnect(&mut self) {
            self.connected = false;
        }
    }

    // 비공개 함수: 연결 유효성 검사
    fn validate_connection() {
        println!("  🗄️  [DB] 연결 유효성 검증 완료");
    }

    // 비공개 함수: 쿼리 실행
    fn execute_query(sql: &str) -> String {
        format!("Query result for: {}", sql)
    }
}

// ────────────────────────────────────────────────────────────────────────
// [섹션 6] 모듈 설계 원칙: 응집도와 캡슐화
// ────────────────────────────────────────────────────────────────────────

mod analytics {
    // 공개 인터페이스: 사용자가 호출하는 함수들
    pub fn track_event(event_name: &str, user_id: u32) {
        println!("  📊 [Analytics] 이벤트 기록: {} (User: {})", event_name, user_id);
        collect_data(event_name, user_id);
    }

    pub fn get_stats() -> String {
        println!("  📊 [Analytics] 통계 조회 중...");
        calculate_metrics()
    }

    // 비공개 함수들: 내부 구현 (사용자가 알 필요 없음)
    fn collect_data(event: &str, user_id: u32) {
        serialize_event(event, user_id);
        send_to_server();
    }

    fn serialize_event(event: &str, _user_id: u32) {
        println!("  📊 [Analytics] 이벤트 직렬화: {}", event);
    }

    fn send_to_server() {
        println!("  📊 [Analytics] 서버로 전송");
    }

    fn calculate_metrics() -> String {
        "User Engagement: 85%".to_string()
    }
}

