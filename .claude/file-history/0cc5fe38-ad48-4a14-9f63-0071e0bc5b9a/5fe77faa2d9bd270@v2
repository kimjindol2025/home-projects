mod security {
    pub mod auth {
        pub fn login(username: &str) {
            println!("  🔑 [Auth] {} 사용자 로그인", username);
            verify_credentials();
        }

        fn verify_credentials() {
            println!("  🔑 [Auth] 자격증명 확인 완료");
        }
    }

    pub mod encryption {
        pub fn encrypt(data: &str) -> String {
            println!("  🔐 [Encryption] 데이터 암호화 중: {}", data);
            format!("encrypted_{}", data)
        }
    }
}

// pub use로 하위 모듈을 상위 모듈에서 접근 가능하게 함
