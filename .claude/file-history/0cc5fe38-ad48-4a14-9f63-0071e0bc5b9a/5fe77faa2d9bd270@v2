// ────────────────────────────────────────────────────────────────────────
// [섹션 1] 기본 모듈 정의: 공개(pub)와 비공개 함수
// ────────────────────────────────────────────────────────────────────────

mod core_system {
    // 공개 함수: 외부에서 호출 가능
    pub fn initiate() {
        println!("  ✅ [Public] 시스템 모듈이 활성화되었습니다.");
        check_internal_safety();  // 내부 함수 호출 (모듈 내부이므로 가능)
    }

    // 공개 함수: 상태 확인
    pub fn status() -> &'static str {
        "System Online"
    }

    // 비공개 함수: 외부에서 호출 불가 (캡슐화)
    fn check_internal_safety() {
        println!("  🔒 [Private] 내부 보안 무결성 검사 중...");
        validate_core();
    }

    // 비공개 함수: 핵심 유효성 검사
    fn validate_core() {
        println!("  🔒 [Private] 핵심 시스템 유효성 검증 완료");
    }
}

// ────────────────────────────────────────────────────────────────────────
// [섹션 2] 중첩 모듈: 부모-자식 모듈 구조
// ────────────────────────────────────────────────────────────────────────

mod network {
    // 자식 모듈
    pub mod http {
        pub fn get(url: &str) -> String {
            println!("  📡 [HTTP] GET 요청: {}", url);
            format!("Response from {}", url)
        }

        pub fn post(url: &str, data: &str) -> String {
            println!("  📡 [HTTP] POST 요청: {} (Data: {})", url, data);
            format!("Post response from {}", url)
        }

        // 비공개 함수: 헤더 생성 (내부용)
        fn create_headers() -> String {
            "Content-Type: application/json".to_string()
        }
    }

    // 다른 자식 모듈
    pub mod websocket {
        pub fn connect(server: &str) {
            println!("  🔌 [WebSocket] {}에 연결 중...", server);
            establish_connection();
        }

        fn establish_connection() {
            println!("  🔌 [WebSocket] 연결 성공");
        }
    }

    // 모듈 레벨 함수
    pub fn check_connection() -> bool {
        println!("  🌐 [Network] 연결 상태 확인 중...");
        true
    }
}

