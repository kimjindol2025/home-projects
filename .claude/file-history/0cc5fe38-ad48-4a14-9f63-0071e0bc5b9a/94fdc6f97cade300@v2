// 섹션 7: matches! 매크로 (Advanced Idiom)
// ============================================================================
fn section_7_matches_macro() {
    println!("\n📌 섹션 7: matches! 매크로");
    println!("────────────────────────────────────────");

    enum Color {
        Red,
        Green,
        Blue,
        Custom(u32, u32, u32),
    }

    let color = Color::Red;

    // [관용구] matches! 매크로 - 패턴 매칭 결과를 bool로
    if matches!(color, Color::Red | Color::Green | Color::Blue) {
        println!("  기본 색상 감지");
    }

    let colors = vec![
        Color::Red,
        Color::Green,
        Color::Custom(100, 100, 100),
        Color::Blue,
        Color::Custom(255, 0, 0),
    ];

    // 기본 색상의 개수 세기
    let basic_count = colors.iter().filter(|c| {
        matches!(c, Color::Red | Color::Green | Color::Blue)
    }).count();

    println!("  기본 색상 개수: {}", basic_count);

    // Custom 색상만 필터링
    for color in &colors {
        if let Color::Custom(r, g, b) = color {
            println!("  커스텀 색상: RGB({}, {}, {})", r, g, b);
        }
    }

    println!("\n  🔍 matches! 매크로의 특징:");
    println!("    ✅ 패턴 매칭을 bool 표현식으로");
    println!("    ✅ if/filter에서 간결하게 사용");
    println!("    ✅ 여러 패턴을 | 로 조합");
}

