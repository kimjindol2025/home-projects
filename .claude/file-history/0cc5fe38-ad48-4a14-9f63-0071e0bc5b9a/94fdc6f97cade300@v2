// 섹션 8: 에러 전파와 ? 연산자
// ============================================================================
fn section_8_error_propagation() {
    println!("\n📌 섹션 8: 에러 전파와 ? 연산자");
    println!("────────────────────────────────────────");

    enum ParseError {
        NotANumber,
        RangeError,
    }

    // [관용구] ? 연산자로 에러 전파
    fn parse_and_validate(s: &str) -> Result<i32, ParseError> {
        let num = s.parse::<i32>().map_err(|_| ParseError::NotANumber)?;
        if num >= 0 && num <= 100 {
            Ok(num)
        } else {
            Err(ParseError::RangeError)
        }
    }

    // 중첩된 ? 연산자
    fn process_input(a: &str, b: &str) -> Result<String, ParseError> {
        let x = parse_and_validate(a)?;
        let y = parse_and_validate(b)?;
        Ok(format!("결과: {} + {} = {}", x, y, x + y))
    }

    match process_input("42", "58") {
        Ok(msg) => println!("  ✅ {}", msg),
        Err(ParseError::NotANumber) => println!("  ❌ 숫자가 아님"),
        Err(ParseError::RangeError) => println!("  ❌ 범위 오류 (0~100)"),
    }

    match process_input("150", "42") {
        Ok(msg) => println!("  ✅ {}", msg),
        Err(ParseError::RangeError) => println!("  ❌ 범위 오류 (0~100)"),
        _ => println!("  ❌ 기타 오류"),
    }

    println!("\n  🔍 ? 연산자의 특징:");
    println!("    ✅ Err 시 즉시 반환 (조기 종료)");
    println!("    ✅ 깊은 중첩 없이 선형 코드");
    println!("    ✅ 에러 처리 간결화");
}

