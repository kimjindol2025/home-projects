// 섹션 5: 보안 패킷 분석기 (Security Packet Analyzer)
// ============================================================================
fn section_5_security_packet_analyzer() {
    println!("\n📌 섹션 5: 보안 패킷 분석기");
    println!("────────────────────────────────────────");

    #[derive(Debug, Clone, Copy)]
    enum Protocol {
        TCP,
        UDP,
        ICMP,
    }

    struct Packet {
        id: u32,
        protocol: Protocol,
        payload: Option<String>,
        source_ip: (u8, u8, u8, u8),
    }

    fn analyze_threat(packet: &Packet) {
        // [핵심 설계] 중첩된 구조를 한 번에 분해하고 조건을 검사
        match packet {
            // 특정 IP 대역이면서 페이로드가 존재하는 TCP 패킷
            Packet {
                protocol: Protocol::TCP,
                source_ip: (192, 168, _, _),
                payload: Some(content),
                id,
            } if content.contains("ATTACK") => {
                println!("  🚨 [경보] 내부 네트워크 침입 시도 감지: ID {}", id);
            }

            // 페이로드가 없는 모든 UDP 패킷
            Packet {
                protocol: Protocol::UDP,
                payload: None,
                id,
                ..
            } => {
                println!("  ℹ️  [정보] 빈 UDP 패킷 수신 (ID: {})", id);
            }

            // ICMP는 거의 무해함 (핑 용도)
            Packet {
                protocol: Protocol::ICMP,
                ..
            } => {
                println!("  ✅ [통과] ICMP 패킷 스캔 완료");
            }

            // 그 외 모든 경우
            _ => println!("  ℹ️  [통과] 일반 패킷 스캔 완료"),
        }
    }

    let packets = vec![
        Packet {
            id: 1024,
            protocol: Protocol::TCP,
            payload: Some("ATTACK MALWARE".to_string()),
            source_ip: (192, 168, 1, 50),
        },
        Packet {
            id: 2048,
            protocol: Protocol::UDP,
            payload: None,
            source_ip: (10, 0, 0, 1),
        },
        Packet {
            id: 3072,
            protocol: Protocol::ICMP,
            payload: Some("ping".to_string()),
            source_ip: (8, 8, 8, 8),
        },
    ];

    for packet in &packets {
        analyze_threat(packet);
    }

    println!("\n  🔍 패킷 분석의 기교:");
    println!("    ✅ 복잡한 구조를 단일 match에서 처리");
    println!("    ✅ IP 대역 패턴으로 필터링 (192, 168, _, _)");
    println!("    ✅ 문자열 포함 여부를 가드로 검사");
    println!("    ✅ 정밀한 위협 분류 (경보 vs 정보 vs 통과)");
}

