// 섹션 10: 바인딩 패턴
// ============================================================================
fn section_10_binding_patterns() {
    println!("\n📌 섹션 10: 바인딩 패턴");
    println!("────────────────────────────────────────");

    // [@] 패턴 - 범위 검사 + 값 바인딩
    let age = 25;

    match age {
        age @ 0..=12 => println!("  어린이 ({}세)", age),
        age @ 13..=19 => println!("  청소년 ({}세)", age),
        age @ 20..=64 => println!("  성인 ({}세)", age),
        age => println!("  노인 ({}세)", age),
    }

    // [..] 패턴 - 나머지 무시
    let tuple = (1, 2, 3, 4, 5);
    match tuple {
        (first, .., last) => println!("  첫 번째: {}, 마지막: {}", first, last),
    }

    // 구조체에서 [..] 사용
    struct Config {
        name: String,
        version: String,
        debug: bool,
        timeout: u32,
    }

    let config = Config {
        name: "App".to_string(),
        version: "1.0".to_string(),
        debug: true,
        timeout: 30,
    };

    match config {
        Config { name, debug: true, .. } => {
            println!("  디버그 모드 활성화: {}", name);
        }
        _ => (),
    }

    // [mut] 패턴 - 가변 바인딩
    let optional = Some(42);
    if let Some(mut x) = optional {
        x += 10;
        println!("  수정된 값: {}", x);
    }

    println!("\n  🔍 바인딩 패턴의 특징:");
    println!("    ✅ @ 패턴: 범위 + 변수 동시 바인딩");
    println!("    ✅ .. 패턴: 나머지 무시하기");
    println!("    ✅ mut 패턴: 분해와 동시에 가변화");
}

