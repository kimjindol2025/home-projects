// 섹션 1: 기본 패턴 매칭 (Basic Pattern Matching)
// ============================================================================
fn section_1_basic_pattern_matching() {
    println!("\n📌 섹션 1: 기본 패턴 매칭");
    println!("────────────────────────────────────────");

    #[derive(Debug)]
    enum Direction {
        North,
        South,
        East,
        West,
    }

    let direction = Direction::North;

    match direction {
        Direction::North => println!("  북쪽으로 이동 ⬆️"),
        Direction::South => println!("  남쪽으로 이동 ⬇️"),
        Direction::East => println!("  동쪽으로 이동 ➡️"),
        Direction::West => println!("  서쪽으로 이동 ⬅️"),
    }

    // 숫자 범위 매칭
    let number = 42;
    match number {
        0 => println!("  숫자는 0"),
        1..=10 => println!("  숫자는 1~10 범위"),
        11..=100 => println!("  숫자는 11~100 범위"),
        _ => println!("  숫자는 100 초과"),
    }

    println!("\n  🔍 기본 패턴 매칭의 특징:");
    println!("    ✅ 모든 경우의 수를 명시적으로 처리");
    println!("    ✅ 컴파일러가 exhaustiveness 검사");
    println!("    ✅ 값 비교 + 조건 분기 동시 처리");
}

// ============================================================================
// 섹션 2: 구조체 분해 (Destructuring Structs)
// ============================================================================
fn section_2_destructuring_structs() {
    println!("\n📌 섹션 2: 구조체 분해");
    println!("────────────────────────────────────────");

    #[derive(Debug)]
    struct Point {
        x: i32,
        y: i32,
        z: i32,
    }

    let point = Point { x: 10, y: 20, z: 30 };

    // 패턴을 사용한 분해
    match point {
        Point { x: 0, y: 0, z } => println!("  원점 근처 (z = {})", z),
        Point { x, y, z: 0 } => println!("  z축 제외 평면 ({}, {})", x, y),
        Point { x, y, z } if x > 15 => println!("  x > 15인 점: ({}, {}, {})", x, y, z),
        _ => println!("  일반 점"),
    }

    // 중첩된 구조체 분해
    struct Rectangle {
        top_left: Point,
        bottom_right: Point,
    }

    let rect = Rectangle {
        top_left: Point { x: 0, y: 100, z: 0 },
        bottom_right: Point { x: 100, y: 0, z: 0 },
    };

    match rect {
        Rectangle {
            top_left: Point { x: 0, y: y1, z: 0 },
            bottom_right: Point { x: x2, y: 0, z: 0 },
        } => println!("  축정렬 사각형: ({}, {})", x2, y1),
        _ => println!("  일반 사각형"),
    }

    println!("\n  🔍 구조체 분해의 특징:");
    println!("    ✅ 중첩된 구조체도 한 번에 분해");
    println!("    ✅ 필요한 필드만 추출 가능");
    println!("    ✅ .. 문법으로 나머지 무시");
}

