// 섹션 9: 함수형 프로그래밍 스타일
// ============================================================================
fn section_9_functional_style() {
    println!("\n📌 섹션 9: 함수형 프로그래밍 스타일");
    println!("────────────────────────────────────────");

    // [관용구] and_then으로 체인 구성
    let value = Some(5);

    let result = value
        .and_then(|x| {
            if x > 0 { Some(x * 2) } else { None }
        })
        .and_then(|x| {
            if x < 20 { Some(x + 10) } else { None }
        });

    println!("  and_then 결과: {:?}", result);

    // [관용구] map으로 값 변환 체인
    let numbers = vec![1, 2, 3, 4, 5];

    let transformed: Vec<i32> = numbers
        .iter()
        .filter(|n| *n % 2 == 0)
        .map(|n| n * 2)
        .collect();

    println!("  변환된 값: {:?}", transformed);

    // [관용구] Option과 Result의 조합
    fn divide(a: i32, b: i32) -> Option<i32> {
        if b != 0 { Some(a / b) } else { None }
    }

    let calc = divide(10, 2)
        .and_then(|x| divide(x, 2))
        .map(|x| x + 5);

    println!("  연쇄 계산: {:?}", calc);

    println!("\n  🔍 함수형 스타일의 특징:");
    println!("    ✅ 명령형(how) → 선언형(what)");
    println!("    ✅ and_then, map으로 체인 구성");
    println!("    ✅ 중간 상태를 변수에 저장하지 않음");
}

