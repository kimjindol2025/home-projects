// 섹션 3: 열거형 분해 (Enum Destructuring)
// ============================================================================
fn section_3_destructuring_enums() {
    println!("\n📌 섹션 3: 열거형 분해");
    println!("────────────────────────────────────────");

    enum Message {
        Quit,
        Move { x: i32, y: i32 },
        Write(String),
        ChangeColor(i32, i32, i32),
    }

    let messages = vec![
        Message::Quit,
        Message::Move { x: 50, y: 100 },
        Message::Write("Hello".to_string()),
        Message::ChangeColor(255, 0, 0),
    ];

    for message in messages {
        match message {
            Message::Quit => println!("  프로그램 종료"),
            Message::Move { x, y } => println!("  ({}, {})로 이동", x, y),
            Message::Write(text) => println!("  메시지: {}", text),
            Message::ChangeColor(r, g, b) => println!("  색상 변경: RGB({}, {}, {})", r, g, b),
        }
    }

    println!("\n  🔍 열거형 분해의 특징:");
    println!("    ✅ 각 variant별 다른 데이터 구조");
    println!("    ✅ 변수 바인딩으로 내부 값 추출");
    println!("    ✅ 모든 경우를 강제로 처리");
}

