// 섹션 11: 성능과 컴파일러 최적화
// ============================================================================
fn section_11_performance_optimization() {
    println!("\n📌 섹션 11: 성능과 컴파일러 최적화");
    println!("────────────────────────────────────────");

    use std::time::Instant;

    enum Message {
        Small(u32),
        Medium(String),
        Large(Vec<u32>),
    }

    // 패턴 매칭 성능 테스트
    let messages: Vec<Message> = (0..1_000_000)
        .map(|i| {
            match i % 3 {
                0 => Message::Small(i),
                1 => Message::Medium(format!("msg{}", i)),
                _ => Message::Large(vec![i; 10]),
            }
        })
        .collect();

    // match 성능
    let start = Instant::now();
    for msg in &messages {
        match msg {
            Message::Small(n) => { let _ = n + 1; }
            Message::Medium(_) => { let _ = (); }
            Message::Large(v) => { let _ = v.len(); }
        }
    }
    let match_time = start.elapsed();

    // if let 성능
    let start = Instant::now();
    for msg in &messages {
        if let Message::Small(n) = msg {
            let _ = n + 1;
        }
    }
    let if_let_time = start.elapsed();

    println!("  성능 측정 (1M 메시지 처리):");
    println!("    match:   {:.3}ms", match_time.as_secs_f64() * 1000.0);
    println!("    if let:  {:.3}ms", if_let_time.as_secs_f64() * 1000.0);

    println!("\n  💡 결과:");
    println!("    match은 점프 테이블로 최적화됨");
    println!("    패턴 매칭은 if-else보다 빠름");
    println!("    컴파일러가 exhaustiveness 검사로 안전성 보장");
}

