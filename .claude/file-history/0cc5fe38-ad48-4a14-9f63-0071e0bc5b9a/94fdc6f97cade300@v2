// 섹션 4: 매치 가드 (Match Guard)
// ============================================================================
fn section_4_match_guards() {
    println!("\n📌 섹션 4: 매치 가드");
    println!("────────────────────────────────────────");

    enum Status {
        Ready,
        Running { progress: u32 },
        Error { code: u32 },
        Idle,
    }

    let statuses = vec![
        Status::Ready,
        Status::Running { progress: 50 },
        Status::Running { progress: 100 },
        Status::Error { code: 404 },
        Status::Error { code: 500 },
        Status::Idle,
    ];

    for status in statuses {
        match status {
            // 매치 가드: 추가 조건을 if로 검사
            Status::Running { progress } if progress >= 100 => {
                println!("  ✅ 작업 완료!");
            }
            Status::Running { progress } if progress < 50 => {
                println!("  🟡 작업 진행 중 ({}%)", progress);
            }
            Status::Running { progress } => {
                println!("  🟠 작업 진행 중 ({}%)", progress);
            }
            Status::Error { code } if code >= 500 => {
                println!("  🔴 심각한 에러 ({})", code);
            }
            Status::Error { code } => {
                println!("  🟡 일반 에러 ({})", code);
            }
            Status::Ready => println!("  준비 중..."),
            Status::Idle => println!("  대기 중"),
        }
    }

    println!("\n  🔍 매치 가드의 특징:");
    println!("    ✅ 패턴 + 조건을 동시에 검사");
    println!("    ✅ 범위, 비교, 함수 호출 등 복합 조건 가능");
    println!("    ✅ 중복 패턴을 세밀하게 분류");
}

