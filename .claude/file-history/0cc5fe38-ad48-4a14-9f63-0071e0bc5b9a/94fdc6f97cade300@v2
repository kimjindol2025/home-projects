// 섹션 6: if let, while let (관용적 Rust)
// ============================================================================
fn section_6_if_let_while_let() {
    println!("\n📌 섹션 6: if let, while let");
    println!("────────────────────────────────────────");

    let optional_value = Some(42);

    // [관용구 1] if let - 특정 경우만 처리
    if let Some(value) = optional_value {
        println!("  Some 값 발견: {}", value);
    }

    // match와 비교
    match optional_value {
        Some(v) => println!("  Some 값 발견: {}", v),
        None => (),
    }

    // [관용구 2] while let - 특정 패턴이 맞을 때까지 반복
    let mut queue = vec![Some(1), Some(2), None, Some(3), Some(4)];

    println!("\n  while let 반복:");
    while let Some(Some(value)) = queue.pop() {
        println!("    처리: {}", value);
    }

    // [관용구 3] if let 체인 + match guard 효과
    let value = Some(42);
    if let Some(n) = value {
        if n > 0 {
            println!("  양수: {}", n);
        }
    }

    // [관용구] 더 간결한 방식 - 가드와 유사한 표현
    if let Some(n) = value {
        match n {
            n if n > 0 => println!("  조건부 표현: {}", n),
            _ => (),
        }
    }

    println!("\n  🔍 관용구의 특징:");
    println!("    ✅ if let: match보다 간결한 단일 패턴");
    println!("    ✅ while let: 반복 조건으로 패턴 사용");
    println!("    ✅ 코드 가독성 ↑, 중첩 ↓");
}

