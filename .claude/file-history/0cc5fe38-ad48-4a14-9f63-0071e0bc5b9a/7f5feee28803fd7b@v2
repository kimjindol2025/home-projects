    println!("  {}", summary2.summarize());

    println!("\n💡 impl Trait의 핵심:");
    println!("   \"어떤 타입인지는 비밀이지만, Summary는 구현되어 있어\"");

    // ─────────────────────────────────────────
    // Step 5: impl Trait + 다중 트레이트
    // ─────────────────────────────────────────
    println!("\n▶ Step 5: impl Trait + 다중 트레이트\n");

    let displayable = create_displayable_summary();
    println!("Summary + Display를 모두 구현:");
