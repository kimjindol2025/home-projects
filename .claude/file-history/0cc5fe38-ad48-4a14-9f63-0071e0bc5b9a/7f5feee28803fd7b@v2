use std::fmt::Display;

// ===================================================================
// [준비 단계] 핵심 트레이트 정의
// ===================================================================

/// 요약 기능: 데이터의 핵심 정보를 문자열로 표현
trait Summary {
    fn summarize(&self) -> String;
}

/// 상세 정보: 더 자세한 내용을 제공
trait Detailed {
    fn details(&self) -> String;
}

/// 보안 수준: 데이터의 민감도를 표현
trait SecurityLevel {
    fn level(&self) -> u8;
}

/// 직렬화: 데이터를 특정 형식으로 변환
trait Serializable {
    fn serialize(&self) -> String;
}

// ===================================================================
// [구현체 1] Gogs 리포트
// ===================================================================

/// Gogs 시스템에서 생성된 보안 리포트
struct GogsReport {
    id: u32,
    title: String,
    content: String,
    clearance: u8,
}

impl GogsReport {
    fn new(id: u32, title: &str, content: &str, clearance: u8) -> Self {
        GogsReport {
            id,
            title: title.to_string(),
            content: content.to_string(),
            clearance,
        }
    }
}

impl Summary for GogsReport {
    fn summarize(&self) -> String {
        format!("[Report#{}] {}", self.id, self.title)
    }
}

impl Detailed for GogsReport {
    fn details(&self) -> String {
        format!(
            "ID: {}\nTitle: {}\nContent: {}\nClearance: {}",
            self.id, self.title, self.content, self.clearance
        )
    }
}

impl SecurityLevel for GogsReport {
    fn level(&self) -> u8 {
        self.clearance
    }
}

impl Display for GogsReport {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        write!(f, "GogsReport({})", self.title)
    }
}

impl Serializable for GogsReport {
    fn serialize(&self) -> String {
        format!(
            "{{\"id\":{},\"title\":\"{}\",\"level\":{}}}",
            self.id, self.title, self.clearance
        )
    }
}

