// ===================================================================
// [Step 8] where절을 이용한 가독성 확보
// ===================================================================

/// 기본 경계 (직접 표기)
fn print_summary<T: Summary>(item: &T) {
    println!("📝 {}", item.summarize());
}

/// 다중 경계 (직접 표기 - 가독성 감소)
fn process_simple<T: Summary + Display>(item: &T) {
    println!("처리: {} → {}", item.summarize(), item);
}

/// [Step 8-1] where절 사용: 가독성 향상
///
/// 함수 선언부가 깔끔해져 함수의 본질(이름)에 집중 가능
fn process_with_where<T>(item: &T)
where
    T: Summary + Display,
{
    println!("처리: {} → {}", item.summarize(), item);
}

/// [Step 8-2] 다중 제네릭 + 복잡한 조건 = where절 필수
///
/// 함수 선언부가 매우 복잡해지므로 where절로 정리
fn synchronize<T, U>(primary: &T, secondary: &U)
where
    T: Summary + Detailed + SecurityLevel + Display,
    U: SecurityLevel + Serializable,
{
    println!("▶ 동기화 시작");
    println!("  주요 시스템: {}", primary.summarize());
    println!("  백업 시스템: Level {}", secondary.level());
}

/// [Step 8-3] 복잡한 조건의 가독성: where절이 없으면 불가능
///
/// 함수 이름이 완전히 가려짐
fn advanced_analysis<T, U, V>(a: &T, b: &U, c: &V)
where
    T: Summary + Detailed + SecurityLevel + Display,
    U: Serializable + SecurityLevel,
    V: Summary + Serializable,
{
    println!("▶ 고급 분석");
    println!("  A: {} (Level: {})", a.summarize(), a.level());
    println!("  B: 직렬화 -> {}", b.serialize());
    println!("  C: {} -> {}", c.summarize(), c.serialize());
}

/// [Step 8-4] where절과 조건부 경계
///
/// 특정 타입에 대해서만 추가 경계를 설정
fn conditional_process<T, U>(item: &T, helper: &U)
where
    T: Summary + SecurityLevel,
    U: Serializable,
    U: Display, // U가 Display도 구현해야 함
{
    println!("조건부 처리: {}", item.summarize());
    if item.level() > 5 {
        println!("  Helper: {}", helper);
    }
}

// ===================================================================
// [Step 9] 반환 타입으로서의 트레이트 (impl Trait)
// ===================================================================

/// [Step 9-1] impl Trait: 기본형
///
/// "GogsReport를 반환하는지 SystemLog를 반환하는지 호출자는 모름"
/// "하지만 Summary 트레이트는 반드시 구현되어 있음을 보장"
fn create_gogs_report(title: &str) -> impl Summary {
    GogsReport::new(1001, title, "Internal content", 5)
}

/// [Step 9-2] impl Trait: 조건에 따른 다른 구현체 (같은 트레이트)
///
/// 주의: 이것도 impl Trait의 범위 내에서 가능
fn create_summary_by_level(level: u8) -> impl Summary {
    if level > 7 {
        // 고보안: GogsReport 사용
        GogsReport::new(
            2001,
            "High-Security Report",
            "Encrypted data",
            level,
        )
    } else {
        // 저보안: SystemLog 사용 (같은 Summary 트레이트)
        SystemLog::new("2024-01-01", "Normal log", level)
    }
}

/// [Step 9-3] impl Trait: 여러 트레이트를 만족하는 반환
///
/// "이것은 Summary이면서 동시에 Display도 되어야 한다"
fn create_displayable_summary() -> impl Summary + Display {
    GogsReport::new(3001, "Displayable Report", "Content", 6)
}

/// [Step 9-4] impl Trait과 내부 구현 격리
///
/// 나중에 GogsReport 대신 다른 구현체를 반환해도
/// 호출하는 쪽의 코드는 전혀 바뀌지 않음
fn create_secure_document(content: &str) -> impl Summary + SecurityLevel {
    GogsReport::new(4001, "Secure Doc", content, 8)
}

/// [Step 9-5] 배열이나 컬렉션에서 impl Trait 활용
///
/// 각 원소가 Summary를 구현한다는 것만 알고 구체적 타입은 모름
fn create_multiple_summaries() -> impl IntoIterator<Item = impl Summary> {
    vec![
        Box::new(GogsReport::new(5001, "Report 1", "Content 1", 5))
            as Box<dyn Summary>,
        Box::new(SystemLog::new("2024-01-02", "Event", 4)) as Box<dyn Summary>,
        Box::new(AlertMessage::new(5003, "Alert", 7)) as Box<dyn Summary>,
    ]
}

/// [Step 9-6] impl Trait의 가장 큰 장점: 내부 구현 변경
///
/// 이 함수의 반환형이 GogsReport라고 명시하지 않으므로
/// 나중에 다른 구현체로 바꿔도 호출자는 영향받지 않음
fn fetch_latest_report() -> impl Summary + Detailed {
    GogsReport::new(
        6001,
        "Latest Report",
        "This is the most recent report",
        7,
    )
}

// ===================================================================
// [Step 9 vs Box<dyn Trait>의 차이]
// ===================================================================

/// Box<dyn Trait>: 동적 디스패치
fn create_boxed_summary() -> Box<dyn Summary> {
    Box::new(GogsReport::new(7001, "Boxed Report", "Content", 5))
}

/// impl Trait: 정적 디스패치 (더 빠름, 타입 정보 컴파일 타임에 결정)
fn create_impl_summary() -> impl Summary {
    GogsReport::new(8001, "Impl Report", "Content", 5)
}

