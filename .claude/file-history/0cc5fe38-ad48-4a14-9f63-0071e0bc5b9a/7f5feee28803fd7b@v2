    // ─────────────────────────────────────────
    println!("▶ Step 1: 직접 경계 vs where절\n");

    println!("[직접 경계 방식]");
    process_simple(&report);

    println!("\n[where절 방식]");
    process_with_where(&report);

    println!("\n💡 where절의 장점:");
    println!("   함수 선언부: fn process_with_where<T>(item: &T)");
    println!("   ↑ 함수의 본질(이름)이 명확함!");
    println!("   조건들은 where절로 이동됨\n");

    // ─────────────────────────────────────────
