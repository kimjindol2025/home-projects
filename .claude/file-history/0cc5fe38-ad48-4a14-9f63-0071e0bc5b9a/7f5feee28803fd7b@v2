// 추가 학습: where절과 impl Trait의 고급 활용
// ===================================================================

/*

[where절의 강력함]
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

1. 가독성 개선
   ❌ fn process<T: Clone+Debug+Display, U: Serialize+Deserialize, V: Sync+Send>(a:T, b:U, c:V)
   ✅ fn process<T, U, V>(a: T, b: U, c: V)
      where
          T: Clone + Debug + Display,
          U: Serialize + Deserialize,
          V: Sync + Send,

2. 조건부 경계
   fn special<T>(item: T)
   where
       T: Clone,
       T: Debug,  // T가 Clone이고 Debug여야 함

3. 더 복잡한 조건
   fn complex<T, U>(a: T, b: U)
   where
       T: From<U>,      // T가 U로부터 변환 가능
       U: Display,      // U는 Display 가능
       T::Error: Debug, // T의 오류 타입이 Debug 가능


[impl Trait의 경계]
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

✅ impl Trait으로 가능:
   fn create() -> impl Summary { GogsReport { ... } }

✅ 다중 트레이트:
   fn create() -> impl Summary + Display { ... }

❌ impl Trait으로 불가능 (조건부로 다른 타입 반환):
   fn create(flag: bool) -> impl Summary {
       if flag {
           GogsReport { ... }      // ❌ 타입 1
       } else {
           SystemLog { ... }       // ❌ 타입 2 (다름)
       }
   }
   → 두 타입은 다르므로 같은 impl Trait으로 표현 불가
   → 해결책: Box<dyn Summary> 사용

✅ 같은 타입의 조건부 초기화:
   fn create(level: u8) -> impl Summary {
       let content = if level > 5 { "High" } else { "Low" };
       GogsReport { ... }  // 항상 같은 타입
