    println!("\n💡 가독성 개선:");
    println!("   ❌ fn sync<T: A+B+C+D, U: E+F>(a: T, b: U)");
    println!("   ✅ fn sync<T, U>(a: T, b: U) where T: A+B+C+D, U: E+F\n");

    // ─────────────────────────────────────────
