// 러스트 시스템 프로그래밍의 기초
// 1학년 1학기 → 2학기 진행 중
// [저장 필수] 기록이 증명이다 gogs: 프로젝트 진화 로그

mod core;  // core 모듈 임포트

fn main() {
    println!("╔════════════════════════════════════════╗");
    println!("║ Gogs Project Level 2: Control Flow    ║");
    println!("║   제어 흐름 - 시스템의 의사결정        ║");
    println!("╚════════════════════════════════════════╝\n");

    // ==========================================
    // [1.1] 불변 변수 (기본)
    // ==========================================
    let version: &str = "1.0.0";
    let student_name: &str = "Claude Code";

    println!("✅ 학생: {}", student_name);
    println!("✅ 프로젝트 버전: {}\n", version);

    // ==========================================
    // [1.2] 가변 변수 (mut 키워드 사용)
    // ==========================================
    let mut progress_level: i32 = 1;
    const MAX_LEVEL: i32 = 10;

    println!("📊 학습 진도 현황");
    println!("  현재 레벨: {}/{}", progress_level, MAX_LEVEL);

    // 레벨 업 시뮬레이션
    progress_level += 1;
    println!("  레벨 업 성공! 다음 목표 레벨: {}\n", progress_level);

    // ==========================================
    // [1.3] 실습 과제: study_hours 변수
    // ==========================================
    println!("📖 1학기 첫 번째 실습 과제: 학습 시간 추적");
    println!("─────────────────────────────────────────\n");

    let mut study_hours: u32 = 0;
    println!("시작: 학습 시간 = {} 시간", study_hours);

    // 1시간이 지나감
    study_hours += 1;
    println!("1시간 경과 후: {} 시간 ✓", study_hours);

    // 2시간이 지나감
    study_hours += 1;
    println!("2시간 경과 후: {} 시간 ✓", study_hours);

    // 3시간이 지나감
    study_hours += 1;
    println!("3시간 경과 후: {} 시간 ✓", study_hours);

    // 4시간이 지나감
    study_hours += 1;
    println!("4시간 경과 후: {} 시간 ✓", study_hours);

    // 5시간이 지나감
    study_hours += 1;
    println!("5시간 경과 후: {} 시간 ✓\n", study_hours);

    // ==========================================
    // [1.4] Gogs 코딩 표준 검증
    // ==========================================
    println!("🔍 Gogs 코딩 표준 검증");
    println!("─────────────────────────────────────────");
    println!("✅ Strict Typing: 모든 변수에 타입 명시");
    println!("   - version: &str");
    println!("   - progress_level: i32");
    println!("   - MAX_LEVEL: i32");
    println!("   - study_hours: u32");
    println!("");
    println!("✅ Naming Convention: snake_case & SCREAMING_SNAKE_CASE");
    println!("   - student_name (snake_case)");
    println!("   - progress_level (snake_case)");
    println!("   - MAX_LEVEL (SCREAMING_SNAKE_CASE)");
    println!("");
    println!("✅ Documentation: 함수 위에 /// 주석 작성");
    println!("   (다음 과제에서 구현)\n");

    // ==========================================
    // [1.5] 최종 결과 출력
    // ==========================================
    println!("═══════════════════════════════════════════");
    println!("🎓 1학년 1학기 첫 번째 실습 완료!");
    println!("═══════════════════════════════════════════\n");

    // ==========================================
    // [2단계] 제어 흐름 (Control Flow)
    // ==========================================
    println!("🚦 2단계: 제어 흐름 - 시스템의 의사결정\n");

    let current_stage: i32 = 2;
    let is_senior_path: bool = true;

    // [2.1] 조건문: 경로 확인
    println!("📌 [2.1] 조건문 (if/else)");
    println!("────────────────────────────");
    if is_senior_path {
        println!("✅ 시니어 등급을 향한 올바른 경로에 있습니다.");
    } else {
        println!("❌ 경로를 재설정해야 합니다.");
    }
    println!();

    // [2.2] match: 현재 단계별 목표 설정
    println!("📌 [2.2] 패턴 매칭 (match)");
    println!("────────────────────────────");
    let goal: &str = match current_stage {
        1 => "기초 변수 확립",
        2 => "논리 구조 설계",
        3 => "소유권 개념 파악",
        _ => "미지의 영역 탐험",
    };
    println!("현재 단계({}의 목표: {}", current_stage, goal);
    println!();

    // [2.3] for 루프: 1단계부터 현재 단계까지 복습
    println!("📌 [2.3] 반복문 (for loop)");
    println!("────────────────────────────");
    println!("학습 로그 기록 중...");
    for level in 1..=current_stage {
        println!("  ✓ Step {} 완료 기록됨", level);
    }
    println!();

    // [2.4] core.rs의 check_gogs_status 함수 호출
    println!("📌 [2.4] 함수 호출 및 match 활용");
    println!("────────────────────────────");

    let test_values: [i32; 4] = [7, 10, 15, 5];
    println!("Gogs Status 체크:");
    for &value in &test_values {
        let status: &str = core::check_gogs_status(value);
        println!("  value = {} → {}", value, status);
    }
    println!();

    // ==========================================
    // [3단계] 소유권 (Ownership)
    // ==========================================
    println!("💎 3단계: 소유권 (Ownership) - 메모리의 지배자\n");

    // [3.1] 소유권의 이동 (Move)
    println!("📌 [3.1] 소유권의 이동 (Move)");
    println!("────────────────────────────");

    let s1: String = String::from("Gogs Data");
    println!("s1 생성: \"{}\"", s1);

    let s2: String = s1;  // s1의 소유권이 s2로 이동
    println!("s2에 소유권 이동: \"{}\"", s2);
    // println!("s1: {}", s1);  // ❌ 에러! s1은 더 이상 소유권이 없음
    println!("✓ s1의 소유권은 s2로 완전히 이전됨\n");

    // [3.2] 빌려주기 (Borrowing)
    println!("📌 [3.2] 빌려주기 (Borrowing)");
    println!("────────────────────────────");

    let s3: String = String::from("Gogs Learning");
    println!("s3 생성: \"{}\"", s3);

    let len: usize = core::calculate_length(&s3);  // & 기호로 빌려줌
    println!("s3의 길이: {} (참조를 통해 빌림)", len);
    println!("s3은 여전히 소유권 보유: \"{}\" ✓\n", s3);

    // [3.3] 가변 참조 (Mutable Reference)
    println!("📌 [3.3] 가변 참조 (Mutable Reference)");
    println!("────────────────────────────");

    let mut s4: String = String::from("Phase 3");
    println!("s4 생성: \"{}\"", s4);

    core::add_suffix(&mut s4);  // &mut을 사용해 수정 가능하게 빌려줌
    println!("s4 수정 후: \"{}\" ✓\n", s4);

    // [3.4] get_longer 함수 테스트
    println!("📌 [3.4] get_longer 함수 - 더 긴 문자열의 소유권");
    println!("────────────────────────────");

    let str1: String = String::from("Rust");
    let str2: String = String::from("Ownership");

    let longer: String = core::get_longer(&str1, &str2);
    println!("str1: \"{}\"", str1);
    println!("str2: \"{}\"", str2);
    println!("더 긴 문자열: \"{}\" (소유권 반환)", longer);
    println!();

    // ==========================================
    // [최종] 학습 진도 통합 보고
    // ==========================================
    println!("═══════════════════════════════════════════");
    println!("📊 학습 진도 통합 보고");
    println!("═══════════════════════════════════════════");
    println!("1학기 완료: 변수와 불변성 ✅");
    println!("2학기 완료: 제어 흐름 ✅");
    println!("3단계 진행: 소유권 🚀");
    println!("");
    println!("✅ 습득한 기술:");
    println!("   Phase 1: 변수, 불변성, 강타입");
    println!("   Phase 2: if/else, match, for/while/loop");
    println!("   Phase 3: Move, Borrowing, References");
    println!("");
    println!("3단계 핵심 학습:");
    println!("   · 소유권의 이동 (Move)");
    println!("   · 빌려주기 (Borrowing) - 불변 참조");
    println!("   · 가변 참조 (Mutable Reference)");
    println!("   · 빌림 검사기 (Borrow Checker) 통과");
    println!("");
    println!("총 학습 시간: {} 시간", study_hours);
    println!("현재 진도: Level {}/{}", progress_level, MAX_LEVEL);
    println!("");
    println!("저장 필수, 너는 기록이 증명이다 gogs 🔥");
    println!("═══════════════════════════════════════════\n");
}
