// ║                                                              ║
// ║     언어 설계 프로젝트: 제2장 심화 - 조건문의 정밀 설계       ║
// ║                                                              ║
// ║  "단순한 분기를 넘어, 복합적인 상황을 판단하는 능력"        ║
// ║                                                              ║
// ║  v3.1: 복합 조건식과 표현식으로서의 IF                      ║
// ║                                                              ║
// ╚══════════════════════════════════════════════════════════════╝

fn main() {
    println!("\n╔══════════════════════════════════════════════════════════════╗");
    println!("║                                                              ║");
    println!("║     🎯 v3.1: 조건문의 정밀 설계 (Multi-layered Decisions)  ║");
    println!("║                                                              ║");
    println!("║     언어가 '판단력'을 갖는 순간                             ║");
    println!("║     복합적인 상황을 분석하고 최적의 경로를 선택한다.        ║");
    println!("║                                                              ║");
    println!("╚══════════════════════════════════════════════════════════════╝\n");

    // ══════════════════════════════════════════════════════════════
    // [v3.1 설계 철학]
    // ══════════════════════════════════════════════════════════════
    //
    // v3.0: "맞다" vs "틀리다" (이진 결정)
    // v3.1: "복합적 상황"을 여러 조건으로 분석 (다층 결정)
    //
    // v3.1에서 추가되는 개념:
    // 1. 복합 조건식 (&&, ||)
    // 2. 표현식으로서의 IF (값 반환)
    // 3. Short-circuiting (효율성)
    // 4. 타입 일치 검증 (안전성)
    //

    println!("═══════════════════════════════════════════════════════════════");
    println!("🎯 [v3.1 설계 목표]\n");

    println!("1️⃣ 복합 조건식: 여러 상황을 동시에 고려");
    println!("   → && (AND): 모든 조건이 참이어야 참");
    println!("   → || (OR): 하나의 조건만 참이면 참\n");

    println!("2️⃣ 표현식으로서의 IF: 조건의 결과를 변수에 할당");
    println!("   → let x = if condition {{ ... }} else {{ ... }};");
    println!("   → 불변성(Immutability) 유지\n");

    println!("3️⃣ 무결성 검증: 모든 경로가 포착되었는가");
    println!("   → if-else if-else 체인의 완성");
    println!("   → 누락된 시나리오 없음\n");

    println!("4️⃣ Short-circuiting: 불필요한 연산 생략");
    println!("   → false && (복잡한 연산) → 뒤는 계산 안 함");
    println!("   → true || (복잡한 연산) → 뒤는 계산 안 함\n");

    // ══════════════════════════════════════════════════════════════
    // [부분 1] 복합 조건식 (&&, ||)
    // ══════════════════════════════════════════════════════════════
    //
    // && (AND): 모든 조건이 참이어야 결과가 참
    // || (OR): 하나의 조건이 참이면 결과가 참
    //
    // 우선순위: && > ||
    // a || b && c  →  a || (b && c)
    //

    println!("═══════════════════════════════════════════════════════════════");
    println!("▶ [부분 1] 복합 조건식: && (AND) 와 || (OR)\n");

    let access_level: i32 = 5;
    let is_admin: bool = true;
    let system_online: bool = true;
    let is_maintenance: bool = false;

    println!("시나리오 설정:");
    println!("  access_level: {} (권한 레벨)", access_level);
    println!("  is_admin: {} (관리자 여부)", is_admin);
    println!("  system_online: {} (시스템 온라인)", system_online);
    println!("  is_maintenance: {} (유지보수 모드)", is_maintenance);
    println!();

    // ─────────────────────────────────────────────────────────────
    // [AND 연산자 (&&)]
    // ─────────────────────────────────────────────────────────────

    println!("실행 1: AND 조건 (&&) - '모든 조건이 참이어야 함'");
    println!();

    // 조건 1: 관리자이면서 && 시스템이 온라인
    let admin_with_system: bool = is_admin && system_online;
    println!("  is_admin && system_online = {}",
             admin_with_system);
    println!("    → 설명: 관리자이면서 시스템이 온라인이어야만 true\n");

    // 조건 2: 권한이 높으면서 && 유지보수 모드가 아님
    let high_access_and_operational: bool = access_level > 3 && !is_maintenance;
    println!("  access_level > 3 && !is_maintenance = {}",
             high_access_and_operational);
    println!("    → 설명: 권한이 높으면서 유지보수 중이 아니어야 true\n");

    // ─────────────────────────────────────────────────────────────
    // [OR 연산자 (||)]
    // ─────────────────────────────────────────────────────────────

    println!("실행 2: OR 조건 (||) - '하나의 조건이 참이면 됨'");
    println!();

    // 조건 1: 관리자이거나 || 권한 레벨이 높거나
    let elevated_access: bool = is_admin || access_level > 7;
    println!("  is_admin || access_level > 7 = {}",
             elevated_access);
    println!("    → 설명: 관리자이거나 권한이 매우 높으면 true\n");

    // 조건 2: 시스템이 온라인이거나 || 유지보수 모드
    let system_active: bool = system_online || is_maintenance;
    println!("  system_online || is_maintenance = {}",
             system_active);
    println!("    → 설명: 시스템이 활성화되어 있으면 true\n");

    // ─────────────────────────────────────────────────────────────
    // [우선순위: && 가 || 보다 먼저]
    // ─────────────────────────────────────────────────────────────

    println!("실행 3: 우선순위 검증");
    println!();

    // 표현식: a || b && c
    // 해석 1 (잘못): (a || b) && c = (true || true) && true = true
    // 해석 2 (올바름): a || (b && c) = true || (true && true) = true
    let a: bool = true;
    let b: bool = true;
    let c: bool = true;

    println!("  a || b && c 에서:");
    println!("    a={}, b={}, c={}", a, b, c);
    println!("    해석: a || (b && c) = {} || ({} && {}) = {}",
             a, b, c, a || (b && c));
    println!("    → && 가 먼저 계산됨!\n");

    // ══════════════════════════════════════════════════════════════
    // [부분 2] 표현식으로서의 IF (값 할당)
    // ══════════════════════════════════════════════════════════════
    //
    // v3.0: if는 "명령문" (statement)
    // v3.1: if는 "표현식" (expression)
    //
    // 명령문 vs 표현식:
    // - 명령문: 값을 반환하지 않음 (끝에 ;)
    // - 표현식: 값을 반환함 (끝에 ;이 없음)
    //
    // Rust의 철학: 표현식을 우선한다 (functional style)
    //

    println!("═══════════════════════════════════════════════════════════════");
    println!("▶ [부분 2] 표현식으로서의 IF (값 할당과 불변성)\n");

    println!("개념: if/else의 결과를 직접 변수에 할당\n");

    // ─────────────────────────────────────────────────────────────
    // [실행 1] 복합 조건으로 보안 권한 결정
    // ─────────────────────────────────────────────────────────────

    println!("실행 1: 보안 권한 결정\n");

    let security_clearance: &str = if is_admin && system_online {
        "Full Access Granted"
    } else if access_level > 3 || system_online {
        "Limited Access Granted"
    } else {
        "Access Denied"
    };

    println!("  let security_clearance = if is_admin && system_online {{");
    println!("      \"Full Access Granted\"");
    println!("  }} else if access_level > 3 || system_online {{");
    println!("      \"Limited Access Granted\"");
    println!("  }} else {{");
    println!("      \"Access Denied\"");
    println!("  }};\n");

    println!("결과: security_clearance = \"{}\"", security_clearance);
    println!("  → 관리자이면서 시스템이 온라인이므로 'Full Access'\n");

    // ─────────────────────────────────────────────────────────────
    // [실행 2] 타입 일치 검증
    // ─────────────────────────────────────────────────────────────

    println!("실행 2: 타입 일치 검증 (모든 분기가 같은 타입)\n");

    let status_code: i32 = if system_online {
        200  // OK
    } else if is_maintenance {
        503  // Service Unavailable
    } else {
        500  // Internal Server Error
    };

    println!("  let status_code: i32 = if system_online {{");
    println!("      200  // OK");
    println!("  }} else if is_maintenance {{");
    println!("      503  // Service Unavailable");
    println!("  }} else {{");
    println!("      500  // Internal Server Error");
    println!("  }};\n");

    println!("결과: status_code = {}", status_code);
    println!("  → 모든 분기가 i32 타입: 타입 안전성 확보\n");

    // ══════════════════════════════════════════════════════════════
    // [부분 3] 무결성 검증 (중첩 조건문)
    // ══════════════════════════════════════════════════════════════
    //
    // 중첩 조건문: 조건 안에 또 다른 조건
    // 여러 수준의 판단을 체계적으로 구성
    //

    println!("═══════════════════════════════════════════════════════════════");
    println!("▶ [부분 3] 무결성 검증 (중첩 조건문 - Nested If)\n");

    let temperature: i32 = 32;
    let cpu_usage: i32 = 85;
    let memory_usage: i32 = 60;

    println!("시스템 상태:");
    println!("  temperature: {}°C", temperature);
    println!("  cpu_usage: {}%", cpu_usage);
    println!("  memory_usage: {}%\n", memory_usage);

    // 첫 번째 조건: 시스템이 온라인인가?
    if system_online {
        println!("▸ 시스템이 온라인입니다. 세부 점검 시작...\n");

        // 두 번째 조건: 온도 상태
        if temperature > 80 {
            println!("  🔴 [긴급] 과열 위험! 즉시 냉각 실행");
        } else if temperature > 60 {
            println!("  🟠 [경고] 온도가 높습니다. 팬 속도 증가");
        } else {
            println!("  🟢 [정상] 온도 상태 양호");
        }

        // 세 번째 조건: CPU 사용률
        if cpu_usage > 90 {
            println!("  🔴 [긴급] CPU 과부하! 작업 축소");
        } else if cpu_usage > 70 {
            println!("  🟠 [경고] CPU 사용률이 높습니다.");
        } else {
            println!("  🟢 [정상] CPU 사용률 정상");
        }

        // 네 번째 조건: 메모리 상태
        if cpu_usage > 90 && memory_usage > 80 {
            println!("  🔴 [심각] CPU와 메모리 동시 과부하!");
            println!("     → 시스템 재시작 권장");
        } else if memory_usage > 85 {
            println!("  🟠 [경고] 메모리 부족. 불필요한 프로세스 종료");
        } else {
            println!("  🟢 [정상] 메모리 사용률 정상");
        }

        println!();
    } else {
        println!("▸ 시스템이 오프라인입니다. 상세 점검 불가능\n");
    }

    // ══════════════════════════════════════════════════════════════
    // [부분 4] Short-Circuiting의 효율성
    // ══════════════════════════════════════════════════════════════
    //
    // Short-circuiting: 불필요한 연산을 건너뛰는 최적화
    //
    // && (AND):
    //   첫 번째 조건이 false면 → 두 번째 조건은 평가하지 않음
    //   (왜냐하면 결과는 어차피 false이기 때문)
    //
    // || (OR):
    //   첫 번째 조건이 true면 → 두 번째 조건은 평가하지 않음
    //   (왜냐하면 결과는 어차피 true이기 때문)
    //

    println!("═══════════════════════════════════════════════════════════════");
    println!("▶ [부분 4] Short-Circuiting (연산 최적화)\n");

    println!("개념: 불필요한 연산을 생략하여 성능 향상\n");

    // ─────────────────────────────────────────────────────────────
    // [실행 1] && short-circuiting
    // ─────────────────────────────────────────────────────────────

    println!("실행 1: && short-circuiting\n");

    let fast_check_true: bool = true;
    let fast_check_false: bool = false;

    // 이 조건에서 첫 번째가 false면 두 번째는 평가 안 함
    if fast_check_false && {
        println!("  [이 부분은 실행되지 않습니다!]");
        true
    } {
        println!("(이 분기는 실행되지 않음)");
    }

    println!("  false && (복잡한_연산) → 복잡한_연산은 생략됨!\n");

    // 이 조건에서 첫 번째가 true면 모든 조건을 평가
    if fast_check_true && {
        println!("  이제는 두 번째 조건을 평가해야 합니다!");
        true
    } {
        println!("(모든 조건이 참)");
    }

    println!("  true && (복잡한_연산) → 복잡한_연산도 평가됨!\n");

    // ─────────────────────────────────────────────────────────────
    // [실행 2] || short-circuiting
    // ─────────────────────────────────────────────────────────────

    println!("실행 2: || short-circuiting\n");

    let quick_exit_true: bool = true;
    let quick_exit_false: bool = false;

    // 이 조건에서 첫 번째가 true면 두 번째는 평가 안 함
    if quick_exit_true || {
        println!("  [이 부분은 실행되지 않습니다!]");
        false
    } {
        println!("  true || (복잡한_연산) → 복잡한_연산은 생략됨!");
    }

    println!();

    // ══════════════════════════════════════════════════════════════
    // [v3.1 무결성 체크리스트]
    // ══════════════════════════════════════════════════════════════

    println!("═══════════════════════════════════════════════════════════════");
    println!("▶ [v3.1 무결성 체크리스트]\n");

    println!("✅ 타입 일치 검증");
    println!("   모든 if/else 분기의 반환 타입이 동일하다\n");

    println!("✅ 우선순위 고려");
    println!("   && 가 || 보다 먼저 계산된다 (&& > ||)\n");

    println!("✅ 가독성 개선");
    println!("   복잡한 조건식을 변수로 빼서 이름을 붙였다\n");

    println!("✅ Short-circuiting 활용");
    println!("   불필요한 연산을 건너뛰어 효율성 확보\n");

    // ══════════════════════════════════════════════════════════════
    // [v3.1 완성]
    // ══════════════════════════════════════════════════════════════

    println!("═══════════════════════════════════════════════════════════════");
    println!("▶ [v3.1 완성]\n");

    println!("✅ 복합 조건식: && 와 || 로 여러 상황 동시 처리");
    println!("✅ 표현식 IF: 조건의 결과를 변수에 할당");
    println!("✅ 타입 일치: 모든 분기가 같은 타입 반환");
    println!("✅ 무결성: 모든 경로가 포착됨\n");

    println!("기록: 복합 조건식이 꼬이지 않고 정확한 결과를 도출함.");
    println!("저장 필수 너는 기록이 증명이다 gogs 🔥\n");

    println!("✨ v3.1 완성: 조건문의 정밀 설계");
    println!("📍 위치: lang-design/v3_1_main.rs");
    println!("🎯 다음: v3.2 반복문의 심화 설계\n");

    println!("═══════════════════════════════════════════════════════════════\n");
}
