// ===================================================================
// Section 1: 뉴타입의 기본 개념
// ===================================================================
//
// 같은 숫자 타입이라도 의미를 다르게 부여하는 방법
//
fn section_1_newtype_basics() {
    println!("▶ Section 1: 뉴타입의 기본 개념");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 1-1. 문제: 같은 타입의 혼동
    // ─────────────────────────────────────────
    println!("  [1-1] 뉴타입이 없으면?");

    fn register_user_bad(user_id: u32, age: u32) {
        println!("    사용자 {}명(나이) 등록", user_id);
        // user_id와 age를 실수로 바꿀 수 있음!
    }

    println!("    ❌ 문제:");
    println!("       register_user_bad(101, 25);    // user_id=101, age=25");
    println!("       register_user_bad(25, 101);    // 실수로 뒤바뀜!");
    println!("    → 컴파일러가 감지 불가능\n");

    // ─────────────────────────────────────────
    // 1-2. 해결책: 뉴타입 패턴
    // ─────────────────────────────────────────
    println!("  [1-2] 뉴타입으로 의미 분리");

    struct UserId(u32);
    struct Age(u32);
    struct Temperature(f64);

    fn register_user_good(user_id: UserId, age: Age) {
        println!("    사용자 ID {} 등록 (나이: {}살)", user_id.0, age.0);
    }

    println!("    ✅ 해결책:");
    println!("       register_user_good(UserId(101), Age(25));");
    println!("       // register_user_good(Age(25), UserId(101)); ← 컴파일 에러!");
    println!("    → 타입이 다르면 컴파일 불가능\n");

    // ─────────────────────────────────────────
    // 1-3. 뉴타입의 정의
    // ─────────────────────────────────────────
    println!("  [1-3] 뉴타입의 정의");

    // 뉴타입: 하나의 필드만 가진 튜플 구조체
    struct Meters(f64);
    struct Inches(f64);
    struct Celsius(f64);
    struct Fahrenheit(f64);

    println!("    struct 이름(기본타입)으로 정의:");
    println!("      struct Meters(f64);");
    println!("      struct Celsius(f64);");
    println!();
    println!("    성질:");
    println!("      - 컴파일 타임에만 존재 (런타임 오버헤드 없음)");
    println!("      - .0으로 내부 값 접근");
    println!("      - 서로 다른 뉴타입은 호환 불가능\n");

    // ─────────────────────────────────────────
    // 1-4. 실제 사용
    // ─────────────────────────────────────────
    println!("  [1-4] 실제 사용");

    let distance = Meters(1000.0);
    let height = Meters(150.0);
    let temp = Celsius(37.0);

    println!("    거리: {}미터", distance.0);
    println!("    높이: {}미터", height.0);
    println!("    온도: {}℃", temp.0);
    println!();

    // 가능: 같은 타입끼리 합치기
    let total_distance = Meters(distance.0 + height.0);
    println!("    총 거리: {}미터", total_distance.0);

    println!("\n    불가능한 연산 (컴파일 불가):");
    println!("      // let mixed = distance + temp;  ← 타입 다름!");
    println!("      // let celsius_to_f = temp + Fahrenheit(98.6);  ← 호환 불가!");
}

// ===================================================================
// Section 2: 뉴타입 메서드
// ===================================================================
//
// 뉴타입에 메서드를 추가하여 의미있는 연산 정의
//
fn section_2_newtype_methods() {
    println!("▶ Section 2: 뉴타입 메서드");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 2-1. 접근자 패턴
    // ─────────────────────────────────────────
    println!("  [2-1] 접근자 패턴");

    struct Distance(f64);

    impl Distance {
        fn new(meters: f64) -> Self {
            Distance(meters)
        }

        fn meters(&self) -> f64 {
            self.0
        }

        fn kilometers(&self) -> f64 {
            self.0 / 1000.0
        }

        fn display(&self) {
            println!("    거리: {}m ({:.2}km)", self.0, self.kilometers());
        }
    }

    let d = Distance::new(5000.0);
    println!("    원본: {:?}", d.meters());
    d.display();
    println!();

    // ─────────────────────────────────────────
    // 2-2. 타입 검증 메서드
    // ─────────────────────────────────────────
    println!("  [2-2] 타입 검증 메서드");

    struct UserId(u32);

    impl UserId {
        fn new(id: u32) -> Result<Self, String> {
            if id > 0 && id <= 100000 {
                Ok(UserId(id))
            } else {
                Err("ID는 1~100000 범위여야 함".to_string())
            }
        }

        fn is_admin(&self) -> bool {
            self.0 < 100  // 100 미만이 관리자
        }
    }

    match UserId::new(50) {
        Ok(id) => println!("    유효한 ID: {}, 관리자: {}", id.0, id.is_admin()),
        Err(e) => println!("    오류: {}", e),
    }

    match UserId::new(999999) {
        Ok(_) => println!("    유효한 ID"),
        Err(e) => println!("    오류: {}", e),
    }
    println!();

    // ─────────────────────────────────────────
    // 2-3. 변환 메서드
    // ─────────────────────────────────────────
    println!("  [2-3] 변환 메서드");

    struct Money(f64);

    impl Money {
        fn new(amount: f64) -> Self {
            Money(amount)
        }

        fn add(&self, other: Money) -> Money {
            Money(self.0 + other.0)
        }

        fn multiply(&self, factor: f64) -> Money {
            Money(self.0 * factor)
        }

        fn display(&self) {
            println!("    금액: ${:.2}", self.0);
        }
    }

    let price = Money::new(10.0);
    let tax = Money::new(2.0);
    let total = price.add(tax);

    price.display();
    tax.display();
    total.display();
}

// ===================================================================
// Section 3: 뉴타입과 연산자
// ===================================================================
//
// 뉴타입에 연산자를 정의하여 자연스러운 표현
//
fn section_3_newtype_operators() {
    println!("▶ Section 3: 뉴타입 연산자 오버로딩");
    println!("─────────────────────────────────────────\n");

    use std::ops::{Add, Sub};

    // ─────────────────────────────────────────
    // 3-1. Add 트레이트 구현
    // ─────────────────────────────────────────
    println!("  [3-1] Add 트레이트 구현");

    #[derive(Debug, Clone, Copy)]
    struct Distance(f64);

    impl Add for Distance {
        type Output = Distance;

        fn add(self, other: Distance) -> Distance {
            Distance(self.0 + other.0)
        }
    }

    let d1 = Distance(100.0);
    let d2 = Distance(200.0);
    let total = d1 + d2;  // 자연스러운 문법!

    println!("    {}m + {}m = {}m", d1.0, d2.0, total.0);
    println!();

    // ─────────────────────────────────────────
    // 3-2. Sub 트레이트 구현
    // ─────────────────────────────────────────
    println!("  [3-2] Sub 트레이트 구현");

    impl Sub for Distance {
        type Output = Distance;

        fn sub(self, other: Distance) -> Distance {
            Distance((self.0 - other.0).abs())
        }
    }

    let start = Distance(500.0);
    let current = Distance(200.0);
    let remaining = start - current;

    println!("    시작: {}m", start.0);
    println!("    현재: {}m", current.0);
    println!("    남은 거리: {}m", remaining.0);
    println!();

    // ─────────────────────────────────────────
    // 3-3. 제약: 다른 타입과는 연산 불가능
    // ─────────────────────────────────────────
    println!("  [3-3] 타입 안전성");

    #[derive(Debug, Clone, Copy)]
    struct Speed(f64);

    // Speed에는 Add를 구현하지 않음
    // let mixed = d1 + Speed(50.0); // ← 컴파일 에러!

    println!("    Distance + Distance ✅ 가능");
    println!("    Distance + Speed ❌ 컴파일 불가능");
    println!("    → 타입으로 논리 오류를 원천 차단\n");
}

// ===================================================================
// Section 4: 타입 에일리어스
// ===================================================================
//
// 복잡한 타입에 별명을 붙여 가독성 향상
//
fn section_4_type_alias() {
    println!("▶ Section 4: 타입 에일리어스");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 4-1. 기본 에일리어스
    // ─────────────────────────────────────────
    println!("  [4-1] 기본 타입 에일리어스");

    type UserId = u32;
    type Email = String;
    type AccessLog = Vec<(u32, String)>;

    println!("    type UserId = u32;");
    println!("    type Email = String;");
    println!("    type AccessLog = Vec<(u32, String)>;");
    println!();

    let user_id: UserId = 101;
    let email: Email = "alice@example.com".to_string();
    let mut logs: AccessLog = Vec::new();

    logs.push((user_id, "로그인".to_string()));
    logs.push((user_id, "프로필 조회".to_string()));

    println!("    사용자 ID: {}", user_id);
    println!("    이메일: {}", email);
    println!("    로그 기록:");
    for (id, action) in &logs {
        println!("      - 사용자 {}: {}", id, action);
    }
    println!();

    // ─────────────────────────────────────────
    // 4-2. 제네릭 에일리어스
    // ─────────────────────────────────────────
    println!("  [4-2] 제네릭 타입 에일리어스");

    type Result<T> = std::result::Result<T, String>;
    type Database<K, V> = std::collections::HashMap<K, V>;

    println!("    type Result<T> = std::result::Result<T, String>;");
    println!("    type Database<K, V> = std::collections::HashMap<K, V>;");
    println!();

    fn parse_user_count(s: &str) -> Result<u32> {
        s.parse::<u32>().map_err(|_| "유효하지 않은 숫자".to_string())
    }

    match parse_user_count("42") {
        Ok(count) => println!("    사용자 수: {}", count),
        Err(e) => println!("    오류: {}", e),
    }

    match parse_user_count("abc") {
        Ok(_) => println!("    성공"),
        Err(e) => println!("    오류: {}", e),
    }
    println!();

    // ─────────────────────────────────────────
    // 4-3. 에일리어스의 특징
    // ─────────────────────────────────────────
    println!("  [4-3] 에일리어스의 특징");

    println!("    - 새로운 타입 생성 ❌");
    println!("    - 별명만 부여 ✅");
    println!("    - 가독성 향상 ✅");
    println!("    - 런타임 비용 없음 ✅");
    println!();
}

