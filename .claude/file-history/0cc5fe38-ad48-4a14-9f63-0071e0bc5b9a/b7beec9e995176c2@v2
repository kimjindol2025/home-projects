// ===================================================================
// Section 6: 실무 설계 패턴
// ===================================================================
//
// 도메인 지식을 타입으로 표현하는 방법
//
fn section_6_practical_patterns() {
    println!("▶ Section 6: 실무 설계 패턴");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 6-1. 도메인 타입 설계
    // ─────────────────────────────────────────
    println!("  [6-1] 도메인 타입 설계");

    // 금융 도메인
    struct Price(f64);
    struct Discount(f64);
    struct TotalAmount(f64);

    impl Price {
        fn apply_discount(&self, discount: Discount) -> TotalAmount {
            let discounted = self.0 * (1.0 - discount.0);
            TotalAmount(discounted.max(0.0))
        }
    }

    let price = Price(100.0);
    let discount = Discount(0.2);  // 20% 할인
    let total = price.apply_discount(discount);

    println!("    원가: ${}", price.0);
    println!("    할인: {}%", discount.0 * 100.0);
    println!("    최종 가격: ${}", total.0);
    println!();

    // ─────────────────────────────────────────
    // 6-2. 검증이 포함된 뉴타입
    // ─────────────────────────────────────────
    println!("  [6-2] 검증이 포함된 뉴타입");

    struct PasswordHash(String);

    impl PasswordHash {
        fn new(password: &str) -> Result<Self, String> {
            if password.len() < 8 {
                Err("비밀번호는 8자 이상이어야 함".to_string())
            } else {
                // 실제로는 해싱 함수 사용
                let hashed = format!("hashed_{}", password);
                Ok(PasswordHash(hashed))
            }
        }
    }

    match PasswordHash::new("short") {
        Ok(_) => println!("    비밀번호 저장됨"),
        Err(e) => println!("    오류: {}", e),
    }

    match PasswordHash::new("securepass123") {
        Ok(_) => println!("    비밀번호 저장됨"),
        Err(e) => println!("    오류: {}", e),
    }
    println!();

    // ─────────────────────────────────────────
    // 6-3. 타입 에일리어스로 복잡성 숨김
    // ─────────────────────────────────────────
    println!("  [6-3] 타입 에일리어스로 복잡성 숨김");

    type UserRecord = (u32, String, String);  // (ID, 이름, 이메일)
    type QueryResult<T> = Result<T, String>;

    let user: UserRecord = (101, "Alice".to_string(), "alice@example.com".to_string());
    println!("    사용자: {}, {}, {}", user.0, user.1, user.2);

    fn find_user(id: u32) -> QueryResult<UserRecord> {
        Ok((id, "User".to_string(), "user@example.com".to_string()))
    }

    match find_user(101) {
        Ok(record) => println!("    조회 성공: {:?}", record),
        Err(e) => println!("    오류: {}", e),
    }
}

// ===================================================================
// Section 7: 실무 예제 - 종합 시스템
// ===================================================================
//
// 뉴타입과 타입 에일리어스를 함께 사용한 현실적 사례
//
fn section_7_real_world_examples() {
    println!("▶ Section 7: 실무 예제 - 통합 시스템");
    println!("─────────────────────────────────────────\n");

    use std::collections::HashMap;

    // ─────────────────────────────────────────
    // 예제 1: 물리량 시스템
    // ─────────────────────────────────────────
    println!("  [예제 1] 물리량 시스템");

    #[derive(Debug, Clone, Copy)]
    struct Meter(f64);

    #[derive(Debug, Clone, Copy)]
    struct Second(f64);

    #[derive(Debug, Clone, Copy)]
    struct MeterPerSecond(f64);

    impl Meter {
        fn speed_with_time(&self, time: Second) -> MeterPerSecond {
            MeterPerSecond(self.0 / time.0)
        }
    }

    let distance = Meter(100.0);
    let time = Second(10.0);
    let speed = distance.speed_with_time(time);

    println!("    거리: {}m, 시간: {}s", distance.0, time.0);
    println!("    속도: {:.1}m/s", speed.0);
    println!();

    // ─────────────────────────────────────────
    // 예제 2: 사용자 관리 시스템
    // ─────────────────────────────────────────
    println!("  [예제 2] 사용자 관리 시스템");

    struct UserId(u32);
    type UserName = String;
    type UserDatabase = HashMap<u32, UserName>;

    impl UserId {
        fn new(id: u32) -> Result<Self, String> {
            if id > 0 {
                Ok(UserId(id))
            } else {
                Err("ID는 양수여야 함".to_string())
            }
        }
    }

    let mut db: UserDatabase = HashMap::new();
    db.insert(1, "Alice".to_string());
    db.insert(2, "Bob".to_string());

    match UserId::new(1) {
        Ok(id) => {
            if let Some(name) = db.get(&id.0) {
                println!("    사용자 ID {}: {}", id.0, name);
            }
        }
        Err(e) => println!("    오류: {}", e),
    }
    println!();

    // ─────────────────────────────────────────
    // 예제 3: 로깅 시스템
    // ─────────────────────────────────────────
    println!("  [예제 3] 로깅 시스템");

    struct LogLevel(String);
    type LogMessage = String;
    type LogEntry = (u64, LogLevel, LogMessage);
    type LogHistory = Vec<LogEntry>;

    impl LogLevel {
        fn new(level: &str) -> Self {
            LogLevel(level.to_uppercase())
        }

        fn is_error(&self) -> bool {
            self.0 == "ERROR"
        }
    }

    let mut logs: LogHistory = Vec::new();

    logs.push((1000, LogLevel::new("info"), "시스템 시작".to_string()));
    logs.push((1001, LogLevel::new("error"), "데이터베이스 연결 실패".to_string()));
    logs.push((1002, LogLevel::new("info"), "재시도 중".to_string()));

    println!("    로그 기록:");
    for (timestamp, level, message) in &logs {
        println!("      [{}] {}: {}", timestamp, level.0, message);
    }

    let error_count = logs.iter().filter(|(_, level, _)| level.is_error()).count();
    println!("    총 에러 수: {}", error_count);
    println!();

    // ─────────────────────────────────────────
    // 예제 4: 환율 시스템
    // ─────────────────────────────────────────
    println!("  [예제 4] 환율 시스템");

    #[derive(Debug, Clone, Copy)]
    struct Dollar(f64);

    #[derive(Debug, Clone, Copy)]
    struct WonPerDollar(f64);

    impl Dollar {
        fn to_won(&self, rate: WonPerDollar) -> f64 {
            self.0 * rate.0
        }
    }

    let amount = Dollar(100.0);
    let rate = WonPerDollar(1300.0);

    let won_amount = amount.to_won(rate);
    println!("    ${}는 ₩{:.0}입니다", amount.0, won_amount);
    println!();

    println!("  ✅ 결론:");
    println!("    - 뉴타입: 도메인의 의미를 타입으로 강제");
    println!("    - 타입 에일리어스: 복잡한 타입을 단순한 이름으로");
    println!("    - 함께 사용: 안전하고 가독성 높은 시스템");
}

