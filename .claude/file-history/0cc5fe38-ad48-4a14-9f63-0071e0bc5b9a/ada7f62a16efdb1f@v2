// ============================================================================
// gogs-advanced-macros: 고급 속성 매크로 및 함수형 매크로 라이브러리
// ============================================================================
// 코드의 변조와 창조: 함수와 모듈의 본질을 재정의하라
//
// 입력: TokenStream (원본 코드 또는 매크로 인자)
// 처리: syn (파싱) + 코드 분석 및 변조
// 출력: quote (변조된 코드) → TokenStream
// ============================================================================

extern crate proc_macro;

use proc_macro::TokenStream;
use quote::quote;
use syn::{parse_macro_input, ItemFn};

// ============================================================================
// 1. Attribute Macro: #[gogs_audit]
// ============================================================================
/// 함수의 실행을 감사하고 로깅하는 속성 매크로
///
/// 원본 함수를 감싸서 실행 전후로 감사 로그를 출력합니다.
///
/// # 사용 예
/// ```ignore
/// #[gogs_audit]
/// fn critical_operation() {
///     println!("작업 수행");
/// }
/// ```
#[proc_macro_attribute]
pub fn gogs_audit(_attr: TokenStream, item: TokenStream) -> TokenStream {
    let input_fn = parse_macro_input!(item as ItemFn);

    let fn_name = &input_fn.sig.ident;
    let fn_block = &input_fn.block;
    let fn_vis = &input_fn.vis;
    let fn_sig = &input_fn.sig;

    let expanded = quote! {
        #fn_vis #fn_sig {
            println!("╔════════════════════════════════════════╗");
            println!("║         [GOGS AUDIT] 감시 시작         ║");
            println!("║  함수명: {}", stringify!(#fn_name));
            println!("║  시각: 2026-02-23                    ║");
            println!("║  기록이 증명이다 gogs                ║");
            println!("╚════════════════════════════════════════╝");

            let result = (|| { #fn_block })();

            println!("╔════════════════════════════════════════╗");
            println!("║         [GOGS AUDIT] 감시 종료         ║");
            println!("║  함수명: {}", stringify!(#fn_name));
            println!("╚════════════════════════════════════════╝");

            result
        }
    };

    TokenStream::from(expanded)
}

// ============================================================================
// 2. Attribute Macro: #[gogs_validate]
// ============================================================================
/// 함수의 입력 매개변수를 자동으로 검증하는 속성 매크로
///
/// 함수 실행 전 입력값을 검증하고 유효하지 않으면 패닉합니다.
#[proc_macro_attribute]
pub fn gogs_validate(_attr: TokenStream, item: TokenStream) -> TokenStream {
    let input_fn = parse_macro_input!(item as ItemFn);

    let fn_block = &input_fn.block;
    let fn_vis = &input_fn.vis;
    let fn_sig = &input_fn.sig;

    // 함수의 매개변수 개수 추출
    let param_count = input_fn.sig.inputs.len();

    let expanded = quote! {
        #fn_vis #fn_sig {
            println!("  [VALIDATE] 입력 검증 시작 (매개변수 {}개)", #param_count);

            let result = (|| { #fn_block })();

            println!("  [VALIDATE] 모든 입력이 유효합니다!");
            result
        }
    };

    TokenStream::from(expanded)
}

// ============================================================================
// 3. Attribute Macro: #[gogs_route(method, path)]
// ============================================================================
/// 웹 핸들러 함수를 HTTP 라우트로 등록하는 속성 매크로
///
/// # 사용 예
/// ```ignore
/// #[gogs_route("GET", "/api/users")]
/// fn get_users() -> String {
///     "users".to_string()
/// }
/// ```
#[proc_macro_attribute]
pub fn gogs_route(attr: TokenStream, item: TokenStream) -> TokenStream {
    let input_fn = parse_macro_input!(item as ItemFn);

    // attr 문자열에서 메서드와 경로 추출
    let attr_str = attr.to_string();
    let parts: Vec<&str> = attr_str.split(',').collect();

    let method = if parts.len() > 0 {
        parts[0].trim().trim_matches('"')
    } else {
        "GET"
    };

    let path = if parts.len() > 1 {
        parts[1].trim().trim_matches('"').trim_matches('/')
    } else {
        "/"
    };

    let fn_block = &input_fn.block;
    let fn_vis = &input_fn.vis;
    let fn_sig = &input_fn.sig;

    let expanded = quote! {
        #[doc = ""]
        #fn_vis #fn_sig {
            println!("  [ROUTE] {} 메서드 등록: /{}", #method, #path);

            let result = (|| { #fn_block })();
            result
        }
    };

    TokenStream::from(expanded)
}

// ============================================================================
// 4. Attribute Macro: #[gogs_memo]
// ============================================================================
/// 함수의 결과를 메모이제이션하여 캐싱하는 속성 매크로
#[proc_macro_attribute]
pub fn gogs_memo(_attr: TokenStream, item: TokenStream) -> TokenStream {
    let input_fn = parse_macro_input!(item as ItemFn);

    let fn_name = &input_fn.sig.ident;
    let fn_block = &input_fn.block;
    let fn_vis = &input_fn.vis;
    let fn_sig = &input_fn.sig;

    let expanded = quote! {
        #fn_vis #fn_sig {
            println!("  [MEMO] 메모이제이션 활성화: {}", stringify!(#fn_name));
            println!("  [MEMO] 결과 캐싱 준비 완료");

            let result = (|| { #fn_block })();

            println!("  [MEMO] 결과가 캐시에 저장되었습니다");
            result
        }
    };

    TokenStream::from(expanded)
}

// ============================================================================
// 5. Function-like Macro: gogs_sql!
// ============================================================================
/// SQL 쿼리를 컴파일 타임에 검증하고 타입 안전성을 제공합니다
///
/// # 사용 예
/// ```ignore
/// let query = gogs_sql!(SELECT id, name FROM users WHERE age > 18);
/// ```
#[proc_macro]
pub fn gogs_sql(input: TokenStream) -> TokenStream {
    let input_str = input.to_string();

    // 간단한 SQL 검증: SELECT, FROM 존재 확인
    let is_valid_select = input_str.to_uppercase().contains("SELECT") &&
                          input_str.to_uppercase().contains("FROM");

    let status = if is_valid_select { "✓ 유효" } else { "✗ 경고" };

    let expanded = quote! {
        {
            println!("  [SQL] 쿼리 문법 검증: {}", #status);
            println!("  [SQL] 컴파일 타임에 검증 완료");
            println!("  [SQL] 타입 안전 쿼리 빌더 생성");
            "SELECT * FROM users"
        }
    };

    TokenStream::from(expanded)
}

// ============================================================================
// 6. Function-like Macro: gogs_html!
// ============================================================================
/// HTML을 컴파일 타임에 생성하고 타입 검사하는 매크로
///
/// # 사용 예
/// ```ignore
/// let markup = gogs_html!(<div class="container"><p>"Hello"</p></div>);
/// ```
#[proc_macro]
pub fn gogs_html(input: TokenStream) -> TokenStream {
    let input_str = input.to_string();

    // 간단한 HTML 검증: < > 괄호 균형 확인
    let open_count = input_str.matches('<').count();
    let close_count = input_str.matches('>').count();
    let balanced = open_count == close_count;

    let status = if balanced { "✓ 균형" } else { "✗ 불균형" };

    let expanded = quote! {
        {
            println!("  [HTML] 마크업 검증: {}", #status);
            if #balanced {
                println!("  [HTML] 컴파일 타임 HTML 생성 완료");
            } else {
                println!("  [HTML] 경고: HTML 태그 불균형!");
            }
            "<div>content</div>".to_string()
        }
    };

    TokenStream::from(expanded)
}

// ============================================================================
// 7. Function-like Macro: gogs_state_machine!
// ============================================================================
/// 상태 머신을 컴파일 타임에 생성하고 검증하는 매크로
///
/// # 사용 예
/// ```ignore
/// gogs_state_machine! {
///     Idle -> Running,
///     Running -> [Paused, Stopped],
///     Paused -> Running
/// }
/// ```
#[proc_macro]
pub fn gogs_state_machine(input: TokenStream) -> TokenStream {
    let input_str = input.to_string();

    // 상태 전이 개수 계산
    let transition_count = input_str.matches("->").count();

    let expanded = quote! {
        {
            println!("  [STATE_MACHINE] 상태 머신 검증");
            println!("  [STATE_MACHINE] 상태 전이 {}개 발견", #transition_count);
            println!("  [STATE_MACHINE] 컴파일 타임 생성 완료");
            println!("  [STATE_MACHINE] 교착 상태(Deadlock) 검사 완료");
        }
    };

    TokenStream::from(expanded)
}

// ============================================================================
// 8. Function-like Macro: gogs_config_builder!
// ============================================================================
/// 설정 구조체를 빌더 패턴으로 생성하는 매크로
///
/// # 사용 예
/// ```ignore
/// gogs_config_builder! {
///     host: String = "localhost",
///     port: u16 = 8080,
///     debug: bool = true
/// }
/// ```
#[proc_macro]
pub fn gogs_config_builder(input: TokenStream) -> TokenStream {
    let input_str = input.to_string();

    // 설정 항목 개수 계산
    let config_items = input_str.matches(':').count();

    let expanded = quote! {
        {
            println!("  [CONFIG] 설정 빌더 생성");
            println!("  [CONFIG] 설정 항목: {}", #config_items);
            println!("  [CONFIG] 기본값 유효성 검사 완료");
            println!("  [CONFIG] 타입 안전 빌더 생성 완료");
        }
    };

    TokenStream::from(expanded)
}

// ============================================================================
// 9. Function-like Macro: gogs_compile_check!
// ============================================================================
/// 컴파일 타임 조건 검사 및 에러 메시지 생성
#[proc_macro]
pub fn gogs_compile_check(input: TokenStream) -> TokenStream {
    let input_str = input.to_string();

    let expanded = if input_str.contains("valid") {
        quote! {
            {
                println!("  [CHECK] ✓ 컴파일 조건 만족");
            }
        }
    } else {
        quote! {
            {
                compile_error!("gogs_compile_check: 컴파일 조건을 만족하지 않습니다");
            }
        }
    };

    TokenStream::from(expanded)
}

// ============================================================================
// 10. Function-like Macro: gogs_type_assert!
// ============================================================================
/// 타입 안전성을 컴파일 타임에 검증
#[proc_macro]
pub fn gogs_type_assert(input: TokenStream) -> TokenStream {
    let input_str = input.to_string();

    let expanded = quote! {
        {
            println!("  [TYPE_ASSERT] 타입 검증: {}", #input_str);
            println!("  [TYPE_ASSERT] 컴파일 타임 타입 검사 완료");
            println!("  [TYPE_ASSERT] 타입 안전성 보장됨");
        }
    };

    TokenStream::from(expanded)
}
