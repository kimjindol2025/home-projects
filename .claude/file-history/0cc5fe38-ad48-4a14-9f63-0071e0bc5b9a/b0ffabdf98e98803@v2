// ============================================================================
// 스코프 체인(Scope Chain): 변수 검색의 메커니즘
// ============================================================================

use crate::environment::Environment;

/// 스코프 체인 추적
pub struct ScopeChain;

impl ScopeChain {
    /// 변수 검색 경로 추적
    pub fn trace_lookup(env: &Environment, var_name: &str) -> Vec<String> {
        let mut path = Vec::new();
        Self::_trace(env, var_name, 0, &mut path);
        path
    }

    fn _trace(env: &Environment, var_name: &str, level: usize, path: &mut Vec<String>) {
        let level_desc = format!(
            "  Scope Level {}: {}",
            level,
            if env.bindings.contains_key(var_name) {
                format!("✓ Found '{}' = {}", var_name, env.bindings[var_name])
            } else {
                format!("✗ '{}' not found", var_name)
            }
        );
        path.push(level_desc);

        if !env.bindings.contains_key(var_name) {
            if let Some(parent) = &env.parent {
                Self::_trace(parent, var_name, level + 1, path);
            } else {
                path.push(format!("  ERROR: '{}' is undefined", var_name));
            }
        }
    }

    /// 변수 섀도잉 감지
    pub fn detect_shadowing(env: &Environment) -> Vec<(String, (i64, i64))> {
        let mut shadowed = Vec::new();
        let mut seen = std::collections::HashSet::new();

        Self::_detect_shadowing(env, &mut seen, &mut shadowed, 0);
        shadowed
    }

    fn _detect_shadowing(
        env: &Environment,
        parent_vars: &mut std::collections::HashSet<String>,
        shadowed: &mut Vec<(String, (i64, i64))>,
        _level: usize,
    ) {
        // 현재 환경의 변수들
        for (name, value) in &env.bindings {
            // 부모 환경에도 같은 이름이 있으면 섀도잉
            if let Some(parent) = &env.parent {
                if let Some(parent_value) = parent.get(name) {
                    shadowed.push((name.clone(), (parent_value, *value)));
                }
            }
            parent_vars.insert(name.clone());
        }

        // 부모 환경 탐색
        if let Some(parent) = &env.parent {
            Self::_detect_shadowing(parent, parent_vars, shadowed, _level + 1);
        }
    }

    /// 클로저 변수 분석
    pub fn analyze_closure_vars(
        closure_env: &Environment,
        local_env: &Environment,
    ) -> ClosureVarAnalysis {
        let captured = Self::_find_captured(closure_env, local_env);
        let shadowed = Self::detect_shadowing(local_env);

        ClosureVarAnalysis { captured, shadowed }
    }

    fn _find_captured(closure_env: &Environment, local_env: &Environment) -> Vec<String> {
        let mut captured = Vec::new();

        for (name, _) in &closure_env.bindings {
            // 클로저 환경에 있지만 로컬 환경에는 없는 변수 = 캡처된 변수
            if !local_env.bindings.contains_key(name) {
                captured.push(name.clone());
            }
        }

        captured
    }
}

/// 클로저 변수 분석 결과
pub struct ClosureVarAnalysis {
    /// 캡처된 변수들
    pub captured: Vec<String>,

    /// 섀도잉된 변수들 (이름, (원래값, 새로운값))
    pub shadowed: Vec<(String, (i64, i64))>,
}

impl ClosureVarAnalysis {
    /// 분석 결과 출력
    pub fn report(&self) {
        println!("Closure Variable Analysis:");
        println!("  Captured variables: {}", self.captured.len());
        for var in &self.captured {
            println!("    - {}", var);
        }

        if !self.shadowed.is_empty() {
            println!("  ⚠ Shadowed variables: {}", self.shadowed.len());
            for (var, (original, shadowed)) in &self.shadowed {
                println!(
                    "    - {} (original: {}, shadowed: {})",
                    var, original, shadowed
                );
            }
        }
    }
}

/// 함수 호출 스택 추적
pub struct CallStack {
    /// 함수 호출 이력
    frames: Vec<StackFrame>,
}

pub struct StackFrame {
    pub function_name: String,
    pub parameters: Vec<String>,
    pub locals: Vec<(String, i64)>,
}

impl CallStack {
    /// 새로운 스택 생성
    pub fn new() -> Self {
        CallStack {
            frames: Vec::new(),
        }
    }

    /// 함수 호출 (스택에 푸시)
    pub fn push(&mut self, function_name: String, parameters: Vec<String>) {
        self.frames.push(StackFrame {
            function_name,
            parameters,
            locals: Vec::new(),
        });
    }

    /// 함수 반환 (스택에서 팝)
    pub fn pop(&mut self) -> Option<StackFrame> {
        self.frames.pop()
    }

    /// 현재 깊이
    pub fn depth(&self) -> usize {
        self.frames.len()
    }

    /// 스택 시각화
    pub fn visualize(&self) {
        println!("Call Stack (depth: {}):", self.depth());
        for (i, frame) in self.frames.iter().enumerate() {
            println!("  [{}] {} ({})", i, frame.function_name, frame.parameters.join(", "));
            for (name, value) in &frame.locals {
                println!("      - {} = {}", name, value);
            }
        }
    }
}

impl Default for CallStack {
    fn default() -> Self {
        Self::new()
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_scope_chain_lookup() {
        let mut global = Environment::global();
        global.set("x".to_string(), 10);

        let local = Environment::extend(&global);

        let path = ScopeChain::trace_lookup(&local, "x");
        assert!(!path.is_empty());
    }

    #[test]
    fn test_call_stack() {
        let mut stack = CallStack::new();
        stack.push("main".to_string(), vec![]);
        stack.push("add".to_string(), vec!["x".to_string(), "y".to_string()]);

        assert_eq!(stack.depth(), 2);

        stack.pop();
        assert_eq!(stack.depth(), 1);
    }
}
