// 🧪 v8.1: 통합 테스트 #1 - 금고 기본 기능
// 테스트 목표: GogsVault의 공개 인터페이스 검증
//
// 주의: 이 파일은 외부 프로젝트의 입장에서 라이브러리를 테스트합니다.
// 따라서 pub API만 접근 가능합니다.

#[path = "../src/lib.rs"]
mod gogs_project;

use gogs_project::{GogsVault, VaultError, VaultInfo};

// ==================== 테스트 1: 기본 금고 생성 ====================

#[test]
fn test_vault_creation_success() {
    // 정상적인 키로 금고 생성
    let result = GogsVault::new("SECURE_KEY_123456789");

    assert!(result.is_ok());
    let vault = result.unwrap();

    // 정보 조회
    let info = vault.info();
    assert_eq!(info.status, "locked");
    assert!(info.key_length >= 16);
}

#[test]
fn test_vault_creation_short_key() {
    // 너무 짧은 키로 금고 생성 시도
    let result = GogsVault::new("SHORT");

    assert!(result.is_err());
    match result.unwrap_err() {
        VaultError::InvalidKeyLength { expected, got } => {
            assert_eq!(expected, 16);
            assert_eq!(got, 5);
        }
        _ => panic!("Wrong error type"),
    }
}

// ==================== 테스트 2: 접근 제어 ====================

#[test]
fn test_vault_correct_access() {
    // 올바른 키로 접근
    let vault = GogsVault::new("CORRECT_SECRET_KEY_123").unwrap();
    let result = vault.access("CORRECT_SECRET_KEY_123");

    assert!(result.is_ok());
    assert!(result.unwrap());
}

#[test]
fn test_vault_wrong_access() {
    // 잘못된 키로 접근
    let vault = GogsVault::new("CORRECT_SECRET_KEY_123").unwrap();
    let result = vault.access("WRONG_SECRET_KEY_1234");

    assert!(result.is_ok());
    assert!(!result.unwrap());
}

#[test]
fn test_vault_empty_input() {
    // 빈 입력으로 접근 시도
    let vault = GogsVault::new("CORRECT_SECRET_KEY_123").unwrap();
    let result = vault.access("");

    assert!(result.is_err());
    match result.unwrap_err() {
        VaultError::InvalidInput(msg) => {
            assert!(msg.contains("Empty"));
        }
        _ => panic!("Wrong error type"),
    }
}

// ==================== 테스트 3: 정보 조회 ====================

#[test]
fn test_vault_info() {
    let vault = GogsVault::new("VERY_LONG_SECRET_KEY_WITH_MANY_CHARACTERS").unwrap();
    let info = vault.info();

    // 정보의 불변성 확인
    assert_eq!(info.status, "locked");
    assert!(info.key_length > 20);
}

#[test]
fn test_vault_info_consistency() {
    let key = "CONSISTENT_KEY_123456";
    let vault1 = GogsVault::new(key).unwrap();
    let vault2 = GogsVault::new(key).unwrap();

    assert_eq!(vault1.info().key_length, vault2.info().key_length);
}

// ==================== 테스트 4: 여러 금고 인스턴스 ====================

#[test]
fn test_multiple_vaults() {
    let vault1 = GogsVault::new("FIRST_VAULT_KEY_123456").unwrap();
    let vault2 = GogsVault::new("SECOND_VAULT_KEY_123456").unwrap();

    // 각 금고는 독립적으로 작동
    assert!(vault1.access("FIRST_VAULT_KEY_123456").unwrap());
    assert!(!vault1.access("SECOND_VAULT_KEY_123456").unwrap());

    assert!(vault2.access("SECOND_VAULT_KEY_123456").unwrap());
    assert!(!vault2.access("FIRST_VAULT_KEY_123456").unwrap());
}

// ==================== 테스트 5: 금고 클론 ====================

#[test]
fn test_vault_clone() {
    let vault1 = GogsVault::new("CLONEABLE_KEY_123456").unwrap();
    let vault2 = vault1.clone();

    // 클론된 금고도 동일하게 작동
    assert!(vault2.access("CLONEABLE_KEY_123456").unwrap());
}

// ==================== 테스트 6: 디버그 출력 ====================

#[test]
fn test_vault_debug_format() {
    let vault = GogsVault::new("DEBUG_TEST_KEY_123456").unwrap();
    let debug_str = format!("{:?}", vault);

    // 디버그 출력에 보안 정보가 없는지 확인
    assert!(!debug_str.contains("DEBUG_TEST_KEY"));
    assert!(debug_str.contains("locked"));
}

// ==================== 테스트 7: 키 길이 경계 ====================

#[test]
fn test_vault_exact_min_length() {
    // 정확히 최소 길이 (16)
    let result = GogsVault::new("EXACTLY_MIN_LEN1");
    assert!(result.is_ok());
}

#[test]
fn test_vault_one_below_min_length() {
    // 최소 길이보다 1 작음 (15)
    let result = GogsVault::new("JUST_BELOW_LEN1");
    assert!(result.is_err());
}

#[test]
fn test_vault_long_key() {
    // 매우 긴 키
    let long_key = "A".repeat(1000);
    let result = GogsVault::new(&long_key);
    assert!(result.is_ok());
}
