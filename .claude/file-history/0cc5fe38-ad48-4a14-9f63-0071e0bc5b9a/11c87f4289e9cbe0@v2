// ═════════════════════════════════════════════════════════════════════════════
// Section 5: 수동 메모리 할당 (std::alloc::alloc)
// ═════════════════════════════════════════════════════════════════════════════
//
// 핵심: Box나 Vec 없이 OS로부터 직접 메모리를 빌려온다.

fn section_5_manual_allocation() {
    println!("\n╔══ Section 5: Manual Memory Allocation ══╗");

    unsafe {
        // [5-1] 단일 값 할당
        println!("✓ 단일 u32 할당");
        let layout = Layout::new::<u32>();
        let ptr = alloc(layout) as *mut u32;

        if ptr.is_null() {
            println!("  메모리 할당 실패!");
            return;
        }

        println!("  할당 크기: {} bytes", layout.size());
        println!("  할당 정렬: {} bytes", layout.align());
        println!("  할당 주소: {:p}", ptr);

        // [5-2] 배열 할당
        println!("✓ 배열 할당 (100 × u32)");
        let array_layout = Layout::array::<u32>(100).unwrap();
        let array_ptr = alloc(array_layout) as *mut u32;

        if !array_ptr.is_null() {
            println!("  할당 크기: {} bytes", array_layout.size());
            println!("  요소 수: 100");
            println!("  할당 주소: {:p}", array_ptr);
        }

        // [5-3] 구조체 할당
        println!("✓ 구조체 할당");
        let struct_layout = Layout::new::<GoodLayout>();
        let struct_ptr = alloc(struct_layout) as *mut GoodLayout;

        println!("  할당 크기: {} bytes", struct_layout.size());
        println!("  할당 주소: {:p}", struct_ptr);

        // 메모리 해제 (나중에 더 자세히)
        dealloc(ptr as *mut u8, layout);
        dealloc(array_ptr as *mut u8, array_layout);
        dealloc(struct_ptr as *mut u8, struct_layout);
    }

    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
}

// ═════════════════════════════════════════════════════════════════════════════
// Section 6: 수동 메모리 해제 (dealloc) & 생명주기 관리
// ═════════════════════════════════════════════════════════════════════════════
//
// 핵심: 할당한 메모리는 반드시 같은 Layout으로 해제해야 한다.
//      그렇지 않으면 "메모리 누수" 또는 "이중 해제(Double Free)"

fn section_6_manual_deallocation() {
    println!("\n╔══ Section 6: Memory Deallocation ══╗");

    unsafe {
        // [6-1] 올바른 할당/해제 패턴
        println!("✓ 올바른 할당/해제 생명주기");
        println!("  Step 1: 레이아웃 정의");
        let layout = Layout::new::<i32>();

        println!("  Step 2: 메모리 할당");
        let ptr = alloc(layout) as *mut i32;
        println!("    주소: {:p}", ptr);

        println!("  Step 3: 메모리 사용");
        ptr::write(ptr, 42);
        println!("    값: {}", ptr::read(ptr));

        println!("  Step 4: 메모리 해제");
        dealloc(ptr as *mut u8, layout);
        println!("    반납 완료");

        // [6-2] 잘못된 패턴: 잘못된 Layout으로 해제
        println!("✓ 주의: 잘못된 해제 패턴");
        println!("  ❌ alloc(Layout::new::<u32>())");
        println!("  ❌ dealloc(ptr, Layout::new::<u16>()) ← 잘못된 Layout!");
        println!("  → Undefined Behavior!");

        // [6-3] 이중 해제 방지
        println!("✓ 이중 해제 방지");
        println!("  할당한 포인터는 해제 후 사용 불가");
        println!("  ptr를 null로 설정하거나 소유권 이동 필요");
    }

    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
}

// ═════════════════════════════════════════════════════════════════════════════
// Section 7: Raw Buffer (미니 동적 할당 컨테이너)
// ═════════════════════════════════════════════════════════════════════════════
//
// 핵심: std::alloc을 사용한 기초적인 벡터 구현

struct RawBuffer<T> {
    ptr: *mut T,
    capacity: usize,
    len: usize,
}

impl<T> RawBuffer<T> {
    fn new(capacity: usize) -> Self {
        unsafe {
            let layout = Layout::array::<T>(capacity).unwrap();
            let ptr = alloc(layout) as *mut T;

            RawBuffer {
                ptr,
                capacity,
                len: 0,
            }
        }
    }

    fn push(&mut self, value: T) {
        if self.len < self.capacity {
            unsafe {
                ptr::write(self.ptr.add(self.len), value);
            }
            self.len += 1;
        }
    }

    fn get(&self, index: usize) -> Option<&T> {
        if index < self.len {
            unsafe { Some(&*self.ptr.add(index)) }
        } else {
            None
        }
    }

    fn len(&self) -> usize {
        self.len
    }
}

impl<T> Drop for RawBuffer<T> {
    fn drop(&mut self) {
        unsafe {
            let layout = Layout::array::<T>(self.capacity).unwrap();
            dealloc(self.ptr as *mut u8, layout);
        }
    }
}

fn section_7_raw_buffer() {
    println!("\n╔══ Section 7: Raw Buffer (Mini Vector) ══╗");

    // [7-1] RawBuffer 생성 및 사용
    let mut buf = RawBuffer::<i32>::new(10);
    println!("✓ RawBuffer 생성 (capacity=10)");

    // [7-2] 데이터 추가
    println!("✓ 데이터 추가");
    for i in 0..5 {
        buf.push(i * 10);
    }
    println!("  추가된 요소: 5개");
    println!("  len: {}, capacity: {}", buf.len(), buf.capacity);

    // [7-3] 데이터 읽기
    println!("✓ 데이터 읽기");
    for i in 0..buf.len() {
        if let Some(val) = buf.get(i) {
            println!("  buf[{}] = {}", i, val);
        }
    }

    // [7-4] 범위 밖 접근
    println!("✓ 범위 검사");
    match buf.get(100) {
        Some(v) => println!("  buf[100] = {}", v),
        None => println!("  buf[100] = 범위 밖"),
    }

    println!("  (Drop이 자동으로 메모리 해제)");

    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
}

