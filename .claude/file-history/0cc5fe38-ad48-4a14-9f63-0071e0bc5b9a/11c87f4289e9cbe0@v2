// ═════════════════════════════════════════════════════════════════════════════
// Section 11: Drop과 RAII (Resource Acquisition Is Initialization)
// ═════════════════════════════════════════════════════════════════════════════
//
// 핵심: Drop trait으로 메모리 관리의 자동화 구현

struct SafeAllocator {
    ptr: *mut u8,
    size: usize,
    name: String,
}

impl SafeAllocator {
    fn allocate(size: usize, name: &str) -> Self {
        unsafe {
            let layout = Layout::from_size_align(size, 1).unwrap();
            let ptr = alloc(layout);

            SafeAllocator {
                ptr,
                size,
                name: name.to_string(),
            }
        }
    }

    fn write_byte(&mut self, offset: usize, byte: u8) {
        if offset < self.size {
            unsafe {
                *self.ptr.add(offset) = byte;
            }
        }
    }
}

impl Drop for SafeAllocator {
    fn drop(&mut self) {
        unsafe {
            let layout = Layout::from_size_align(self.size, 1).unwrap();
            dealloc(self.ptr, layout);
            println!("  [DROP] '{}' 메모리 자동 해제 ({} bytes)", self.name, self.size);
        }
    }
}

fn section_11_drop_and_raii() {
    println!("\n╔══ Section 11: Drop & RAII ══╗");

    // [11-1] RAII 패턴
    println!("✓ RAII 패턴 (Resource Acquisition Is Initialization)");
    {
        let mut alloc1 = SafeAllocator::allocate(100, "buffer1");
        println!("  [ALLOC] buffer1 할당 (100 bytes)");

        alloc1.write_byte(0, 42);
        println!("  [USE] buffer1 사용");

        // 스코프 종료 시 자동 Drop
    }
    println!("  (스코프 종료)");

    // [11-2] 여러 할당 관리
    println!("✓ 여러 할당의 자동 관리");
    {
        let _buf1 = SafeAllocator::allocate(50, "buf1");
        let _buf2 = SafeAllocator::allocate(75, "buf2");
        let _buf3 = SafeAllocator::allocate(100, "buf3");

        println!("  3개 버퍼 할당 완료");
        // 역순으로 자동 해제
    }
    println!("  (모든 버퍼 자동 해제 완료)");

    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
}

