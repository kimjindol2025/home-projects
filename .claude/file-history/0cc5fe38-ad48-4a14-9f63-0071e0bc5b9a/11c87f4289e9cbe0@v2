fn section_9_memory_leak_prevention() {
    println!("\n╔══ Section 9: Memory Leak Prevention ══╗");

    // [9-1] 메모리 누수 시뮬레이션
    println!("✓ 메모리 누수 패턴");
    unsafe {
        let layout = Layout::new::<u32>();
        let ptr = alloc(layout) as *mut u32;
        ptr::write(ptr, 42);

        // 이 포인터를 잊으면 누수!
        // dealloc(ptr as *mut u8, layout);  ← 이 줄이 없으면 누수!

        println!("  ⚠️  할당했지만 해제하지 않으면 메모리 누수");
        println!("  주소: {:p} ← 영원히 잃어버림", ptr);

        // 실제로 정리 (예제이므로)
        dealloc(ptr as *mut u8, layout);
    }

    // [9-2] Drop으로 누수 방지
