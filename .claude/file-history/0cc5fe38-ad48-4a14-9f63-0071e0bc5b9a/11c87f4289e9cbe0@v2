// Section 8: ptr::write와 ptr::read (포인터 초기화)
// ═════════════════════════════════════════════════════════════════════════════
//
// 핵심: 수동 할당 메모리에 값을 쓰고 읽을 때 사용한다.

fn section_8_pointer_initialization() {
    println!("\n╔══ Section 8: Pointer Initialization ══╗");

    unsafe {
        // [8-1] ptr::write 사용
        println!("✓ ptr::write로 메모리에 값 쓰기");
        let layout = Layout::new::<u32>();
        let ptr = alloc(layout) as *mut u32;

        ptr::write(ptr, 2026);
        println!("  wrote: 2026 @ {:p}", ptr);

        // [8-2] ptr::read 사용
        println!("✓ ptr::read로 메모리에서 값 읽기");
        let value = ptr::read(ptr);
        println!("  read: {} @ {:p}", value, ptr);

        // [8-3] 복잡한 타입의 초기화
        println!("✓ 구조체 초기화");
        let struct_ptr = alloc(Layout::new::<GoodLayout>()) as *mut GoodLayout;
        let data = GoodLayout { a: 100, b: 200, c: 1, d: 2 };
        ptr::write(struct_ptr, data);
        println!("  wrote struct @ {:p}", struct_ptr);

        let read_data = ptr::read(struct_ptr);
        println!("  read struct: a={}", read_data.a);

        // 메모리 정리
        dealloc(ptr as *mut u8, layout);
        dealloc(struct_ptr as *mut u8, Layout::new::<GoodLayout>());
    }

    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
}

