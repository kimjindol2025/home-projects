// ═════════════════════════════════════════════════════════════════════════════
// Section 2: Padding과 구조체 레이아웃
// ═════════════════════════════════════════════════════════════════════════════
//
// 핵심: 컴파일러는 CPU 효율을 위해 구조체에 "패딩"을 자동 삽입한다.

#[allow(dead_code)]
struct Padded {
    a: u8,      // 1 바이트 @ 오프셋 0
    // padding: 3 바이트 (컴파일러가 자동 삽입)
    b: u32,     // 4 바이트 @ 오프셋 4
    c: u8,      // 1 바이트 @ 오프셋 8
    // padding: 7 바이트 (정렬 맞추기)
}

fn section_2_padding() {
    println!("\n╔══ Section 2: Padding & Alignment ══╗");

    // [2-1] 패딩의 개념
    println!("✓ 구조체 Padded의 메모리 레이아웃");
    println!("  struct Padded {{");
    println!("      a: u8,    // 1 바이트");
    println!("      b: u32,   // 4 바이트");
    println!("      c: u8,    // 1 바이트");
    println!("  }}");

    println!("✓ 실제 메모리 배치");
    let size = mem::size_of::<Padded>();
    let align = mem::align_of::<Padded>();
    println!("  크기: {} bytes (1 + 3 패딩 + 4 + 1 + 7 패딩)", size);
    println!("  정렬: {} bytes", align);

    // [2-2] 필드별 오프셋 계산
    let p = Padded { a: 1, b: 2, c: 3 };
    let base = &p as *const _ as usize;
    let a_offset = std::ptr::addr_of!(p.a) as usize - base;
    let b_offset = std::ptr::addr_of!(p.b) as usize - base;
    let c_offset = std::ptr::addr_of!(p.c) as usize - base;

    println!("✓ 필드 오프셋");
    println!("  a: 오프셋 {} (정렬 1)", a_offset);
    println!("  b: 오프셋 {} (정렬 4 ← 패딩으로 정렬!)", b_offset);
    println!("  c: 오프셋 {} (남은 공간)", c_offset);

    // [2-3] 수동 계산 vs 실제 크기
    println!("✓ 메모리 낭비 계산");
    let used = 1 + 4 + 1;      // 실제 데이터
    let waste = size - used;   // 패딩
    println!("  사용: {} bytes", used);
    println!("  낭비(패딩): {} bytes ({:.1}%)", waste, (waste as f64 / size as f64) * 100.0);

    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
}

