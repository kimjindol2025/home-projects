/// [impl Trait] 조건에 따라 다른 이벤트 생성
/// (Step 9: impl Trait - 구현을 숨김)
fn create_alert_by_severity(severity: u32) -> impl Summary + Secure {
    if severity > 7 {
        IntrusionAlert::new(1, "192.168.1.100", 22, severity, "2026-02-22 10:00")
    } else {
        SystemEvent::new("Minor Event", "Low risk event", severity)
    }
}

/// [impl Trait] 보고서 생성
fn generate_security_report<T: Summary + Secure + Reportable>(item: &T) -> impl Display {
    format!(
        "{}\n\n점수: {}\n상태: {}",
        item.full_report(),
        item.security_score(),
        if item.security_score() > 70 { "긴급" } else { "정상" }
    )
}

