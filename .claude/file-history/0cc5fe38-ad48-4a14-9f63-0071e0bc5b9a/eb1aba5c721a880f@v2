/// 요약 기능: 핵심 정보를 간단히 표현
/// (Step 1: 트레이트 정의)
trait Summary {
    fn summarize(&self) -> String;
}

/// 보안 등급: 데이터의 위험도를 수치화
/// (Step 1: 트레이트 정의)
trait Secure {
    fn security_score(&self) -> u32;
}

/// 로깅 기능: 이벤트를 기록
/// (Step 1: 트레이트 정의)
trait Loggable {
    fn log(&self) -> String;
}

/// 감시 가능: 실시간 감시 대상
/// (Step 2: 트레이트 메서드)
trait Auditable: Summary + Secure {
    fn audit_level(&self) -> String {
        format!("Level: {}", self.security_score())
    }
}

/// 기본 구현을 포함한 트레이트
/// (Step 5: 기본 구현)
trait Reportable {
    fn report_header(&self) -> String {
        "=== 보안 보고서 ===".to_string()
    }

    fn report_body(&self) -> String;

    fn full_report(&self) -> String {
        format!("{}\n{}", self.report_header(), self.report_body())
    }
}

