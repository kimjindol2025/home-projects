/// [단일 경계] Summary만 필요
fn brief_report<T: Summary>(item: &T) {
    println!("📋 간단 보고: {}", item.summarize());
}

/// [다중 경계] Summary + Secure 필요
/// (Step 6-7: 다중 경계)
fn security_alert<T: Summary + Secure>(item: &T) {
    println!("🔒 보안 알람: {}", item.summarize());
    println!("  위험도 점수: {}", item.security_score());

    if item.security_score() > 80 {
        println!("  ⚠️  CRITICAL - 즉각 대응 필요!");
    } else if item.security_score() > 50 {
        println!("  ⚠️  WARNING - 주의 필요");
    } else {
        println!("  ✅ 정상 모니터링");
    }
}

/// [다중 경계] Summary + Loggable 필요
fn log_event<T: Summary + Loggable>(item: &T) {
    println!("📝 이벤트 로깅:");
    println!("  요약: {}", item.summarize());
    println!("  로그: {}", item.log());
}

/// [다중 경계] Summary + Secure + Loggable
/// (Step 6-7: 3개 경계)
fn comprehensive_audit<T: Summary + Secure + Loggable>(item: &T) {
    println!("🔍 종합 감시:");
    println!("  {}", item.summarize());
    println!("  점수: {} | 로그: {}", item.security_score(), item.log());
}

/// [다중 경계 + where절]
/// (Step 8: where절로 가독성 개선)
fn analyze_risk<T, U>(event: &T, threshold: U)
where
    T: Summary + Secure,
    U: Into<u32> + Copy,
{
    let threshold_val = threshold.into();
    let score = event.security_score();

    println!("📊 위험도 분석:");
    println!("  이벤트: {}", event.summarize());
    println!("  점수: {} | 임계값: {}", score, threshold_val);

    if score > threshold_val {
        println!("  결과: 위협 수준 상회 - 대응 필요!");
    } else {
        println!("  결과: 정상 범위 - 계속 모니터링");
    }
}

