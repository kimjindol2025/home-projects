/// 외부에서의 침입 시도 감지
struct IntrusionAlert {
    alert_id: u32,
    ip_address: String,
    port: u16,
    severity: u32,
    timestamp: String,
}

impl IntrusionAlert {
    fn new(alert_id: u32, ip: &str, port: u16, severity: u32, timestamp: &str) -> Self {
        IntrusionAlert {
            alert_id,
            ip_address: ip.to_string(),
            port,
            severity,
            timestamp: timestamp.to_string(),
        }
    }
}

impl Summary for IntrusionAlert {
    fn summarize(&self) -> String {
        format!("🚨 침입 감지! IP: {}:{}", self.ip_address, self.port)
    }
}

impl Secure for IntrusionAlert {
    fn security_score(&self) -> u32 {
        self.severity * 15 // 침입은 심각도가 높음
    }
}

impl Loggable for IntrusionAlert {
    fn log(&self) -> String {
        format!(
            "[{}] INTRUSION ALERT #{}: {}:{} (심각도: {})",
            self.timestamp, self.alert_id, self.ip_address, self.port, self.severity
        )
    }
}

impl Auditable for IntrusionAlert {}

impl Display for IntrusionAlert {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        write!(f, "IntrusionAlert({}:{})", self.ip_address, self.port)
    }
}

impl Reportable for IntrusionAlert {
    fn report_body(&self) -> String {
        format!(
            "침입 소스: {}:{}\n심각도: {}\n점수: {}\n감지 시간: {}",
            self.ip_address,
            self.port,
            self.severity,
            self.security_score(),
            self.timestamp
        )
    }
}

