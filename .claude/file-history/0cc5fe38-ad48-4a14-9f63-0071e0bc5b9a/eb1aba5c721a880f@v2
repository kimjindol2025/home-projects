/// 회사 내부 직원의 활동 로그
struct EmployeeLog {
    id: u32,
    name: String,
    action: String,
    timestamp: String,
}

impl EmployeeLog {
    fn new(id: u32, name: &str, action: &str, timestamp: &str) -> Self {
        EmployeeLog {
            id,
            name: name.to_string(),
            action: action.to_string(),
            timestamp: timestamp.to_string(),
        }
    }
}

impl Summary for EmployeeLog {
    fn summarize(&self) -> String {
        format!("직원 '{}': {}", self.name, self.action)
    }
}

impl Secure for EmployeeLog {
    fn security_score(&self) -> u32 {
        50 // 내부 직원의 기본 점수
    }
}

impl Loggable for EmployeeLog {
    fn log(&self) -> String {
        format!("[{}] EMP#{} - {}: {}", self.timestamp, self.id, self.name, self.action)
    }
}

impl Auditable for EmployeeLog {}

impl Display for EmployeeLog {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        write!(f, "EmployeeLog({})", self.name)
    }
}

impl Reportable for EmployeeLog {
    fn report_body(&self) -> String {
        format!(
            "직원: {}\n작업: {}\n시간: {}\n위험도: {}",
            self.name,
            self.action,
            self.timestamp,
            self.security_score()
        )
    }
}

