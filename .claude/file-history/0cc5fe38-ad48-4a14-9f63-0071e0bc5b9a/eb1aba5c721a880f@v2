━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

상호운용성:
  EmployeeLog, IntrusionAlert, SystemEvent, DataAccessLog
  └─ 각각 다른 구조
  └─ 하지만 같은 규약(Summary + Secure)
  └─ 따라서 같은 함수로 처리 가능

확장성:
  센터에 항목 추가 중:
  center.register_event(Box::new(new_item));
  └─ new_item만 규약을 구현하면 됨
  └─ center와 process 함수는 수정 불필요

견고함:
  컴파일러의 엄격함:
  let wrong_item = "string";  // Summary 미구현
  center.register_event(Box::new(wrong_item));  // ❌ 컴파일 에러
  └─ 런타임에 오류 발생 불가능


