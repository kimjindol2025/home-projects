/// 모든 감시 대상을 통합 관리하는 센터
/// (Step 4-5: 다형성 + 기본 구현)
struct SecurityAuditCenter {
    audits: Vec<Box<dyn Auditable + Display>>,
    events: Vec<Box<dyn Summary + Secure + Loggable>>,
}

impl SecurityAuditCenter {
    fn new() -> Self {
        SecurityAuditCenter {
            audits: Vec::new(),
            events: Vec::new(),
        }
    }

    /// 감시 대상 등록 (플러그인 추가)
    fn register_audit<T: Auditable + Display + 'static>(&mut self, audit: T) {
        self.audits.push(Box::new(audit));
    }

    /// 이벤트 등록
    fn register_event<T: Summary + Secure + Loggable + 'static>(&mut self, event: T) {
        self.events.push(Box::new(event));
    }

    /// 모든 감시 항목 점검
    fn check_all_audits(&self) {
        println!("\n╔═══════════════════════════════════════════════════════╗");
        println!("║ 🔒 통합 보안 감시 시스템: 감사 항목 점검");
        println!("╚═══════════════════════════════════════════════════════╝\n");

        for (idx, audit) in self.audits.iter().enumerate() {
            println!("[감사 {}] {}", idx + 1, audit);
            println!("  설명: {}", audit.summarize());
            println!("  수준: {}", audit.audit_level());
        }
    }

    /// 모든 이벤트 로깅
    fn log_all_events(&self) {
        println!("\n╔═══════════════════════════════════════════════════════╗");
        println!("║ 📝 통합 이벤트 로깅");
        println!("╚═══════════════════════════════════════════════════════╝\n");

        for (idx, event) in self.events.iter().enumerate() {
            println!("[이벤트 {}]", idx + 1);
            println!("  {}", event.log());
            println!("  위험도: {}", event.security_score());
        }
    }

    /// 심각도 높은 항목만 필터링
    fn critical_alerts(&self, threshold: u32) {
        println!("\n╔═══════════════════════════════════════════════════════╗");
        println!("║ 🚨 긴급 경보 (위험도 {} 이상)", threshold);
        println!("╚═══════════════════════════════════════════════════════╝\n");

        let critical: Vec<_> = self
            .events
            .iter()
            .filter(|e| e.security_score() >= threshold)
            .collect();

        if critical.is_empty() {
            println!("✅ 긴급 경보 없음\n");
            return;
        }

        for (idx, event) in critical.iter().enumerate() {
            println!("[경보 {}] {}", idx + 1, event.summarize());
            println!("  점수: {}", event.security_score());
        }
    }

    /// 전체 시스템 상태 보고
    fn system_status(&self) {
        println!("\n╔═══════════════════════════════════════════════════════╗");
        println!("║ 📊 시스템 전체 상태");
        println!("╚═══════════════════════════════════════════════════════╝\n");

        println!("감사 항목: {}", self.audits.len());
        println!("기록 이벤트: {}", self.events.len());

        if !self.events.is_empty() {
            let total_score: u32 = self.events.iter().map(|e| e.security_score()).sum();
            let avg_score = total_score / self.events.len() as u32;
            println!("평균 위험도: {}", avg_score);
        }
    }
}

