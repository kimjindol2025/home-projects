fn section_10_default_trait_methods() {
    println!("\n📌 섹션 10: 기본 트레이트 메서드");
    println!("────────────────────────────────────────");

    trait DataProcessor {
        fn process(&self, input: &str) -> String;

        // [기본 구현] 플러그인 제작자가 구현하지 않아도 됨
        fn process_and_log(&self, input: &str) -> String {
            let result = self.process(input);
            println!("    [로그] 입력: '{}' -> 출력: '{}'", input, result);
            result
        }

        fn get_description(&self) -> &str {
            "기본 설명"
        }
    }

    struct ToUpperProcessor;
    impl DataProcessor for ToUpperProcessor {
        fn process(&self, input: &str) -> String {
            input.to_uppercase()
        }

        // get_description은 기본 구현 사용
        // process_and_log도 기본 구현 사용 (process만 재정의하면 됨)
    }

    struct ReverseProcessor;
    impl DataProcessor for ReverseProcessor {
        fn process(&self, input: &str) -> String {
            input.chars().rev().collect()
        }

        fn get_description(&self) -> &str {
            "문자열을 역순으로 처리"
        }
    }

    println!("  ToUpperProcessor:");
    let p1 = ToUpperProcessor;
    p1.process_and_log("hello");

    println!("\n  ReverseProcessor:");
    let p2 = ReverseProcessor;
    p2.process_and_log("hello");
    println!("    [설명] {}", p2.get_description());

    println!("\n  🔍 기본 메서드의 특징:");
    println!("    ✅ 플러그인 제작자의 코드 감소");
    println!("    ✅ 공통 로직을 트레이트에서 관리");
    println!("    ✅ 필요시 오버라이드 가능");
}

// ============================================================================
// 섹션 11: 성능과 확장성의 트레이드오프
// ============================================================================
fn section_11_performance_extensibility() {
    println!("\n📌 섹션 11: 성능과 확장성의 트레이드오프");
    println!("────────────────────────────────────────");

    use std::time::Instant;

    trait Operation {
        fn execute(&self, x: i32) -> i32;
    }

    struct DoubleOp;
    impl Operation for DoubleOp {
        fn execute(&self, x: i32) -> i32 {
            x * 2
        }
    }

    // 직접 함수 호출 (최적화됨)
    fn direct_call(x: i32) -> i32 {
        x * 2
    }

    // 트레이트 객체 (동적 디스패치)
    let op: Box<dyn Operation> = Box::new(DoubleOp);

    let start = Instant::now();
    for i in 0..1_000_000 {
        let _ = direct_call(i);
    }
    let direct_time = start.elapsed();

    let start = Instant::now();
    for i in 0..1_000_000 {
        let _ = op.execute(i);
    }
    let dynamic_time = start.elapsed();

    println!("  성능 측정 (1M 연산):");
    println!("    직접 호출:      {:.3}ms", direct_time.as_secs_f64() * 1000.0);
    println!("    동적 디스패치:  {:.3}ms", dynamic_time.as_secs_f64() * 1000.0);

    println!("\n  💡 결과:");
    println!("    동적 디스패치는 약간 느리지만");
    println!("    확장성과 유연성의 이득이 훨씬 큼");
    println!("    (일반적으로 5-10% 정도의 오버헤드)");

    println!("\n  🔍 트레이드오프:");
    println!("    ✅ 확장성 극대화");
    println!("    ⚠️  약간의 성능 손실 (무시할 수준)");
    println!("    ✅ 유지보수성 향상");
}

