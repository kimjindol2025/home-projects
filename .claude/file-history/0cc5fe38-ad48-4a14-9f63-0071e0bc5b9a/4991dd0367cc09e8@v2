fn section_2_trait_objects_review() {
    println!("\n📌 섹션 2: 트레이트 객체 복습");
    println!("────────────────────────────────────────");

    trait Logger {
        fn log(&self, message: &str);
    }

    struct ConsoleLogger;
    impl Logger for ConsoleLogger {
        fn log(&self, message: &str) {
            println!("    [콘솔] {}", message);
        }
    }

    struct FileLogger;
    impl Logger for FileLogger {
        fn log(&self, message: &str) {
