// 섹션 6: 여러 플러그인
// ============================================================================
fn section_6_multiple_plugins() {
    println!("\n📌 섹션 6: 여러 플러그인 (확장성 시연)");
    println!("────────────────────────────────────────");

    trait DataValidator {
        fn name(&self) -> &str;
        fn validate(&self, data: &str) -> bool;
    }

    struct EmailValidator;
    impl DataValidator for EmailValidator {
        fn name(&self) -> &str {
            "Email-Validator"
        }
        fn validate(&self, data: &str) -> bool {
            data.contains("@")
        }
    }

    struct LengthValidator;
    impl DataValidator for LengthValidator {
        fn name(&self) -> &str {
            "Length-Validator"
        }
        fn validate(&self, data: &str) -> bool {
            data.len() > 3 && data.len() < 100
        }
    }

    struct SpecialCharValidator;
    impl DataValidator for SpecialCharValidator {
        fn name(&self) -> &str {
            "SpecialChar-Validator"
        }
        fn validate(&self, data: &str) -> bool {
            !data.contains("!") && !data.contains("$")
        }
    }

    struct ValidatorEngine {
        validators: Vec<Box<dyn DataValidator>>,
    }

    impl ValidatorEngine {
        fn new() -> Self {
            ValidatorEngine {
                validators: Vec::new(),
            }
        }

        fn add(&mut self, validator: Box<dyn DataValidator>) {
            println!("  ✨ {} 추가됨", validator.name());
            self.validators.push(validator);
        }

        fn validate(&self, data: &str) -> bool {
            println!("  검증 시작: '{}'", data);
            for validator in &self.validators {
                if !validator.validate(data) {
                    println!("    ❌ {} 실패", validator.name());
                    return false;
                } else {
                    println!("    ✅ {} 통과", validator.name());
                }
            }
            true
        }
    }

    let mut engine = ValidatorEngine::new();
    engine.add(Box::new(EmailValidator));
    engine.add(Box::new(LengthValidator));
    engine.add(Box::new(SpecialCharValidator));

    println!("  시나리오 1: 유효한 이메일");
    let result1 = engine.validate("user@example.com");
    println!("  결과: {}\n", if result1 { "성공" } else { "실패" });

    println!("  시나리오 2: 유효하지 않은 데이터");
    let result2 = engine.validate("short");
    println!("  결과: {}", if result2 { "성공" } else { "실패" });

    println!("\n  🔍 다중 플러그인 체계:");
    println!("    ✅ 플러그인들이 서로 독립적");
    println!("    ✅ 순서대로 검증 수행");
    println!("    ✅ 새 검증 로직 추가 = 새 플러그인 구현");
}

