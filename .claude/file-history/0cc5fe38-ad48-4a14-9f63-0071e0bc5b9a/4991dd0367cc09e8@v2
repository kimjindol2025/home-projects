// 섹션 4: 플러그인 아키텍처 기초
// ============================================================================
fn section_4_plugin_architecture_basics() {
    println!("\n📌 섹션 4: 플러그인 아키텍처 기초");
    println!("────────────────────────────────────────");

    // [Core] 모든 플러그인이 구현해야 할 명세서
    trait Plugin {
        fn name(&self) -> &str;
        fn version(&self) -> &str;
        fn execute(&self, input: &str) -> String;
    }

    // [Core Engine] 플러그인을 관리하는 엔진
    struct PluginEngine {
        plugins: Vec<Box<dyn Plugin>>,
    }

    impl PluginEngine {
        fn new() -> Self {
            PluginEngine {
                plugins: Vec::new(),
            }
        }

        fn register(&mut self, plugin: Box<dyn Plugin>) {
            println!("  [엔진] {} v{} 등록 완료", plugin.name(), plugin.version());
            self.plugins.push(plugin);
        }

        fn execute_all(&self, input: &str) {
            println!("  모든 플러그인 실행:");
            for plugin in &self.plugins {
                let result = plugin.execute(input);
                println!("    [{}] {}", plugin.name(), result);
            }
        }
    }

    // [Plugin 1]
    struct UppercasePlugin;
    impl Plugin for UppercasePlugin {
        fn name(&self) -> &str {
            "Uppercase"
        }
        fn version(&self) -> &str {
            "1.0"
        }
        fn execute(&self, input: &str) -> String {
            input.to_uppercase()
        }
    }

    // [Plugin 2]
    struct ReversePlugin;
    impl Plugin for ReversePlugin {
        fn name(&self) -> &str {
            "Reverse"
        }
        fn version(&self) -> &str {
            "1.0"
        }
        fn execute(&self, input: &str) -> String {
            input.chars().rev().collect()
        }
    }

    let mut engine = PluginEngine::new();
    engine.register(Box::new(UppercasePlugin));
    engine.register(Box::new(ReversePlugin));

    engine.execute_all("hello");

    println!("\n  🔍 플러그인 아키텍처의 특징:");
    println!("    ✅ 엔진 코드는 건드리지 않음");
    println!("    ✅ Plugin 트레이트만 구현하면 자동으로 수용");
    println!("    ✅ 무한 확장성");
}

