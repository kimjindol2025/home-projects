fn section_1_trait_bounds() {
    println!("\n📌 섹션 1: 트레이트 바운드와 상속");
    println!("────────────────────────────────────────");

    trait Animal {
        fn speak(&self) -> &str;
    }

    trait Mammal: Animal {
        fn warm_blooded(&self) -> bool {
            true
        }
    }

    struct Dog;
    impl Animal for Dog {
        fn speak(&self) -> &str {
            "멍멍!"
        }
    }

    impl Mammal for Dog {}

    let dog = Dog;
    println!("  개: {}", dog.speak());
    println!("  온혈동물: {}", dog.warm_blooded());

    // 트레이트 바운드 사용
    fn describe_mammal<T: Mammal>(mammal: &T) {
        println!("  말하는 포유동물: {}", mammal.speak());
    }

    describe_mammal(&dog);

    println!("\n  🔍 트레이트 바운드의 특징:");
    println!("    ✅ 트레이트가 다른 트레이트를 상속");
    println!("    ✅ T: Mammal은 'T는 Mammal을 구현해야 함' 의미");
    println!("    ✅ 제네릭 + 트레이트 = 유연한 설계");
}

