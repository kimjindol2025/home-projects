    println!("  여러 로거가 동일한 메서드로 실행:");
    for logger in &loggers {
        logger.log("시스템 메시지");
    }

    println!("\n  🔍 트레이트 객체의 특징:");
    println!("    ✅ 런타임 다형성 (동적 디스패치)");
    println!("    ✅ 서로 다른 구체 타입을 동일하게 처리");
    println!("    ✅ 플러그인 시스템의 기반");
}

