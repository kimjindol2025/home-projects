// 섹션 5: 보안 엔진 (핵심 예제)
// ============================================================================
fn section_5_security_engine_core() {
    println!("\n📌 섹션 5: 보안 엔진 (핵심 예제)");
    println!("────────────────────────────────────────");

    // [Core Specification] 모든 보안 플러그인의 명세서
    trait SecurityPlugin {
        fn name(&self) -> &str;
        fn scan(&self, data: &str) -> bool;
    }

    // [Core Engine] 플러그인을 관리하는 보안 엔진
    struct SecurityEngine {
        plugins: Vec<Box<dyn SecurityPlugin>>,
    }

    impl SecurityEngine {
        fn new() -> Self {
            SecurityEngine {
                plugins: Vec::new(),
            }
        }

        fn add_plugin(&mut self, plugin: Box<dyn SecurityPlugin>) {
            println!("  [보안엔진] '{}' 플러그인 장착 완료", plugin.name());
            self.plugins.push(plugin);
        }

        fn run_all_scans(&self, data: &str) -> bool {
            println!("  [보안엔진] 통합 보안 스캔 시작...");
            let mut all_safe = true;
            for plugin in &self.plugins {
                if !plugin.scan(data) {
                    println!("    🚨 [위험] '{}'에서 문제 감지!", plugin.name());
                    all_safe = false;
                } else {
                    println!("    ✅ [안전] '{}' 통과", plugin.name());
                }
            }
            all_safe
        }
    }

    // [Plugin 1: 외부에서 만들어진 바이러스 스캐너]
    struct VirusScanner;
    impl SecurityPlugin for VirusScanner {
        fn name(&self) -> &str {
            "Virus-Scanner v1.0"
        }
        fn scan(&self, data: &str) -> bool {
            !data.contains("VIRUS")
        }
    }

    // [Plugin 2: SQL 인젝션 방어]
    struct SqlInjectionDefender;
    impl SecurityPlugin for SqlInjectionDefender {
        fn name(&self) -> &str {
            "SQL-Guard v2.0"
        }
        fn scan(&self, data: &str) -> bool {
            !data.contains("DROP TABLE") && !data.contains("SELECT *")
        }
    }

    let mut engine = SecurityEngine::new();
    engine.add_plugin(Box::new(VirusScanner));
    engine.add_plugin(Box::new(SqlInjectionDefender));

    let safe_data = "SAFE INPUT DATA";
    let unsafe_data = "DROP TABLE users;";

    println!("\n  안전한 데이터 스캔:");
    engine.run_all_scans(safe_data);

    println!("\n  위험한 데이터 스캔:");
    engine.run_all_scans(unsafe_data);

    println!("\n  🔍 보안 엔진의 특징:");
    println!("    ✅ 핵심 엔진은 변경 없음");
    println!("    ✅ 새 보안 플러그인 추가만으로 기능 확장");
    println!("    ✅ OCP (개방-폐쇄 원칙) 완벽 준수");
}

