// 섹션 9: 안티패턴 2: Tight Coupling 피하기
// ============================================================================
fn section_9_antipattern_tight_coupling() {
    println!("\n📌 섹션 9: 안티패턴 2 - Tight Coupling 피하기");
    println!("────────────────────────────────────────");

    println!("  ❌ 나쁜 설계 (강한 결합):");
    println!("    struct EmailService {{");
    println!("        smtp_server: SmtpServer,  // 구체 타입");
    println!("    }}");
    println!("    → EmailService가 SmtpServer에 의존");
    println!("    → SmtpServer 변경 시 EmailService도 변경 필수");

    println!("\n  ✅ 좋은 설계 (약한 결합):");
    println!("    trait MailServer {{");
    println!("        fn send(&self, to: &str, msg: &str);");
    println!("    }}");
    println!("    struct EmailService {{");
    println!("        server: Box<dyn MailServer>,  // 트레이트 객체");
    println!("    }}");
    println!("    → 구현은 외부에서 주입");
    println!("    → 어떤 MailServer든 작동 가능");

    // 실제 구현
    trait MailServer {
        fn send(&self, to: &str, msg: &str);
    }

    struct SmtpServer;
    impl MailServer for SmtpServer {
        fn send(&self, to: &str, msg: &str) {
            println!("    [SMTP] {} -> {}", to, msg);
        }
    }

    struct CloudMailServer;
    impl MailServer for CloudMailServer {
        fn send(&self, to: &str, msg: &str) {
            println!("    [Cloud] {} -> {}", to, msg);
        }
    }

    struct EmailService {
        server: Box<dyn MailServer>,
    }

    impl EmailService {
        fn send_welcome(&self, email: &str) {
            self.server.send(email, "환영합니다!");
        }
    }

    println!("\n  SMTP 서버 사용:");
    let service1 = EmailService {
        server: Box::new(SmtpServer),
    };
    service1.send_welcome("user@example.com");

    println!("\n  클라우드 서버 사용 (같은 코드):");
    let service2 = EmailService {
        server: Box::new(CloudMailServer),
    };
    service2.send_welcome("user@example.com");

    println!("\n  🔍 느슨한 결합의 특징:");
    println!("    ✅ 서비스와 구현이 독립적");
    println!("    ✅ 서버 구현 변경 불필요");
    println!("    ✅ 테스트 서버 주입 가능");
}

