// 섹션 3: Blanket Implementation
// ============================================================================
fn section_3_blanket_implementations() {
    println!("\n📌 섹션 3: Blanket Implementation");
    println!("────────────────────────────────────────");

    trait Printable {
        fn print(&self);
    }

    trait Serializable {
        fn serialize(&self) -> String;
    }

    // [Blanket Implementation] Printable을 구현하는 모든 타입에 자동으로 기능 부여
    impl<T: Serializable> Printable for T {
        fn print(&self) {
            println!("    [출력] {}", self.serialize());
        }
    }

    struct Person {
        name: String,
    }

    impl Serializable for Person {
        fn serialize(&self) -> String {
            format!("Person({})", self.name)
        }
    }

    let person = Person {
        name: "Alice".to_string(),
    };

    // Person이 Serializable을 구현하면, 자동으로 Printable 사용 가능
    person.print();

    println!("\n  🔍 Blanket Implementation의 특징:");
    println!("    ✅ 조건을 만족하는 모든 타입에 자동 구현");
    println!("    ✅ 코드 중복 제거");
    println!("    ✅ 새로운 타입도 자동으로 이 기능 사용 가능");
}

