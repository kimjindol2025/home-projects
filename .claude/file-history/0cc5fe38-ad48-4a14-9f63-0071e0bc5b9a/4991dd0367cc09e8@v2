// 섹션 7: 의존성 주입 (Dependency Injection)
// ============================================================================
fn section_7_dependency_injection() {
    println!("\n📌 섹션 7: 의존성 주입 (Dependency Injection)");
    println!("────────────────────────────────────────");

    trait Repository {
        fn find(&self, id: u32) -> Option<String>;
    }

    struct InMemoryRepository {
        data: std::collections::HashMap<u32, String>,
    }

    impl Repository for InMemoryRepository {
        fn find(&self, id: u32) -> Option<String> {
            self.data.get(&id).cloned()
        }
    }

    // [좋은 설계] Service가 구체 타입을 모름
    struct UserService {
        repository: Box<dyn Repository>,
    }

    impl UserService {
        fn new(repo: Box<dyn Repository>) -> Self {
            UserService { repository: repo }
        }

        fn get_user(&self, id: u32) -> Option<String> {
            self.repository.find(id)
        }
    }

    // 구현
    let mut data = std::collections::HashMap::new();
    data.insert(1, "Alice".to_string());
    data.insert(2, "Bob".to_string());

    let repo = Box::new(InMemoryRepository { data });
    let service = UserService::new(repo);

    println!("  사용자 조회:");
    if let Some(user) = service.get_user(1) {
        println!("    사용자 1: {}", user);
    }

    if let Some(user) = service.get_user(2) {
        println!("    사용자 2: {}", user);
    }

    println!("\n  🔍 의존성 주입의 특징:");
    println!("    ✅ Service는 Repository 인터페이스만 알음");
    println!("    ✅ 구체 구현은 외부에서 주입");
    println!("    ✅ 테스트하기 쉬움 (Mock 주입 가능)");
    println!("    ✅ 느슨한 결합 (loose coupling)");
}

