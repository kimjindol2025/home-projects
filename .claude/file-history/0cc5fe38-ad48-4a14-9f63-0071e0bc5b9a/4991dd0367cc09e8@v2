fn section_8_antipattern_deep_hierarchy() {
    println!("\n📌 섹션 8: 안티패턴 1 - Deep Hierarchy 피하기");
    println!("────────────────────────────────────────");

    println!("  ❌ 나쁜 설계 (상속 지옥):");
    println!("    Animal (trait)");
    println!("      ↓");
    println!("    Mammal (trait: Animal)");
    println!("      ↓");
    println!("    Carnivore (trait: Mammal)");
    println!("      ↓");
    println!("    DogBreed (trait: Carnivore)");
    println!("      ↓");
    println!("    SpecificDog (struct: impl DogBreed)");
    println!("    → 깊은 계층, 이해 어려움, 수정 위험");

    println!("\n  ✅ 좋은 설계 (합성):");
    println!("    trait Walkable {{ }}");
    println!("    trait Eatable {{ }}");
    println!("    trait Trainable {{ }}");
    println!("    ");
    println!("    struct Dog;");
    println!("    impl Walkable for Dog {{ }}");
    println!("    impl Eatable for Dog {{ }}");
    println!("    impl Trainable for Dog {{ }}");
    println!("    → 평탄한 구조, 명확함, 유연함");

    // 실제 구현
    trait Walkable {
        fn walk(&self) -> &str;
    }

    trait Eatable {
        fn eat(&self) -> &str;
    }

    trait Trainable {
        fn train(&self) -> &str;
    }

    struct Dog;
    impl Walkable for Dog {
        fn walk(&self) -> &str {
            "산책 중..."
        }
    }
    impl Eatable for Dog {
        fn eat(&self) -> &str {
            "먹이 섭취 중..."
        }
    }
    impl Trainable for Dog {
        fn train(&self) -> &str {
            "훈련 중..."
        }
    }

    let dog = Dog;
    println!("\n  개의 행동:");
    println!("    {}", dog.walk());
    println!("    {}", dog.eat());
    println!("    {}", dog.train());

    println!("\n  🔍 합성의 특징:");
    println!("    ✅ 각 기능이 명확한 경계");
    println!("    ✅ 필요한 기능만 구현");
    println!("    ✅ 수정과 확장이 용이");
}

