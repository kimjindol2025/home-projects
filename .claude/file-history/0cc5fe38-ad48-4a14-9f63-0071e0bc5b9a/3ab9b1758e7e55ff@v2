## 📊 실전 예제: 지능형 시스템

```rust
#[derive(Debug, Clone)]
struct IntelligentSystem {
    name: String,
    status: String,
    load: u32,
    components: Vec<String>,
}

// impl 1: 생성과 조회
impl IntelligentSystem {
    fn new(name: &str) -> IntelligentSystem {
        IntelligentSystem {
            name: String::from(name),
            status: String::from("IDLE"),
            load: 0,
            components: Vec::new(),
        }
    }

    fn status(&self) -> &str {
        &self.status
    }

    fn display(&self) {
        println!("📊 [{}] 상태: {}, 부하: {}%",
                 self.name, self.status, self.load);
    }
}

// impl 2: 상태 변경
impl IntelligentSystem {
    fn activate(&mut self) {
        self.status = String::from("ACTIVE");
        self.load = 45;
    }

    fn deactivate(&mut self) {
        self.status = String::from("IDLE");
        self.load = 0;
    }
}

// impl 3: 컴포넌트 관리
impl IntelligentSystem {
    fn add_component(&mut self, component: String) {
        self.components.push(component);
    }

    fn component_count(&self) -> usize {
        self.components.len()
    }
}

// 사용
let mut system = IntelligentSystem::new("Alpha");
system.display();           // 📊 [Alpha] 상태: IDLE, 부하: 0%

system.add_component(String::from("CPU"));
system.add_component(String::from("GPU"));
println!("컴포넌트: {}", system.component_count());  // 2

system.activate();
system.display();           // 📊 [Alpha] 상태: ACTIVE, 부하: 45%
```

