    println!("📌 섹션 2: 금고 생성 및 접근\n");
    {
        match GogsVault::new("VERY_SECRET_KEY_123456") {
            Ok(vault) => {
                println!("✅ 금고 생성 성공");
                println!("   정보: {:?}\n", vault.info());

                // 올바른 키로 접근
                match vault.access("VERY_SECRET_KEY_123456") {
                    Ok(true) => println!("✅ 올바른 키로 접근 성공"),
                    Ok(false) => println!("❌ 키 불일치"),
                    Err(e) => println!("❌ 에러: {}", e),
                }

                // 잘못된 키로 접근
                match vault.access("WRONG_KEY_123456") {
                    Ok(true) => println!("❌ 보안 위반!"),
                    Ok(false) => println!("✅ 잘못된 키 차단됨"),
                    Err(e) => println!("❌ 에러: {}", e),
                }
                println!();
            }
            Err(e) => println!("❌ 금고 생성 실패: {}\n", e),
        }
    }

    // ==================== 섹션 3: 에러 처리 ====================
    println!("📌 섹션 3: 에러 처리 및 검증\n");
    {
        println!("경우 1: 너무 짧은 키");
        match GogsVault::new("SHORT") {
            Ok(_) => println!("❌ 보안 위반"),
            Err(VaultError::InvalidKeyLength { expected, got }) => {
                println!("✅ 올바른 에러 처리: 예상 {}, 실제 {}\n", expected, got)
            }
            Err(e) => println!("❌ 예상치 못한 에러: {}\n", e),
        }

        println!("경우 2: 빈 입력 처리");
        let vault = GogsVault::new("VALID_SECRET_KEY_123456").unwrap();
        match vault.access("") {
            Ok(_) => println!("❌ 빈 입력이 허용됨"),
            Err(VaultError::InvalidInput(msg)) => {
                println!("✅ 올바른 에러 처리: {}\n", msg)
            }
            Err(e) => println!("❌ 예상치 못한 에러: {}\n", e),
        }
    }

    // ==================== 섹션 4: 입력 검증 ====================
    println!("📌 섹션 4: 입력 검증 공개 함수\n");
    {
        let test_cases = vec![
            ("LONG_VALID_INPUT_123", "유효한 입력"),
            ("SHORT", "너무 짧은 입력"),
            ("", "빈 입력"),
        ];

        for (input, description) in test_cases {
            match validate_input(input) {
                Ok(true) => println!("✅ {}: 유효함", description),
                Ok(false) => println!("⚠️  {}: 빈 입력", description),
                Err(e) => println!("❌ {}: {}", description, e),
            }
        }
        println!();
    }

    // ==================== 섹션 5: 보안 이벤트 ====================
    println!("📌 섹션 5: 보안 이벤트 생성 및 로깅\n");
    {
        let event1 = create_event("user_login", true);
        let event2 = create_event("failed_access", false);

        println!("이벤트 1: {:?}", event1);
        println!("로그: {}", SecurityHandler::log_access(&event1));
        println!();

        println!("이벤트 2: {:?}", event2);
        println!("로그: {}", SecurityHandler::log_access(&event2));
        println!();
    }

    // ==================== 섹션 6: 보안 정책 확인 ====================
    println!("📌 섹션 6: 보안 정책 검증\n");
    {
        let test_levels = vec![3, 5, 8, 10];

        for level in test_levels {
            let policy_ok = SecurityHandler::check_policy(level);
            let status = if policy_ok { "✅ 허용" } else { "❌ 거부" };
            println!("보안 레벨 {}: {}", level, status);
        }
        println!();
    }

    // ==================== 섹션 7: 모니터링 ====================
    println!("📌 섹션 7: 이벤트 모니터링\n");
    {
        let event = create_event("system_check", true);

        match monitor_event(&event) {
            Ok(()) => println!("✅ 이벤트 모니터링 성공: {:?}\n", event),
            Err(e) => println!("❌ 모니터링 실패: {}\n", e),
        }
    }

    // ==================== 섹션 8: 통계 수집 ====================
    println!("📌 섹션 8: 성공률 통계\n");
    {
        let test_cases = vec![(10, 10), (8, 10), (5, 10), (0, 10)];

        for (success, total) in test_cases {
            let percentage = collect_stats(success, total);
            println!("성공 {}/{}: {:.1}%", success, total, percentage);
        }
        println!();
    }

    // ==================== 섹션 9: 통합 시나리오 ====================
    println!("📌 섹션 9: 실전 통합 시나리오\n");
    {
        println!("시나리오: 사용자 인증 시스템");
        println!();

        // 단계 1: 금고 생성
        let vault = match GogsVault::new("SECURE_AUTH_KEY_2026") {
            Ok(v) => {
                println!("1️⃣  금고 생성: ✅");
                v
            }
            Err(e) => {
                println!("1️⃣  금고 생성: ❌ ({})", e);
                return;
            }
        };

        // 단계 2: 사용자 입력 검증
        let user_input = "SECURE_AUTH_KEY_2026";
        match validate_input(user_input) {
            Ok(true) => println!("2️⃣  입력 유효성: ✅"),
            _ => println!("2️⃣  입력 유효성: ❌"),
        }

        // 단계 3: 접근 제어
        match vault.access(user_input) {
            Ok(true) => {
                println!("3️⃣  접근 제어: ✅");
                let event = create_event("user_authenticated", true);
                println!("4️⃣  이벤트 기록: {:?}", event);
                println!("5️⃣  로그 작성: {}", SecurityHandler::log_access(&event));
            }
            _ => println!("3️⃣  접근 제어: ❌"),
        }
        println!();
    }

    // ==================== 섹션 10: 라이브러리 설계 원칙 ====================
    println!("📌 섹션 10: 라이브러리 설계 원칙\n");
    {
        println!("✅ 1. 공개 인터페이스의 명확성");
        println!("   모든 pub 항목은 외부 사용자가 사용할 수 있습니다.");
        println!();

        println!("✅ 2. 캡슐화");
        println!("   private 항목은 외부에서 접근 불가능합니다.");
        println!();

        println!("✅ 3. 에러 처리");
        println!("   공개 enum(VaultError)로 통일된 에러 관리");
        println!();

        println!("✅ 4. 모듈 조직");
        println!("   pub mod security, pub mod monitoring으로 기능 분류");
        println!();

        println!("✅ 5. 문서화");
        println!("   /// doc comments로 사용법 명시");
        println!();
    }

    // ==================== 섹션 11: 통합 테스트 준비 ====================
    println!("📌 섹션 11: 통합 테스트 환경\n");
    {
        println!("이 라이브러리는 다음과 같이 테스트됩니다:");
        println!();

        println!("🧪 단위 테스트 (lib.rs 내부):");
        println!("   #[cfg(test)] 모듈에서 구현 세부 사항 검증");
        println!();

        println!("🧪 통합 테스트 (tests/ 디렉토리):");
        println!("   use gogs_project::GogsVault; // 공개 API만 사용");
        println!("   다른 개발자의 입장에서 라이브러리 사용 흐름 검증");
        println!();

        println!("테스트 파일 구조:");
        println!("   tests/integration_test_vault.rs");
        println!("   tests/integration_test_workflow.rs");
        println!("   tests/integration_test_edge_cases.rs");
        println!();
    }

