// 러스트 시스템 프로그래밍의 기초
// Phase 1 ~ 5 진행 중
// [저장 필수] 기록이 증명이다 gogs: 프로젝트 진화 로그

// Phase 5: 모듈 시스템을 활용한 리팩토링
use gogs_project::{GogsEngine, logger};

fn main() {
    println!("╔════════════════════════════════════════╗");
    println!("║ Gogs Project Level 5: Module System   ║");
    println!("║   코드의 확장성과 보안 제어           ║");
    println!("╚════════════════════════════════════════╝\n");

    // ==========================================
    // [5.1] 모듈 시스템: 공개와 비공개
    // ==========================================
    println!("📦 [5.1] 모듈 시스템\n");

    // lib.rs에서 공개한 GogsEngine 사용
    let mut engine = GogsEngine::new("Gogs Standard Edition");

    // 공개 필드: 접근 가능
    println!("공개 필드 - 엔진 이름: {}", engine.name);

    // 엔진 상태 출력
    engine.print_status();

    // 비공개 필드: 접근 불가능
    // println!("비공개 필드: {}", engine.version);  // ❌ 컴파일 에러!
    println!("비공개 필드는 getter를 통해 접근: {}\n", engine.get_version());

    // ==========================================
    // [5.2] 모듈 경로와 use 키워드
    // ==========================================
    println!("📌 [5.2] 모듈 경로와 use 키워드\n");

    // utils 모듈의 logger 함수 사용
    logger::info("프로젝트 레벨 5: 모듈 시스템 시작");
    logger::debug("모듈 구조 확인");

    println!();

    // ==========================================
    // [5.3] 캡슐화: 공개 API 설계
    // ==========================================
    println!("📌 [5.3] 캡슐화와 공개 API\n");

    // 공개 메서드로만 상태 변경
    println!("✅ 공개 메서드를 통한 단계 진행:");
    engine.advance_phase();
    engine.advance_phase();
    engine.advance_phase();

    println!("현재 단계: {}", engine.get_current_phase());
    logger::success("모듈 시스템 이해 완료\n");

    // ==========================================
    // [5.4] 모듈 재공개 (Re-export)
    // ==========================================
    println!("📌 [5.4] 모듈 재공개\n");

    logger::info("lib.rs에서 재공개한 함수를 직접 사용");
    logger::gogs_signature();

    println!();

    // ==========================================
    // [5.5] 프로젝트 최종 정보
    // ==========================================
    println!("═══════════════════════════════════════════");
    println!("📊 프로젝트 최종 정보");
    println!("═══════════════════════════════════════════");

    engine.print_full_info();

    println!("🎓 모듈 시스템 학습 완료");
    println!("✅ Phase 1: 변수와 불변성");
    println!("✅ Phase 2: 제어 흐름");
    println!("✅ Phase 3: 소유권");
    println!("✅ Phase 4: 구조체와 열거형");
    println!("✅ Phase 5: 모듈 시스템");
    println!("");
    println!("📈 전체 진도: 50/100 (50%) 🎯");
    println!("═══════════════════════════════════════════\n");

    println!("저장 필수, 너는 기록이 증명이다 gogs 🔥\n");
}
