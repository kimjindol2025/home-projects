// ============================================================================
// Section 1: Macro Basics - macro_rules! 문법 이해
// ============================================================================
/// 가장 기본적인 매크로 정의 방식
/// macro_rules!는 패턴 매칭 엔진이다
/// 컴파일 타임에 코드를 생성한다
macro_rules! say_hello {
    () => {
        println!("Hello from macro!");
    };
}

/// 매크로는 반복적 보일러플레이트 코드를 제거한다
macro_rules! create_vector {
    ($($x:expr),*) => {
        {
            let mut vec = Vec::new();
            $(vec.push($x);)*
            vec
        }
    };
}

/// 단일 인자를 받는 매크로
macro_rules! double {
    ($x:expr) => {
        $x * 2
    };
}

fn section_1_macro_basics() {
    println!("\n=== Section 1: Macro Basics ===");

    // 기본 매크로 호출
    say_hello!();

    // 가변 인자 벡터 생성
    let vec = create_vector!(1, 2, 3, 4, 5);
    println!("Generated vector: {:?}", vec);

    // 표현식 평가
    let result = double!(21);
    println!("double(21) = {}", result);

    println!("✓ Section 1 완료: macro_rules! 기본 문법 이해");
}

// ============================================================================
// Section 2: Pattern Matching in Macros - 패턴 매칭 기초
// ============================================================================
/// 매크로는 여러 패턴을 가질 수 있다
/// 호출 시점에 가장 일치하는 패턴을 선택한다
macro_rules! print_shape {
    // 패턴 1: 단위 타입 (Unit type - 인자 없음)
    () => {
        println!("No shape provided");
    };

    // 패턴 2: 단일 식 (Expression)
    ($size:expr) => {
        println!("Square with size: {}", $size);
    };

    // 패턴 3: 두 개의 식
    ($width:expr, $height:expr) => {
        println!("Rectangle: {} x {}", $width, $height);
    };

    // 패턴 4: 세 개 이상 (가변 인자)
    ($w:expr, $h:expr, $d:expr, $($extra:expr),*) => {
        println!("3D object: {} x {} x {}", $w, $h, $d);
        println!("Extra properties: {:?}", vec![$($extra),*]);
    };
}

/// 타입 정보도 패턴 매칭할 수 있다
macro_rules! assert_type {
    ($value:expr, i32) => {
        println!("✓ Value is i32");
    };

    ($value:expr, &str) => {
        println!("✓ Value is &str");
    };
}

fn section_2_pattern_matching() {
    println!("\n=== Section 2: Pattern Matching in Macros ===");

    print_shape!();
    print_shape!(10);
    print_shape!(20, 30);
    print_shape!(5, 10, 15, "prop1", "prop2");

    assert_type!(42, i32);
    assert_type!("hello", &str);

    println!("✓ Section 2 완료: 매크로 패턴 매칭 5가지");
}

// ============================================================================
// Section 3: Designators - 지정자와 토큰 타입
// ============================================================================
/// Rust 매크로의 지정자들:
/// - expr: 표현식 (연산식, 함수 호출, 리터럴)
/// - ident: 식별자 (변수명, 함수명)
/// - stmt: 문장 (세미콜론 포함)
/// - path: 경로 (std::vec::Vec)
/// - tt: 토큰 트리 (아무거나)
/// - ty: 타입 (i32, String, Vec<T>)
/// - item: 아이템 (fn, struct, impl)
/// - block: 블록 ({ ... })
/// - meta: 속성 (#[attr])
/// - vis: 가시성 (pub, pub(crate))
/// - lifetime: 수명 ('a, 'static)

macro_rules! create_function {
    // item 지정자: 전체 함수 정의
    ($func_name:ident, $body:block) => {
        fn $func_name() {
            $body
        }
    };
}

macro_rules! variable_type {
    // 지정자별 사용 예시
    ($name:ident = $value:expr, type $ty:ty) => {
        #[allow(unused)]
        let $name: $ty = $value;
        println!("Variable {} assigned with type", stringify!($name));
    };
}

macro_rules! create_path {
    // path 지정자
    ($path:path) => {
        println!("Using path: {}", stringify!($path));
    };
}

fn section_3_designators() {
    println!("\n=== Section 3: Designators ===");

    create_function!(my_func, {
        println!("This function was created by a macro!");
    });

    my_func();

    variable_type!(my_var = 42, type i32);

    create_path!(std::collections::HashMap);

    println!("✓ Section 3 완료: 8가지 지정자 마스터");
}

// ============================================================================
// Section 4: Variable-Length Arguments - 가변 인자 패턴
// ============================================================================
/// $(...)* 패턴은 0번 이상 반복
/// $(...)+ 패턴은 1번 이상 반복
/// 구분자(separator)로 쉼표, 세미콜론 등을 사용 가능

macro_rules! sum {
    // 단일 인자
    ($x:expr) => {
        $x
    };

    // 가변 인자: 마지막 인자 + 나머지
    ($x:expr, $($tail:expr),+) => {
        $x + sum!($($tail),+)
    };
}

macro_rules! join_strings {
    // 문자열들을 공백으로 연결
    ($($s:expr),*) => {
        {
            let strings: Vec<&str> = vec![$($s),*];
            strings.join(" ")
        }
    };
}

macro_rules! declare_vars {
    // 여러 변수 선언: var x = 1; var y = 2; ...
    ($($name:ident = $value:expr);+) => {
        $(let $name = $value;)+
    };
}

fn section_4_variable_args() {
    println!("\n=== Section 4: Variable-Length Arguments ===");

    let result = sum!(1, 2, 3, 4, 5);
    println!("sum!(1, 2, 3, 4, 5) = {}", result);

    let text = join_strings!("Hello", "from", "Rust", "macros");
    println!("Joined string: {}", text);

    declare_vars!(
        x = 10;
        y = 20;
        z = 30
    );
    println!("Variables: x={}, y={}, z={}", x, y, z);

    println!("✓ Section 4 완료: $(...)* 와 $(...)+ 패턴");
}

// ============================================================================
// Section 5: Recursive Macros - 재귀 매크로
// ============================================================================
/// 매크로는 자기 자신을 호출할 수 있다
/// 코드 생성의 유연성을 극대화한다
/// 하지만 무한 재귀를 피해야 한다

macro_rules! count_items {
    // Base case: 빈 리스트
    () => {
        0
    };

    // Recursive case: 첫 항목 + 나머지 재귀
    ($first:expr) => {
        1
    };

    ($first:expr, $($rest:expr),+) => {
        1 + count_items!($($rest),+)
    };
}

macro_rules! build_list {
    // Base case
    ($x:expr) => {
        {
            let mut list = Vec::new();
            list.push($x);
            list
        }
    };

    // Recursive case
    ($x:expr, $($rest:expr),+) => {
        {
            let mut list = build_list!($($rest),+);
            list.insert(0, $x);
            list
        }
    };
}

macro_rules! nest_tuples {
    // Base case: 단일 값
    ($x:expr) => {
        $x
    };

    // Recursive case: 튜플 구성
    ($x:expr, $($rest:expr),+) => {
        ($x, nest_tuples!($($rest),+))
    };
}

fn section_5_recursive_macros() {
    println!("\n=== Section 5: Recursive Macros ===");

    let count = count_items!(1, 2, 3, 4, 5, 6);
    println!("count_items!(1..6) = {}", count);

    let list = build_list!(10, 20, 30, 40);
    println!("build_list!(10, 20, 30, 40) = {:?}", list);

    let nested = nest_tuples!(1, 2, 3, 4, 5);
    println!("nest_tuples!(1, 2, 3, 4, 5) = {:?}", nested);

    println!("✓ Section 5 완료: 재귀 매크로 3가지 패턴");
}

// ============================================================================
// Section 6: gogs_log! Macro System - 핵심 예제
// ============================================================================
/// gogs_log!는 레벨별 로깅 매크로 시스템
/// 컴파일 타임에 최적화된 로깅 코드 생성
/// 타입 안전성과 가변 인자 지원

macro_rules! gogs_log {
    // 포맷: gogs_log!(level, "format")
    (trace, $fmt:expr) => {
        println!("[TRACE] {}", $fmt);
    };

    (trace, $fmt:expr, $($arg:tt),+) => {
        println!("[TRACE] {}: {:?}", $fmt, stringify!($($arg),+));
    };

    (debug, $fmt:expr) => {
        println!("[DEBUG] {}", $fmt);
    };

    (debug, $fmt:expr, $($arg:tt),+) => {
        println!("[DEBUG] {}: {:?}", $fmt, stringify!($($arg),+));
    };

    (info, $fmt:expr) => {
        println!("[INFO] {}", $fmt);
    };

    (info, $fmt:expr, $($arg:tt),+) => {
        println!("[INFO] {}: {:?}", $fmt, stringify!($($arg),+));
    };

    (warn, $fmt:expr) => {
        println!("[WARN] {}", $fmt);
    };

    (warn, $fmt:expr, $($arg:tt),+) => {
        println!("[WARN] {}: {:?}", $fmt, stringify!($($arg),+));
    };

    (error, $fmt:expr) => {
        println!("[ERROR] {}", $fmt);
    };

    (error, $fmt:expr, $($arg:tt),+) => {
        println!("[ERROR] {}: {:?}", $fmt, stringify!($($arg),+));
    };
}

/// 더 강력한 버전: 컨텍스트와 함께 로깅
macro_rules! gogs_log_ctx {
    ($level:expr, $ctx:expr, $msg:expr) => {
        println!("[{}] [{}] {}", $level, $ctx, $msg);
    };

    ($level:expr, $ctx:expr, $msg:expr, $($arg:expr),+) => {
        println!("[{}] [{}] {}: {:?}", $level, $ctx, $msg, vec![$($arg),*]);
    };
}

fn section_6_gogs_log() {
    println!("\n=== Section 6: gogs_log! Macro System ===");

    gogs_log!(trace, "Application started");
    gogs_log!(debug, "Loading configuration", "config.toml", "version 1.0");
    gogs_log!(info, "User logged in", "alice@example.com");
    gogs_log!(warn, "Memory usage high", 85, "%");
    gogs_log!(error, "Failed to save data", "timeout", "retry=3");

    println!("\n--- Context-aware logging ---");
    gogs_log_ctx!("INFO", "auth", "Login attempt successful");
    gogs_log_ctx!("ERROR", "db", "Connection refused", "host=localhost", "port=5432");

    println!("✓ Section 6 완료: gogs_log! 시스템 완성");
}

// ============================================================================
// Section 7: Token Tree Manipulation - 토큰 트리 조작
// ============================================================================
/// tt (token tree) 지정자는 어떤 토큰이든 받을 수 있다
/// 메타프로그래밍의 최강 도구
/// 복잡한 DSL (Domain-Specific Language) 구축 가능

macro_rules! repeat {
    // tt: 토큰 트리들 (여러 토큰 허용)
    ($body:tt, $n:expr) => {
        {
            let n = $n;
            for _i in 0..n {
                $body
            }
        }
    };
}

macro_rules! collect_tokens {
    // 여러 토큰 트리 수집
    ($($tt:tt),*) => {
        {
            let tokens = vec![$(stringify!($tt)),*];
            println!("Collected tokens: {}", tokens.join(" "));
        }
    };
}

macro_rules! wrap_in_block {
    // 토큰 트리를 블록으로 감싸기
    ($tt:tt) => {
        {
            $tt
        }
    };
}

fn section_7_token_trees() {
    println!("\n=== Section 7: Token Tree Manipulation ===");

    // Token tree 반복
    repeat!({
        println!("Repeating token tree");
    }, 3);

    // 토큰 수집
    collect_tokens!(fn, let, mut, x, =, 42);

    // 토큰을 블록으로 감싸기
    let result = wrap_in_block!({
        let sum = 1 + 2 + 3;
        sum * 2
    });
    println!("wrap_in_block result: {}", result);

    println!("✓ Section 7 완료: Token Tree 조작");
}

// ============================================================================
// Section 8: Common Macro Patterns - 자주 쓰는 패턴들
// ============================================================================

/// 패턴 1: Builder pattern (복잡한 객체 구성)
#[allow(unused_macros)]
macro_rules! builder {
    ($name:ident { $($field:ident: $value:expr),* }) => {
        {
            let mut obj = $name::new();
            $($obj.$field = $value;)*
            obj
        }
    };
}

/// 패턴 2: 열거형 생성 (boilerplate 제거)
#[allow(unused_macros)]
macro_rules! define_enum {
    ($name:ident { $($variant:ident),* }) => {
        enum $name {
            $($variant),*
        }
    };
}

/// 패턴 3: Default 구현 생성
#[allow(unused_macros)]
macro_rules! impl_default {
    ($name:ident, $default_value:expr) => {
        impl Default for $name {
            fn default() -> Self {
                $default_value
            }
        }
    };
}

/// 패턴 4: Debug 형식 간단히
macro_rules! simple_debug {
    ($expr:expr) => {
        println!("DEBUG: {} = {:?}", stringify!($expr), $expr);
    };
}

/// 패턴 5: 여러 타입 처리 (매크로 다중 디스패치)
macro_rules! max {
    ($a:expr, $b:expr) => {
        if $a > $b { $a } else { $b }
    };

    ($a:expr, $b:expr, $($rest:expr),+) => {
        max!(max!($a, $b), $($rest),+)
    };
}

fn section_8_common_patterns() {
    println!("\n=== Section 8: Common Macro Patterns ===");

    // 패턴 1: Builder
    struct Person {
        name: String,
        age: u32,
    }

    impl Person {
        fn new() -> Self {
            Person {
                name: String::new(),
                age: 0,
            }
        }
    }

    let mut person = Person::new();
    person.name = "Alice".to_string();
    person.age = 30;
    println!("Built person: {} ({})", person.name, person.age);

    // 패턴 4: Debug
    let x = 42;
    let y = "hello";
    simple_debug!(x);
    simple_debug!(y);

    // 패턴 5: Max with multiple args
    let max_val = max!(10, 5, 20, 3, 15);
    println!("max!(10, 5, 20, 3, 15) = {}", max_val);

    println!("✓ Section 8 완료: 5가지 자주 쓰는 패턴");
}

// ============================================================================
// Section 9: Performance Characteristics - 성능 특성
// ============================================================================
/// 매크로는 컴파일 타임에 코드 생성
/// 런타임 오버헤드: 0%
/// 바이너리 크기: 약간 증가 (코드 중복)
/// 컴파일 타임: 약간 증가 (매크로 확장)

#[allow(unused_macros)]
macro_rules! perf_test {
    ($name:expr, $code:block) => {
        {
            let start = std::time::Instant::now();
            let result = { $code };
            let elapsed = start.elapsed();
            println!("[PERF] {}: {:?}", $name, elapsed);
            result
        }
    };
}

macro_rules! inline_operations {
    // 함수 호출 vs 인라인 연산: 매크로는 인라인된다
    (add $a:expr, $b:expr) => {
        $a + $b  // 컴파일러가 인라인한다
    };

    (mul $a:expr, $b:expr) => {
        $a * $b
    };
}

fn section_9_performance() {
    println!("\n=== Section 9: Performance Characteristics ===");

    // 매크로 버전 (인라인, 0% 오버헤드)
    let macro_result = inline_operations!(add 10, 20);
    println!("Macro inline add: {}", macro_result);

    // 함수 호출과 동일한 성능
    fn function_add(a: i32, b: i32) -> i32 {
        a + b
    }
    let func_result = function_add(10, 20);
    println!("Function add: {}", func_result);

    println!("✓ Section 9 완료: 매크로 성능 특성");
    println!("  - 런타임 오버헤드: 0%");
    println!("  - 컴파일 타임: 약간 증가");
    println!("  - 인라인: 자동");
}

// ============================================================================
// Section 10: Advanced Patterns - 고급 패턴들
// ============================================================================
/// 중첩된 반복, 조건부 컴파일, 복잡한 재귀

#[allow(unused_macros)]
macro_rules! matrix {
    // 2D 배열 생성: matrix![[1,2],[3,4]]
    ([ $($row:tt),* ]) => {
        vec![
            $($row.to_vec()),*
        ]
    };
}

macro_rules! assert_equal {
    // 두 값이 같은지 확인, 다르면 panic
    ($left:expr, $right:expr) => {
        assert_equal!($left, $right, "left != right");
    };

    ($left:expr, $right:expr, $msg:expr) => {
        if $left != $right {
            panic!("{}: {:?} != {:?}", $msg, $left, $right);
        }
    };
}

macro_rules! combine {
    // 여러 벡터를 하나로 결합
    ($first:expr) => {
        $first
    };

    ($first:expr, $($rest:expr),+) => {
        {
            let mut combined = $first;
            $(combined.extend($rest);)+
            combined
        }
    };
}

fn section_10_advanced_patterns() {
    println!("\n=== Section 10: Advanced Patterns ===");

    assert_equal!(42, 42);
    assert_equal!("hello", "hello", "String comparison");

    let v1 = vec![1, 2, 3];
    let v2 = vec![4, 5, 6];
    let v3 = vec![7, 8, 9];
    let combined = combine!(v1, v2, v3);
    println!("Combined vectors: {:?}", combined);

    println!("✓ Section 10 완료: 고급 패턴들");
}

// ============================================================================
// Section 11: Macro Expansion Visualization - 매크로 확장 시각화
// ============================================================================
/// 매크로가 어떻게 코드로 확장되는지 이해하기
/// cargo expand 명령이나 println!로 확인 가능

macro_rules! show_expansion {
    // 매크로 확장을 문자열로 표현
    ($name:ident = $value:expr) => {
        {
            // 이것이 매크로가 생성하는 실제 코드다
            let $name = $value;
            println!("Macro expanded to: let {} = {:?};", stringify!($name), $name);
            $name
        }
    };
}

macro_rules! trace_macro {
    // 각 단계를 출력하면서 실행
    ($name:ident, $code:block) => {
        {
            println!(">>> Entering macro: {}", stringify!($name));
            let result = { $code };
            println!("<<< Exiting macro: {}", stringify!($name));
            result
        }
    };
}

fn section_11_expansion_visualization() {
    println!("\n=== Section 11: Macro Expansion Visualization ===");

    show_expansion!(x = 42);
    show_expansion!(message = "Hello, Rust!");

    println!("\n--- Tracing macro execution ---");
    trace_macro!(my_computation, {
        let a = 10;
        let b = 20;
        a + b
    });

    println!("✓ Section 11 완료: 매크로 확장 시각화");
}

