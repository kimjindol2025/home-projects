// 🧠 v9.4: Weak<T>과 순환 참조 방지 (Weak and Circular Reference Prevention)
// 🔗 "순환 참조를 안전하게 끊기"
// 🎯 "메모리 누수를 원천 차단"
//
// 핵심 개념:
// - Rc<T>: 강한 참조 (소유권, 메모리 소유)
// - Weak<T>: 약한 참조 (비소유, 소유권 없음)
// - 부모-자식 관계: 부모는 Rc, 자식은 Weak
// - upgrade(): Weak을 안전하게 Rc로 변환
// - 순환 참조 방지: A → B, B → A에서 한쪽은 Weak로
// - 실무 패턴: 트리, 그래프, UI 계층 구조

use std::rc::Rc;
use std::cell::RefCell;

fn main() {
    println!("╔══════════════════════════════════════════════════════════╗");
    println!("║ v9.4: Weak<T>과 순환 참조 방지                            ║");
    println!("║ \"순환 참조를 안전하게 끊기\"                              ║");
    println!("╚══════════════════════════════════════════════════════════╝\n");

    // ==================== 섹션 1: 강한 참조 vs 약한 참조 ====================
    println!("📌 섹션 1: 강한 참조 vs 약한 참조\n");
    {
        println!("Rc<T> (강한 참조):");
        println!("  ✅ 소유권 있음");
        println!("  ✅ 메모리 소유");
        println!("  ⚠️  순환 참조 위험");
        println!();

        println!("Weak<T> (약한 참조):");
        println!("  ❌ 소유권 없음");
        println!("  ❌ 메모리 소유하지 않음");
        println!("  ✅ 순환 참조 방지");
        println!();

        println!("메모리 생명 주기:");
        println!("  Rc: 마지막 Rc::drop()될 때 메모리 해제");
        println!("  Weak: 참조 카운트 영향 안 함");
        println!();
    }

    // ==================== 섹션 2: 순환 참조 문제 ====================
    println!("📌 섹션 2: 순환 참조 문제 (원래 문제)\n");
    {
        #[derive(Debug)]
        struct NodeWithCycle {
            id: usize,
            parent: RefCell<Option<Rc<NodeWithCycle>>>,
            children: RefCell<Vec<Rc<NodeWithCycle>>>,
        }

        println!("❌ 문제 구조 (순환 참조 발생):");
        println!("  struct NodeWithCycle {{");
        println!("    parent: RefCell<Option<Rc<NodeWithCycle>>>,");
        println!("    children: RefCell<Vec<Rc<NodeWithCycle>>>,");
        println!("  }}");
        println!();

        println!("순환 참조 문제:");
        println!("  1. parent가 child를 Rc로 소유");
        println!("  2. child가 parent를 Rc로 소유");
        println!("  3. 둘 다 스코프를 벗어나도 메모리 해제 불가");
        println!("  4. 메모리 누수 발생 ❌");
        println!();

        let _parent = Rc::new(NodeWithCycle {
            id: 1,
            parent: RefCell::new(None),
            children: RefCell::new(vec![]),
        });

        println!("이 구조에서는 업그레이드가 필요합니다...");
        println!();
    }

    // ==================== 섹션 3: Weak를 이용한 해결책 ====================
    println!("📌 섹션 3: Weak를 이용한 해결책\n");
    {
        use std::rc::Weak;

        #[derive(Debug)]
        struct Node {
            id: usize,
            parent: RefCell<Option<Weak<Node>>>,
            children: RefCell<Vec<Rc<Node>>>,
        }

        println!("✅ 해결 구조 (순환 참조 방지):");
        println!("  struct Node {{");
        println!("    parent: RefCell<Option<Weak<Node>>>,  // Weak 사용!");
        println!("    children: RefCell<Vec<Rc<Node>>>,");
        println!("  }}");
        println!();

        println!("해결 방법:");
        println!("  1. parent는 Weak (약한 참조)");
        println!("  2. children은 Rc (강한 참조)");
        println!("  3. 부모는 자식들 소유, 자식은 부모 비소유");
        println!("  4. 메모리 누수 없음 ✅");
        println!();

        let parent = Rc::new(Node {
            id: 1,
            parent: RefCell::new(None),
            children: RefCell::new(vec![]),
        });

        let child1 = Rc::new(Node {
            id: 2,
            parent: RefCell::new(Some(Rc::downgrade(&parent))),
            children: RefCell::new(vec![]),
        });

        let child2 = Rc::new(Node {
            id: 3,
            parent: RefCell::new(Some(Rc::downgrade(&parent))),
            children: RefCell::new(vec![]),
        });

        parent.children.borrow_mut().push(Rc::clone(&child1));
        parent.children.borrow_mut().push(Rc::clone(&child2));

        println!("노드 생성:");
        println!("  parent (id=1): {} 개 자식", parent.children.borrow().len());
        println!("  child1 (id=2): parent 참조 (Weak)");
        println!("  child2 (id=3): parent 참조 (Weak)");
        println!();
    }

    // ==================== 섹션 4: upgrade() 패턴 ====================
    println!("📌 섹션 4: upgrade() 패턴\n");
    {
        use std::rc::Weak;

        #[derive(Debug)]
        struct TreeNode {
            value: i32,
            parent: RefCell<Option<Weak<TreeNode>>>,
            children: RefCell<Vec<Rc<TreeNode>>>,
        }

        println!("upgrade() 함수:");
        println!("  - Weak<T>를 Option<Rc<T>>로 변환");
        println!("  - Some(Rc<T>): 부모가 아직 살아있음");
        println!("  - None: 부모가 이미 드롭됨");
        println!();

        let root = Rc::new(TreeNode {
            value: 1,
            parent: RefCell::new(None),
            children: RefCell::new(vec![]),
        });

        let child = Rc::new(TreeNode {
            value: 2,
            parent: RefCell::new(Some(Rc::downgrade(&root))),
            children: RefCell::new(vec![]),
        });

        root.children.borrow_mut().push(Rc::clone(&child));

        println!("upgrade() 사용:");
        {
            let parent_rc = child.parent.borrow().as_ref().and_then(|p| p.upgrade());
            match parent_rc {
                Some(parent) => {
                    println!("  ✅ 부모 살아있음: value = {}", parent.value);
                }
                None => {
                    println!("  ❌ 부모 드롭됨");
                }
            }
        }
        println!();

        println!("부모 드롭 후:");
        let child_weak = Rc::downgrade(&child);
        drop(root);

        println!("  부모가 드롭됨");
        if let Some(_) = child.parent.borrow().as_ref().and_then(|p| p.upgrade()) {
            println!("  ✅ 부모 살아있음");
        } else {
            println!("  ❌ 부모 이미 드롭됨");
        }
        println!();
    }

    // ==================== 섹션 5: 나무 구조 (부모-자식 관계) ====================
    println!("📌 섹션 5: 나무 구조 (부모-자식 관계)\n");
    {
        use std::rc::Weak;

        #[derive(Debug)]
        struct TreeNode {
            name: String,
            value: i32,
            parent: RefCell<Option<Weak<TreeNode>>>,
            children: RefCell<Vec<Rc<TreeNode>>>,
        }

        println!("나무 구조 예제:");
        println!();

        let root = Rc::new(TreeNode {
            name: "root".to_string(),
            value: 1,
            parent: RefCell::new(None),
            children: RefCell::new(vec![]),
        });

        let branch1 = Rc::new(TreeNode {
            name: "branch1".to_string(),
            value: 2,
            parent: RefCell::new(Some(Rc::downgrade(&root))),
            children: RefCell::new(vec![]),
        });

        let branch2 = Rc::new(TreeNode {
            name: "branch2".to_string(),
            value: 3,
            parent: RefCell::new(Some(Rc::downgrade(&root))),
            children: RefCell::new(vec![]),
        });

        let leaf1 = Rc::new(TreeNode {
            name: "leaf1".to_string(),
            value: 4,
            parent: RefCell::new(Some(Rc::downgrade(&branch1))),
            children: RefCell::new(vec![]),
        });

        let leaf2 = Rc::new(TreeNode {
            name: "leaf2".to_string(),
            value: 5,
            parent: RefCell::new(Some(Rc::downgrade(&branch1))),
            children: RefCell::new(vec![]),
        });

        root.children.borrow_mut().push(Rc::clone(&branch1));
        root.children.borrow_mut().push(Rc::clone(&branch2));

        branch1.children.borrow_mut().push(Rc::clone(&leaf1));
        branch1.children.borrow_mut().push(Rc::clone(&leaf2));

        println!("트리 구조:");
        println!("  root");
        println!("  ├── branch1");
        println!("  │   ├── leaf1");
        println!("  │   └── leaf2");
        println!("  └── branch2");
        println!();

        println!("부모-자식 관계:");
        println!("  leaf1의 부모: {}",
            leaf1.parent.borrow()
                .as_ref()
                .and_then(|p| p.upgrade())
                .map(|p| p.name.clone())
                .unwrap_or("없음".to_string())
        );
        println!("  branch1의 부모: {}",
            branch1.parent.borrow()
                .as_ref()
                .and_then(|p| p.upgrade())
                .map(|p| p.name.clone())
                .unwrap_or("없음".to_string())
        );
        println!();
    }

    // ==================== 섹션 6: 참조 카운트 분석 ====================
    println!("📌 섹션 6: 참조 카운트 분석\n");
    {
        use std::rc::Weak;

        #[derive(Debug)]
        struct Node {
            id: usize,
            parent: RefCell<Option<Weak<Node>>>,
            children: RefCell<Vec<Rc<Node>>>,
        }

        println!("참조 카운팅 추적:");
        println!();

        let parent = Rc::new(Node {
            id: 1,
            parent: RefCell::new(None),
            children: RefCell::new(vec![]),
        });

        println!("1. parent 생성:");
        println!("  strong_count = {}", Rc::strong_count(&parent));
        println!("  weak_count = {}", Rc::weak_count(&parent));
        println!();

        let child1 = Rc::new(Node {
            id: 2,
            parent: RefCell::new(Some(Rc::downgrade(&parent))),
            children: RefCell::new(vec![]),
        });

        println!("2. child1 생성 (Weak 참조):");
        println!("  parent strong_count = {}", Rc::strong_count(&parent));
        println!("  parent weak_count = {}", Rc::weak_count(&parent));
        println!();

        parent.children.borrow_mut().push(Rc::clone(&child1));

        println!("3. parent가 child1을 Rc로 소유:");
        println!("  parent strong_count = {}", Rc::strong_count(&parent));
        println!("  child1 strong_count = {}", Rc::strong_count(&child1));
        println!();

        let child2 = Rc::new(Node {
            id: 3,
            parent: RefCell::new(Some(Rc::downgrade(&parent))),
            children: RefCell::new(vec![]),
        });

        parent.children.borrow_mut().push(Rc::clone(&child2));

        println!("4. child2 생성:");
        println!("  parent strong_count = {}", Rc::strong_count(&parent));
        println!("  parent weak_count = {}", Rc::weak_count(&parent));
        println!();

        println!("분석:");
        println!("  ✅ strong_count 증가 = 메모리 소유권");
        println!("  ✅ weak_count 증가 = 비소유 참조");
        println!("  ✅ strong_count만 메모리 해제에 영향");
        println!();
    }

    // ==================== 섹션 7: 양방향 링크드 리스트 (Weak 사용) ====================
    println!("📌 섹션 7: 양방향 링크드 리스트 (Weak로 역방향)\n");
    {
        use std::rc::Weak;

        #[derive(Debug)]
        struct DoublyLinkedNode {
            data: i32,
            next: RefCell<Option<Rc<DoublyLinkedNode>>>,
            prev: RefCell<Option<Weak<DoublyLinkedNode>>>,
        }

        println!("양방향 링크드 리스트:");
        println!("  next: Rc (앞으로 이동)");
        println!("  prev: Weak (뒤로 이동)");
        println!();

        let node1 = Rc::new(DoublyLinkedNode {
            data: 10,
            next: RefCell::new(None),
            prev: RefCell::new(None),
        });

        let node2 = Rc::new(DoublyLinkedNode {
            data: 20,
            next: RefCell::new(None),
            prev: RefCell::new(Some(Rc::downgrade(&node1))),
        });

        let node3 = Rc::new(DoublyLinkedNode {
            data: 30,
            next: RefCell::new(None),
            prev: RefCell::new(Some(Rc::downgrade(&node2))),
        });

        node1.next.borrow_mut().replace(Rc::clone(&node2));
        node2.next.borrow_mut().replace(Rc::clone(&node3));

        println!("리스트: 10 <-> 20 <-> 30");
        println!();

        println!("forward 순회:");
        let mut current = Some(Rc::clone(&node1));
        while let Some(node) = current {
            print!("{} ", node.data);
            current = node.next.borrow().as_ref().map(Rc::clone);
        }
        println!();

        println!("backward 순회 (node3에서):");
        print!("{} ", node3.data);
        if let Some(weak_prev) = node3.prev.borrow().as_ref() {
            if let Some(prev) = weak_prev.upgrade() {
                print!("{} ", prev.data);
                if let Some(weak_prev2) = prev.prev.borrow().as_ref() {
                    if let Some(prev2) = weak_prev2.upgrade() {
                        print!("{} ", prev2.data);
                    }
                }
            }
        }
        println!();
        println!();
    }

    // ==================== 섹션 8: 그래프 순환 참조 방지 ====================
    println!("📌 섹션 8: 그래프 순환 참조 방지\n");
    {
        use std::rc::Weak;

        #[derive(Debug)]
        struct GraphNode {
            id: usize,
            neighbors: RefCell<Vec<Rc<GraphNode>>>,
            parent_graph: RefCell<Option<Weak<GraphNode>>>,
        }

        println!("그래프 구조 (순환 참조 방지):");
        println!("  neighbors: Rc (강한 참조, 주 소유)");
        println!("  parent_graph: Weak (약한 참조)");
        println!();

        let node1 = Rc::new(GraphNode {
            id: 1,
            neighbors: RefCell::new(vec![]),
            parent_graph: RefCell::new(None),
        });

        let node2 = Rc::new(GraphNode {
            id: 2,
            neighbors: RefCell::new(vec![]),
            parent_graph: RefCell::new(None),
        });

        let node3 = Rc::new(GraphNode {
            id: 3,
            neighbors: RefCell::new(vec![]),
            parent_graph: RefCell::new(None),
        });

        // 간선 추가
        node1.neighbors.borrow_mut().push(Rc::clone(&node2));
        node1.neighbors.borrow_mut().push(Rc::clone(&node3));

        node2.neighbors.borrow_mut().push(Rc::clone(&node1));
        node2.neighbors.borrow_mut().push(Rc::clone(&node3));

        node3.neighbors.borrow_mut().push(Rc::clone(&node1));

        println!("그래프 간선:");
        println!("  1 → 2, 3");
        println!("  2 → 1, 3");
        println!("  3 → 1");
        println!();

        println!("✅ Weak를 사용하면 순환 참조 해결!");
        println!("  even if: 1 ↔ 2 ↔ 3 ↔ 1");
        println!("  메모리 누수 없음");
        println!();
    }

    // ==================== 섹션 9: 실무 패턴 - UI 계층 구조 ====================
    println!("📌 섹션 9: 실무 패턴 - UI 계층 구조\n");
    {
        use std::rc::Weak;

        #[derive(Debug)]
        struct Widget {
            name: String,
            parent: RefCell<Option<Weak<Widget>>>,
            children: RefCell<Vec<Rc<Widget>>>,
        }

        println!("UI 계층 구조:");
        println!();

        let window = Rc::new(Widget {
            name: "Window".to_string(),
            parent: RefCell::new(None),
            children: RefCell::new(vec![]),
        });

        let panel = Rc::new(Widget {
            name: "Panel".to_string(),
            parent: RefCell::new(Some(Rc::downgrade(&window))),
            children: RefCell::new(vec![]),
        });

        let button = Rc::new(Widget {
            name: "Button".to_string(),
            parent: RefCell::new(Some(Rc::downgrade(&panel))),
            children: RefCell::new(vec![]),
        });

        window.children.borrow_mut().push(Rc::clone(&panel));
        panel.children.borrow_mut().push(Rc::clone(&button));

        println!("계층 구조:");
        println!("  Window");
        println!("  └── Panel");
        println!("      └── Button");
        println!();

        println!("부모 접근 (upgrade 사용):");
        if let Some(parent) = button.parent.borrow()
            .as_ref()
            .and_then(|p| p.upgrade())
        {
            println!("  Button의 부모: {}", parent.name);
        }
        println!();

        println!("자식 접근:");
        println!("  Window의 자식: {} 개", window.children.borrow().len());
        println!("  Panel의 자식: {} 개", panel.children.borrow().len());
        println!();

        println!("✅ UI 계층도 메모리 누수 없음!");
        println!();
    }

    // ==================== 섹션 10: Rc와 Weak 비교 ====================
    println!("📌 섹션 10: Rc와 Weak 비교\n");
    {
        use std::rc::Weak;

        #[derive(Debug)]
        struct Data {
            value: i32,
        }

        println!("Rc<T> vs Weak<T>:");
        println!();
        println!("┌─────────────────┬──────────────┬──────────────┐");
        println!("│ 특성            │ Rc<T>        │ Weak<T>      │");
        println!("├─────────────────┼──────────────┼──────────────┤");
        println!("│ 소유권          │ 있음 ✅      │ 없음 ❌      │");
        println!("│ strong_count    │ 증가 ✅      │ 증가 ❌      │");
        println!("│ weak_count      │ 증가 ❌      │ 증가 ✅      │");
        println!("│ 메모리 소유     │ 예 ✅        │ 아니오 ❌    │");
        println!("│ downgrade       │ 가능 ✅      │ 불가 ❌     │");
        println!("│ upgrade         │ 불가 ❌     │ 가능 ✅      │");
        println!("│ 순환 참조 위험  │ 높음 ⚠️     │ 없음 ✅      │");
        println!("└─────────────────┴──────────────┴──────────────┘");
        println!();

        println!("사용 규칙:");
        println!("  ✅ 부모 → 자식: Rc (소유권)");
        println!("  ✅ 자식 → 부모: Weak (비소유)");
        println!("  ✅ 주 관계: Rc");
        println!("  ✅ 역참조: Weak");
        println!();
    }

    // ==================== 섹션 11: 메모리 안전성 보장 ====================
    println!("📌 섹션 11: 메모리 안전성 보장\n");
    {
        use std::rc::Weak;

        #[derive(Debug)]
        struct SafeNode {
            id: usize,
            parent: RefCell<Option<Weak<SafeNode>>>,
            children: RefCell<Vec<Rc<SafeNode>>>,
        }

        println!("메모리 안전성 보장:");
        println!();

        let parent = Rc::new(SafeNode {
            id: 1,
            parent: RefCell::new(None),
            children: RefCell::new(vec![]),
        });

        let child = Rc::new(SafeNode {
            id: 2,
            parent: RefCell::new(Some(Rc::downgrade(&parent))),
            children: RefCell::new(vec![]),
        });

        parent.children.borrow_mut().push(Rc::clone(&child));

        println!("시나리오 1: 부모가 살아있음");
        {
            let strong_count = Rc::strong_count(&parent);
            let weak_count = Rc::weak_count(&parent);
            println!("  strong_count: {} (부모 + 자식의 Rc)", strong_count);
            println!("  weak_count: {} (자식의 Weak)", weak_count);

            if let Some(_) = child.parent.borrow().as_ref().and_then(|p| p.upgrade()) {
                println!("  ✅ 부모 접근 가능");
            }
        }
        println!();

        println!("시나리오 2: 부모 드롭 (스코프 벗어남)");
        drop(parent);
        {
            if let Some(_) = child.parent.borrow().as_ref().and_then(|p| p.upgrade()) {
                println!("  ✅ 부모 접근 가능");
            } else {
                println!("  ❌ 부모가 이미 해제됨 (안전)");
            }
        }
        println!();

        println!("✅ Weak는 항상 안전합니다!");
        println!("  - 부모 살아있으면 upgrade() 성공");
