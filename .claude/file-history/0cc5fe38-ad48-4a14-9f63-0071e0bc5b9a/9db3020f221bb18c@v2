// ╔══════════════════════════════════════════════════════════════╗
// ║                                                              ║
// ║     언어 설계 프로젝트: 제2장 심화 - 반복문의 심화 설계       ║
// ║                                                              ║
// ║  "수동 복제를 넘어, 자동화 엔진의 가동"                      ║
// ║                                                              ║
// ║  v3.2: 지치지 않는 수행 능력                                 ║
// ║                                                              ║
// ╚══════════════════════════════════════════════════════════════╝

fn main() {
    println!("\n╔══════════════════════════════════════════════════════════════╗");
    println!("║                                                              ║");
    println!("║     ⚙️ v3.2: 반복문의 심화 설계 (Automated Iteration)      ║");
    println!("║                                                              ║");
    println!("║     '어디로 갈 것인가'를 넘어,                             ║");
    println!("║     '어떻게 계속할 것인가'를 다루는 지구력의 단계           ║");
    println!("║                                                              ║");
    println!("╚══════════════════════════════════════════════════════════════╝\n");

    // ══════════════════════════════════════════════════════════════
    // [v3.2 설계 철학]
    // ══════════════════════════════════════════════════════════════
    //
    // v3.0: LOOP의 기초 (탈출 조건)
    // v3.1: 조건식의 정밀 (복합 조건)
    // v3.2: 반복문의 심화 (자동화 엔진)
    //
    // 반복문은 "자동화 엔진"입니다.
    // 수동으로 복제하는 대신, 코드 한 줄로 수천 번 반복할 수 있습니다.
    //

    println!("═══════════════════════════════════════════════════════════════");
    println!("🎯 [v3.2 설계 목표]\n");

    println!("1️⃣ 순환 로직: 동일한 작업을 자동으로 반복");
    println!("   → 수동 복제 NO, 코드 한 줄로 수천 번 실행\n");

    println!("2️⃣ 탈출 전략: 명확한 종료 조건");
    println!("   → 무한 루프 방지");
    println!("   → Exit Condition 설계\n");

    println!("3️⃣ 데이터 순회: 메모리의 데이터를 하나씩 처리");
    println!("   → for i in data { ... }");
    println!("   → Iterator의 기초\n");

    println!("4️⃣ 루프의 삼요소: 모든 반복의 필수 요소");
    println!("   → 초기화 (Initialization)\n");
    println!("   → 조건식 (Condition)\n");
    println!("   → 변화식 (Increment/Decrement)\n");

    // ══════════════════════════════════════════════════════════════
    // [부분 1] WHILE: 유연한 반복 (조건 기반)
    // ══════════════════════════════════════════════════════════════
    //
    // WHILE: "조건이 참인 동안" 반복
    //
    // 특징:
    // - 조건이 언제 거짓이 될지 불명확
    // - 유연한 제어 가능
    // - 초기화, 조건식, 변화식을 명시적으로 작성해야 함
    //

    println!("═══════════════════════════════════════════════════════════════");
    println!("▶ [부분 1] WHILE: 유연한 반복 (조건 기반)\n");

    println!("개념: 조건이 참인 동안 계속 반복\n");

    // ─────────────────────────────────────────────────────────────
    // [실행 1] 에너지 소진 시뮬레이션
    // ─────────────────────────────────────────────────────────────

    println!("실행 1: 에너지 소진까지 작업 수행\n");

    let mut energy: i32 = 5;
    let initial_energy: i32 = energy;

    println!("  초기화: energy = {}", initial_energy);
    println!("  조건식: while energy > 0");
    println!("  변화식: energy -= 1\n");

    println!("실행 과정:");

    while energy > 0 {
        println!("    에너지 잔량: {:2}, 작업 수행 중... ⚙️", energy);
        energy -= 1;
    }

    println!("    에너지 부족! 작업 완료.\n");

    // ─────────────────────────────────────────────────────────────
    // [실행 2] 시스템 복구 시도 (최대 시도 횟수 제한)
    // ─────────────────────────────────────────────────────────────

    println!("실행 2: 시스템 복구 (최대 3회 시도)\n");

    let mut attempt: i32 = 0;
    let max_attempts: i32 = 3;
    let mut recovery_success: bool = false;

    println!("  초기화: attempt = 0");
    println!("  조건식: while attempt < max_attempts && !recovery_success");
    println!("  변화식: attempt += 1\n");

    println!("실행 과정:");

    while attempt < max_attempts && !recovery_success {
        attempt += 1;
        println!("    [시도 {}] 시스템 복구 진행 중...", attempt);

        if attempt == 2 {
            println!("      → 복구 성공!");
            recovery_success = true;
        }
    }

    println!("    복구 상태: {}\n",
             if recovery_success { "성공" } else { "실패" });

    // ══════════════════════════════════════════════════════════════
    // [부분 2] FOR: 안전하고 효율적인 반복 (범위 기반)
    // ══════════════════════════════════════════════════════════════
    //
    // FOR: "정해진 범위만큼" 반복
    //
    // 특징:
    // - 반복 횟수가 명확
    // - 초기화, 조건식, 변화식이 한 줄에 표현
    // - 컴파일러가 최적화 가능
    // - 가장 안전하고 빠름
    //

    println!("═══════════════════════════════════════════════════════════════");
    println!("▶ [부분 2] FOR: 안전하고 효율적인 반복 (범위 기반)\n");

    println!("개념: 정해진 범위만큼 정확하게 반복\n");

    // ─────────────────────────────────────────────────────────────
    // [실행 1] 범위 반복 (1부터 5까지)
    // ─────────────────────────────────────────────────────────────

    println!("실행 1: 1부터 5까지 반복\n");

    println!("  코드: for i in 1..=5 {{ ... }}\n");
    println!("실행 과정:");

    for i in 1..=5 {
        println!("    [반복 {}] Phase {} 검증 완료 ✓", i, i);
    }

    println!();

    // ─────────────────────────────────────────────────────────────
    // [실행 2] 데이터 배열 순회
    // ─────────────────────────────────────────────────────────────

    println!("실행 2: 배열의 모든 요소 처리\n");

    let system_checks: [&str; 4] = [
        "메모리 점검",
        "CPU 온도 확인",
        "디스크 상태 진단",
        "네트워크 연결 테스트"
    ];

    println!("  배열: {:?}\n", system_checks);
    println!("실행 과정:");

    for (index, check) in system_checks.iter().enumerate() {
        println!("    [{}] {} → 통과 ✓", index + 1, check);
    }

    println!();

    // ─────────────────────────────────────────────────────────────
    // [실행 3] 범위 패턴
    // ─────────────────────────────────────────────────────────────

    println!("실행 3: 다양한 범위 패턴\n");

    println!("  패턴 1: 0..5 (0 포함, 5 제외)");
    for i in 0..3 {
        print!("{} ", i);
    }
    println!("  → 출력\n");

    println!("  패턴 2: 1..=5 (1과 5 모두 포함)");
    for i in 1..=3 {
        print!("{} ", i);
    }
    println!("  → 출력\n");

    // ══════════════════════════════════════════════════════════════
    // [부분 3] LOOP + BREAK: 명시적 제어 (강력한 엔진)
    // ══════════════════════════════════════════════════════════════
    //
    // LOOP: 명확한 종료 조건이 있을 때 사용
    //
    // 특징:
    // - 반복 횟수가 불규칙
    // - break로 명시적 탈출
    // - 강력한 제어 가능
    //

    println!("═══════════════════════════════════════════════════════════════");
    println!("▶ [부분 3] LOOP + BREAK: 명시적 제어 (강력한 엔진)\n");

    println!("개념: 명시적 탈출 조건을 통한 강력한 제어\n");

    // ─────────────────────────────────────────────────────────────
    // [실행 1] 재시도 루프 (최대 5회)
    // ─────────────────────────────────────────────────────────────

    println!("실행 1: 시스템 시작 재시도\n");

    let mut retry_count: i32 = 0;
    let max_retries: i32 = 5;

    println!("  최대 재시도: {} 회\n", max_retries);
    println!("실행 과정:");

    loop {
        retry_count += 1;
        println!("    [재시도 {}] 시스템 부팅 시도 중...", retry_count);

        if retry_count == 3 {
            println!("      → 부팅 성공! 탈출합니다.");
            break;  // 명시적 탈출
        }

        if retry_count >= max_retries {
            println!("      → 최대 재시도 횟수 도달. 강제 탈출.");
            break;  // 안전 장치
        }
    }

    println!();

    // ─────────────────────────────────────────────────────────────
    // [실행 2] Break with Value (값을 반환하며 탈출)
    // ─────────────────────────────────────────────────────────────

    println!("실행 2: Break with Value (값을 반환하며 탈출)\n");

    let result: i32 = loop {
        for attempt in 1..=3 {
            println!("    [시도 {}] 데이터 검색 중...", attempt);

            if attempt == 2 {
                println!("      → 목표 데이터 발견!");
                break 2;  // 바깥쪽 loop를 탈출하며 값 반환
            }
        }
        break 0;  // 기본값
    };

    println!("    반환값: {}\n", result);

    // ══════════════════════════════════════════════════════════════
    // [부분 4] CONTINUE: 건너뛰기 제어
    // ══════════════════════════════════════════════════════════════
    //
    // CONTINUE: 현재 반복을 건너뛰고 다음으로
    //

    println!("═══════════════════════════════════════════════════════════════");
    println!("▶ [부분 4] CONTINUE: 건너뛰기 제어\n");

    println!("개념: 현재 반복을 건너뛰고 다음 반복으로\n");

    println!("실행: 짝수만 처리 (홀수는 스킵)\n");

    for i in 1..=6 {
        if i % 2 == 1 {
            continue;  // 홀수는 처리하지 않음
        }
        println!("    [{}] 짝수 처리 중... ✓", i);
    }

    println!();

    // ══════════════════════════════════════════════════════════════
    // [부분 5] 루프 최적화: WHILE vs FOR
    // ══════════════════════════════════════════════════════════════
    //
    // WHILE 사용:
    // - 종료 조건이 복잡할 때
    // - 조건이 예측 불가능할 때
    // - 유연한 제어가 필요할 때
    //
    // FOR 사용:
    // - 범위가 명확할 때
    // - 배열 순회
    // - 정확한 반복 횟수를 알 때
    // → 더 빠르고 안전함!
    //

    println!("═══════════════════════════════════════════════════════════════");
    println!("▶ [부분 5] 루프 최적화: WHILE vs FOR\n");

    println!("❌ 비효율적: WHILE로 범위 반복");
    println!("   let mut i = 0;");
    println!("   while i < 5 {{");
    println!("     println!(\\\"{{}}\\\" , i);");
    println!("     i += 1;");
    println!("   }}\n");

    println!("✅ 효율적: FOR로 범위 반복");
    println!("   for i in 0..5 {{");
    println!("     println!(\\\"{{}}\\\" , i);");
    println!("   }}\n");

    println!("→ FOR가 더 짧고, 컴파일러가 최적화 가능!\n");

    // ══════════════════════════════════════════════════════════════
    // [부분 6] 루프의 삼요소 검증
    // ══════════════════════════════════════════════════════════════
    //
    // 모든 반복문은 세 가지 필수 요소가 있어야 합니다:
    // 1. 초기화 (Initialization)
    // 2. 조건식 (Condition)
    // 3. 변화식 (Increment/Decrement)
    //

    println!("═══════════════════════════════════════════════════════════════");
    println!("▶ [부분 6] 루프의 삼요소 검증\n");

    println!("모든 안전한 루프는 세 가지를 명확하게 정의합니다:\n");

    println!("1️⃣ 초기화 (Initialization)");
    println!("   → 어디서 시작할 것인가?\n");

    println!("2️⃣ 조건식 (Condition)");
    println!("   → 언제까지 계속할 것인가?\n");

    println!("3️⃣ 변화식 (Increment/Decrement)");
    println!("   → 다음 단계로 어떻게 나아갈 것인가?\n");

    println!("예시:");
    println!("┌────────────────────────────────────┐");
    println!("│ for i in 0..10 {{              │");
    println!("│   ↑          ↑                      │");
    println!("│   초기화    변화식                 │");
    println!("│        ↑                           │");
    println!("│      조건식                        │");
    println!("│ }}                                 │");
    println!("└────────────────────────────────────┘\n");

    // ══════════════════════════════════════════════════════════════
    // [부분 7] 중첩 루프 최소화 (성능 고려)
    // ══════════════════════════════════════════════════════════════
    //
    // 주의: 루프가 중첩될수록 시스템 부하가 기하급수적으로 증가
    // - 단일 루프: O(n)
    // - 이중 루프: O(n²)
    // - 삼중 루프: O(n³)
    //

    println!("═══════════════════════════════════════════════════════════════");
    println!("▶ [부분 7] 중첩 루프 (Nested Loop) 성능 경고\n");

    println!("⚠️ 주의: 루프가 중첩될수록 성능 악화\n");

    println!("예시: 3x3 행렬 순회\n");
    println!("실행:");

    for row in 0..3 {
        for col in 0..3 {
            print!("[{},{}] ", row, col);
        }
        println!();
    }

    println!("\n→ 9번 반복 (3 × 3)\n");

    println!("만약 10×10이라면?");
    println!("→ 100번 반복\n");

    println!("만약 100×100이라면?");
    println!("→ 10,000번 반복 ⚠️\n");

    println!("중첩 루프를 최소화하고, 필요시 함수로 분해하는 것이 권장됩니다.\n");

    // ══════════════════════════════════════════════════════════════
    // [v3.2 완성]
    // ══════════════════════════════════════════════════════════════

    println!("═══════════════════════════════════════════════════════════════");
    println!("▶ [v3.2 완성]\n");

    println!("✅ WHILE: 유연한 반복 (조건 기반)");
    println!("✅ FOR: 안전하고 효율적인 반복 (범위 기반)");
    println!("✅ LOOP + BREAK: 명시적 제어");
    println!("✅ CONTINUE: 건너뛰기 제어");
    println!("✅ 루프의 삼요소: 초기화, 조건식, 변화식");
    println!("✅ 루프 최적화: WHILE vs FOR\n");

    println!("기록: 자동화 엔진들이 정확한 조건에서 작동함.");
    println!("저장 필수 너는 기록이 증명이다 gogs 🔥\n");

    println!("✨ v3.2 완성: 반복문의 심화 설계");
    println!("📍 위치: lang-design/v3_2_main.rs");
    println!("🎯 다음: 제2장 최종 검증 → 제3장 (v4.0)\n");

    println!("═══════════════════════════════════════════════════════════════\n");
}
