// ===================================================================
// Section 1: 기본 열거형 정의 (Basic Enum Definition)
// ===================================================================
//
// 열거형의 세 가지 형태:
// 1. 단순 variant (데이터 없음)
// 2. 튜플 variant (단일 또는 복수 데이터)
// 3. 구조체 variant (이름 있는 필드)
//
fn section_1_basic_enum() {
    println!("▶ Section 1: 기본 열거형 정의");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 1-1. 단순 variant (Simple Enum)
    // ─────────────────────────────────────────
    println!("  [1-1] 단순 열거형 - 데이터를 포함하지 않는 상태");

    #[derive(Debug)]
    enum TrafficLight {
        Red,
        Yellow,
        Green,
    }

    let light = TrafficLight::Red;
    println!("    신호: {:?}", light);
    println!("    의미: 단순 상태만 나타냄 (추가 데이터 없음)\n");

    // ─────────────────────────────────────────
    // 1-2. 튜플 variant (Tuple Enum)
    // ─────────────────────────────────────────
    println!("  [1-2] 튜플 열거형 - 데이터를 포함하는 상태");

    #[derive(Debug)]
    enum SystemSignal {
        Reset,                           // 데이터 없음
        UpdateVersion(f32),              // 단일 데이터
        ErrorMessage(String),            // 문자열 데이터
        ChangeColor(i32, i32, i32),      // 복수 데이터 (RGB)
    }

    let signals = vec![
        SystemSignal::Reset,
        SystemSignal::UpdateVersion(5.2),
        SystemSignal::ErrorMessage(String::from("메모리 부족")),
        SystemSignal::ChangeColor(255, 100, 50),
    ];

    for signal in signals {
        println!("    신호: {:?}", signal);
    }
    println!("    의미: 상태마다 다른 형태의 데이터 포함\n");

    // ─────────────────────────────────────────
    // 1-3. 구조체 variant (Struct Enum)
    // ─────────────────────────────────────────
    println!("  [1-3] 구조체 열거형 - 이름 있는 필드 포함");

    #[derive(Debug)]
    enum NetworkMessage {
        Connect { addr: String, port: u16 },
        Disconnect { reason: String },
        Data { payload: String, size: usize },
    }

    let msg = NetworkMessage::Connect {
        addr: String::from("192.168.1.1"),
        port: 8080,
    };
    println!("    메시지: {:?}", msg);
    println!("    의미: 상태가 구조체처럼 이름 있는 필드를 가짐\n");

    println!("  💡 핵심: 각 상태는 서로 배타적이면서도 필요한 데이터를 정확히 담을 수 있습니다.\n");
}

// ===================================================================
// Section 2: match 패턴 매칭 (Pattern Matching with match)
// ===================================================================
//
// match는 Enum의 모든 경우를 처리하도록 강제합니다.
// 컴파일러가 빠뜨린 경우를 자동으로 감지합니다.
//
fn section_2_match_patterns() {
    println!("▶ Section 2: match 패턴 매칭");
    println!("─────────────────────────────────────────\n");

    #[derive(Debug)]
    enum DeviceStatus {
        Idle,
        Running(f32),              // 부하 (%)
        Error(String),             // 에러 메시지
        Shutdown,
    }

    // ─────────────────────────────────────────
    // 2-1. 기본 match (Basic Match)
    // ─────────────────────────────────────────
    println!("  [2-1] 모든 경우를 처리하는 기본 match");

    let status = DeviceStatus::Running(65.5);

    match status {
        DeviceStatus::Idle => {
            println!("    📊 장치 상태: 대기 중");
        }
        DeviceStatus::Running(load) => {
            println!("    🔄 장치 상태: 가동 중 (부하: {:.1}%)", load);
        }
        DeviceStatus::Error(msg) => {
            println!("    ❌ 장치 상태: 오류 ({}))", msg);
        }
        DeviceStatus::Shutdown => {
            println!("    ⏹️  장치 상태: 종료됨");
        }
    }
    println!("    의미: 모든 가능한 상태를 처리\n");

    // ─────────────────────────────────────────
    // 2-2. 데이터 추출 (Data Extraction)
    // ─────────────────────────────────────────
    println!("  [2-2] 열거형에서 데이터 추출");

    #[derive(Debug)]
    enum Result<T, E> {
        Ok(T),
        Err(E),
    }

    let operation: std::result::Result<i32, String> = std::result::Result::Ok(42);

    match operation {
        std::result::Result::Ok(value) => {
            println!("    ✅ 성공: 값 = {}", value);
        }
        std::result::Result::Err(error) => {
            println!("    ❌ 실패: 오류 = {}", error);
        }
    }
    println!("    의미: 각 상태의 데이터를 안전하게 추출\n");

    // ─────────────────────────────────────────
    // 2-3. 와일드카드 (_) 처리
    // ─────────────────────────────────────────
    println!("  [2-3] 와일드카드를 이용한 기본값 처리");

    #[derive(Debug)]
    enum HttpStatus {
        Ok,
        Created,
        BadRequest,
        NotFound,
        ServerError,
    }

    let status = HttpStatus::NotFound;

    match status {
        HttpStatus::Ok => println!("    ✅ 200 OK"),
        HttpStatus::Created => println!("    ✨ 201 Created"),
        _ => println!("    ⚠️  다른 상태: {:?}", status),
    }
    println!("    의미: 주요 경우만 처리하고 나머지는 와일드카드로\n");

    // ─────────────────────────────────────────
    // 2-4. guard 조건 추가
    // ─────────────────────────────────────────
    println!("  [2-4] match guard: 추가 조건 지정");

    let score = 85;
    match score {
        s if s >= 90 => println!("    🏆 학점: A"),
        s if s >= 80 => println!("    ⭐ 학점: B"),
        s if s >= 70 => println!("    ✓ 학점: C"),
        _ => println!("    📝 학점: F"),
    }
    println!("    의미: 값의 범위나 조건을 추가로 확인\n");

    println!("  💡 핵심: match는 compiler-enforced exhaustiveness를 제공합니다.\n");
}

// ===================================================================
// Section 3: if let 간편한 패턴 매칭 (if let Pattern)
// ===================================================================
//
// 하나의 특정 경우만 처리하고 싶을 때 if let을 사용하면 더 간단합니다.
//
fn section_3_if_let_pattern() {
    println!("▶ Section 3: if let 간편한 패턴 매칭");
    println!("─────────────────────────────────────────\n");

    #[derive(Debug)]
    enum UserAction {
        Login(String),      // 사용자명
        Logout,
        ViewProfile,
        Settings,
    }

    // ─────────────────────────────────────────
    // 3-1. match vs if let 비교
    // ─────────────────────────────────────────
    println!("  [3-1] match vs if let 비교");

    let action = UserAction::Login(String::from("alice"));

    // match 버전
    match &action {
        UserAction::Login(name) => {
            println!("    [match] {} 님이 로그인했습니다.", name);
        }
        _ => {}
    }

    // if let 버전
    if let UserAction::Login(name) = &action {
        println!("    [if let] {} 님이 로그인했습니다.", name);
    }
    println!("    의미: 한 가지 경우만 필요하면 if let이 더 간단\n");

    // ─────────────────────────────────────────
    // 3-2. if let else 조합
    // ─────────────────────────────────────────
    println!("  [3-2] if let ... else 조합");

    let device_state = Some(String::from("Running"));

    if let Some(state) = device_state {
        println!("    🔄 상태: {}", state);
    } else {
        println!("    ❌ 상태 정보 없음");
    }
    println!("    의미: 특정 경우와 그 외의 경우를 동시에 처리\n");

    // ─────────────────────────────────────────
    // 3-3. while let 루프
    // ─────────────────────────────────────────
    println!("  [3-3] while let 루프");

    let mut messages = vec![
        Some(String::from("Hello")),
        Some(String::from("World")),
        None,
        Some(String::from("!")),
    ];

    println!("    메시지 처리:");
    while let Some(msg) = messages.pop() {
        println!("      - {}", msg);
    }
    println!("    의미: Some이 나오는 동안만 반복\n");

    println!("  💡 핵심: if let은 match의 문법 설탕이지만 더 간결합니다.\n");
}

// ===================================================================
// Section 4: 열거형에 메서드 추가 (impl for Enum)
// ===================================================================
//
// 구조체처럼 열거형도 impl 블록을 가질 수 있습니다.
//
fn section_4_enum_with_methods() {
    println!("▶ Section 4: 열거형에 메서드 추가");
    println!("─────────────────────────────────────────\n");

    #[derive(Debug, Clone)]
    enum Permission {
        Guest,
        User,
        Admin,
        SuperAdmin,
    }

    impl Permission {
        // 권한 레벨을 숫자로 반환
        fn level(&self) -> u8 {
            match self {
                Permission::Guest => 0,
                Permission::User => 1,
                Permission::Admin => 2,
                Permission::SuperAdmin => 3,
            }
        }

        // 해당 권한이 특정 작업을 할 수 있는지 확인
        fn can_delete(&self) -> bool {
            self.level() >= 2
        }

        // 권한 설명
        fn description(&self) -> &str {
            match self {
                Permission::Guest => "손님 (읽기만 가능)",
                Permission::User => "사용자 (기본 작성 권한)",
                Permission::Admin => "관리자 (삭제 권한)",
                Permission::SuperAdmin => "슈퍼 관리자 (전체 권한)",
            }
        }
    }

    println!("  [4-1] 열거형 메서드 호출");

    let perms = vec![
        Permission::Guest,
        Permission::User,
        Permission::Admin,
    ];

    for perm in perms {
        println!("    {} (레벨: {})", perm.description(), perm.level());
        if perm.can_delete() {
            println!("      ✅ 삭제 권한 있음");
        } else {
            println!("      ❌ 삭제 권한 없음");
        }
    }
    println!();

    println!("  💡 핵심: 열거형도 데이터처럼 메서드를 가질 수 있습니다.\n");
}

// ===================================================================
// Section 5: 복잡한 열거형 설계 (Complex Enum Design)
// ===================================================================
//
// 실제 시스템에서 필요한 복잡한 열거형 설계
//
fn section_5_complex_enum() {
    println!("▶ Section 5: 복잡한 열거형 설계");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 5-1. 네트워크 패킷 설계
    // ─────────────────────────────────────────
    println!("  [5-1] 네트워크 패킷 모델링");

    #[derive(Debug)]
    enum Packet {
        // TCP 제어 패킷
        Syn { seq: u32 },
        Ack { seq: u32, ack_seq: u32 },
        Fin { seq: u32 },
        // 데이터 패킷
        Data { payload: Vec<u8> },
        // 에러 패킷
        Reset,
    }

    let packets = vec![
        Packet::Syn { seq: 100 },
        Packet::Data { payload: vec![1, 2, 3] },
        Packet::Ack { seq: 101, ack_seq: 200 },
        Packet::Fin { seq: 102 },
    ];

    println!("    송수신 패킷:");
    for packet in packets {
        match packet {
            Packet::Syn { seq } => println!("      [SYN]  seq={}", seq),
            Packet::Ack { seq, ack_seq } => println!("      [ACK]  seq={}, ack_seq={}", seq, ack_seq),
            Packet::Fin { seq } => println!("      [FIN]  seq={}", seq),
            Packet::Data { payload } => println!("      [DATA] {} bytes", payload.len()),
            Packet::Reset => println!("      [RST]  연결 초기화"),
        }
    }
    println!();

    // ─────────────────────────────────────────
    // 5-2. 데이터베이스 쿼리 결과
    // ─────────────────────────────────────────
    println!("  [5-2] 데이터베이스 쿼리 결과 모델링");

    #[derive(Debug)]
    enum QueryResult {
        Success { rows: usize, data: Vec<String> },
        PartialSuccess { rows: usize, failed: usize },
        Empty,
        Error { code: i32, message: String },
    }

    let results = vec![
        QueryResult::Success {
            rows: 10,
            data: vec![String::from("user1"), String::from("user2")]
        },
        QueryResult::Empty,
        QueryResult::Error {
            code: 1054,
            message: String::from("Unknown column")
        },
    ];

    println!("    쿼리 결과:");
    for result in results {
        match result {
            QueryResult::Success { rows, .. } => {
                println!("      ✅ 성공: {} 행", rows);
            }
            QueryResult::PartialSuccess { rows, failed } => {
                println!("      ⚠️  부분 성공: {}행 성공, {}행 실패", rows, failed);
            }
            QueryResult::Empty => {
                println!("      ℹ️  결과 없음");
            }
            QueryResult::Error { code, message } => {
                println!("      ❌ 오류 [{}]: {}", code, message);
            }
        }
    }
    println!();

    println!("  💡 핵심: 실제 도메인의 복잡성을 열거형으로 명확히 표현합니다.\n");
}

// ===================================================================
// Section 6: 상태 관리 패턴 (State Management Pattern)
// ===================================================================
//
// 열거형으로 시스템의 상태를 안전하게 관리합니다.
//
fn section_6_state_management() {
    println!("▶ Section 6: 상태 관리 패턴");
    println!("─────────────────────────────────────────\n");

    #[derive(Debug, Clone, PartialEq)]
    enum OrderStatus {
        Pending,                // 대기 중
        Processing,             // 처리 중
        Shipped { tracking: String },  // 배송됨 (추적 번호)
        Delivered,              // 배송 완료
        Cancelled { reason: String },  // 취소됨 (사유)
    }

    struct Order {
        id: u32,
        status: OrderStatus,
    }

    impl Order {
        fn new(id: u32) -> Order {
            Order {
                id,
                status: OrderStatus::Pending,
            }
        }

        // 상태 전이 (State Transition)
        fn process(&mut self) -> Result<(), String> {
            match self.status {
                OrderStatus::Pending => {
                    self.status = OrderStatus::Processing;
                    Ok(())
                }
                OrderStatus::Processing => {
                    Err("Already processing".to_string())
                }
                _ => Err("Cannot process from this state".to_string()),
            }
        }

        fn ship(&mut self, tracking: String) -> Result<(), String> {
            match &self.status {
                OrderStatus::Processing => {
                    self.status = OrderStatus::Shipped { tracking };
                    Ok(())
                }
                _ => Err("Can only ship from Processing state".to_string()),
            }
        }

        fn deliver(&mut self) -> Result<(), String> {
            match &self.status {
                OrderStatus::Shipped { .. } => {
                    self.status = OrderStatus::Delivered;
                    Ok(())
                }
                _ => Err("Can only deliver from Shipped state".to_string()),
            }
        }

        fn cancel(&mut self, reason: String) -> Result<(), String> {
            match &self.status {
                OrderStatus::Delivered | OrderStatus::Cancelled { .. } => {
                    Err("Cannot cancel at this stage".to_string())
                }
                _ => {
                    self.status = OrderStatus::Cancelled { reason };
                    Ok(())
                }
            }
        }
    }

    println!("  [6-1] 주문 상태 변이 시뮬레이션");

    let mut order = Order::new(12345);
    println!("    [초기] {:?}", order.status);

    if let Ok(_) = order.process() {
        println!("    [처리] {:?}", order.status);
    }

    if let Ok(_) = order.ship(String::from("TRACK123456")) {
        println!("    [배송] {:?}", order.status);
    }

    if let Ok(_) = order.deliver() {
        println!("    [완료] {:?}", order.status);
    }

    println!("\n  💡 핵심: 열거형이 상태를 강력하게 제약하여 잘못된 상태 전이를 방지합니다.\n");
}

// ===================================================================
// Section 7: 고급 예제 - 신호 처리 엔진 (Advanced Signal Engine)
// ===================================================================
//
// 모든 개념을 종합한 실제 시스템 구현
//
fn section_7_advanced_signal_engine() {
    println!("▶ Section 7: 고급 예제 - 신호 처리 엔진");
    println!("─────────────────────────────────────────\n");

    #[derive(Debug, Clone)]
    enum SystemSignal {
        // 제어 신호
        Reset,
        Shutdown,
        // 상태 업데이트
        UpdateVersion(f32),
        SetConfig(String),
        // 에러 신호
        ErrorMessage(String),
        WarningMessage(String),
        // 하드웨어 신호
        ChangeColor(u8, u8, u8),  // RGB
        SetBrightness(u8),
        // 센서 신호
        SensorReading { sensor: String, value: f32 },
    }

    impl SystemSignal {
        fn severity(&self) -> u8 {
            match self {
                SystemSignal::ErrorMessage(_) => 3,
                SystemSignal::WarningMessage(_) => 2,
                _ => 1,
            }
        }

        fn should_log(&self) -> bool {
            matches!(
                self,
                SystemSignal::ErrorMessage(_)
                    | SystemSignal::WarningMessage(_)
                    | SystemSignal::Reset
                    | SystemSignal::Shutdown
            )
        }

        fn handle(&self) -> String {
            match self {
                SystemSignal::Reset => {
                    "시스템을 초기 상태로 되돌립니다.".to_string()
                }
                SystemSignal::Shutdown => {
                    "시스템을 종료합니다.".to_string()
                }
                SystemSignal::UpdateVersion(v) => {
                    format!("v{}로 버전을 갱신합니다.", v)
                }
                SystemSignal::SetConfig(cfg) => {
                    format!("설정을 변경합니다: {}", cfg)
                }
                SystemSignal::ErrorMessage(msg) => {
                    format!("❌ 치명적 오류: {}", msg)
                }
                SystemSignal::WarningMessage(msg) => {
                    format!("⚠️  경고: {}", msg)
                }
                SystemSignal::ChangeColor(r, g, b) => {
                    format!("조명을 R{}, G{}, B{}로 변경합니다.", r, g, b)
                }
                SystemSignal::SetBrightness(level) => {
                    format!("밝기를 {}%로 설정합니다.", level)
                }
                SystemSignal::SensorReading { sensor, value } => {
                    format!("[{}] 센서 값: {}", sensor, value)
                }
            }
        }
    }

    println!("  [7-1] 신호 처리 시스템 시뮬레이션\n");

    let signals = vec![
        SystemSignal::Reset,
        SystemSignal::UpdateVersion(5.2),
        SystemSignal::ChangeColor(255, 100, 50),
        SystemSignal::SetBrightness(75),
        SystemSignal::SensorReading {
            sensor: String::from("Temperature"),
            value: 45.3,
        },
        SystemSignal::WarningMessage(String::from("온도가 높습니다")),
        SystemSignal::ErrorMessage(String::from("연료 부족")),
    ];

    let mut logged_signals = 0;

    println!("    신호 처리 결과:");
    for signal in signals {
        let action = signal.handle();
        let severity = signal.severity();
        let should_log = signal.should_log();

        println!("    ├─ [심각도:{}] {}", severity, action);

        if should_log {
            logged_signals += 1;
        }
    }

    println!("\n    📊 처리 요약: {} 개의 신호를 기록했습니다.", logged_signals);
    println!();

    // ─────────────────────────────────────────
    // 7-2. 신호 큐 처리
    // ─────────────────────────────────────────
    println!("  [7-2] 신호 우선순위에 따른 처리\n");

    let mut signal_queue = vec![
        (SystemSignal::WarningMessage(String::from("Low Power")), 2),
        (SystemSignal::ErrorMessage(String::from("Overload")), 3),
        (SystemSignal::UpdateVersion(5.2), 1),
    ];

    // 심각도순으로 정렬
    signal_queue.sort_by(|a, b| b.1.cmp(&a.1));

    println!("    우선순위 순서로 처리:");
    for (signal, priority) in signal_queue {
        println!(
            "    ├─ [P{}] {}",
            priority,
            signal.handle()
        );
    }

    println!("\n  💡 핵심: 열거형으로 복잡한 신호를 안전하고 명확하게 처리합니다.\n");
}

