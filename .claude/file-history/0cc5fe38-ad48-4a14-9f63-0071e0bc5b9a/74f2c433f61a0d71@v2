## 📊 String 메모리 모델 상세

```rust
// String의 내부 구조
let s = String::from("Hello");

// 스택:
// ┌─ ptr ────────┐
// │  (주소)      │
// ├─ len ────────┤
// │  5           │
// ├─ capacity ───┤
// │  5           │
// └──────────────┘
//      ↓
// 힙:
// ┌─────────────────────────┐
// │ [H] [e] [l] [l] [o] [?] │
// │ 0   1   2   3   4   5   │
// └─────────────────────────┘
//
// len: 현재 문자의 바이트 수
// capacity: 할당된 공간의 바이트 수

let mut s = String::with_capacity(10);
// 스택: ptr, len=0, capacity=10

s.push_str("Hello");
// 스택: ptr, len=5, capacity=10 (재할당 없음)

s.push_str("World!");
// 스택: ptr, len=11, capacity >= 11 (재할당 가능)
```

