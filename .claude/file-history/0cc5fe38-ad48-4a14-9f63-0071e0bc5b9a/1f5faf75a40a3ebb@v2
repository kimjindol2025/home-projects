## 🔑 5개 핵심 패턴

### 패턴 1: 함수 감시 속성 매크로

```rust
#[proc_macro_attribute]
pub fn gogs_audit(_attr: TokenStream, item: TokenStream) -> TokenStream {
    let input_fn = parse_macro_input!(item as ItemFn);
    let fn_name = &input_fn.sig.ident;
    let fn_block = &input_fn.block;
    let fn_sig = &input_fn.sig;

    let expanded = quote! {
        #fn_sig {
            println!("[AUDIT] 시작: {}", stringify!(#fn_name));

            // 핵심: 클로저로 감싸서 반환값 보존!
            let result = (|| { #fn_block })();

            println!("[AUDIT] 종료: {}", stringify!(#fn_name));
            result  // ← 원본 반환값 그대로 반환
        }
    };

    TokenStream::from(expanded)
}

// 사용
#[gogs_audit]
fn critical_operation() {
    println!("작업 수행");
}

// 결과: 자동으로 실행 감시 + 로깅!
```

**학습 포인트**:
- Attribute 매크로의 attr과 item 파라미터
- 클로저 `(|| { #fn_block })()`로 반환값 보존
- quote!로 함수 완전 재정의

