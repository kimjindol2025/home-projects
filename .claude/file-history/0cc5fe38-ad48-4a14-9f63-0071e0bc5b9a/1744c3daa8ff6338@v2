## 핵심 기법

### 기법 1: Layout 이해하기

```rust
use std::mem::{size_of, align_of};
use std::alloc::Layout;

// [방법 1] mem 모듈 사용
let size = size_of::<u32>();      // 4
let align = align_of::<u32>();    // 4

// [방법 2] Layout 사용
let layout = Layout::new::<u32>();
let size = layout.size();          // 4
let align = layout.align();        // 4

// [배열의 Layout]
let array_layout = Layout::array::<u32>(100).unwrap();
// 크기: 100 × 4 = 400 bytes
```

### 기법 2: Padding 최소화

```rust
// ❌ 나쁜 설계 (패딩 많음)
struct Bad {
    a: u8,      // 1
    b: u32,     // 4 (패딩 3)
    c: u8,      // 1 (패딩 7)
}
// 크기: 16 bytes

// ✅ 좋은 설계 (패딩 최소)
struct Good {
    b: u32,     // 4
    a: u8,      // 1
    c: u8,      // 1 (패딩 2)
}
// 크기: 8 bytes (50% 절약)
```

### 기법 3: repr 속성 활용

```rust
// FFI용 (C와 호환)
#[repr(C)]
struct CCompatible {
    x: i32,
    y: i32,
}

// 최소 공간 (성능 저하 가능)
#[repr(packed)]
struct Compact {
    x: u32,
    y: u8,
}

// Rust 최적화
#[repr(Rust)]
struct Optimized {
    x: u32,
    y: u8,
}
```

### 기법 4: 수동 메모리 할당

```rust
use std::alloc::{alloc, dealloc, Layout};
use std::ptr;

unsafe {
    // 1. 레이아웃 정의
    let layout = Layout::new::<u32>();

    // 2. 할당
    let ptr = alloc(layout) as *mut u32;

    // 3. 초기화
    ptr::write(ptr, 42);

    // 4. 사용
    let value = ptr::read(ptr);

    // 5. 해제
    dealloc(ptr as *mut u8, layout);
}
```

### 기법 5: Drop과 RAII

```rust
struct Buffer {
    ptr: *mut u8,
    size: usize,
}

impl Drop for Buffer {
    fn drop(&mut self) {
        unsafe {
            let layout = Layout::from_size_align(self.size, 1).unwrap();
            dealloc(self.ptr, layout);
        }
    }
}

// 사용
{
    let buf = Buffer { ptr, size: 100 };
    // 스코프 종료 시 Drop 호출 → 자동 해제
}
```

