## 실전 패턴

### 패턴 1: Safe Allocator Wrapper

```rust
pub struct SafeBuffer<T> {
    ptr: *mut T,
    capacity: usize,
}

impl<T> SafeBuffer<T> {
    pub fn new(capacity: usize) -> Self {
        unsafe {
            let layout = Layout::array::<T>(capacity).unwrap();
            let ptr = alloc(layout) as *mut T;
            SafeBuffer { ptr, capacity }
        }
    }

    pub fn get(&self, index: usize) -> Option<&T> {
        if index < self.capacity {
            unsafe { Some(&*self.ptr.add(index)) }
        } else {
            None
        }
    }
}

impl<T> Drop for SafeBuffer<T> {
    fn drop(&mut self) {
        unsafe {
            let layout = Layout::array::<T>(self.capacity).unwrap();
            dealloc(self.ptr as *mut u8, layout);
        }
    }
}
```

### 패턴 2: Layout 캐싱

```rust
pub struct Allocator {
    layouts: HashMap<TypeId, Layout>,
}

impl Allocator {
    pub fn allocate<T>(&self) -> *mut T {
        let layout = *self.layouts.get(&TypeId::of::<T>())
            .unwrap_or_else(|| &Layout::new::<T>());
        alloc(layout) as *mut T
    }
}
```

