    // ══════════════════════════════════════════════════════════════
    // [부분 1] 테스트 시나리오: 정상, 경고, 에러의 혼합
    // ══════════════════════════════════════════════════════════════

    println!("═══════════════════════════════════════════════════════════════");
    println!("▶ [부분 1] 통합 테스트: 혼합 시나리오\\n");

    // 테스트 데이터: 정상, 경계값, 에러, 유효하지 않은 값의 혼합
    let test_inputs = vec![
        10,   // 정상
        85,   // 경계값 (경고 수준)
        0,    // 에러 (유효하지 않음)
        120,  // 초과 (비상 정지)
        45,   // 정상
        99,   // 경계값
        -5,   // 음수 (유효하지 않음)
        50,   // 정상
    ];

    let mut current_state = SystemState::Ready;
    let mut metrics_log: Vec<SystemMetrics> = Vec::new();
    let mut state_transitions = 0;

    println!("테스트 데이터: {:?}\\n", test_inputs);
    println!("v3.9 최종 엔진 가동...\\n");

    // ══════════════════════════════════════════════════════════════
    // [부분 2] v3.8 반복자와 v3.4 패턴 매칭의 결합
    // ══════════════════════════════════════════════════════════════

    'main_loop: for (cycle, &input) in test_inputs.iter().enumerate() {
        println!("[Cycle {}] 입력값: {}", cycle + 1, input);

        // [v3.6 가드] 비상 정지 상태면 즉시 루프 탈출
        if matches!(current_state, SystemState::EmergencyStop(_)) {
            println!("  🛑 [비상 정지 상태] 엔진 중단");
            break 'main_loop;
        }

        // [v3.3 무결성] 입력값 유효성 검증
        let is_valid = input >= 0;

        // [v3.1 & v3.4] 복합 조건과 패턴 매칭
        let previous_state = current_state.clone();
        let (next_state, action) = match (&current_state, input, is_valid) {
            // [v3.7 상태 전이] Ready 상태에서의 전이
            (SystemState::Ready, i, true) if i > 0 => {
                println!("  ✅ 초기화 시작");
                (SystemState::Initializing, "준비 완료".to_string())
            }
            (SystemState::Ready, _, _) => {
                println!("  ⚠️  Ready 상태에서 유효하지 않은 입력");
                (SystemState::Ready, "입력 거부".to_string())
            }

            // [v3.7 상태 전이] Initializing 상태에서의 전이
            (SystemState::Initializing, i, true) if i > 0 => {
                println!("  ✅ 초기화 완료, 가동 시작");
                (SystemState::Active(i as u8), "가동 중".to_string())
            }
            (SystemState::Initializing, _, _) => {
                println!("  ⚠️  초기화 중 유효하지 않은 입력");
                (SystemState::Initializing, "초기화 재시도".to_string())
            }

            // [v3.7 상태 전이] Active 상태에서의 전이
            (SystemState::Active(prev_val), i, true) if i >= 100 => {
                println!("  🔴 임계치 초과({}) - 비상 정지 발령!", i);
                (
                    SystemState::EmergencyStop(format!("임계치 초과: {}", i)),
                    "비상 정지".to_string(),
                )
            }
            (SystemState::Active(prev_val), i, true) if i >= 80 => {
                println!("  ⚠️  고출력 모드 진입");
                (SystemState::HighLoad(i as u8), "고부하 운영".to_string())
            }
            (SystemState::Active(_), i, true) if i > 0 => {
                println!("  ✅ 정상 모드");
                (SystemState::Active(i as u8), "정상 운영".to_string())
            }
            (SystemState::Active(v), 0, _) => {
                println!("  ⚠️  유효하지 않은 입력, 상태 유지");
                (SystemState::Active(*v), "입력 무시".to_string())
            }
            (SystemState::Active(_), _, false) => {
                println!("  ⚠️  음수 입력 감지, 상태 유지");
                (current_state.clone(), "음수 거부".to_string())
            }

            // [v3.7 상태 전이] HighLoad 상태에서의 전이
            (SystemState::HighLoad(_), i, true) if i >= 100 => {
                println!("  🔴 고부하 중 임계치 초과 - 비상 정지!");
                (
                    SystemState::EmergencyStop(format!("고부하 중 임계치 초과: {}", i)),
                    "비상 정지".to_string(),
                )
            }
            (SystemState::HighLoad(_), i, true) if i < 80 => {
                println!("  ✅ 고부하에서 정상 부하로 복구");
                (SystemState::Active(i as u8), "부하 감소".to_string())
            }
            (SystemState::HighLoad(v), _, _) => {
                println!("  ℹ️  고부하 상태 유지");
                (SystemState::HighLoad(*v), "부하 유지".to_string())
            }

            // [v3.1 기본값] 기타 모든 경우
            (state, _, _) => {
                (state.clone(), "상태 유지".to_string())
            }
        };

        current_state = next_state.clone();

        // [v3.6 가드] 상태 전이가 발생했는지 확인
        if previous_state != next_state {
            state_transitions += 1;
        }

        // [v3.8 반복자] 로그 기록
        metrics_log.push(SystemMetrics {
            cycle: cycle + 1,
            input,
            previous_state,
            next_state,
            action,
            is_valid,
        });

        // [v3.6 가드] 비상 정지 상태 감지 시 루프 중단
        if matches!(current_state, SystemState::EmergencyStop(_)) {
            println!("  🛑 [비상 정지] 엔진 중단");
            break 'main_loop;
        }

        println!("  → {:?}\\n", current_state);
    }

    // ══════════════════════════════════════════════════════════════
    // [부분 3] 완료 상태 분석: 결정론적 수렴 검증
    // ══════════════════════════════════════════════════════════════

    println!("═══════════════════════════════════════════════════════════════");
    println!("▶ [부분 3] 최종 상태 분석 및 무결성 검증\\n");

    println!("[📊 실행 통계]");
    println!("  총 사이클: {}", metrics_log.len());
    println!("  상태 전이: {} 회", state_transitions);
    println!("  유효한 입력: {}",
        metrics_log.iter().filter(|m| m.is_valid).count()
    );
    println!("  무시된 입력: {}",
        metrics_log.iter().filter(|m| !m.is_valid).count()
    );

    println!("\\n[🔍 최종 시스템 상태]");
    match &current_state {
        SystemState::Ready => println!("  상태: Ready (대기)"),
        SystemState::Initializing => println!("  상태: Initializing (초기화 중)"),
        SystemState::Active(val) => println!("  상태: Active (가동 중) - 출력: {}", val),
        SystemState::HighLoad(val) => println!("  상태: HighLoad (고부하) - 출력: {}", val),
        SystemState::ShuttingDown => println!("  상태: ShuttingDown (종료 중)"),
        SystemState::EmergencyStop(msg) => println!("  상태: EmergencyStop - 메시지: {}", msg),
    }

    // ══════════════════════════════════════════════════════════════
    // [부분 4] 전체 흐름 로그: 불변 기록의 원칙
