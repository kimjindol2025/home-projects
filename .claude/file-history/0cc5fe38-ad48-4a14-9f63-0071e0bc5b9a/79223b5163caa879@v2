/// [댕글링 포인터 방지] 유효하지 않은 참조
///
/// 잘못된 예 (컴파일 오류):
/// fn create_dangling_reference() -> &String {
///     let s = String::from("hello");
///     &s  // ❌ 오류: s가 함수 종료 시 사라짐
/// }
fn demonstrate_dangling_pointer_prevention() {
    println!("\n┌─────────────────────────────────────────────────┐");
    println!("│ [댕글링 포인터] 유효하지 않은 참조 방지        │");
    println!("└─────────────────────────────────────────────────┘\n");

    println!("❌ 허용 안 됨 (컴파일 오류):");
    println!("   fn create_dangling() -> &String {{");
    println!("       let s = String::from(\"hello\");");
    println!("       &s  // 함수 종료 시 s가 사라짐!");
    println!("   }}\n");

    println!("✅ 올바른 방법:");
    println!("   fn create_string() -> String {{");
    println!("       String::from(\"hello\")");
    println!("   }}\n");

    let data = create_string();
    println!("   data: '{}'", data);
    println!("   (소유권과 함께 반환되므로 유효)\n");
}

fn create_string() -> String {
    String::from("안전한 데이터")
}

