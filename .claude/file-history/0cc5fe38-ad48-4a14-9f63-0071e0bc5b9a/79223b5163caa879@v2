/// [가변 참조 시연 1] 기본 가변 참조
///
/// 특징:
///   - &mut로 수정 권한 대여
///   - 함수가 데이터를 읽고 쓸 수 있음
///   - 호출 후 원본이 변경됨
fn demonstrate_mutable_reference() {
    println!("\n┌─────────────────────────────────────────────────┐");
    println!("│ [가변 참조] 수정 권한 대여                      │");
    println!("└─────────────────────────────────────────────────┘\n");

    let mut system_log = String::from("v4.2 시작");
    println!("📌 원본 log 생성: '{}'", system_log);

    add_status(&mut system_log);
    println!("📌 함수 호출 후 log 변경됨: '{}'\n", system_log);
}

fn add_status(s: &mut String) {
    // &mut String: 가변 참조
    s.push_str(" - 모니터링 중");
    println!("  [함수 내부] 데이터 수정: '{}'", s);
    println!("  [메모리] 수정 사항이 원본에 반영됨");
}

/// [가변 참조 시연 2] 벡터 수정
///
/// 특징:
///   - 벡터의 원소를 추가, 제거, 수정
///   - 가변 참조를 통해 안전하게 수정
fn demonstrate_mutable_vector() {
    println!("\n┌─────────────────────────────────────────────────┐");
    println!("│ [가변 참조] 벡터 수정                           │");
    println!("└─────────────────────────────────────────────────┘\n");

    let mut readings = vec![10, 20, 30];
    println!("📌 원본 readings: {:?}", readings);

    update_readings(&mut readings);
    println!("📌 함수 호출 후 readings 변경됨: {:?}\n", readings);
}

fn update_readings(vec: &mut Vec<i32>) {
    vec.push(40);
    vec.push(50);
    println!("  [함수 내부] 새로운 값 추가: {:?}", vec);
}

/// [가변 참조 시연 3] 구조체 수정
///
/// 특징:
///   - 구조체의 필드를 가변 참조로 수정
fn demonstrate_mutable_struct() {
    println!("\n┌─────────────────────────────────────────────────┐");
    println!("│ [가변 참조] 구조체 필드 수정                    │");
    println!("└─────────────────────────────────────────────────┘\n");

    #[derive(Debug)]
    struct System {
        name: String,
        status: u32,
        uptime: u32,
    }

    let mut system = System {
        name: String::from("SystemV4.2"),
        status: 100,
        uptime: 0,
    };

    println!("📌 원본 system: {:?}", system);

    update_system(&mut system);
    println!("📌 함수 호출 후 system 변경됨: {:?}\n", system);
}

fn update_system(sys: &mut System) {
    sys.status = 99;
    sys.uptime += 1;
    println!("  [함수 내부] system 수정: {:?}", sys);
}

