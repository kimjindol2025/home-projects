/// [불변 참조 시연 1] 기본 불변 참조
///
/// 특징:
///   - &String으로 소유권 없이 빌려받음
///   - 함수가 데이터를 읽기만 함
///   - 호출자는 여전히 데이터 사용 가능
fn demonstrate_immutable_reference() {
    println!("\n┌─────────────────────────────────────────────────┐");
    println!("│ [불변 참조] 읽기 권한만 대여                    │");
    println!("└─────────────────────────────────────────────────┘\n");

    let data = String::from("시스템 설정 데이터");
    println!("📌 원본 data 생성 (소유자: main): '{}'", data);

    analyze_data(&data);
    println!("📌 함수 호출 후 data 여전히 사용 가능: '{}'\n", data);
}

fn analyze_data(s: &String) {
    // &String: 불변 참조
    println!("  [함수 내부] 참조 받음: '{}' (읽기만 가능)", s);
    println!("  [길이] {}", s.len());
    println!("  [메모리] 참조자만 사라지고, 원본은 유지됨");
}

/// [불변 참조 시연 2] 여러 불변 참조 동시 사용
///
/// 특징:
///   - 같은 데이터에 대해 여러 참조 생성 가능
///   - 각각 독립적으로 데이터 읽기 가능
fn demonstrate_multiple_immutable_references() {
    println!("\n┌─────────────────────────────────────────────────┐");
    println!("│ [불변 참조] 여러 참조 동시 사용                 │");
    println!("└─────────────────────────────────────────────────┘\n");

    let log = String::from("시스템 로그 데이터");
    println!("📌 log 생성: '{}'", log);

    let ref1 = &log;
    let ref2 = &log;
    let ref3 = &log;

    println!("📌 세 개의 불변 참조 생성 가능");
    println!("  ref1: '{}'", ref1);
    println!("  ref2: '{}'", ref2);
    println!("  ref3: '{}'", ref3);

    print_with_reference(ref1);
    print_with_reference(ref2);
    print_with_reference(ref3);

    println!("📌 모든 참조가 동일한 데이터를 안전하게 공유\n");
}

fn print_with_reference(s: &String) {
    println!("  [읽기] {}", s);
}

/// [불변 참조 시연 3] 슬라이스를 통한 참조
///
/// 특징:
///   - 데이터의 일부만 참조
///   - 범위 검증이 컴파일 타임에 됨
fn demonstrate_string_slice() {
    println!("\n┌─────────────────────────────────────────────────┐");
    println!("│ [불변 참조] 슬라이스를 통한 부분 참조           │");
    println!("└─────────────────────────────────────────────────┘\n");

    let message = String::from("Hello, Rust!");
    println!("📌 원본: '{}'", message);

    let hello = &message[0..5];
    let rust = &message[7..11];

    println!("📌 슬라이스 참조:");
    println!("  hello: '{}'", hello);
    println!("  rust: '{}'", rust);
    println!("📌 원본은 변하지 않음: '{}'\n", message);
}

