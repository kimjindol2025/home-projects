/// [사례 1] 대용량 데이터 처리
///
/// v4.1 (Move): 데이터의 소유권이 이전
/// fn process_large_data(data: String) { /* ... */ }
///
/// v4.2 (Borrowing): 소유권은 유지, 참조만 전달
/// fn process_large_data(data: &String) { /* ... */ }
fn demonstrate_performance_improvement() {
    println!("\n┌─────────────────────────────────────────────────┐");
    println!("│ [성능 최적화] 참조를 통한 효율성 개선           │");
    println!("└─────────────────────────────────────────────────┘\n");

    let large_data = String::from("대용량 데이터 ");
    println!("📌 원본 (메모리 복사 없음): '{}'", large_data);

    analyze_immutably(&large_data);
    analyze_immutably(&large_data);
    analyze_immutably(&large_data);

    println!("📌 여러 번 호출해도 메모리 복사 없음\n");
}

fn analyze_immutably(data: &String) {
    // 참조를 받으므로 복사 없음
    println!("  [분석] {} 크기: {}", data, data.len());
}

/// [사례 2] 데이터 수정 파이프라인
///
/// 여러 단계에서 데이터를 수정하되, 소유권은 유지
fn demonstrate_modification_pipeline() {
    println!("\n┌─────────────────────────────────────────────────┐");
    println!("│ [수정 파이프라인] 단계별 데이터 수정            │");
    println!("└─────────────────────────────────────────────────┘\n");

    let mut log = String::from("로그 시작");
    println!("📌 초기: '{}'", log);

    step1_add_timestamp(&mut log);
    println!("  중간: '{}'", log);

    step2_add_status(&mut log);
    println!("  중간: '{}'", log);

    step3_add_summary(&mut log);
    println!("  최종: '{}'\n", log);
}

fn step1_add_timestamp(s: &mut String) {
    s.push_str(" [14:30]");
}

fn step2_add_status(s: &mut String) {
    s.push_str(" - 완료");
}

fn step3_add_summary(s: &mut String) {
    s.push_str(" ✅");
}

