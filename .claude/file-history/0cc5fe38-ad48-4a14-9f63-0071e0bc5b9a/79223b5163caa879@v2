// [Section 6] 참조 vs 소유권: 선택 기준
// ══════════════════════════════════════════════════════════════

fn demonstrate_ownership_vs_borrowing() {
    println!("\n┌─────────────────────────────────────────────────┐");
    println!("│ [선택 기준] 소유권 vs 참조                      │");
    println!("└─────────────────────────────────────────────────┘\n");

    println!("v4.1 [Move]: 함수가 데이터 소유권이 필요");
    println!("   fn take_ownership(data: String) {{");
    println!("       // 함수가 메모리 책임");
    println!("   }}\n");

    println!("v4.2 [Borrow]: 함수가 데이터를 읽기만 함");
    println!("   fn borrow_immutably(data: &String) {{");
    println!("       // 읽기만 가능");
    println!("   }}\n");

    println!("v4.2 [Borrow Mut]: 함수가 데이터를 수정");
    println!("   fn borrow_mutably(data: &mut String) {{");
    println!("       // 읽기 + 쓰기 가능");
    println!("   }}\n");

    println!("선택 기준:");
    println!("  • 읽기만 필요? → &T (불변 참조)");
    println!("  • 수정 필요? → &mut T (가변 참조)");
    println!("  • 메모리 책임이 필요? → T (소유권 이동)");
    println!("  • 대용량 데이터? → 반드시 참조 사용!\n");
}

