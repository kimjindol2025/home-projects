// [Section 3] 빌림의 규칙: 데이터 무결성 보장
// ══════════════════════════════════════════════════════════════

/// [규칙 1] 가변 참조는 한 번에 하나만
///
/// 잘못된 예 (컴파일 오류):
/// let mut x = 5;
/// let r1 = &mut x;
/// let r2 = &mut x;  // ❌ 오류: 두 개의 가변 참조
fn demonstrate_rule_one_mutable_reference() {
    println!("\n┌─────────────────────────────────────────────────┐");
    println!("│ [규칙 1] 가변 참조는 한 번에 하나만            │");
    println!("└─────────────────────────────────────────────────┘\n");

    println!("❌ 허용 안 됨:");
    println!("   let mut x = 5;");
    println!("   let r1 = &mut x;");
    println!("   let r2 = &mut x;  // 컴파일 오류!\n");

    println!("✅ 올바른 방법:");
    let mut x = 5;
    let r1 = &mut x;
    println!("   r1 값: {}", r1);
    // r1의 사용이 끝남
    let r2 = &mut x;  // 이제 r2 생성 가능
    println!("   r2 값: {}\n", r2);
}

/// [규칙 2] 가변 참조와 불변 참조 동시 사용 불가
///
/// 잘못된 예 (컴파일 오류):
/// let mut x = 5;
/// let r1 = &x;      // 불변 참조
/// let r2 = &mut x;  // ❌ 오류: 가변 참조는 불가능
fn demonstrate_rule_immutable_mutable_conflict() {
    println!("\n┌─────────────────────────────────────────────────┐");
    println!("│ [규칙 2] 불변과 가변 참조 동시 사용 불가      │");
    println!("└─────────────────────────────────────────────────┘\n");

    println!("❌ 허용 안 됨:");
    println!("   let mut x = 5;");
    println!("   let r1 = &x;      // 불변");
    println!("   let r2 = &mut x;  // 컴파일 오류!\n");

    println!("✅ 올바른 방법:");
    let mut x = 5;
    let r1 = &x;
    println!("   r1 값: {}", r1);
    // r1의 사용이 끝남
    let r2 = &mut x;  // 이제 가변 참조 가능
    println!("   r2 값: {}\n", r2);
}

/// [규칙 3] 여러 불변 참조는 동시 사용 가능
///
/// 올바른 예:
/// let x = 5;
/// let r1 = &x;
/// let r2 = &x;
/// let r3 = &x;  // ✅ 모두 가능!
fn demonstrate_rule_multiple_immutable_allowed() {
    println!("\n┌─────────────────────────────────────────────────┐");
    println!("│ [규칙 3] 불변 참조는 여러 개 동시 사용 가능    │");
    println!("└─────────────────────────────────────────────────┘\n");

    println!("✅ 허용됨:");
    let x = 5;
    let r1 = &x;
    let r2 = &x;
    let r3 = &x;

    println!("   r1: {}", r1);
    println!("   r2: {}", r2);
    println!("   r3: {}\n", r3);
}

