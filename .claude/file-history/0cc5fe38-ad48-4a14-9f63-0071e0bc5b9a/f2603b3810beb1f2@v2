// 🧠 v10.0: 두려움 없는 동시성과 스레드 (Fearless Concurrency and Threads)
// ⚡ "병렬 실행의 격리"
// 🎯 "멀티코어 프로세서의 완전한 활용"
//
// 핵심 개념:
// - std::thread::spawn: 새로운 실행 흐름 생성
// - Move 클로저: 데이터를 스레드로 이동
// - Join 핸들: 스레드 완료 대기
// - 데이터 경합 차단: 소유권으로 동시 접근 방지
// - 멀티 코어 병렬화: 독립적 작업의 동시 실행
// - Send/Sync 트레이트: 스레드 안전성 제약

use std::thread;
use std::time::Duration;

fn main() {
    println!("╔══════════════════════════════════════════════════════════╗");
    println!("║ v10.0: 두려움 없는 동시성과 스레드                       ║");
    println!("║ \"병렬 실행의 격리\"                                       ║");
    println!("╚══════════════════════════════════════════════════════════╝\n");

    // ==================== 섹션 1: 스레드 vs 메인 스레드 ====================
    println!("📌 섹션 1: 스레드 vs 메인 스레드\n");
    {
        println!("메인 스레드 (Main Thread):");
        println!("  ✅ 프로그램 시작점");
        println!("  ✅ 메인 로직 실행");
        println!("  ⚠️  메인 스레드 종료 = 프로그램 종료");
        println!();

        println!("서브 스레드 (Worker Thread):");
        println!("  ✅ 병렬 작업 실행");
        println!("  ✅ 독립적 실행");
        println!("  ⚠️  메인이 기다려야 함");
        println!();

        println!("멀티 스레드 이점:");
        println!("  ✅ 병렬 처리로 성능 향상");
        println!("  ✅ 응답성 개선");
        println!("  ✅ 멀티 코어 활용");
        println!();
    }

    // ==================== 섹션 2: thread::spawn의 기본 ====================
    println!("📌 섹션 2: thread::spawn의 기본\n");
    {
        println!("스레드 생성 예제:");
        println!();

        let handle = thread::spawn(|| {
            for i in 1..5 {
                println!("  [워커 스레드] 작업 {} 진행 중", i);
                thread::sleep(Duration::from_millis(100));
            }
        });

        println!("  [메인 스레드] 계속 실행");
        thread::sleep(Duration::from_millis(150));

        println!("  [메인 스레드] 워커 스레드 대기 중...");
        handle.join().unwrap();

        println!("  [메인 스레드] 완료!");
        println!();
    }

    // ==================== 섹션 3: Move 클로저 ====================
    println!("📌 섹션 3: Move 클로저\n");
    {
        println!("Move 없이 변수 공유 (불가능):");
        println!("  let v = vec![1, 2, 3];");
        println!("  thread::spawn(|| {{");
        println!("    println!(\"{{:?}}\", v);  // ❌ v의 소유권?");
        println!("  }});");
        println!();

        println!("Move로 소유권 이동:");
        let v = vec![1, 2, 3];
        let handle = thread::spawn(move || {
            println!("  [워커] 벡터 수신: {:?}", v);
            // v의 소유권을 스레드로 완전히 이동
        });
        // println!("{:?}", v);  // ❌ v는 이제 없음 (이동됨)

        handle.join().unwrap();
        println!();

        println!("Move의 의미:");
        println!("  ✅ 데이터의 완전한 소유권 이동");
        println!("  ✅ 스레드가 데이터 소유");
        println!("  ✅ 경합 불가능");
        println!();
    }

    // ==================== 섹션 4: Join 핸들과 반환값 ====================
    println!("📌 섹션 4: Join 핸들과 반환값\n");
    {
        println!("스레드에서 값 반환:");
        println!();

        let handle = thread::spawn(|| {
            let result = {
                let mut sum = 0;
                for i in 1..=5 {
                    sum += i;
                }
                sum
            };
            result  // 반환값
        });

        println!("  [메인] 스레드 작업 대기");
        let value = handle.join().unwrap();
        println!("  [메인] 스레드 결과: {}", value);
        println!();

        println!("Join의 역할:");
        println!("  ✅ 스레드 완료 대기");
        println!("  ✅ 반환값 수신");
        println!("  ✅ 패닉 처리 (Ok/Err)");
        println!();
    }

    // ==================== 섹션 5: 멀티 스레드 병렬 실행 ====================
    println!("📌 섹션 5: 멀티 스레드 병렬 실행\n");
    {
        println!("3개 스레드 동시 실행:");
        println!();

        let start = std::time::Instant::now();

        let handle1 = thread::spawn(|| {
            for i in 1..=3 {
                println!("  [스레드 1] 작업 {}", i);
                thread::sleep(Duration::from_millis(50));
            }
            "스레드 1 완료"
        });

        let handle2 = thread::spawn(|| {
            for i in 1..=3 {
                println!("  [스레드 2] 작업 {}", i);
                thread::sleep(Duration::from_millis(50));
            }
            "스레드 2 완료"
        });

        let handle3 = thread::spawn(|| {
            for i in 1..=3 {
                println!("  [스레드 3] 작업 {}", i);
                thread::sleep(Duration::from_millis(50));
            }
            "스레드 3 완료"
        });

        println!("  [메인] 3개 스레드 모두 대기...");
        let result1 = handle1.join().unwrap();
        let result2 = handle2.join().unwrap();
        let result3 = handle3.join().unwrap();

        let elapsed = start.elapsed();
        println!("  [메인] 결과: {}, {}, {}", result1, result2, result3);
        println!("  [메인] 총 시간: {:.3}초", elapsed.as_secs_f64());
        println!();

        println!("병렬 실행의 장점:");
        println!("  ✅ 독립적 작업 동시 수행");
        println!("  ✅ 전체 시간 단축");
        println!("  ✅ CPU 활용도 증가");
        println!();
    }

    // ==================== 섹션 6: 데이터 경합 문제 ====================
    println!("📌 섹션 6: 데이터 경합 문제\n");
    {
        println!("데이터 경합 (Data Race) 정의:");
        println!("  두 개 이상의 스레드가 동시에");
        println!("  같은 메모리에 접근하고");
        println!("  최소 하나는 쓰기 작업을 수행");
        println!();

        println!("러스트의 대응:");
        println!("  ❌ 컴파일 거부 (스레드 경계 소유권 검사)");
        println!("  ✅ 컴파일 가능하면 런타임 안전");
        println!();

        println!("경합 불가능 예제:");
        {
            let data = vec![1, 2, 3];
            let handle = thread::spawn(move || {
                println!("  [워커] 데이터: {:?}", data);
                // 워커가 data 소유
            });
            // let x = data[0];  // ❌ 컴파일 에러!
            // data는 워커로 이동되었음

            handle.join().unwrap();
        }
        println!("  [메인] data는 워커로 이동되어 경합 불가능");
        println!();
    }

    // ==================== 섹션 7: 스레드 ID와 이름 ====================
    println!("📌 섹션 7: 스레드 ID와 이름\n");
    {
        println!("메인 스레드 ID: {:?}", thread::current().id());
        println!("메인 스레드 이름: {:?}", thread::current().name());
        println!();

        let handle = thread::Builder::new()
            .name("작업 스레드".to_string())
            .spawn(|| {
                println!("  [워커] ID: {:?}", thread::current().id());
                println!("  [워커] 이름: {:?}", thread::current().name());
            })
            .unwrap();

        handle.join().unwrap();
        println!();

        println!("스레드 이름의 용도:");
        println!("  ✅ 디버깅 시 스레드 식별");
        println!("  ✅ 로그에서 어느 스레드인지 확인");
        println!("  ✅ 스레드 풀 관리");
        println!();
    }

    // ==================== 섹션 8: 패닉 처리 ====================
    println!("📌 섹션 8: 패닉 처리\n");
    {
        println!("정상 스레드:");
        let handle1 = thread::spawn(|| {
            println!("  [스레드 1] 정상 완료");
            "성공"
        });

        match handle1.join() {
            Ok(result) => println!("  [메인] 결과: {}", result),
            Err(_) => println!("  [메인] 스레드 패닉!"),
        }
        println!();

        println!("패닉하는 스레드:");
        let handle2 = thread::spawn(|| {
            println!("  [스레드 2] 작업 중...");
            panic!("의도적인 패닉!");
        });

        match handle2.join() {
            Ok(_) => println!("  [메인] 정상 완료"),
            Err(_) => println!("  [메인] 워커 스레드가 패닉했지만 프로그램 계속"),
        }
        println!();

        println!("패닉의 격리:");
        println!("  ✅ 워커 패닉 = 워커만 종료");
        println!("  ✅ 메인은 안전");
        println!("  ✅ 다른 워커도 안전");
        println!();
    }

    // ==================== 섹션 9: 성능 측정 ====================
    println!("📌 섹션 9: 성능 측정\n");
    {
        println!("순차 처리 (Sequential):");
        let start = std::time::Instant::now();
        {
            let mut sum = 0;
            for i in 1..=1000000 {
                sum += i;
            }
            for i in 1..=1000000 {
                let _ = i * 2;
            }
            for i in 1..=1000000 {
                let _ = i / 2;
            }
        }
        let elapsed = start.elapsed();
        println!("  순차 처리 시간: {:.3}ms", elapsed.as_secs_f64() * 1000.0);
        println!();

        println!("병렬 처리 (Parallel):");
        let start = std::time::Instant::now();
        {
            let handle1 = thread::spawn(|| {
                let mut sum = 0;
                for i in 1..=1000000 {
                    sum += i;
                }
                sum
            });

            let handle2 = thread::spawn(|| {
                let mut result = 0;
                for i in 1..=1000000 {
                    result += i * 2;
                }
                result
            });

            let handle3 = thread::spawn(|| {
                let mut result = 0;
                for i in 1..=1000000 {
                    result += i / 2;
                }
                result
            });

            let _r1 = handle1.join().unwrap();
            let _r2 = handle2.join().unwrap();
            let _r3 = handle3.join().unwrap();
        }
        let elapsed = start.elapsed();
        println!("  병렬 처리 시간: {:.3}ms", elapsed.as_secs_f64() * 1000.0);
        println!();

        println!("성능 특성:");
        println!("  ✅ CPU 바운드 작업은 멀티 코어로 가속");
        println!("  ✅ I/O 대기는 병렬로 숨김");
        println!("  ⚠️  오버헤드도 존재 (작은 작업은 비효율)");
        println!();
    }

    // ==================== 섹션 10: 스레드 풀 개념 ====================
    println!("📌 섹션 10: 스레드 풀 개념\n");
    {
        println!("문제: 매번 스레드 생성 = 오버헤드");
        println!("  작업 100개");
        println!("  → 스레드 100개 생성?");
        println!("  → 메모리 낭비, 시간 낭비");
        println!();

        println!("해결책: 스레드 풀 (Thread Pool)");
        println!("  작업 100개");
        println!("  → 스레드 4개 (또는 CPU 코어 수)");
        println!("  → 작업 큐에서 순차 처리");
        println!("  → 효율적! ✅");
        println!();

        println!("스레드 풀 설계:");
        println!("  1. Worker: 작업을 처리할 스레드");
        println!("  2. Job Queue: 처리할 작업 목록");
        println!("  3. Channel: 메인과 워커 통신");
        println!("  4. ThreadPool: 전체 관리");
        println!();

        println!("다음 버전 (v10.1)에서 구현...");
        println!();
    }

    // ==================== 섹션 11: Scope 스레드 ====================
    println!("📌 섹션 11: Scope 스레드\n");
    {
        println!("일반 스레드 (Move 필수):");
        {
            let v = vec![1, 2, 3];
            let handle = thread::spawn(move || {
                println!("  일반: {:?}", v);
            });
            // v는 이동되었으므로 여기서 사용 불가
            handle.join().unwrap();
            // println!("{:?}", v);  // ❌ 불가능
        }
        println!();

        println!("Scope 스레드 (참조 가능):");
        {
            let v = vec![1, 2, 3];
            thread::scope(|s| {
                s.spawn(|| {
                    println!("  Scope: {:?}", v);
                    // v를 빌려옴 (move 아님)
                });
                // v는 여전히 사용 가능
                println!("  메인: {:?}", v);
            });
            // scope 블록이 끝나면 모든 스레드가 완료됨 (join 불필요)
            println!("  메인: 스레드 완료");
        }
        println!();

        println!("Scope 스레드의 장점:");
        println!("  ✅ Move 불필요");
        println!("  ✅ 참조 사용 가능");
        println!("  ✅ 자동 join");
        println!("  ⚠️  스코프 내 사용만 가능");
        println!();
    }

    // ==================== 섹션 12: 설계자 관점과 다음 단계 ====================
    println!("📌 섹션 12: 설계자 관점과 다음 단계\n");
    {
        println!("설계자 관점: \"병렬 실행의 격리\"");
        println!();

        println!("1️⃣  독립성 극대화");
        println!("   각 스레드가 자신의 데이터만 사용");
        println!("   → 경합 불가능");
        println!();

        println!("2️⃣  소유권의 확장");
        println!("   메모리 규칙을 스레드 경계까지 적용");
        println!("   → 데이터 경합 원천 차단");
        println!();

        println!("3️⃣  성능과 안전의 조화");
        println!("   락 없이도 안전한 병렬화");
        println!("   → \"두려움 없는 동시성\"");
        println!();

        println!("v10 스레드 시리즈:");
        println!("  v10.0: 스레드 기초 (spawn, join, move) ✅");
        println!("  v10.1: 채널 (메시지 패싱)");
        println!("  v10.2: 뮤텍스 (공유 상태)");
        println!("  v10.3: 원자 연산 (Atomic)");
        println!();

        println!("다음 단계: v10.1 채널");
        println!("  \"스레드 간 안전한 통신\"");
        println!("  메시지 패싱으로 데이터 공유");
        println!("  Sender / Receiver 패턴");
        println!();
    }

    // ==================== 최종 선언 ====================
    println!("╔══════════════════════════════════════════════════════════╗");
    println!("║ 두려움 없는 동시성 (Fearless Concurrency) 입문          ║");
    println!("╚══════════════════════════════════════════════════════════╝\n");

    println!("✅ 당신이 이제 할 수 있는 것:");
    println!("   • 스레드 생성 및 관리");
    println!("   • 데이터 경합 방지");
    println!("   • 병렬 실행으로 성능 향상");
    println!("   • Move 클로저로 소유권 이동");
    println!("   • Join으로 동기화");
    println!();

    println!("✅ 러스트의 강력함:");
    println!("   • 컴파일러가 경합 차단");
    println!("   • 런타임 락 필요 없음");
    println!("   • 멀티 코어 완전 활용");
    println!("   • 여전히 메모리 안전");
    println!();

    println!("🏆 당신은 이제 병렬 시스템 설계자입니다.");
    println!("   단일 스레드 한계를 벗어났습니다. ⚡");
    println!();
}
