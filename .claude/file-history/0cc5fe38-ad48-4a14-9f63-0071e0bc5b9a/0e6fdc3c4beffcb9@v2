// ============================================================================
// Lexer Implementation: 유한 상태 기계 기반 어휘 분석기
// ============================================================================
// 소스코드를 한 글자씩 읽으며 토큰으로 분해하는 엔진

use crate::token::{Token, Position, TokenWithPos};

/// 유한 상태 기계 기반 어휘 분석기
pub struct Lexer {
    // 입력
    input: Vec<char>,      // 소스코드를 문자 배열로 변환

    // 위치 추적
    position: usize,       // 현재 읽은 위치
    read_position: usize,  // 다음 읽을 위치
    ch: char,              // 현재 조사 중인 문자

    // 행/열 추적 (에러 메시지용)
    line: usize,
    column: usize,
}

impl Lexer {
    /// 새로운 Lexer 인스턴스 생성
    pub fn new(input: String) -> Self {
        let mut lexer = Lexer {
            input: input.chars().collect(),
            position: 0,
            read_position: 0,
            ch: '\0',
            line: 1,
            column: 1,
        };
        lexer.read_char();
        lexer
    }

    /// 다음 문자로 이동
    fn read_char(&mut self) {
        if self.read_position >= self.input.len() {
            self.ch = '\0';
        } else {
            self.ch = self.input[self.read_position];

            // 행/열 추적
            if self.ch == '\n' {
                self.line += 1;
                self.column = 1;
            } else {
                self.column += 1;
            }
        }
        self.position = self.read_position;
        self.read_position += 1;
    }

    /// 다음 문자를 미리 보기 (peeking)
    fn peek_char(&self) -> char {
        if self.read_position >= self.input.len() {
            '\0'
        } else {
            self.input[self.read_position]
        }
    }

    /// 현재 위치 정보 반환
    fn current_position(&self) -> Position {
        Position::new(self.line, self.column.saturating_sub(1), self.position)
    }

    /// 공백과 주석 건너뛰기
    fn skip_whitespace_and_comments(&mut self) {
        loop {
            match self.ch {
                ' ' | '\t' | '\n' | '\r' => {
                    self.read_char();
                }
                '/' if self.peek_char() == '/' => {
                    // 한 줄 주석: // 이후 모든 문자 무시
                    while self.ch != '\n' && self.ch != '\0' {
                        self.read_char();
                    }
                }
                '/' if self.peek_char() == '*' => {
                    // 블록 주석: /* ... */ 무시
                    self.read_char(); // '/'
                    self.read_char(); // '*'
                    while self.ch != '\0' {
                        if self.ch == '*' && self.peek_char() == '/' {
                            self.read_char(); // '*'
                            self.read_char(); // '/'
                            break;
                        }
                        self.read_char();
                    }
                }
                _ => break,
            }
        }
    }

    /// 식별자 읽기 (변수명, 함수명, 키워드)
    fn read_identifier(&mut self) -> String {
        let pos = self.position;
        while self.ch.is_alphanumeric() || self.ch == '_' {
            self.read_char();
        }
        self.input[pos..self.position].iter().collect()
    }

    /// 숫자 읽기 (정수 또는 실수)
    fn read_number(&mut self) -> (Token, bool) {
        let pos = self.position;
        let mut is_float = false;

        while self.ch.is_numeric() {
            self.read_char();
        }

        // 실수 검사
        if self.ch == '.' && self.peek_char().is_numeric() {
            is_float = true;
            self.read_char(); // '.'
            while self.ch.is_numeric() {
                self.read_char();
            }
        }

        let num_str: String = self.input[pos..self.position].iter().collect();

        if is_float {
            let num = num_str.parse::<f64>().unwrap_or(0.0);
            (Token::Float(num), true)
        } else {
            let num = num_str.parse::<i64>().unwrap_or(0);
            (Token::Int(num), true)
        }
    }

    /// 문자열 읽기
    fn read_string(&mut self, quote_char: char) -> Option<String> {
        let mut result = String::new();
        self.read_char(); // 여는 따옴표 건너뛰기

        while self.ch != quote_char && self.ch != '\0' {
            if self.ch == '\\' {
                // 이스케이프 시퀀스
                self.read_char();
                match self.ch {
                    'n' => result.push('\n'),
                    't' => result.push('\t'),
                    '\\' => result.push('\\'),
                    '"' => result.push('"'),
                    '\'' => result.push('\''),
                    _ => {
                        result.push('\\');
                        result.push(self.ch);
                    }
                }
            } else {
                result.push(self.ch);
            }
            self.read_char();
        }

        if self.ch == quote_char {
            self.read_char(); // 닫는 따옴표 건너뛰기
            Some(result)
        } else {
            None // 닫히지 않은 문자열
        }
    }

    /// 키워드 또는 식별자 구분
    fn keyword_or_ident(ident: String) -> Token {
        match ident.as_str() {
            "let" => Token::Let,
            "fn" => Token::Fn,
            "if" => Token::If,
            "else" => Token::Else,
            "return" => Token::Return,
            "while" => Token::While,
            "for" => Token::For,
            "break" => Token::Break,
            "continue" => Token::Continue,
            "const" => Token::Const,
            "mut" => Token::Mut,
            "true" => Token::True,
            "false" => Token::False,
            "null" => Token::Null,
            _ => Token::Ident(ident),
        }
    }

    /// 다음 토큰 추출
    pub fn next_token(&mut self) -> TokenWithPos {
        self.skip_whitespace_and_comments();

        let pos = self.current_position();
        let token = match self.ch {
            // ========== 단일 문자 토큰 ==========
            '+' => {
                if self.peek_char() == '=' {
                    self.read_char();
                    Token::PlusAssign
                } else {
                    Token::Plus
                }
            }
            '-' => {
                if self.peek_char() == '>' {
                    self.read_char();
                    Token::Arrow
                } else if self.peek_char() == '=' {
                    self.read_char();
                    Token::MinusAssign
                } else {
                    Token::Minus
                }
            }
            '*' => {
                if self.peek_char() == '=' {
                    self.read_char();
                    Token::AsteriskAssign
                } else {
                    Token::Asterisk
                }
            }
            '/' => {
                if self.peek_char() == '=' {
                    self.read_char();
                    Token::SlashAssign
                } else {
                    Token::Slash
                }
            }
            '%' => Token::Percent,
            '=' => {
                if self.peek_char() == '=' {
                    self.read_char();
                    Token::EqualEqual
                } else if self.peek_char() == '>' {
                    self.read_char();
                    Token::FatArrow
                } else {
                    Token::Assign
                }
            }
            '!' => {
                if self.peek_char() == '=' {
                    self.read_char();
                    Token::NotEqual
                } else {
                    Token::Bang
                }
            }
            '<' => {
                if self.peek_char() == '=' {
                    self.read_char();
                    Token::LessEqual
                } else if self.peek_char() == '<' {
                    self.read_char();
                    Token::LeftShift
                } else {
                    Token::Less
                }
            }
            '>' => {
                if self.peek_char() == '=' {
                    self.read_char();
                    Token::GreaterEqual
                } else if self.peek_char() == '>' {
                    self.read_char();
                    Token::RightShift
                } else {
                    Token::Greater
                }
            }
            '&' => Token::Ampersand,
            '|' => Token::Pipe,
            '^' => Token::Caret,
            '(' => Token::LeftParen,
            ')' => Token::RightParen,
            '{' => Token::LeftBrace,
            '}' => Token::RightBrace,
            '[' => Token::LeftBracket,
            ']' => Token::RightBracket,
            ';' => Token::Semicolon,
            ':' => Token::Colon,
            ',' => Token::Comma,
            '.' => {
                if self.peek_char() == '.' && self.read_position + 1 < self.input.len() &&
                   self.input[self.read_position + 1] == '.' {
                    self.read_char();
                    self.read_char();
                    Token::Ellipsis
                } else {
                    Token::Dot
                }
            }

            // ========== 문자열 ==========
            '"' => {
                match self.read_string('"') {
                    Some(s) => Token::String(s),
                    None => Token::Unknown('"'),
                }
            }
            '\'' => {
                match self.read_string('\'') {
                    Some(s) => {
                        if s.len() == 1 {
                            Token::Char(s.chars().next().unwrap())
                        } else {
                            Token::String(s)
                        }
                    }
                    None => Token::Unknown('\''),
                }
            }

            // ========== 식별자 & 숫자 ==========
            _ => {
                if self.ch.is_alphabetic() || self.ch == '_' {
                    let ident = self.read_identifier();
                    return TokenWithPos::new(Self::keyword_or_ident(ident), pos);
                } else if self.ch.is_numeric() {
                    let (token, _) = self.read_number();
                    return TokenWithPos::new(token, pos);
                } else if self.ch == '\0' {
                    Token::EOF
                } else {
                    Token::Unknown(self.ch)
                }
            }
        };

        self.read_char();
        TokenWithPos::new(token, pos)
    }

    /// 모든 토큰을 한 번에 추출 (편의함수)
    pub fn tokenize(&mut self) -> Vec<TokenWithPos> {
        let mut tokens = Vec::new();
        loop {
            let token_with_pos = self.next_token();
            let is_eof = token_with_pos.token == Token::EOF;
            tokens.push(token_with_pos);
            if is_eof {
                break;
            }
        }
        tokens
    }
}
