/// 섹션 1: 기초 구조체 정의
///
/// 구조체: 이름 있는 필드들의 모음
/// - 설계도: 데이터가 메모리에 어떻게 배치될지 정의
/// - 타입 안전성: 단순 String/i32가 아닌 고유 타입
/// - 의미 명확성: 각 필드의 목적이 드러남
mod section_1_basic_struct {
    // 예시 1: 학생 정보 구조체
    // 파편화된 변수들을 하나의 의미 있는 단위로 묶음
    #[derive(Debug)]
    pub struct Student {
        pub name: String,      // 이름
        pub id: u32,           // 학번
        pub gpa: f32,          // 학점
        pub is_active: bool,   // 활성 상태
    }

    // 예시 2: Gogs 레코드 (선생님의 예시)
    #[derive(Debug)]
    pub struct GogsRecord {
        pub id: u64,
        pub subject: String,
        pub content: String,
        pub is_verified: bool,
        pub version: f32,
    }

    // 예시 3: 서버 상태 구조체
    #[derive(Debug)]
    pub struct ServerStatus {
        pub hostname: String,
        pub port: u16,
        pub is_running: bool,
        pub cpu_usage: f32,
        pub memory_usage: f32,
    }

    pub fn demonstrate() {
        println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
        println!("📚 섹션 1: 기초 구조체 정의");
        println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n");

        // ┌─────────────────────────────────────────────────────┐
        // │ 예시 1: Student 구조체
        // └─────────────────────────────────────────────────────┘
        println!("1️⃣ Student 구조체:");

        // 인스턴스화: 설계도를 바탕으로 실제 데이터 객체 생성
        let student_01 = Student {
            name: String::from("Claude"),
            id: 20260001,
            gpa: 4.5,
            is_active: true,
        };

        // 점(.) 표기법으로 필드 접근
        println!("   이름: {}", student_01.name);
        println!("   학번: {}", student_01.id);
        println!("   학점: {:.1}", student_01.gpa);
        println!("   활성: {}\n", student_01.is_active);

        // ┌─────────────────────────────────────────────────────┐
        // │ 예시 2: GogsRecord 구조체
        // └─────────────────────────────────────────────────────┘
        println!("2️⃣ GogsRecord 구조체:");

        let gogs_record = GogsRecord {
            id: 20260222,
            subject: String::from("중간고사 수료 기록"),
            content: String::from("제3장까지의 모든 논리와 모듈화 과정을 완수함."),
            is_verified: true,
            version: 5.0,
        };

        println!("   ID: {}", gogs_record.id);
        println!("   주제: {}", gogs_record.subject);
        println!("   내용: {}", gogs_record.content);
        println!("   검증됨: {}", gogs_record.is_verified);
        println!("   버전: v{:.1}\n", gogs_record.version);

        // ┌─────────────────────────────────────────────────────┐
        // │ 예시 3: ServerStatus 구조체
        // └─────────────────────────────────────────────────────┘
        println!("3️⃣ ServerStatus 구조체:");

        let server = ServerStatus {
            hostname: String::from("gogs.dclub.kr"),
            port: 3000,
            is_running: true,
            cpu_usage: 45.3,
            memory_usage: 62.7,
        };

        println!("   호스트명: {}", server.hostname);
        println!("   포트: {}", server.port);
        println!("   실행 상태: {}", server.is_running);
        println!("   CPU 사용률: {:.1}%", server.cpu_usage);
        println!("   메모리 사용률: {:.1}%\n", server.memory_usage);
    }
}

/// 섹션 2: 가변성과 필드 수정
///
/// 구조체의 가변성:
/// - immutable (기본): 구조체 전체가 불변
/// - mutable (mut): 구조체 필드를 수정 가능
/// - 필드별 독립성: Rust는 필드 레벨 가변성을 지원하지 않음 (모 아니면 도)
mod section_2_mutability {
    use super::section_1_basic_struct::Student;

    pub fn demonstrate() {
        println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
        println!("📚 섹션 2: 가변성과 필드 수정");
        println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n");

        // immutable 구조체: 생성 후 수정 불가
        println!("1️⃣ Immutable 구조체:");
        let student_immutable = Student {
            name: String::from("Alice"),
            id: 20260002,
            gpa: 3.8,
            is_active: true,
        };
        println!("   이름: {}", student_immutable.name);
        println!("   학점: {:.1}", student_immutable.gpa);
        println!("   ❌ student_immutable.gpa = 4.0; // 오류! 수정 불가\n");

        // mutable 구조체: 필드 수정 가능
        println!("2️⃣ Mutable 구조체:");
        let mut student_mutable = Student {
            name: String::from("Bob"),
            id: 20260003,
            gpa: 3.2,
            is_active: true,
        };

        println!("   초기 학점: {:.1}", student_mutable.gpa);

        // 필드 수정
        student_mutable.gpa = 3.9;
        student_mutable.is_active = false;

        println!("   수정 후 학점: {:.1}", student_mutable.gpa);
        println!("   수정 후 활성: {}\n", student_mutable.is_active);

        // 주의: 전체 구조체를 재할당하는 것도 가능
        println!("3️⃣ 구조체 재할당 (구조 업데이트):");
        let mut student_update = Student {
            name: String::from("Carol"),
            id: 20260004,
            gpa: 3.5,
            is_active: true,
        };

        println!("   초기 정보:");
        println!("      이름: {}, 학점: {:.1}", student_update.name, student_update.gpa);

        // 구조 업데이트 문법 (struct update syntax)
        student_update = Student {
            gpa: 4.0,
            name: String::from("Carol (Updated)"),
            ..student_update  // 나머지 필드는 기존 값 유지
        };

        println!("   업데이트 후 정보:");
        println!("      이름: {}, 학점: {:.1}\n", student_update.name, student_update.gpa);
    }
}

/// 섹션 3: 소유권과 구조체
///
/// 구조체와 메모리:
/// - String 필드: 구조체가 메모리 소유권 보유
/// - &str 필드: 참조만 보유 (lifetime 필요)
/// - Copy 타입 (i32, bool, f32): 복사됨
mod section_3_ownership {
    #[derive(Debug)]
    pub struct Project {
        pub title: String,       // owned (Move)
        pub version: i32,        // Copy
        pub is_active: bool,     // Copy
    }

    pub fn demonstrate() {
        println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
        println!("📚 섹션 3: 소유권과 구조체");
        println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n");

        println!("1️⃣ 구조체와 String 소유권:");

        let project_name = String::from("FreeLang v5.0");

        let mut project = Project {
            title: project_name,  // 소유권 이전! project_name은 더 이상 사용 불가
            version: 5,
            is_active: true,
        };

        println!("   프로젝트 제목: {}", project.title);
        // println!("{}", project_name);  // ❌ 오류! 소유권이 project로 이전됨

        println!("   ✅ project가 project_name의 소유권을 가짐\n");

        // project가 drop되면 내부 String도 함께 정리됨
        drop(project);
        println!("   drop(project) 후: project와 내부 String 모두 정리됨\n");

        println!("2️⃣ 구조체의 Clone:");

        let project2 = Project {
            title: String::from("Rust Design"),
            version: 4,
            is_active: true,
        };

        // Clone: 깊은 복사
        let project2_clone = project2.clone();

        println!("   원본: title = '{}', version = {}", project2.title, project2.version);
        println!("   복사본: title = '{}', version = {}", project2_clone.title, project2_clone.version);
        println!("   ✅ 두 구조체는 독립적인 String을 소유\n");
    }
}

/// 섹션 4: 구조체 비교와 Debug
///
/// Derived Traits:
/// - Debug: println!("{:?}", struct_instance)
/// - PartialEq: == 비교
/// - Clone: clone() 메서드
mod section_4_traits {
    #[derive(Debug, PartialEq, Clone)]
    pub struct Task {
        pub id: u32,
        pub title: String,
        pub is_completed: bool,
    }

    pub fn demonstrate() {
        println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
        println!("📚 섹션 4: 구조체 비교와 Debug");
        println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n");

        let task1 = Task {
            id: 1,
            title: String::from("v5.0 구조체 설계"),
            is_completed: true,
        };

        let task2 = Task {
            id: 1,
            title: String::from("v5.0 구조체 설계"),
            is_completed: true,
        };

        let task3 = Task {
            id: 2,
            title: String::from("v5.1 메서드 구현"),
            is_completed: false,
        };

        println!("1️⃣ Debug 출력:");
        println!("   {:?}\n", task1);

        println!("2️⃣ 구조체 비교 (PartialEq):");
        println!("   task1 == task2? {}", task1 == task2);
        println!("   task1 == task3? {}\n", task1 == task3);

        println!("3️⃣ Clone:");
        let task1_clone = task1.clone();
        println!("   task1 복사 완료");
        println!("   원본: {:?}", task1);
        println!("   복사본: {:?}\n", task1_clone);
    }
}

/// 섹션 5: 실전 예제 — 언어 레코드 시스템
///
/// 복합 구조체 활용:
/// - 중첩된 데이터 구조
/// - 벡터 내 구조체
/// - 여러 구조체 조합
mod section_5_real_world {
    #[derive(Debug, Clone)]
    pub struct LanguageRecord {
        pub chapter: u32,
        pub version: f32,
        pub title: String,
        pub description: String,
        pub is_completed: bool,
    }

    pub fn demonstrate() {
        println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
        println!("📚 섹션 5: 실전 예제 — 언어 레코드 시스템");
        println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n");

        // 언어 설계 기록들
        let records = vec![
            LanguageRecord {
                chapter: 1,
                version: 1.0,
                title: String::from("존재의 증명"),
                description: String::from("출력과 연산으로 언어의 존재를 증명"),
                is_completed: true,
            },
            LanguageRecord {
                chapter: 2,
                version: 2.0,
                title: String::from("메모리의 명명"),
                description: String::from("변수, 타입, 불변성 개념 도입"),
                is_completed: true,
            },
            LanguageRecord {
                chapter: 3,
                version: 5.0,
                title: String::from("데이터 구조화"),
                description: String::from("구조체를 통한 데이터의 인격화"),
                is_completed: true,
            },
        ];

        println!("1️⃣ 모든 기록 출력:");
        for record in &records {
            println!("   [{:?}] v{:.1}: {}", record.chapter, record.version, record.title);
            println!("      └─ {}", record.description);
            println!("      └─ 완료: {}\n", record.is_completed);
        }

        println!("2️⃣ 구조체 필터링 및 통계:");
        let completed_count = records.iter().filter(|r| r.is_completed).count();
        println!("   완료된 레코드: {}/{}", completed_count, records.len());

        let latest_version = records.iter()
            .map(|r| r.version)
            .fold(0.0, f32::max);
        println!("   최신 버전: v{:.1}\n", latest_version);

        println!("3️⃣ 특정 레코드 접근:");
        if let Some(current) = records.iter().find(|r| r.chapter == 3) {
            println!("   현재 단계: {}", current.title);
            println!("   설명: {}", current.description);
        }
    }
}

/// 섹션 6: 구조체 설계의 황금률
///
/// v5.0 설계자의 3가지 원칙:
/// 1. 필드의 최소화: 꼭 필요한 데이터만
/// 2. 이름의 구체성: 의도가 드러나는 이름
/// 3. 소유권 주의: String과 참조의 차이 이해
mod section_6_best_practices {
    // ❌ 나쁜 설계: 필드가 너무 많고 이름이 모호함
    #[allow(dead_code)]
    pub struct BadDesign {
        pub data1: String,
        pub val: i32,
        pub state: bool,
        pub extra1: f32,
        pub extra2: String,
        pub extra3: bool,
        pub info: String,
    }

    // ✅ 좋은 설계: 필드는 최소한이고 이름이 명확함
    #[derive(Debug)]
    pub struct GoodDesign {
        pub username: String,
        pub user_id: u32,
        pub is_active: bool,
    }

    pub fn demonstrate() {
        println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
        println!("📚 섹션 6: 구조체 설계의 황금률");
        println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n");

        println!("1️⃣ 원칙 1: 필드의 최소화");
        println!("   ❌ BadDesign: 7개 필드 (이중 복잡성)");
        println!("   ✅ GoodDesign: 3개 필드 (핵심만 보존)\n");

        println!("2️⃣ 원칙 2: 이름의 구체성");
        println!("   ❌ data1, val, extra1 → 의도 불명확");
        println!("   ✅ username, user_id, is_active → 명확한 의도\n");

        println!("3️⃣ 원칙 3: 소유권 주의");
        let user = GoodDesign {
            username: String::from("claude"),
            user_id: 001,
            is_active: true,
        };
        println!("   {:?}", user);
        println!("   → user가 String 소유권 보유");
        println!("   → user가 drop되면 username 자동 정리\n");
    }
}

