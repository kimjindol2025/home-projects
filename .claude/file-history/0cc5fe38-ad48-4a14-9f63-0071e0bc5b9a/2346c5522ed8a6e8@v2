mod cargo_management {
    pub fn explain_cargo_system() {
        println!("【섹션 2】Cargo와 의존성 관리");
        println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n");

        println!("[Cargo란]");
        println!("  Cargo = Rust의 패키지 매니저 + 빌드 시스템\n");

        println!("[Cargo.toml의 역할]");
        println!("  [package]");
        println!("    name = \"my_project\"");
        println!("    version = \"0.1.0\"");
        println!();
        println!("  [dependencies]");
        println!("    rand = \"0.8\"");
        println!("    chrono = \"0.4\"\n");

        println!("[버전 명시 방식]");
        println!("  \"0.8\"        → 0.8.0 이상, 0.9.0 미만");
        println!("  \"0.8.3\"      → 정확히 0.8.3");
        println!("  \"0.8.*\"      → 0.8.x 모든 버전");
        println!("  \">= 0.8\"     → 0.8.0 이상 모든 버전\n");

        println!("[의존성 추가 명령어]");
        println!("  $ cargo add rand");
        println!("  $ cargo add chrono --version \"0.4\"\n");

        println!("[Cargo.lock 파일]");
        println!("  └─ 정확한 버전 기록");
        println!("  └─ 모든 협업자가 같은 버전 사용");
        println!("  └─ 재현 가능한 빌드 보장\n");
    }
}

