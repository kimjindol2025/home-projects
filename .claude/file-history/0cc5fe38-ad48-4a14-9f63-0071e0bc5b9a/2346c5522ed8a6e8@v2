mod external_crates {
    // 주의: 이 예제는 실제 rand 라이브러리 없이 시뮬레이션합니다

    pub fn demonstrate_external_usage() {
        println!("【섹션 3】외부 라이브러리 사용");
        println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n");

        println!("[예제 1] rand 크레이트 (난수 생성)");
        println!("  use rand::Rng;");
        println!();
        println!("  let mut rng = rand::thread_rng();");
        println!("  let random_number = rng.gen_range(1..100);\n");

        println!("[예제 2] chrono 크레이트 (시간 처리)");
        println!("  use chrono::Local;");
        println!();
        println!("  let now = Local::now();");
        println!("  println!(\"{}\", now);\n");

        println!("[예제 3] serde 크레이트 (직렬화)");
        println!("  use serde::{Serialize, Deserialize};");
        println!();
        println!("  #[derive(Serialize, Deserialize)]");
        println!("  struct User {{");
        println!("    name: String,");
        println!("    age: u32,");
        println!("  }}\n");

        println!("[예제 4] regex 크레이트 (패턴 매칭)");
        println!("  use regex::Regex;");
        println!();
        println!("  let re = Regex::new(r\"\\d+\").unwrap();");
        println!("  let result = re.find(\"hello123\");\n");
    }

    pub fn simulate_random_usage() {
        println!("[시뮬레이션] rand 크레이트의 실제 사용");

        // 시뮬레이션: 난수 생성
        let simulated_random = 7463;  // 실제로는 rng.gen_range()

        println!("  🎲 보안 코드 생성: {}", simulated_random);
        println!("  🎲 난수 범위 (1000..10000)");
        println!("  🎲 생성 방식: thread_rng() - 스레드별 난수 생성기\n");
    }

    pub fn demonstrate_datetime() {
        println!("[시뮬레이션] chrono 크레이트의 실제 사용");

        println!("  📅 현재 시간: 2026-02-22T15:30:45");
        println!("  📅 시간 포맷: \"%Y-%m-%d %H:%M:%S\"");
        println!("  📅 타임존: UTC + 0\n");
    }

    pub fn demonstrate_serialization() {
        println!("[시뮬레이션] serde 크레이트의 실제 사용");

        println!("  📦 직렬화: Rust struct → JSON");
        println!("  📦 역직렬화: JSON → Rust struct");
        println!("  📦 포맷: JSON, YAML, TOML 등\n");
    }
}

// ────────────────────────────────────────────────────────────────────────
// [섹션 4] 표준 라이브러리 심화: Std Lib 고급 활용
// ────────────────────────────────────────────────────────────────────────

mod std_lib_advanced {
    use std::collections::{HashMap, HashSet, VecDeque};

    pub fn demonstrate_collections() {
        println!("【섹션 4】표준 라이브러리 심화");
        println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n");

        println!("[시연 4-1] HashMap - 키-값 쌍");
        let mut map = HashMap::new();
        map.insert("rust", 90);
        map.insert("python", 85);
        map.insert("go", 88);

        println!("  HashMap: {:?}", map);
        println!("  Rust 점수: {}\n", map.get("rust").unwrap_or(&0));

        println!("[시연 4-2] HashSet - 중복 없는 컬렉션");
        let mut set = HashSet::new();
        set.insert("apple");
        set.insert("banana");
        set.insert("apple");  // 중복은 무시

        println!("  HashSet: {:?}", set);
        println!("  크기: {}\n", set.len());

        println!("[시연 4-3] VecDeque - 양쪽 끝 접근");
        let mut deque = VecDeque::new();
        deque.push_back(1);
        deque.push_back(2);
        deque.push_front(0);

        println!("  VecDeque: {:?}\n", deque);
    }

    pub fn demonstrate_error_handling() {
        println!("[시연 4-4] 표준 라이브러리의 에러 처리");

        println!("  Option<T>:");
        let value: Option<i32> = Some(42);
        match value {
            Some(v) => println!("    값: {}", v),
            None => println!("    값 없음"),
        }
        println!();

        println!("  Result<T, E>:");
        let result: Result<i32, &str> = Ok(100);
        match result {
            Ok(v) => println!("    성공: {}", v),
            Err(e) => println!("    오류: {}", e),
        }
        println!();
    }
}

