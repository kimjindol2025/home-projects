mod integration {
    use std::collections::HashMap;

    pub fn demonstrate_integration() {
        println!("【섹션 7】응용: 크레이트와 내부 모듈의 조화");
        println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n");

        println!("[시스템 아키텍처]");
        println!();
        println!("  외부 크레이트 (검증된 도구)");
        println!("  ├─ rand: 난수 생성");
        println!("  ├─ chrono: 시간 처리");
        println!("  └─ serde: 직렬화");
        println!("        ↓");
        println!("  내부 모듈 (우리의 비즈니스 로직)");
        println!("  ├─ core_system: 시스템 관리");
        println!("  ├─ security: 보안 기능");
        println!("  └─ analytics: 분석 기능\n");

        println!("[통합 예제]");

        // 내부 모듈
        let mut user_sessions = HashMap::new();
        user_sessions.insert("user1", "active");
        user_sessions.insert("user2", "inactive");

        println!("  📊 사용자 세션 현황:");
        for (user, status) in &user_sessions {
            println!("    - {}: {}", user, status);
        }
        println!();

        // 외부 크레이트 사용 (시뮬레이션)
        let simulated_timestamp = "2026-02-22T15:30:45";
        let simulated_random_id = 9847;

        println!("  🎲 세션 ID 생성 (rand 크레이트 사용)");
        println!("    Session ID: {}", simulated_random_id);
        println!("    생성 시간: {}", simulated_timestamp);
        println!("    → 외부 크레이트 + 내부 모듈의 완벽한 조화\n");
