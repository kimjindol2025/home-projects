// ────────────────────────────────────────────────────────────────────────
// [섹션 1] 크레이트의 개념: 러스트의 컴파일과 공유 단위
// ────────────────────────────────────────────────────────────────────────

mod crate_concepts {
    // 크레이트는 두 가지 형태로 존재:
    // 1. Binary Crate: 실행 가능한 프로그램 (main.rs 있음)
    // 2. Library Crate: 다른 프로그램이 사용할 라이브러리 (lib.rs 있음)

    pub fn explain_crate_types() {
        println!("【섹션 1】크레이트의 개념");
        println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n");

        println!("[크레이트의 정의]");
        println!("  크레이트 = 러스트의 컴파일 단위 + 공유 단위\n");

        println!("[크레이트 종류]");
        println!("  1️⃣ Binary Crate");
        println!("     └─ main.rs가 있음");
        println!("     └─ 실행 가능한 프로그램");
        println!("     └─ 예: 이 프로그램\n");

        println!("  2️⃣ Library Crate");
        println!("     └─ lib.rs가 있음");
        println!("     └─ 다른 프로젝트가 사용 가능");
        println!("     └─ 예: rand, chrono, serde\n");

        println!("[크레이트의 구조]");
        println!("  my_project/");
        println!("  ├── Cargo.toml        (메타데이터)");
        println!("  ├── src/");
        println!("  │   ├── main.rs       (Binary Crate)");
        println!("  │   └── lib.rs        (Library Crate)");
        println!("  └── target/");
        println!("      └── (컴파일 결과)\n");
    }
}

// ────────────────────────────────────────────────────────────────────────
// [섹션 2] Cargo와 의존성 관리: 외부 도구 통합
