// [섹션 6] 버전 관리와 재현 가능한 빌드
// ────────────────────────────────────────────────────────────────────────

mod version_management {
    pub fn explain_version_control() {
        println!("【섹션 6】버전 관리와 재현 가능한 빌드");
        println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n");

        println!("[Semantic Versioning]");
        println!("  X.Y.Z (MAJOR.MINOR.PATCH)\n");

        println!("  MAJOR: 호환 불가능한 변경");
        println!("    예: 1.0.0 → 2.0.0");
        println!("    영향: API 변경, 함수 제거\n");

        println!("  MINOR: 하위 호환 기능 추가");
        println!("    예: 1.0.0 → 1.1.0");
        println!("    영향: 새 함수 추가\n");

        println!("  PATCH: 하위 호환 버그 수정");
        println!("    예: 1.0.0 → 1.0.1");
        println!("    영향: 버그 수정만\n");

        println!("[Cargo.lock의 중요성]");
        println!("  ✅ Cargo.lock 파일:");
        println!("    └─ 정확한 버전 기록");
        println!("    └─ git에 커밋해야 함");
        println!("    └─ 모든 협업자가 같은 버전 보장\n");

        println!("  예시:");
        println!("    Alice가 rand 0.8.0 사용");
        println!("    Bob도 같은 Cargo.lock으로 rand 0.8.0 사용");
        println!("    → 같은 환경에서 동일 결과\n");
    }

    pub fn demonstrate_reproducible_build() {
        println!("[재현 가능한 빌드 구현]");
        println!();

        println!("  파일 1: Cargo.toml");
        println!("    [dependencies]");
        println!("    rand = \"0.8\"\n");

        println!("  파일 2: Cargo.lock (생성됨)");
        println!("    [[package]]");
        println!("    name = \"rand\"");
        println!("    version = \"0.8.5\"");
        println!("    # (의존성의 의존성도 모두 기록)\n");

        println!("  결과:");
        println!("    1. 처음 빌드: cargo build");
        println!("    2. Cargo.lock 생성");
        println!("    3. git에 커밋");
        println!("    4. 모든 팀원이 같은 환경\n");
    }
}

