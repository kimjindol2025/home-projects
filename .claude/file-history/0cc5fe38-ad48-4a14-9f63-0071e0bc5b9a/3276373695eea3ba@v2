/// [메모리 문제 방지 1] Double Free (이중 해제) 방지
///
/// 소유권 시스템이 없으면:
///   - 함수가 메모리 해제
///   - 호출자도 메모리 해제
///   - → 오류! (같은 메모리를 두 번 해제)
///
/// 러스트:
///   - 소유권이 함수로 이전됨
///   - 함수만 메모리 해제
///   - → 안전!
fn demonstrate_double_free_prevention() {
    println!("\n┌─────────────────────────────────────────────────┐");
    println!("│ [메모리 안전] Double Free 방지                  │");
    println!("└─────────────────────────────────────────────────┘\n");

    println!("❌ 다른 언어의 문제:");
    println!("   String s = \"data\";");
    println!("   function(s);  // 함수가 메모리 해제");
    println!("   s.use();      // 오류! 해제된 메모리 접근\n");

    println!("✅ 러스트의 해결:");
    println!("   let s = String::from(\"data\");");
    println!("   function(s);  // 소유권이 이전됨");
    println!("   // s 사용 불가 (컴파일 오류)");
    println!("   // → 메모리 안전 보장!\n");
}

/// [메모리 문제 방지 2] Use After Free 방지
///
/// 해제된 메모리를 사용하려는 시도를 컴파일 타임에 차단
fn demonstrate_use_after_free_prevention() {
    println!("\n┌─────────────────────────────────────────────────┐");
    println!("│ [메모리 안전] Use After Free 방지               │");
    println!("└─────────────────────────────────────────────────┘\n");

    println!("❌ 다른 언어의 문제:");
    println!("   String s = \"data\";");
    println!("   String s2 = s;   // s의 메모리를 s2로 복사");
    println!("   s.use();         // 오류! s는 이미 해제됨\n");

    println!("✅ 러스트의 해결:");
    println!("   let s = String::from(\"data\");");
    println!("   let s2 = s;      // s의 소유권이 s2로 이전");
    println!("   // s.use();      // 컴파일 오류! s는 더 이상 사용 불가");
    println!("   // → 런타임 오류 불가능!\n");
}

