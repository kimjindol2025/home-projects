// [v4.1 핵심 개념 1] Copy 타입 vs Move 타입
// ══════════════════════════════════════════════════════════════
//
// [Copy 타입] 스택에 저장되는 고정 크기 데이터
// - i32, u32, f64, bool 등
// - 함수로 넘길 때: 값 자체가 복사됨
// - 호출 후: 원본도 사용 가능
//
// [Move 타입] 힙에 저장되는 가변 크기 데이터
// - String, Vec, HashMap 등
// - 함수로 넘길 때: 소유권(메모리 책임)이 이전됨
// - 호출 후: 원본 사용 불가 (메모리 오류 방지)
//

// ══════════════════════════════════════════════════════════════
// [Section 1] Copy 타입: 자유로운 복사
// ══════════════════════════════════════════════════════════════

/// [Copy 타입 시연 1] 정수 타입 (i32)
///
/// 특징:
///   - 스택에 저장 (크기 고정: 4바이트)
///   - 함수 호출 시 값이 복사됨
///   - 호출 후에도 원본 사용 가능
fn demonstrate_copy_i32() {
    println!("\n┌─────────────────────────────────────────────────┐");
    println!("│ [Copy 타입] i32: 정수 값의 복사                 │");
    println!("└─────────────────────────────────────────────────┘\n");

    let x = 100;
    println!("📌 원본 x 생성: {}", x);

    process_copy_value(x);
    println!("📌 함수 호출 후 x 여전히 사용 가능: {}\n", x);

    let y = 42;
    let z = transfer_copy_value(y);
    println!("📌 함수에서 반환된 값: {}", z);
    println!("📌 원본 y도 여전히 사용 가능: {}\n", y);
}

fn process_copy_value(val: i32) {
    println!("  [함수 내부] val 받음: {}", val);
    println!("  [메모리] 스택에서 값을 읽음 (원본 영향 없음)");
}

fn transfer_copy_value(val: i32) -> i32 {
    println!("  [함수 내부] val 받음: {}", val);
    val * 2  // 복사된 값을 변환하여 반환
}

/// [Copy 타입 시연 2] 불리언 타입 (bool)
///
/// 특징:
///   - 스택에 저장 (크기 고정: 1바이트)
///   - 함수 호출 시 값이 복사됨
fn demonstrate_copy_bool() {
    println!("\n┌─────────────────────────────────────────────────┐");
    println!("│ [Copy 타입] bool: 불리언 값의 복사              │");
    println!("└─────────────────────────────────────────────────┘\n");

    let is_active = true;
    println!("📌 원본 is_active 생성: {}", is_active);

    check_status(is_active);
    println!("📌 함수 호출 후 is_active 여전히 사용 가능: {}\n", is_active);
}

fn check_status(status: bool) {
    if status {
        println!("  [함수 내부] 상태 활성 (복사된 값 사용)");
    }
}

/// [Copy 타입 시연 3] 튜플 (Copy 타입들의 조합)
///
/// 특징:
///   - 모든 원소가 Copy 타입이면, 튜플도 Copy
///   - (i32, i32, bool) → Copy
///   - (String, i32) → Move (String 때문에)
fn demonstrate_copy_tuple() {
    println!("\n┌─────────────────────────────────────────────────┐");
    println!("│ [Copy 타입] 튜플: Copy 타입들의 조합            │");
    println!("└─────────────────────────────────────────────────┘\n");

    let coordinates = (10, 20);
    println!("📌 좌표 (10, 20) 생성");

    process_coordinates(coordinates);
    println!("📌 함수 호출 후 coordinates 여전히 사용 가능: {:?}\n", coordinates);
}

fn process_coordinates((x, y): (i32, i32)) {
    println!("  [함수 내부] 좌표 수신: ({}, {})", x, y);
    println!("  [메모리] 스택에서 복사된 값 사용");
}

