// [Section 5] 스택 vs 힙: 메모리 구조의 이해
// ══════════════════════════════════════════════════════════════

fn explain_stack_vs_heap() {
    println!("\n┌─────────────────────────────────────────────────┐");
    println!("│ [메모리 구조] 스택 vs 힙                         │");
    println!("└─────────────────────────────────────────────────┘\n");

    println!("🏗️  스택 (Stack):");
    println!("   크기: 고정");
    println!("   속도: 매우 빠름 (포인터 증가만으로 할당)");
    println!("   해제: 자동 (블록 종료 시)");
    println!("   예: i32, bool, (i32, i32)");
    println!("   → Copy 타입\n");

    println!("📚 힙 (Heap):");
    println!("   크기: 동적");
    println!("   속도: 상대적으로 느림 (메모리 검색)");
    println!("   해제: 수동 (소유권 이동 시)");
    println!("   예: String, Vec, HashMap");
    println!("   → Move 타입\n");

    // 시각화
    println!("메모리 구조:");
    println!("  ┌──────────────┐");
    println!("  │    스택      │  [포인터] 0x1000 → String 데이터 위치");
    println!("  │              │  [데이터] 100 (i32)");
    println!("  └──────────────┘");
    println!("         ↓");
    println!("  ┌──────────────┐");
    println!("  │    힙        │  [String 데이터]");
    println!("  │              │  \"시스템 핵심 데이터\"");
    println!("  └──────────────┘\n");
}

