// ══════════════════════════════════════════════════════════════

/// [Move 타입 시연 1] String 타입
///
/// 특징:
///   - 힙에 저장되는 동적 크기 데이터
///   - 함수 호출 시 소유권이 이전됨
///   - 호출 후 원본 사용 불가
fn demonstrate_move_string() {
    println!("\n┌─────────────────────────────────────────────────┐");
    println!("│ [Move 타입] String: 소유권의 이전                │");
    println!("└─────────────────────────────────────────────────┘\n");

    let s = String::from("시스템 핵심 데이터");
    println!("📌 String 생성: '{}' (소유권: main)", s);
    println!("   메모리: 힙에 저장, 포인터는 스택에");

    take_ownership_string(s);
    println!("📌 함수에서 반환 (s의 메모리는 해제됨)\n");

    // 이 코드는 컴파일 오류:
    // println!("📌 s 사용 시도: {}", s);  // ❌ 오류: s의 소유권이 함수로 이동됨
}

fn take_ownership_string(data: String) {
    println!("  [함수 내부] String 수신: '{}' (소유권: 현재 함수)", data);
    println!("  [Memory] 함수 종료 시 '{}' 메모리 자동 해제", data);
}

/// [Move 타입 시연 2] Vec 타입
///
/// 특징:
///   - 동적 배열
///   - 힙에 저장
///   - 함수 호출 시 소유권 이전
fn demonstrate_move_vec() {
    println!("\n┌─────────────────────────────────────────────────┐");
    println!("│ [Move 타입] Vec<T>: 벡터의 소유권 이전          │");
    println!("└─────────────────────────────────────────────────┘\n");

    let mut numbers = vec![1, 2, 3, 4, 5];
    println!("📌 Vec 생성: {:?} (소유권: main)", numbers);
    println!("   크기: {} 원소", numbers.len());

    let sum = consume_and_sum(numbers);
    println!("📌 벡터의 소유권이 함수로 이전됨");
    println!("📌 계산 결과 반환: {}\n", sum);

    // 이 코드는 컴파일 오류:
    // println!("numbers 재사용: {:?}", numbers);  // ❌ 오류: 소유권 이전됨
}

fn consume_and_sum(vec: Vec<i32>) -> i32 {
    println!("  [함수 내부] Vec 수신: {:?} (소유권: 현재 함수)", vec);
    let sum: i32 = vec.iter().sum();
    println!("  [계산] 합계: {}", sum);
    sum  // 합계를 반환 (벡터는 함수 종료 시 해제)
}

/// [Move 타입 시연 3] 소유권 반환
///
/// 특징:
///   - 함수에서 새로운 데이터를 만들어 반환
///   - 호출자가 소유권을 받음
fn demonstrate_return_ownership() {
    println!("\n┌─────────────────────────────────────────────────┐");
    println!("│ [Move 타입] 소유권 반환: 데이터 생성 및 반환     │");
    println!("└─────────────────────────────────────────────────┘\n");

    println!("📌 함수 호출 전: 데이터 없음");

    let new_data = create_and_return_string();
    println!("📌 함수 호출 후: 새로운 String 소유권 받음");
    println!("📌 데이터: '{}' (소유권: main)\n", new_data);

    let new_vec = create_and_return_vec();
    println!("📌 새로운 Vec 소유권 받음: {:?}\n", new_vec);
}

fn create_and_return_string() -> String {
    let s = String::from("함수 내부에서 생성된 데이터");
    println!("  [함수 내부] String 생성: '{}'", s);
    s  // 소유권과 함께 반환
}

fn create_and_return_vec() -> Vec<i32> {
    let v = vec![10, 20, 30];
    println!("  [함수 내부] Vec 생성: {:?}", v);
    v  // 소유권과 함께 반환
}

