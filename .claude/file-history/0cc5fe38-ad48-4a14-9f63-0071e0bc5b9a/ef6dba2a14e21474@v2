// ============================================================================
// Section 5: Complex Recursive Patterns - 복잡한 재귀 패턴
// ============================================================================
/// 재귀 매크로의 고급 패턴들
/// - 중첩된 반복
/// - 트리 구조 생성
/// - 상태 누적

macro_rules! fold_left {
    // Base case: 단일 값
    ($init:expr; $op:tt; $x:expr) => {
        {
            let acc = $init;
            acc $op $x
        }
    };

    // Recursive case
    ($init:expr; $op:tt; $first:expr, $($rest:expr),+) => {
        fold_left!(
            ({ let acc = $init; acc $op $first });
            $op;
            $($rest),+
        )
    };
}

macro_rules! build_tree {
    // Leaf node
    ($val:expr) => {
        format!("[{}]", $val)
    };

    // Internal node: 자식 노드들을 재귀적으로 처리
    ($root:expr; $($child:expr),+) => {
        {
            let children = vec![$(build_tree!($child)),+];
            format!("({}: [{}])", $root, children.join(", "))
        }
    };
}

#[allow(unused_macros)]
macro_rules! accumulate {
    // 누적 결과 반환
    ($acc:expr) => {
        $acc
    };

    // 현재 값을 누적기에 추가
    ($acc:expr; $op:path; $first:expr, $($rest:expr),+) => {
        accumulate!(
            $op($acc, $first);
            $op;
            $($rest),+
        )
    };
}

fn section_5_complex_patterns() {
    println!("\n=== Section 5: Complex Recursive Patterns ===");

    // fold_left 예제
    let result = fold_left!(0; +; 1, 2, 3, 4, 5);
    println!("fold_left!(0; +; 1, 2, 3, 4, 5) = {}", result);

    // Tree building - use string literals
    let tree = build_tree!("Root"; "Leaf1", "Leaf2");
    println!("Tree structure: {}", tree);

    println!("✓ Section 5 완료: 복잡한 재귀 패턴");
}

// ============================================================================
// Section 6: Query DSL - 질의 언어 DSL
// ============================================================================
/// 데이터베이스 쿼리 같은 DSL 설계

macro_rules! query {
    // 진입점: SELECT ... FROM ... WHERE ...
    (SELECT $($col:ident),+ FROM $table:ident WHERE $cond:expr) => {
        {
            println!("Query:");
            println!("  SELECT: [{}]", vec![$(stringify!($col)),+].join(", "));
            println!("  FROM: {}", stringify!($table));
            println!("  WHERE: {}", stringify!($cond));
        }
    };
}

macro_rules! json_obj {
    // JSON 객체 생성 DSL
    ({$($key:ident: $val:expr),* $(,)?}) => {
        {
            println!("{{");
            $(
                println!("  {}: {:?},", stringify!($key), $val);
            )*
            println!("}}");
        }
    };
}

