// ============================================================================
// Section 11: Advanced DSL Examples - 고급 DSL 예제들
// ============================================================================
/// 실무에서 사용되는 고급 DSL 패턴들

macro_rules! html {
    // HTML 생성 DSL
    ($tag:ident [$($child:tt),*]) => {
        {
            println!("<{}>", stringify!($tag));
            $(html!(@child $child);)*
            println!("</{}>", stringify!($tag));
        }
    };

    (@child $text:expr) => {
        println!("  {}", $text);
    };
}

macro_rules! sql_select {
    // SQL 쿼리 빌더 DSL
    {
        select: [$($col:ident),+],
        from: $table:ident,
        where: $cond:expr
    } => {
        {
            let cols = vec![$(stringify!($col)),+];
            println!("SELECT {} FROM {} WHERE {}",
                     cols.join(", "),
                     stringify!($table),
                     stringify!($cond));
        }
    };
}

#[allow(unused_must_use)]
macro_rules! test_suite {
    // 테스트 스위트 DSL
    {$($test_name:ident { $($assertion:expr),* $(,)? }),* $(,)?} => {
        {
            println!("Running tests:");
            $(
                println!("  Test: {}", stringify!($test_name));
                $($assertion;)*
            )*
        }
    };
}

