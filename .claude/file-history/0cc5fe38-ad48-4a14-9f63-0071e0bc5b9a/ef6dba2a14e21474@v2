// ============================================================================
// Section 1: Recursive Macro Basics - 재귀 매크로의 기초
// ============================================================================
/// 재귀 매크로의 기본 구조: Base Case + Recursive Case
///
/// 재귀 매크로는 다음과 같이 동작한다:
/// 1. 입력을 받는다
/// 2. 첫 항목을 처리한다
/// 3. 남은 항목들을 자신에게 다시 전달한다 (재귀)
/// 4. 더 이상 처리할 항목이 없으면 종료한다

macro_rules! sum_recursive {
    // Base case: 단일 요소
    ($x:expr) => {
        $x
    };

    // Recursive case: 첫 요소 처리 + 나머지 재귀
    ($x:expr, $($rest:expr),+) => {
        $x + sum_recursive!($($rest),+)
    };
}

macro_rules! print_each {
    // Base case: 종료 조건
    () => {};

    // Recursive case: 첫 요소 출력 + 나머지 재귀
    ($first:expr) => {
        println!("{}", $first);
    };

    ($first:expr, $($rest:expr),+) => {
        println!("{}", $first);
        print_each!($($rest),+);
    };
}

fn section_1_recursive_basics() {
    println!("\n=== Section 1: Recursive Macro Basics ===");

    let result = sum_recursive!(1, 2, 3, 4, 5);
    println!("sum_recursive!(1, 2, 3, 4, 5) = {}", result);

    println!("\nPrinting each element:");
    print_each!("Hello", "Recursive", "Macros", "are", "powerful");

    println!("✓ Section 1 완료: 재귀 매크로 기초");
}

// ============================================================================
// Section 2: Incremental Parsing - 증분 파싱 패턴
// ============================================================================
/// 증분 파싱: 입력을 조각 내어 앞에서부터 처리하는 방식
///
/// 패턴: (@next $($rest:tt)*)
/// - 이 패턴은 "내부용 규칙"을 표시하는 관례이다
/// - 컴파일러 설계자들이 자주 사용하는 기법

macro_rules! collect_into_vec {
    // Public entry point
    ($($item:expr),*) => {
        collect_into_vec!(@next [] $($item),*)
    };

    // Internal recursive rule: 모든 항목을 처리할 때까지
    (@next [$($collected:tt)*]) => {
        vec![$($collected)*]
    };

    // Internal: 첫 항목 추출하고 나머지 재귀
    (@next [$($collected:tt)*] $first:expr) => {
        collect_into_vec!(@next [$($collected)* $first,])
    };

    (@next [$($collected:tt)*] $first:expr, $($rest:expr),+) => {
        collect_into_vec!(@next [$($collected)* $first,] $($rest),+)
    };
}

macro_rules! parse_pairs {
    // 공개 진입점: key => value 쌍 파싱
    ($($key:ident => $val:tt),*) => {
        parse_pairs!(@parse [] $($key => $val),*)
    };

    // 기저 사례: 모든 항목 처리 완료
    (@parse [$($collected:tt)*]) => {
        {
            vec![$($collected)*]
        }
    };

    // 재귀 사례: 첫 쌍 수집 + 나머지 재귀
    (@parse [$($collected:tt)*] $key:ident => $val:tt, $($rest:tt)*) => {
        parse_pairs!(@parse [$($collected)* (stringify!($key), stringify!($val)),] $($rest)*)
    };

    // 마지막 항목 (쉼표 없음)
    (@parse [$($collected:tt)*] $key:ident => $val:tt) => {
        parse_pairs!(@parse [$($collected)* (stringify!($key), stringify!($val))])
    };
}

fn section_2_incremental_parsing() {
    println!("\n=== Section 2: Incremental Parsing ===");

    let vec1 = collect_into_vec!(10, 20, 30, 40, 50);
    println!("collect_into_vec!(10, 20, 30, 40, 50) = {:?}", vec1);

    let pairs = parse_pairs!(
        name => Alice,
        age => 30,
        city => Seoul
    );
    println!("Parsed pairs: {:?}", pairs);

    println!("✓ Section 2 완료: 증분 파싱 패턴");
}

// ============================================================================
// Section 3: DSL Design Principles - DSL 설계 원칙
// ============================================================================
/// DSL (Domain Specific Language) = 특정 분야를 위한 언어
/// 매크로로 DSL을 만들면:
/// - 새로운 문법을 정의할 수 있다
/// - 도메인에 맞는 표현이 가능하다
/// - 컴파일 타임에 모든 검증이 된다

macro_rules! route {
    // 라우팅 시스템 DSL
    ($($method:ident $path:expr => $handler:ident),* $(,)?) => {
        {
            println!("=== Route Configuration ===");
            $(
                println!("[{}] {}: calls {}", stringify!($method), $path, stringify!($handler));
            )*
        }
    };
}

macro_rules! state_machine {
    // 상태 머신 DSL
    ($name:ident { $($state:ident -> [ $($next:ident),* ]),* $(,)? }) => {
        {
            println!("State machine '{}' defined:", stringify!($name));
            $(
                println!("  {} -> [{}]", stringify!($state),
                    vec![$(stringify!($next)),*].join(", "));
            )*
        }
    };
}

fn section_3_dsl_design() {
    println!("\n=== Section 3: DSL Design Principles ===");

    println!("\nRoute DSL Example:");
    route! {
        GET "/home" => handle_home,
        POST "/login" => handle_login,
        DELETE "/user/:id" => handle_delete
    }

    println!("\nState Machine DSL Example:");
