/// 재귀 매크로의 성능 특성
/// - 컴파일 타임 비용
/// - 런타임 비용 (0%)
/// - 확장 결과

macro_rules! perf_measure {
    ($label:expr, $code:block) => {
        {
            let start = std::time::Instant::now();
            let result = $code;
            let elapsed = start.elapsed();
            println!("[PERF] {}: {:?}", $label, elapsed);
            result
        }
    };
}

