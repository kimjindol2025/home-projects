}

// ============================================================================
// Section 4: gogs_config! Macro System - 핵심 예제
// ============================================================================
/// 컴파일러 설정 DSL
/// 커스텀 문법으로 컴파일러 옵션을 설정한다

macro_rules! gogs_config {
    // 공개 진입점
    ($($key:ident => $val:expr),* $(,)?) => {
        gogs_config!(@internal [] $($key => $val),*)
    };

    // 기저 사례: 모든 설정 처리 완료
    (@internal [$($config:tt)*]) => {
        {
            println!("╔════════════════════════════════════════╗");
            println!("║     GOGS Compiler Configuration       ║");
            println!("╚════════════════════════════════════════╝");
            $($config)*
            println!();
        }
    };

    // 재귀 사례: 첫 항목 처리 + 나머지 재귀
    (@internal [$($config:tt)*] $key:ident => $val:expr, $($rest:tt)*) => {
        gogs_config!(@internal [$($config)* println!("  ✓ {}: {:?}", stringify!($key), $val);] $($rest)*)
    };

    // 마지막 항목
    (@internal [$($config:tt)*] $key:ident => $val:expr) => {
        gogs_config!(@internal [$($config)* println!("  ✓ {}: {:?}", stringify!($key), $val);])
    };
}

/// 더 복잡한 설정 DSL: 중첩된 구조
#[allow(unused_macros)]
macro_rules! gogs_config_advanced {
    // 간단한 버전: 섹션별로 설정 출력
    (
        $(
            $section:ident {
                $($key:ident = $val:tt),*
                $(,)?
            }
        ),*
        $(,)?
    ) => {
        {
            println!("╔════════════════════════════════════════╗");
            println!("║     Advanced GOGS Configuration       ║");
            println!("╚════════════════════════════════════════╝");
            $(
                println!("[{}]", stringify!($section));
                $(
                    println!("  {} = {:?}", stringify!($key), stringify!($val));
                )*
            )*
            println!();
        }
    };
}

