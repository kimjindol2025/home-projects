// ==================== 엣지 케이스 테스트 9: 입력 검증 경계 ====================

#[test]
fn test_validate_input_boundaries() {
    // 입력 검증 함수의 경계값 테스트

    // 빈 문자열
    assert_eq!(validate_input("").unwrap(), false);

    // 7자 (최소값보다 1 작음)
    assert!(validate_input("1234567").is_err());

    // 정확히 8자 (최소값)
    assert!(validate_input("12345678").unwrap());

    // 9자 (최소값보다 1 많음)
    assert!(validate_input("123456789").unwrap());
}

// ==================== 엣지 케이스 테스트 10: 클론 독립성 ====================

#[test]
fn test_vault_clone_independence() {
    // 클론된 금고가 독립적인지 확인
    let original = GogsVault::new("ORIGINAL_KEY_123456789").unwrap();
    let cloned = original.clone();

    // 두 금고가 같은 키로 작동
    assert!(original.access("ORIGINAL_KEY_123456789").unwrap());
    assert!(cloned.access("ORIGINAL_KEY_123456789").unwrap());

    // 한 금고의 수정이 다른 금고에 영향을 주지 않음
    // (라이브러리가 immutable이므로 직접 수정은 불가능)
}

// ==================== 엣지 케이스 테스트 11: 에러 메시지 정확성 ====================

#[test]
fn test_error_message_accuracy() {
    // 에러 메시지가 정확한지 확인

    let error1 = GogsVault::new("SHORT").unwrap_err();
    match error1 {
        VaultError::InvalidKeyLength { expected, got } => {
            assert_eq!(expected, 16);
            assert_eq!(got, 5);
        }
        _ => panic!("Wrong error type"),
    }

    let vault = GogsVault::new("CORRECT_KEY_123456").unwrap();
    let error2 = vault.access("").unwrap_err();
    match error2 {
        VaultError::InvalidInput(msg) => {
            assert!(msg.contains("Empty"));
        }
        _ => panic!("Wrong error type"),
    }
}

