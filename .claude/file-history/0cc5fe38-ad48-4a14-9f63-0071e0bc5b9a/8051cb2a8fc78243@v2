// ==================== 엣지 케이스 테스트 1: 특수 문자 키 ====================

#[test]
fn test_vault_special_characters_in_key() {
    // 특수 문자를 포함한 키
    let special_key = "KEY!@#$%^&*()_+-=[]{}|;:',.<>?/`~";

    if special_key.len() >= 16 {
        let vault = GogsVault::new(special_key).unwrap();
        assert!(vault.access(special_key).unwrap());
    }
}

#[test]
fn test_vault_unicode_in_key() {
    // 유니코드 문자를 포함한 키
    let unicode_key = "키를_포함한_장_시크릿_키_123456";
    let vault = GogsVault::new(unicode_key).unwrap();
    assert!(vault.access(unicode_key).unwrap());
}

// ==================== 엣지 케이스 테스트 2: 공백 처리 ====================

#[test]
fn test_vault_whitespace_sensitivity() {
    // 공백이 중요한지 확인
    let key_with_space = "KEY WITH SPACES 123";
    let vault = GogsVault::new(key_with_space).unwrap();

    // 정확한 공백
    assert!(vault.access("KEY WITH SPACES 123").unwrap());

    // 공백이 빠진 경우
    assert!(!vault.access("KEYWITHSPACES 123").unwrap());
}

#[test]
fn test_vault_tab_newline_sensitivity() {
    // 탭과 개행 문자 처리
    let key_with_tab = "KEY\tWITH\tTAB\t123456";
    let vault = GogsVault::new(key_with_tab).unwrap();

    assert!(vault.access("KEY\tWITH\tTAB\t123456").unwrap());
    assert!(!vault.access("KEY WITH TAB 123456").unwrap());
}

// ==================== 엣지 케이스 테스트 3: 대소문자 민감도 ====================

#[test]
fn test_vault_case_sensitivity() {
    // 대소문자 구분 확인
    let lowercase_key = "lowercase_secret_key_123456";
    let vault = GogsVault::new(lowercase_key).unwrap();

    assert!(vault.access("lowercase_secret_key_123456").unwrap());
    assert!(!vault.access("LOWERCASE_SECRET_KEY_123456").unwrap());
    assert!(!vault.access("Lowercase_Secret_Key_123456").unwrap());
}

