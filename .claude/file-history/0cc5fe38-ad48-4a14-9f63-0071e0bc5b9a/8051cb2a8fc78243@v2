// ==================== 엣지 케이스 테스트 6: 부분 일치 거부 ====================

#[test]
fn test_vault_partial_match_rejection() {
    // 부분 일치하는 입력이 거부되는지 확인
    let full_key = "FULL_SECRET_KEY_123456789";
    let vault = GogsVault::new(full_key).unwrap();

    // 전체 키
    assert!(vault.access("FULL_SECRET_KEY_123456789").unwrap());

    // 부분 일치 (처음부터)
    assert!(!vault.access("FULL_SECRET_KEY_1234567").unwrap());

    // 부분 일치 (끝부터)
    assert!(!vault.access("SECRET_KEY_123456789").unwrap());

    // 부분 일치 (중간)
    assert!(!vault.access("SECRET_KEY").unwrap());
}

// ==================== 엣지 케이스 테스트 7: 비슷한 키 구분 ====================

#[test]
fn test_vault_similar_keys() {
    // 비슷하지만 다른 키들을 구분할 수 있는지 확인
    let vault1_key = "ALMOST_SAME_KEY_123456789";
    let vault1 = GogsVault::new(vault1_key).unwrap();

    let similar_keys = vec![
        "ALMOST_SAME_KEY_123456788", // 마지막 문자 다름
        "ALMOST_SAME_KEY_12345678", // 한 문자 빠짐
        "ALMOST_SAME_KEY_1234567890", // 한 문자 많음
        "ALMOST_SAME_KEY_234567890", // 첫 번째 숫자 다름
    ];

    for similar_key in similar_keys {
        assert!(!vault1.access(similar_key).unwrap(),
            "Vault should reject key: {}", similar_key);
    }
}

