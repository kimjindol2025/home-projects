// ==================== 엣지 케이스 테스트 15: 접근 거부 확실성 ====================

#[test]
fn test_access_denial_confidence() {
    // 비슷한 여러 시도에서 확실하게 거부되는지 확인
    let vault = GogsVault::new("DENIAL_TEST_KEY_123456789").unwrap();
    let correct_key = "DENIAL_TEST_KEY_123456789";

    let mut denial_count = 0;
    let attempts = vec![
        "DENIAL_TEST_KEY_123456788",
        "DENIAL_TEST_KEY_12345678",
        "DENIAL_TEST_KEY_1234567890",
        "DENIAL_TEST_KEY",
    ];

    for attempt in attempts {
        if !vault.access(attempt).unwrap() {
            denial_count += 1;
        }
    }

    assert_eq!(denial_count, 4);

    // 올바른 키는 여전히 작동
    assert!(vault.access(correct_key).unwrap());
}
