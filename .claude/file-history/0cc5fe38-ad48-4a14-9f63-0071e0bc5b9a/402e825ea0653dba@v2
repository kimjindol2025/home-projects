## 🚀 다음 단계

### Parking Lot 사용

```rust
use parking_lot::{Mutex, RwLock};

let mutex = Mutex::new(0);
let guard = mutex.lock();  // 더 빠름

let rwlock = RwLock::new(vec![]);
let read = rwlock.read();  // 병렬 읽기
let write = rwlock.write();  // 배타적 쓰기
```

### Condition Variables (신호)

```rust
use parking_lot::Condvar;

let (mutex, cvar) = (Mutex::new(false), Condvar::new());

// 대기
let guard = mutex.lock();
cvar.wait(&mut guard);

// 신호
*mutex.lock() = true;
cvar.notify_all();
```

