## 📦 Core Concepts

### 1. HashMap 생성 방법

```rust
use std::collections::HashMap;

// 방법 1: HashMap::new() - 빈 해시맵
let mut map: HashMap<String, i32> = HashMap::new();

// 방법 2: with_capacity() - 사전 할당 (성능↑)
let mut map: HashMap<String, i32> = HashMap::with_capacity(100);

// 방법 3: HashMap::from() - 초기값 지정
let map = HashMap::from([
    ("alice", 30),
    ("bob", 25),
]);

// 방법 4: collect() - 반복자에서
let map: HashMap<&str, i32> = vec![
    ("alice", 30),
    ("bob", 25),
]
.into_iter()
.collect();

// 타입 명시 필요!
let map: HashMap<String, String> = HashMap::new();
```

### 2. 소유권과 참조

```rust
// 패턴 1: 슬라이스로 여러 번 사용 (권장)
let host = "localhost";
let port = "3000";

let mut config = HashMap::new();
config.insert("host", host);
config.insert("port", port);

println!("host: {}", host);  // ✅ 여전히 사용 가능

// 패턴 2: String으로 한 번만 사용
let key = String::from("user");
let value = String::from("alice");

let mut data = HashMap::new();
data.insert(key, value);

// println!("key: {}", key);   // ❌ 오류! 소유권 이동

// 패턴 3: clone()으로 여러 번 사용
let key = String::from("username");
map.insert(key.clone(), "alice");
map.insert(key.clone(), "bob");   // 여러 번 사용 가능
map.insert(key, "charlie");       // 마지막은 이동

// 성능 비교:
// 슬라이스 > clone() > String 소유권 이동
```

### 3. 안전한 접근 (5가지)

```rust
let users = HashMap::from([("alice", 30), ("bob", 25)]);

// 방법 1: get() - 불변 참조
if let Some(&age) = users.get("alice") {
    println!("age: {}", age);  // 30
}

// 방법 2: contains_key() - 존재 확인
if users.contains_key("alice") {
    println!("alice exists");
}

// 방법 3: remove() - 제거
let mut map = HashMap::from([("temp", 1)]);
if let Some(val) = map.remove("temp") {
    println!("removed: {}", val);
}

// 방법 4: get_mut() - 가변 참조
let mut map = HashMap::from([("count", 1)]);
if let Some(count) = map.get_mut("count") {
    *count += 1;
}

// 방법 5: entry() - 조건부 처리
map.entry("count")
    .and_modify(|c| *c += 1)
    .or_insert(0);
```

### 4. entry() API - 복잡한 로직의 단순화

```rust
let mut counts: HashMap<&str, i32> = HashMap::new();

// 상황: 단어가 없으면 1, 있으면 +1

// ❌ 나쁤 방식 (이중 해싱)
if counts.contains_key("apple") {
    counts.insert("apple", counts["apple"] + 1);
} else {
    counts.insert("apple", 1);
}

// ✅ 좋은 방식 (entry)
counts
    .entry("apple")
    .and_modify(|count| *count += 1)
    .or_insert(1);

// entry의 메서드 조합:
// 1. and_modify + or_insert (가장 흔함)
map.entry(key)
    .and_modify(|v| *v += 1)
    .or_insert(0);

// 2. or_insert_with (계산된 값)
map.entry(key)
    .or_insert_with(|| expensive_function());

// 3. and_modify 만
map.entry(key)
    .and_modify(|v| *v = 100);

// 4. or_insert 만
map.entry(key)
    .or_insert(default);
```

