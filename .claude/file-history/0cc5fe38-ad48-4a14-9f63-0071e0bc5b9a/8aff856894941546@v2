//! 🔐 v8.2: 문서화 테스트와 주석 설계 (Documentation Tests & Comments)
//!
//! # 개요
//!
//! 이 라이브러리는 **문서 주석과 테스트가 동기화되는** 시스템을 보여줍니다.
//!
//! ## 주요 특징
//!
//! - **Doc Comments (///)**: 모든 공개 항목에 문서화
//! - **Doc Tests**: 주석 내 예제 코드가 `cargo test` 시 자동으로 검증됨
//! - **마크다운 지원**: 풍부한 형식의 문서
//! - **자가 검증**: 문서가 코드와 항상 동기화됨
//!
//! # 예제
//!
//! ```
//! use gogs_vault::SecureVault;
//!
//! let vault = SecureVault::new("SECURE_KEY_123456").unwrap();
//! assert!(vault.verify("SECURE_KEY_123456").unwrap());
//! ```

use std::fmt;
use std::error::Error as StdError;

// ==================== 공개 에러 타입 ====================

/// 금고 시스템의 모든 에러를 정의합니다.
///
/// # 변형
///
/// - `InvalidKeyLength`: 키가 최소 길이(16자)를 만족하지 않음
/// - `VerificationFailed`: 제공된 키가 일치하지 않음
/// - `InvalidInput`: 잘못된 형식의 입력
/// - `SystemError`: 시스템 수준의 에러
///
/// # 예제
///
/// ```
/// use gogs_vault::VaultError;
///
/// // 키 길이 에러 처리
/// match VaultError::InvalidKeyLength { expected: 16, got: 5 } {
///     VaultError::InvalidKeyLength { expected, got } => {
///         println!("Expected {}, got {}", expected, got);
///     }
///     _ => {}
/// }
/// ```
#[derive(Debug, Clone)]
pub enum VaultError {
    /// 입력된 키의 길이가 부족합니다.
    ///
    /// - `expected`: 필요한 최소 길이
    /// - `got`: 실제 입력된 길이
    InvalidKeyLength { expected: usize, got: usize },

    /// 제공된 입력이 저장된 키와 일치하지 않습니다.
    VerificationFailed,

    /// 입력 데이터의 형식이 잘못되었습니다.
    InvalidInput(String),

    /// 시스템 수준의 에러가 발생했습니다.
    SystemError(String),
}

impl fmt::Display for VaultError {
    fn fmt(&self, f: &mut fmt::Formatter) -> fmt::Result {
        match self {
            VaultError::InvalidKeyLength { expected, got } => {
                write!(f, "Invalid key length: expected {}, got {}", expected, got)
            }
            VaultError::VerificationFailed => write!(f, "Verification failed"),
            VaultError::InvalidInput(msg) => write!(f, "Invalid input: {}", msg),
            VaultError::SystemError(msg) => write!(f, "System error: {}", msg),
        }
    }
}

impl StdError for VaultError {}

/// 이 라이브러리에서 사용하는 표준 Result 타입입니다.
///
/// # 예제
///
/// ```
/// use gogs_vault::{SecureVault, VaultResult};
///
/// let result: VaultResult<SecureVault> = SecureVault::new("KEY_123456789");
/// assert!(result.is_ok());
/// ```
pub type VaultResult<T> = Result<T, VaultError>;

// ==================== 핵심 공개 구조체 ====================

/// 안전한 보안 금고를 관리합니다.
///
/// 이 구조체는 비공개 키를 저장하고, 공개 인터페이스를 통해서만 접근을 제어합니다.
///
/// # 필드
///
/// - `key`: 저장된 보안 키 (비공개)
///
/// # 예제
///
/// 기본 사용:
/// ```
/// use gogs_vault::SecureVault;
///
/// // 금고 생성
/// let vault = SecureVault::new("SUPER_SECRET_KEY_123456").unwrap();
///
/// // 올바른 키로 검증
/// assert!(vault.verify("SUPER_SECRET_KEY_123456").unwrap());
///
/// // 잘못된 키 거부
/// assert!(!vault.verify("WRONG_KEY_123456").unwrap());
/// ```
///
/// # Panics
///
/// 이 구조체의 메서드는 panic을 발생시키지 않습니다.
/// 모든 에러는 `Result` 타입으로 반환됩니다.
///
/// # Safety
///
/// 이 구조체는 메모리 안전성을 완전히 보장합니다.
/// 키는 private 필드에 저장되므로 직접 접근이 불가능합니다.
#[derive(Clone)]
pub struct SecureVault {
    key: String,
}

impl SecureVault {
    /// 새로운 보안 금고를 생성합니다.
    ///
    /// # 인자
    ///
    /// * `key` - 최소 16자 이상의 보안 키
    ///
    /// # 반환
    ///
    /// 성공하면 새로운 `SecureVault` 인스턴스, 실패하면 `VaultError`
    ///
    /// # Errors
    ///
    /// 다음과 같은 경우에 에러를 반환합니다:
    ///
    /// - 키의 길이가 16자 미만인 경우: `InvalidKeyLength`
    ///
    /// # Examples
    ///
    /// 정상적인 금고 생성:
    /// ```
    /// use gogs_vault::SecureVault;
    ///
    /// let vault = SecureVault::new("VERY_SECURE_KEY_123456");
    /// assert!(vault.is_ok());
    /// ```
    ///
    /// 너무 짧은 키:
    /// ```
    /// use gogs_vault::{SecureVault, VaultError};
    ///
    /// let result = SecureVault::new("SHORT");
    /// assert!(result.is_err());
    /// ```
    pub fn new(key: &str) -> VaultResult<Self> {
        const MIN_KEY_LENGTH: usize = 16;

        if key.len() < MIN_KEY_LENGTH {
            return Err(VaultError::InvalidKeyLength {
                expected: MIN_KEY_LENGTH,
                got: key.len(),
            });
        }

        Ok(SecureVault {
            key: key.to_string(),
        })
    }

    /// 제공된 입력이 올바른 키인지 검증합니다.
    ///
    /// # 인자
    ///
    /// * `input` - 검증할 입력값
    ///
    /// # 반환
    ///
    /// 키가 일치하면 `Ok(true)`, 불일치하면 `Ok(false)`, 에러는 `Err`
    ///
    /// # Errors
    ///
    /// 다음과 같은 경우에 에러를 반환합니다:
    ///
    /// - 입력이 빈 문자열인 경우: `InvalidInput`
    ///
    /// # Examples
    ///
    /// 올바른 키로 검증:
    /// ```
    /// use gogs_vault::SecureVault;
    ///
    /// let vault = SecureVault::new("CORRECT_KEY_123456789").unwrap();
    /// assert!(vault.verify("CORRECT_KEY_123456789").unwrap());
    /// ```
    ///
    /// 잘못된 키로 검증:
    /// ```
    /// use gogs_vault::SecureVault;
    ///
    /// let vault = SecureVault::new("CORRECT_KEY_123456789").unwrap();
    /// assert!(!vault.verify("WRONG_KEY_123456789").unwrap());
    /// ```
    ///
    /// 빈 입력 처리:
    /// ```
    /// use gogs_vault::{SecureVault, VaultError};
    ///
    /// let vault = SecureVault::new("CORRECT_KEY_123456789").unwrap();
    /// let result = vault.verify("");
    /// assert!(result.is_err());
    /// ```
    pub fn verify(&self, input: &str) -> VaultResult<bool> {
        if input.is_empty() {
            return Err(VaultError::InvalidInput("Empty input".to_string()));
        }

        Ok(self.key == input)
    }

    /// 금고의 정보를 반환합니다.
    ///
    /// # 반환
    ///
    /// 금고의 상태 정보 (키 자체는 노출하지 않음)
    ///
    /// # Examples
    ///
    /// ```
    /// use gogs_vault::SecureVault;
    ///
    /// let vault = SecureVault::new("INFO_TEST_KEY_123456").unwrap();
    /// let info = vault.get_info();
    /// assert_eq!(info.is_locked, true);
    /// ```
    pub fn get_info(&self) -> VaultInfo {
        VaultInfo {
            is_locked: true,
            key_length: self.key.len(),
        }
    }
}

impl fmt::Debug for SecureVault {
    fn fmt(&self, f: &mut fmt::Formatter) -> fmt::Result {
        f.debug_struct("SecureVault")
            .field("key_length", &self.key.len())
            .field("status", &"locked")
            .finish()
    }
}

// ==================== 보조 공개 타입 ====================

/// 금고의 상태 정보를 나타냅니다.
///
/// # 필드
///
/// - `is_locked`: 금고가 잠겨있는 상태
/// - `key_length`: 저장된 키의 길이
///
/// # Examples
///
/// ```
/// use gogs_vault::{SecureVault, VaultInfo};
///
/// let vault = SecureVault::new("VAULT_INFO_TEST_123456").unwrap();
/// let info = vault.get_info();
///
/// assert!(info.is_locked);
/// assert!(info.key_length >= 16);
/// ```
#[derive(Debug, Clone, PartialEq)]
pub struct VaultInfo {
    /// 금고의 잠금 상태
    pub is_locked: bool,
    /// 저장된 키의 길이
    pub key_length: usize,
}

/// 보안 이벤트를 기록합니다.
///
/// # 필드
///
/// - `event_type`: 이벤트의 유형
/// - `timestamp`: 이벤트 발생 시간
/// - `success`: 작업 성공 여부
///
/// # Examples
///
/// ```
/// use gogs_vault::SecurityEvent;
///
/// let event = SecurityEvent {
///     event_type: "user_login".to_string(),
///     timestamp: 1708610000,
///     success: true,
/// };
///
/// assert_eq!(event.event_type, "user_login");
/// assert!(event.success);
/// ```
#[derive(Debug, Clone, PartialEq)]
pub struct SecurityEvent {
    /// 이벤트의 타입
    pub event_type: String,
    /// 이벤트 발생 시각
    pub timestamp: u64,
    /// 작업의 성공 여부
    pub success: bool,
}

// ==================== 공개 유틸리티 함수 ====================

/// 입력 데이터의 유효성을 검증합니다.
///
/// # 인자
///
/// * `data` - 검증할 데이터
///
/// # 반환
///
/// 유효하면 `Ok(true)`, 유효하지 않으면 `Ok(false)`, 에러는 `Err`
///
/// # Errors
///
/// - 데이터가 8자 미만인 경우: `InvalidInput`
///
/// # Examples
///
/// 유효한 입력:
/// ```
/// use gogs_vault::validate_data;
///
/// assert!(validate_data("VALID_DATA_12345").unwrap());
/// ```
///
/// 빈 입력:
/// ```
/// use gogs_vault::validate_data;
///
/// assert_eq!(validate_data("").unwrap(), false);
/// ```
///
/// 너무 짧은 입력:
/// ```
/// use gogs_vault::{validate_data, VaultError};
///
/// let result = validate_data("SHORT");
/// assert!(result.is_err());
/// ```
pub fn validate_data(data: &str) -> VaultResult<bool> {
    if data.is_empty() {
        return Ok(false);
    }

    if data.len() < 8 {
        return Err(VaultError::InvalidInput("Data too short".to_string()));
    }

    Ok(true)
}

/// 보안 이벤트를 생성합니다.
///
/// # 인자
///
/// * `event_type` - 이벤트의 타입
/// * `success` - 작업의 성공 여부
///
/// # 반환
///
/// 생성된 `SecurityEvent`
///
/// # Examples
///
/// 성공 이벤트 생성:
/// ```
/// use gogs_vault::create_security_event;
///
/// let event = create_security_event("login", true);
/// assert_eq!(event.event_type, "login");
/// assert!(event.success);
/// ```
///
/// 실패 이벤트 생성:
/// ```
/// use gogs_vault::create_security_event;
///
/// let event = create_security_event("failed_login", false);
/// assert!(!event.success);
/// ```
pub fn create_security_event(event_type: &str, success: bool) -> SecurityEvent {
    SecurityEvent {
        event_type: event_type.to_string(),
        timestamp: 1708610000u64,
        success,
    }
}

