pub use function::GogsFunction;
pub use closure::ClosureEnvironment;
pub use environment::Environment;
pub use scope_chain::ScopeChain;

/// 함수 호출 시뮬레이션
pub fn call_function(
    func: &GogsFunction,
    args: Vec<i64>,
) -> Result<i64, String> {
    // 1. 함수 정의 시점의 환경을 부모로 하는 새 환경 생성
    let mut local_env = Environment::extend(&func.closure_env);

    // 2. 매개변수 바인딩
    for (param, arg) in func.parameters.iter().zip(args.iter()) {
        local_env.set(param.clone(), *arg);
    }

    // 3. 함수 본체 평가 (간단한 예: 바로 결과 계산)
    func.evaluate(&local_env)
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_function_creation() {
        let func = GogsFunction::new(
            vec!["x".to_string()],
            Box::new(|env, _| {
                env.get("x").ok_or_else(|| "x not found".to_string())
            }),
        );
        assert_eq!(func.parameters.len(), 1);
    }

    #[test]
    fn test_environment_extension() {
        let mut parent = Environment::global();
        parent.set("x".to_string(), 10);

        let _child = Environment::extend(&parent);
        // child는 x를 조회할 때 parent에서 찾을 수 있어야 함
    }

    #[test]
    fn test_closure_capture() {
        let func = GogsFunction::new(
            vec!["y".to_string()],
            Box::new(|env, _| {
                // 클로저: x를 외부 환경에서, y를 지역 환경에서 찾음
                let x = env.get("x").unwrap_or(0);
                let y = env.get("y").unwrap_or(0);
                Ok(x + y)
            }),
        );

        let mut closure_env = Environment::global();
        closure_env.set("x".to_string(), 5);

        assert!(func.evaluate(&closure_env).is_ok());
    }
}
