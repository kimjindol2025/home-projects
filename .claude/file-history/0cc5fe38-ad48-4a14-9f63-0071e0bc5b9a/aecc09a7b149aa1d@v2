// 섹션 8: 성능 비교 (Static vs Dynamic)
// ============================================================================
fn section_8_performance_comparison() {
    println!("\n📌 섹션 8: 성능 비교 (Static vs Dynamic)");
    println!("────────────────────────────────────────");

    trait Processor {
        fn process(&self, x: i32) -> i32;
    }

    struct StaticProc;
    impl Processor for StaticProc {
        fn process(&self, x: i32) -> i32 {
            x * 2
        }
    }

    struct DynamicProc;
    impl Processor for DynamicProc {
        fn process(&self, x: i32) -> i32 {
            x * 2
        }
    }

    let iterations = 10_000_000;

    fn static_process(proc: &StaticProc, x: i32) -> i32 {
        proc.process(x)
    }

    fn dynamic_process(proc: &dyn Processor, x: i32) -> i32 {
        proc.process(x)
    }

    // 정적 디스패치
    let start = Instant::now();
    let proc = StaticProc;
    for i in 0..iterations {
        let _ = static_process(&proc, i);
    }
    let static_time = start.elapsed();

    // 동적 디스패치
    let start = Instant::now();
    let proc: Box<dyn Processor> = Box::new(DynamicProc);
    for i in 0..iterations {
        let _ = dynamic_process(proc.as_ref(), i);
    }
    let dynamic_time = start.elapsed();

    println!("  성능 측정 ({} 반복):", iterations);
    println!("    정적 디스패치:  {:.2}ms", static_time.as_secs_f64() * 1000.0);
    println!("    동적 디스패치:  {:.2}ms", dynamic_time.as_secs_f64() * 1000.0);
    println!("    오버헤드:       {:.1}%",
        (dynamic_time.as_secs_f64() - static_time.as_secs_f64()) / static_time.as_secs_f64() * 100.0);

    println!("\n  💡 결론:");
    println!("    현대 CPU는 최적화로 차이를 거의 없앰");
    println!("    차이가 있어도 수나노초 단위");
    println!("    유연성 > 미미한 성능 차이");
}

