// 섹션 7: Object Safety (객체 안전성) 제약
// ============================================================================
fn section_7_object_safety() {
    println!("\n📌 섹션 7: Object Safety (객체 안전성)");
    println!("────────────────────────────────────────");

    // ✅ Object-safe 트레이트
    trait SafeTrait {
        fn method(&self) -> String;
    }

    struct ConcreteA;
    impl SafeTrait for ConcreteA {
        fn method(&self) -> String {
            "A".to_string()
        }
    }

    let obj: Box<dyn SafeTrait> = Box::new(ConcreteA);
    println!("  ✅ Object-safe: {}", obj.method());

    println!("\n  🔍 Object Safety 규칙:");
    println!("    ✅ 가능한 경우:");
    println!("      - 일반 메서드 (self 인자)");
    println!("      - 리턴값이 구체적 타입");
    println!("      - 제네릭 매개변수 없음");

    println!("\n    ❌ 불가능한 경우:");
    println!("      trait Bad {{");
    println!("        fn returns_self(self) -> Self;  // ❌ Self 반환");
    println!("        fn generic<T>(&self, t: T);     // ❌ 제네릭 매개변수");
    println!("        fn clone_me(&self) -> Self;      // ❌ Self 반환");
    println!("      }}");

    println!("\n  💡 왜 Self를 반환할 수 없는가?");
    println!("    dyn Trait는 런타임에만 구체적 타입을 알게 됨");
    println!("    Self 타입은 컴파일 타임에 결정되어야 함");
    println!("    → 충돌! → dyn으로 만들 수 없음");

    println!("\n  💡 해결책:");
    println!("    trait Cloneable {{");
    println!("      fn clone_box(&self) -> Box<dyn Cloneable>;");
    println!("    }}");
    println!("    (Self 대신 Box<dyn Trait> 반환)");
}

