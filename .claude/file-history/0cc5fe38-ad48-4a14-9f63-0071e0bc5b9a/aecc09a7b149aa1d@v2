// 섹션 5: vtable 동작 원리
// ============================================================================
fn section_5_vtable_mechanism() {
    println!("\n📌 섹션 5: vtable 동작 원리");
    println!("────────────────────────────────────────");

    trait Component {
        fn name(&self) -> &str;
        fn update(&mut self);
    }

    struct Button {
        name: String,
    }
    impl Component for Button {
        fn name(&self) -> &str {
            &self.name
        }
        fn update(&mut self) {
            println!("    [Button] 클릭 감지");
        }
    }

    struct TextBox {
        name: String,
    }
    impl Component for TextBox {
        fn name(&self) -> &str {
            &self.name
        }
        fn update(&mut self) {
            println!("    [TextBox] 입력 감지");
        }
    }

    let mut button: Box<dyn Component> = Box::new(Button {
        name: "Ok".to_string(),
    });
    let mut textbox: Box<dyn Component> = Box::new(TextBox {
        name: "InputField".to_string(),
    });

    println!("  런타임 메서드 호출:");
    println!("    button.update():");
    button.update();

    println!("\n    textbox.update():");
    textbox.update();

    println!("\n  🔍 vtable 호출 과정:");
    println!("    1. box의 vtable 포인터 읽음");
    println!("    2. vtable에서 update() 함수 주소 찾음");
    println!("    3. 해당 함수 호출 (Button::update or TextBox::update)");
    println!("    4. Box의 데이터 포인터를 self로 전달");

    println!("\n  💡 각 타입의 vtable:");
    println!("    Button의 vtable:");
    println!("      - name() → Button::name");
    println!("      - update() → Button::update");
    println!("      - drop() → Button::drop");
    println!("\n    TextBox의 vtable:");
    println!("      - name() → TextBox::name");
    println!("      - update() → TextBox::update");
    println!("      - drop() → TextBox::drop");
}

