// 섹션 6: 트레이트 객체 컬렉션
// ============================================================================
fn section_6_trait_object_collections() {
    println!("\n📌 섹션 6: 트레이트 객체 컬렉션");
    println!("────────────────────────────────────────");

    trait SecurityLog {
        fn severity(&self) -> u8;
        fn message(&self) -> String;
    }

    struct NetworkLog {
        ip: String,
        attack: String,
    }
    impl SecurityLog for NetworkLog {
        fn severity(&self) -> u8 {
            5
        }
        fn message(&self) -> String {
            format!("침입: {} ({})", self.attack, self.ip)
        }
    }

    struct AuthLog {
        user: String,
        action: String,
    }
    impl SecurityLog for AuthLog {
        fn severity(&self) -> u8 {
            3
        }
        fn message(&self) -> String {
            format!("권한: {} by {}", self.action, self.user)
        }
    }

    // 핵심: 서로 다른 타입을 하나의 Vec에 담음!
    let logs: Vec<Box<dyn SecurityLog>> = vec![
        Box::new(NetworkLog {
            ip: "192.168.1.1".into(),
            attack: "DDoS".into(),
        }),
        Box::new(AuthLog {
            user: "admin".into(),
            action: "sudo".into(),
        }),
        Box::new(NetworkLog {
            ip: "10.0.0.1".into(),
            attack: "SQL Injection".into(),
        }),
    ];

    println!("  보안 로그 처리:");
    for log in &logs {
        println!("    [Level {}] {}", log.severity(), log.message());
    }

    println!("\n  🔍 컬렉션의 강력함:");
    println!("    ✅ 서로 다른 타입을 같은 Vec에 저장");
    println!("    ✅ 각 요소마다 올바른 메서드 호출");
    println!("    ✅ 런타임에 타입 결정");
    println!("    ✅ 코드 간결함");

    println!("\n  💡 불가능한 방식:");
    println!("    let logs: Vec<SecurityLog> = vec![...];  // ❌ 컴파일 에러");
    println!("    (SecurityLog는 Sized 트레이트 미구현)");
}

