// 섹션 10: 실전 다형성 컬렉션
// ============================================================================
fn section_10_practical_polymorphism() {
    println!("\n📌 섹션 10: 실전 다형성 컬렉션");
    println!("────────────────────────────────────────");

    trait DataStore {
        fn save(&self, key: &str, value: &str);
        fn load(&self, key: &str) -> Option<String>;
    }

    struct MemoryStore {
        data: std::collections::HashMap<String, String>,
    }
    impl MemoryStore {
        fn new() -> Self {
            Self {
                data: std::collections::HashMap::new(),
            }
        }
    }
    impl DataStore for MemoryStore {
        fn save(&self, key: &str, value: &str) {
            println!("    [Memory] {} = {}", key, value);
        }
        fn load(&self, key: &str) -> Option<String> {
            println!("    [Memory] {} 로드", key);
            None
        }
    }

    struct FileStore {
        name: String,
    }
    impl DataStore for FileStore {
        fn save(&self, key: &str, value: &str) {
            println!("    [File({})] {} = {}", self.name, key, value);
        }
        fn load(&self, key: &str) -> Option<String> {
            println!("    [File({})] {} 로드", self.name, key);
            None
        }
    }

    // 런타임에 선택된 저장소 사용
    let stores: Vec<Box<dyn DataStore>> = vec![
        Box::new(MemoryStore::new()),
        Box::new(FileStore {
            name: "data.db".to_string(),
        }),
    ];

    println!("  데이터 저장:");
    for (i, store) in stores.iter().enumerate() {
        println!("  Store {}:", i + 1);
        store.save("user_id", "12345");
        store.load("user_id");
    }

    println!("\n  💡 다형성의 이점:");
    println!("    ✅ 저장 방식을 추상화");
    println!("    ✅ 코드가 저장 방식에 의존하지 않음");
    println!("    ✅ 새 저장소 추가 용이");
}

// ============================================================================
// 섹션 11: Any Trait로 타입 캐스팅
// ============================================================================
fn section_11_any_trait_casting() {
    println!("\n📌 섹션 11: Any Trait로 타입 캐스팅");
    println!("────────────────────────────────────────");

    trait Data: Any {
        fn describe(&self) -> String;
    }

    impl Data for String {
        fn describe(&self) -> String {
            format!("String: {}", self)
        }
    }

    impl Data for i32 {
        fn describe(&self) -> String {
            format!("i32: {}", self)
        }
    }

    let data_objs: Vec<Box<dyn Data>> = vec![
        Box::new("Hello".to_string()),
        Box::new(42i32),
        Box::new("World".to_string()),
    ];

    println!("  타입 캐스팅:");
    for obj in data_objs {
        println!("    {}", obj.describe());

        // downcast_ref로 원래 타입 복원
        if let Some(s) = (obj.as_ref() as &dyn Any).downcast_ref::<String>() {
            println!("      → 문자열 길이: {}", s.len());
        } else if let Some(n) = (obj.as_ref() as &dyn Any).downcast_ref::<i32>() {
            println!("      → 정수값: {}", n * 2);
        }
    }

    println!("\n  🔍 Any Trait의 용도:");
    println!("    ✅ 런타임 타입 검사 (type_id)");
    println!("    ✅ 안전한 타입 캐스팅 (downcast)");
    println!("    ✅ 동적 타입 언어처럼 사용");

    println!("\n  💡 사용 시 주의:");
    println!("    ⚠️ downcast 실패 가능성 존재");
    println!("    ⚠️ 런타임 오버헤드 증가");
    println!("    ⚠️ 타입 안전성 감소");
}

