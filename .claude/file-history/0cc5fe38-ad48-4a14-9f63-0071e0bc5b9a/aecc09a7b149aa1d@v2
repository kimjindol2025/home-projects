fn section_12_designer_perspective() {
    println!("\n📌 섹션 12: 설계자의 관점");
    println!("────────────────────────────────────────");

    println!("\n  🎯 관점 1: \"언제 dyn을 써야 하는가?\"");
    println!("    정적 디스패치 (제네릭):");
    println!("      → 성능이 극도로 중요할 때");
    println!("      → 호출 시점에 타입을 이미 알 때");
    println!("      → 바이너리 크기가 중요하지 않을 때");

    println!("\n    동적 디스패치 (dyn Trait):");
    println!("      → 플러그인처럼 타입이 불명확할 때");
    println!("      → 컬렉션에 여러 타입을 섞어 담을 때");
    println!("      → 유연성이 성능보다 중요할 때");

    println!("\n  🎯 관점 2: \"Fat Pointer의 의미\"");
    println!("    (데이터 포인터, vtable 포인터)");
    println!("      - 데이터: 실제 객체가 있는 메모리");
    println!("      - vtable: 메서드 구현 정보");
    println!("      → 런타임에 메서드 선택 가능");

    println!("\n  🎯 관점 3: \"Object Safety의 제약\"");
    println!("    Self 반환 불가:");
    println!("      fn clone(&self) -> Self;  // ❌ Self의 크기가 불명확");
    println!("    해결책:");
    println!("      fn clone_box(&self) -> Box<dyn Trait>;  // ✅");

    println!("\n  🎯 관점 4: \"성능 고려\"");
    println!("    정적: ~100% 성능");
    println!("    동적: ~99-99.9% 성능 (대부분의 경우)");
    println!("    → 유연성이 미미한 성능 차이보다 가치있음");

    println!("\n  🎯 관점 5: \"설계 선택\"");
    println!("    기본: 제네릭 사용");
    println!("    필요하면: dyn Trait으로 변경");
    println!("    → \"조기 최적화는 악\"");

    println!("\n  💡 황금 규칙:");
    println!("    1. 먼저 제네릭으로 명확히 쓴다");
    println!("    2. 런타임 유연성이 필요하면 dyn으로 변경");
    println!("    3. 성능 문제는 프로파일링 후 최적화");
    println!("    4. 99%는 성능 문제가 아닌 설계 문제");

    println!("\n  ⚡ 최종 통찰:");
    println!("    트레이트 객체 = Rust의 다형성");
    println!("    정적/동적 선택 = 설계의 자유도");
    println!("    Object Safety = 안전성의 대가");
}
