// 섹션 4: Fat Pointer 구조 이해
// ============================================================================
fn section_4_fat_pointer_structure() {
    println!("\n📌 섹션 4: Fat Pointer 구조");
    println!("────────────────────────────────────────");

    trait Shape {
        fn area(&self) -> f64;
    }

    struct Circle {
        radius: f64,
    }
    impl Shape for Circle {
        fn area(&self) -> f64 {
            3.14 * self.radius * self.radius
        }
    }

    struct Square {
        side: f64,
    }
    impl Shape for Square {
        fn area(&self) -> f64 {
            self.side * self.side
        }
    }

    let circle = Circle { radius: 5.0 };

    println!("  포인터 크기 분석:");
    println!("    원본 포인터 (&T): {} bytes", std::mem::size_of::<&Circle>());
    println!("    트레이트 객체 참조 (&dyn Trait): {} bytes", std::mem::size_of::<&dyn Shape>());

    let shape_ref: &dyn Shape = &circle;
    println!("\n  🔍 Fat Pointer 구조:");
    println!("    &dyn Shape = (데이터 포인터, vtable 포인터)");
    println!("    각 포인터: {} bytes", std::mem::size_of::<*const ()>());
    println!("    합계: {} bytes", std::mem::size_of::<*const ()>() * 2);

    println!("\n  💡 Fat Pointer가 가리키는 것:");
    println!("    [데이터 포인터] → Circle {{ radius: 5.0 }}");
    println!("    [vtable 포인터] → Circle의 Shape 구현");
    println!("      - area() 함수 주소");
    println!("      - drop() 함수 주소");
    println!("      - 타입 메타데이터");

    println!("  ✅ Circle.area() = {}", shape_ref.area());
    println!("  ✅ Square도 같은 방식으로 처리 가능");
}

