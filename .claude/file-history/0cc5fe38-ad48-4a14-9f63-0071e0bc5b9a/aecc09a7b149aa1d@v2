// 섹션 3: Box<dyn Trait> (힙 할당)
// ============================================================================
fn section_3_boxed_trait_objects() {
    println!("\n📌 섹션 3: Box<dyn Trait> (힙 할당 트레이트 객체)");
    println!("────────────────────────────────────────");

    trait Logger {
        fn log(&self, msg: &str);
    }

    struct FileLogger;
    impl Logger for FileLogger {
        fn log(&self, msg: &str) {
            println!("  [File] {}", msg);
        }
    }

    struct ConsoleLogger;
    impl Logger for ConsoleLogger {
        fn log(&self, msg: &str) {
            println!("  [Console] {}", msg);
        }
    }

    // Box<dyn Trait>: 힙에 할당된 트레이트 객체
    let logger1: Box<dyn Logger> = Box::new(FileLogger);
    let logger2: Box<dyn Logger> = Box::new(ConsoleLogger);

    logger1.log("파일에 기록");
    logger2.log("콘솔에 기록");

    println!("\n  🔍 Box<dyn Trait>의 특징:");
    println!("    ✅ 힙에 할당되어 크기 가변");
    println!("    ✅ Vec에 담을 수 있음");
    println!("    ✅ 유연한 구조");
    println!("    ❌ 포인터 간접 참조 비용");

    println!("\n  💡 메모리 구조:");
    println!("    Box<dyn Trait> = (데이터 포인터, vtable 포인터)");
}

