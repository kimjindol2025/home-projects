// 섹션 1: 정적 디스패치 (Static Dispatch with Generics)
// ============================================================================
fn section_1_static_dispatch() {
    println!("\n📌 섹션 1: 정적 디스패치 (Static Dispatch)");
    println!("────────────────────────────────────────");

    trait Animal {
        fn speak(&self) -> String;
    }

    struct Dog;
    impl Animal for Dog {
        fn speak(&self) -> String {
            "멍멍!".to_string()
        }
    }

    struct Cat;
    impl Animal for Cat {
        fn speak(&self) -> String {
            "야옹!".to_string()
        }
    }

    // 제네릭: 컴파일 타임에 각 타입 버전이 생성됨
    fn make_sound<A: Animal>(animal: &A) -> String {
        animal.speak()
    }

    let dog = Dog;
    let cat = Cat;

    println!("  Dog: {}", make_sound(&dog));
    println!("  Cat: {}", make_sound(&cat));

    println!("\n  🔍 정적 디스패치의 특징:");
    println!("    ✅ 빠름 (인라인 최적화 가능)");
    println!("    ✅ 타입 안전 (컴파일 타임 검사)");
    println!("    ❌ 바이너리 크기 증가 (각 타입마다 복사)");
    println!("    ❌ 런타임에 타입 결정 불가능");

    println!("\n  💡 컴파일러가 생성하는 코드:");
    println!("    make_sound::<Dog>(&dog) → println!(\"멍멍!\")");
    println!("    make_sound::<Cat>(&cat) → println!(\"야옹!\")");
}

// ============================================================================
// 섹션 2: 동적 디스패치 - 참조 (&dyn Trait)
// ============================================================================
fn section_2_dynamic_dispatch_reference() {
    println!("\n📌 섹션 2: 동적 디스패치 - 참조 (&dyn Trait)");
    println!("────────────────────────────────────────");

    trait Instrument {
        fn play(&self) -> String;
    }

    struct Guitar;
    impl Instrument for Guitar {
        fn play(&self) -> String {
            "기타 소리: 딩딩딩".to_string()
        }
    }

    struct Piano;
    impl Instrument for Piano {
        fn play(&self) -> String {
            "피아노 소리: 땡땡땡".to_string()
        }
    }

    // 동적 디스패치: 런타임에 메서드 선택
    fn perform(instrument: &dyn Instrument) {
        println!("  {}", instrument.play());
    }

    let guitar = Guitar;
    let piano = Piano;

    perform(&guitar);
    perform(&piano);

    println!("\n  🔍 동적 디스패치의 특징:");
    println!("    ✅ 런타임에 타입 결정 가능");
    println!("    ✅ 바이너리 크기 작음");
    println!("    ❌ 약간 느림 (vtable 간접 호출)");
    println!("    ⚠️ 타입 정보 런타임에 유지");

    println!("\n  💡 런타임에 vtable 조회:");
    println!("    &dyn Instrument → vtable 조회 → play() 호출");
}

