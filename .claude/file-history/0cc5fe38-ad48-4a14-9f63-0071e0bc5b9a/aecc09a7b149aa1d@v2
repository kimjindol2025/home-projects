fn section_9_plugin_architecture() {
    println!("\n📌 섹션 9: 플러그인 아키텍처 패턴");
    println!("────────────────────────────────────────");

    trait Plugin {
        fn name(&self) -> &str;
        fn execute(&self) -> String;
    }

    struct ImagePlugin;
    impl Plugin for ImagePlugin {
        fn name(&self) -> &str {
            "ImageProcessor"
        }
        fn execute(&self) -> String {
            "이미지 처리 완료".to_string()
        }
    }

    struct AudioPlugin;
    impl Plugin for AudioPlugin {
        fn name(&self) -> &str {
            "AudioProcessor"
        }
        fn execute(&self) -> String {
            "음성 처리 완료".to_string()
        }
    }

    // 플러그인 시스템
    let plugins: Vec<Box<dyn Plugin>> = vec![
        Box::new(ImagePlugin),
        Box::new(AudioPlugin),
        Box::new(ImagePlugin),
    ];

    println!("  플러그인 로드 및 실행:");
    for plugin in &plugins {
        println!("    [{}] {}", plugin.name(), plugin.execute());
    }

    println!("\n  🔍 플러그인 패턴의 강점:");
    println!("    ✅ 런타임에 플러그인 추가 가능");
    println!("    ✅ 기존 코드 수정 없음");
    println!("    ✅ 각 플러그인은 독립적");
    println!("    ✅ 확장 가능한 아키텍처");
}

