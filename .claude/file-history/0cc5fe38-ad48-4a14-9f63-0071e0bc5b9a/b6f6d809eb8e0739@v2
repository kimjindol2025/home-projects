mod core;

fn main() {
    let mut step_count: i32 = 0;

    // Gogs 저장소의 첫 번째 가동 로그
    println!("--- Gogs Project: Level 1-2 Startup ---");
    println!("📂 Rust Language Development - Phase 1 시작\n");

    let final_status = loop {
        step_count += 1;

        // match를 통한 정교한 상태 분기
        match step_count {
            1 => {
                println!("✓ Step {}: 모듈 로드 완료", step_count);
            }
            2 => {
                println!("✓ Step {}: 메인 함수 초기화", step_count);
            }
            3 => {
                println!("✓ Step {}: core.rs 함수 호출 준비", step_count);
            }
            4 => {
                println!("✓ Step {}: 7의 배수 추출 중...\n", step_count);

                // core.rs의 함수 호출
                let (multiples, sum) = core::extract_multiples_of_seven();

                // 통계 출력
                core::print_statistics(&multiples, sum);

                println!("\n📊 분석 완료:");
                println!("  - 총 추출된 배수: {}", multiples.len());
                println!("  - 합계: {}", sum);
            }
            5 => {
                println!("\n✓ Step {}: 검증 완료", step_count);
            }
            6 => {
                println!("✓ Step {}: 결과 저장 준비", step_count);
            }
            10 => {
                println!("\n🎉 Step {}: 목표 달성 - 10단계 완료", step_count);
                println!("최종 상태: SUCCESS");
                break "SUCCESS"; // 루프 탈출 및 결과 반환
            }
            _ => {
                // 아무것도 하지 않음 (Placeholder)
            }
        }

        if step_count > 100 {
            break "ERROR"; // 안전 장치
        }
    };

    println!("\n최종 빌드 상태: {}", final_status);
    println!("\n--- Gogs Project: 첫 번째 커밋 준비 완료 ---");
}
