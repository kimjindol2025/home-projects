### 기법 4: FFI (Foreign Function Interface)

```rust
extern "C" {
    fn strlen(s: *const u8) -> usize;   // C 함수 선언
    fn malloc(size: usize) -> *mut u8;  // C 할당
}

#[repr(C)]
struct CCompatible {
    x: i32,
    y: i32,                             // C와 동일한 메모리 레이아웃
}
```

### 기법 5: 메모리 레이아웃 계산

```rust
use std::mem;

// [크기와 정렬]
mem::size_of::<i32>()                  // 4 bytes
mem::align_of::<i32>()                 // 4 bytes

// [오프셋 계산]
let base = &x as *const X as usize;
let field_addr = unsafe { std::ptr::addr_of!(x.field) } as usize;
let offset = field_addr - base;        // 바이트 오프셋

// [패딩 이해]
#[repr(C)]
struct Padded {
    a: u8,      // 0 바이트
    // padding: 3 바이트 (정렬을 위해)
    b: u32,     // 4 바이트
}
// 크기: 8 바이트 (보이는 데이터 5 + 보이지 않는 패딩 3)
```

