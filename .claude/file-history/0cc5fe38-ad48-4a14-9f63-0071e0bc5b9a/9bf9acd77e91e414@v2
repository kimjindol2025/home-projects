## Undefined Behavior 가이드

### ❌ 절대 하면 안 될 것

```rust
// 1. Null 포인터 역참조
let null = std::ptr::null::<i32>();
unsafe { *null; }  // ← UB! Segmentation Fault

// 2. Dangling 포인터
let dangling = {
    let local = 42;
    &local as *const i32
};
unsafe { *dangling; }  // ← UB! 스택 해제 후 접근

// 3. 초기화되지 않은 메모리
let uninit: i32 = unsafe { std::mem::uninitialized() };
println!("{}", uninit);  // ← UB! 값이 정의되지 않음

// 4. 정렬 위반
let arr = [1u8, 2, 3, 4];
let ptr = &arr[1] as *const u8 as *const u32;
unsafe { *ptr; }  // ← UB! 정렬 깨짐

// 5. Data Race
static mut X: i32 = 0;
unsafe { X = 100; }  // 여러 스레드에서 동시 수정 ← UB!
```

### ✅ 안전하게 하는 방법

```rust
// [검증 먼저]
fn safe_dereference(ptr: *const i32) -> Option<i32> {
    if ptr.is_null() {
        None  // Null 검사
    } else {
        unsafe { Some(*ptr) }  // 검증 후 역참조
    }
}

// [범위 체크]
fn safe_array_access(ptr: *const i32, index: usize, len: usize) -> Option<i32> {
    if index < len {
        unsafe { Some(*ptr.add(index)) }
    } else {
        None
    }
}

// [생명주기 보장]
fn safe_lifetime_access(x: &i32) -> i32 {
    let ptr = x as *const i32;
    unsafe { *ptr }  // x의 생명주기 동안 유효
}
```

