mod token;
mod lexer;

use lexer::Lexer;
use token::Token;

// ============================================================================
// Section 1: Lexer 기초 - 단순한 프로그램 토큰화
// ============================================================================
fn section_1_basics() {
    println!("\n=== Section 1: Lexer 기초 ===");
    println!("가장 단순한 Gogs-Lang 프로그램을 토큰화:");
    println!();

    let source = "let x = 10;".to_string();
    println!("  입력: {}", source);
    println!("  토큰화 진행:");
    println!();

    let mut lexer = Lexer::new(source);
    let mut token_count = 0;

    loop {
        let token_with_pos = lexer.next_token();
        if token_count < 6 {
            println!("    [{}] {:?}", token_count, token_with_pos.token);
        }
        token_count += 1;
        if token_with_pos.token == Token::EOF {
            break;
        }
    }

    println!();
    println!("  총 {} 개의 토큰 생성", token_count);
    println!("✓ Section 1 완료: 기본 토큰화");
}

// ============================================================================
// Section 2: 연산 표현식 분석
// ============================================================================
fn section_2_arithmetic() {
    println!("\n=== Section 2: 연산 표현식 분석 ===");
    println!("수학 연산식을 토큰으로 분해:");
    println!();

    let source = "x + y * 2 - z / 3".to_string();
    println!("  입력: {}", source);
    println!("  토큰 스트림:");

    let mut lexer = Lexer::new(source);
    let mut idx = 0;

    loop {
        let token_with_pos = lexer.next_token();
        match &token_with_pos.token {
            Token::Ident(name) => {
                print!("  [{}] Ident({})", idx, name);
            }
            Token::Int(n) => {
                print!("  [{}] Int({})", idx, n);
            }
            Token::Plus => print!("  [{}] Plus(+)", idx),
            Token::Minus => print!("  [{}] Minus(-)", idx),
            Token::Asterisk => print!("  [{}] Multiply(*)", idx),
            Token::Slash => print!("  [{}] Divide(/)", idx),
            Token::EOF => {
                println!();
                println!("  [{}] EOF", idx);
                break;
            }
            _ => {}
        }
        if token_with_pos.token != Token::EOF {
            println!();
        }
        idx += 1;
    }

    println!("✓ Section 2 완료: 연산식 분석");
}

// ============================================================================
// Section 3: 키워드 인식
// ============================================================================
fn section_3_keywords() {
    println!("\n=== Section 3: 키워드 인식 ===");
    println!("Gogs-Lang 언어 키워드를 구분:");
    println!();

    let source = "let fn if else return while for true false".to_string();
    println!("  입력: {}", source);
    println!("  토큰 분석:");

    let mut lexer = Lexer::new(source);
    let tokens = lexer.tokenize();

    for (idx, token_with_pos) in tokens.iter().enumerate() {
        if idx >= 8 {
            break; // EOF 제외
        }
        println!("    [{}] {:?}", idx, token_with_pos.token);
    }

    println!("✓ Section 3 완료: 키워드 인식");
}

// ============================================================================
// Section 4: 문자열 & 리터럴
// ============================================================================
fn section_4_literals() {
    println!("\n=== Section 4: 문자열 & 리터럴 ===");
    println!("다양한 리터럴 타입 토큰화:");
    println!();

    let source = r#"let name = "Alice"; let age = 30; let pi = 3.14;"#.to_string();
    println!("  입력: {}", source);
    println!("  리터럴 토큰:");

    let mut lexer = Lexer::new(source);
    loop {
        let token_with_pos = lexer.next_token();
        match &token_with_pos.token {
            Token::String(s) => println!("    String(\"{}\")", s),
            Token::Int(n) => println!("    Int({})", n),
            Token::Float(f) => println!("    Float({})", f),
            Token::Ident(name) => println!("    Ident({})", name),
            Token::EOF => break,
            _ => {}
        }
    }

    println!("✓ Section 4 완료: 리터럴 분석");
}

// ============================================================================
// Section 5: 주석 무시
// ============================================================================
fn section_5_comments() {
    println!("\n=== Section 5: 주석 무시 ===");
    println!("Lexer가 한 줄 주석과 블록 주석을 올바르게 무시:");
    println!();

    println!("  입력: (주석 포함)");
    println!("  let x = 10; // 한 줄 주석");
    println!("  /* 블록 주석 */ let y = 20;");
    println!();
    println!("  실제 토큰 (주석 제외):");

    let source = "let x = 10; // 이것은 주석\n/* 블록 주석 */ let y = 20;".to_string();
    let mut lexer = Lexer::new(source);
    loop {
        let token_with_pos = lexer.next_token();
        match &token_with_pos.token {
            Token::Let => println!("    Let"),
            Token::Ident(name) => println!("    Ident({})", name),
            Token::Assign => println!("    Assign(=)"),
            Token::Int(n) => println!("    Int({})", n),
            Token::Semicolon => println!("    Semicolon(;)"),
            Token::EOF => break,
            _ => {}
        }
    }

    println!("✓ Section 5 완료: 주석 무시");
}

// ============================================================================
// Section 6: 2글자 연산자 (Peeking)
// ============================================================================
fn section_6_operators() {
    println!("\n=== Section 6: 2글자 연산자 (Peeking) ===");
    println!("Lexer가 peek_char()로 다음 글자를 미리 본 후 올바른 토큰 결정:");
    println!();

    let source = "a == b; c != d; x <= y; z >= 0;".to_string();
    println!("  입력: {}", source);
    println!("  2글자 연산자 토큰:");

    let mut lexer = Lexer::new(source);
    loop {
        let token_with_pos = lexer.next_token();
        match &token_with_pos.token {
            Token::EqualEqual => println!("    EqualEqual(==)"),
            Token::NotEqual => println!("    NotEqual(!=)"),
            Token::LessEqual => println!("    LessEqual(<=)"),
            Token::GreaterEqual => println!("    GreaterEqual(>=)"),
            Token::EOF => break,
            _ => {}
        }
    }

    println!("✓ Section 6 완료: 2글자 연산자");
}

// ============================================================================
// Section 7: 위치 추적 (Line & Column)
// ============================================================================
fn section_7_positions() {
    println!("\n=== Section 7: 위치 추적 (Line & Column) ===");
    println!("에러 메시지를 위해 각 토큰의 줄과 열 번호 추적:");
    println!();

    let source = "let x = 10;\nlet y = 20;".to_string();
    println!("  입력:");
    println!("    1: let x = 10;");
    println!("    2: let y = 20;");
    println!();
    println!("  각 토큰의 위치:");

    let mut lexer = Lexer::new(source);
    let mut count = 0;

    loop {
        let token_with_pos = lexer.next_token();
        match &token_with_pos.token {
            Token::Let | Token::Ident(_) | Token::Int(_) => {
                println!("    [{}:{}] {:?}",
                    token_with_pos.position.line,
                    token_with_pos.position.column,
                    token_with_pos.token
                );
            }
            Token::EOF => break,
            _ => {}
        }
        count += 1;
        if count > 20 {
            break;
        }
    }

    println!("✓ Section 7 완료: 위치 추적");
}

// ============================================================================
// Section 8: 복잡한 프로그램 분석
// ============================================================================
fn section_8_complex() {
    println!("\n=== Section 8: 복잡한 프로그램 분석 ===");
    println!("함수 정의를 포함한 복잡한 프로그램 토큰화:");
    println!();

    let source = r#"fn add(x, y) {
    return x + y;
}"#.to_string();

    println!("  입력 프로그램:");
    println!("    fn add(x, y) {{");
    println!("        return x + y;");
    println!("    }}");
    println!();
    println!("  토큰 스트림:");

    let mut lexer = Lexer::new(source);
    let tokens = lexer.tokenize();

    for token_with_pos in tokens.iter() {
        if token_with_pos.token == Token::EOF {
            break;
        }
        println!("    {:?}", token_with_pos.token);
    }

    println!("  총 {} 개 토큰", tokens.len() - 1); // EOF 제외
    println!("✓ Section 8 완료: 복잡한 프로그램");
}

// ============================================================================
// Section 9: 이스케이프 시퀀스
// ============================================================================
fn section_9_escape_sequences() {
    println!("\n=== Section 9: 이스케이프 시퀀스 ===");
    println!("문자열 내 이스케이프 시퀀스 처리:");
    println!();

    let source = r#"let greeting = "Hello\nWorld"; let path = "C:\\Users\\alice";"#.to_string();
    println!("  입력:");
    println!("    let greeting = \"Hello\\nWorld\";");
    println!("    let path = \"C:\\\\Users\\\\alice\";");
    println!();
    println!("  해석된 문자열:");

    let mut lexer = Lexer::new(source);
    loop {
        let token_with_pos = lexer.next_token();
        if let Token::String(s) = &token_with_pos.token {
            println!("    String(\"{}\")", s);
        }
        if token_with_pos.token == Token::EOF {
            break;
        }
    }

    println!("✓ Section 9 완료: 이스케이프 시퀀스");
}

// ============================================================================
// Section 10: 토큰 범주 통계
// ============================================================================
fn section_10_statistics() {
    println!("\n=== Section 10: 토큰 범주 통계 ===");
    println!("소스코드의 토큰 분포 분석:");
    println!();

    let source = "let x = 10 + 20; let y = 5 * 2; if x > y { x = y + 1; }".to_string();

    let mut lexer = Lexer::new(source.clone());
    let tokens = lexer.tokenize();

    let mut keywords = 0;
    let mut identifiers = 0;
    let mut numbers = 0;
    let mut operators = 0;
    let mut punctuation = 0;

    for token_with_pos in &tokens {
        match &token_with_pos.token {
            Token::Let | Token::If | Token::Return | Token::While | Token::For => keywords += 1,
            Token::Ident(_) => identifiers += 1,
            Token::Int(_) | Token::Float(_) => numbers += 1,
            Token::Plus | Token::Minus | Token::Asterisk | Token::Slash |
            Token::Assign | Token::EqualEqual | Token::Less | Token::Greater => operators += 1,
            Token::Semicolon | Token::Comma | Token::LeftBrace | Token::RightBrace |
            Token::LeftParen | Token::RightParen => punctuation += 1,
            Token::EOF => {}
            _ => {}
        }
    }

    println!("  소스코드: {}", source);
    println!();
    println!("  토큰 분포:");
    println!("    키워드: {}", keywords);
    println!("    식별자: {}", identifiers);
    println!("    숫자: {}", numbers);
    println!("    연산자: {}", operators);
    println!("    구두점: {}", punctuation);
    println!("    총합: {}", keywords + identifiers + numbers + operators + punctuation);

    println!("✓ Section 10 완료: 통계");
}

// ============================================================================
// Section 11: 에러 처리
// ============================================================================
fn section_11_error_handling() {
    println!("\n=== Section 11: 에러 처리 ===");
    println!("정의되지 않은 문자나 닫히지 않은 문자열 감지:");
    println!();

    let sources = vec![
        ("let x = @;", "정의되지 않은 문자 '@'"),
        ("let name = \"unclosed;", "닫히지 않은 문자열"),
    ];

    for (source, description) in sources {
        println!("  경우: {}", description);
        println!("    코드: {}", source);
        println!("    토큰:");

        let mut lexer = Lexer::new(source.to_string());
        loop {
            let token_with_pos = lexer.next_token();
            match &token_with_pos.token {
                Token::Unknown(ch) => {
                    println!("      ⚠️ Unknown('{}')", ch);
                }
                Token::EOF => {
                    println!("      EOF");
                    break;
                }
                token => println!("      {:?}", token),
            }
        }
        println!();
    }

    println!("✓ Section 11 완료: 에러 처리");
}

