    println!("📌 섹션 4: 규칙 2 실패 — 여러 입력\n");
    {
        let text1 = "short";
        let text2 = "much_longer_text";

        // longest_explicit는 작동 (명시적 수명)
        let result = longest_explicit(&text1, &text2);
        println!("명시적 longest: \"{}\"", result);

        println!("❌ longest_elided(x: &str, y: &str)는 컴파일 오류!");
        println!("   → 컴파일러가 어느 쪽의 수명을 반환값에 할당할지 모름");
        println!("   → 반드시 fn longest<'a>(x: &'a str, y: &'a str) 형태로 명시\n");
    }

    // ==================== 섹션 5: 규칙 3 — 메서드의 특권 ====================
    println!("📌 섹션 5: 규칙 3 — 메서드의 특권\n");
    {
        let text = "Hello World from GOGS";
        let parser = TextParser { text };

        // 명시적 버전
        let word1 = parser.first_word_explicit();
        println!("명시적 메서드: 첫 단어 = \"{}\"", word1);

        // 생략된 버전 (내부적으로 동일, &self의 수명을 따름)
        let word2 = parser.first_word_elided();
        println!("생략됨 메서드: 첫 단어 = \"{}\"", word2);

        println!("✅ 메서드에서는 &self의 수명이 자동으로 할당됨\n");
    }

    // ==================== 섹션 6: 메서드 여러 입력 ====================
    println!("📌 섹션 6: 메서드 규칙 3 — 다른 입력도 무시\n");
    {
        let text = "GOGS Protocol Active";
        let parser = TextParser { text };

        let contains_gogs1 = parser.contains_word_explicit("GOGS");
