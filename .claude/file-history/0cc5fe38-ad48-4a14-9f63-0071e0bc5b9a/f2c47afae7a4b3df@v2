        println!("명시적: contains(\"GOGS\") = {}", contains_gogs1);
        println!("생략됨: contains(\"GOGS\") = {}", contains_gogs2);

        println!("✅ &self의 수명이 우선됨 (word 매개변수의 수명 무시)\n");
    }

    // ==================== 섹션 7: &mut self ====================
    println!("📌 섹션 7: &mut self도 동일\n");
    {
        let text = "Original";
        let mut parser = TextParser { text };

        // 명시적 버전 (일반적으로 사용하지 않음)
        // let result = parser.modify_text_explicit();

        // 생략된 버전 (흔하게 사용)
        let result = parser.modify_text_elided();

        println!("메서드 반환: \"{}\"", result);
        println!("✅ &mut self도 동일한 규칙 3 적용\n");
    }

    // ==================== 섹션 8: 특수 케이스 LogEntry ====================
    println!("📌 섹션 8: 특수 케이스 — 반환값이 &str\n");
    {
        let log_text = "System initialized at 2026-02-22";
        let entry = LogEntry { log: &log_text };

        let log = entry.get_log();
        println!("로그: {}", log);
        println!("✅ &self의 수명이 반환값에 할당됨\n");
    }

    // ==================== 섹션 9: 생략 규칙 요약 ====================
    println!("📌 섹션 9: 생략 규칙 정리\n");
    {
        println!("🏆 3가지 황금 규칙:");
        println!();

        println!("규칙 1️⃣ : 각 입력은 독립적");
        println!("  fn foo(x: &str, y: &str)");
        println!("  → fn foo<'a, 'b>(x: &'a str, y: &'b str)");
        println!();

        println!("규칙 2️⃣ : 외동은 유산을 독점");
        println!("  fn foo(x: &str) -> &str");
        println!("  → fn foo<'a>(x: &'a str) -> &'a str");
        println!();

        println!("규칙 3️⃣ : 메서드의 특권");
        println!("  fn method(&self) -> &str");
        println!("  → fn method<'a>(&'a self) -> &'a str");
        println!();
    }

    // ==================== 섹션 10: 언제 생략하고 언제 명시할까 ====================
    println!("📌 섹션 10: 설계자의 안목\n");
    {
        println!("✅ 생략해도 되는 경우:");
        println!("  1. 입력이 하나이고 반환값이 참조");
        println!("  2. 메서드(&self 포함)");
        println!("  3. 3가지 규칙 중 하나에 명확히 해당");
        println!();

        println!("❌ 반드시 명시해야 하는 경우:");
        println!("  1. 여러 입력의 수명을 구분해야 함");
        println!("  2. 어느 입력의 수명을 반환할지 불명확");
