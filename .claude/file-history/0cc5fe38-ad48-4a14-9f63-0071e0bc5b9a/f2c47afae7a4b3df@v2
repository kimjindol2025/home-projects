        println!();

        println!("코드의 독해자가 되어야 합니다:");
        println!("  - 컴파일러의 의도를 읽어내고");
        println!("  - 필요할 때만 명시하고");
        println!("  - 코드를 깨끗하게 유지하세요");
        println!();
    }

    // ==================== 섹션 11: 실전 비교 ====================
    println!("📌 섹션 11: 실전 코드 비교\n");
    {
        println!("나쁜 설계 (불필요하게 복잡함):");
        println!("  fn find_word<'a>(text: &'a str, word: &'a str) -> Option<usize>");
        println!("  → word의 수명이 필요하지 않은데 명시함");
