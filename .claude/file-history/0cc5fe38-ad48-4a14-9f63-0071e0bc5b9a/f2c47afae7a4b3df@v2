// 🕐 v7.2: 수명 생략 법칙 (Lifetime Elision)
// ⏳ "보이지 않는 규칙: 생략"
// 🎯 "명시와 생략의 조화" — 코드의 독해자
//
// 핵심 개념:
// - 명시적 수명 vs 생략된 수명 (논리적으로 동일)
// - 3가지 황금 규칙 (컴파일러가 적용하는 결정론적 규칙)
// - 언제 생략이 안전한지 판단하는 안목

// ==================== 규칙 1: 각 입력은 독립적 ====================

/// [명시적] 여러 입력, 각각 독립적인 수명
fn compare_explicit<'a, 'b>(x: &'a str, y: &'b str) -> bool {
    x.len() > y.len()
}

/// [생략됨] 규칙 1에 따라 생략 가능
/// 내부적으로 compare_explicit과 동일하게 해석됨
fn compare_elided(x: &str, y: &str) -> bool {
    x.len() > y.len()
}

// ==================== 규칙 2: 외동은 유산을 독점 ====================

/// [명시적] 입력이 하나, 그 수명이 반환값의 수명
fn first_word_explicit<'a>(s: &'a str) -> &'a str {
    let bytes = s.as_bytes();
    for (i, &item) in bytes.iter().enumerate() {
        if item == b' ' {
            return &s[0..i];
        }
    }
    &s[..]
}

/// [생략됨] 규칙 2에 따라 생략 가능
/// 입력이 &str 하나 → 반환값도 같은 수명
fn first_word_elided(s: &str) -> &str {
    let bytes = s.as_bytes();
    for (i, &item) in bytes.iter().enumerate() {
        if item == b' ' {
            return &s[0..i];
        }
    }
    &s[..]
}

/// 또 다른 예: 최대 길이 찾기
fn longest_word_explicit<'a>(s: &'a str) -> &'a str {
    s.split_whitespace()
        .max_by_key(|word| word.len())
        .unwrap_or("")
}

fn longest_word_elided(s: &str) -> &str {
    s.split_whitespace()
        .max_by_key(|word| word.len())
        .unwrap_or("")
}

// ==================== 규칙 2 실패: 여러 입력 ====================

/// [명시적] 여러 입력이 있으면 생략 불가능
fn longest_explicit<'a>(x: &'a str, y: &'a str) -> &'a str {
    if x.len() > y.len() {
        x
    } else {
        y
    }
}

/// [생략 불가] 여러 입력이 있으면?
/// ❌ 다음 코드는 컴파일 오류 발생:
/// fn longest_elided(x: &str, y: &str) -> &str {
///     컴파일러가 어느 쪽 수명을 반환값에 할당할지 모름!
/// }

// ==================== 규칙 3: 메서드의 특권 ====================

struct TextParser<'a> {
    text: &'a str,
}

impl<'a> TextParser<'a> {
    /// [명시적] self의 수명을 명시
    fn first_word_explicit(&'a self) -> &'a str {
        self.text.split_whitespace().next().unwrap_or("")
    }

    /// [생략됨] 규칙 3에 따라 생략 가능
    /// &self의 수명 'a가 자동으로 반환값에 할당됨
    fn first_word_elided(&self) -> &str {
        self.text.split_whitespace().next().unwrap_or("")
    }

    /// 메서드: 여러 입력이 있어도 &self의 수명을 따름
    fn contains_word_explicit(&'a self, word: &str) -> bool {
        self.text.contains(word)
    }

    fn contains_word_elided(&self, word: &str) -> bool {
        self.text.contains(word)
    }

    /// &mut self의 경우도 동일
    fn modify_text_explicit(&'a mut self) -> &'a str {
        self.text = "Modified";
        self.text
    }

    fn modify_text_elided(&mut self) -> &str {
        self.text = "Modified";
        self.text
    }
}

// ==================== 특수 케이스: &self 메서드 ====================

struct LogEntry<'a> {
    log: &'a str,
}

impl<'a> LogEntry<'a> {
    /// &self를 참조로 반환하는 메서드
    /// 규칙 3: &self의 수명이 반환값의 수명
    fn get_log(&self) -> &str {
        self.log
    }

    /// &self를 받고 다른 참조를 받음
    /// 규칙 3: &self의 수명이 반환값의 수명
    fn compare_with<'b>(&self, other: &'b str) -> bool {
        self.log.len() > other.len()
    }
}

fn main() {
    println!("╔══════════════════════════════════════════════════════════╗");
    println!("║ v7.2: 수명 생략 법칙 (Lifetime Elision)                 ║");
    println!("║ \"보이지 않는 규칙: 생략\"                               ║");
    println!("╚══════════════════════════════════════════════════════════╝\n");

    // ==================== 섹션 1: 규칙 1 ====================
    println!("📌 섹션 1: 규칙 1 — 각 입력은 독립적\n");
    {
        let text1 = "GOGS";
        let text2 = "Protocol";

        // 명시적 버전
        let result1 = compare_explicit(&text1, &text2);
        println!("명시적: {} > {} ? {}", text1, text2, result1);

        // 생략된 버전 (내부적으로 동일)
        let result2 = compare_elided(&text1, &text2);
        println!("생략됨: {} > {} ? {}", text1, text2, result2);

        println!("✅ 두 결과는 동일합니다: {} == {}\n", result1, result2);
    }

    // ==================== 섹션 2: 규칙 2 (입력 1개) ====================
    println!("📌 섹션 2: 규칙 2 — 외동은 유산을 독점\n");
    {
        let sentence = "GOGS is awesome";

        // 명시적 버전
        let word1 = first_word_explicit(&sentence);
        println!("명시적: \"{}\"의 첫 단어 = \"{}\"", sentence, word1);

        // 생략된 버전 (내부적으로 동일)
        let word2 = first_word_elided(&sentence);
        println!("생략됨: \"{}\"의 첫 단어 = \"{}\"", sentence, word2);

        println!("✅ 두 결과는 동일합니다: \"{}\" == \"{}\"\n", word1, word2);
    }

    // ==================== 섹션 3: 규칙 2 또 다른 예 ====================
    println!("📌 섹션 3: 규칙 2 변형 — 가장 긴 단어\n");
    {
        let text = "Rust programming is very interesting";

        let longest1 = longest_word_explicit(&text);
        let longest2 = longest_word_elided(&text);

        println!("명시적: 가장 긴 단어 = \"{}\"", longest1);
        println!("생략됨: 가장 긴 단어 = \"{}\"", longest2);
        println!("✅ 동일: \"{}\" == \"{}\"\n", longest1, longest2);
    }

