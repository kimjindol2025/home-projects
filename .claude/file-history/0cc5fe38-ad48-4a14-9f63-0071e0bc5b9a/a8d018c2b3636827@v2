/// [순수 함수] 입력에만 의존하고 외부 상태를 변경하지 않음
///
/// 설계 철학:
///   - 같은 입력 → 항상 같은 출력
///   - 함수 외부의 변수를 읽거나 수정하지 않음
///   - 테스트와 디버깅이 쉬움
fn calculate_average(values: &[i32]) -> f32 {
    if values.is_empty() {
        return 0.0;
    }

    let sum: i32 = values.iter().sum();
    sum as f32 / values.len() as f32
}

/// [순수 함수] 최대값과 최소값을 반환
///
/// 설계 철학:
///   - 입력 슬라이스만 사용
///   - 외부 상태 변경 없음
///   - Option을 이용하여 빈 벡터 처리
fn find_min_max(values: &[i32]) -> Option<(i32, i32)> {
    if values.is_empty() {
        return None;
    }

    let min = values.iter().min().copied();
    let max = values.iter().max().copied();

    match (min, max) {
        (Some(m), Some(M)) => Some((m, M)),
        _ => None,
    }
}

