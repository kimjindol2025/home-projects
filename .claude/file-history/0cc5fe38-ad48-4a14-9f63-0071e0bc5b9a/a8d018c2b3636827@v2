/// [복합 함수] 위의 기본 함수들을 조합하여 더 복잡한 로직 구현
///
/// 설계 철학:
///   - 작은 함수들을 조합하여 큰 기능을 만듦
///   - 각 함수는 독립적으로 테스트 가능
///   - 코드 재사용성 극대화
fn comprehensive_analysis(sensor_values: Vec<i32>) -> Vec<String> {
    sensor_values
        .iter()
        .filter(|&&v| is_within_bounds(v, 0, 100))   // 범위 검증 (v3.3)
        .map(|&v| analyze_sensor_level(v))            // 분석 (v3.0~v3.1)
        .collect()
}

