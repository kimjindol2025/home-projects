/// [v3.0~v3.1 캡슐화] 센서 값을 분석하고 조건에 따라 분류
///
/// 매개변수:
///   - input: i32 (센서에서 읽은 값)
///
/// 반환값:
///   - String (분석 결과 메시지)
///
/// 설계 철학:
///   - v3.0의 IF/MATCH 논리를 함수 내부로 캡슐화
///   - 호출자는 "분석해줘"라고 부르기만 하면 됨
///   - 내부의 복잡한 조건문은 모두 숨김
fn analyze_sensor_level(input: i32) -> String {
    match input {
        i if i >= 100  => format!("[🔴 CRITICAL] 위험 수치: {}", i),
        i if i >= 80   => format!("[🟡 WARNING] 주의 수치: {}", i),
        i if i >= 50   => format!("[🟢 NORMAL] 안정 수치: {}", i),
        i if i >= 0    => format!("[🔵 LOW] 저수치: {}", i),
        _              => format!("[⚫ ERROR] 유효하지 않은 입력: {}", i),
    }
}

/// [v3.2 캡슐화] 숫자 범위를 반복하며 유효한 값만 처리
///
/// 매개변수:
///   - start: i32 (시작 범위)
///   - end: i32 (종료 범위)
///
/// 반환값:
///   - Vec<i32> (범위 내 짝수들의 벡터)
///
/// 설계 철학:
///   - v3.2의 FOR 루프를 함수로 추상화
///   - 범위 내에서 조건을 만족하는 값들을 자동으로 수집
fn filter_even_numbers(start: i32, end: i32) -> Vec<i32> {
    let mut result = Vec::new();
    for i in start..=end {
        if i % 2 == 0 {
            result.push(i);
        }
    }
    result
}

/// [v3.3 캡슐화] 입력값의 경계값 유효성 검증
///
/// 매개변수:
///   - value: i32 (검증할 값)
///   - min: i32 (최소값)
///   - max: i32 (최대값)
///
/// 반환값:
///   - bool (유효하면 true, 아니면 false)
///
/// 설계 철학:
///   - v3.3의 무결성 검증을 함수로 캡슐화
///   - 경계값 처리의 복잡성을 숨김
fn is_within_bounds(value: i32, min: i32, max: i32) -> bool {
    value >= min && value <= max
}

/// [v3.4 캡슐화] 패턴 매칭으로 데이터 분류
///
/// 매개변수:
///   - input: i32 (분류할 값)
///
/// 반환값:
///   - String (분류 결과)
///
/// 설계 철학:
///   - v3.4의 패턴 매칭 논리를 함수로 재사용 가능하게 만듦
///   - 여러 곳에서 동일한 분류 로직을 반복하지 않음
fn categorize_value(input: i32) -> String {
    match input {
        0          => "영점".to_string(),
        1..=50     => "낮은 범위".to_string(),
        51..=100   => "중간 범위".to_string(),
        101..      => "높은 범위".to_string(),
        _          => "음수 범위".to_string(),
    }
}

/// [v3.6 캡슐화] 가드 절을 이용한 조기 반환
///
/// 매개변수:
///   - user_input: i32 (사용자 입력)
///
/// 반환값:
///   - String (처리 결과 또는 에러 메시지)
///
/// 설계 철학:
///   - v3.6의 가드 패턴을 함수 시작 부분에서 적용
///   - 유효하지 않은 입력은 즉시 반환
///   - 함수의 청정 구역(clean zone)을 보호
fn process_with_guards(user_input: i32) -> String {
    // [가드 1] 음수는 즉시 거부
    if user_input < 0 {
        return "❌ 음수는 허용되지 않습니다".to_string();
    }

    // [가드 2] 경계값 벗어나면 거부
    if user_input > 1000 {
        return "❌ 1000을 초과할 수 없습니다".to_string();
    }

    // [청정 구역] 모든 가드를 통과한 유효한 값만 처리
    format!("✅ 처리 완료: {} -> {}", user_input, user_input * 2)
}

/// [v3.7 캡슐화] 상태 머신을 함수로 구현
///
/// 매개변수:
///   - input: i32 (센서 값)
///
/// 반환값:
///   - String (현재 상태와 권장 조치)
///
/// 설계 철학:
///   - v3.7의 상태 전이 로직을 함수로 캡슐화
///   - 복잡한 상태 관리를 간단한 함수 호출로 처리
fn get_system_state(input: i32) -> String {
    #[derive(Debug, Clone, PartialEq)]
    enum SystemState {
        Idle,
        Running(i32),
        Warning(i32),
        Shutdown,
    }

    let state = if input == 0 {
        SystemState::Idle
    } else if input > 0 && input <= 50 {
        SystemState::Running(input)
    } else if input > 50 && input <= 100 {
        SystemState::Warning(input)
    } else {
        SystemState::Shutdown
    };

    match state {
        SystemState::Idle => "🔘 대기 중: 입력을 기다리는 중".to_string(),
        SystemState::Running(val) => format!("🟢 운영 중: 정상 수치 {}", val),
        SystemState::Warning(val) => format!("🟡 경고: 주의 필요 {}", val),
        SystemState::Shutdown => "🛑 종료됨: 시스템 정지".to_string(),
    }
}

/// [v3.8 캡슐화] 반복자를 이용한 데이터 처리
///
/// 매개변수:
///   - values: Vec<i32> (처리할 값들)
///
/// 반환값:
///   - Vec<String> (변환된 문자열 벡터)
///
/// 설계 철학:
///   - v3.8의 선언적 반복자를 함수로 재사용 가능하게 만듦
///   - 함수의 역할: 데이터를 받아 변환하고 반환
///   - 부수 효과(Side Effect) 없음: 오직 입력에만 의존
fn transform_values_declaratively(values: Vec<i32>) -> Vec<String> {
    values
        .iter()
        .filter(|&&v| v > 0)                          // 양수만 선택
        .map(|&v| format!("[{}] -> [{}]", v, v * 2)) // 값을 2배로 변환
        .collect()                                     // 결과 수집
}

