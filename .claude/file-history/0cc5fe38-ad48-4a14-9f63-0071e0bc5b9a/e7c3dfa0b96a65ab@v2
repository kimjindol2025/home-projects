## 📊 실전 예제: 은행 계좌 시스템

```rust
#[derive(Debug, Clone)]
struct BankAccount {
    account_number: String,
    holder_name: String,
    balance: f64,
    transaction_log: Vec<String>,
}

// impl 1: 생성 및 조회
impl BankAccount {
    fn new(account_number: &str, holder_name: &str, initial: f64) -> BankAccount {
        BankAccount {
            account_number: String::from(account_number),
            holder_name: String::from(holder_name),
            balance: initial,
            transaction_log: vec![],
        }
    }

    fn balance(&self) -> f64 {
        self.balance
    }

    fn display(&self) {
        println!("계좌번호: {}", self.account_number);
        println!("예금주: {}", self.holder_name);
        println!("잔액: {} 원", self.balance);
    }
}

// impl 2: 거래
impl BankAccount {
    fn deposit(&mut self, amount: f64) -> Result<f64, String> {
        if amount <= 0.0 {
            return Err("양수만 입금 가능".to_string());
        }
        self.balance += amount;
        self.transaction_log.push(format!("입금: {} 원", amount));
        Ok(self.balance)
    }

    fn withdraw(&mut self, amount: f64) -> Result<f64, String> {
        if amount <= 0.0 {
            return Err("양수만 출금 가능".to_string());
        }
        if self.balance < amount {
            return Err("잔액 부족".to_string());
        }
        self.balance -= amount;
        self.transaction_log.push(format!("출금: {} 원", amount));
        Ok(self.balance)
    }
}

// impl 3: 거래 내역
impl BankAccount {
    fn show_transactions(&self) {
        println!("\n=== 거래 내역 ===");
        for log in &self.transaction_log {
            println!("{}", log);
        }
    }

    fn transaction_count(&self) -> usize {
        self.transaction_log.len()
    }
}

// 사용
let mut account = BankAccount::new("123-456", "김철수", 10000.0);

account.display();

match account.deposit(5000.0) {
    Ok(new_balance) => println!("입금 후 잔액: {}", new_balance),
    Err(e) => println!("오류: {}", e),
}

match account.withdraw(3000.0) {
    Ok(new_balance) => println!("출금 후 잔액: {}", new_balance),
    Err(e) => println!("오류: {}", e),
}

account.show_transactions();
println!("거래 횟수: {}", account.transaction_count());
```

