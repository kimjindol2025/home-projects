// ===================================================================
// Section 3: 메서드와 비즈니스 로직
// ===================================================================
//
// impl 블록에서 시스템의 동작을 정의합니다.
//
fn section_3_business_logic() {
    println!("▶ Section 3: 메서드와 비즈니스 로직");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 3-1. 기본 구조
    // ─────────────────────────────────────────
    println!("  [3-1] impl 블록의 메서드");

    #[derive(Debug, Clone)]
    enum NodeStatus {
        Active,
        Warning(String),
        Critical(String),
        Offline,
    }

    #[derive(Debug, Clone)]
    struct SecurityNode {
        id: u32,
        location: String,
        status: NodeStatus,
    }

    #[derive(Debug, Clone)]
    struct SystemLog {
        timestamp: u64,
        message: String,
    }

    struct ControlCenter {
        center_name: String,
        nodes: HashMap<u32, SecurityNode>,
        logs: Vec<SystemLog>,
    }

    impl ControlCenter {
        fn new(name: &str) -> Self {
            ControlCenter {
                center_name: String::from(name),
                nodes: HashMap::new(),
                logs: Vec::new(),
            }
        }

        fn register_node(&mut self, id: u32, location: &str) -> Result<(), String> {
            if self.nodes.contains_key(&id) {
                return Err(format!("노드 {}는 이미 등록됨", id));
            }

            let node = SecurityNode {
                id,
                location: String::from(location),
                status: NodeStatus::Active,
            };

            self.nodes.insert(id, node);
            self.log(format!("노드 {} 등록 ({})", id, location));
            Ok(())
        }

        fn log(&mut self, message: String) {
            let log = SystemLog {
                timestamp: 0,  // 실제로는 current_time()
                message,
            };
            self.logs.push(log);
        }

        fn node_count(&self) -> usize {
            self.nodes.len()
        }
    }

    println!("    new(name: &str) -> Self");
    println!("    register_node(id, location) -> Result<(), String>");
    println!("    log(message: String)");
    println!("    node_count() -> usize\n");

    // ─────────────────────────────────────────
    // 3-2. 메서드 호출
    // ─────────────────────────────────────────
    println!("  [3-2] 메서드 호출 예제");

    let mut center = ControlCenter::new("GOGS-HQ");
    match center.register_node(101, "Main Gate") {
        Ok(()) => println!("    ✓ 노드 101 등록 성공"),
        Err(e) => println!("    ✗ 오류: {}", e),
    }

    println!("    센터 내 노드: {} 개\n", center.node_count());

    println!("  💡 핵심: impl 블록에서 데이터와 로직을 결합합니다.\n");
}

// ===================================================================
// Section 4: 상태 관리 - Option과 Result
// ===================================================================
//
// 모든 데이터 접근을 안전하게 처리합니다.
//
fn section_4_state_management() {
    println!("▶ Section 4: 상태 관리");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 4-1. 안전한 조회
    // ─────────────────────────────────────────
    println!("  [4-1] 안전한 노드 조회");

    #[derive(Debug, Clone)]
    enum NodeStatus {
        Active,
        Warning(String),
        Critical(String),
        Offline,
    }

    #[derive(Debug, Clone)]
    struct SecurityNode {
        id: u32,
        location: String,
        status: NodeStatus,
    }

    struct ControlCenter {
        nodes: HashMap<u32, SecurityNode>,
    }

    impl ControlCenter {
        fn get_node(&self, id: u32) -> Option<&SecurityNode> {
            self.nodes.get(&id)
        }

        fn check_node_status(&self, id: u32) -> Result<String, String> {
            match self.nodes.get(&id) {
                Some(node) => {
                    let status_msg = match &node.status {
                        NodeStatus::Active => "정상".to_string(),
                        NodeStatus::Warning(msg) => format!("주의: {}", msg),
                        NodeStatus::Critical(msg) => format!("위험: {}", msg),
                        NodeStatus::Offline => "오프라인".to_string(),
                    };
                    Ok(status_msg)
                }
                None => Err(format!("노드 {}를 찾을 수 없음", id)),
            }
        }
    }

    let mut center = ControlCenter {
        nodes: HashMap::new(),
    };

    center.nodes.insert(
        101,
        SecurityNode {
            id: 101,
            location: String::from("Main"),
            status: NodeStatus::Active,
        },
    );

    // Option 사용
    if let Some(node) = center.get_node(101) {
        println!("    노드 찾음: {} ({})", node.id, node.location);
    }

    // Result 사용
    match center.check_node_status(101) {
        Ok(status) => println!("    상태: {}", status),
        Err(e) => println!("    오류: {}", e),
    }

    println!();

    // ─────────────────────────────────────────
    // 4-2. 상태 변경
    // ─────────────────────────────────────────
    println!("  [4-2] 상태 변경");

    impl ControlCenter {
        fn update_node_status(
            &mut self,
            id: u32,
            new_status: NodeStatus,
        ) -> Result<(), String> {
            match self.nodes.get_mut(&id) {
                Some(node) => {
                    node.status = new_status;
                    Ok(())
                }
                None => Err(format!("노드 {}를 찾을 수 없음", id)),
            }
        }
    }

    let mut center = ControlCenter {
        nodes: HashMap::new(),
    };
    center.nodes.insert(
        101,
        SecurityNode {
            id: 101,
            location: String::from("Main"),
            status: NodeStatus::Active,
        },
    );

    match center.update_node_status(101, NodeStatus::Warning("High CPU".to_string())) {
        Ok(()) => println!("    상태 업데이트 성공"),
        Err(e) => println!("    오류: {}", e),
    }

    println!("\n  💡 핵심: Option과 Result로 모든 가능성을 안전하게 처리합니다.\n");
}

// ===================================================================
// Section 5: 데이터 검증과 무결성
// ===================================================================
//
// 데이터 접근 시 유효성을 검사합니다.
//
fn section_5_data_validation() {
    println!("▶ Section 5: 데이터 검증과 무결성");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 5-1. 검증 함수
    // ─────────────────────────────────────────
    println!("  [5-1] 데이터 검증");

    struct Validator;

    impl Validator {
        fn validate_node_id(id: u32) -> Result<(), String> {
            if id == 0 {
                Err("노드 ID는 0이 될 수 없음".to_string())
            } else if id > 10000 {
                Err("노드 ID는 10000 이하여야 함".to_string())
            } else {
                Ok(())
            }
        }

        fn validate_location(location: &str) -> Result<(), String> {
            if location.is_empty() {
                Err("위치는 비어있을 수 없음".to_string())
            } else if location.len() > 100 {
                Err("위치는 100자 이하여야 함".to_string())
            } else {
                Ok(())
            }
        }
    }

    // 테스트
    match Validator::validate_node_id(101) {
        Ok(()) => println!("    ✓ 노드 ID 유효"),
        Err(e) => println!("    ✗ {}", e),
    }

    match Validator::validate_location("Main Gate") {
        Ok(()) => println!("    ✓ 위치 유효"),
        Err(e) => println!("    ✗ {}", e),
    }

    println!();

    // ─────────────────────────────────────────
    // 5-2. 불변성 유지
    // ─────────────────────────────────────────
    println!("  [5-2] 불변성 유지");

    struct ImmutableCenter {
        // 필드를 private으로 숨김
        nodes: HashMap<u32, String>,
    }

    impl ImmutableCenter {
        // 제어된 접근만 허용
        fn get_nodes(&self) -> &HashMap<u32, String> {
            &self.nodes
        }

        // 메서드로만 수정 가능
        fn add_node(&mut self, id: u32, name: String) -> Result<(), String> {
            if self.nodes.contains_key(&id) {
                Err("중복된 ID".to_string())
            } else {
                self.nodes.insert(id, name);
                Ok(())
            }
        }
    }

    println!("    private 필드로 직접 접근 불가");
    println!("    메서드로 제어된 접근만 허용");
    println!("    데이터 무결성 보장\n");

    println!("  💡 핵심: 검증과 캡슐화로 데이터 무결성을 보장합니다.\n");
}

// ===================================================================
// Section 6: 고급 쿼리와 필터링
// ===================================================================
//
// 복잡한 검색 로직을 함수형 스타일로 구현합니다.
//
fn section_6_advanced_queries() {
    println!("▶ Section 6: 고급 쿼리와 필터링");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 6-1. 반복자와 필터링
    // ─────────────────────────────────────────
    println!("  [6-1] 데이터 쿼리");

    #[derive(Debug, Clone)]
    enum NodeStatus {
        Active,
        Warning(String),
        Critical(String),
        Offline,
    }

    #[derive(Debug, Clone)]
    struct SecurityNode {
        id: u32,
        location: String,
        status: NodeStatus,
    }

    struct ControlCenter {
        nodes: HashMap<u32, SecurityNode>,
    }

    impl ControlCenter {
        // 쿼리 1: 모든 정상 노드
        fn get_active_nodes(&self) -> Vec<u32> {
            self.nodes
                .iter()
                .filter(|(_, node)| matches!(node.status, NodeStatus::Active))
                .map(|(id, _)| *id)
                .collect()
        }

        // 쿼리 2: 특정 위치의 노드
        fn find_by_location(&self, loc: &str) -> Vec<&SecurityNode> {
            self.nodes
                .values()
                .filter(|node| node.location.contains(loc))
                .collect()
        }

        // 쿼리 3: 경고 상태인 노드
        fn get_warnings(&self) -> Vec<String> {
            self.nodes
                .values()
                .filter_map(|node| match &node.status {
                    NodeStatus::Warning(msg) => Some(format!("노드 {}: {}", node.id, msg)),
                    _ => None,
                })
                .collect()
        }
    }

    let mut center = ControlCenter {
        nodes: HashMap::new(),
    };

    center.nodes.insert(
        101,
        SecurityNode {
            id: 101,
            location: String::from("Main Gate"),
            status: NodeStatus::Active,
        },
    );

    center.nodes.insert(
        102,
        SecurityNode {
            id: 102,
            location: String::from("Server Room"),
            status: NodeStatus::Warning("High CPU".to_string()),
        },
    );

    println!("    활성 노드: {:?}", center.get_active_nodes());
    println!("    경고 메시지: {:?}", center.get_warnings());
    println!();

    println!("  💡 핵심: 반복자로 선언적이고 우아한 쿼리를 작성합니다.\n");
}

