// Section 7: 실전 통합 시스템
// ===================================================================
//
// 모든 개념을 통합한 완전한 보안 관제 시스템을 구현합니다.
//
fn section_7_integrated_system() {
    println!("▶ Section 7: 실전 통합 시스템");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 실전: 보안 관제 시스템
    // ─────────────────────────────────────────
    println!("  [통합 예제] GOGS 보안 관제 시스템\n");

    #[derive(Debug, Clone)]
    enum NodeStatus {
        Active,
        Warning(String),
        Critical(String),
        Offline,
    }

    #[derive(Debug, Clone)]
    struct SecurityNode {
        id: u32,
        location: String,
        status: NodeStatus,
    }

    #[derive(Debug, Clone)]
    struct SystemLog {
        message: String,
    }

    struct ControlCenter {
        center_name: String,
        nodes: HashMap<u32, SecurityNode>,
        logs: Vec<SystemLog>,
        alert_threshold: i32,
    }

    impl ControlCenter {
        fn new(name: &str) -> Self {
            ControlCenter {
                center_name: String::from(name),
                nodes: HashMap::new(),
                logs: Vec::new(),
                alert_threshold: 80,
            }
        }

        fn register_node(&mut self, id: u32, location: &str) -> Result<(), String> {
            if self.nodes.contains_key(&id) {
                return Err(format!("노드 {}는 이미 등록됨", id));
            }

            let node = SecurityNode {
                id,
                location: String::from(location),
                status: NodeStatus::Active,
            };

            self.nodes.insert(id, node);
            self.add_log(format!("노드 {} 등록 완료 ({})", id, location));
            Ok(())
        }

        fn add_log(&mut self, message: String) {
            self.logs.push(SystemLog { message });
        }

        fn audit_report(&self) {
            println!("    === [{}] 보안 감사 리포트 ===", self.center_name);
            println!("    등록된 노드: {}", self.nodes.len());
            println!("    경고/위험: {} 건",
                self.nodes.values()
                    .filter(|n| !matches!(n.status, NodeStatus::Active | NodeStatus::Offline))
                    .count());
            println!("    기록: {} 개\n", self.logs.len());

            for (id, node) in &self.nodes {
                let status_str = match &node.status {
                    NodeStatus::Active => "정상".to_string(),
                    NodeStatus::Warning(msg) => format!("주의: {}", msg),
                    NodeStatus::Critical(msg) => format!("위험: {}", msg),
                    NodeStatus::Offline => "오프라인".to_string(),
                };
                println!("      Node #{}: {} -> {}", id, node.location, status_str);
            }
        }

        fn update_status(&mut self, id: u32, status: NodeStatus) -> Result<(), String> {
            match self.nodes.get_mut(&id) {
                Some(node) => {
                    node.status = status;
                    self.add_log(format!("노드 {}의 상태 변경됨", id));
                    Ok(())
                }
                None => Err(format!("노드 {} 없음", id)),
            }
        }

        fn get_health_score(&self) -> i32 {
            let total = self.nodes.len() as i32;
            if total == 0 {
                return 100;
            }

            let active = self.nodes.values()
                .filter(|n| matches!(n.status, NodeStatus::Active))
                .count() as i32;

            (active * 100) / total
        }
    }

    // ─────────────────────────────────────────
    // 시스템 운영
    // ─────────────────────────────────────────
    println!("  [시스템 운영 시뮬레이션]\n");

    let mut center = ControlCenter::new("GOGS-HQ");

    // 노드 등록
    let _ = center.register_node(101, "Main Gate");
    let _ = center.register_node(102, "Server Room");
    let _ = center.register_node(103, "Storage");

    // 상태 업데이트
    let _ = center.update_status(102, NodeStatus::Warning("High CPU".to_string()));
    let _ = center.update_status(103, NodeStatus::Offline);

    // 감사 리포트
    center.audit_report();

    // 시스템 상태
    println!("    시스템 건강도: {}%", center.get_health_score());
    println!("    최근 로그:");
    for log in center.logs.iter().rev().take(3) {
        println!("      - {}", log.message);
    }

    println!("\n  💡 핵심: 모든 개념을 통합한 완전한 시스템을 구축했습니다.\n");
}

