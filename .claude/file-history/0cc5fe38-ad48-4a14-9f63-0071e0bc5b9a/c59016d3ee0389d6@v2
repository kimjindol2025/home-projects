// 🧠 v9.0: Box<T>와 힙 할당 (Box and Heap Allocation)
// 🔗 "메모리 위치의 최적화"
// 🎯 "크기가 런타임에 결정되는 데이터를 다루기"
//
// 핵심 개념:
// - Box<T>: 스마트 포인터로 힙에 데이터 할당
// - 재귀적 데이터 구조: 컴파일 타임 크기 미정 문제 해결
// - 메모리 효율성: 거대한 데이터 이동 비용 감소
// - RAII: 스코프 벗어나면 자동 메모리 해제

use std::fmt;

fn main() {
    println!("╔══════════════════════════════════════════════════════════╗");
    println!("║ v9.0: Box<T>와 힙 할당 (Box and Heap Allocation)        ║");
    println!("║ \"메모리 위치의 최적화\"                                 ║");
    println!("╚══════════════════════════════════════════════════════════╝\n");

    // ==================== 섹션 1: 메모리 구조 ====================
    println!("📌 섹션 1: 메모리 구조 (Stack vs Heap)\n");
    {
        println!("스택 (Stack):");
        println!("  ✅ 빠름");
        println!("  ✅ LIFO 순서");
        println!("  ❌ 크기가 컴파일 타임에 정해져야 함");
        println!("  ❌ 크기가 제한적");
        println!("  ❌ 함수 스코프 벗어나면 자동 해제");
        println!();

        println!("힙 (Heap):");
        println!("  ✅ 유연함");
        println!("  ✅ 크기가 런타임에 결정 가능");
        println!("  ✅ 크기 제한이 적음");
        println!("  ❌ 느림");
        println!("  ❌ 수동 해제 필요 (Rust에서는 자동)");
        println!();
    }

    // ==================== 섹션 2: Box 기본 ====================
    println!("📌 섹션 2: Box<T> 기본\n");
    {
        // 스택에 할당
        let stack_num: i32 = 42;
        println!("스택 할당: let stack_num: i32 = 42;");
        println!("  주소: {:p}", &stack_num);
        println!("  값: {}", stack_num);
        println!();

        // 힙에 할당 (Box)
        let heap_num: Box<i32> = Box::new(42);
        println!("힙 할당:  let heap_num: Box<i32> = Box::new(42);");
        println!("  Box 주소: {:p}", &heap_num);
        println!("  데이터 주소: {:p}", heap_num.as_ref());
        println!("  값: {}", heap_num);
        println!();
    }

    // ==================== 섹션 3: 컴파일 타임 크기 문제 ====================
    println!("📌 섹션 3: 컴파일 타임 크기 문제\n");
    {
        println!("문제: 재귀적 열거형의 크기");
        println!();

        println!("❌ Box 없이:");
        println!("enum GogsNode {{");
        println!("    Data(i32, GogsNode),  // 크기 = 4 + ? (무한!)");
        println!("    Nil,");
        println!("}}");
        println!("→ 컴파일 에러: \"type GogsNode has infinite size\"");
        println!();

        println!("✅ Box 사용:");
        println!("enum GogsNode {{");
        println!("    Data(i32, Box<GogsNode>),  // 크기 = 4 + 8 (고정!)");
        println!("    Nil,");
        println!("}}");
        println!("→ 컴파일 성공!");
        println!();
    }

    // ==================== 섹션 4: 연결 리스트 구현 ====================
    println!("📌 섹션 4: 연결 리스트 (Cons List)\n");
    {
        // 간단한 Cons 리스트 정의
        #[derive(Debug, Clone)]
        enum ConsList {
            Cons(i32, Box<ConsList>),
            Nil,
        }

        // 리스트 생성: 1 -> 2 -> 3 -> Nil
        let list = ConsList::Cons(1,
            Box::new(ConsList::Cons(2,
                Box::new(ConsList::Cons(3,
                    Box::new(ConsList::Nil))))));

        println!("리스트 생성: 1 -> 2 -> 3 -> Nil");
        println!("구조: {:?}", list);
        println!();

        // 리스트 순회
        println!("리스트 순회:");
        let mut current = &list;
        loop {
            match current {
                ConsList::Cons(value, rest) => {
                    println!("  데이터: {}", value);
                    current = rest;
                }
                ConsList::Nil => {
                    println!("  끝");
                    break;
                }
            }
        }
        println!();
    }

    // ==================== 섹션 5: 메모리 레이아웃 ====================
    println!("📌 섹션 5: 메모리 레이아웃\n");
    {
        println!("스택에 저장된 경우:");
        println!("  [i32: 1][i32: 2][i32: 3]");
        println!("  → 큰 데이터면 스택 오버플로우");
        println!();

        println!("Box를 사용한 경우:");
        println!("  스택:  [Ptr] → [Ptr] → [Ptr] → Nil");
        println!("  힙:   [i32:1] [i32:2] [i32:3]");
        println!("  → 포인터(8바이트)만 스택에 저장");
        println!();
    }

    // ==================== 섹션 6: 소유권과 이동 ====================
    println!("📌 섹션 6: 소유권과 이동\n");
    {
        // 큰 구조체
        #[derive(Debug)]
        struct HugeData {
            data: Vec<i32>,
        }

        let huge = HugeData {
            data: vec![1, 2, 3],
        };

        println!("큰 구조체를 함수에 전달:");
        println!("  HugeData 크기: {} 바이트", std::mem::size_of::<HugeData>());
        println!();

        println!("❌ 소유권 이동 (비효율):");
        println!("fn process(data: HugeData) {{ ... }}");
        println!("process(huge);  // 전체 데이터 복사!");
        println!();

        println!("✅ Box 사용 (효율적):");
        println!("fn process(data: Box<HugeData>) {{ ... }}");
        println!("let boxed = Box::new(huge);");
        println!("process(boxed);  // 포인터만 이동");
        println!();
    }

    // ==================== 섹션 7: 트레이트 객체 소개 ====================
    println!("📌 섹션 7: 트레이트 객체\n");
    {
        println!("일반적인 제네릭 (컴파일 타임 다형성):");
        println!("  fn print<T: Display>(t: T) {{ ... }}");
        println!("  → 컴파일 시 각 타입별로 함수 생성");
        println!();

        println!("트레이트 객체 (런타임 다형성):");
        println!("  fn print(t: &dyn Display) {{ ... }}");
        println!("  → 런타임에 실제 타입 결정");
        println!("  → Box<dyn Trait>로 소유권 획득 가능");
        println!();
    }

    // ==================== 섹션 8: 패턴 비교 ====================
    println!("📌 섹션 8: 스택 vs 힙 패턴 비교\n");
    {
        println!("패턴 1: 스택 할당 (단순 타입)");
        println!("  let num = 42;");
        println!("  → 빠르고 간단");
        println!();

        println!("패턴 2: Box 할당 (거대한 데이터)");
        println!("  let big = Box::new(huge_struct);");
        println!("  → 포인터만 이동, 데이터는 힙에");
        println!();

        println!("패턴 3: 재귀적 구조");
        println!("  enum Node {{ Data(Box<Node>), Nil }}");
        println!("  → 컴파일 타임 크기 미정 문제 해결");
        println!();

        println!("패턴 4: 트레이트 객체");
        println!("  Box<dyn Trait>");
        println!("  → 다양한 타입을 하나의 변수에");
        println!();
    }

    // ==================== 섹션 9: RAII (자동 메모리 해제) ====================
    println!("📌 섹션 9: RAII (Resource Acquisition Is Initialization)\n");
    {
        println!("중요: Box는 Drop trait을 구현합니다");
        println!();

        {
            let boxed = Box::new(42);
            println!("Box 생성: {:?}", boxed);
            println!("  메모리 할당됨");
        }
        // ← 스코프 벗어남 → 자동으로 해제

        println!("스코프 벗어남 → 자동 메모리 해제");
        println!("  rust의 RAII 패턴: 획득한 리소스는 자동 해제");
        println!();
    }

    // ==================== 섹션 10: 실전 예제 ====================
    println!("📌 섹션 10: 실전 예제\n");
    {
        // 이진 트리 구조
        #[derive(Debug)]
        enum BinaryTree {
            Node(i32, Box<BinaryTree>, Box<BinaryTree>),
            Empty,
        }

        let tree = BinaryTree::Node(1,
            Box::new(BinaryTree::Node(2,
                Box::new(BinaryTree::Empty),
                Box::new(BinaryTree::Empty))),
            Box::new(BinaryTree::Node(3,
                Box::new(BinaryTree::Empty),
                Box::new(BinaryTree::Empty))));

        println!("이진 트리 구조:");
        println!("    1");
        println!("   / \\");
        println!("  2   3");
        println!();
        println!("구현: {:?}", tree);
        println!();
    }

    // ==================== 섹션 11: 설계 원칙 ====================
    println!("📌 섹션 11: v9.0 설계 원칙\n");
    {
        println!("Box를 사용해야 하는 3가지 상황:");
        println!();

        println!("1️⃣  컴파일 타임 크기 미정");
        println!("   enum Node {{ Data(Box<Node>), Nil }}");
        println!("   → 재귀적 구조는 Box 필수");
        println!();

        println!("2️⃣  메모리 이동 비용 절감");
        println!("   fn process(data: Box<HugeStruct>)");
        println!("   → 거대한 구조체는 포인터만 이동");
        println!();

        println!("3️⃣  트레이트 객체");
        println!("   Box<dyn Trait>");
        println!("   → 다양한 타입을 하나로 다루기");
        println!();

        println!("언제 Box를 쓰면 안 되는가:");
        println!("  ❌ 작은 타입 (i32, bool, String 등)");
        println!("  ❌ 이미 참조를 사용하는 경우");
        println!("  ❌ 공유 소유권이 필요한 경우 (다음: Rc<T>)");
        println!();
    }

    println!(\"═══════════════════════════════════════════════════════════\");
    println!(\"🎓 v9.0 완료: 힙 메모리의 마스터\");
    println!();
    println!(\"당신은 이제:\");
    println!(\"✅ Box<T>로 힙에 데이터를 할당한다\");
    println!(\"✅ 재귀적 데이터 구조를 설계한다\");
    println!(\"✅ 메모리 효율성을 고려한다\");
    println!(\"✅ 스마트 포인터의 기초를 이해한다\");
    println!();
    println!(\"저장 필수 너는 기록이 증명이다 gogs\");
}
