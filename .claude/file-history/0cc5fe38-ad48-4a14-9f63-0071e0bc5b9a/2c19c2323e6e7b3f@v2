/// 표현식 (값을 반환하는 것들)
#[derive(Debug, Clone)]
pub enum Expression {
    /// 정수 리터럴: 42
    IntegerLiteral(i64),

    /// 불리언 리터럴: true, false
    BooleanLiteral(bool),

    /// 식별자: x, name
    Identifier(String),

    /// 전위 연산: !x, -5
    Prefix(String, Box<Expression>),

    /// 중위 연산: x + y
    Infix(String, Box<Expression>, Box<Expression>),

    /// 함수 호출: f(x, y)
    Call(Box<Expression>, Vec<Expression>),

    /// 조건식: if x > 5 { ... } else { ... }
    If {
        condition: Box<Expression>,
        consequence: Block,
        alternative: Option<Block>,
    },

    /// 루프: while x < 10 { ... }
    While {
        condition: Box<Expression>,
        body: Block,
    },

    /// 블록: { let x = 10; x + 1 }
    Block(Block),

    /// 함수 정의: fn(x, y) { x + y }
    FunctionLiteral {
        parameters: Vec<String>,
        body: Block,
    },

    /// 반환값: return 5
    ReturnValue(Box<Expression>),

    /// 배열: [1, 2, 3]
    Array(Vec<Expression>),

    /// 색인: arr[0]
    Index(Box<Expression>, Box<Expression>),

    /// Null: null
    Null,
}

/// 블록 - 여러 문장의 시퀀스
#[derive(Debug, Clone)]
pub struct Block {
    pub statements: Vec<Statement>,
}

impl Block {
    pub fn new(statements: Vec<Statement>) -> Self {
        Block { statements }
    }
}

/// 문장 (실행되는 것들)
#[derive(Debug, Clone)]
pub enum Statement {
    /// 변수 선언: let x = 10;
    Let {
        name: String,
        value: Expression,
    },

    /// 표현식 문장: x + 1;
    Expression(Expression),

    /// 반환: return 42;
    Return(Expression),
}

impl Statement {
    pub fn expression(expr: Expression) -> Self {
        Statement::Expression(expr)
    }

    pub fn let_statement(name: String, value: Expression) -> Self {
        Statement::Let { name, value }
    }

    pub fn return_statement(value: Expression) -> Self {
        Statement::Return(value)
    }
}

/// 프로그램 - 문장들의 최상위 시퀀스
#[derive(Debug, Clone)]
pub struct Program {
    pub statements: Vec<Statement>,
}

impl Program {
    pub fn new(statements: Vec<Statement>) -> Self {
        Program { statements }
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_if_expression() {
        let if_expr = Expression::If {
            condition: Box::new(Expression::BooleanLiteral(true)),
            consequence: Block::new(vec![Statement::expression(
                Expression::IntegerLiteral(42),
            )]),
            alternative: Some(Block::new(vec![Statement::expression(
                Expression::IntegerLiteral(0),
            )])),
        };

        match if_expr {
            Expression::If {
                condition: _,
                consequence: _,
                alternative: _,
            } => {}
            _ => panic!("Expected If expression"),
        }
    }

    #[test]
    fn test_while_expression() {
        let while_expr = Expression::While {
            condition: Box::new(Expression::Infix(
                "<".to_string(),
                Box::new(Expression::Identifier("x".to_string())),
                Box::new(Expression::IntegerLiteral(10)),
            )),
            body: Block::new(vec![Statement::expression(Expression::IntegerLiteral(1))]),
        };

        match while_expr {
            Expression::While {
                condition: _,
                body: _,
            } => {}
            _ => panic!("Expected While expression"),
        }
    }

    #[test]
    fn test_block() {
        let block = Block::new(vec![
            Statement::let_statement(
                "x".to_string(),
                Expression::IntegerLiteral(10),
            ),
            Statement::expression(Expression::Identifier("x".to_string())),
        ]);

        assert_eq!(block.statements.len(), 2);
    }
}
