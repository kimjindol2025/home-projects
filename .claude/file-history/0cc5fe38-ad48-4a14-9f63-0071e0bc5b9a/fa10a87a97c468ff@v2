/// Alert 트레이트: 경고 및 로깅 규약
///
/// [특징]
/// - alert_message(): 기본 구현 포함 (필수 아님)
/// - log_alert(): 필수 구현 (각 타입이 구현해야 함)
trait Alert {
    /// 경고 메시지 반환 (기본 구현)
    ///
    /// 대부분의 시스템은 이 기본 메시지를 사용하지만,
    /// 특수한 시스템은 이를 오버라이딩할 수 있습니다.
    fn alert_message(&self) -> String {
        "⚠️ 시스템 일반 경고 발생".to_string()
    }

    /// 경고 로그 기록 (필수 구현)
    ///
    /// 각 구현체는 자신만의 방식으로 로그를 기록해야 합니다.
    /// 세미콜론으로 끝나므로 반드시 구현 필요.
    fn log_alert(&self);

    /// 경고 심각도 반환 (기본 구현)
    fn severity(&self) -> u8 {
        5  // 기본 심각도: 중간
    }

    /// 전체 경고 정보 (기본 구현에서 다른 메서드 활용)
    fn full_alert(&self) -> String {
        format!(
            "[심각도: {}] {}",
            self.severity(),
            self.alert_message()
        )
    }
}

