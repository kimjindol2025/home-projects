/// 전원 관리: 기본 구현 최대 활용
struct PowerManagement {
    battery_level: u8,
}

impl PowerManagement {
    fn new(battery_level: u8) -> Self {
        PowerManagement { battery_level }
    }
}

impl Alert for PowerManagement {
    // alert_message: 기본값 사용

    fn severity(&self) -> u8 {
        if self.battery_level > 50 {
            0
        } else if self.battery_level > 20 {
            5
        } else {
            9
        }
    }

    fn log_alert(&self) {
        println!(
            "  [LOG] 전원 상태 기록: {}%",
            self.battery_level
        );
    }
}

