// 다형성 활용: 모든 Alert 구현체를 통일된 인터페이스로 처리
// ===================================================================

/// 경고 센터: 모든 Alert 구현체를 관리
struct AlertCenter {
    systems: Vec<Box<dyn Alert>>,
}

impl AlertCenter {
    fn new() -> Self {
        AlertCenter {
            systems: Vec::new(),
        }
    }

    /// 시스템 등록 (다형성)
    fn register_system(&mut self, system: Box<dyn Alert>) {
        self.systems.push(system);
    }

    /// 모든 시스템의 경고 확인
    fn check_all_alerts(&self) {
        println!("\n╔═══════════════════════════════════════╗");
        println!("║ 경고 센터: 모든 시스템 상태 점검");
        println!("╚═══════════════════════════════════════╝\n");

        for (idx, system) in self.systems.iter().enumerate() {
            println!("  [시스템 {}]", idx + 1);
            println!("    {}", system.full_alert());  // 기본 구현 활용
            system.log_alert();
            println!();
        }
    }

    /// 심각도 순으로 정렬된 경고 목록
    fn get_sorted_alerts(&self) -> Vec<(usize, u8, String)> {
        let mut alerts: Vec<(usize, u8, String)> = self
            .systems
            .iter()
            .enumerate()
            .map(|(idx, system)| (idx, system.severity(), system.alert_message()))
            .collect();

        // 심각도 순으로 정렬 (높을수록 먼저)
        alerts.sort_by(|a, b| b.1.cmp(&a.1));
        alerts
    }

    /// 심각도가 임계값 이상인 경고만 표시
    fn show_critical_alerts(&self, threshold: u8) {
        println!("\n╔═══════════════════════════════════════╗");
        println!("║ 🚨 긴급 경고 (심각도: {} 이상)", threshold);
        println!("╚═══════════════════════════════════════╝\n");

        let critical: Vec<_> = self
            .get_sorted_alerts()
            .into_iter()
            .filter(|(_, severity, _)| *severity >= threshold)
            .collect();

        if critical.is_empty() {
            println!("  ✅ 긴급 경고 없음\n");
            return;
        }

        for (idx, severity, message) in critical {
            println!("  [시스템 {}] (심각도: {}) {}", idx + 1, severity, message);
        }
        println!();
    }
}

