/// 핵심 엔진: 기본 구현 대부분 사용
struct CoreEngine {
    name: String,
}

impl CoreEngine {
    fn new(name: &str) -> Self {
        CoreEngine {
            name: name.to_string(),
        }
    }
}

impl Alert for CoreEngine {
    // alert_message는 기본값 사용 (오버라이딩 X)
    // severity는 기본값 사용 (오버라이딩 X)
    // full_alert는 자동으로 위의 메서드들을 활용

    // log_alert만 필수 구현
    fn log_alert(&self) {
        println!("  [LOG] {} 엔진 로그 기록 중...", self.name);
    }
}

/// 보안 모듈: 기본 구현을 오버라이딩
struct SecurityModule {
    threat_level: u8,
}

impl SecurityModule {
    fn new(threat_level: u8) -> Self {
        SecurityModule { threat_level }
    }
}

impl Alert for SecurityModule {
    // alert_message 오버라이딩 (기본값 무시)
    fn alert_message(&self) -> String {
        match self.threat_level {
            0..=3 => "🔵 보안 경고: 낮음 수준".to_string(),
            4..=6 => "🟡 보안 경고: 중간 수준".to_string(),
            7..=9 => "🔴 보안 경고: 높음 수준".to_string(),
            _ => "🚨 보안 경고: 긴급! 침입 감지!".to_string(),
        }
    }

    // severity 오버라이딩 (위협 수준 반영)
    fn severity(&self) -> u8 {
        self.threat_level
    }

    // log_alert 필수 구현
    fn log_alert(&self) {
        println!(
            "  [LOG] 보안 이벤트 데이터베이스 전송 (위협도: {})",
            self.threat_level
        );
    }
}

/// 네트워크 모니터: 모든 메서드를 커스터마이징
struct NetworkMonitor {
    packet_loss: f32,
}

impl NetworkMonitor {
    fn new(packet_loss: f32) -> Self {
        NetworkMonitor { packet_loss }
    }
}

impl Alert for NetworkMonitor {
    fn alert_message(&self) -> String {
        format!(
            "📡 네트워크 경고: 패킷 손실 {:.1}%",
            self.packet_loss
        )
    }

    fn severity(&self) -> u8 {
        if self.packet_loss < 1.0 {
            1
        } else if self.packet_loss < 5.0 {
            3
        } else if self.packet_loss < 10.0 {
            7
        } else {
            10
        }
    }

    fn log_alert(&self) {
        println!("  [LOG] 네트워크 진단 도구 시작... 손실: {:.1}%", self.packet_loss);
    }
}

