//! Gogs 프로젝트: 코어 기능 모듈
//!
//! 이 모듈은 다양한 러스트 개념을 구현합니다:
//! - Phase 2: 제어 흐름 (if/else, match, loop)
//! - Phase 3: 소유권 (Move, Borrowing, References)
//! - Phase 4: 구조체와 열거형 (Structs, Enums, impl)

/// Gogs 프로젝트의 상태를 판별하는 함수입니다.
///
/// # 인자
/// * `value` - 상태를 판별할 정수값 (i32)
///
/// # 반환값
/// * `&'static str` - 상태에 따른 메시지
///
/// # 로직
/// - 7이면 'Gogs Luck!' (행운의 숫자)
/// - 10 이상이면 'Senior Goal!' (시니어 목표)
/// - 그 외에는 'Keep Going!' (계속 진행)
///
/// # 예제
/// ```
/// let result = check_gogs_status(7);
/// assert_eq!(result, "Gogs Luck!");
/// ```
pub fn check_gogs_status(value: i32) -> &'static str {
    match value {
        7 => "Gogs Luck! 🍀",
        10..=i32::MAX => "Senior Goal! 🚀",
        _ => "Keep Going! 💪",
    }
}

/// 레벨별 학습 목표를 반환합니다.
///
/// # 인자
/// * `level` - 현재 레벨 (i32)
///
/// # 반환값
/// * `&'static str` - 레벨에 해당하는 학습 목표
///
/// # 예제
/// ```
/// let goal = get_level_goal(1);
/// assert_eq!(goal, "기초 변수 확립");
/// ```
pub fn get_level_goal(level: i32) -> &'static str {
    match level {
        1 => "기초 변수 확립",
        2 => "논리 구조 설계",
        3 => "소유권 개념 파악",
        4 => "구조체와 메서드",
        5 => "Trait과 다형성",
        _ => "미지의 영역 탐험",
    }
}

/// 학습 상태를 평가하는 함수입니다.
///
/// # 인자
/// * `hours` - 학습한 시간 (u32)
///
/// # 반환값
/// * `&'static str` - 평가 결과
// ==========================================
// Phase 3: 소유권 (Ownership)
// ==========================================

/// 문자열의 길이를 계산합니다 (불변 참조 사용).
///
/// # 인자
/// * `s` - 불변 참조로 빌린 문자열
///
/// # 반환값
/// * `usize` - 문자열의 길이
///
/// # 특징
/// - &String을 사용하여 소유권을 빌려옴
/// - 함수가 끝나도 원본 s는 여전히 유효함
///
/// # 예제
/// ```
/// let s = String::from("Gogs");
/// let len = calculate_length(&s);
/// println!("{} → {}", s, len);  // 여전히 s 사용 가능
/// ```
pub fn calculate_length(s: &String) -> usize {
    s.len()
}
// 여기서 s는 범위를 벗어나지만, 빌린 것이므로 원본은 삭제되지 않음

/// 문자열에 접미사를 추가합니다 (가변 참조 사용).
///
/// # 인자
/// * `s` - 가변 참조로 빌린 문자열 (&mut String)
///
/// # 동작
/// - 원본 문자열을 수정함
/// - " - processed" 텍스트 추가
///
/// # 예제
/// ```
/// let mut s = String::from("Data");
/// add_suffix(&mut s);
/// // s는 이제 "Data - processed"
/// ```
pub fn add_suffix(s: &mut String) {
    s.push_str(" - processed");
}

/// 두 문자열 중 더 긴 것의 소유권을 반환합니다 (핵심 과제).
///
/// # 인자
/// * `s1` - 첫 번째 문자열 (참조)
/// * `s2` - 두 번째 문자열 (참조)
///
/// # 반환값
/// * `String` - 더 긴 문자열의 복사본 (소유권 보유)
///
/// # 로직
/// - s1과 s2의 길이를 비교
/// - 더 긴 문자열을 새로운 String으로 반환
/// - 빌림 검사기를 만족하는 설계
///
/// # 예제
/// ```
/// let s1 = String::from("Rust");
/// let s2 = String::from("Ownership");
/// let longer = get_longer(&s1, &s2);
/// // longer = "Ownership" (소유권 있음)
/// // s1, s2는 여전히 유효 (참조만 빌렸으므로)
/// ```
pub fn get_longer(s1: &String, s2: &String) -> String {
    if s1.len() > s2.len() {
        s1.clone()  // 더 긴 문자열 복사
    } else {
        s2.clone()
    }
}

// ==========================================
// Phase 4: 구조체와 열거형
// ==========================================

/// 프로그래밍 언어의 특징을 나타내는 열거형
#[derive(Debug, Clone, Copy, PartialEq)]
pub enum Feature {
    /// 메모리 안전성 (Rust, Go)
    Safety,
    /// 실행 속도 (C, C++, Rust)
    Speed,
    /// 배우기 쉬움 (Python, JavaScript)
    Simplicity,
}

impl Feature {
    /// 특징을 설명하는 텍스트를 반환합니다.
    pub fn description(&self) -> &'static str {
        match self {
            Feature::Safety => "메모리 안전성을 보장합니다",
            Feature::Speed => "매우 빠른 실행 속도를 자랑합니다",
            Feature::Simplicity => "배우기 쉬운 문법을 제공합니다",
        }
    }
}

/// 프로그래밍 언어의 정보를 담는 구조체
#[derive(Debug)]
pub struct Language {
    /// 언어의 이름
    pub name: String,
    /// 다목적성 점수 (0-100)
    pub versatility: u8,
    /// 주요 특징
    pub feature: Feature,
}

impl Language {
    /// 언어 정보를 전체 출력하는 메서드
    pub fn display_info(&self) {
        println!("📚 언어 정보");
        println!("  이름: {}", self.name);
        println!("  다목적성: {}%", self.versatility);
        println!("  주요 특징: {:?}", self.feature);
        println!("  설명: {}", self.feature.description());
        println!("  저장 필수, 너는 기록이 증명이다 gogs 🔥");
    }

    /// 언어의 다목적성을 평가합니다.
    pub fn evaluate_versatility(&self) -> &'static str {
        match self.versatility {
            0..=30 => "특수 목적 언어",
            31..=60 => "범용 언어",
            61..=85 => "매우 범용적인 언어",
            86..=100 => "거의 모든 분야에 사용 가능",
            _ => "등급 불명",
        }
    }

    /// 새로운 Language 인스턴스를 생성하는 연관 함수
    pub fn new(name: &str, versatility: u8, feature: Feature) -> Language {
        Language {
            name: String::from(name),
            versatility,
            feature,
        }
    }
}

pub fn evaluate_progress(hours: u32) -> &'static str {
    if hours < 1 {
        "아직 시작하지 않음"
    } else if hours < 5 {
        "시작 단계"
    } else if hours < 20 {
        "진행 중"
    } else if hours < 50 {
        "중급 진행"
    } else {
        "시니어 수준"
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_check_gogs_status_lucky() {
        assert_eq!(check_gogs_status(7), "Gogs Luck! 🍀");
    }

    #[test]
    fn test_check_gogs_status_senior() {
        assert_eq!(check_gogs_status(10), "Senior Goal! 🚀");
        assert_eq!(check_gogs_status(15), "Senior Goal! 🚀");
    }

    #[test]
    fn test_check_gogs_status_keep_going() {
        assert_eq!(check_gogs_status(5), "Keep Going! 💪");
        assert_eq!(check_gogs_status(8), "Keep Going! 💪");
    }

    #[test]
    fn test_get_level_goal() {
        assert_eq!(get_level_goal(1), "기초 변수 확립");
        assert_eq!(get_level_goal(2), "논리 구조 설계");
        assert_eq!(get_level_goal(3), "소유권 개념 파악");
    }

    #[test]
    fn test_evaluate_progress() {
        assert_eq!(evaluate_progress(0), "아직 시작하지 않음");
        assert_eq!(evaluate_progress(3), "시작 단계");
        assert_eq!(evaluate_progress(10), "진행 중");
        assert_eq!(evaluate_progress(30), "중급 진행");
        assert_eq!(evaluate_progress(60), "시니어 수준");
    }

    // ==========================================
    // Phase 3: 소유권 (Ownership) 테스트
    // ==========================================

    #[test]
    fn test_calculate_length() {
        let s: String = String::from("Gogs Ownership");
        let len: usize = calculate_length(&s);
        assert_eq!(len, 14);
        // s는 여전히 유효함 (빌려준 것뿐)
        assert_eq!(s, "Gogs Ownership");
    }

    #[test]
    fn test_add_suffix() {
        let mut s: String = String::from("Phase 3");
        add_suffix(&mut s);
        assert_eq!(s, "Phase 3 - processed");
    }

    #[test]
    fn test_get_longer_first_longer() {
        let s1: String = String::from("Rust Programming");
        let s2: String = String::from("is");
        let longer: String = get_longer(&s1, &s2);
        assert_eq!(longer, "Rust Programming");
    }

    #[test]
    fn test_get_longer_second_longer() {
        let s1: String = String::from("Fun");
        let s2: String = String::from("Ownership System");
        let longer: String = get_longer(&s1, &s2);
        assert_eq!(longer, "Ownership System");
    }

    #[test]
    fn test_get_longer_equal_length() {
        let s1: String = String::from("Same!");
        let s2: String = String::from("Sizes");
        let longer: String = get_longer(&s1, &s2);
        // s2가 더 길지 않으면 s1의 복사본 반환
        assert_eq!(longer, "Same!");
    }

    #[test]
    fn test_ownership_move() {
        let s1: String = String::from("Move Test");
        let s2: String = s1;  // 소유권 이동
        assert_eq!(s2, "Move Test");
        // s1은 더 이상 유효하지 않음 (컴파일러가 확인)
    }

    #[test]
    fn test_borrowing_multiple_refs() {
        let s: String = String::from("Multiple Borrows");
        let len1: usize = calculate_length(&s);
        let len2: usize = calculate_length(&s);
        assert_eq!(len1, len2);
        assert_eq!(len1, 16);
        // s는 여전히 유효함 (여러 번 빌려줌)
    }

    // ==========================================
    // Phase 4: 구조체와 열거형 테스트
    // ==========================================

    #[test]
    fn test_feature_description() {
        assert_eq!(Feature::Safety.description(), "메모리 안전성을 보장합니다");
        assert_eq!(Feature::Speed.description(), "매우 빠른 실행 속도를 자랑합니다");
        assert_eq!(Feature::Simplicity.description(), "배우기 쉬운 문법을 제공합니다");
    }

    #[test]
    fn test_language_new() {
        let lang: Language = Language::new("Rust", 90, Feature::Safety);
        assert_eq!(lang.name, "Rust");
        assert_eq!(lang.versatility, 90);
        assert_eq!(lang.feature, Feature::Safety);
    }

    #[test]
    fn test_language_evaluate_versatility() {
        let low: Language = Language::new("CUDA", 15, Feature::Speed);
        assert_eq!(low.evaluate_versatility(), "특수 목적 언어");

        let medium: Language = Language::new("Java", 50, Feature::Safety);
        assert_eq!(medium.evaluate_versatility(), "범용 언어");

        let high: Language = Language::new("Python", 85, Feature::Simplicity);
        assert_eq!(high.evaluate_versatility(), "매우 범용적인 언어");

        let very_high: Language = Language::new("JavaScript", 95, Feature::Simplicity);
        assert_eq!(very_high.evaluate_versatility(), "거의 모든 분야에 사용 가능");
    }

    #[test]
    fn test_language_struct() {
        let rust: Language = Language {
            name: String::from("Rust"),
            versatility: 95,
            feature: Feature::Safety,
        };

        assert_eq!(rust.name, "Rust");
        assert_eq!(rust.versatility, 95);
        assert!(rust.feature == Feature::Safety);
    }
}
