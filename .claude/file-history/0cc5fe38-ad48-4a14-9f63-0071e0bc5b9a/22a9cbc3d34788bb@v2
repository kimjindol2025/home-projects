// ============================================================================
// Section 9️⃣: If 표현식 (조건문)
// ============================================================================
fn section_9_if_expression() {
    println!("█ Section 9️⃣: If 표현식 (조건문)");
    println!("  {}", "═".repeat(60));

    let program = Program::new(vec![Statement::Expression(Expression::If {
        condition: Box::new(Expression::Integer(5)),
        consequence: vec![Statement::Expression(Expression::Integer(10))],
        alternative: Some(vec![Statement::Expression(Expression::Integer(20))]),
    })]);

    println!("📝 원본 코드:");
    println!("   if 5 {{ 10 }} else {{ 20 }}\n");

    println!("📌 컴파일 과정:");
    println!("   1. 조건식 컴파일");
    println!("   2. OpJumpNotTruthy 점프 명령어 (목표 미정)");
    println!("   3. consequence 블록 컴파일");
    println!("   4. 점프 목표 수정 (backfilling)");
    println!("   5. alternative 블록 컴파일\n");

    let bytecode = compile(&program).unwrap();

    println!("🔧 바이트코드 생성:");
    println!("{}\n", disassemble_bytecode(&bytecode));
}

// ============================================================================
// Section 🔟: 함수 호출
// ============================================================================
fn section_10_function_call() {
    println!("█ Section 🔟: 함수 호출");
    println!("  {}", "═".repeat(60));

    let program = Program::new(vec![Statement::Expression(Expression::Call {
        function: Box::new(Expression::Identifier("add".to_string())),
        arguments: vec![Expression::Integer(5), Expression::Integer(3)],
    })]);

    println!("📝 원본 코드:");
    println!("   add(5, 3)\n");

    println!("📌 컴파일 과정:");
    println!("   1. 함수명 컴파일");
    println!("   2. 각 인자 순서대로 컴파일");
    println!("   3. OpCall N 명령어 (N=인자 개수)\n");

    match compile(&program) {
        Ok(bytecode) => {
            println!("🔧 바이트코드 생성:");
            println!("{}\n", disassemble_bytecode(&bytecode));
        }
        Err(e) => {
            println!("⚠️  참고: {}\n", e);
            println!("💡 식별자는 v15.2 (Virtual Machine)에서 구현됩니다.\n");
        }
    }

    println!("⚙️ 예상 실행 시뮬레이션 (v15.2에서):");
    println!("   스택: []");
    println!("   → OpGetLocal 0 (함수 가져오기) → [func]");
    println!("   → OpConstant 0 (5) → [func, 5]");
    println!("   → OpConstant 1 (3) → [func, 5, 3]");
    println!("   → OpCall 2 → [결과]\n");
}

// ============================================================================
// Section 1️⃣1️⃣: 복잡한 표현식
// ============================================================================
fn section_11_complex_expression() {
    println!("█ Section 1️⃣1️⃣: 복잡한 표현식");
    println!("  {}", "═".repeat(60));

    let program = Program::new(vec![
        Statement::Expression(Expression::Infix(
            "+".to_string(),
            Box::new(Expression::Infix(
                "*".to_string(),
                Box::new(Expression::Integer(2)),
                Box::new(Expression::Integer(3)),
            )),
            Box::new(Expression::Infix(
                "-".to_string(),
                Box::new(Expression::Integer(10)),
                Box::new(Expression::Integer(5)),
            )),
        )),
    ]);

    println!("📝 원본 코드:");
    println!("   2 * 3 + 10 - 5\n");

    println!("📌 AST 구조:");
    println!("   덧셈(곱셈(2, 3), 뺄셈(10, 5))\n");

    let bytecode = compile(&program).unwrap();

    println!("🔧 바이트코드 생성:");
    println!("{}\n", disassemble_bytecode(&bytecode));

    println!("⚙️ 단계별 실행:");
    println!("   1. 2 * 3 = 6");
    println!("   2. 10 - 5 = 5");
    println!("   3. 6 + 5 = 11\n");
}

// ============================================================================
// Section 1️⃣2️⃣: 바이트코드 아키텍처
// ============================================================================
fn section_12_bytecode_architecture() {
    println!("█ Section 1️⃣2️⃣: 바이트코드 아키텍처");
    println!("  {}", "═".repeat(60));

    println!("🏗️ 핵심 설계 원칙:\n");

    println!("1️⃣  Post-order 순회");
    println!("    └─ 왼쪽 자식 → 오른쪽 자식 → 부모");
    println!("    └─ 스택 기반 계산에 최적\n");

    println!("2️⃣  상수 풀 (Constant Pool)");
    println!("    └─ 정수 리터럴을 한 번만 저장");
    println!("    └─ 인덱스로 참조 (효율적)\n");

    println!("3️⃣  OpCode 명령어");
    println!("    └─ 0~255 범위의 u8 바이트");
    println!("    └─ 피연산자: 1바이트 또는 2바이트\n");

    println!("4️⃣  점프 백필링 (Jump Backfilling)");
    println!("    └─ if 문의 점프 목표를 나중에 결정");
    println!("    └─ 조건부 점프 구현 가능\n");

    println!("📊 명령어 구조:");
    println!("   ┌─────────────────────────┐");
    println!("   │ Byte 0: OpCode (u8)     │");
    println!("   │ Byte 1-2: Operand (u16) │ (필요시)");
    println!("   └─────────────────────────┘\n");

    println!("🔄 컴파일 파이프라인:");
    println!("   소스 코드");
    println!("      ↓");
    println!("   AST (추상 구문 트리)");
    println!("      ↓");
    println!("   Compiler::compile()");
    println!("      ↓");
    println!("   후위 순회 및 명령어 방출");
    println!("      ↓");
    println!("   Bytecode (명령어 + 상수)\n");

    println!("💾 메모리 구조:");
    println!("   ┌──────────────────────────┐");
    println!("   │ Bytecode                 │");
    println!("   ├──────────────────────────┤");
    println!("   │ instructions: Vec<u8>    │");
    println!("   │  [OpConstant, 0, 0,      │");
    println!("   │   OpConstant, 0, 1, ...] │");
    println!("   ├──────────────────────────┤");
    println!("   │ constants: Vec<i64>      │");
    println!("   │  [42, 100, 5, ...]       │");
    println!("   └──────────────────────────┘\n");

    println!("✨ v15.1의 역할:");
    println!("   ✓ 소스 코드를 바이트코드로 변환");
    println!("   ✓ 스택 기반 실행 준비");
    println!("   ✓ v15.2에서 VM이 실행\n");

    println!("🚀 다음 단계 (v15.2):");
    println!("   └─ Virtual Machine 구현");
    println!("   └─ 바이트코드 실행 엔진\n");
}
