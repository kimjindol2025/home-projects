    println!("   · OpFalse: 스택에 false 푸시\n");
}

// ============================================================================
// Section 3️⃣: 산술 표현식 컴파일
// ============================================================================
fn section_3_arithmetic_expression() {
    println!("█ Section 3️⃣: 산술 표현식 컴파일");
    println!("  {}", "═".repeat(60));

    let program = Program::new(vec![Statement::Expression(Expression::Infix(
        "+".to_string(),
        Box::new(Expression::Integer(5)),
        Box::new(Expression::Integer(3)),
    ))]);

    println!("📝 원본 코드:");
    println!("   5 + 3\n");

    println!("📌 후위 순회(Post-order):");
    println!("   1. 왼쪽(5) 컴파일 → OpConstant 0");
    println!("   2. 오른쪽(3) 컴파일 → OpConstant 1");
    println!("   3. 연산자(+) 방출 → OpAdd\n");

    let bytecode = compile(&program).unwrap();

    println!("🔧 바이트코드 생성:");
    println!("{}\n", disassemble_bytecode(&bytecode));

    println!("⚙️ 실행 시뮬레이션:");
    println!("   스택: []");
    println!("   → OpConstant 0 → 스택: [5]");
    println!("   → OpConstant 1 → 스택: [5, 3]");
    println!("   → OpAdd → 스택: [8]\n");
}

// ============================================================================
// Section 4️⃣: 연산자 우선순위
// ============================================================================
fn section_4_operator_precedence() {
    println!("█ Section 4️⃣: 연산자 우선순위");
    println!("  {}", "═".repeat(60));

    let program = Program::new(vec![Statement::Expression(Expression::Infix(
        "+".to_string(),
        Box::new(Expression::Infix(
            "*".to_string(),
            Box::new(Expression::Integer(2)),
            Box::new(Expression::Integer(3)),
        )),
        Box::new(Expression::Integer(4)),
    ))]);

    println!("📝 원본 코드:");
    println!("   2 * 3 + 4\n");

    println!("📌 AST 구조 (우선순위 적용):");
    println!("   덧셈(곱셈(2, 3), 4)\n");

    let bytecode = compile(&program).unwrap();

    println!("🔧 바이트코드 생성:");
    println!("{}\n", disassemble_bytecode(&bytecode));

    println!("⚙️ 실행 시뮬레이션:");
    println!("   스택: []");
    println!("   → OpConstant 0 (2) → [2]");
    println!("   → OpConstant 1 (3) → [2, 3]");
    println!("   → OpMul → [6]");
    println!("   → OpConstant 2 (4) → [6, 4]");
    println!("   → OpAdd → [10]\n");
}

