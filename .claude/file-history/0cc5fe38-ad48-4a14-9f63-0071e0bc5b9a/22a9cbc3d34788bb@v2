// Section 6️⃣: 전위 연산식
// ============================================================================
fn section_6_prefix_expression() {
    println!("█ Section 6️⃣: 전위 연산식");
    println!("  {}", "═".repeat(60));

    let program1 = Program::new(vec![Statement::Expression(Expression::Prefix(
        "-".to_string(),
        Box::new(Expression::Integer(5)),
    ))]);

    println!("📝 원본 코드 (음수):");
    println!("   -5\n");

    let bytecode1 = compile(&program1).unwrap();

    println!("🔧 바이트코드 생성:");
    println!("{}\n", disassemble_bytecode(&bytecode1));

    let program2 = Program::new(vec![Statement::Expression(Expression::Prefix(
        "!".to_string(),
        Box::new(Expression::Boolean(true)),
    ))]);

    println!("📝 원본 코드 (부정):");
    println!("   !true\n");

    let bytecode2 = compile(&program2).unwrap();

    println!("🔧 바이트코드 생성:");
    println!("{}\n", disassemble_bytecode(&bytecode2));
}

