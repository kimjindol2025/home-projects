// ============================================================================
// Section 1️⃣: 정수 리터럴 컴파일
// ============================================================================
fn section_1_integer_literal() {
    println!("█ Section 1️⃣: 정수 리터럴 컴파일");
    println!("  {}", "═".repeat(60));

    let program = Program::new(vec![Statement::Expression(Expression::Integer(42))]);

    println!("📝 원본 코드:");
    println!("   42\n");

    let bytecode = compile(&program).unwrap();

    println!("🔧 바이트코드 생성:");
    println!("{}\n", disassemble_bytecode(&bytecode));

    println!("💡 해석:");
    println!("   1. 42를 상수 풀에 추가 (인덱스 0)");
    println!("   2. OpConstant 0 명령어 방출");
    println!("   → 스택에 42를 푸시합니다.\n");
}

// ============================================================================
// Section 2️⃣: 불리언 리터럴 컴파일
// ============================================================================
fn section_2_boolean_literal() {
    println!("█ Section 2️⃣: 불리언 리터럴 컴파일");
    println!("  {}", "═".repeat(60));

    let program = Program::new(vec![
        Statement::Expression(Expression::Boolean(true)),
        Statement::Expression(Expression::Boolean(false)),
    ]);

    println!("📝 원본 코드:");
    println!("   true");
    println!("   false\n");

    let bytecode = compile(&program).unwrap();

    println!("🔧 바이트코드 생성:");
    println!("{}\n", disassemble_bytecode(&bytecode));

    println!("💡 해석:");
