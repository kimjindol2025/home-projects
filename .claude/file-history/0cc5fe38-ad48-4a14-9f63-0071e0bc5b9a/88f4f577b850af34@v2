// ============================================================================
// 환경(Environment): 변수 저장소와 스코프 체인
// ============================================================================

use std::collections::HashMap;
use std::fmt;

/// 함수의 스코프 환경
#[derive(Clone, Debug)]
pub struct Environment {
    /// 이 환경의 변수 바인딩
    pub bindings: HashMap<String, i64>,

    /// 부모 환경 (스코프 체인)
    pub parent: Option<Box<Environment>>,
}

impl Environment {
    /// 새로운 글로벌 환경 생성
    pub fn global() -> Self {
        Environment {
            bindings: HashMap::new(),
            parent: None,
        }
    }

    /// 부모 환경을 가진 새로운 환경 생성 (블록/함수 스코프용)
    pub fn extend(parent: &Environment) -> Self {
        Environment {
            bindings: HashMap::new(),
            parent: Some(Box::new(parent.clone())),
        }
    }

    /// 변수 설정 (현재 환경에만)
    pub fn set(&mut self, name: String, value: i64) {
        self.bindings.insert(name, value);
    }

    /// 변수 조회 (스코프 체인 따라 검색)
    pub fn get(&self, name: &str) -> Option<i64> {
        // 현재 환경에서 찾기
        if let Some(&value) = self.bindings.get(name) {
            return Some(value);
        }

        // 부모 환경에서 찾기 (재귀)
        if let Some(parent) = &self.parent {
            return parent.get(name);
        }

        None
    }

    /// 모든 바인딩 출력
    pub fn dump(&self) {
        println!("Environment {{");
        for (name, value) in &self.bindings {
            println!("  {}: {}", name, value);
        }
        if self.parent.is_some() {
            println!("  (has parent scope)");
        }
        println!("}}");
    }

    /// 현재 환경의 깊이 반환
    pub fn depth(&self) -> usize {
        1 + self
            .parent
            .as_ref()
            .map(|p| p.depth())
            .unwrap_or(0)
    }

    /// 환경 체인 시각화
    pub fn visualize(&self) {
        self._visualize(0);
    }

    fn _visualize(&self, level: usize) {
        let indent = "  ".repeat(level);
        println!("{}Scope Level {}:", indent, level);
        for (name, value) in &self.bindings {
            println!("{}  {} = {}", indent, name, value);
        }
        if let Some(parent) = &self.parent {
            parent._visualize(level + 1);
        }
    }
}

impl fmt::Display for Environment {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        write!(f, "Environment(depth={})", self.depth())
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_environment_set_get() {
        let mut env = Environment::global();
        env.set("x".to_string(), 42);
        assert_eq!(env.get("x"), Some(42));
    }

    #[test]
    fn test_scope_chain() {
        let mut global = Environment::global();
        global.set("x".to_string(), 10);

        let mut local = Environment::extend(&global);
        local.set("y".to_string(), 20);

        assert_eq!(local.get("x"), Some(10));  // 부모에서 찾음
        assert_eq!(local.get("y"), Some(20));  // 현재에서 찾음
        assert_eq!(global.get("y"), None);     // 부모는 자식을 볼 수 없음
    }

    #[test]
    fn test_shadowing() {
        let mut global = Environment::global();
        global.set("x".to_string(), 10);

        let mut local = Environment::extend(&global);
        local.set("x".to_string(), 20);  // 같은 이름의 변수

        assert_eq!(local.get("x"), Some(20));  // 가장 가까운 환경의 값
        assert_eq!(global.get("x"), Some(10)); // 부모는 여전히 원래 값
    }
}
