// ============================================================================
// 환경 (Environment): 변수 바인딩 저장소 (심볼 테이블)
// ============================================================================
// 평가 중에 let x = 5; 같은 변수 바인딩을 저장하고 조회합니다.

use crate::object::GogsObject;
use std::collections::HashMap;
use std::rc::Rc;
use std::cell::RefCell;

/// 변수 바인딩을 저장하는 환경
#[derive(Debug, Clone)]
pub struct Environment {
    /// 이 환경의 바인딩 (let x = 5; 같은 선언)
    bindings: HashMap<String, GogsObject>,

    /// 부모 환경 (스코프 체인)
    /// 함수 호출 시 새로운 환경을 만들고 부모로 연결합니다.
    outer: Option<Rc<RefCell<Environment>>>,
}

impl Environment {
    /// 새로운 환경 생성
    pub fn new() -> Self {
        Environment {
            bindings: HashMap::new(),
            outer: None,
        }
    }

    /// 부모 환경을 가진 새로운 환경 생성 (함수 스코프용)
    pub fn with_outer(outer: Rc<RefCell<Environment>>) -> Self {
        Environment {
            bindings: HashMap::new(),
            outer: Some(outer),
        }
    }

    /// 변수를 환경에 저장
    pub fn set(&mut self, name: String, value: GogsObject) {
        self.bindings.insert(name, value);
    }

    /// 변수를 환경에서 조회
    pub fn get(&self, name: &str) -> Option<GogsObject> {
        // 현재 환경에서 찾기
        if let Some(value) = self.bindings.get(name) {
            return Some(value.clone());
        }

        // 부모 환경에서 찾기 (재귀적 스코프 체인)
        if let Some(outer) = &self.outer {
            return outer.borrow().get(name);
        }

        None
    }

    /// 모든 바인딩을 출력 (디버깅용)
    pub fn dump(&self) {
        println!("Environment bindings:");
        for (name, value) in &self.bindings {
            println!("  {} = {}", name, value);
        }
        if self.outer.is_some() {
            println!("(has parent scope)");
        }
    }
}

impl Default for Environment {
    fn default() -> Self {
        Self::new()
    }
}
