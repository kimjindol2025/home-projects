pub mod ast;
pub mod bytecode;
pub mod compiler;
pub mod disassembler;
pub mod opcode;

pub use ast::{Expression, Program, Statement};
pub use bytecode::Bytecode;
pub use compiler::Compiler;
pub use disassembler::Disassembler;
pub use opcode::OpCode;

/// 간단한 컴파일 함수
pub fn compile(program: &Program) -> Result<Bytecode, String> {
    let mut compiler = Compiler::new();
    compiler.compile(program)?;
    Ok(compiler.bytecode())
}

/// 바이트코드를 분해해서 출력
pub fn disassemble_bytecode(bytecode: &Bytecode) -> String {
    Disassembler::disassemble(bytecode)
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_compile_integer() {
        let program = Program::new(vec![Statement::Expression(Expression::Integer(42))]);

        let bytecode = compile(&program).unwrap();

        assert!(!bytecode.instructions.is_empty());
        assert_eq!(bytecode.constants.len(), 1);
        assert_eq!(bytecode.constants[0], 42);
    }

    #[test]
    fn test_compile_and_disassemble() {
        let program = Program::new(vec![Statement::Expression(Expression::Infix(
            "+".to_string(),
            Box::new(Expression::Integer(5)),
            Box::new(Expression::Integer(3)),
        ))]);

        let bytecode = compile(&program).unwrap();
        let disassembly = disassemble_bytecode(&bytecode);

        assert!(disassembly.contains("CONSTANT"));
        assert!(disassembly.contains("ADD"));
    }

    #[test]
    fn test_compile_boolean() {
        let program = Program::new(vec![Statement::Expression(Expression::Boolean(true))]);

        let bytecode = compile(&program).unwrap();

        assert!(!bytecode.instructions.is_empty());
    }

    #[test]
    fn test_compile_prefix() {
        let program = Program::new(vec![Statement::Expression(Expression::Prefix(
            "!".to_string(),
            Box::new(Expression::Boolean(true)),
        ))]);

        let bytecode = compile(&program).unwrap();
        let disassembly = disassemble_bytecode(&bytecode);

        assert!(disassembly.contains("TRUE"));
        assert!(disassembly.contains("BANG"));
    }

    #[test]
    fn test_compile_array() {
        let program = Program::new(vec![Statement::Expression(Expression::Array(vec![
            Expression::Integer(1),
            Expression::Integer(2),
            Expression::Integer(3),
        ]))]);

        let bytecode = compile(&program).unwrap();
        let disassembly = disassemble_bytecode(&bytecode);

        assert!(disassembly.contains("ARRAY"));
        assert_eq!(bytecode.constants.len(), 3);
    }

    #[test]
    fn test_compile_index() {
        let program = Program::new(vec![Statement::Expression(Expression::Index(
            Box::new(Expression::Array(vec![Expression::Integer(1), Expression::Integer(2)])),
            Box::new(Expression::Integer(0)),
        ))]);

        let bytecode = compile(&program).unwrap();
        let disassembly = disassemble_bytecode(&bytecode);

        assert!(disassembly.contains("ARRAY"));
        assert!(disassembly.contains("INDEX"));
    }

    #[test]
    fn test_compile_call() {
        // 참고: 식별자는 v15.2에서 구현 예정
        // 현재는 식별자 사용 시 에러 반환
        let program = Program::new(vec![Statement::Expression(Expression::Call {
            function: Box::new(Expression::Identifier("add".to_string())),
            arguments: vec![Expression::Integer(5), Expression::Integer(3)],
        })]);

        let result = compile(&program);
        assert!(result.is_err());
        assert!(result.unwrap_err().contains("Identifiers not yet implemented"));
    }

    #[test]
    fn test_compile_multiple_statements() {
        let program = Program::new(vec![
            Statement::Expression(Expression::Integer(10)),
            Statement::Expression(Expression::Integer(20)),
            Statement::Expression(Expression::Integer(30)),
        ]);

        let bytecode = compile(&program).unwrap();

        assert_eq!(bytecode.constants.len(), 3);
        assert_eq!(bytecode.constants[0], 10);
        assert_eq!(bytecode.constants[1], 20);
        assert_eq!(bytecode.constants[2], 30);
    }

    #[test]
    fn test_disassemble_all_instructions() {
        Disassembler::print_instructions();
        // 출력 확인용 테스트
    }
}
