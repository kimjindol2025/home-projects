## 📊 실전 패턴: 상태 머신

```rust
enum State {
    Start,
    Processing { step: u32 },
    Completed { result: String },
    Failed { error: String },
}

fn transition(state: State, action: &str) -> Result<State, String> {
    match (state, action) {
        (State::Start, "begin") => {
            Ok(State::Processing { step: 1 })
        }
        (State::Processing { step }, "next") if step < 3 => {
            Ok(State::Processing { step: step + 1 })
        }
        (State::Processing { step }, "next") if step == 3 => {
            Ok(State::Completed { result: String::from("Done") })
        }
        (State::Processing { .. }, "abort") => {
            Ok(State::Failed { error: String::from("Aborted") })
        }
        (state, action) => {
            Err(format!("Invalid action {:?} for state {:?}", action, state))
        }
    }
}
```

