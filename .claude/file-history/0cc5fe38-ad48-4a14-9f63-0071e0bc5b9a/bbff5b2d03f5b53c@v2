/// 1부터 100까지의 숫자 중 7의 배수만 추출하여 합계를 반환합니다.
///
/// # Returns
/// - `(Vec<i32>, i32)`: (7의 배수 리스트, 합계)
pub fn extract_multiples_of_seven() -> (Vec<i32>, i32) {
    let mut multiples: Vec<i32> = Vec::new();
    let mut sum: i32 = 0;

    // 1부터 100까지 반복
    for num in 1..=100 {
        // match를 이용한 7의 배수 판별
        match num % 7 {
            0 => {
                // 7의 배수인 경우
                multiples.push(num);
                sum += num;
            }
            _ => {
                // 7의 배수가 아닌 경우는 아무것도 하지 않음
            }
        }
    }

    (multiples, sum)
}

/// 추출된 배수들의 통계 정보를 출력합니다.
pub fn print_statistics(multiples: &Vec<i32>, sum: i32) {
    println!("=== 7의 배수 추출 결과 ===");
    println!("개수: {}", multiples.len());
    println!("합계: {}", sum);
    println!("평균: {:.2}", sum as f64 / multiples.len() as f64);
    println!("\n추출된 숫자들:");

    for (index, &num) in multiples.iter().enumerate() {
        if (index + 1) % 5 == 0 {
            println!("{}", num);
        } else {
            print!("{}, ", num);
        }
    }
    if !multiples.is_empty() {
        println!();
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_extract_multiples_of_seven() {
        let (multiples, sum) = extract_multiples_of_seven();

        // 예상: 7, 14, 21, 28, 35, 42, 49, 56, 63, 70, 77, 84, 91, 98
        assert_eq!(multiples.len(), 14);
        assert_eq!(sum, 735); // 7+14+21+28+35+42+49+56+63+70+77+84+91+98

        // 첫 번째와 마지막 요소 확인
        assert_eq!(multiples[0], 7);
        assert_eq!(multiples[multiples.len() - 1], 98);
    }
}
