// ============================================================================
// v13.1 절차적 매크로(Procedural Macros) - 12개 섹션
// ============================================================================
// 컴파일러 내부에서 작동하는 코드 분석기 + 코드 생성기
// 입력: TokenStream → 처리: syn (파싱) + 데이터 구조 → 출력: quote (코드 생성)
// ============================================================================

use gogs_macros::{GogsInfo, GogsDebug, GogsToString, gogs_mark, gogs_serialize, GogsBuilder, GogsStats};

// ============================================================================
// Section 1: Derive Macros 기초 - #[derive(GogsInfo)]
// ============================================================================
/// GogsInfo를 파생시킨 구조체입니다.
/// 컴파일 타임에 절차적 매크로가 메서드를 추가합니다.
#[derive(GogsInfo)]
#[allow(dead_code)]
struct User {
    id: u32,
    name: String,
    email: String,
}

#[derive(GogsInfo)]
#[allow(dead_code)]
struct Project {
    name: String,
    version: String,
}

fn section_1_derive_basics() {
    println!("\n=== Section 1: Derive Macros 기초 ===");
    println!("절차적 매크로가 컴파일 타임에 메서드를 추가:");

    let user = User {
        id: 1,
        name: "Alice".to_string(),
        email: "alice@example.com".to_string(),
    };

    user.print_gogs_info();

    let project = Project {
        name: "GOGS".to_string(),
        version: "1.0.0".to_string(),
    };

    project.print_gogs_info();

    println!("✓ Section 1 완료: Derive 매크로 기초");
}

// ============================================================================
// Section 2: 다중 Derive 매크로 - 여러 매크로 조합
// ============================================================================
#[derive(GogsInfo, GogsDebug, GogsToString)]
#[allow(dead_code)]
struct Product {
    id: u32,
    name: String,
    price: f64,
}

fn section_2_multiple_derives() {
    println!("\n=== Section 2: 다중 Derive 매크로 ===");

    let product = Product {
        id: 100,
        name: "Laptop".to_string(),
        price: 999.99,
    };

    println!("Type name: {}", Product::gogs_type_name());
    println!("Debug output: {:?}", product);

    println!("✓ Section 2 완료: 다중 Derive 매크로");
}

// ============================================================================
// Section 3: Attribute Macros - #[gogs_mark]
// ============================================================================
#[gogs_mark(category = "authentication")]
#[allow(dead_code)]
struct Session {
    token: String,
    user_id: u32,
}

#[gogs_mark(category = "database")]
#[allow(dead_code)]
struct Record {
    id: u32,
    data: String,
}

fn section_3_attribute_macros() {
    println!("\n=== Section 3: Attribute Macros ===");
    println!("매크로 속성으로 메타데이터 표시:");

    let _session = Session {
        token: "abc123".to_string(),
        user_id: 1,
    };

    let _record = Record {
        id: 1,
        data: "example data".to_string(),
    };

    println!("  @gogs_mark(category = \"authentication\") - Session 구조체");
    println!("  @gogs_mark(category = \"database\") - Record 구조체");

    println!("✓ Section 3 완료: Attribute 매크로");
}

// ============================================================================
// Section 4: Serialize Attribute - 직렬화 메서드 자동 추가
// ============================================================================
#[gogs_serialize]
#[allow(dead_code)]
struct Config {
    version: String,
    debug: bool,
    timeout: u32,
}

fn section_4_serialize_attribute() {
    println!("\n=== Section 4: Serialize Attribute ===");

    let config = Config {
        version: "2.0".to_string(),
        debug: true,
        timeout: 30,
    };

    println!("Serialized: {}", config.gogs_serialize());

    println!("✓ Section 4 완료: 직렬화 메서드 자동 추가");
}

// ============================================================================
// Section 5: GogsDebug Derive - 커스텀 Debug 구현
// ============================================================================
#[derive(GogsDebug)]
#[allow(dead_code)]
struct Request {
    method: String,
    url: String,
    body: String,
}

fn section_5_custom_debug() {
    println!("\n=== Section 5: 커스텀 Debug Derive ===");

    let request = Request {
        method: "POST".to_string(),
        url: "https://api.example.com/users".to_string(),
        body: "{\"name\": \"Bob\"}".to_string(),
    };

    println!("Debug representation:");
    println!("{:#?}", request);

    println!("✓ Section 5 완료: 커스텀 Debug");
}

