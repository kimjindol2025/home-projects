    println!("\n=== Section 6: 타입 이름 추출 ===");

    println!("Event type: {}", Event::gogs_type_name());
    println!("Message type: {}", Message::gogs_type_name());

    println!("✓ Section 6 완료: 타입 이름 추출");
}

// ============================================================================
// Section 7: TokenStream과 AST 이해
// ============================================================================
fn section_7_tokenstream_ast() {
    println!("\n=== Section 7: TokenStream과 AST ===");

    println!("절차적 매크로의 3단계 처리:");
    println!();

    println!("1️⃣  [Parsing Phase - TokenStream → AST]");
    println!("   입력: #[derive(GogsInfo)]");
    println!("         struct User {{ id: u32, name: String }}");
    println!("   ↓");
    println!("   AST 구조로 파싱됨");
    println!();

    println!("2️⃣  [Extraction Phase - 정보 추출]");
    println!("   구조체 이름: \"User\"");
    println!("   필드 개수: 2");
    println!("   필드 타입: [u32, String]");
    println!();

    println!("3️⃣  [Generation Phase - 새 코드 생성]");
    println!("   quote! 매크로로 Rust 코드 템플릿 작성");
    println!("   구체적인 값들을 대입");
    println!("   TokenStream으로 변환하여 반환");
    println!();

    println!("✓ Section 7 완료: 처리 흐름 이해");
}

// ============================================================================
// Section 8: syn 라이브러리 - 구조 분석
// ============================================================================
fn section_8_syn_parsing() {
    println!("\n=== Section 8: syn 라이브러리 ===");

    println!("syn이 제공하는 기능:");
    println!();

    println!("📦 DeriveInput");
    println!("   → 전체 derive 입력 정보");
    println!("   → 구조체 이름, 필드, 속성 등");
    println!();

    println!("📦 Data");
    println!("   → Struct / Enum / Union 구분");
    println!("   → 각각의 필드 정보 포함");
    println!();

    println!("📦 Fields");
    println!("   → Named (struct Type {{ name: i32 }})");
    println!("   → Unnamed (struct Type(i32))");
    println!("   → Unit (struct Type;)");
    println!();

    println!("✓ Section 8 완료: syn 라이브러리");
}

// ============================================================================
// Section 9: quote 매크로 - 코드 생성
// ============================================================================
fn section_9_quote_generation() {
    println!("\n=== Section 9: quote 매크로 ===");

    println!("quote! 매크로를 사용한 코드 생성:");
    println!();

    println!("예: 구조체 이름이 \"User\"일 때");
    println!();
    println!("quote! {{");
    println!("    impl #ident {{");
    println!("        pub fn gogs_type() -> &'static str {{");
    println!("            stringify!(#ident)");
    println!("        }}");
    println!("    }}");
    println!("}}");
    println!();
    println!("↓ 전개됨 ↓");
    println!();
    println!("impl User {{");
    println!("    pub fn gogs_type() -> &'static str {{");
    println!("        \"User\"");
    println!("    }}");
    println!("}}");
    println!();

    println!("✓ Section 9 완료: quote 매크로");
}

// ============================================================================
// Section 10: GogsBuilder - 빌더 패턴 자동화
// ============================================================================
#[derive(GogsBuilder)]
struct DatabaseConfig {
    host: String,
    port: u16,
    username: String,
    password: String,
}

fn section_10_builder_pattern() {
    println!("\n=== Section 10: 빌더 패턴 자동화 ===");

    println!("절차적 매크로가 빌더 메서드를 자동 생성:");
    println!("  - builder() 메서드");
    println!("  - 각 필드의 setter 메서드");
    println!("  - 메서드 체이닝 지원");
    println!();

    // 빌더 패턴 실제 사용
    let config = DatabaseConfig::builder()
        .host("localhost".to_string())
        .port(5432)
        .username("admin".to_string())
        .password("secret".to_string())
        .build();

    println!("생성된 설정:");
    println!("  Host: {}", config.host);
    println!("  Port: {}", config.port);
    println!("  Username: {}", config.username);
    println!("  Password: {}", config.password);
    println!();

    println!("✓ Section 10 완료: 빌더 패턴");
}

