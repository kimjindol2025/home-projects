/// 모듈 정의 (v4.4: 모듈과 패키지 관리)
///
/// 이 모듈은 보안 검증과 관련된 모든 기능을 캡슐화합니다.
/// - 모듈 내부의 함수들은 보안 검증 로직에만 집중
/// - 외부 인터페이스는 pub fn validate_admin만 노출
/// - 내부 헬퍼 함수는 비공개로 유지
mod security_unit {
    /// ADMIN 권한 검증 함수
    ///
    /// # 설계 원칙 (v4.2, v4.3)
    /// - 매개변수: &str (슬라이스) 사용
    ///   → 더 넓은 범위 지원 (&String, &str 모두 가능)
    ///   → 메모리 복사 없음 (효율성)
    ///
    /// - 반환값: bool (Copy 타입)
    ///   → 간단한 판단 결과만 반환
    ///   → 메시지 원본은 caller가 계속 소유
    ///
    /// # 알고리즘 (v4.3: 슬라이스 활용)
    /// 1. 메시지 길이가 5 이상인지 확인
    /// 2. 첫 5글자(&msg[0..5])가 "ADMIN"인지 비교
    /// 3. true/false 반환
    pub fn validate_admin(msg: &str) -> bool {
        // v4.3: 슬라이싱을 통한 부분 참조
        // - &msg[0..5]는 메시지의 처음 5글자만 참조
        // - Fat Pointer: (포인터, 길이=5) 구조
        // - 범위 검사: 런타임에 길이 확인

        if msg.len() >= 5 {
            &msg[0..5] == "ADMIN"
        } else {
            false
        }
    }

    /// 보안 점수 계산 함수 (의사 코드)
    ///
    /// 실제 구현 시 rand 크레이트 사용:
    /// use rand::Rng;
    /// fn generate_security_score() -> u32 {
    ///     rand::thread_rng().gen_range(0..100)
    /// }
    pub fn generate_security_score() -> u32 {
        // v4.5: 외부 크레이트 시뮬레이션
        // 실제 코드라면:
        // use rand::Rng;
        // let mut rng = rand::thread_rng();
        // rng.gen_range(0..100)

        // 현재는 의사 코드로 85를 반환
        85
    }

    /// 접근 허가 메시지 생성 (내부 헬퍼)
    ///
    /// v4.4의 "비공개 우선" 원칙:
    /// - pub이 없으므로 모듈 외부에서 호출 불가
    /// - 모듈 내부에서만 사용 가능
    /// - validate_admin의 보조 역할
    fn create_access_grant_message(score: u32) -> String {
        format!("✅ 관리자 접속 허가됨\n보안 점수: {}/100", score)
    }

    /// 접근 거부 메시지 생성 (내부 헬퍼)
    fn create_access_denial_message() -> String {
        "❌ 관리자 권한 없음. 접속이 거부되었습니다.".to_string()
    }

    /// 최종 보안 검증 및 결과 반환
    ///
    /// v4.4: 공개 인터페이스 설계
    /// - 하나의 '입구'로 모든 기능 통합
    /// - 내부 헬퍼 함수들을 조율
    pub fn check_and_report(msg: &str) -> String {
        if validate_admin(msg) {
            let score = generate_security_score();
            create_access_grant_message(score)
        } else {
            create_access_denial_message()
        }
    }
}

