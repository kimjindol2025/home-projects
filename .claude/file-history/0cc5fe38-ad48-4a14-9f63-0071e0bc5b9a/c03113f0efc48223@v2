// ===================================================================
// Section 1: HashMap 기본 - 생성, 삽입, 조회
// ===================================================================
//
// HashMap<K, V>는 키를 통해 값을 빠르게 검색합니다.
//
fn section_1_hashmap_basics() {
    println!("▶ Section 1: HashMap 기본");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 1-1. HashMap 생성
    // ─────────────────────────────────────────
    println!("  [1-1] HashMap 생성");

    // 방법 1: new()
    let mut scores: HashMap<String, i32> = HashMap::new();
    println!("    HashMap::new(): {:?}", scores);

    // 방법 2: with_capacity() (사전 할당)
    let mut users: HashMap<String, String> = HashMap::with_capacity(100);
    println!("    with_capacity(100): capacity={}\n", users.capacity());

    // ─────────────────────────────────────────
    // 1-2. 데이터 삽입 (소유권 이동)
    // ─────────────────────────────────────────
    println!("  [1-2] 데이터 삽입");

    let mut permissions = HashMap::new();
    permissions.insert("Admin", 10);
    permissions.insert("Operator", 5);
    permissions.insert("Guest", 1);

    println!("    삽입 후: {:?}", permissions);
    println!("    크기: {}\n", permissions.len());

    // ─────────────────────────────────────────
    // 1-3. 기본 조회
    // ─────────────────────────────────────────
    println!("  [1-3] 기본 조회");

    let mut users = HashMap::new();
    users.insert(String::from("alice"), 30);
    users.insert(String::from("bob"), 25);
    users.insert(String::from("charlie"), 35);

    if let Some(&age) = users.get("alice") {
        println!("    alice의 나이: {}", age);
    }

    println!("    bob 있음: {}", users.contains_key("bob"));
    println!("    david 있음: {}\n", users.contains_key("david"));

    // ─────────────────────────────────────────
    // 1-4. 메모리 구조
    // ─────────────────────────────────────────
    println!("  [1-4] 해시맵의 메모리 구조");

    println!("    HashMap<K, V>는 내부적으로:");
    println!("    ┌──────────────────┐");
    println!("    │ 해시 테이블      │");
    println!("    ├──────────────────┤");
    println!("    │ hash(key) → idx  │");
    println!("    │ idx → (K, V)     │");
    println!("    └──────────────────┘");
    println!("    → Key를 해시하여 버킷 위치 결정");
    println!("    → O(1) 평균 시간 복잡도\n");

    println!("  💡 핵심: HashMap은 '의미있는 이름'으로 데이터에 접근합니다.\n");
}

// ===================================================================
// Section 2: 소유권과 참조
// ===================================================================
//
// insert() 시 소유권이 HashMap으로 이동합니다.
// 이를 이해하고 효과적으로 관리해야 합니다.
//
fn section_2_ownership_and_reference() {
    println!("▶ Section 2: 소유권과 참조");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 2-1. insert로 소유권 이동
    // ─────────────────────────────────────────
    println!("  [2-1] insert로 소유권 이동");

    let mut data = HashMap::new();
    let key = String::from("user_id");
    let value = String::from("alice");

    data.insert(key, value);
    // key와 value의 소유권이 data로 이동

    // println!("key: {}", key);    // 오류! 소유권 이동됨
    // println!("value: {}", value);  // 오류! 소유권 이동됨

    println!("    insert 후 소유권이 HashMap으로 이동됨");
    println!("    data: {:?}\n", data);

    // ─────────────────────────────────────────
    // 2-2. 참조로 여러 번 사용
    // ─────────────────────────────────────────
    println!("  [2-2] 참조로 여러 번 사용");

    let mut config = HashMap::new();

    let host = "localhost";
    let port = "3000";

    config.insert("host", host);
    config.insert("port", port);

    // host와 port는 여전히 사용 가능 (슬라이스 참조)
    println!("    host: {}", host);
    println!("    port: {}", port);
    println!("    config: {:?}\n", config);

    // ─────────────────────────────────────────
    // 2-3. 얻은 참조 사용 패턴
    // ─────────────────────────────────────────
    println!("  [2-3] HashMap에서 얻은 참조");

    let mut users = HashMap::new();
    users.insert(String::from("alice"), 30);

    // get()으로 참조 얻기
    if let Some(age) = users.get("alice") {
        println!("    alice의 나이: {} (get으로 얻은 참조)", age);
    }

    // 원본은 여전히 사용 가능
    println!("    users는 여전히 사용 가능: {:?}\n", users);

    // ─────────────────────────────────────────
    // 2-4. 여러 HashMap의 상호작용
    // ─────────────────────────────────────────
    println!("  [2-4] 여러 HashMap의 상호작용");

    let mut map1 = HashMap::new();
    map1.insert("a", 1);
    map1.insert("b", 2);

    let mut map2 = HashMap::new();
    map2.insert("x", 10);
    map2.insert("y", 20);

    println!("    map1: {:?}", map1);
    println!("    map2: {:?}\n", map2);

    println!("  💡 핵심: insert()는 소유권을 이동시킵니다. 여러 번 쓰려면 참조를 사용하세요.\n");
}

// ===================================================================
// Section 3: 접근 패턴
// ===================================================================
//
// HashMap에서 데이터에 접근하는 안전한 방법들을 배웁니다.
//
fn section_3_access_patterns() {
    println!("▶ Section 3: 접근 패턴");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 3-1. get() - 불변 참조
    // ─────────────────────────────────────────
    println!("  [3-1] get() - 불변 접근");

    let mut scores = HashMap::new();
    scores.insert("alice", 95);
    scores.insert("bob", 87);

    match scores.get("alice") {
        Some(score) => println!("    alice의 점수: {}", score),
        None => println!("    alice를 찾을 수 없음"),
    }

    println!();

    // ─────────────────────────────────────────
    // 3-2. get_mut() - 가변 참조
    // ─────────────────────────────────────────
    println!("  [3-2] get_mut() - 가변 접근");

    let mut scores = HashMap::new();
    scores.insert("alice", 95);
    scores.insert("bob", 87);

    if let Some(score) = scores.get_mut("alice") {
        *score += 5;
        println!("    alice의 새 점수: {}", score);
    }

    println!("    수정 후: {:?}\n", scores);

    // ─────────────────────────────────────────
    // 3-3. contains_key() - 존재 확인
    // ─────────────────────────────────────────
    println!("  [3-3] contains_key() - 존재 확인");

    let users = HashMap::from([
        ("alice", "alice@example.com"),
        ("bob", "bob@example.com"),
    ]);

    println!("    alice 있음: {}", users.contains_key("alice"));
    println!("    charlie 있음: {}\n", users.contains_key("charlie"));

    // ─────────────────────────────────────────
    // 3-4. remove() - 제거
    // ─────────────────────────────────────────
    println!("  [3-4] remove() - 제거");

    let mut data = HashMap::new();
    data.insert("temp", "temporary");
    println!("    제거 전: {:?}", data);

    if let Some(value) = data.remove("temp") {
        println!("    제거된 값: {}", value);
    }

    println!("    제거 후: {:?}\n", data);

    // ─────────────────────────────────────────
    // 3-5. 기본값 처리
    // ─────────────────────────────────────────
    println!("  [3-5] 기본값 처리");

    let scores = HashMap::from([
        ("alice", 95),
        ("bob", 87),
    ]);

    let default = 0;
    let alice_score = scores.get("alice").copied().unwrap_or(default);
    let charlie_score = scores.get("charlie").copied().unwrap_or(default);

    println!("    alice 점수: {} (있음)", alice_score);
    println!("    charlie 점수: {} (없음, 기본값)\n", charlie_score);

    println!("  💡 핵심: get(), get_mut(), contains_key()로 안전하게 접근합니다.\n");
}

// ===================================================================
// Section 4: 수정과 갱신 - entry API
// ===================================================================
//
// entry() 메서드는 복잡한 수정 로직을 우아하게 처리합니다.
//
fn section_4_modification_and_update() {
    println!("▶ Section 4: 수정과 갱신");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 4-1. insert로 덮어쓰기
    // ─────────────────────────────────────────
    println!("  [4-1] insert로 덮어쓰기");

    let mut permissions = HashMap::new();
    permissions.insert("admin", 10);
    println!("    최초: {:?}", permissions);

    permissions.insert("admin", 20);
    println!("    수정: {:?}\n", permissions);

    // ─────────────────────────────────────────
    // 4-2. entry()와 and_modify()
    // ─────────────────────────────────────────
    println!("  [4-2] entry()와 and_modify()");

    let mut permissions = HashMap::new();
    permissions.insert("admin", 10);

    permissions
        .entry("admin")
        .and_modify(|level| *level += 1);

    println!("    and_modify 후: {:?}\n", permissions);

    // ─────────────────────────────────────────
    // 4-3. entry()와 or_insert()
    // ─────────────────────────────────────────
    println!("  [4-3] entry()와 or_insert()");

    let mut permissions = HashMap::new();
    permissions.insert("admin", 10);

    permissions
        .entry("guest")
        .or_insert(1);

    println!("    or_insert 후: {:?}\n", permissions);

    // ─────────────────────────────────────────
    // 4-4. 단어 빈도수 계산 (entry 활용의 강점)
    // ─────────────────────────────────────────
    println!("  [4-4] 단어 빈도수 계산");

    let text = "hello world hello rust hello";
    let mut word_count: HashMap<&str, i32> = HashMap::new();

    for word in text.split_whitespace() {
        word_count
            .entry(word)
            .and_modify(|count| *count += 1)
            .or_insert(1);
    }

    println!("    단어 빈도:");
    for (word, count) in &word_count {
        println!("      {}: {}", word, count);
    }
    println!();

    // ─────────────────────────────────────────
    // 4-5. clear() - 모두 삭제
    // ─────────────────────────────────────────
    println!("  [4-5] clear() - 모두 삭제");

    let mut data = HashMap::from([("a", 1), ("b", 2)]);
    println!("    clear 전: {:?}", data);
    data.clear();
    println!("    clear 후: {:?}\n", data);

    println!("  💡 핵심: entry API는 조건부 수정을 우아하게 처리합니다.\n");
}

// ===================================================================
// Section 5: 반복과 순회
// ===================================================================
//
// HashMap을 반복하면서 모든 키-값 쌍에 접근합니다.
//
fn section_5_iteration_and_traversal() {
    println!("▶ Section 5: 반복과 순회");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 5-1. for 루프로 순회
    // ─────────────────────────────────────────
    println!("  [5-1] for 루프로 순회");

    let users = HashMap::from([
        ("alice", 30),
        ("bob", 25),
        ("charlie", 35),
    ]);

    for (name, age) in &users {
        println!("    {}: {} years old", name, age);
    }
    println!();

    // ─────────────────────────────────────────
    // 5-2. keys() - 모든 키
    // ─────────────────────────────────────────
    println!("  [5-2] keys() - 모든 키");

    let users = HashMap::from([
        ("alice", 30),
        ("bob", 25),
    ]);

    print!("    키: ");
    for key in users.keys() {
        print!("{} ", key);
    }
    println!("\n");

    // ─────────────────────────────────────────
    // 5-3. values() - 모든 값
    // ─────────────────────────────────────────
    println!("  [5-3] values() - 모든 값");

    let users = HashMap::from([
        ("alice", 30),
        ("bob", 25),
    ]);

    print!("    값: ");
    for age in users.values() {
        print!("{} ", age);
    }
    println!("\n");

    // ─────────────────────────────────────────
    // 5-4. 반복자 메서드 (filter, map)
    // ─────────────────────────────────────────
    println!("  [5-4] 반복자 메서드");

    let scores = HashMap::from([
        ("alice", 95),
        ("bob", 60),
        ("charlie", 85),
    ]);

    let high_scores: Vec<(&str, i32)> = scores
        .iter()
        .filter(|(_, score)| score > &80)
        .map(|(name, score)| (*name, *score))
        .collect();

    println!("    80점 이상: {:?}\n", high_scores);

    // ─────────────────────────────────────────
    // 5-5. 정렬된 순회
    // ─────────────────────────────────────────
    println!("  [5-5] 정렬된 순회");

    let scores = HashMap::from([
        ("alice", 95),
        ("bob", 87),
        ("charlie", 92),
    ]);

    let mut items: Vec<_> = scores.iter().collect();
    items.sort_by_key(|&(_, score)| std::cmp::Reverse(score));

    println!("    점수 높은 순:");
    for (name, score) in items {
        println!("      {}: {}", name, score);
    }
    println!();

    println!("  💡 핵심: 반복자로 유연하게 모든 데이터에 접근합니다.\n");
}

// ===================================================================
// Section 6: 해시 메커니즘과 성능
// ===================================================================
//
// HashMap의 내부 동작 원리를 이해합니다.
//
fn section_6_hash_mechanism() {
    println!("▶ Section 6: 해시 메커니즘과 성능");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 6-1. 해시 함수의 원리
    // ─────────────────────────────────────────
    println!("  [6-1] 해시 함수의 원리");

    println!("    Key → hash(Key) → 인덱스 → Bucket → (Key, Value)");
    println!("    예제:");
    println!("      \"alice\" → hash(...) → 7 → Bucket[7] → (\"alice\", 30)");
    println!("      \"bob\"   → hash(...) → 2 → Bucket[2] → (\"bob\", 25)");
    println!();

    // ─────────────────────────────────────────
    // 6-2. 시간 복잡도
    // ─────────────────────────────────────────
    println!("  [6-2] 시간 복잡도");

    println!("    get():        O(1) 평균, O(n) 최악 (충돌 많음)");
    println!("    insert():     O(1) 상각");
    println!("    remove():     O(1) 평균");
    println!("    iteration:    O(n)");
    println!();

    // ─────────────────────────────────────────
    // 6-3. Rust의 SipHash
    // ─────────────────────────────────────────
    println!("  [6-3] Rust의 SipHash");

    println!("    • 암호학적 보안 수준의 해시");
    println!("    • 해시 공격(DoS)에 강함");
    println!("    • 모든 프로그램마다 다른 시드 사용 (ASLR)");
    println!("    • 동일 키는 항상 동일 해시값\n");

    // ─────────────────────────────────────────
    // 6-4. 용량과 재할당
    // ─────────────────────────────────────────
    println!("  [6-4] 용량과 재할당");

    let mut map = HashMap::with_capacity(10);
    println!("    초기 capacity: {}", map.capacity());

    for i in 0..20 {
        map.insert(format!("key{}", i), i);
        if i == 5 || i == 10 || i == 15 || i == 19 {
            println!("    insert {} 후: capacity={}", i, map.capacity());
        }
    }
    println!();

    // ─────────────────────────────────────────
    // 6-5. 로드 팩터 (Load Factor)
    // ─────────────────────────────────────────
    println!("  [6-5] 로드 팩터");

    let map = HashMap::from([
        ("a", 1),
        ("b", 2),
        ("c", 3),
    ]);

    let load_factor = map.len() as f64 / map.capacity() as f64;
    println!("    크기: {}", map.len());
    println!("    용량: {}", map.capacity());
    println!("    로드 팩터: {:.2}", load_factor);
    println!("    → 임계값(0.75) 초과 시 자동 재할당\n");

    println!("  💡 핵심: HashMap은 해시로 O(1) 검색을, SipHash로 보안을 제공합니다.\n");
}

// ===================================================================
// Section 7: 실전 예제 - 데이터 관리 시스템
// ===================================================================
//
// 실제 사용 사례를 통해 HashMap의 강력함을 보여줍니다.
//
fn section_7_advanced_real_world() {
    println!("▶ Section 7: 실전 예제");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 예제 1: 시스템 권한 저장소
    // ─────────────────────────────────────────
    println!("  [예제 1] 시스템 권한 저장소");

    struct PermissionSystem {
        permissions: HashMap<String, u32>,
    }

    impl PermissionSystem {
        fn new() -> Self {
            PermissionSystem {
                permissions: HashMap::new(),
            }
        }

        fn grant(&mut self, user: String, level: u32) {
            self.permissions.insert(user, level);
        }

        fn check_permission(&self, user: &str, required: u32) -> bool {
            self.permissions
                .get(user)
                .map(|&level| level >= required)
                .unwrap_or(false)
        }

        fn list_all(&self) {
            for (user, level) in &self.permissions {
                println!("      - {}: Level {}", user, level);
            }
        }
    }

    let mut sys = PermissionSystem::new();
    sys.grant(String::from("admin"), 10);
    sys.grant(String::from("operator"), 5);
    sys.grant(String::from("guest"), 1);

    println!("    권한 목록:");
    sys.list_all();
    println!("    admin 권한 5 요청: {}", sys.check_permission("admin", 5));
    println!("    guest 권한 5 요청: {}\n", sys.check_permission("guest", 5));

    // ─────────────────────────────────────────
    // 예제 2: 설정 저장소
    // ─────────────────────────────────────────
    println!("  [예제 2] 설정 저장소");

    let mut config = HashMap::new();
    config.insert("host", "localhost");
    config.insert("port", "3000");
    config.insert("debug", "true");

    fn get_config(config: &HashMap<&str, &str>, key: &str, default: &str) -> String {
        config
            .get(key)
            .map(|v| v.to_string())
            .unwrap_or_else(|| default.to_string())
    }

    println!("    host: {}", get_config(&config, "host", "0.0.0.0"));
    println!("    port: {}", get_config(&config, "port", "8080"));
    println!("    timeout: {}\n", get_config(&config, "timeout", "30"));

    // ─────────────────────────────────────────
    // 예제 3: 단어 빈도 분석
    // ─────────────────────────────────────────
    println!("  [예제 3] 단어 빈도 분석");

    let text = "the quick brown fox jumps over the lazy dog the fox is quick";
    let mut frequencies: HashMap<&str, i32> = HashMap::new();

    for word in text.split_whitespace() {
        frequencies
            .entry(word)
            .and_modify(|count| *count += 1)
            .or_insert(1);
    }

    println!("    텍스트: {}", text);
    println!("    단어 빈도:");

    let mut sorted: Vec<_> = frequencies.iter().collect();
    sorted.sort_by_key(|&(_, count)| std::cmp::Reverse(*count));

    for (word, count) in sorted.iter().take(5) {
        println!("      {}: {}", word, count);
    }
    println!();

    // ─────────────────────────────────────────
    // 예제 4: 사용자 프로필 저장소
    // ─────────────────────────────────────────
    println!("  [예제 4] 사용자 프로필 저장소");

    struct User {
        name: String,
        age: u32,
        email: String,
    }

    let mut users: HashMap<String, User> = HashMap::new();

    users.insert(
        String::from("alice"),
        User {
            name: String::from("Alice"),
            age: 30,
            email: String::from("alice@example.com"),
        },
    );

    users.insert(
        String::from("bob"),
        User {
            name: String::from("Bob"),
            age: 25,
            email: String::from("bob@example.com"),
        },
    );

    if let Some(user) = users.get("alice") {
        println!("    사용자 정보:");
        println!("      이름: {}", user.name);
        println!("      나이: {}", user.age);
        println!("      이메일: {}\n", user.email);
    }

    // ─────────────────────────────────────────
    // 예제 5: 캐시 시스템
    // ─────────────────────────────────────────
    println!("  [예제 5] 간단한 캐시 시스템");

    struct Cache {
        data: HashMap<String, String>,
    }

    impl Cache {
        fn new() -> Self {
            Cache {
                data: HashMap::new(),
            }
        }

        fn set(&mut self, key: String, value: String) {
            self.data.insert(key, value);
        }

        fn get(&self, key: &str) -> Option<String> {
            self.data.get(key).cloned()
        }

        fn size(&self) -> usize {
            self.data.len()
        }
    }

    let mut cache = Cache::new();
    cache.set(String::from("user:1"), String::from("Alice"));
    cache.set(String::from("user:2"), String::from("Bob"));

    println!("    캐시 크기: {}", cache.size());
    println!("    user:1 = {:?}", cache.get("user:1"));
    println!("    user:3 = {:?}\n", cache.get("user:3"));

    println!("  💡 핵심: HashMap으로 실무의 다양한 저장소를 구현할 수 있습니다.\n");
}

