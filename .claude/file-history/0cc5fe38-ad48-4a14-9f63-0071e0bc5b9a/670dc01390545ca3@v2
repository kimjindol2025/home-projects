// ===================================================================
// Section 1: Option의 기본 (Option Basics)
// ===================================================================
//
// Option<T>는 값이 '있을 수도, 없을 수도 있음'을 타입으로 표현합니다.
//
// enum Option<T> {
//     Some(T),  // 값이 있음
//     None,     // 값이 없음
// }
//
fn section_1_option_basics() {
    println!("▶ Section 1: Option의 기본");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 1-1. Option 생성
    // ─────────────────────────────────────────
    println!("  [1-1] Option 인스턴스 생성");

    let some_number = Some(5);
    let none_number: Option<i32> = None;

    println!("    Some: {:?}", some_number);
    println!("    None: {:?}", none_number);
    println!("    → Option은 None일 수도, Some(값)일 수도 있음\n");

    // ─────────────────────────────────────────
    // 1-2. 값 찾기: Vec.get() 메서드
    // ─────────────────────────────────────────
    println!("  [1-2] Vec.get()으로 Option 반환");

    let numbers = vec![10, 20, 30, 40];

    let first = numbers.get(0);  // Some(10)
    let fifth = numbers.get(5);  // None

    println!("    첫 번째 원소: {:?}", first);
    println!("    다섯 번째 원소: {:?}", fifth);
    println!("    → 존재하지 않으면 None, 존재하면 Some\n");

    // ─────────────────────────────────────────
    // 1-3. null이 없다는 의미
    // ─────────────────────────────────────────
    println!("  [1-3] null의 문제와 Option의 해결");

    // Java 방식 (null 위험)
    // String name = getUserName(123);  // null일 수 있음
    // println!("{}", name.length());   // NullPointerException!

    // Rust 방식 (안전함)
    let user_name: Option<String> = get_user_name(999);
    // println!("{}", user_name.len());  // ❌ 컴파일 오류! Option을 먼저 처리해야 함

    match user_name {
        Some(name) => println!("    사용자명: {}", name),
        None => println!("    사용자를 찾을 수 없습니다"),
    }
    println!("    → 컴파일러가 None 경우를 반드시 처리하도록 강제\n");

    println!("  💡 핵심: Option은 '값이 있을 수도, 없을 수도 있음'을 타입으로 표현하여\n");
    println!("           null pointer exception을 컴파일 타임에 방지합니다.\n");
}

// ─────────────────────────────────────────
// 헬퍼 함수
// ─────────────────────────────────────────
fn get_user_name(user_id: u32) -> Option<String> {
    match user_id {
        1 => Some(String::from("Alice")),
        2 => Some(String::from("Bob")),
        3 => Some(String::from("Charlie")),
        _ => None,
    }
}

// ===================================================================
// Section 2: Result의 기본 (Result Basics)
// ===================================================================
//
// Result<T, E>는 '작업이 성공할 수도, 실패할 수도 있음'을 타입으로 표현합니다.
//
// enum Result<T, E> {
//     Ok(T),    // 성공 (값 반환)
//     Err(E),   // 실패 (에러 정보)
// }
//
fn section_2_result_basics() {
    println!("▶ Section 2: Result의 기본");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 2-1. Result 생성
    // ─────────────────────────────────────────
    println!("  [2-1] Result 인스턴스 생성");

    let success: Result<i32, String> = Ok(42);
    let failure: Result<i32, String> = Err(String::from("계산 실패"));

    println!("    Ok: {:?}", success);
    println!("    Err: {:?}", failure);
    println!("    → 성공하면 Ok(값), 실패하면 Err(에러)\n");

    // ─────────────────────────────────────────
    // 2-2. 실패할 수 있는 연산
    // ─────────────────────────────────────────
    println!("  [2-2] 실패 가능한 연산 함수");

    let result1 = divide(10, 2);
    let result2 = divide(10, 0);

    println!("    10 ÷ 2 = {:?}", result1);
    println!("    10 ÷ 0 = {:?}", result2);
    println!("    → 0으로 나누는 것을 실시간으로 감지하고 Err 반환\n");

    // ─────────────────────────────────────────
    // 2-3. 파일 I/O의 Result
    // ─────────────────────────────────────────
    println!("  [2-3] 파일 읽기: 실패할 가능성");

    let read_result = read_file_content("config.txt");

    match read_result {
        Ok(content) => println!("    파일 내용: {}", content),
        Err(err) => println!("    파일 읽기 실패: {}", err),
    }
    println!("    → 실제로는 파일이 없으므로 Err 반환\n");

    println!("  💡 핵심: Result는 함수가 실패할 수 있음을 명시하고\n");
    println!("           에러를 타입 안전하게 처리하도록 강제합니다.\n");
}

// ─────────────────────────────────────────
// 헬퍼 함수
// ─────────────────────────────────────────
fn divide(a: i32, b: i32) -> Result<i32, String> {
    if b == 0 {
        Err(String::from("0으로 나눌 수 없습니다"))
    } else {
        Ok(a / b)
    }
}

fn read_file_content(path: &str) -> Result<String, String> {
    // 실제 파일 I/O: std::fs::read_to_string(path)
    // 여기서는 시뮬레이션
    match path {
        "config.txt" => Err(String::from("파일을 찾을 수 없습니다")),
        _ => Ok(String::from("파일 내용")),
    }
}

// ===================================================================
// Section 3: 패턴 매칭으로 처리 (Pattern Matching)
// ===================================================================
//
// match를 사용하여 Option과 Result의 모든 경우를 명시적으로 처리합니다.
//
fn section_3_pattern_matching() {
    println!("▶ Section 3: 패턴 매칭으로 처리");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 3-1. Option의 match
    // ─────────────────────────────────────────
    println!("  [3-1] Option의 match 패턴 매칭");

    let search_result = search_database("GOGS_02");

    match search_result {
        Some(data) => {
            println!("    ✅ 데이터 발견: {}", data);
        }
        None => {
            println!("    ❌ 데이터를 찾을 수 없습니다");
        }
    }
    println!();

    // ─────────────────────────────────────────
    // 3-2. Result의 match
    // ─────────────────────────────────────────
    println!("  [3-2] Result의 match 패턴 매칭");

    let parse_result = parse_integer("123");
    let parse_error = parse_integer("abc");

    match parse_result {
        Ok(num) => println!("    ✅ 파싱 성공: {}", num),
        Err(e) => println!("    ❌ 파싱 실패: {}", e),
    }

    match parse_error {
        Ok(num) => println!("    ✅ 파싱 성공: {}", num),
        Err(e) => println!("    ❌ 파싱 실패: {}", e),
    }
    println!();

    // ─────────────────────────────────────────
    // 3-3. 복합 match
    // ─────────────────────────────────────────
    println!("  [3-3] Option과 Result를 함께 다루기");

    let user = get_user_name(1);
    let score = calculate_score(90);

    match (user, score) {
        (Some(name), Ok(s)) => {
            println!("    {}님의 점수: {}", name, s);
        }
        (Some(name), Err(e)) => {
            println!("    {}님의 점수 계산 실패: {}", name, e);
        }
        (None, _) => {
            println!("    사용자를 찾을 수 없습니다");
        }
    }
    println!();

    println!("  💡 핵심: match는 모든 경우를 명시적으로 처리하도록 강제합니다.\n");
}

// ─────────────────────────────────────────
// 헬퍼 함수
// ─────────────────────────────────────────
fn search_database(id: &str) -> Option<String> {
    let data = vec!["GOGS_01", "GOGS_02", "GOGS_03"];
    data.iter()
        .find(|&&d| d == id)
        .map(|s| s.to_string())
}

fn parse_integer(s: &str) -> Result<i32, String> {
    match s.parse::<i32>() {
        Ok(num) => Ok(num),
        Err(_) => Err(format!("'{}' 는 정수가 아닙니다", s)),
    }
}

fn calculate_score(points: u32) -> Result<u32, String> {
    if points > 100 {
        Err(String::from("점수가 100을 초과합니다"))
    } else {
        Ok(points)
    }
}

// ===================================================================
// Section 4: if let과 unwrap (if let and unwrap)
// ===================================================================
//
// match보다 간단하게 한 가지 경우만 처리할 때 if let을 사용합니다.
// 하지만 unwrap()은 신중하게 사용해야 합니다.
//
fn section_4_if_let_and_unwrap() {
    println!("▶ Section 4: if let과 unwrap");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 4-1. if let (권장)
    // ─────────────────────────────────────────
    println!("  [4-1] if let: 한 경우만 처리할 때");

    let value = Some(42);

    // match 버전 (번거로움)
    match value {
        Some(v) => println!("    값: {}", v),
        None => {}
    }

    // if let 버전 (간단함)
    if let Some(v) = value {
        println!("    값: {}", v);
    }
    println!("    → 한 가지 경우만 필요하면 if let이 더 간단\n");

    // ─────────────────────────────────────────
    // 4-2. if let ... else
    // ─────────────────────────────────────────
    println!("  [4-2] if let ... else");

    let user = get_user_name(999);

    if let Some(name) = user {
        println!("    사용자: {}", name);
    } else {
        println!("    사용자를 찾을 수 없습니다");
    }
    println!();

    // ─────────────────────────────────────────
    // 4-3. unwrap() (주의!)
    // ─────────────────────────────────────────
    println!("  [4-3] unwrap(): 위험한 방법");

    let safe_value = Some(100);
    let unsafe_value: Option<i32> = None;

    // ✅ 안전
    println!("    Some일 때 unwrap: {}", safe_value.unwrap());

    // ❌ 위험! 패닉 발생
    // println!("    None일 때 unwrap: {}", unsafe_value.unwrap());
    // → thread 'main' panicked at 'called `Option::unwrap()` on a `None` value'

    println!("    → unwrap()은 값이 반드시 존재한다고 확신할 때만 사용\n");

    // ─────────────────────────────────────────
    // 4-4. unwrap_or() (권장)
    // ─────────────────────────────────────────
    println!("  [4-4] unwrap_or(): 기본값 제공");

    let name1 = Some(String::from("Alice"));
    let name2: Option<String> = None;

    println!("    Some: {}", name1.unwrap_or(String::from("Unknown")));
    println!("    None: {}", name2.unwrap_or(String::from("Unknown")));
    println!("    → None일 때 기본값을 사용\n");

    println!("  💡 핵심: match/if let을 사용하거나, unwrap_or() 같은\n");
    println!("           안전한 메서드를 선호하세요.\n");
}

// ===================================================================
// Section 5: ? 연산자 (Error Propagation)
// ===================================================================
//
// ?는 Result를 반환하는 함수에서 에러를 즉시 상위로 전파합니다.
// 복잡한 에러 처리 로직을 간단하게 만들어줍니다.
//
fn section_5_error_propagation() {
    println!("▶ Section 5: ? 연산자 (Error Propagation)");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 5-1. ? 없이 처리 (번거로움)
    // ─────────────────────────────────────────
    println!("  [5-1] ? 없이 에러 처리 (번거로움)");

    fn load_config_without_question_mark() -> Result<String, String> {
        match read_file_content("config.txt") {
            Ok(content) => {
                match parse_integer("123") {
                    Ok(num) => Ok(format!("Config: {}, Value: {}", content, num)),
                    Err(e) => Err(e),
                }
            }
            Err(e) => Err(e),
        }
    }

    println!("    match를 중첩으로 써야 함\n");

    // ─────────────────────────────────────────
    // 5-2. ? 사용 (간단함)
    // ─────────────────────────────────────────
    println!("  [5-2] ? 연산자 사용 (간단함)");

    fn load_config_with_question_mark() -> Result<String, String> {
        let content = read_file_content("config.txt")?;
        let num = parse_integer("123")?;
        Ok(format!("Config: {}, Value: {}", content, num))
    }

    println!("    ? 연산자로 에러를 자동으로 전파\n");

    // 실제 호출
    match load_config_with_question_mark() {
        Ok(config) => println!("    ✅ {}", config),
        Err(e) => println!("    ❌ {}", e),
    }
    println!();

    // ─────────────────────────────────────────
    // 5-3. ? 의미 분석
    // ─────────────────────────────────────────
    println!("  [5-3] ? 연산자의 의미");
    println!("    let x = operation()?;");
    println!("    는 다음과 같음:");
    println!("    let x = match operation() {{");
    println!("        Ok(v) => v,");
    println!("        Err(e) => return Err(e),  // 즉시 반환");
    println!("    }};");
    println!("\n    → 에러가 발생하면 즉시 상위로 전파\n");

    println!("  💡 핵심: ?는 Result 체인을 간결하게 만듭니다.\n");
}

// ===================================================================
// Section 6: 체인 메서드 (Chain Methods)
// ===================================================================
//
// map, and_then, or_else 등의 메서드로 Option과 Result를 변환합니다.
//
fn section_6_chain_methods() {
    println!("▶ Section 6: 체인 메서드");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 6-1. Option.map()
    // ─────────────────────────────────────────
    println!("  [6-1] Option.map(): 값을 변환");

    let number = Some(5);

    let doubled = number.map(|n| n * 2);
    println!("    Some(5).map(|n| n * 2) = {:?}", doubled);

    let none: Option<i32> = None;
    let result = none.map(|n| n * 2);
    println!("    None.map(|n| n * 2) = {:?}", result);
    println!("    → Some이면 함수 적용, None이면 None 반환\n");

    // ─────────────────────────────────────────
    // 6-2. Result.map()과 map_err()
    // ─────────────────────────────────────────
    println!("  [6-2] Result.map()과 map_err()");

    let ok_result: Result<i32, String> = Ok(10);
    let doubled = ok_result.map(|n| n * 2);
    println!("    Ok(10).map(|n| n * 2) = {:?}", doubled);

    let err_result: Result<i32, String> = Err(String::from("에러"));
    let result = err_result.map_err(|_| String::from("새 에러"));
    println!("    Err(\"에러\").map_err(...) = {:?}", result);
    println!("    → Ok이면 값 변환, Err이면 에러 변환\n");

    // ─────────────────────────────────────────
    // 6-3. and_then (flatMap)
    // ─────────────────────────────────────────
    println!("  [6-3] and_then: 중첩된 Result 펼치기");

    fn get_user_and_score(id: u32) -> Result<u32, String> {
        // 사용자 존재 확인
        if id == 1 {
            Ok(90)  // 점수
        } else {
            Err(String::from("사용자 없음"))
        }
    }

    let result = get_user_name(1)
        .ok_or(String::from("사용자 없음"))  // Option을 Result로
        .and_then(|_| get_user_and_score(1));  // 점수 조회

    println!("    and_then으로 연쇄 처리: {:?}", result);
    println!("    → Option/Result를 중첩할 때 유용\n");

    // ─────────────────────────────────────────
    // 6-4. or_else (대체값)
    // ─────────────────────────────────────────
    println!("  [6-4] or_else: 대체값 제공");

    let value = None::<i32>.or_else(|| Some(42));
    println!("    None.or_else(|| Some(42)) = {:?}", value);
    println!("    → None일 때 대체 옵션 제공\n");

    println!("  💡 핵심: 체인 메서드로 함수형 프로그래밍 스타일 적용\n");
}

// ===================================================================
// Section 7: 실전 예제 - 안전한 데이터 추출 (Advanced Real-World)
// ===================================================================
//
// 데이터베이스, API, 파일 I/O를 안전하게 다루는 예제
//
fn section_7_advanced_real_world() {
    println!("▶ Section 7: 실전 예제 - 무결성 데이터 추출");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 7-1. 데이터베이스 쿼리 시뮬레이션
    // ─────────────────────────────────────────
    println!("  [7-1] 데이터베이스 쿼리 처리");

    #[derive(Debug)]
    struct User {
        id: u32,
        name: String,
        email: String,
    }

    fn query_user(id: u32) -> Option<User> {
        let users = vec![
            User {
                id: 1,
                name: String::from("Alice"),
                email: String::from("alice@example.com"),
            },
            User {
                id: 2,
                name: String::from("Bob"),
                email: String::from("bob@example.com"),
            },
        ];

        users.into_iter().find(|u| u.id == id)
    }

    match query_user(1) {
        Some(user) => println!("    ✅ 사용자 발견: {} ({})", user.name, user.email),
        None => println!("    ❌ 사용자를 찾을 수 없습니다"),
    }

    match query_user(999) {
        Some(user) => println!("    ✅ 사용자 발견: {} ({})", user.name, user.email),
        None => println!("    ❌ 사용자를 찾을 수 없습니다"),
    }
    println!();

    // ─────────────────────────────────────────
    // 7-2. 여러 단계의 검증
    // ─────────────────────────────────────────
    println!("  [7-2] 여러 단계의 검증");

    fn validate_and_process_user(name: &str, age: u32) -> Result<String, String> {
        // 1단계: 이름 검증
        if name.is_empty() {
            return Err(String::from("이름이 비어있습니다"));
        }

        // 2단계: 나이 검증
        if age < 18 {
            return Err(String::from("18세 이상이어야 합니다"));
        }

        // 3단계: 성공
        Ok(format!("{}님 환영합니다 (나이: {})", name, age))
    }

    let result1 = validate_and_process_user("Alice", 25);
    let result2 = validate_and_process_user("", 25);
    let result3 = validate_and_process_user("Charlie", 15);

    println!("    Case 1: {:?}", result1);
    println!("    Case 2: {:?}", result2);
    println!("    Case 3: {:?}", result3);
    println!();

    // ─────────────────────────────────────────
    // 7-3. 신호 처리 시스템
    // ─────────────────────────────────────────
    println!("  [7-3] 신호 처리 시스템");

    #[derive(Debug)]
    enum SystemEvent {
        DataReady(String),
        ProcessError(String),
        NoData,
    }

    fn fetch_data(sensor_id: u32) -> Result<String, String> {
        match sensor_id {
            1 => Ok(String::from("온도: 25.5°C")),
            2 => Ok(String::from("습도: 60%")),
            _ => Err(String::from("센서 연결 실패")),
        }
    }

    fn process_sensor_data(id: u32) -> SystemEvent {
        match fetch_data(id) {
            Ok(data) => SystemEvent::DataReady(data),
            Err(e) => SystemEvent::ProcessError(e),
        }
    }

    let events = vec![
        process_sensor_data(1),
        process_sensor_data(2),
        process_sensor_data(999),
    ];

    println!("    센서 데이터 처리:");
    for event in events {
        match event {
            SystemEvent::DataReady(data) => {
                println!("      ✅ 데이터 수신: {}", data);
            }
            SystemEvent::ProcessError(e) => {
                println!("      ❌ 오류: {}", e);
            }
            SystemEvent::NoData => {
                println!("      ℹ️  데이터 없음");
            }
        }
    }
    println!();

    // ─────────────────────────────────────────
    // 7-4. 설정 파일 로딩
    // ─────────────────────────────────────────
    println!("  [7-4] 복합 에러 처리");

    fn load_application_config() -> Result<String, String> {
        let config_path = "app.config";

        // 1. 파일 읽기
        let content = read_file_content(config_path)?;

        // 2. 파싱
        let _value = parse_integer("8080")?;

        // 3. 검증
        if content.is_empty() {
            return Err(String::from("설정이 비어있습니다"));
        }

        Ok(format!("설정 로드 완료: {}", content))
    }

    match load_application_config() {
        Ok(msg) => println!("    ✅ {}", msg),
        Err(e) => println!("    ❌ {}", e),
    }
    println!();

    println!("  💡 핵심: Option과 Result로 실제 프로덕션 코드의 에러를 안전하게 처리합니다.\n");
}

