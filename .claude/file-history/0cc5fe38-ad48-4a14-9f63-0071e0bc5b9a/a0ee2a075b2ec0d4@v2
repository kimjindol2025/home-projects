// ============================================================================
// 클로저(Closure): 환경을 캡처하는 함수
// ============================================================================

use crate::environment::Environment;
use crate::function::GogsFunction;

/// 클로저 환경
pub struct ClosureEnvironment {
    /// 클로저가 캡처한 바깥 변수들
    pub captured_vars: Vec<String>,

    /// 클로저가 정의된 환경
    pub defining_env: Environment,
}

impl ClosureEnvironment {
    /// 새로운 클로저 환경 생성
    pub fn new(defining_env: Environment) -> Self {
        ClosureEnvironment {
            captured_vars: Vec::new(),
            defining_env,
        }
    }

    /// 변수 캡처
    pub fn capture(&mut self, var_name: String) {
        if !self.captured_vars.contains(&var_name) {
            self.captured_vars.push(var_name);
        }
    }

    /// 캡처된 변수 확인
    pub fn is_captured(&self, var_name: &str) -> bool {
        self.captured_vars.contains(&var_name.to_string())
    }
}

/// 클로저 분석
pub struct ClosureAnalysis {
    /// 캡처된 변수 개수
    pub captured_count: usize,

    /// 바깥 환경 깊이
    pub env_depth: usize,

    /// 메모리 점유 예상 크기 (바이트)
    pub memory_estimate: usize,
}

impl ClosureAnalysis {
    /// 함수에서 클로저 분석
    pub fn analyze(func: &GogsFunction) -> Self {
        let captured_count = func.closure_env.bindings.len();
        let env_depth = func.closure_env.depth();
        let memory_estimate = captured_count * 16 + env_depth * 8; // 대략적 추정

        ClosureAnalysis {
            captured_count,
            env_depth,
            memory_estimate,
        }
    }

    /// 분석 결과 출력
    pub fn report(&self) {
        println!("Closure Analysis:");
        println!("  Captured variables: {}", self.captured_count);
        println!("  Environment depth: {}", self.env_depth);
        println!("  Estimated memory: {} bytes", self.memory_estimate);
    }
}

/// 함수형 프로그래밍 유틸리티

/// 함수 합성: (f ∘ g)(x) = f(g(x))
pub fn compose(
    f: Box<dyn Fn(i64) -> i64>,
    g: Box<dyn Fn(i64) -> i64>,
) -> Box<dyn Fn(i64) -> i64> {
    Box::new(move |x| f(g(x)))
}

/// 부분 적용: 매개변수를 일부만 바인딩
pub fn partial_apply(
    func: &GogsFunction,
    bound_args: Vec<i64>,
) -> Result<GogsFunction, String> {
    if bound_args.len() > func.parameters.len() {
        return Err("Too many arguments".to_string());
    }

    // 바인딩된 매개변수 개수
    let _remaining_arity = func.parameters.len() - bound_args.len();

    Ok(GogsFunction::new(
        func.parameters[bound_args.len()..].to_vec(),
        Box::new(move |_env, args| {
            // bound_args와 args를 합쳐서 호출
            let mut all_args = bound_args.clone();
            all_args.extend_from_slice(args);

            // 원래 함수 호출 시뮬레이션
            Ok(all_args.iter().sum())
        }),
    ))
}

/// 고차 함수: 함수를 받아서 함수를 반환
pub fn map_with_function(
    values: Vec<i64>,
    transformer: &GogsFunction,
) -> Result<Vec<i64>, String> {
    let mut result = Vec::new();
    for value in values {
        let transformed = transformer.call(&[value])?;
        result.push(transformed);
    }
    Ok(result)
}

/// 필터링: 조건을 만족하는 값들만
pub fn filter_with_function(
    values: Vec<i64>,
    predicate: &GogsFunction,
) -> Result<Vec<i64>, String> {
    let mut result = Vec::new();
    for value in values {
        let is_match = predicate.call(&[value])?;
        if is_match != 0 {
            result.push(value);
        }
    }
    Ok(result)
}

/// 축약(Fold): 값들을 하나로 축약
pub fn fold_with_function(
    values: Vec<i64>,
    initial: i64,
    combiner: &GogsFunction,
) -> Result<i64, String> {
    let mut accumulator = initial;
    for value in values {
        accumulator = combiner.call(&[accumulator, value])?;
    }
    Ok(accumulator)
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_closure_capture() {
        let mut env = Environment::global();
        env.set("x".to_string(), 10);

        let func = GogsFunction::new(
            vec!["y".to_string()],
            Box::new(|env, _| {
                let x = env.get("x").unwrap_or(0);
                let y = env.get("y").unwrap_or(0);
                Ok(x + y)
            }),
        ).with_closure_env(env);

        let analysis = ClosureAnalysis::analyze(&func);
        assert!(analysis.captured_count > 0);
    }

    #[test]
    fn test_partial_application() {
        let add = GogsFunction::new(
            vec!["x".to_string(), "y".to_string()],
            Box::new(|env, _| {
                let x = env.get("x").unwrap_or(0);
                let y = env.get("y").unwrap_or(0);
                Ok(x + y)
            }),
        );

        let add_5 = partial_apply(&add, vec![5]);
        assert!(add_5.is_ok());
    }
}
