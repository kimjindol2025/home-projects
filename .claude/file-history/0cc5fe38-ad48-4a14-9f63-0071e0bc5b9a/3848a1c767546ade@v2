### 패턴 4: URL 파싱

```rust
fn parse_url(url: &str) -> Option<(&str, &str, &str)> {
    if let Some(proto_end) = url.find("://") {
        let protocol = &url[0..proto_end];
        let rest = &url[proto_end + 3..];

        if let Some(path_start) = rest.find("/") {
            let host = &rest[0..path_start];
            let path = &rest[path_start..];
            return Some((protocol, host, path));
        } else {
            return Some((protocol, rest, ""));
        }
    }
    None
}

// 사용
if let Some((proto, host, path)) = parse_url("https://example.com/api") {
    println!("프로토콜: {}", proto);
    println!("호스트: {}", host);
    println!("경로: {}", path);
}
```

