// 트리 워킹 인터프리터: AST를 순회하며 실행합니다.

pub mod ast;
pub mod object;
pub mod environment;
pub mod evaluator;

pub use ast::{Program, Statement, Expression};
pub use object::GogsObject;
pub use environment::Environment;
pub use evaluator::Evaluator;

/// 프로그램을 평가하고 결과를 반환
pub fn eval(program: Program) -> GogsObject {
    let mut evaluator = Evaluator::new();
    evaluator.eval_program(program)
}

#[cfg(test)]
mod tests {
    use super::*;
    use crate::ast::{InfixOp, Expression};

    #[test]
    fn test_integer_evaluation() {
        let program = Program::new(vec![
            Statement::Expression(Expression::IntegerLiteral(42)),
        ]);

        let result = eval(program);
        assert_eq!(result, GogsObject::Integer(42));
    }

    #[test]
    fn test_integer_addition() {
        let program = Program::new(vec![
            Statement::Expression(Expression::Infix {
                left: Box::new(Expression::IntegerLiteral(5)),
                operator: InfixOp::Plus,
                right: Box::new(Expression::IntegerLiteral(10)),
            }),
        ]);

        let result = eval(program);
        assert_eq!(result, GogsObject::Integer(15));
    }

    #[test]
    fn test_boolean_evaluation() {
        let program = Program::new(vec![
            Statement::Expression(Expression::BooleanLiteral(true)),
        ]);

        let result = eval(program);
        assert_eq!(result, GogsObject::Boolean(true));
    }
}
