// 러스트 시스템 프로그래밍의 기초
// Phase 1 ~ 6 진행 중
// [저장 필수] 기록이 증명이다 gogs: 프로젝트 진화 로그

// Phase 6: 제네릭과 트레이트를 활용한 유연성 확대
use gogs_project::{GogsEngine, logger, Loggable, GogsLogger};

// ==========================================
// Phase 6.1: 기본 제네릭과 트레이트 예제
// ==========================================

/// 학습 작업을 나타내는 구조체
#[derive(Debug)]
struct Task {
    name: String,
    difficulty: u8,
}

// Task에 Loggable 트레이트를 구현
// 이제 Task도 GogsLogger에 기록될 수 있습니다!
impl Loggable for Task {
    fn format_log(&self) -> String {
        format!(
            "작업명: '{}' | 난이도: {} ⭐",
            self.name, self.difficulty
        )
    }
}

fn main() {
    println!("╔════════════════════════════════════════════════════════╗");
    println!("║ Gogs Project Level 6: Generics & Traits              ║");
    println!("║   코드의 유연성과 재사용 가능한 설계                  ║");
    println!("╚════════════════════════════════════════════════════════╝\n");

    // ==========================================
    // [6.1] 기본 제네릭과 트레이트
    // ==========================================
    println!("🧬 [6.1] 기본 제네릭과 트레이트\n");

    // Task 구조체 생성
    let task1: Task = Task {
        name: String::from("변수와 불변성 이해"),
        difficulty: 3,
    };

    let task2: Task = Task {
        name: String::from("소유권(Ownership) 마스터"),
        difficulty: 9,
    };

    // GogsLogger<Task>를 사용해 Task를 기록
    // 이것이 제네릭과 트레이트의 힘입니다!
    let logger_task1 = GogsLogger { entry: task1 };
    let logger_task2 = GogsLogger { entry: task2 };

    logger_task1.record();
    logger_task2.record();
    println!();

    // ==========================================
    // [6.2] 엔진과의 통합
    // ==========================================
    println!("📌 [6.2] 모듈 시스템과 제네릭의 통합\n");

    // GogsEngine도 사용
    let mut engine = GogsEngine::new("Gogs Advanced Edition");
    engine.print_status();

    // ==========================================
    // [6.3] 제네릭의 장점: Code Reuse
    // ==========================================
    println!("📌 [6.3] 제네릭의 장점: 중복 코드 제거\n");

    // 다른 타입도 같은 GogsLogger를 사용할 수 있습니다!
    // (이는 core.rs에서 더 자세히 다룰 것입니다)
    logger::info("제네릭 함수 하나로 여러 타입을 처리합니다");
    logger::debug("Task → GogsLogger → record()");

    println!();

    // ==========================================
    // [6.4] 트레이트 바운드: 안전성 확보
    // ==========================================
    println!("📌 [6.4] 트레이트 바운드와 안전성\n");

    logger::info("GogsLogger<T: Loggable>는 T가 Loggable을 구현해야 함");
    logger::debug("이를 통해 컴파일 타임에 안전성을 확보합니다");

    println!();

    // ==========================================
    // [6.5] 다형성: 같은 인터페이스, 다른 동작
    // ==========================================
    println!("📌 [6.5] 다형성 (Polymorphism)\n");

    println!("✅ 같은 record() 호출:");
    logger_task1.record();
    logger_task2.record();

    println!("\n💡 두 record() 호출이 다른 Task 정보를 출력했습니다!");
    println!("   이것이 다형성입니다!\n");

    // ==========================================
    // [6.6] 프로젝트 진행 상황
    // ==========================================
    println!("═════════════════════════════════════════════════════════");
    println!("📊 Gogs 프로젝트 진행 상황");
    println!("═════════════════════════════════════════════════════════");

    engine.advance_phase();
    engine.advance_phase();

    println!("✅ Phase 1: 변수와 불변성");
    println!("✅ Phase 2: 제어 흐름");
    println!("✅ Phase 3: 소유권");
    println!("✅ Phase 4: 구조체와 열거형");
    println!("✅ Phase 5: 모듈 시스템");
    println!("🚀 Phase 6: 제네릭과 트레이트 (현재)\n");

    println!("📈 전체 진도: 60/100 (60%) 🎯\n");

    logger::gogs_signature();
    println!("저장 필수, 너는 기록이 증명이다 gogs 🔥\n");
}
