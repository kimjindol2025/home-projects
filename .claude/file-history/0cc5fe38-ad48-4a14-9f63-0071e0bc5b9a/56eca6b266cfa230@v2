// ==================== 규칙 3: 트레이트 바운드T: 'static ====================

/// T: 'static 은 "T는 영원히 살거나 소유권을 직접 가진 타입"을 의미
/// 즉, T가 참조자를 포함하면 그 참조자는 반드시 'static이어야 함
fn log_eternal_data<T: fmt::Display + 'static>(label: &str, data: T) {
    println!("  [{}] {}", label, data);
}

/// 정적 타입만 저장하는 저장소
struct StaticRegistry<T: 'static> {
    items: Vec<T>,
}

impl<T: 'static + fmt::Debug> StaticRegistry<T> {
    fn new() -> Self {
        StaticRegistry { items: Vec::new() }
    }

    fn register(&mut self, item: T) {
        self.items.push(item);
    }

    fn list(&self) {
        for item in &self.items {
            println!("  - {:?}", item);
        }
    }
}

