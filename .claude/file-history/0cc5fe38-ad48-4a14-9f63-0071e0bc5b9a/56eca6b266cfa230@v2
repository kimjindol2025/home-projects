// ==================== 규칙 5: 실전 예제 ====================

/// 프로토콜 설정 저장소 - 모두 'static
struct ProtocolConfig {
    version: &'static str,
    policy: &'static str,
    max_retries: usize,
    timeout: usize,
}

impl ProtocolConfig {
    /// 기본 설정 (모두 'static)
    fn default() -> &'static Self {
        // 주의: 함수가 반환해야 하므로 static으로 선언
        // 실제 사용 시에는 더 안전한 방법이 필요
        const CONFIG: ProtocolConfig = ProtocolConfig {
            version: "2.0.26",
            policy: "STRICT",
            max_retries: 5,
            timeout: 30000,
        };
        &CONFIG
    }

    fn display(&self) {
        println!("📋 프로토콜 설정:");
        println!("  Version: {}", self.version);
        println!("  Policy:  {}", self.policy);
        println!("  Retries: {}", self.max_retries);
        println!("  Timeout: {} ms", self.timeout);
    }
}

