// ==================== 규칙 7: 보안 프로토콜 저장소 ====================

/// 불변의 보안 프로토콜 저장소
struct SecurityProtocol {
    name: &'static str,
    version: &'static str,
    rules: Vec<&'static str>,
}

impl SecurityProtocol {
    fn new(name: &'static str, version: &'static str) -> Self {
        SecurityProtocol {
            name,
            version,
            rules: Vec::new(),
        }
    }

    fn add_rule(&mut self, rule: &'static str) {
        self.rules.push(rule);
    }

    fn display(&self) {
        println!("🔐 보안 프로토콜: {} (v{})", self.name, self.version);
        for rule in &self.rules {
            println!("  ✓ {}", rule);
        }
    }
}

// ==================== 규칙 8: 에러 타입 ====================

/// 에러 메시지는 항상 'static이어야 함
#[derive(Debug)]
enum SystemError {
    Timeout,
    AuthFailure,
    ProtocolViolation,
    Custom(&'static str),
}

impl fmt::Display for SystemError {
    fn fmt(&self, f: &mut fmt::Formatter) -> fmt::Result {
        match self {
            SystemError::Timeout => write!(f, "{}", ERROR_TIMEOUT),
            SystemError::AuthFailure => write!(f, "{}", ERROR_AUTH),
            SystemError::ProtocolViolation => write!(f, "{}", ERROR_PROTOCOL),
            SystemError::Custom(msg) => write!(f, "{}", msg),
        }
    }
}

