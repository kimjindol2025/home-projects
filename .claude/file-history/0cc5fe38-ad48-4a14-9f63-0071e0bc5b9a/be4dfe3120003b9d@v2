//! 2단계: 제어 흐름 (Control Flow)
//!
//! 이 모듈은 러스트의 제어 흐름 개념을 구현합니다:
//! - if/else 조건문
//! - match 패턴 매칭
//! - 반복문 (for, while, loop)

/// Gogs 프로젝트의 상태를 판별하는 함수입니다.
///
/// # 인자
/// * `value` - 상태를 판별할 정수값 (i32)
///
/// # 반환값
/// * `&'static str` - 상태에 따른 메시지
///
/// # 로직
/// - 7이면 'Gogs Luck!' (행운의 숫자)
/// - 10 이상이면 'Senior Goal!' (시니어 목표)
/// - 그 외에는 'Keep Going!' (계속 진행)
///
/// # 예제
/// ```
/// let result = check_gogs_status(7);
/// assert_eq!(result, "Gogs Luck!");
/// ```
pub fn check_gogs_status(value: i32) -> &'static str {
    match value {
        7 => "Gogs Luck! 🍀",
        10..=i32::MAX => "Senior Goal! 🚀",
        _ => "Keep Going! 💪",
    }
}

/// 레벨별 학습 목표를 반환합니다.
///
/// # 인자
/// * `level` - 현재 레벨 (i32)
///
/// # 반환값
/// * `&'static str` - 레벨에 해당하는 학습 목표
///
/// # 예제
/// ```
/// let goal = get_level_goal(1);
/// assert_eq!(goal, "기초 변수 확립");
/// ```
pub fn get_level_goal(level: i32) -> &'static str {
    match level {
        1 => "기초 변수 확립",
        2 => "논리 구조 설계",
        3 => "소유권 개념 파악",
        4 => "구조체와 메서드",
        5 => "Trait과 다형성",
        _ => "미지의 영역 탐험",
    }
}

/// 학습 상태를 평가하는 함수입니다.
///
/// # 인자
/// * `hours` - 학습한 시간 (u32)
///
/// # 반환값
/// * `&'static str` - 평가 결과
pub fn evaluate_progress(hours: u32) -> &'static str {
    if hours < 1 {
        "아직 시작하지 않음"
    } else if hours < 5 {
        "시작 단계"
    } else if hours < 20 {
        "진행 중"
    } else if hours < 50 {
        "중급 진행"
    } else {
        "시니어 수준"
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_check_gogs_status_lucky() {
        assert_eq!(check_gogs_status(7), "Gogs Luck! 🍀");
    }

    #[test]
    fn test_check_gogs_status_senior() {
        assert_eq!(check_gogs_status(10), "Senior Goal! 🚀");
        assert_eq!(check_gogs_status(15), "Senior Goal! 🚀");
    }

    #[test]
    fn test_check_gogs_status_keep_going() {
        assert_eq!(check_gogs_status(5), "Keep Going! 💪");
        assert_eq!(check_gogs_status(8), "Keep Going! 💪");
    }

    #[test]
    fn test_get_level_goal() {
        assert_eq!(get_level_goal(1), "기초 변수 확립");
        assert_eq!(get_level_goal(2), "논리 구조 설계");
        assert_eq!(get_level_goal(3), "소유권 개념 파악");
    }

    #[test]
    fn test_evaluate_progress() {
        assert_eq!(evaluate_progress(0), "아직 시작하지 않음");
        assert_eq!(evaluate_progress(3), "시작 단계");
        assert_eq!(evaluate_progress(10), "진행 중");
        assert_eq!(evaluate_progress(30), "중급 진행");
        assert_eq!(evaluate_progress(60), "시니어 수준");
    }
}
