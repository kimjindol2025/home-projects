## 🎯 5개 핵심 패턴

### 패턴 1: Derive 매크로 - GogsInfo

```rust
#[proc_macro_derive(GogsInfo)]
pub fn gogs_info_derive(input: TokenStream) -> TokenStream {
    let DeriveInput { ident, data, .. } = parse_macro_input!(input as DeriveInput);

    let field_count = match &data {
        Data::Struct(data) => match &data.fields {
            Fields::Named(fields) => fields.named.len(),
            _ => 0,
        },
        _ => 0,
    };

    let expanded = quote! {
        impl #ident {
            pub fn print_gogs_info(&self) {
                println!("Type: {}", stringify!(#ident));
                println!("Fields: {}", #field_count);
            }
        }
    };

    TokenStream::from(expanded)
}

// 사용
#[derive(GogsInfo)]
struct User { id: u32, name: String }

user.print_gogs_info();
// 출력: Type: User, Fields: 2
```

**학습 포인트**: Derive 매크로 기초, 필드 카운팅, quote! 사용

