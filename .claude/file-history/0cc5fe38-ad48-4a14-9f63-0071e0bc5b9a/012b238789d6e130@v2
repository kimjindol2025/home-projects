### 패턴 3: 빌더 패턴 - GogsBuilder

```rust
#[proc_macro_derive(GogsBuilder)]
pub fn gogs_builder_derive(input: TokenStream) -> TokenStream {
    let DeriveInput { ident, data, .. } = parse_macro_input!(input as DeriveInput);

    let (field_names, setter_methods, builder_fields) = /* 필드 분석 */;
    let builder_name = quote::format_ident!("{}Builder", ident);

    let expanded = quote! {
        impl #ident {
            pub fn builder() -> #builder_name {
                #builder_name { #(#field_names: None,)* }
            }
        }

        pub struct #builder_name {
            #(#builder_fields)*
        }

        impl #builder_name {
            #(#setter_methods)*

            pub fn build(self) -> #ident {
                #ident {
                    #(
                        #field_names: self.#field_names.unwrap_or_default(),
                    )*
                }
            }
        }
    };

    TokenStream::from(expanded)
}

// 사용
#[derive(GogsBuilder)]
struct DatabaseConfig {
    host: String,
    port: u16,
}

let config = DatabaseConfig::builder()
    .host("localhost".to_string())
    .port(5432)
    .build();
```

**학습 포인트**: 복잡한 매크로, 반복 처리, Option<T> 패턴, build() 메서드

