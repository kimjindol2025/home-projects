### 패턴 5: 필드 반복 처리

```rust
#[proc_macro_derive(GogsStats)]
pub fn gogs_stats_derive(input: TokenStream) -> TokenStream {
    let DeriveInput { ident, data, .. } = parse_macro_input!(input as DeriveInput);

    let field_count = match &data {
        Data::Struct(data) => match &data.fields {
            Fields::Named(fields) => fields.named.len(),
            Fields::Unnamed(fields) => fields.unnamed.len(),
            Fields::Unit => 0,
        },
        _ => 0,
    };

    let expanded = quote! {
        impl #ident {
            pub fn gogs_stats() -> String {
                format!("Type: {}\nFields: {}", stringify!(#ident), #field_count)
            }
        }
    };

    TokenStream::from(expanded)
}

// 사용
#[derive(GogsStats)]
struct DataModel { id: u32, name: String }

println!("{}", DataModel::gogs_stats());
// 출력: Type: DataModel, Fields: 2
```

**학습 포인트**: 반복적 필드 처리, 통계 정보 수집

