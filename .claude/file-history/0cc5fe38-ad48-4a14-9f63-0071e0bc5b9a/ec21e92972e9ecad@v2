// ╔══════════════════════════════════════════════════════════════╗
// ║                                                              ║
// ║     언어 설계 프로젝트: 제2장 최종 - 논리의 집약             ║
// ║                                                              ║
// ║  "모든 경우의 수를 하나의 거대한 논리 체계로 묶는 정점"      ║
// ║                                                              ║
// ║  v3.4: 패턴 매칭 (Pattern Matching)                         ║
// ║  상태 머신(State Machine)의 완성                             ║
// ║                                                              ║
// ╚══════════════════════════════════════════════════════════════╝

fn main() {
    println!("\n╔══════════════════════════════════════════════════════════════╗");
    println!("║                                                              ║");
    println!("║     🎯 v3.4: 논리의 집약 (Pattern Matching)                 ║");
    println!("║                                                              ║");
    println!("║     상태 머신의 완성 - 모든 경우를 빈틈없이 처리             ║");
    println!("║                                                              ║");
    println!("╚══════════════════════════════════════════════════════════════╝\n");

    // ══════════════════════════════════════════════════════════════
    // [v3.4 설계 철학]
    // ══════════════════════════════════════════════════════════════
    //
    // v3.0: 의지 (IF/LOOP/MATCH 기초)
    // v3.1: 판단력 (&&, ||, IF-expression)
    // v3.2: 자동화 (FOR/WHILE/LOOP 심화)
    // v3.3: 자의식 (무결성 검증)
    // v3.4: 완벽성 (패턴 매칭 완성) ✨
    //
    // v3.4는 v3.0~v3.3의 최정점입니다.
    // 단순 if-else 분기를 넘어,
    // 모든 경우의 수를 하나의 논리 체계로 통합합니다.
    //

    println!("═══════════════════════════════════════════════════════════════");
    println!("🎯 [v3.4 설계 목표]\n");

    println!("1️⃣ 전수 조사 (Exhaustiveness)");
    println!("   모든 경우의 수를 빠짐없이 처리하는가?\n");

    println!("2️⃣ 구조적 분해 (Destructuring)");
    println!("   복잡한 데이터를 패턴으로 분해할 수 있는가?\n");

    println!("3️⃣ 가독성 혁명");
    println!("   else if 덩어리를 깔끔한 match로 대체했는가?\n");

    println!("4️⃣ 가드 (Match Guards)");
    println!("   패턴 + 조건으로 촘촘한 논리를 구성했는가?\n");

    println!("5️⃣ 와일드카드");
    println!("   '나머지 전부'를 명시적으로 처리하는가?\n");

    println!("6️⃣ 효율성");
    println!("   match는 내부적으로 점프 테이블로 최적화되는가?\n");

    // ══════════════════════════════════════════════════════════════
    // [부분 1] match 문의 기초: 단순 값 매칭
    // ══════════════════════════════════════════════════════════════

    println!("═══════════════════════════════════════════════════════════════");
    println!("▶ [부분 1] match의 기초: 단순 값 매칭\n");

    let core_id = 1;

    println!("원칙: 각 패턴은 명확한 의미를 가져야 함");
    println!("  1️⃣ 정확한 값: match 1 => ...");
    println!("  2️⃣ 여러 값: match 2 | 3 | 4 => ...");
    println!("  3️⃣ 전체: match _ => ...\n");

    println!("실행: Core ID = {}\n", core_id);

    match core_id {
        1 => println!("  ✓ Core 1: 메인 프로세서"),
        2 => println!("  ✓ Core 2: 첫 번째 보조"),
        3 => println!("  ✓ Core 3: 두 번째 보조"),
        _ => println!("  ? Unknown Core"),
    }

    println!("\n[설계자의 관찰]");
    println!("  if-else가 필요 없음");
    println!("  match 자체가 이미 완벽한 분기");
    println!("  모든 경우가 처리됨 (컴파일러 검증)");

    // ══════════════════════════════════════════════════════════════
    // [부분 2] 범위 패턴: 여러 값을 한번에
    // ══════════════════════════════════════════════════════════════

    println!("\n═══════════════════════════════════════════════════════════════");
    println!("▶ [부분 2] 범위 패턴: 구간별 처리\n");

    let core_id = 5;
    let priority = 50;

    println!("원칙: 5..=10은 '5부터 10까지'를 한 패턴으로 처리");
    println!("  1️⃣ 배타적: 5..10 (5~9)");
    println!("  2️⃣ 포함적: 5..=10 (5~10)");
    println!("  3️⃣ 조합: 1..=3 | 7..=9\n");

    println!("실행: Core ID = {}\n", core_id);

    match core_id {
        1 => println!("  ✓ Core 1: 독립 CPU"),
        2..=4 => println!("  ✓ Cores 2-4: 보조 그룹"),
        5..=10 => println!("  ✓ Cores 5-10: 확장 그룹"),
        11..=20 => println!("  ✓ Cores 11-20: 초과 그룹"),
        _ => println!("  ? 범위를 벗어남"),
    }

    println!("\n[설계자의 관찰]");
    println!("  여러 else if를 한 라인으로 정리");
    println!("  의도가 명확해짐 (5~10의 범위)");
    println!("  코드의 가독성 혁명!");

    // ══════════════════════════════════════════════════════════════
    // [부분 3] 가드 (Match Guards): 패턴 + 조건
    // ══════════════════════════════════════════════════════════════

    println!("\n═══════════════════════════════════════════════════════════════");
    println!("▶ [부분 3] 가드 (Match Guards): 촘촘한 논리\n");

    let core_id = 7;
    let system_status = "OVERLOAD";
    let temperature = 95;

    println!("원칙: 패턴 매칭만으로는 부족한 세밀한 조건을 추가");
    println!("  문법: match value {");
    println!("      pattern if condition => result,");
    println!("  }\n");

    println!("실행: Core ID = {}, Status = {}, Temp = {}°C\n", core_id, system_status, temperature);

    match core_id {
        5..=10 if system_status == "OVERLOAD" && temperature > 90 => {
            println!("  🚨 [CRITICAL] Core {} 과부하 + 고온 상태!", core_id);
            println!("     즉각 냉각 조치 필요!");
        }
        5..=10 if system_status == "OVERLOAD" => {
            println!("  ⚠️  [WARNING] Core {} 과부하 상태", core_id);
            println!("     모니터링 필요");
        }
        5..=10 if temperature > 85 => {
            println!("  🌡️  [HEAT] Core {} 온도 상승 중", core_id);
            println!("     냉각팬 작동");
        }
        5..=10 => {
            println!("  ✓ [STABLE] Core {} 정상 작동", core_id);
        }
        _ => println!("  ? 범위 외 코어"),
    }

    println!("\n[설계자의 관찰]");
    println!("  범위 + 조건으로 촘촘한 논리 구성");
    println!("  각 경로가 명확함 (과부하+고온 vs 과부하만 vs 고온만)");
    println!("  중첩 if-else를 완전히 제거!");

    // ══════════════════════════════════════════════════════════════
    // [부분 4] 와일드카드: '나머지 전부'의 명시적 처리
    // ══════════════════════════════════════════════════════════════

    println!("\n═══════════════════════════════════════════════════════════════");
    println!("▶ [부분 4] 와일드카드: 예외 상황 처리\n");

    let core_id = 99;

    println!("원칙: '_'는 '여기에 오는 모든 나머지'를 의미");
    println!("  1️⃣ 명시적: _ => println!(\"Unknown\")");
    println!("  2️⃣ 바인딩: other => println!(\"Code: {}\", other)");
    println!("  3️⃣ 스킵: (_, value) => use value\n");

    println!("실행: Core ID = {}\n", core_id);

    match core_id {
        1 => println!("  ✓ 메인 코어"),
        2..=10 => println!("  ✓ 보조 코어"),
        _ => println!("  ? 예상 밖의 코어 ID (정의 필요)"),
    }

    println!("\n[설계자의 관찰]");
    println!("  와일드카드로 예외 처리");
    println!("  모든 경우가 처리되므로 컴파일러 만족");
    println!("  에러 상황도 명시적으로 표현");

    // ══════════════════════════════════════════════════════════════
    // [부분 5] match as expression: 값 반환
    // ══════════════════════════════════════════════════════════════

    println!("\n═══════════════════════════════════════════════════════════════");
    println!("▶ [부분 5] match as expression: 값 반환\n");

    let system_status = "WARNING";

    println!("원칙: match 자체가 값을 반환하므로 변수에 할당 가능");
    println!("  모든 암(arm)이 같은 타입을 반환해야 함\n");

    let action_plan = match system_status {
        "STABLE" => "Monitor",
        "WARNING" => "Alert Administrator",
        "OVERLOAD" => "Force Cooling",
        "SHUTDOWN" => "Emergency Stop",
        _ => "Standard Procedure",
    };

    println!("실행: Status = {}\n", system_status);
    println!("  → Action Plan: {}", action_plan);
    println!("  → 코드가 매우 간결하고 명확함\n");

    // 다른 상태도 확인
    let statuses = vec!["STABLE", "WARNING", "OVERLOAD", "SHUTDOWN", "UNKNOWN"];
    println!("[모든 상태 확인]");
    for status in statuses {
        let plan = match status {
            "STABLE" => "Monitor",
            "WARNING" => "Alert",
            "OVERLOAD" => "Cool",
            "SHUTDOWN" => "Stop",
            _ => "Standard",
        };
        println!("  {} → {}", status, plan);
    }

    println!("\n[설계자의 관찰]");
    println!("  match 표현식의 강력함");
    println!("  변수 할당이 불변성을 유지");
    println!("  if-else let으로 가변성을 추가할 필요 없음");

    // ══════════════════════════════════════════════════════════════
    // [부분 6] 구조적 분해: 복잡한 데이터 처리
    // ══════════════════════════════════════════════════════════════

    println!("\n═══════════════════════════════════════════════════════════════");
    println!("▶ [부분 6] 구조적 분해: 복잡한 데이터 추출\n");

    let core_status = (5, "OVERLOAD", 92);  // (id, status, temp)

    println!("원칙: 패턴으로 튜플/구조를 즉석에서 분해");
    println!("  (id, status, temp) 같은 형태로 값 추출\n");

    println!("실행: Core Status = {:?}\n", core_status);

    match core_status {
        (1, "STABLE", _) => println!("  ✓ Main core stable"),
        (id, "OVERLOAD", temp) if temp > 90 => {
            println!("  🚨 Core {} OVERLOAD with high temp {}°C", id, temp);
        }
        (id, status, temp) => {
            println!("  ✓ Core {}: {} status, {}°C", id, status, temp);
        }
    }

    println!("\n[설계자의 관찰]");
    println!("  복잡한 데이터를 패턴으로 분해");
    println!("  필요한 값만 추출하여 사용");
    println!("  (id, status, temp) 같은 명명이 이미 문서");

    // ══════════════════════════════════════════════════════════════
    // [부분 7] 상태 머신: 최종 통합
    // ══════════════════════════════════════════════════════════════

    println!("\n═══════════════════════════════════════════════════════════════");
    println!("▶ [부분 7] 상태 머신: 제2장 최종 통합\n");

    let states = vec![
        (1, "STABLE", 65),
        (5, "WARNING", 80),
        (7, "OVERLOAD", 95),
        (10, "STABLE", 70),
        (99, "UNKNOWN", 50),
    ];

    println!("원칙: 모든 상태 전이를 match로 처리");
    println!("  각 상태별 명확한 의사결정\n");

    println!("상태 머신 실행:\n");

    for (id, status, temp) in states {
        let action = match (id, status, temp) {
            // 메인 코어: 안정성 최우선
            (1, "STABLE", _) => "Monitor Main Core",

            // 보조 코어 (2-4): 일반 처리
            (2..=4, status, _) => match status {
                "STABLE" => "Normal Operation",
                "WARNING" => "Check Auxiliary",
                "OVERLOAD" => "Reduce Load",
                _ => "Error",
            },

            // 확장 코어 (5-10): 세밀한 관리
            (5..=10, "STABLE", t) if t < 75 => "Continue",
            (5..=10, "STABLE", t) if t < 85 => "Monitor Temperature",
            (5..=10, "STABLE", _) => "Apply Cooling",
            (5..=10, "WARNING", _) => "Prepare Throttle",
            (5..=10, "OVERLOAD", t) if t > 90 => "Emergency Shutdown",
            (5..=10, "OVERLOAD", _) => "Reduce Frequency",

            // 그 외
            (_, _, _) => "Unknown State",
        };

        println!("  Core {} ({}, {}°C) → {}", id, status, temp, action);
    }

    println!("\n[최종 설계자의 말]");
    println!("═══════════════════════════════════════════════════════════════");
    println!();
    println!("v3.0~v3.4를 거치며 언어는 다음을 얻었습니다:");
    println!();
    println!("✅ 의지:     조건에 따라 경로를 선택할 수 있음");
    println!("✅ 판단력:   복합 조건으로 정교한 분석 가능");
    println!("✅ 자동화:   반복을 통해 규칙을 자동으로 적용");
    println!("✅ 자의식:   모든 경계에서 안전성을 검증");
    println!("✅ 완벽성:   패턴 매칭으로 모든 경우를 빈틈없이 처리");
    println!();
    println!("이제 언어는:");
    println!("- 존재합니다");
    println!("- 데이터를 관리합니다");
    println!("- 스스로 판단합니다");
    println!("- 효율적으로 선택합니다");
    println!("- 지치지 않고 반복합니다");
    println!("- 논리적으로 완벽합니다");
    println!("- 모든 상황을 빈틈없이 처리합니다 ← NEW");
    println!();
    println!("이것이 제2장 [흐름의 통제]의 완성입니다.");
    println!();
    println!("의지 → 판단력 → 자동화 능력 → 자의식 → 완벽성");
    println!();
    println!("다음: 제3장 [모듈화의 초석] — 함수(Functions)");
    println!("      이 거대한 로직들을 부품화하여 재사용합니다.");
    println!();
    println!("═══════════════════════════════════════════════════════════════");
}
