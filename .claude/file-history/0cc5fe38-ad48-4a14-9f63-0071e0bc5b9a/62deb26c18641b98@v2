    struct DatabaseConnection {
        connected: bool,
        authenticated: bool,
        transaction_active: bool,
    }

    impl DatabaseConnection {
        fn execute_query(&self, query: &str) -> Result<String, String> {
            // 가드 1: 연결 확인
            if !self.connected {
                return Err("[G1] 데이터베이스 연결되지 않음".to_string());
            }

            // 가드 2: 인증 확인
            if !self.authenticated {
                return Err("[G2] 인증되지 않은 사용자".to_string());
            }

            // 가드 3: 트랜잭션 확인
            if !self.transaction_active {
                return Err("[G3] 활성 트랜잭션 없음".to_string());
            }

            // 청정 구역: 안전한 쿼리 실행
            Ok(format!("✅ 쿼리 실행 완료: {}", query))
        }
    }

