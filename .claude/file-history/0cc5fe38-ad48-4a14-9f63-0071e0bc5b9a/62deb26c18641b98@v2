    #[derive(Debug)]
    enum SystemState {
        Idle,
        Running,
        Error(String),
    }

    fn process_state_transition(current_state: &SystemState, can_transition: bool) {
        // 가드 1: 상태 확인
        match current_state {
            SystemState::Error(msg) => {
                println!("  [GUARD] 에러 상태입니다: {}", msg);
                return;
            }
            _ => println!("  ✅ 상태 정상"),
        }

        // 가드 2: 전이 가능 여부
        if !can_transition {
            println!("  [GUARD] 상태 전이가 불가능합니다.");
            return;
        }
        println!("  ✅ 전이 가능");

        // 청정 구역: 실제 상태 전이 로직
        println!("  🔄 상태 전이 진행 중...");
        match current_state {
            SystemState::Idle => println!("  → Idle → Running"),
            SystemState::Running => println!("  → Running → Idle"),
            _ => println!("  → Unknown transition"),
        }
    }

    println!("시나리오 1: 정상 전이\\n");
    process_state_transition(&SystemState::Idle, true);

