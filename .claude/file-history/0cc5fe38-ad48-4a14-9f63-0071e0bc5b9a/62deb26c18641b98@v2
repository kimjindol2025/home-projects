    fn safe_divide(numerator: i32, denominator: i32) -> Option<i32> {
        // 가드: 0으로 나누기 방지
        if denominator == 0 {
            println!("  [GUARD] 분모가 0입니다. 연산 불가.");
            return None;
        }

        // 불변 보증: 이 시점부터 denominator != 0 이라고 보장
        println!("  ✅ [INVARIANT] denominator != 0 보장됨");
        println!("  → 안전하게 나누기 가능");

        Some(numerator / denominator)
    }

    println!("정상 호출: 10 / 2\\n");
    let result1 = safe_divide(10, 2);
    println!("  결과: {:?}", result1);

