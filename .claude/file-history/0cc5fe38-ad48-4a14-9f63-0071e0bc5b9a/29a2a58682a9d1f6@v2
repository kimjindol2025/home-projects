## 🏗️ 실전 패턴: 로그 관리 시스템

```rust
struct LogEntry {
    timestamp: String,
    level: String,
    message: String,
}

struct LogManager {
    entries: Vec<LogEntry>,
}

impl LogManager {
    fn new() -> Self {
        LogManager {
            entries: Vec::with_capacity(100),  // 사전 할당
        }
    }

    fn log(&mut self, level: &str, message: &str) {
        self.entries.push(LogEntry {
            timestamp: String::from("2026-02-22"),
            level: String::from(level),
            message: String::from(message),
        });
    }

    // 필터링: 함수형 스타일
    fn errors(&self) -> Vec<&LogEntry> {
        self.entries
            .iter()
            .filter(|entry| entry.level == "ERROR")
            .collect()
    }

    // 통계: fold 활용
    fn count_by_level(&self, level: &str) -> usize {
        self.entries
            .iter()
            .filter(|entry| entry.level == level)
            .count()
    }
}
```

