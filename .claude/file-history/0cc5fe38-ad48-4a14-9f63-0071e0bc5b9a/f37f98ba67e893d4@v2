// ============================================================================
// Token Definition: Gogs-Lang 어휘 분석 결과물
// ============================================================================
// 어휘 분석기(Lexer)가 소스코드를 분석하여 생성하는 의미 있는 최소 단위

use std::fmt;

/// Token: 소스코드를 구성하는 최소 의미 단위
#[derive(Debug, Clone, PartialEq)]
#[allow(dead_code)]
pub enum Token {
    // ========== 키워드 ==========
    Let,        // let
    Fn,         // fn
    If,         // if
    Else,       // else
    Return,     // return
    While,      // while
    For,        // for
    Break,      // break
    Continue,   // continue
    Const,      // const
    Mut,        // mut
    True,       // true
    False,      // false
    Null,       // null

    // ========== 식별자 & 리터럴 ==========
    Ident(String),    // 변수/함수명 (x, foo, myVar)
    Int(i64),         // 정수 (10, 42, 0)
    Float(f64),       // 실수 (3.14, 2.5)
    String(String),   // 문자열 ("hello", "world")
    Char(char),       // 문자 ('a', 'b')

    // ========== 연산자 ==========
    Plus,             // +
    Minus,            // -
    Asterisk,         // *
    Slash,            // /
    Percent,          // %
    Assign,           // =
    EqualEqual,       // ==
    NotEqual,         // !=
    Less,             // <
    Greater,          // >
    LessEqual,        // <=
    GreaterEqual,     // >=
    Bang,             // !
    Ampersand,        // &
    Pipe,             // |
    Caret,            // ^
    LeftShift,        // <<
    RightShift,       // >>
    PlusAssign,       // +=
    MinusAssign,      // -=
    AsteriskAssign,   // *=
    SlashAssign,      // /=

    // ========== 구두점 ==========
    LeftParen,        // (
    RightParen,       // )
    LeftBrace,        // {
    RightBrace,       // }
    LeftBracket,      // [
    RightBracket,     // ]
    Semicolon,        // ;
    Colon,            // :
    Comma,            // ,
    Dot,              // .
    Arrow,            // ->
    FatArrow,         // =>
    Ellipsis,         // ...

    // ========== 특수 토큰 ==========
    Newline,          // 줄바꿈 (선택적)
    EOF,              // 파일 끝
    Unknown(char),    // 정의되지 않은 문자
}

impl fmt::Display for Token {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        match self {
            Token::Let => write!(f, "Let"),
            Token::Fn => write!(f, "Fn"),
            Token::If => write!(f, "If"),
            Token::Else => write!(f, "Else"),
            Token::Return => write!(f, "Return"),
            Token::While => write!(f, "While"),
            Token::For => write!(f, "For"),
            Token::Ident(s) => write!(f, "Ident({})", s),
            Token::Int(n) => write!(f, "Int({})", n),
            Token::Float(n) => write!(f, "Float({})", n),
            Token::String(s) => write!(f, "String(\"{}\")", s),
            Token::Plus => write!(f, "Plus"),
            Token::Minus => write!(f, "Minus"),
            Token::Asterisk => write!(f, "Asterisk"),
            Token::Slash => write!(f, "Slash"),
            Token::Assign => write!(f, "Assign"),
            Token::EqualEqual => write!(f, "EqualEqual"),
            Token::LeftParen => write!(f, "LeftParen"),
            Token::RightParen => write!(f, "RightParen"),
            Token::LeftBrace => write!(f, "LeftBrace"),
            Token::RightBrace => write!(f, "RightBrace"),
            Token::Semicolon => write!(f, "Semicolon"),
            Token::Comma => write!(f, "Comma"),
            Token::EOF => write!(f, "EOF"),
            _ => write!(f, "{:?}", self),
        }
    }
}

/// 토큰의 위치 정보 (에러 메시지 용)
#[derive(Debug, Clone, PartialEq)]
pub struct Position {
    pub line: usize,      // 줄 번호 (1부터 시작)
    pub column: usize,    // 열 번호 (1부터 시작)
    pub byte_offset: usize, // 바이트 오프셋
}

impl Position {
    pub fn new(line: usize, column: usize, byte_offset: usize) -> Self {
        Position {
            line,
            column,
            byte_offset,
        }
    }

    #[allow(dead_code)]
    pub fn start() -> Self {
        Position {
            line: 1,
            column: 1,
            byte_offset: 0,
        }
    }
}

impl fmt::Display for Position {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        write!(f, "{}:{}", self.line, self.column)
    }
}

/// 토큰과 위치 정보를 함께 관리
#[derive(Debug, Clone, PartialEq)]
pub struct TokenWithPos {
    pub token: Token,
    pub position: Position,
}

impl TokenWithPos {
    pub fn new(token: Token, position: Position) -> Self {
        TokenWithPos { token, position }
    }
}

impl fmt::Display for TokenWithPos {
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {
        write!(f, "[{}] {}", self.position, self.token)
    }
}
