let handle1 = thread::spawn(|| { /* 계산 1 */ });
let handle2 = thread::spawn(|| { /* 계산 2 */ });
let handle3 = thread::spawn(|| { /* 계산 3 */ });

// 4 코어 시스템 = ~4배 빠름
```

### 상황 2: I/O 대기 시간 숨기기

```rust
// 스레드 1: 네트워크 요청 (느림)
let handle1 = thread::spawn(|| {
    fetch_from_api()
});

// 스레드 2: 로컬 처리 (빠름)
let handle2 = thread::spawn(|| {
    process_local_data()
});

// 두 작업이 동시 진행 → 전체 시간 단축
```

### 상황 3: 응답성 개선

```rust
// 메인: UI 응답
// 워커: 무거운 작업

// 무거운 작업을 워커로 → UI 반응 빠름
```

