//! Gogs 엔진의 핵심 모듈
//!
//! 이 모듈은 Gogs 프로젝트의 중앙 엔진을 제공합니다.
//! 모든 기능의 진입점이 되는 GogsEngine 구조체를 정의합니다.

/// Gogs 프로젝트의 중앙 엔진 구조체
///
/// 이 구조체는 프로젝트의 상태와 버전을 관리합니다.
/// 내부 필드들은 캡슐화되어 있어 직접 수정할 수 없습니다.
#[derive(Debug)]
pub struct GogsEngine {
    /// 공개 필드: 엔진의 이름
    pub name: String,
    /// 비공개 필드: 엔진의 버전 (외부에서 직접 수정 불가)
    version: f32,
    /// 비공개 필드: 현재 학습 단계
    current_phase: u32,
}

impl GogsEngine {
    /// 새로운 GogsEngine 인스턴스를 생성합니다.
    ///
    /// # 인자
    /// * `name` - 엔진의 이름
    ///
    /// # 반환값
    /// * `Self` - 초기화된 GogsEngine 인스턴스
    ///
    /// # 예제
    /// ```
    /// let engine = GogsEngine::new("Standard Gogs");
    /// ```
    pub fn new(name: &str) -> Self {
        Self {
            name: name.to_string(),
            version: 1.0,
            current_phase: 1,
        }
    }

    /// 엔진의 상태를 출력합니다.
    pub fn print_status(&self) {
        println!("═════════════════════════════════════");
        println!("🔧 Gogs Engine Status");
        println!("═════════════════════════════════════");
        println!("엔진 이름: {}", self.name);
        println!("버전: {}", self.version);
        println!("현재 단계: Phase {}", self.current_phase);
        println!("═════════════════════════════════════\n");
    }

    /// 엔진의 버전을 반환합니다 (읽기만 가능).
    pub fn get_version(&self) -> f32 {
        self.version
    }

    /// 현재 학습 단계를 반환합니다.
    pub fn get_current_phase(&self) -> u32 {
        self.current_phase
    }

    /// 단계를 진행합니다.
    pub fn advance_phase(&mut self) {
        if self.current_phase < 10 {
            self.current_phase += 1;
            println!("✅ Phase {} 진행 완료!", self.current_phase);
        } else {
            println!("⚠️ 최종 단계에 도달했습니다.");
        }
    }

    /// 엔진의 모든 정보를 상세히 출력합니다.
    pub fn print_full_info(&self) {
        self.print_status();
        println!("엔진 정보 조회 완료");
        println!("저장 필수, 너는 기록이 증명이다 gogs 🔥\n");
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_gogs_engine_new() {
        let engine = GogsEngine::new("Test Engine");
        assert_eq!(engine.name, "Test Engine");
        assert_eq!(engine.get_version(), 1.0);
        assert_eq!(engine.get_current_phase(), 1);
    }

    #[test]
    fn test_advance_phase() {
        let mut engine = GogsEngine::new("Test");
        let initial_phase = engine.get_current_phase();
        engine.advance_phase();
        assert_eq!(engine.get_current_phase(), initial_phase + 1);
    }

    #[test]
    fn test_version_immutable() {
        let engine = GogsEngine::new("Test");
        // version은 비공개이므로 직접 접근 불가
        // engine.version = 2.0;  // ❌ 컴파일 에러!
        assert_eq!(engine.get_version(), 1.0);
    }
}
