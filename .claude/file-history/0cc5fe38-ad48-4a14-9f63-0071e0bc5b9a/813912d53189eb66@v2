pub mod token;
pub mod lexer;

pub use token::{Token, Position, TokenWithPos};
pub use lexer::Lexer;

/// 소스코드를 토큰화
pub fn tokenize(source: String) -> Vec<TokenWithPos> {
    let mut lexer = Lexer::new(source);
    lexer.tokenize()
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_simple_tokens() {
        let source = "let x = 10;".to_string();
        let tokens = tokenize(source);

        assert_eq!(tokens[0].token, Token::Let);
        assert_eq!(tokens[1].token, Token::Ident("x".to_string()));
        assert_eq!(tokens[2].token, Token::Assign);
        assert_eq!(tokens[3].token, Token::Int(10));
        assert_eq!(tokens[4].token, Token::Semicolon);
        assert_eq!(tokens[5].token, Token::EOF);
    }

    #[test]
    fn test_arithmetic() {
        let source = "5 + 10 * 2".to_string();
        let tokens = tokenize(source);

        assert_eq!(tokens[0].token, Token::Int(5));
        assert_eq!(tokens[1].token, Token::Plus);
        assert_eq!(tokens[2].token, Token::Int(10));
        assert_eq!(tokens[3].token, Token::Asterisk);
        assert_eq!(tokens[4].token, Token::Int(2));
    }

    #[test]
    fn test_string_literal() {
        let source = r#""hello world""#.to_string();
        let tokens = tokenize(source);

        assert_eq!(tokens[0].token, Token::String("hello world".to_string()));
    }
}
