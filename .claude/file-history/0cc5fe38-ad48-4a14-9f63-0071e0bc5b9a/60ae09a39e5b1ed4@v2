## 📊 v10.1이 필요한 3가지 상황

### 상황 1: 다중 소스 수집

```rust
let (tx, rx) = mpsc::channel();

// 여러 센서에서 데이터 전송
for _ in 0..10 {
    let tx = tx.clone();
    thread::spawn(move || {
        for data in sensor_read() {
            tx.send(data).unwrap();
        }
    });
}

// 중앙에서 모든 데이터 처리
for data in rx {
    process(data);
}
```

### 상황 2: 작업 큐

```rust
let (tx, rx) = mpsc::channel();

// 작업 생성자들
for _ in 0..num_producers {
    let tx = tx.clone();
    thread::spawn(move || {
        for task in generate_tasks() {
            tx.send(task).unwrap();
        }
    });
}

// 단일 작업 처리자
for task in rx {
    execute(task);
}
```

### 상황 3: 이벤트 기반 처리

```rust
enum Event {
    UserInput(String),
    Timer(u64),
    NetworkData(Vec<u8>),
}

let (tx, rx) = mpsc::channel();

// 여러 이벤트 소스
thread::spawn(move || {
    for event in get_user_input() {
        tx.send(Event::UserInput(event)).unwrap();
    }
});

// 중앙 이벤트 루프
for event in rx {
    match event {
        Event::UserInput(data) => handle_input(data),
        Event::Timer(id) => handle_timer(id),
        Event::NetworkData(data) => handle_network(data),
    }
}
```

