//! Gogs 프로젝트 1학년 기말고사: 미니 로깅 시스템
//!
//! Phase 1-6 모든 개념을 통합한 시스템:
//! - Phase 1: 변수와 불변성
//! - Phase 2: 제어 흐름 (match, loop)
//! - Phase 3: 소유권과 참조
//! - Phase 4: 구조체와 열거형
//! - Phase 5: 모듈 시스템
//! - Phase 6: 제네릭과 트레이트

use std::fmt::Display;

// ==========================================
// Phase 4: 열거형 (Enum)
// ==========================================

/// 로그 레벨을 나타내는 열거형
///
/// Info: 일반 정보 로그
/// Warning: 경고 로그
/// Error(u32): 에러 로그 (에러 코드 포함)
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum LogLevel {
    /// 일반 정보
    Info,
    /// 경고
    Warning,
    /// 에러 (에러 코드 포함)
    Error(u32),
}

impl LogLevel {
    /// 로그 레벨을 문자열로 변환합니다.
    pub fn as_str(&self) -> &'static str {
        match self {
            LogLevel::Info => "INFO",
            LogLevel::Warning => "WARN",
            LogLevel::Error(_) => "ERROR",
        }
    }

    /// 에러 코드를 반환합니다. (Error일 경우에만)
    pub fn error_code(&self) -> Option<u32> {
        match self {
            LogLevel::Error(code) => Some(*code),
            _ => None,
        }
    }

    /// 심각한 에러 여부를 판별합니다. (404 이상)
    pub fn is_critical(&self) -> bool {
        match self {
            LogLevel::Error(code) => *code >= 404,
            _ => false,
        }
    }
}

// ==========================================
// Phase 6: 제네릭 구조체
// ==========================================

/// 로그 메시지를 나타내는 제네릭 구조체
///
/// # 제네릭 파라미터
/// * `T` - 메시지 본문 타입 (Display를 구현해야 함)
#[derive(Debug)]
pub struct LogMessage<T> {
    /// 로그 레벨
    pub level: LogLevel,
    /// 로그 타임스탐프 (간단히 ID로 표현)
    pub timestamp: u64,
    /// 메시지 본문
    pub content: T,
}

impl<T> LogMessage<T> {
    /// 새로운 LogMessage를 생성합니다.
    pub fn new(level: LogLevel, timestamp: u64, content: T) -> Self {
        LogMessage {
            level,
            timestamp,
            content,
        }
    }

    /// 로그 레벨을 반환합니다.
    pub fn level(&self) -> LogLevel {
        self.level
    }

    /// 타임스탬프를 반환합니다.
    pub fn timestamp(&self) -> u64 {
        self.timestamp
    }
}

// ==========================================
// Phase 6: 트레이트 (Trait)
// ==========================================

/// 출력 가능한 모든 것에 대한 약속(Trait)
///
/// 이 트레이트를 구현하는 타입은 format_message() 메서드를 반드시 제공해야 합니다.
pub trait Printable {
    /// 메시지를 형식화된 문자열로 반환합니다.
    fn format_message(&self) -> String;

    /// 메시지를 출력합니다 (기본 구현)
    fn print(&self) {
        println!("{}", self.format_message());
    }
}

// ==========================================
// Phase 6: 트레이트 구현 (Trait Bounds)
// ==========================================

/// LogMessage<T>가 Printable을 구현합니다.
/// 단, T는 Display를 구현해야 합니다. (제네릭 제약)
impl<T: Display> Printable for LogMessage<T> {
    fn format_message(&self) -> String {
        format!(
            "[{}] (ts: {}) {}",
            self.level.as_str(),
            self.timestamp,
            self.content
        )
    }
}

// ==========================================
// 유틸리티 함수
// ==========================================

/// 여러 로그 메시지를 처리하는 함수
///
/// # 인자
/// * `messages` - 로그 메시지 슬라이스 (참조)
/// * `should_halt_on_critical` - 심각한 에러 발생 시 중단 여부
///
/// # 반환값
/// * critical 에러 발생 시 에러 코드를 반환
pub fn process_logs<T: Display>(
    messages: &[LogMessage<T>],
    should_halt_on_critical: bool,
) -> Option<u32> {
    for message in messages {
        // Printable 트레이트의 print() 메서드 호출
        message.print();

        // Phase 2: match를 사용한 제어 흐름
        if should_halt_on_critical {
            match message.level() {
                LogLevel::Error(code) if code >= 404 => {
                    return Some(code);
                }
                _ => continue,
            }
        }
    }

    None
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_log_level_str() {
        assert_eq!(LogLevel::Info.as_str(), "INFO");
        assert_eq!(LogLevel::Warning.as_str(), "WARN");
        assert_eq!(LogLevel::Error(500).as_str(), "ERROR");
    }

    #[test]
    fn test_log_level_error_code() {
        assert_eq!(LogLevel::Info.error_code(), None);
        assert_eq!(LogLevel::Error(404).error_code(), Some(404));
    }

    #[test]
    fn test_log_level_is_critical() {
        assert!(!LogLevel::Info.is_critical());
        assert!(!LogLevel::Warning.is_critical());
        assert!(!LogLevel::Error(403).is_critical());
        assert!(LogLevel::Error(404).is_critical());
        assert!(LogLevel::Error(500).is_critical());
    }

    #[test]
    fn test_log_message_new() {
        let msg = LogMessage::new(LogLevel::Info, 1000, "Test message");
        assert_eq!(msg.level(), LogLevel::Info);
        assert_eq!(msg.timestamp(), 1000);
    }

    #[test]
    fn test_printable_format() {
        let msg = LogMessage::new(LogLevel::Info, 100, "System started");
        let formatted = msg.format_message();
        assert!(formatted.contains("INFO"));
        assert!(formatted.contains("100"));
        assert!(formatted.contains("System started"));
    }

    #[test]
    fn test_process_logs_no_critical() {
        let messages = vec![
            LogMessage::new(LogLevel::Info, 1, "Start"),
            LogMessage::new(LogLevel::Warning, 2, "Careful"),
            LogMessage::new(LogLevel::Info, 3, "End"),
        ];

        let result = process_logs(&messages, true);
        assert_eq!(result, None);
    }

    #[test]
    fn test_process_logs_with_critical() {
        let messages = vec![
            LogMessage::new(LogLevel::Info, 1, "Start"),
            LogMessage::new(LogLevel::Error(404), 2, "Not found"),
            LogMessage::new(LogLevel::Info, 3, "Never reached"),
        ];

        let result = process_logs(&messages, true);
        assert_eq!(result, Some(404));
    }
}
