//! 로깅 유틸리티 모듈
//!
//! 이 모듈은 프로젝트 전체에서 사용되는 로깅 함수를 제공합니다.

/// 정보 메시지를 로그로 출력합니다.
///
/// # 인자
/// * `msg` - 출력할 메시지
///
/// # 예제
/// ```
/// info("프로젝트 시작");
/// ```
pub fn info(msg: &str) {
    println!("ℹ️  [INFO] {}", msg);
}

/// 디버그 메시지를 로그로 출력합니다.
///
/// # 인자
/// * `msg` - 출력할 메시지
///
/// # 예제
/// ```
/// debug("변수 확인");
/// ```
pub fn debug(msg: &str) {
    println!("🐛 [DEBUG] {}", msg);
}

/// 성공 메시지를 로그로 출력합니다.
///
/// # 인자
/// * `msg` - 출력할 메시지
///
/// # 예제
/// ```
/// success("작업 완료");
/// ```
pub fn success(msg: &str) {
    println!("✅ [SUCCESS] {}", msg);
}

/// 경고 메시지를 로그로 출력합니다.
///
/// # 인자
/// * `msg` - 출력할 메시지
pub fn warning(msg: &str) {
    println!("⚠️  [WARNING] {}", msg);
}

/// 에러 메시지를 로그로 출력합니다.
///
/// # 인자
/// * `msg` - 출력할 메시지
pub fn error(msg: &str) {
    println!("❌ [ERROR] {}", msg);
}

/// Gogs 프로젝트의 시그니처 메시지를 출력합니다.
pub fn gogs_signature() {
    println!("저장 필수, 너는 기록이 증명이다 gogs 🔥");
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_logger_functions() {
        // 이 테스트는 로거 함수들이 panic하지 않는지 확인합니다
        info("테스트 정보");
        debug("테스트 디버그");
        success("테스트 성공");
        warning("테스트 경고");
        error("테스트 에러");
        gogs_signature();
    }
}
