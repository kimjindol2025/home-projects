// 🧠 v9.2: RefCell<T>과 내부 가변성 (RefCell and Interior Mutability)
// 🔗 "불변 참조로 내부 데이터를 수정하기"
// 🎯 "런타임 대여 검사를 통한 안전한 규칙 우회"
//
// 핵심 개념:
// - RefCell<T>: 컴파일 타임이 아닌 런타임에 대여 규칙을 검사
// - 내부 가변성: 불변 값을 가진 상태에서 내부 데이터를 수정
// - borrow()와 borrow_mut(): 런타임 대여 규칙 검사
// - panic!: 규칙 위반 시 컴파일 에러 대신 실행 시점에 panic
// - 싱글 스레드 전용: 멀티 스레드에서는 Mutex<T> 사용

use std::cell::RefCell;
use std::rc::Rc;

fn main() {
    println!("╔══════════════════════════════════════════════════════════╗");
    println!("║ v9.2: RefCell<T>과 내부 가변성 (Interior Mutability)    ║");
    println!("║ \\\"불변 참조로 내부 데이터 수정\\\"                          ║");
    println!("╚══════════════════════════════════════════════════════════╝\\n");

    // ==================== 섹션 1: 대여 규칙의 한계 ====================
    println!("📌 섹션 1: 러스트 대여 규칙의 한계\\n");
    {
        println!("컴파일 타임 검사 (&T):");
        println!("  ✅ 안전함");
        println!("  ✅ 컴파일 타임에 검증");
        println!("  ❌ 불변 참조로는 값 수정 불가");
        println!();\

        println!("런타임 검사 (RefCell<T>):");
        println!("  ✅ 유연함");
        println!("  ✅ 불변 참조(&self)로도 수정 가능");
        println!("  ⚠️ 런타임 에러 가능 (panic!)");
        println!();\
    }

    // ==================== 섹션 2: RefCell 기본 ====================
    println!("📌 섹션 2: RefCell<T> 기본\\n");
    {
        let value = RefCell::new(42);

        println!("불변 참조로도 값 변경 가능:");
        println!("  let value = RefCell::new(42);\");
        println!();\

        // 읽기
        println!("읽기: borrow()");
        {
            let borrowed = value.borrow();
            println!("  값: {}", *borrowed);
        }
        println!();\

        // 쓰기
        println!("쓰기: borrow_mut()");
        {
            let mut borrowed_mut = value.borrow_mut();
            *borrowed_mut = 100;
        }
        println!("  값 수정 후: {}", *value.borrow());
        println!();\
    }

    // ==================== 섹션 3: 보안 메신저 (설계자 예제) ====================
    println!("📌 섹션 3: 보안 메신저 (내부 가변성 패턴)\\n");
    {
        trait Messenger {
            fn send(&self, msg: &str);
        }

        struct GogsTracker {
            sent_messages: RefCell<Vec<String>>,
        }

        impl GogsTracker {
            fn new() -> Self {
                Self {
                    sent_messages: RefCell::new(vec![]),
                }
            }

            fn get_sent_count(&self) -> usize {
                self.sent_messages.borrow().len()
            }
        }

        impl Messenger for GogsTracker {
            fn send(&self, msg: &str) {
                // &self는 불변이지만 내부는 수정 가능
                self.sent_messages.borrow_mut().push(String::from(msg));
                println!("  [전송 완료]: {}", msg);
            }
        }

        println!("메신저 사용:");
        let tracker = GogsTracker::new();

        tracker.send("첫 번째 보안 코드");
        tracker.send("두 번째 보안 코드");
        tracker.send("세 번째 보안 코드");

        println!("  총 전송 기록 수: {}", tracker.get_sent_count());
        println!();\

        println!("핵심: &self(불변)로도 내부 값을 수정할 수 있음!");
        println!();\
    }

    // ==================== 섹션 4: borrow() vs borrow_mut() ====================
    println!("📌 섹션 4: borrow() vs borrow_mut()\\n");
    {
        println!("borrow() - 불변 대여:");
        println!("  let value = RefCell::new(42);\");
        println!("  let borrowed1 = value.borrow();\");
        println!("  let borrowed2 = value.borrow();  // 여러 개 가능\");
        println!("  // 읽기만 가능, 쓰기는 불가\");
        println!();\

        println!("borrow_mut() - 가변 대여:");
        println!("  let value = RefCell::new(42);\");
        println!("  let mut borrowed = value.borrow_mut();\");
        println!("  *borrowed = 100;  // 수정 가능\");
        println!("  // 한 번에 하나만 가능\");
        println!();\
    }

    // ==================== 섹션 5: 대여 규칙 위반 ====================
    println!("📌 섹션 5: 대여 규칙 위반 (Panic!)\\n");
    {
        println!("RefCell의 규칙:");
        println!("  ✅ 여러 불변 대여 동시 가능");
        println!("  ✅ 하나의 가변 대여만 가능");
        println!("  ❌ 불변 + 가변 대여 동시 불가");
        println!();\

        println!("규칙 위반 시나리오:");
        println!("  let value = RefCell::new(42);\");
        println!("  let borrowed1 = value.borrow();  // 불변 대여 1");
        println!("  let borrowed_mut = value.borrow_mut();  // ❌ PANIC!");
        println!();\

        println!("대여 범위 주의:");
        println!("  {{\");
        println!("    let borrowed1 = value.borrow();  // 시작");
        println!("    println!(\\\"{}\\\", *borrowed1);\");
        println!(\"  }}  // ← 여기서 끝남\");
        println!("  let borrowed_mut = value.borrow_mut();  // ✅ 가능\");
        println!();\
    }

    // ==================== 섹션 6: 로그 기록 시스템 ====================
    println!("📌 섹션 6: 로그 기록 시스템\\n");
    {
        struct Logger {
            logs: RefCell<Vec<String>>,
        }

        impl Logger {
            fn new() -> Self {
                Self {
                    logs: RefCell::new(vec![]),
                }
            }

            fn log(&self, msg: &str) {
                self.logs.borrow_mut().push(format!(
                    "[LOG] {}",
                    msg
                ));
            }

            fn print_logs(&self) {
                for (i, log) in self.logs.borrow().iter().enumerate() {
                    println!("  {}: {}", i + 1, log);
                }
            }
        }

        println!("로거 사용:");
        let logger = Logger::new();

        logger.log("시스템 시작");
        logger.log("데이터 로드");
        logger.log("설정 적용");

        println!("기록된 로그:");
        logger.print_logs();
        println!();\
    }

    // ==================== 섹션 7: Rc + RefCell 조합 ====================
    println!("📌 섹션 7: Rc + RefCell 조합\\n");
    {
        println!("공유 + 가변: Rc<RefCell<T>>");
        println!();\

        struct Node {
            data: i32,
            refcount_log: RefCell<usize>,
        }

        let node = Rc::new(Node {
            data: 42,
            refcount_log: RefCell::new(0),
        });

        println!(\"원본: data={}, log={}\", node.data, *node.refcount_log.borrow());

        {
            let cloned = Rc::clone(&node);
            *node.refcount_log.borrow_mut() += 1;
            println!(\"Clone 후: log={}\", *node.refcount_log.borrow());
        }

        {
            let cloned = Rc::clone(&node);
            *node.refcount_log.borrow_mut() += 1;
            println!(\"또 Clone: log={}\", *node.refcount_log.borrow());
        }

        println!();\
    }

    // ==================== 섹션 8: 계산기 상태 관리 ====================
    println!("📌 섹션 8: 계산기 상태 관리\\n");
    {
        struct Calculator {
            memory: RefCell<i32>,
            operation_count: RefCell<usize>,
        }

        impl Calculator {
            fn new() -> Self {
                Self {
                    memory: RefCell::new(0),
                    operation_count: RefCell::new(0),
                }
            }

            fn add(&self, x: i32) {
                let mut mem = self.memory.borrow_mut();
                *mem += x;
                *self.operation_count.borrow_mut() += 1;
            }

            fn multiply(&self, x: i32) {
                let mut mem = self.memory.borrow_mut();
                *mem *= x;
                *self.operation_count.borrow_mut() += 1;
            }

            fn result(&self) -> i32 {
                *self.memory.borrow()
            }

            fn operation_count(&self) -> usize {
                *self.operation_count.borrow()
            }
        }

        println!("계산 실행:");
        let calc = Calculator::new();

        calc.add(5);
        println!("  + 5 → {}", calc.result());

        calc.multiply(3);
        println!("  × 3 → {}", calc.result());

        calc.add(10);
        println!("  + 10 → {}", calc.result());

        println!("  연산 횟수: {}", calc.operation_count());
        println!();\
    }

    // ==================== 섹션 9: Mock 객체 테스트 ====================
    println!("📌 섹션 9: Mock 객체 테스트\\n");
    {
        trait Service {
            fn execute(&self);
        }

        struct MockService {
            calls: RefCell<Vec<String>>,
        }

        impl MockService {
            fn new() -> Self {
                Self {
                    calls: RefCell::new(vec![]),
                }
            }

            fn get_call_count(&self) -> usize {
                self.calls.borrow().len()
            }
        }

        impl Service for MockService {
            fn execute(&self) {
                self.calls.borrow_mut().push("execute called".to_string());
            }
        }

        println!("Mock 서비스:");
        let mock = MockService::new();

        mock.execute();
        mock.execute();
        mock.execute();

        println!("  호출 횟수: {}", mock.get_call_count());
        println!("  (테스트에서 동작 검증 가능)\");
        println!();\
    }

    // ==================== 섹션 10: 설계 원칙 ====================
    println!("📌 섹션 10: RefCell 설계 원칙\\n");
    {
        println!("RefCell을 사용해야 하는 경우:");
        println!();\

        println!("1️⃣  Mock 객체 테스트");
        println!(\"   // 불변 인터페이스로 호출 기록\");
        println!();\

        println!("2️⃣  로그/상태 기록");
        println!(\"   // &self로도 내부 상태 추적\");
        println!();\

        println!("3️⃣  캐시 관리");
        println!(\"   // 불변 캐시 구조에 값 저장\");
        println!();\

        println!("4️⃣  Rc와의 결합");
        println!(\"   // Rc<RefCell<T>>로 공유 + 가변\");
        println!();\
    }

    // ==================== 섹션 11: 성능 주의 ====================
    println!("📌 섹션 11: 성능과 주의사항\\n");
    {
        println!("RefCell의 오버헤드:");
        println!("  ⚠️ 모든 borrow() 호출마다 런타임 검사");
        println!("  ⚠️ Panic의 가능성");
        println!("  ⚠️ 싱글 스레드만 지원");
        println!();\

        println!("멀티 스레드에서는:");
        println!("  use std::sync::Mutex;\");
        println!(\"  let value = Mutex::new(42);\");
        println!("  let guard = value.lock().unwrap();");
        println!();\
    }

    // ==================== 섹션 12: RefCell vs 다른 패턴 ====================
    println!("📌 섹션 12: RefCell vs 다른 패턴\\n");
    {
        println!("컴파일 타임 검사 (&T):");
        println!("  장점: 안전, 오버헤드 없음");
        println!("  단점: 유연성 부족");
        println!();\

        println!("RefCell (런타임 검사):");
        println!("  장점: 유연, 내부 가변성 가능");
        println!("  단점: 런타임 오버헤드, panic 가능");
        println!();\

        println!("Mutex (스레드 안전):");
        println!("  장점: 멀티 스레드 지원");
        println!("  단점: 더 큰 오버헤드, lock 필요");
        println!();\
    }

    println!(\\\"═══════════════════════════════════════════════════════════\\\");
    println!(\\\"🎓 v9.2 완료: 불변 속의 가변성\\\");
    println!();\
    println!(\\\"당신은 이제:\\\");
    println!(\\\"✅ RefCell<T>로 불변 참조에서 내부 데이터를 수정한다\\\");
    println!(\\\"✅ 런타임 대여 검사의 원리를 이해한다\\\");
    println!(\\\"✅ 내부 가변성 패턴을 설계할 수 있다\\\");
    println!(\\\"✅ Rc + RefCell로 강력한 동적 구조를 만든다\\\");
    println!();\
    println!(\\\"저장 필수 너는 기록이 증명이다 gogs\\\");
}
