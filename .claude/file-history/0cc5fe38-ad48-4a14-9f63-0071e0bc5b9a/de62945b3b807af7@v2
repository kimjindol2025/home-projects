// ═════════════════════════════════════════════════════════════════════════════
// Section 9: Null Check와 Dangling Pointer 검증
// ═════════════════════════════════════════════════════════════════════════════
//
// 핵심: Null 포인터와 dangling 포인터는 Undefined Behavior의 원인.
//      반드시 검증해야 한다.

fn section_9_validation() {
    println!("\n╔══ Section 9: Null Check & Dangling Pointer ══╗");

    // [9-1] Null 포인터 검사
    println!("✓ Null 포인터 검사");
    let null_ptr: *const i32 = ptr::null();
    println!("  is_null() = {}", null_ptr.is_null());

    let valid_ptr: *const i32 = &42;
    println!("  유효한 포인터: is_null() = {}", valid_ptr.is_null());

    // [9-2] 안전한 Null 검증 패턴
    fn safe_dereference(ptr: *const i32) -> Option<i32> {
        if ptr.is_null() {
            None
        } else {
            unsafe { Some(*ptr) }
        }
    }

    println!("✓ 안전한 역참조 패턴");
    match safe_dereference(null_ptr) {
        Some(v) => println!("  값: {}", v),
        None => println!("  Null 포인터입니다"),
    }

    match safe_dereference(valid_ptr) {
        Some(v) => println!("  값: {}", v),
        None => println!("  Null 포인터입니다"),
    }

    // [9-3] Dangling 포인터 감지 (범위 밖)
    println!("✓ Dangling 포인터 상황 (시뮬레이션)");
    let dangling = {
        let local = 42;
        &local as *const i32
    };
    println!("  ⚠️  스택에 할당된 변수의 포인터가 범위를 벗어남");
    println!("  포인터: {:p}", dangling);
    println!("  주소: 0x{:x}", dangling as usize);
    // unsafe { println!("  값: {}", *dangling); }  // ← 이것은 UB!

    // [9-4] 유효한 범위 내에서만 사용
    println!("✓ 유효한 범위 내에서만 포인터 사용");
    let local = 42;
    let valid_dangling = &local as *const i32;
    unsafe {
        println!("  범위 내: {}", *valid_dangling);
    }  // ← 여기까지만 유효

    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
}

// ═════════════════════════════════════════════════════════════════════════════
// Section 10: 성능 측정 (안전한 접근 vs 포인터 조작)
// ═════════════════════════════════════════════════════════════════════════════
//
// 핵심: Unsafe 코드의 성능 이점을 정량 측정.

fn section_10_performance() {
    println!("\n╔══ Section 10: Performance Measurement ══╗");
    println!("💡 1,000,000회 배열 접근 성능 비교");

    let arr: Vec<i32> = (0..100).collect();

    // [10-1] 안전한 접근 (인덱싱)
    let start = std::time::Instant::now();
    let mut sum = 0i64;
    for _ in 0..10_000 {
        for (i, &val) in arr.iter().enumerate() {
            sum += val as i64;
        }
    }
    let safe_time = start.elapsed();
    println!("✓ 안전한 접근 (arr[i]): {:?}", safe_time);
    println!("  결과: {}", sum);

    // [10-2] 포인터를 사용한 접근
    let start = std::time::Instant::now();
    let mut sum = 0i64;
    let ptr = arr.as_ptr();
    unsafe {
        for _ in 0..10_000 {
            for i in 0..arr.len() {
                sum += *ptr.add(i) as i64;
            }
        }
    }
    let unsafe_time = start.elapsed();
    println!("✓ 포인터 접근 (*ptr.add(i)): {:?}", unsafe_time);
    println!("  결과: {}", sum);

    // [10-3] 포인터 산술
    let start = std::time::Instant::now();
    let mut sum = 0i64;
    let ptr = arr.as_ptr();
    unsafe {
        for _ in 0..10_000 {
            let mut p = ptr;
            let end = ptr.add(arr.len());
            while p < end {
                sum += *p as i64;
                p = p.add(1);
            }
        }
    }
    let ptr_arithmetic_time = start.elapsed();
    println!("✓ 포인터 산술 (p++): {:?}", ptr_arithmetic_time);
    println!("  결과: {}", sum);

    // [10-4] 성능 비교
    println!("✓ 성능 비교");
    let safe_ms = safe_time.as_secs_f64() * 1000.0;
    let unsafe_ms = unsafe_time.as_secs_f64() * 1000.0;
    let arithmetic_ms = ptr_arithmetic_time.as_secs_f64() * 1000.0;

    println!("  안전: {:.2}ms", safe_ms);
    println!("  포인터: {:.2}ms ({:.1}%)", unsafe_ms, (unsafe_ms / safe_ms) * 100.0);
    println!("  산술: {:.2}ms ({:.1}%)", arithmetic_ms, (arithmetic_ms / safe_ms) * 100.0);

    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
}

// ═════════════════════════════════════════════════════════════════════════════
// Section 11: 안전한 래퍼 (Unsafe를 캡슐화하기)
// ═════════════════════════════════════════════════════════════════════════════
//
// 핵심: Unsafe 코드는 반드시 안전한 인터페이스로 감싸야 한다.
//      그래야 호출자가 안전성 책임을 알 수 있다.

struct SafeVector<T> {
    data: Vec<T>,
    len: usize,
}

impl<T: Copy> SafeVector<T> {
    fn new(capacity: usize) -> Self {
        SafeVector {
            data: vec![unsafe { std::mem::zeroed() }; capacity],
            len: 0,
        }
    }

    fn push(&mut self, value: T) {
        if self.len < self.data.len() {
            self.data[self.len] = value;
            self.len += 1;
        }
    }

    fn get(&self, index: usize) -> Option<T> {
        if index < self.len {
            unsafe { Some(*self.data.as_ptr().add(index)) }
        } else {
            None
        }
    }

    fn len(&self) -> usize {
        self.len
    }
}

fn section_11_safe_wrapper() {
    println!("\n╔══ Section 11: Safe Wrapper ══╗");
    println!("💡 Unsafe 코드를 안전한 인터페이스로 캡슐화");

    // [11-1] 안전한 벡터 구현
    let mut vec = SafeVector::<i32>::new(10);
    println!("✓ 커스텀 SafeVector 생성");

    // [11-2] Push/Get 사용
    println!("✓ 데이터 추가 및 읽기");
    for i in 0..5 {
        vec.push(i * 10);
    }

    println!("  데이터: {:?}", (0..vec.len()).map(|i| vec.get(i)).collect::<Vec<_>>());

    // [11-3] 경계 검사
    println!("✓ 경계 검사");
    match vec.get(2) {
        Some(v) => println!("  vec[2] = {}", v),
        None => println!("  vec[2] = 범위 밖"),
    }

    match vec.get(100) {
        Some(v) => println!("  vec[100] = {}", v),
        None => println!("  vec[100] = 범위 밖"),
    }

    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
}

