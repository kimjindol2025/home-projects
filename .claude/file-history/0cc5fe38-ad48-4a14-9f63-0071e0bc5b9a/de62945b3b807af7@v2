#![allow(unused_variables)]

use std::mem;
use std::ptr;

// ═════════════════════════════════════════════════════════════════════════════
// Section 1: Raw Pointers 기본 (불변과 가변 포인터)
// ═════════════════════════════════════════════════════════════════════════════
//
// 핵심: Rust의 대부분의 메모리는 컴파일 타임에 안전성을 검증하지만,
//      Raw pointers는 이 검증을 우회한다. 대신 절대적 자유를 얻는다.

fn section_1_raw_pointers_basic() {
    println!("\n╔══ Section 1: Raw Pointers Basic ══╗");

    // [1-1] 불변 포인터 생성 (*const T)
    let x = 42;
    let ptr_const: *const i32 = &x as *const i32;
    println!("✓ 불변 포인터 생성: {:p}", ptr_const);

    // [1-2] 가변 포인터 생성 (*mut T)
    let mut y = 100;
    let ptr_mut: *mut i32 = &mut y as *mut i32;
    println!("✓ 가변 포인터 생성: {:p}", ptr_mut);

    // [1-3] 포인터 해제 (역참조는 unsafe 필요)
    unsafe {
        let value = *ptr_const;
        println!("✓ 포인터 해제 (읽기): *ptr_const = {}", value);

        *ptr_mut = 200;
        println!("✓ 포인터 해제 (쓰기): *ptr_mut = 200");
    }

    // [1-4] Null 포인터
    let null_ptr: *const i32 = ptr::null();
    println!("✓ Null 포인터: {:p}", null_ptr);
    println!("  is_null() = {}", null_ptr.is_null());

    // [1-5] 포인터 비교
    println!("✓ 포인터 비교: ptr_const == ptr_mut? {}", ptr_const == ptr_mut as *const i32);

    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
}

// ═════════════════════════════════════════════════════════════════════════════
// Section 2: Unsafe Blocks와 Unsafe Functions
// ═════════════════════════════════════════════════════════════════════════════
//
// 핵심: unsafe 키워드는 책임의 경계를 표시한다.
//      "여기서부터는 내가 메모리 안전성을 보장한다"는 약속이다.

unsafe fn dangerous_read(ptr: *const i32) -> i32 {
    // 이 함수는 unsafe! 호출자는 포인터가 유효함을 보장해야 함
    *ptr
}

fn unsafe_function_example() {
    println!("✓ unsafe fn를 호출할 때도 unsafe 블록 필요");
    let x = 42;
    let ptr = &x as *const i32;

    let value = unsafe { dangerous_read(ptr) };
    println!("  읽은 값: {}", value);
}

unsafe fn dangerous_write(ptr: *mut i32, value: i32) {
    // 이 함수도 unsafe! 호출자가 포인터 유효성을 보장
    *ptr = value;
}

fn section_2_unsafe_blocks() {
    println!("\n╔══ Section 2: Unsafe Blocks & Functions ══╗");

    // [2-1] Unsafe block 기본
    let mut x = 42;
    let ptr = &mut x as *mut i32;

    unsafe {
        println!("✓ unsafe 블록 안에서 포인터 조작 가능");
        *ptr = 100;
        println!("  값 변경: {}", *ptr);
    }

    // [2-2] Unsafe function 호출
    unsafe_function_example();

    // [2-3] Unsafe function으로 쓰기
    unsafe {
        dangerous_write(ptr, 200);
        println!("✓ unsafe fn으로 쓰기: {}", *ptr);
    }

    // [2-4] Unsafe 블록으로 감싸기 (안전한 인터페이스 제공)
    fn safe_read(ptr: *const i32) -> Option<i32> {
        if ptr.is_null() {
            None
        } else {
            unsafe { Some(*ptr) }
        }
    }

    let y = 99;
    let ptr_y = &y as *const i32;
    match safe_read(ptr_y) {
        Some(v) => println!("✓ 안전한 래퍼: 값 = {}", v),
        None => println!("  Null 포인터"),
    }

    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
}

// ═════════════════════════════════════════════════════════════════════════════
// Section 3: 메모리 주소 조작 (address_of!, 직접 주소 접근)
// ═════════════════════════════════════════════════════════════════════════════
//
// 핵심: 변수의 메모리 주소에 직접 접근하고 조작할 수 있다.
//      하지만 이는 컴파일러의 최적화를 방해할 수 있다.

fn section_3_memory_address_manipulation() {
    println!("\n╔══ Section 3: Memory Address Manipulation ══╗");

    // [3-1] 변수 주소 가져오기
    let x = 42;
    let addr = &x as *const i32;
    println!("✓ 변수 주소: {:p}", addr);
    println!("  16진수: 0x{:x}", addr as usize);

    // [3-2] 주소에서 값 읽기
    unsafe {
        let value = *addr;
        println!("✓ 주소에서 값 읽기: {}", value);
    }

    // [3-3] 포인터에서 주소 얻기
    let ptr: *const i32 = addr;
    println!("✓ 포인터 주소: {:p}", ptr);
    println!("  포인터 자체의 값(주소): 0x{:x}", ptr as usize);

    // [3-4] Mutable reference에서 포인터 얻기
    let mut y = 100;
    let addr_mut = &mut y as *mut i32;
    unsafe {
        *addr_mut = 200;
        println!("✓ Mutable 포인터로 쓰기: {}", *addr_mut);
    }

    // [3-5] 배열의 각 요소 주소
    let arr = [1, 2, 3, 4, 5];
    let arr_ptr = arr.as_ptr();
    println!("✓ 배열 첫 요소 주소: {:p}", arr_ptr);
    unsafe {
        for i in 0..5 {
            println!("  arr[{}] @ {:p} = {}", i, arr_ptr.add(i), *arr_ptr.add(i));
        }
    }

    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
}

// ═════════════════════════════════════════════════════════════════════════════
// Section 4: Virtual Memory Manager (핵심 예제)
// ═════════════════════════════════════════════════════════════════════════════
//
// 실전: 실제 메모리 관리 시스템을 구현해본다.
//      malloc/free와 유사한 간단한 메모리 할당자를 만든다.

struct SimpleMemoryManager {
    // 매우 제한된 메모리 풀 (실제로는 더 복잡)
    memory: Vec<u8>,
    allocations: Vec<(usize, usize)>,  // (시작 주소, 크기)
}

impl SimpleMemoryManager {
    fn new(size: usize) -> Self {
        SimpleMemoryManager {
            memory: vec![0u8; size],
            allocations: Vec::new(),
        }
    }

    fn allocate(&mut self, size: usize) -> Option<*mut u8> {
        // 빈 공간 찾기
        let mut current = 0;
        for &(start, len) in &self.allocations {
            if current + size <= start {
                // 이 공간을 사용할 수 있음
                self.allocations.push((current, size));
                return Some(&mut self.memory[current] as *mut u8);
            }
            current = start + len;
        }

        // 마지막 빈 공간 확인
        if current + size <= self.memory.len() {
            self.allocations.push((current, size));
            return Some(&mut self.memory[current] as *mut u8);
        }

        None
    }

    fn deallocate(&mut self, ptr: *mut u8) {
        let addr = ptr as usize;
        let base = self.memory.as_ptr() as usize;
        let offset = addr.saturating_sub(base);

        self.allocations.retain(|&(start, _)| start != offset);
    }

    fn write_value<T: Copy>(&mut self, ptr: *mut u8, value: T) -> bool {
        let size = mem::size_of::<T>();
        let addr = ptr as usize;
        let base = self.memory.as_ptr() as usize;
        let offset = addr.saturating_sub(base);

        if offset + size <= self.memory.len() {
            unsafe {
                ptr::copy_nonoverlapping(&value as *const T as *const u8, ptr, size);
            }
            true
        } else {
            false
        }
    }

    fn read_value<T: Copy>(&self, ptr: *const u8) -> Option<T> {
        let size = mem::size_of::<T>();
        let addr = ptr as usize;
        let base = self.memory.as_ptr() as usize;
        let offset = addr.saturating_sub(base);

        if offset + size <= self.memory.len() {
            unsafe {
                let mut value: T = mem::zeroed();
                ptr::copy_nonoverlapping(ptr, &mut value as *mut T as *mut u8, size);
                Some(value)
            }
        } else {
            None
        }
    }
}

fn section_4_virtual_memory_manager() {
    println!("\n╔══ Section 4: Virtual Memory Manager ══╗");
    println!("💡 간단한 메모리 할당자 구현 (malloc/free 유사)");

    let mut mgr = SimpleMemoryManager::new(1024);

    // [4-1] 메모리 할당
    let ptr_i32 = mgr.allocate(mem::size_of::<i32>());
    let ptr_i64 = mgr.allocate(mem::size_of::<i64>());

    if let Some(p) = ptr_i32 {
        println!("✓ i32 할당: {:p}", p);
        mgr.write_value(p, 42i32);
        if let Some(v) = mgr.read_value::<i32>(p) {
            println!("  쓴 값: 42, 읽은 값: {}", v);
        }
    }

    if let Some(p) = ptr_i64 {
        println!("✓ i64 할당: {:p}", p);
        mgr.write_value(p, 9999999i64);
        if let Some(v) = mgr.read_value::<i64>(p) {
            println!("  쓴 값: 9999999, 읽은 값: {}", v);
        }
    }

    // [4-2] 할당 해제
    if let Some(p) = ptr_i32 {
        mgr.deallocate(p);
        println!("✓ i32 메모리 해제");
    }

    // [4-3] 할당/해제 반복
    println!("✓ 할당/해제 반복:");
    for i in 0..3 {
        if let Some(p) = mgr.allocate(16) {
            mgr.write_value(p, i as i32);
            if let Some(v) = mgr.read_value::<i32>(p) {
                println!("  반복 {}: 값 = {}", i, v);
            }
            mgr.deallocate(p);
        }
    }

    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
}

