// Section 5: FFI (Foreign Function Interface) 기초
// ═════════════════════════════════════════════════════════════════════════════
//
// 핵심: Rust에서 C 함수를 호출할 수 있다.
//      메모리 레이아웃이 호환되어야 하고, 안전성 검증 책임은 프로그래머에게.

extern "C" {
    // libc의 strlen 함수를 선언 (실제로는 사용하지 않음)
    // fn strlen(s: *const u8) -> usize;
}

fn c_compatible_struct(value: i32) {
    println!("✓ C 호환 데이터 구조 생성");
    #[repr(C)]
    struct CCompatible {
        x: i32,
        y: i32,
    }

    let data = CCompatible { x: 42, y: 100 };
    let ptr = &data as *const CCompatible as *const u8;
    println!("  C 호환 구조체 @ {:p}", ptr);
    println!("  크기: {} bytes", mem::size_of::<CCompatible>());
}

fn section_5_ffi_basics() {
    println!("\n╔══ Section 5: FFI (Foreign Function Interface) ══╗");

    // [5-1] C 호환 데이터 구조
    println!("✓ C 호환 데이터 구조");
    c_compatible_struct(42);

    // [5-2] 포인터를 C 함수에 전달 (시뮬레이션)
    println!("✓ 외부 함수로 포인터 전달 시뮬레이션");
    let data = [1, 2, 3, 4, 5];
    let ptr = data.as_ptr();
    println!("  배열 @ {:p}", ptr);
    println!("  배열 길이: {}", data.len());

    // [5-3] Callback 함수 포인터 (함수의 주소)
    println!("✓ 함수 포인터 (Callback)");
    fn my_callback(x: i32) -> i32 {
        x * 2
    }

    let fn_ptr: fn(i32) -> i32 = my_callback;
    println!("  함수 포인터 @ {:p}", fn_ptr);
    let result = fn_ptr(21);
    println!("  실행 결과: 21 * 2 = {}", result);

    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
}

// ═════════════════════════════════════════════════════════════════════════════
// Section 6: 메모리 레이아웃 (크기, 정렬, 오프셋)
// ═════════════════════════════════════════════════════════════════════════════
//
// 핵심: 메모리 위치를 정확히 계산하려면 레이아웃을 알아야 한다.

#[repr(C)]
struct MemoryLayout {
    a: u8,
    b: u32,
    c: u8,
}

fn section_6_memory_layout() {
    println!("\n╔══ Section 6: Memory Layout ══╗");

    // [6-1] 타입의 크기와 정렬
    println!("✓ 기본 타입의 크기와 정렬");
    println!("  u8:   size={}, align={}", mem::size_of::<u8>(), mem::align_of::<u8>());
    println!("  u32:  size={}, align={}", mem::size_of::<u32>(), mem::align_of::<u32>());
    println!("  u64:  size={}, align={}", mem::size_of::<u64>(), mem::align_of::<u64>());
    println!("  bool: size={}, align={}", mem::size_of::<bool>(), mem::align_of::<bool>());

    // [6-2] 구조체의 메모리 레이아웃
    println!("✓ 구조체 메모리 레이아웃");
    println!("  MemoryLayout size={}, align={}", mem::size_of::<MemoryLayout>(), mem::align_of::<MemoryLayout>());

    // [6-3] 오프셋 계산
    let layout = MemoryLayout { a: 1, b: 2, c: 3 };
    let base = &layout as *const _ as usize;
    let a_addr = std::ptr::addr_of!(layout.a) as usize;
    let b_addr = std::ptr::addr_of!(layout.b) as usize;
    let c_addr = std::ptr::addr_of!(layout.c) as usize;

    println!("✓ 필드 오프셋");
    println!("  base         @ 0x{:x}", base);
    println!("  a (offset 0) @ 0x{:x} (+{})", a_addr, a_addr - base);
    println!("  b (offset 4) @ 0x{:x} (+{})", b_addr, b_addr - base);
    println!("  c (offset 8) @ 0x{:x} (+{})", c_addr, c_addr - base);

    // [6-4] 패딩 계산
    println!("✓ 패딩 (padding) 계산");
    println!("  a(1) + padding(3) + b(4) + c(1) + padding(3) = {} bytes",
        mem::size_of::<MemoryLayout>());

    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
}

// ═════════════════════════════════════════════════════════════════════════════
// Section 7: 포인터 산술 (Pointer Arithmetic)
// ═════════════════════════════════════════════════════════════════════════════
//
// 핵심: 포인터에 정수를 더하거나 빼서 배열 요소에 접근한다.

fn section_7_pointer_arithmetic() {
    println!("\n╔══ Section 7: Pointer Arithmetic ══╗");

    // [7-1] 배열 포인터 산술
    let arr = [10, 20, 30, 40, 50];
    let ptr = arr.as_ptr();

    println!("✓ 배열 포인터 산술");
    unsafe {
        println!("  arr[0] @ {:p} = {}", ptr, *ptr);
        println!("  arr[1] @ {:p} = {}", ptr.add(1), *ptr.add(1));
        println!("  arr[2] @ {:p} = {}", ptr.add(2), *ptr.add(2));
    }

    // [7-2] offset() 메서드
    println!("✓ offset() 메서드 (음수 오프셋 가능)");
    unsafe {
        let ptr_mid = ptr.add(2);  // arr[2]를 가리킴
        println!("  ptr.add(2)  = {}", *ptr_mid);
        println!("  ptr.offset(-1) = {}", *ptr_mid.offset(-1));  // arr[1]
        println!("  ptr.offset(1)  = {}", *ptr_mid.offset(1));   // arr[3]
    }

    // [7-3] sub() 메서드
    println!("✓ sub() 메서드");
    unsafe {
        let end_ptr = ptr.add(4);  // arr[4]를 가리킴
        println!("  ptr.add(4)    = {}", *end_ptr);
        println!("  ptr.sub(1)    = {}", *end_ptr.sub(1));  // arr[3]
        println!("  ptr.sub(2)    = {}", *end_ptr.sub(2));  // arr[2]
    }

    // [7-4] 포인터 차이 계산
    println!("✓ 포인터 간 거리");
    unsafe {
        let ptr1 = ptr.add(1);
        let ptr2 = ptr.add(4);
        let distance = ptr2.offset_from(ptr1);  // 요소 개수
        println!("  ptr.add(4) - ptr.add(1) = {} elements", distance);
    }

    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
}

// ═════════════════════════════════════════════════════════════════════════════
// Section 8: 포인터 캐스팅과 변환
// ═════════════════════════════════════════════════════════════════════════════
//
// 핵심: 포인터를 다른 타입으로 변환할 수 있지만, 메모리 레이아웃 호환성이 필수.

fn section_8_pointer_casting() {
    println!("\n╔══ Section 8: Pointer Casting & Conversion ══╗");

    // [8-1] 기본 캐스팅
    let x: i32 = 42;
    let ptr_i32 = &x as *const i32;
    let ptr_u32 = ptr_i32 as *const u32;
    println!("✓ i32 포인터를 u32 포인터로 캐스팅");
    unsafe {
        println!("  i32 값: {}", *ptr_i32);
        println!("  u32로 읽기: {}", *ptr_u32);
    }

    // [8-2] 포인터를 정수로 변환
    println!("✓ 포인터를 정수로 변환");
    let ptr = &x as *const i32;
    let addr: usize = ptr as usize;
    println!("  포인터: {:p}", ptr);
    println!("  주소(usize): 0x{:x}", addr);
    println!("  주소(10진): {}", addr);

    // [8-3] 정수를 포인터로 변환 (위험!)
    println!("✓ 정수를 포인터로 변환 (매우 위험!)");
    let addr = 0x1000usize;
    let dangerous_ptr: *const i32 = addr as *const i32;
    println!("  생성된 포인터: {:p}", dangerous_ptr);
    println!("  ⚠️  이 포인터는 유효하지 않을 가능성이 높음!");

    // [8-4] void 포인터 시뮬레이션 (*const u8 사용)
    println!("✓ 범용 포인터 (void* 시뮬레이션)");
    fn generic_pointer_handler(ptr: *const u8, size: usize) {
        println!("  포인터: {:p}, 크기: {}", ptr, size);
    }

    let value = 100i32;
    let ptr = &value as *const i32 as *const u8;
    generic_pointer_handler(ptr, mem::size_of::<i32>());

    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
