// ║                                                              ║
// ║  v3.5: 논리의 집대성 (Syntactic Sugar & Refinement)          ║
// ║  문법적 설탕을 통한 복잡성 제거, 노이즈 감소               ║
// ║                                                              ║
// ╚══════════════════════════════════════════════════════════════╝

fn main() {
    println!("\n╔══════════════════════════════════════════════════════════════╗");
    println!("║                                                              ║");
    println!("║     🔧 v3.5: 논리의 집대성 (Syntactic Sugar)                ║");
    println!("║                                                              ║");
    println!("║     간결함 속의 강력함 - 노이즈 제거의 정점                  ║");
    println!("║                                                              ║");
    println!("╚══════════════════════════════════════════════════════════════╝\n");

    // ══════════════════════════════════════════════════════════════
    // [v3.5 설계 철학]
    // ══════════════════════════════════════════════════════════════
    //
    // v3.0: 의지 (기초 흐름 제어)
    // v3.1: 판단력 (복합 조건)
    // v3.2: 자동화 (루프 심화)
    // v3.3: 자의식 (무결성 검증)
    // v3.4: 완벽성 (패턴 매칭)
    // v3.5: 정제 (문법적 설탕) ✨
    //
    // v3.5는 v3.0~v3.4의 도구들을 가장 효율적이고
    // 읽기 쉬운 형태로 정제하는 단계입니다.
    //
    // 철학: "노이즈 제거 (Noise Reduction)"
    // 관심사의 집중, 안전한 추출, 코드의 정결함
    //

    println!("═══════════════════════════════════════════════════════════════");
    println!("🎯 [v3.5 설계 목표]\n");

    println!("1️⃣ if let 패턴");
    println!("   관심 있는 경우만 처리, _ => () 제거\n");

    println!("2️⃣ while let 루프");
    println!("   조건 확인 + 데이터 추출을 동시에\n");

    println!("3️⃣ 불변성 결합");
    println!("   조건 결과를 안전하게 바인딩\n");

    println!("4️⃣ 관심사의 집중");
    println!("   코드에서 핵심 로직만 부각\n");

    println!("5️⃣ 보일러플레이트 제거");
    println!("   불필요한 반복 코드 최소화\n");

    println!("6️⃣ 안전한 추출");
    println!("   존재하지 않는 데이터 접근 원천 차단\n");

    // ══════════════════════════════════════════════════════════════
    // [부분 1] if let: match 구문의 간결화
    // ══════════════════════════════════════════════════════════════

    println!("═══════════════════════════════════════════════════════════════");
    println!("▶ [부분 1] if let: match의 간결화\n");

    let system_signal = Some("EMERGENCY_STOP");

    println!("원칙: 하나의 패턴에만 관심이 있을 때 사용");
    println!("  v3.4: match + 불필요한 _ => ()");
    println!("  v3.5: if let으로 간결화\n");

    println!("[비교 1] v3.4 스타일 (모든 경우 다루기)\n");

    match system_signal {
        Some(msg) => println!("  ✓ 신호 수신: {}", msg),
        None => (), // 관심 없지만 명시해야 함
    }

    println!("\n[비교 2] v3.5 스타일 (if let으로 간결화)\n");

    if let Some(msg) = system_signal {
        println!("  ✓ 신호 수신: {}", msg);
    }

    println!("\n[설계자의 관찰]");
    println!("  • match는 '모든 경우'를 다룸");
    println!("  • if let은 '특정 경우'에 집중");
    println!("  • 관심사가 명확해짐");
    println!("  • 코드가 40% 더 짧음");

    // ══════════════════════════════════════════════════════════════
    // [부분 2] while let: 루프의 정제
    // ══════════════════════════════════════════════════════════════

    println!("\n═══════════════════════════════════════════════════════════════");
    println!("▶ [부분 2] while let: 루프와 데이터 추출의 결합\n");

    let mut task_queue = vec!["냉각수 주입", "압력 조절", "시스템 체크"];

    println!("원칙: pop()이 Some을 반환하는 동안만 루프 실행");
    println!("  • 데이터 존재 확인");
    println!("  • 데이터 추출");
    println!("  • 루프 실행");
    println!("  이 세 가지를 한 라인으로!\n");

    println!("실행: 작업 큐 처리\n");

    while let Some(task) = task_queue.pop() {
        println!("  [실행 중] {} ... 완료 (남은 과업: {}개)", task, task_queue.len());
    }

    println!("\n[설계자의 관찰]");
    println!("  • while let은 loop 조건과 데이터 추출을 결합");
    println!("  • pop()이 None을 반환하면 자동 종료");
    println!("  • Index out of bounds 위험 완벽히 제거");
    println!("  • Intent가 매우 명확함");

    // ══════════════════════════════════════════════════════════════
    // [부분 3] if let else: 조건과 기본값
    // ══════════════════════════════════════════════════════════════

    println!("\n═══════════════════════════════════════════════════════════════");
    println!("▶ [부분 3] if let else: 조건 + 기본값\n");

    let user_input = Some("OVERRIDE");

    println!("원칙: if let + else로 두 경로를 명확하게");
    println!("  if let Some(value) = option {");
    println!("    // Some인 경우");
    println!("  } else {");
    println!("    // None인 경우 (기본값 처리)");
    println!("  }\n");

    println!("실행:\n");

    let action = if let Some(cmd) = user_input {
        format!("사용자 명령 실행: {}", cmd)
    } else {
        "자동 명령 실행: DEFAULT_ACTION".to_string()
    };

    println!("  → {}", action);

    println!("\n[설계자의 관찰]");
    println!("  • 두 경로가 명확함");
    println!("  • 값을 반환할 수 있음 (표현식)");
    println!("  • match와 비교하면 매우 간결함");

    // ══════════════════════════════════════════════════════════════
    // [부분 4] 혼합: 여러 Option/Result 처리
    // ══════════════════════════════════════════════════════════════

    println!("\n═══════════════════════════════════════════════════════════════");
    println!("▶ [부분 4] 복합 시나리오: 여러 조건의 조합\n");

    let core_id = Some(7);
    let temperature = Some(95);
    let status = Some("OVERLOAD");

    println!("원칙: if let을 중첩하여 복합 조건 표현\n");

    if let Some(id) = core_id {
        if let Some(temp) = temperature {
            if let Some(state) = status {
                println!("  Core {} ({}, {}°C)", id, state, temp);

                // v3.5: 중첩 if let의 강점
                if temp > 90 && state == "OVERLOAD" {
                    println!("  🚨 [CRITICAL] 긴급 조치 필요!");
                }
            }
        }
    }

    println!("\n[대안: 더 간결하게]\n");

    // 혹은 match와 if let을 조합
    if let (Some(id), Some(temp), Some(state)) = (core_id, temperature, status) {
        println!("  한 번에 처리: Core {} ({}, {}°C)", id, state, temp);
    }

    println!("\n[설계자의 관찰]");
    println!("  • if let 중첩: 읽기는 쉽지만 깊어질 수 있음");
    println!("  • 튜플 패턴: 여러 값을 동시에 처리");
    println!("  • 의도에 따라 선택하기");

    // ══════════════════════════════════════════════════════════════
    // [부분 5] 불변성 유지: if let과 함께
    // ══════════════════════════════════════════════════════════════

    println!("\n═══════════════════════════════════════════════════════════════");
    println!("▶ [부분 5] 불변성 유지: if let과 함께\n");

    let config = Some(("STABLE", 75));

    println!("원칙: if let으로 추출한 값은 자동으로 불변");
    println!("  각 분기에서 독립적인 바인딩\n");

    if let Some((state, value)) = config {
        // 이 범위 내에서만 state, value 사용 가능
        println!("  범위 1: state = {}, value = {}", state, value);

        // 값을 수정하려면 명시적으로
        let modified_value = value * 2;
        println!("  → 수정값: {}", modified_value);
    }

    // state, value는 이 범위에서 사용 불가능
    // 스코프 밖에서의 실수 사용 원천 차단!

    println!("\n[설계자의 관찰]");
    println!("  • 각 if let 블록은 독립적인 스코프");
    println!("  • 변수 누수 걱정 없음");
    println!("  • 불변성이 자동으로 유지됨");

    // ══════════════════════════════════════════════════════════════
    // [부분 6] 실전: 데이터 처리 파이프라인
    // ══════════════════════════════════════════════════════════════

    println!("\n═══════════════════════════════════════════════════════════════");
    println!("▶ [부분 6] 실전: 정제된 데이터 처리\n");

    let data_source = vec![
        Some(10),
        None,
        Some(20),
        Some(30),
        None,
        Some(40),
    ];

    println!("원칙: while let + if let을 결합한 안전한 처리\n");

    let mut processed = 0;
    let mut skipped = 0;

    for item in data_source {
        if let Some(value) = item {
            if value > 15 {
                println!("  ✓ 처리: {} (필터링 통과)", value);
                processed += 1;
            }
        } else {
            println!("  ⊘ 스킵: None 데이터");
            skipped += 1;
        }
    }

    println!("\n결과: 처리 {}개, 스킵 {}개", processed, skipped);

    println!("\n[설계자의 관찰]");
    println!("  • None을 무시하고 Some만 처리");
    println!("  • 추가 조건 (value > 15)도 명확함");
    println!("  • 모든 경로가 명시적이고 안전함");

    // ══════════════════════════════════════════════════════════════
    // [부분 7] 최종 통합: 정제된 엔진
    // ══════════════════════════════════════════════════════════════

    println!("\n═══════════════════════════════════════════════════════════════");
    println!("▶ [부분 7] v3.5 최종: 정제된 논리 엔진\n");

    let operations = vec![
        ("initialize", Some(true)),
        ("process", Some(false)),
        ("finalize", None),
        ("backup", Some(true)),
    ];

    println!("실행: 명령 처리 엔진 (v3.5 정제 버전)\n");

    let mut executed = 0;
    let mut failed = 0;

    for (cmd, result) in operations {
        if let Some(success) = result {
            if success {
                println!("  ✓ [{}] 성공", cmd);
                executed += 1;
            } else {
                println!("  ✗ [{}] 실패", cmd);
                failed += 1;
            }
        } else {
            println!("  ⊘ [{}] 데이터 없음", cmd);
        }
    }

    println!("\n통계: 실행 {}개, 실패 {}개", executed, failed);

    println!("\n[최종 설계자의 말]");
    println!("═══════════════════════════════════════════════════════════════");
    println!();
    println!("v3.0~v3.5를 거치며 언어는 다음을 얻었습니다:");
    println!();
    println!("✅ 의지:     조건에 따라 경로를 선택");
    println!("✅ 판단력:   복합 조건으로 정교한 분석");
    println!("✅ 자동화:   반복을 통해 규칙 자동 적용");
    println!("✅ 자의식:   모든 경계에서 안전성 검증");
    println!("✅ 완벽성:   패턴 매칭으로 빈틈 제거");
    println!("✅ 정제:     문법적 설탕으로 보일러플레이트 제거");
    println!();
    println!("이제 언어는:");
    println!("- 존재합니다");
    println!("- 데이터를 관리합니다");
    println!("- 스스로 판단합니다");
    println!("- 효율적으로 선택합니다");
    println!("- 지치지 않고 반복합니다");
    println!("- 논리적으로 완벽합니다");
    println!("- 모든 상황을 빈틈없이 처리합니다");
    println!("- 불필요한 복잡성 없이 간결합니다 ← NEW");
    println!();
    println!("이것이 제2장 [흐름의 통제]의 완성입니다.");
    println!();
    println!("의지 → 판단력 → 자동화 → 자의식 → 완벽성 → 정제");
    println!();
    println!("다음: 제3장 [모듈화의 초석] — 함수(Functions)");
    println!("      이 정제된 논리들을 부품화하여 재사용합니다.");
    println!();
    println!("═══════════════════════════════════════════════════════════════");
}
