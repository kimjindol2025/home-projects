### 3. 중첩 패턴

```rust
enum Event {
    UserAction(UserAction),
    SystemEvent(SystemEvent),
}

enum UserAction {
    Click { x: i32, y: i32 },
    KeyPress(char),
}

enum SystemEvent {
    Startup,
    Error(String),
}

match event {
    Event::UserAction(UserAction::Click { x, y }) => {
        println!("click at ({}, {})", x, y);
    }
    Event::SystemEvent(SystemEvent::Error(msg)) => {
        println!("error: {}", msg);
    }
    _ => {}
}
```

