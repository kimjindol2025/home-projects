### 4. Guard 패턴

```rust
match status {
    code @ 200..=299 => println!("success [{}]", code),
    code @ 300..=399 => println!("redirect [{}]", code),
    code @ 400..=499 => println!("client error [{}]", code),
    code @ 500..=599 => println!("server error [{}]", code),
    code => println!("unknown [{}]", code),
}

// 구조체와 결합
match person {
    Person { age, status } if age >= 18 && status == "active" => {
        println!("eligible");
    }
    _ => {}
}
```

---

### 5. 바인딩 패턴 (@)

```rust
// 범위 + 값 바인딩
match point {
    point @ Point { x, y } if x == y => {
        println!("diagonal point: {:?}", point);
    }
    _ => {}
}

// 리스트 처리
match numbers {
    [first, .., last] => {
        println!("first: {}, last: {}", first, last);
    }
    [single] => {
        println!("only one: {}", single);
    }
    [] => {
        println!("empty");
    }
}
```

