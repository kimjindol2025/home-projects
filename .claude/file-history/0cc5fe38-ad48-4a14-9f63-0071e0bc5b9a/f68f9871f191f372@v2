## 📊 실전 예제: 다층 메시지 프로세서

```rust
#[derive(Debug)]
enum Message {
    Text(String),
    Image { url: String, size: usize },
    Command { name: String, args: Vec<String> },
}

fn process(msg: Message) -> Result<String, String> {
    match msg {
        Message::Text(content) if content.len() > 1000 => {
            Err(String::from("message too long"))
        }
        Message::Text(content) => {
            Ok(format!("text processed: {} chars", content.len()))
        }
        Message::Image { url, size: s @ 0..=10_000_000 } => {
            Ok(format!("image loaded: {} ({}MB)", url, s / 1_000_000))
        }
        Message::Image { size, .. } => {
            Err(format!("image too large: {}MB", size / 1_000_000))
        }
        Message::Command { name, args: a } if a.is_empty() => {
            Ok(format!("command: {}", name))
        }
        Message::Command { name, args } => {
            Ok(format!("command: {} {:?}", name, args))
        }
    }
}
```

