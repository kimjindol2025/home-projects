```rust
// ❌ 나쁜 설계
if message_type == "text" {
    // ...
} else if message_type == "image" {
    // ...
} else if message_type == "file" {
    // ...
}

// ✅ 좋은 설계
match message {
    Message::Text(content) => { /* ... */ }
    Message::Image(url) => { /* ... */ }
    Message::File(path) => { /* ... */ }
}
```

### 규칙 2: 모든 경우 명시

```rust
// ❌ 빈틈 있음
match status {
    Status::Online => println!("online"),
    _ => {}  // Error와 Maintenance를 무시!
}

// ✅ 완벽함
match status {
    Status::Online => println!("online"),
    Status::Offline => println!("offline"),
    Status::Maintenance { duration } => println!("maintenance"),
}
```

