// ╔══════════════════════════════════════════════════════════════╗
// ║                                                              ║
// ║     언어 설계 프로젝트: 제1장 - 존재의 시작                  ║
// ║                                                              ║
// ║  "공허에 점을 찍는 것부터 시작이다"                          ║
// ║                                                              ║
// ║  v1.0 ~ v2.0: 기초 설계의 철학                              ║
// ║                                                              ║
// ╚══════════════════════════════════════════════════════════════╝

fn main() {
    println!("\n╔══════════════════════════════════════════════════════════════╗");
    println!("║                                                              ║");
    println!("║     🌍 제1장: 존재의 시작 (Architecture v1.0 ~ v2.0)        ║");
    println!("║                                                              ║");
    println!("║     언어 설계자의 첫 번째 선택: 무엇을 우선할 것인가?       ║");
    println!("║                                                              ║");
    println!("╚══════════════════════════════════════════════════════════════╝\n");

    // ══════════════════════════════════════════════════════════════
    // [v1.0] 존재의 증명: 출력과 연산
    // ══════════════════════════════════════════════════════════════
    //
    // 설계 원칙:
    // - 모든 언어의 첫 단계는 "존재를 증명"하는 것입니다.
    // - 표준 출력(stdout)을 통해 외부 세계와 통신합니다.
    // - 기초 산술 연산으로 CPU가 살아있음을 확인합니다.
    //
    // 철학:
    // "언어가 세상에 존재함을 보여주는 첫 비명이다."
    //

    println!("▶ [v1.0] 존재의 증명: 출력과 연산\n");

    // 첫 번째 선언: 시스템이 온라인임을 알림
    println!("  v1.0: System Online.");

    // 산술 연산: CPU에게 계산을 시킵니다
    let result_1: i32 = 10 + 20;
    println!("  [연산] 10 + 20 = {}", result_1);

    let result_2: f64 = 3.14 * 2.0;
    println!("  [연산] 3.14 * 2.0 = {}", result_2);

    let result_3: i32 = 100 / 5;
    println!("  [연산] 100 / 5 = {}", result_3);

    println!("  ✅ v1.0: 존재 증명 완료\n");

    // ══════════════════════════════════════════════════════════════
    // [v2.0] 메모리의 명명: 변수와 타입의 탄생
    // ══════════════════════════════════════════════════════════════
    //
    // 설계 원칙:
    // - 메모리는 이름 없는 거대한 사막입니다.
    // - 변수(let)로 울타리를 쳐서 공간을 확보합니다.
    // - 타입(:i32, :f64, :bool)으로 그 공간의 규칙을 정합니다.
    //
    // 핵심 선택 #1: "불변성을 기본으로 한다"
    // ╔════════════════════════════════════════════════════════╗
    // ║ let x = 10;      // 기본: 불변 (읽기만 가능)          ║
    // ║ let mut y = 20;  // 선택: 가변 (읽기/쓰기 가능)        ║
    // ║                                                        ║
    // ║ 왜? 안전성을 최우선으로 한다.                          ║
    // ║     변경 가능한 것은 명시적으로 표시해야 한다.          ║
    // ╚════════════════════════════════════════════════════════╝
    //
    // 핵심 선택 #2: "타입을 엄격하게 선언한다"
    // ╔════════════════════════════════════════════════════════╗
    // ║ let count: i32 = 42;     // 명시적 선언 (추천)        ║
    // ║ let name: &str = "Lang";                              ║
    // ║ let enabled: bool = true;                             ║
    // ║                                                        ║
    // ║ 왜? 컴파일 타임에 모든 타입 에러를 잡아낸다.          ║
    // ║     런타임 에러를 원천적으로 차단한다.                 ║
    // ╚════════════════════════════════════════════════════════╝
    //

    println!("▶ [v2.0] 메모리의 명명: 변수와 타입\n");

    // ─────────────────────────────────────────────────────────
    // [불변 변수 선언]
    // 한 번 정해지면 절대 바뀌지 않습니다.
    // 도서관의 "열람실 책"처럼, 누구나 볼 수 있지만
    // 함부로 수정할 수 없습니다.
    // ─────────────────────────────────────────────────────────

    println!("  [불변 변수 선언]");
    let language_name: &str = "MyLang";
    println!("    language_name: &str = \"{}\"", language_name);
    // language_name = "Other";  // ❌ 컴파일 에러!

    let version_number: f32 = 1.0;
    println!("    version_number: f32 = {}", version_number);

    let is_production: bool = false;
    println!("    is_production: bool = {}\n", is_production);

    // ─────────────────────────────────────────────────────────
    // [가변 변수 선언]
    // 한 번 정해진 후에도 필요하면 변경할 수 있습니다.
    // 개인 노트처럼, 자유롭게 수정 가능하지만
    // "mut"을 명시해야 합니다 (의도 표현).
    // ─────────────────────────────────────────────────────────

    println!("  [가변 변수 선언]");
    let mut current_version: f32 = 1.0;
    println!("    current_version: f32 = {} (초기값)", current_version);

    current_version = 1.5;
    println!("    current_version: f32 = {} (업데이트)", current_version);

    current_version = 2.0;
    println!("    current_version: f32 = {} (최종값)\n", current_version);

    // ─────────────────────────────────────────────────────────
    // [타입의 다양성]
    // 메모리 공간마다 "들어올 수 있는 것"을 정합니다.
    // ─────────────────────────────────────────────────────────

    println!("  [다양한 타입 활용]");

    let integer: i32 = 42;
    println!("    정수형 (i32):     {} bytes, 값: {}",
             std::mem::size_of_val(&integer), integer);

    let floating: f64 = 3.14159;
    println!("    부동소수점 (f64): {} bytes, 값: {}",
             std::mem::size_of_val(&floating), floating);

    let text: &str = "Hello, Language Design";
    println!("    문자열 (&str):    길이: {} chars", text.len());

    let flag: bool = true;
    println!("    불린 (bool):      {} bytes, 값: {}\n",
             std::mem::size_of_val(&flag), flag);

    // ══════════════════════════════════════════════════════════════
    // [v2.0의 핵심: 메모리의 메타포]
    // ══════════════════════════════════════════════════════════════
    //
    // 메모리는 아파트 건물입니다:
    //
    // ┌─────────────────────────────────────┐
    // │ 메모리 (아파트 건물)                │
    // ├─────────────────────────────────────┤
    // │ 🏠 [101호] "language_name"  (400호)│
    // │         불변 변수                  │
    // │         "MyLang" 저장              │
    // │         🔒 읽기만 가능             │
    // ├─────────────────────────────────────┤
    // │ 🏠 [102호] "current_version" (403호)│
    // │         가변 변수                  │
    // │         2.0 저장 (변경됨)          │
    // │         🔓 읽기/쓰기 가능          │
    // ├─────────────────────────────────────┤
    // │ 🏠 [103호] "is_production" (401호)│
    // │         불변 bool                  │
    // │         false 저장                 │
    // │         🔒 읽기만 가능             │
    // └─────────────────────────────────────┘
    //

    println!("  [메모리의 메타포]\n");
    println!("    메모리 = 아파트 건물");
    println!("    변수 = 방 (각 방은 이름이 있음)");
    println!("    타입 = 방의 규칙 (\"이 방에는 숫자만\")\n");

    // ══════════════════════════════════════════════════════════════
    // [설계자의 결정 기록]
    // ══════════════════════════════════════════════════════════════
    //
    // 우리 언어의 초기 결정 사항:
    //
    // ✅ 선택 1: 불변성을 기본으로 한다
    //    - 안전성을 최우선으로 함
    //    - 변경 의도는 명시적으로 (mut)
    //
    // ✅ 선택 2: 타입을 엄격하게 선언한다
    //    - 컴파일 타임에 에러 잡기
    //    - 런타임 에러 원천 차단
    //
    // ✅ 선택 3: 이 결정들은 나중에 확장된다
    //    - 함수 설계 (매개변수 타입 명시)
    //    - 구조체 설계 (필드 타입 명시)
    //    - 에러 처리 (Result<T, E>)
    //

    println!("▶ [설계자의 결정]\n");
    println!("  ✅ 선택 1: 불변성을 기본으로 한다");
    println!("     이유: 안전성을 최우선으로\n");

    println!("  ✅ 선택 2: 타입을 엄격하게 선언한다");
    println!("     이유: 컴파일 타임에 모든 에러 잡기\n");

    println!("  ✅ 선택 3: 명시성(Explicitness)을 중시한다");
    println!("     이유: '암묵적 행동'보다 '명시적 의도'\n");

    // ══════════════════════════════════════════════════════════════
    // [v2.0 완성 시점]
    // ══════════════════════════════════════════════════════════════

    println!("▶ [v1.0 ~ v2.0 완성]\n");

    println!("  ✅ v1.0: 출력과 연산으로 존재를 증명");
    println!("  ✅ v2.0: 변수와 타입으로 메모리를 조직");
    println!("  ✅ 설계자의 첫 선택: 안전성과 명시성\n");

    println!("  이제 우리의 언어는:");
    println!("  - 존재합니다 (출력할 수 있음)");
    println!("  - 계산할 수 있습니다 (연산)");
    println!("  - 데이터를 안전하게 저장합니다 (타입 안전)");
    println!("  - 의도를 명확히 표현합니다 (불변 기본)\n");

    println!("══════════════════════════════════════════════════════════════\n");

    // ══════════════════════════════════════════════════════════════
    // [다음 장 예고]
    // ══════════════════════════════════════════════════════════════
    //
    // 다음 장: [v3.0] 흐름의 통제 (Control Flow)
    // - if / else: 조건에 따른 분기
    // - match: 패턴 매칭
    // - loop / for / while: 반복
    //
    // 언어에 "의지"를 부여합니다.
    // 시스템이 스스로 판단하고 선택하게 만듭니다.
    //

    println!("▶ [다음 장 예고]\n");
    println!("  제2장: [v3.0] 흐름의 통제 (Control Flow)\n");
    println!("  언어에 '의지'를 부여하는 단계:");
    println!("  - if/else: 조건에 따른 분기");
    println!("  - match: 패턴 매칭");
    println!("  - loop/for/while: 반복\n");
    println!("  준비: 시스템이 스스로 판단하게 만들기\n");

    println!("══════════════════════════════════════════════════════════════");
    println!("\n저장 필수 너는 기록이 증명이다 gogs 🔥\n");

    println!("✨ 제1장 완성: 존재의 시작 (v1.0 ~ v2.0)");
    println!("📍 위치: lang-design/main.rs");
    println!("🎯 다음: 제2장 (v3.0) - 흐름의 통제\n");
}
