/// 은하 네트워크 구조체
/// HashMap을 사용하여 노드를 효율적으로 관리합니다.
struct GalaxyNetwork {
    name: String,
    nodes: HashMap<u32, Node>,
    log: Vec<String>,
}

impl GalaxyNetwork {
    /// 새로운 네트워크 생성
    fn new(name: &str) -> Self {
        GalaxyNetwork {
            name: name.to_string(),
            nodes: HashMap::new(),
            log: Vec::new(),
        }
    }

    /// 노드 등록 (v5.3: Result 사용)
    fn register_node(&mut self, id: NodeID, location: &str) -> Result<(), String> {
        if self.nodes.contains_key(&id.0) {
            Err(format!("노드 {}는 이미 등록되어 있습니다", id.0))
        } else {
            let node = Node::new(id, location.to_string());
            self.nodes.insert(id.0, node);
            self.log(format!("노드 {} 등록됨", id.0));
            Ok(())
        }
    }

    /// 특정 노드 검색 (v5.3: Option 사용)
    fn get_node(&self, id: NodeID) -> Option<&Node> {
        self.nodes.get(&id.0)
    }

    /// 특정 노드 검색 (가변)
    fn get_node_mut(&mut self, id: NodeID) -> Option<&mut Node> {
        self.nodes.get_mut(&id.0)
    }

    /// 노드 신호 갱신
    fn update_signal(&mut self, id: NodeID, signal: SignalType) -> Result<(), String> {
        match self.get_node_mut(id) {
            Some(node) => {
                node.update_signal(signal);
                self.log(format!("노드 {} 신호 갱신", id.0));
                Ok(())
            }
            None => Err(format!("노드 {}를 찾을 수 없습니다", id.0)),
        }
    }

    /// 모든 노드 정보 표시
    fn display_all_nodes(&self) {
        println!("\n╔═══════════════════════════════════════╗");
        println!("║ 은하 네트워크: {} 노드 현황", self.name);
        println!("╚═══════════════════════════════════════╝\n");

        if self.nodes.is_empty() {
            println!("  등록된 노드가 없습니다.\n");
            return;
        }

        for node in self.nodes.values() {
            node.display_status();
        }
        println!();
    }

    /// 긴급 신호 확인 및 처리 (v5.4: 패턴 매칭)
    fn check_emergency_signals(&self) {
        println!("\n╔═══════════════════════════════════════╗");
        println!("║ 🚨 긴급 신호 점검");
        println!("╚═══════════════════════════════════════╝\n");

        let mut emergency_count = 0;

        for node in self.nodes.values() {
            // 패턴 매칭을 사용한 안전한 처리
            match &node.last_signal {
                SignalType::Emergency(level) => {
                    println!(
                        "  ⚠️  노드 {} (위치: {})에서 심각도 {} 긴급 신호!",
                        node.id.0, node.location, level
                    );
                    emergency_count += 1;
                }
                SignalType::Data(msg) => {
                    println!("  📡 노드 {}: {}", node.id.0, msg);
                }
                SignalType::Beacon => {
                    println!("  ✓ 노드 {} 정상 작동", node.id.0);
                }
            }
        }

        if emergency_count == 0 {
            println!("  ✅ 모든 노드가 정상입니다.");
        } else {
            println!("\n  🚨 총 {} 개의 긴급 신호 감지됨!", emergency_count);
        }
        println!();
    }

    /// 특정 심각도 이상의 긴급 신호 필터링
    fn get_critical_emergencies(&self, threshold: u8) -> Vec<&Node> {
        self.nodes
            .values()
            .filter(|node| node.last_signal.severity() >= threshold)
            .collect()
    }

    /// 네트워크 로그 기록
    fn log(&mut self, message: String) {
        self.log.push(format!("[{}] {}", self.log.len() + 1, message));
    }

    /// 네트워크 로그 표시
    fn display_log(&self) {
        println!("\n╔═══════════════════════════════════════╗");
        println!("║ 네트워크 활동 로그");
        println!("╚═══════════════════════════════════════╝\n");

        if self.log.is_empty() {
            println!("  로그가 없습니다.\n");
            return;
        }

        for entry in &self.log {
            println!("  {}", entry);
        }
        println!();
    }

    /// 네트워크 통계
    fn statistics(&self) {
        println!("\n╔═══════════════════════════════════════╗");
        println!("║ 네트워크 통계");
        println!("╚═══════════════════════════════════════╝\n");

        println!("  네트워크명: {}", self.name);
        println!("  등록된 노드: {}", self.nodes.len());
        println!("  기록된 활동: {}", self.log.len());

        let emergency_nodes: Vec<_> = self
            .nodes
            .values()
            .filter(|n| n.last_signal.is_emergency())
            .collect();

        if !emergency_nodes.is_empty() {
            println!("  🚨 긴급 상태 노드: {}", emergency_nodes.len());
        } else {
            println!("  ✅ 긴급 상태: 없음");
        }
        println!();
    }
}

