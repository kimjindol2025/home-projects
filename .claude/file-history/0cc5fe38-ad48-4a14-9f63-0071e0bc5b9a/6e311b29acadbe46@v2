/// 신호 타입 열거형 (v5.2)
/// 세 가지 신호 상태를 명확히 정의합니다.
#[derive(Debug, Clone, PartialEq)]
enum SignalType {
    /// 정상 신호 (비콘)
    Beacon,
    /// 데이터 전송
    Data(String),
    /// 긴급 신호 (심각도 0-255)
    Emergency(u8),
}

impl SignalType {
    /// 신호가 긴급인지 판단
    fn is_emergency(&self) -> bool {
        matches!(self, SignalType::Emergency(_))
    }

    /// 신호 심각도 반환 (0-255, 없으면 0)
    fn severity(&self) -> u8 {
        match self {
            SignalType::Emergency(level) => *level,
            _ => 0,
        }
    }
}

/// NodeID 뉴타입 (v5.8.2)
/// u32를 감싸서 ID의 의미를 명확히 하고, 혼동을 방지합니다.
#[derive(Debug, Clone, Copy, PartialEq, Eq, Hash)]
struct NodeID(u32);

impl NodeID {
    /// NodeID 생성 (유효성 검증)
    fn new(id: u32) -> Result<Self, String> {
        if id > 0 {
            Ok(NodeID(id))
        } else {
            Err("NodeID는 양수여야 합니다".to_string())
        }
    }

    /// 내부 값 반환
    fn value(&self) -> u32 {
        self.0
    }
}

/// 통신 노드 구조체 (v5.0)
#[derive(Debug, Clone)]
struct Node {
    id: NodeID,
    location: String,
    last_signal: SignalType,
}

/// Node 메서드 구현 (v5.1)
impl Node {
    /// 새로운 노드 생성
    fn new(id: NodeID, location: String) -> Self {
        Node {
            id,
            location,
            last_signal: SignalType::Beacon,
        }
    }

    /// 신호 갱신
    fn update_signal(&mut self, signal: SignalType) {
        self.last_signal = signal;
    }

    /// 노드 정보 표시
    fn display_status(&self) {
        println!(
            "  노드 ID: {} | 위치: {} | 신호: {:?}",
            self.id.0, self.location, self.last_signal
        );
    }
}

/// 제네릭 패킷 구조체 (v5.8.1)
/// 어떤 타입의 데이터든 담을 수 있습니다.
#[derive(Debug, Clone)]
struct Packet<T> {
    sender_id: NodeID,
    payload: T,
    timestamp: u64,
}

impl<T: std::fmt::Debug> Packet<T> {
    /// 새로운 패킷 생성
    fn new(sender_id: NodeID, payload: T, timestamp: u64) -> Self {
        Packet {
            sender_id,
            payload,
            timestamp,
        }
    }

    /// 패킷 정보 표시
    fn display(&self) {
        println!(
            "  발신: Node {}, 타임스탬프: {}, 페이로드: {:?}",
            self.sender_id.0, self.timestamp, self.payload
        );
    }
}

