// ============================================================================
// gogs-macros: 절차적 매크로 라이브러리
// ============================================================================
// 컴파일러 내부에서 작동하는 코드 분석기 + 코드 생성기
// 입력: TokenStream (토큰 스트림)
// 처리: syn (파싱) + 데이터 구조화
// 출력: quote (코드 생성) → TokenStream
// ============================================================================

extern crate proc_macro;

use proc_macro::TokenStream;
use quote::quote;
use syn::{parse_macro_input, DeriveInput, Data, Fields};

// ============================================================================
// 1. Derive Macro: #[derive(GogsInfo)]
// ============================================================================
/// 구조체에 자동으로 메타데이터 메서드를 추가합니다.
///
/// 이 매크로가 하는 일:
/// 1. 입력 코드를 TokenStream으로 받음
/// 2. syn으로 파싱하여 구조체 정보 추출
/// 3. quote!로 새로운 메서드 코드 생성
/// 4. 결과를 TokenStream으로 반환
#[proc_macro_derive(GogsInfo)]
pub fn gogs_info_derive(input: TokenStream) -> TokenStream {
    // [Parsing Phase]
    // 입력받은 토큰 스트림을 Rust AST 구조로 변환
    let DeriveInput {
        ident,
        data,
        ..
    } = parse_macro_input!(input as DeriveInput);

    // [Extraction Phase]
    // 구조체의 필드 정보 추출
    let fields_count = match &data {
        Data::Struct(data) => {
            match &data.fields {
                Fields::Named(fields) => fields.named.len(),
                Fields::Unnamed(fields) => fields.unnamed.len(),
                Fields::Unit => 0,
            }
        }
        _ => 0,
    };

    // [Generation Phase]
    // quote! 매크로로 새로운 Rust 코드 생성
    let expanded = quote! {
        impl #ident {
            /// 구조체의 메타데이터 정보 출력
            pub fn print_gogs_info(&self) {
                println!("╔════════════════════════════════════════╗");
                println!("║        GOGS Meta Information           ║");
                println!("╚════════════════════════════════════════╝");
                println!("Type Name: {}", stringify!(#ident));
                println!("Field Count: {}", #fields_count);
                println!("Generated: 2026-02-23");
                println!("저장 필수 너는 기록이 증명이다 gogs");
            }
        }
    };

    // [Output Phase]
    // 생성된 코드를 TokenStream으로 변환하여 반환
    TokenStream::from(expanded)
}

// ============================================================================
// 2. Derive Macro: #[derive(GogsDebug)]
// ============================================================================
/// 구조체에 자동으로 Debug 구현을 추가합니다.
/// 커스텀 디버그 포맷을 제공합니다.
#[proc_macro_derive(GogsDebug)]
pub fn gogs_debug_derive(input: TokenStream) -> TokenStream {
    let DeriveInput {
        ident,
        data,
        ..
    } = parse_macro_input!(input as DeriveInput);

    // 필드 이름 추출
    let field_names = match &data {
        Data::Struct(data) => {
            match &data.fields {
                Fields::Named(fields) => {
                    fields.named.iter().map(|f| {
                        let name = &f.ident;
                        quote! { stringify!(#name) }
                    }).collect::<Vec<_>>()
                }
                _ => vec![],
            }
        }
        _ => vec![],
    };

    let expanded = quote! {
        impl std::fmt::Debug for #ident {
            fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
                f.debug_struct(stringify!(#ident))
                    #(.field(#field_names, &"<gogs_debug>"))*
                    .finish()
            }
        }
    };

    TokenStream::from(expanded)
}

// ============================================================================
// 3. Derive Macro: #[derive(GogsToString)]
// ============================================================================
/// 구조체의 이름을 문자열로 변환합니다.
#[proc_macro_derive(GogsToString)]
pub fn gogs_to_string_derive(input: TokenStream) -> TokenStream {
    let DeriveInput {
        ident,
        ..
    } = parse_macro_input!(input as DeriveInput);

    let type_name = ident.to_string();

    let expanded = quote! {
        impl #ident {
            /// 구조체 타입의 이름을 반환합니다.
            pub fn gogs_type_name() -> &'static str {
                #type_name
            }
        }
    };

    TokenStream::from(expanded)
}

// ============================================================================
// 4. Attribute Macro: #[gogs_mark(category = "...")]
// ============================================================================
/// 구조체에 카테고리 정보를 추가합니다.
#[proc_macro_attribute]
pub fn gogs_mark(_args: TokenStream, input: TokenStream) -> TokenStream {
    // args: 매크로 인자 (category = "test")
    // input: 실제 코드 (struct ...)

    let item = input.clone();

    // 간단한 구현: 원본 코드 반환 (속성은 문서에 기록)
    let expanded = quote! {
        #[doc = "Marked by gogs procedural macro"]
    };

    let mut result = TokenStream::from(expanded);
    result.extend(item);

    result
}

// ============================================================================
// 5. Attribute Macro: #[gogs_serialize]
// ============================================================================
/// 구조체에 직렬화 메서드를 추가합니다.
#[proc_macro_attribute]
pub fn gogs_serialize(_args: TokenStream, input: TokenStream) -> TokenStream {
    let input_clone = input.clone();
    let DeriveInput {
        ident,
        data,
        ..
    } = parse_macro_input!(input as DeriveInput);

    // 필드 이름들 수집
    let field_count = match &data {
        Data::Struct(data) => {
            match &data.fields {
                Fields::Named(fields) => fields.named.len(),
                Fields::Unnamed(fields) => fields.unnamed.len(),
                Fields::Unit => 0,
            }
        }
        _ => 0,
    };

    // 원본 입력을 proc_macro2로 변환
    let original_tokens = proc_macro2::TokenStream::from(input_clone);

    let expanded = quote! {
        #original_tokens

        impl #ident {
            /// 구조체를 직렬화합니다.
            pub fn gogs_serialize(&self) -> String {
                format!("{{{}: {} fields}}", stringify!(#ident), #field_count)
            }
        }
    };

    TokenStream::from(expanded)
}

// ============================================================================
// 6. Function-like Macro: gogs_struct!
// ============================================================================
/// 매크로로 구조체를 정의합니다.
/// gogs_struct!(MyType { field1: i32, field2: String })
#[proc_macro]
pub fn gogs_struct(input: TokenStream) -> TokenStream {
    // 입력을 문자열로 처리 (간단한 구현)
    let _input_str = input.to_string();

    let expanded = quote! {
        // 이 부분은 실제로는 더 복잡한 파싱이 필요합니다.
        // 여기서는 개념 시연을 위해 단순화했습니다.
        compile_error!("gogs_struct! requires more complex parsing");
    };

    TokenStream::from(expanded)
}

// ============================================================================
// 7. Function-like Macro: gogs_sql!
// ============================================================================
/// SQL 쿼리를 안전하게 처리합니다.
/// gogs_sql!(SELECT * FROM users WHERE id = 1)
#[proc_macro]
pub fn gogs_sql(_input: TokenStream) -> TokenStream {
    // SQL 쿼리 매크로 (개념 시연)
    // 입력 분석은 컴파일 타임에 수행됨
    #[allow(unused_variables)]
    let input_str = _input.to_string();

    let expanded = quote! {
        {
            // 컴파일 타임에 SQL 문법 검증
            println!("[GOGS SQL] Query validated at compile time");
            "SELECT * FROM users"
        }
    };

    TokenStream::from(expanded)
}

// ============================================================================
// 8. Function-like Macro: gogs_assert_type!
// ============================================================================
/// 타입을 검증하는 매크로입니다.
#[proc_macro]
pub fn gogs_assert_type(input: TokenStream) -> TokenStream {
    let input_str = input.to_string();

    let expanded = quote! {
        {
            println!("[GOGS TYPE CHECK] Asserting: {}", #input_str);
        }
    };

    TokenStream::from(expanded)
}

// ============================================================================
// 9. Derive Macro: #[derive(GogsBuilder)]
// ============================================================================
/// 구조체에 빌더 패턴을 자동으로 추가합니다.
#[proc_macro_derive(GogsBuilder)]
pub fn gogs_builder_derive(input: TokenStream) -> TokenStream {
    let DeriveInput {
        ident,
        data,
        ..
    } = parse_macro_input!(input as DeriveInput);

    // 필드 정보 추출: 이름, 타입, Setter 메서드, 빌더 구조체 필드
    let (field_names, _field_types, setter_methods, builder_fields) = match &data {
        Data::Struct(data) => {
            match &data.fields {
                Fields::Named(fields) => {
                    let mut names = vec![];
                    let mut types = vec![];
                    let mut setters = vec![];
                    let mut builder_struct_fields = vec![];

                    for f in fields.named.iter() {
                        let name = &f.ident;
                        let ty = &f.ty;

                        names.push(quote! { #name });
                        types.push(quote! { #ty });

                        setters.push(quote! {
                            pub fn #name(mut self, value: #ty) -> Self {
                                self.#name = Some(value);
                                self
                            }
                        });

                        builder_struct_fields.push(quote! {
                            pub #name: Option<#ty>,
                        });
                    }

                    (names, types, setters, builder_struct_fields)
                }
                _ => (vec![], vec![], vec![], vec![]),
            }
        }
        _ => (vec![], vec![], vec![], vec![]),
    };

    let builder_name = quote::format_ident!("{}Builder", ident);

    let expanded = quote! {
        impl #ident {
            pub fn builder() -> #builder_name {
                #builder_name {
                    #(#field_names: None,)*
                }
            }
        }

        pub struct #builder_name {
            #(#builder_fields)*
        }

        impl #builder_name {
            #(#setter_methods)*

            /// 빌더로부터 최종 구조체를 생성합니다.
            pub fn build(self) -> #ident {
                #ident {
                    #(
                        #field_names: self.#field_names.unwrap_or_default(),
                    )*
                }
            }
        }
    };

    TokenStream::from(expanded)
}

// ============================================================================
// 10. Derive Macro: #[derive(GogsStats)]
// ============================================================================
/// 구조체의 필드 개수와 타입 정보를 포함하는 통계 메서드를 추가합니다.
#[proc_macro_derive(GogsStats)]
pub fn gogs_stats_derive(input: TokenStream) -> TokenStream {
    let DeriveInput {
        ident,
        data,
        ..
    } = parse_macro_input!(input as DeriveInput);

    let field_count = match &data {
        Data::Struct(data) => {
            match &data.fields {
                Fields::Named(fields) => fields.named.len(),
                Fields::Unnamed(fields) => fields.unnamed.len(),
                Fields::Unit => 0,
            }
        }
        _ => 0,
    };

    let expanded = quote! {
        impl #ident {
            /// 구조체의 통계 정보를 반환합니다.
            pub fn gogs_stats() -> String {
                format!("Type: {}\nFields: {}", stringify!(#ident), #field_count)
            }
        }
    };

    TokenStream::from(expanded)
}
