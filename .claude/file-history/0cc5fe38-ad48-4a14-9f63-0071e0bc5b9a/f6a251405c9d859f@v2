// ═════════════════════════════════════════════════════════════════════════════
// Section 10: Panic 격리 (Panic Isolation)
// ═════════════════════════════════════════════════════════════════════════════
//
// 핵심: Rust panic!이 C 영역으로 전파되면 Undefined Behavior

#[allow(dead_code)]
extern "C" fn risky_callback(x: i32) -> i32 {
    if x < 0 {
        panic!("음수는 허용 안 됨!");  // ⚠️ C로 전파되면 UB!
    }
    x * 2
}

#[allow(dead_code)]
extern "C" fn safe_callback(x: i32) -> i32 {
    if x < 0 {
        return -1;  // panic 대신 에러 코드 반환
    }
    x * 2
}

fn section_10_panic_isolation() {
    println!("\n╔══ Section 10: Panic Isolation ══╗");

    // [10-1] Panic의 위험성
    println!("✓ Rust panic!의 위험성");
    println!("  Rust 코드 내부에서만 안전:");
    println!("    panic!() → 스택 언와인드");
    println!("  C 코드를 거치면 위험:");
    println!("    panic!() → C 영역에 진입 → UB!");

    // [10-2] catch_unwind로 보호
    println!("✓ panic::catch_unwind로 격리");
    let result = panic::catch_unwind(|| {
        if 1 < 0 {
            panic!("이것은 실행 안 됨");
        }
        42
    });

    match result {
        Ok(val) => println!("  정상: {}", val),
        Err(_) => println!("  Panic 감지!"),
    }

    // [10-3] 안전한 콜백
    println!("✓ 안전한 콜백 작성");
    println!("  panic!() 대신 에러 코드 반환");
    println!("  safe_callback()는 C에 안전");

    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
}

// ═════════════════════════════════════════════════════════════════════════════
// Section 11: 안전한 래퍼 (Safe Wrapper)
// ═════════════════════════════════════════════════════════════════════════════
//
// 핵심: unsafe FFI 호출을 안전한 Rust 함수로 감싸기

pub struct SafeMath;

impl SafeMath {
    /// abs의 안전한 래퍼
    pub fn absolute(num: i32) -> i32 {
        unsafe { abs(num) }
    }

    /// strlen의 안전한 래퍼
    pub fn strlen(s: &str) -> usize {
        let c_str = CString::new(s).expect("내부 null 불가");
        unsafe { strlen(c_str.as_ptr()) }
    }

    /// sqrt의 안전한 래퍼
    pub fn sqrt(x: f64) -> f64 {
        if x < 0.0 {
            f64::NAN
        } else {
            unsafe { sqrt(x) }
        }
    }
}

fn section_11_safe_wrapper() {
    println!("\n╔══ Section 11: Safe Wrapper ══╗");

    // [11-1] 안전한 abs
    println!("✓ SafeMath::absolute");
    let result = SafeMath::absolute(-42);
    println!("  absolute(-42) = {}", result);

    // [11-2] 안전한 strlen
    println!("✓ SafeMath::strlen");
    let len = SafeMath::strlen("Hello");
    println!("  strlen(\"Hello\") = {}", len);

    // [11-3] 안전한 sqrt
    println!("✓ SafeMath::sqrt");
    let result = SafeMath::sqrt(16.0);
    println!("  sqrt(16.0) = {}", result);

    let bad_result = SafeMath::sqrt(-1.0);
    println!("  sqrt(-1.0) = {} (안전하게 처리)", bad_result);

    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
}

