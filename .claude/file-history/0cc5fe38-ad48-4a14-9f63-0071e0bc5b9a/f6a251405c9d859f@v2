// ═════════════════════════════════════════════════════════════════════════════
// Section 1: FFI 기본 개념 (extern "C" 블록)
// ═════════════════════════════════════════════════════════════════════════════
//
// 핵심: extern "C"는 Rust가 C 함수를 호출하기 위한 "약속"이다.
//      ABI (Application Binary Interface)를 명시한다.

extern "C" {
    // [C 표준 라이브러리 함수들]
    fn abs(input: c_int) -> c_int;
    fn strlen(s: *const c_char) -> usize;
    fn strcmp(s1: *const c_char, s2: *const c_char) -> c_int;
}

fn section_1_ffi_basics() {
    println!("\n╔══ Section 1: FFI Basics ══╗");

    // [1-1] extern "C" 블록의 의미
    println!("✓ extern \"C\" 블록의 역할");
    println!("  이 블록은 외부 C 함수 선언입니다");
    println!("  런타임에 시스템 라이브러리(libc)에서 찾아 링크합니다");

    // [1-2] ABI (Application Binary Interface)
    println!("✓ ABI란 무엇인가?");
    println!("  함수 호출 규약 (calling convention):");
    println!("    - 인수는 어디에 전달되는가?");
    println!("    - 반환값은 어디에서 받는가?");
    println!("    - 레지스터 보존은?");
