// ═════════════════════════════════════════════════════════════════════════════
// Section 5: 포인터 마샬링 (Pointer Marshalling)
// ═════════════════════════════════════════════════════════════════════════════
//
// 핵심: C 함수에 포인터를 전달할 때 메모리 안전성을 보장해야 한다.

extern "C" {
    fn memcpy(dest: *mut u8, src: *const u8, n: usize) -> *mut u8;
}

fn section_5_pointer_marshalling() {
    println!("\n╔══ Section 5: Pointer Marshalling ══╗");

    // [5-1] 배열 포인터 전달
    println!("✓ C 함수에 포인터 전달");
    let mut dest = vec![0u8; 10];
    let src = vec![1u8, 2, 3, 4, 5];

    unsafe {
        // [주의] 메모리 안전성 확인:
        // - dest는 충분한 크기 (10 >= 5)
        // - src는 유효한 메모리
        // - 겹치지 않음
        memcpy(dest.as_mut_ptr(), src.as_ptr(), 5);
    }

    println!("  memcpy 후: {:?}", &dest[..5]);

    // [5-2] 구조체 포인터 전달
    println!("✓ 구조체 포인터 전달");
    let mut x = 42i32;
    let ptr: *mut i32 = &mut x;
    println!("  변수 주소: {:p}", ptr);
    println!("  변수 값: {}", unsafe { *ptr });

    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
}

