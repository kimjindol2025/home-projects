fn section_6_array_marshalling() {
    println!("\n╔══ Section 6: Array Marshalling ══╗");

    // [6-1] Vec을 C 함수에 전달
    println!("✓ Vec을 C 함수로 전달");
    let mut vec = vec![10, 20, 30, 40, 50];
    let ptr = vec.as_mut_ptr();
    let len = vec.len();

    println!("  Vec: {:?}", vec);
    println!("  포인터: {:p}", ptr);
    println!("  길이: {}", len);

    // [6-2] C 함수에서 배열 처리 시뮬레이션
    println!("✓ 배열 값 수정 (포인터로)");
    unsafe {
        *ptr.add(0) = 100;  // vec[0] = 100
        *ptr.add(1) = 200;  // vec[1] = 200
    }
    println!("  수정 후: {:?}", vec);

    // [6-3] 배열 슬라이스 사용
    println!("✓ 슬라이스로 C 함수 호출");
    let slice = &vec[1..3];
    println!("  슬라이스: {:?}", slice);
    println!("  슬라이스 포인터: {:p}", slice.as_ptr());

    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
