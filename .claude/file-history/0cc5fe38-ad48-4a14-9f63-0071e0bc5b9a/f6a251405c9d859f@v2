// ═════════════════════════════════════════════════════════════════════════════
// Section 2: 외부 함수 선언 및 호출
// ═════════════════════════════════════════════════════════════════════════════
//
// 핵심: 외부 함수 호출은 반드시 unsafe 블록 안에서만 가능하다.

fn section_2_external_function_calls() {
    println!("\n╔══ Section 2: External Function Calls ══╗");

    // [2-1] C 표준 함수 호출
    println!("✓ C 표준 함수 abs() 호출");
    unsafe {
        let num = -42i32;
        let result = abs(num);
        println!("  abs({}) = {}", num, result);
    }

    // [2-2] Unsafe 블록이 필수인 이유
    println!("✓ 왜 unsafe 블록이 필수인가?");
    println!("  C 함수 내부에서 무엇이 일어나는지 컴파일러가 모름");
    println!("  메모리가 안전하게 접근되는지 확인 불가");
    println!("  → 개발자가 책임져야 함 (unsafe)");

    // [2-3] 여러 C 함수 호출
    println!("✓ 여러 외부 함수 사용");
    unsafe {
        // strlen 호출
        let c_str = CString::new("Hello").unwrap();
        let len = strlen(c_str.as_ptr());
        println!("  strlen(\"Hello\") = {}", len);

        // strcmp 호출
        let str1 = CString::new("abc").unwrap();
        let str2 = CString::new("abc").unwrap();
        let cmp = strcmp(str1.as_ptr(), str2.as_ptr());
        println!("  strcmp(\"abc\", \"abc\") = {} (0 = 같음)", cmp);
    }

    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
}

// ═════════════════════════════════════════════════════════════════════════════
// Section 3: CString과 C 스타일 문자열 (데이터 마샬링)
// ═════════════════════════════════════════════════════════════════════════════
//
// 핵심: Rust의 String과 C의 char*는 메모리 구조가 다르다.
//      반드시 변환해야 한다.

fn section_3_cstring_marshalling() {
    println!("\n╔══ Section 3: CString & String Marshalling ══╗");

    // [3-1] Rust String vs C String
    println!("✓ 메모리 구조 비교");
    println!("  Rust String:");
    println!("    - 길이 정보 포함");
    println!("    - 내부에 null 문자 없을 수 있음");
    println!("  C String (char*):");
    println!("    - 길이 정보 없음");
    println!("    - 반드시 null 문자('\\0')로 끝남");

    // [3-2] String → CString 변환
    println!("✓ Rust String → C String 변환");
    let rust_str = "Hello, FFI!";
    match CString::new(rust_str) {
        Ok(c_str) => {
            println!("  변환 성공: \"{}\"", rust_str);
            println!("  C 포인터: {:p}", c_str.as_ptr());

            // C 함수에 전달 가능
            unsafe {
                let len = strlen(c_str.as_ptr());
                println!("  strlen() = {}", len);
            }
        }
        Err(e) => println!("  변환 실패: {}", e),
    }

    // [3-3] 내부 null 문자 방지
    println!("✓ null 문자가 포함된 경우");
    let bad_str = "Hello\0World";
    match CString::new(bad_str) {
        Ok(_) => println!("  변환 성공"),
        Err(e) => println!("  변환 실패: {} (null 문자 때문)", e),
    }

    // [3-4] C String → Rust String 변환
    println!("✓ C String → Rust String 변환");
    unsafe {
        let c_str = CString::new("C로부터").unwrap();
        match CStr::from_ptr(c_str.as_ptr()).to_str() {
            Ok(rust_str) => println!("  변환 성공: \"{}\"", rust_str),
            Err(e) => println!("  변환 실패: {}", e),
        }
    }

    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
}

