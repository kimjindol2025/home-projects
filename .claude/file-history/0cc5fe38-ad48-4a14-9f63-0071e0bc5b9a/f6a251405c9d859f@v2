// ═════════════════════════════════════════════════════════════════════════════
// Section 7: 구조체 마샬링 (repr(C) 구조체)
// ═════════════════════════════════════════════════════════════════════════════
//
// 핵심: C와 호환되려면 반드시 #[repr(C)]를 사용해야 한다.

#[allow(dead_code)]
#[repr(C)]
struct Point {
    x: i32,
    y: i32,
}

#[allow(dead_code)]
#[repr(C)]
struct Color {
    r: u8,
    g: u8,
    b: u8,
    a: u8,
}

fn section_7_struct_marshalling() {
    println!("\n╔══ Section 7: Struct Marshalling ══╗");

    // [7-1] C 호환 구조체 생성
    println!("✓ C 호환 구조체 (repr(C))");
    let point = Point { x: 10, y: 20 };
    println!("  Point: {{ x: {}, y: {} }}", point.x, point.y);
    println!("  크기: {} bytes", std::mem::size_of::<Point>());
    println!("  정렬: {} bytes", std::mem::align_of::<Point>());

    // [7-2] 포인터로 접근
    println!("✓ 구조체 포인터로 필드 접근");
    let ptr = &point as *const Point;
    unsafe {
        println!("  x @ {:p} = {}", std::ptr::addr_of!((*ptr).x), (*ptr).x);
        println!("  y @ {:p} = {}", std::ptr::addr_of!((*ptr).y), (*ptr).y);
    }

    // [7-3] 다른 구조체
    println!("✓ Color 구조체");
    let color = Color { r: 255, g: 128, b: 64, a: 255 };
    println!("  Color: RGBA({}, {}, {}, {})", color.r, color.g, color.b, color.a);

    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
}

