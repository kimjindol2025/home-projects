## 📊 실전 예제: 게임 상태 관리

```rust
#[derive(Debug, Clone)]
enum GameState {
    Menu,
    Playing { level: u32, score: u32 },
    Paused { level: u32, score: u32 },
    GameOver { final_score: u32 },
}

struct Game {
    state: GameState,
}

impl Game {
    fn new() -> Game {
        Game {
            state: GameState::Menu,
        }
    }

    fn start(&mut self, level: u32) -> Result<(), String> {
        match &self.state {
            GameState::Menu => {
                self.state = GameState::Playing { level, score: 0 };
                Ok(())
            }
            _ => Err("게임이 진행 중입니다".to_string()),
        }
    }

    fn pause(&mut self) -> Result<(), String> {
        match &self.state {
            GameState::Playing { level, score } => {
                self.state = GameState::Paused {
                    level: *level,
                    score: *score,
                };
                Ok(())
            }
            _ => Err("일시정지할 수 없습니다".to_string()),
        }
    }

    fn resume(&mut self) -> Result<(), String> {
        match &self.state {
            GameState::Paused { level, score } => {
                self.state = GameState::Playing {
                    level: *level,
                    score: *score,
                };
                Ok(())
            }
            _ => Err("재개할 수 없습니다".to_string()),
        }
    }

    fn end(&mut self) {
        match &self.state {
            GameState::Playing { score, .. } | GameState::Paused { score, .. } => {
                self.state = GameState::GameOver {
                    final_score: *score,
                };
            }
            _ => {}
        }
    }

    fn display(&self) {
        match &self.state {
            GameState::Menu => println!("메뉴"),
            GameState::Playing { level, score } => {
                println!("진행 중 - 레벨: {}, 점수: {}", level, score);
            }
            GameState::Paused { level, score } => {
                println!("일시정지 - 레벨: {}, 점수: {}", level, score);
            }
            GameState::GameOver { final_score } => {
                println!("게임 오버 - 최종 점수: {}", final_score);
            }
        }
    }
}

// 사용
let mut game = Game::new();
game.display();                    // 메뉴

game.start(1).ok();
game.display();                    // 진행 중 - 레벨: 1, 점수: 0

game.pause().ok();
game.display();                    // 일시정지

game.resume().ok();
game.display();                    // 진행 중

game.end();
game.display();                    // 게임 오버
```

