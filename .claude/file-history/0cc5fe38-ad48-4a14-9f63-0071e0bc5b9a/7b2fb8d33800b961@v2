### 5. 열거형에 메서드 추가

```rust
enum Status {
    Active,
    Inactive,
    Error(String),
}

impl Status {
    fn is_ok(&self) -> bool {
        matches!(self, Status::Active | Status::Inactive)
    }

    fn description(&self) -> String {
        match self {
            Status::Active => "활성".to_string(),
            Status::Inactive => "비활성".to_string(),
            Status::Error(msg) => format!("오류: {}", msg),
        }
    }
}

let status = Status::Active;
println!("{}", status.description());  // "활성"
println!("{}", status.is_ok());         // true
```

