## 🎯 컴파일 과정 상세

### compile_expression() 로직

```rust
match expr {
    // ① 정수 리터럴
    Integer(42) {
        idx = add_constant(42);      // 인덱스 0
        emit_with_operand(OpConstant, idx);
        // 결과: [OpConstant, 0, 0]
    }

    // ② 중위 연산
    Infix(+, left, right) {
        compile_expression(left);    // 왼쪽 먼저
        compile_expression(right);   // 오른쪽 다음
        emit(OpAdd);                 // 연산자 마지막
        // 결과: [left명령어들, right명령어들, OpAdd]
    }

    // ③ If 표현식
    If { condition, consequence, alternative } {
        compile_expression(condition);

        // 점프 플레이스홀더
        jump_pos = emit_placeholder(OpJumpNotTruthy);

        // consequence 컴파일
        for stmt in consequence {
            compile_statement(stmt);
        }

        // 점프 목표 수정
        fix_jump(jump_pos);

        // alternative 컴파일
        if let Some(alt) = alternative {
            for stmt in alt {
                compile_statement(stmt);
            }
        }
    }

    // ④ 배열
    Array(elements) {
        for elem in elements {
            compile_expression(elem);  // 각 요소 컴파일
        }
        emit_with_operand(OpArray, elements.len());
        // 결과: [요소들..., OpArray, len_high, len_low]
    }

    // ⑤ 함수 호출
    Call { function, arguments } {
        compile_expression(function);  // 함수
        for arg in arguments {
            compile_expression(arg);   // 인자들
        }
        emit_with_operand(OpCall, arguments.len());
        // 결과: [function, args..., OpCall, arg_count]
    }
}
```

