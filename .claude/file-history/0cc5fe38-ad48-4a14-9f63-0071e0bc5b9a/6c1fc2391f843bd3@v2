// 섹션 11: 성능 측정
// ============================================================================
fn section_11_performance_measurement() {
    println!("\n📌 섹션 11: 성능 측정");
    println!("────────────────────────────────────────");

    struct State1;
    struct State2;
    struct State3;

    struct Item<S> {
        value: i32,
        _phantom: std::marker::PhantomData<S>,
    }

    impl Item<State1> {
        fn next(self) -> Item<State2> {
            Item {
                value: self.value,
                _phantom: std::marker::PhantomData,
            }
        }
    }

    impl Item<State2> {
        fn next(self) -> Item<State3> {
            Item {
                value: self.value,
                _phantom: std::marker::PhantomData,
            }
        }
    }

    impl Item<State3> {
        fn result(&self) -> i32 {
            self.value * 2
        }
    }

    let start = Instant::now();
    for i in 0..10_000_000 {
        let item = Item::<State1> {
            value: i,
            _phantom: std::marker::PhantomData,
        };
        let item = item.next();
        let item = item.next();
        let _ = item.result();
    }
    let elapsed = start.elapsed();

    println!("  10M 상태 전이:");
    println!("    시간: {:.2}ms", elapsed.as_secs_f64() * 1000.0);
    println!("    상태/초: {:.0}M", (10_000_000.0 / elapsed.as_secs_f64()) / 1_000_000.0);

    println!("\n  💡 성능:");
    println!("    ✅ 컴파일 최적화로 매우 빠름");
    println!("    ✅ 인라인 가능 (모든 정보 컴파일 타임)");
    println!("    ✅ 런타임 오버헤드: 0");
}

