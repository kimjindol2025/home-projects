// 섹션 8: Deadlock 패턴
// ============================================================================
fn section_8_deadlock_patterns() {
    println!("\n📌 섹션 8: Deadlock 패턴");
    println!("────────────────────────────────────────");

    // 두 개의 뮤텍스
    let lock_a = Arc::new(Mutex::new("A"));
    let lock_b = Arc::new(Mutex::new("B"));

    // ✅ 안전한 패턴: 항상 같은 순서로 잠금
    let a_clone = Arc::clone(&lock_a);
    let b_clone = Arc::clone(&lock_b);

    let handle = thread::spawn(move || {
        // 순서 1: A → B (일관성 유지)
        let _guard_a = a_clone.lock().unwrap();
        println!("  스레드: A 획득");
        thread::sleep(std::time::Duration::from_millis(5));
        let _guard_b = b_clone.lock().unwrap();
        println!("  스레드: B 획득");
    });

    // 메인도 같은 순서: A → B
    let _guard_a = lock_a.lock().unwrap();
    println!("  메인: A 획득");
    let _guard_b = lock_b.lock().unwrap();
    println!("  메인: B 획득");

    handle.join().unwrap();

    println!("  💡 Deadlock 방지: 잠금 순서 일관성");
}

// ============================================================================
// 섹션 9: Deadlock 감지와 회복
// ============================================================================
fn section_9_deadlock_detection_recovery() {
    println!("\n📌 섹션 9: Deadlock 감지와 회복");
    println!("────────────────────────────────────────");

    let lock_a = Arc::new(Mutex::new("A"));
    let lock_b = Arc::new(Mutex::new("B"));

    // Deadlock 회피: try_lock() 사용
    let a = Arc::clone(&lock_a);
    let b = Arc::clone(&lock_b);

    let handle = thread::spawn(move || {
        loop {
            match a.try_lock() {
                Ok(_guard_a) => {
                    match b.try_lock() {
                        Ok(_guard_b) => {
                            println!("  스레드: A와 B 모두 획득 → 진행");
                            break;
                        }
                        Err(_) => {
                            println!("  스레드: B 획득 실패 → 재시도");
                            drop(_guard_a);  // A 해제
                        }
                    }
                }
                Err(_) => {
                    println!("  스레드: A 획득 실패 → 재시도");
                }
            }
            thread::sleep(std::time::Duration::from_millis(1));
        }
    });

    let mut _guard_b = lock_b.lock().unwrap();
    let mut _guard_a = lock_a.lock().unwrap();
    println!("  메인: A와 B 모두 획득");

    drop(_guard_a);
    drop(_guard_b);

    handle.join().unwrap();

    println!("  💡 try_lock(): 실패 시 즉시 반환");
    println!("  💡 Deadlock 회피: 획득 실패 시 해제 후 재시도");
}

// ============================================================================
// 섹션 10: 실전 패턴 - 상태 머신
// ============================================================================
fn section_10_practical_pattern_state_machine() {
    println!("\n📌 섹션 10: 실전 패턴 - 상태 머신");
    println!("────────────────────────────────────────");

    #[derive(Debug, Clone)]
    enum State {
        Idle,
        Running(u32),
        Completed,
    }

    let state = Arc::new(Mutex::new(State::Idle));

    // 상태 전이: Idle → Running → Completed
    {
        let state_clone = Arc::clone(&state);
        let handle = thread::spawn(move || {
            let mut s = state_clone.lock().unwrap();
            *s = State::Running(0);
            println!("  → State::Running 시작");

            drop(s);
            thread::sleep(std::time::Duration::from_millis(50));

            let mut s = state_clone.lock().unwrap();
            *s = State::Completed;
            println!("  → State::Completed 완료");
        });

        handle.join().unwrap();
    }

    let final_state = state.lock().unwrap();
    println!("  최종 상태: {:?}", *final_state);
    println!("  💡 뮤텍스로 상태 전이를 안전하게 관리");
}

// ============================================================================
// 섹션 11: 실전 패턴 - 리소스 풀
// ============================================================================
fn section_11_practical_pattern_resource_pool() {
    println!("\n📌 섹션 11: 실전 패턴 - 리소스 풀");
    println!("────────────────────────────────────────");

    #[derive(Clone)]
    struct Connection(u32);

    let pool = Arc::new(Mutex::new(vec![
        Connection(1),
        Connection(2),
        Connection(3),
    ]));

    let mut handles = vec![];

    for i in 1..=5 {
        let pool_clone = Arc::clone(&pool);
        let handle = thread::spawn(move || {
            let mut connections = pool_clone.lock().unwrap();
            if let Some(conn) = connections.pop() {
                println!("  작업 {}: 연결 {} 획득", i, conn.0);
                // 작업 수행 (시뮬레이션)
                connections.push(conn);
                println!("  작업 {}: 연결 반환", i);
            } else {
                println!("  작업 {}: 연결 없음 (대기 필요)", i);
            }
        });
        handles.push(handle);
    }

    for handle in handles {
        handle.join().unwrap();
    }

    println!("  💡 뮤텍스로 리소스 풀 관리");
    println!("  💡 실전: Condition Variables로 대기 가능");
}

