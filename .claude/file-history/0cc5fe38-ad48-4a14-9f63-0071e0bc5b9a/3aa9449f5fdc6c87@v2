// ============================================================================
// 섹션 1: Mutex와 Arc의 기본 개념
// ============================================================================
fn section_1_mutex_and_arc() {
    println!("\n📌 섹션 1: Mutex와 Arc의 기본 개념");
    println!("────────────────────────────────────────");

    // Arc: Atomic Reference Counting (원자적 참조 카운팅)
    // 여러 스레드가 같은 소유권을 공유
    let counter = Arc::new(Mutex::new(0));

    let mut handles = vec![];

    // 3개 스레드가 같은 카운터 공유
    for i in 1..=3 {
        let counter_clone = Arc::clone(&counter);
        let handle = thread::spawn(move || {
            let mut num = counter_clone.lock().unwrap();
            *num += i;
            println!("  스레드 {}: 카운터 = {}", i, *num);
        });
        handles.push(handle);
    }

    // 모든 스레드 대기
    for handle in handles {
        handle.join().unwrap();
    }

    let final_count = counter.lock().unwrap();
    println!("  최종 결과: {}", *final_count);
    println!("  💡 Arc::clone() = 참조 카운트 증가 (얕은 복사)");
    println!("  💡 lock().unwrap() = 뮤텍스 잠금");
}

// ============================================================================
// 섹션 2: Lock 획득과 해제
// ============================================================================
fn section_2_lock_and_unlock() {
    println!("\n📌 섹션 2: Lock 획득과 해제");
    println!("────────────────────────────────────────");

    let data = Arc::new(Mutex::new(String::from("초기값")));

    let data_clone = Arc::clone(&data);
    let handle = thread::spawn(move || {
        let mut value = data_clone.lock().unwrap();
        value.push_str(" → 수정됨");
        println!("  스레드에서 수정: {}", *value);
        // 스코프를 벗어날 때 자동으로 잠금 해제
    });

    // 메인 스레드에서 접근
    {
        let value = data.lock().unwrap();
        println!("  메인 스레드: {}", *value);
    } // 여기서 자동 해제

    handle.join().unwrap();

    let final_value = data.lock().unwrap();
    println!("  최종 값: {}", *final_value);
    println!("  💡 RAII 패턴: lock()은 Guard를 반환, 스코프 벗어나면 자동 해제");
}

// ============================================================================
// 섹션 3: Poison 에러 처리
// ============================================================================
fn section_3_poison_error() {
    println!("\n📌 섹션 3: Poison 에러 처리");
    println!("────────────────────────────────────────");

    let data = Arc::new(Mutex::new(0));

    // 스레드가 패닉 → 뮤텍스 중독(poisoned)
    let data_clone = Arc::clone(&data);
    let handle = thread::spawn(move || {
        let mut num = data_clone.lock().unwrap();
        *num += 1;
        panic!("의도적 패닉!");
    });

    let _ = handle.join();

    // Poison 에러 처리
    match data.lock() {
        Ok(num) => println!("  안전함: {}", *num),
        Err(poisoned) => {
            let num = poisoned.into_inner();
            println!("  중독됨(Poisoned): {} (복구 가능)", *num);
        }
    }
    println!("  💡 Poison: 스레드 패닉 시 뮤텍스가 '중독'됨");
    println!("  💡 into_inner(): 중독된 뮤텍스에서 데이터 추출");
}

// ============================================================================
// 섹션 4: 여러 스레드에서 공유 상태 수정
// ============================================================================
fn section_4_shared_state_multiple_threads() {
    println!("\n📌 섹션 4: 여러 스레드에서 공유 상태 수정");
    println!("────────────────────────────────────────");

    let bank_account = Arc::new(Mutex::new(1000)); // 초기 잔액
    let mut handles = vec![];

    // 5개 스레드: 각각 200원 입금
    for i in 1..=5 {
        let account = Arc::clone(&bank_account);
        let handle = thread::spawn(move || {
            let mut balance = account.lock().unwrap();
            let old = *balance;
            *balance += 200;
            println!("  스레드 {}: {} + 200 = {}", i, old, *balance);
        });
        handles.push(handle);
    }

    for handle in handles {
        handle.join().unwrap();
    }

    let final_balance = bank_account.lock().unwrap();
    println!("  최종 잔액: {}", *final_balance);
    println!("  예상: 2000 (1000 + 200*5)");
    println!("  💡 모든 연산이 원자적으로 보호됨");
}

// ============================================================================
// 섹션 5: Mutex 성능 측정
// ============================================================================
fn section_5_mutex_performance() {
    println!("\n📌 섹션 5: Mutex 성능 측정");
    println!("────────────────────────────────────────");

    let counter = Arc::new(Mutex::new(0));
    let iterations = 1_000_000;

    let start = Instant::now();

    let mut handles = vec![];
    for _ in 0..4 {
        let counter_clone = Arc::clone(&counter);
        let handle = thread::spawn(move || {
            for _ in 0..iterations {
                let mut num = counter_clone.lock().unwrap();
                *num += 1;
            }
        });
        handles.push(handle);
    }

    for handle in handles {
        handle.join().unwrap();
    }

    let elapsed = start.elapsed();
    let final_count = counter.lock().unwrap();

    println!("  총 연산: {} × 4 = {}", iterations, *final_count);
    println!("  소요 시간: {:.2}ms", elapsed.as_secs_f64() * 1000.0);
    println!("  연산/초: {:.0}K", (iterations as f64 * 4.0) / elapsed.as_secs_f64() / 1000.0);
    println!("  💡 Mutex는 경합이 높을수록 느려짐");
    println!("  💡 동기화 오버헤드 + 캐시 무효화");
}

// ============================================================================
// 섹션 6: RwLock (읽기-쓰기 잠금)
// ============================================================================
fn section_6_rwlock_read_write_lock() {
    println!("\n📌 섹션 6: RwLock (읽기-쓰기 잠금)");
    println!("────────────────────────────────────────");

    let data = Arc::new(RwLock::new(vec![1, 2, 3]));

    // 여러 스레드가 동시에 읽기
    let mut read_handles = vec![];
    for i in 1..=3 {
        let data_clone = Arc::clone(&data);
        let handle = thread::spawn(move || {
            let vec = data_clone.read().unwrap();
            println!("  스레드 {} 읽기: {:?}", i, *vec);
        });
        read_handles.push(handle);
    }

    for handle in read_handles {
        handle.join().unwrap();
    }

    // 쓰기 (배타적)
    {
        let mut vec = data.write().unwrap();
        vec.push(4);
        println!("  쓰기: 4 추가");
    }

    // 최종 읽기
    let vec = data.read().unwrap();
    println!("  최종: {:?}", *vec);
    println!("  💡 read(): 여러 스레드 동시 읽기 가능");
    println!("  💡 write(): 배타적 접근 (한 스레드만)");
}

// ============================================================================
// 섹션 7: RwLock 성능 (읽기가 많은 경우)
// ============================================================================
fn section_7_rwlock_performance() {
    println!("\n📌 섹션 7: RwLock 성능 (읽기가 많은 경우)");
    println!("────────────────────────────────────────");

    let data = Arc::new(RwLock::new(0));
    let iterations = 100_000;

    let start = Instant::now();

    let mut handles = vec![];

    // 10개 읽기 스레드
    for _ in 0..10 {
        let data_clone = Arc::clone(&data);
        let handle = thread::spawn(move || {
            for _ in 0..iterations {
                let _value = data_clone.read().unwrap();
                // 읽기만 수행
            }
        });
        handles.push(handle);
    }

    // 1개 쓰기 스레드
    let data_clone = Arc::clone(&data);
    let write_handle = thread::spawn(move || {
        for _ in 0..1000 {
            let mut value = data_clone.write().unwrap();
            *value += 1;
        }
    });
    handles.push(write_handle);

    for handle in handles {
        handle.join().unwrap();
    }

    let elapsed = start.elapsed();
    println!("  읽기: 10 × {} = {}", iterations, 10 * iterations);
    println!("  쓰기: 1,000");
    println!("  소요 시간: {:.2}ms", elapsed.as_secs_f64() * 1000.0);
    println!("  💡 읽기가 많을 때 RwLock이 효율적");
}

