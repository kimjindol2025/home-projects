// 🧠 v9.3: Rc<RefCell<T>>와 스마트 포인터의 결합 (Combination)
// 🔗 "여러 소유자가 내부 데이터를 함께 수정하기"
// 🎯 "동적 데이터 구조의 완전한 형태"
//
// 핵심 개념:
// - Rc<T>: 여러 소유자가 같은 데이터 공유
// - RefCell<T>: 불변 참조로 내부 데이터 수정
// - Rc<RefCell<T>>: 여러 소유자 + 내부 가변성
// - 동적 구조: 그래프, 링크드 리스트, 트리 구조 구현
// - 실무 패턴: 게임 엔티티, 복잡한 데이터 구조

use std::rc::Rc;
use std::cell::RefCell;

fn main() {
    println!("╔══════════════════════════════════════════════════════════╗");
    println!("║ v9.3: Rc<RefCell<T>>와 스마트 포인터의 결합              ║");
    println!("║ \\\"여러 소유자가 내부 데이터를 함께 수정\\\"                  ║");
    println!("╚══════════════════════════════════════════════════════════╝\\n");

    // ==================== 섹션 1: 세 가지 패턴의 통합 ====================
    println!("📌 섹션 1: 세 가지 패턴의 통합\\n");
    {
        println!("Box<T>:");
        println!("  ✅ 힙 할당");
        println!("  ❌ 단일 소유권");
        println!("  ❌ 내부 가변성 없음");
        println!();\

        println!("Rc<T>:");
        println!("  ✅ 여러 소유권");
        println!("  ❌ 읽기 전용");
        println!("  ❌ 내부 수정 불가");
        println!();\

        println!("RefCell<T>:");
        println!("  ✅ 내부 가변성");
        println!("  ❌ 단일 소유권");
        println!();\

        println!("Rc<RefCell<T>>: 완벽한 조합!");
        println!("  ✅ 여러 소유권");
        println!("  ✅ 내부 가변성");
        println!("  ✅ 동적 데이터 구조");
        println!();\
    }

    // ==================== 섹션 2: 그래프 노드 ====================
    println!("📌 섹션 2: 그래프 노드 (Shared + Mutable)\\n");
    {
        #[derive(Debug)]
        struct GraphNode {
            id: usize,
            value: i32,
            neighbors: RefCell<Vec<Rc<GraphNode>>>,
        }

        println!("그래프 노드 구조:");
        println!("  struct GraphNode {{\");
        println!("    id: usize,\");
        println!("    value: i32,\");
        println!(\"    neighbors: RefCell<Vec<Rc<GraphNode>>>,  // 핵심!\");
        println!(\"  }}\");
        println!();\

        let node1 = Rc::new(GraphNode {
            id: 1,
            value: 10,
            neighbors: RefCell::new(vec![]),
        });

        let node2 = Rc::new(GraphNode {
            id: 2,
            value: 20,
            neighbors: RefCell::new(vec![]),
        });

        let node3 = Rc::new(GraphNode {
            id: 3,
            value: 30,
            neighbors: RefCell::new(vec![]),
        });

        println!(\"노드 생성:\");
        println!(\"  node1: id={}, value={}\", node1.id, node1.value);
        println!(\"  node2: id={}, value={}\", node2.id, node2.value);
        println!(\"  node3: id={}, value={}\", node3.id, node3.value);
        println!();\

        // 간선 추가
        node1.neighbors.borrow_mut().push(Rc::clone(&node2));
        node1.neighbors.borrow_mut().push(Rc::clone(&node3));

        node2.neighbors.borrow_mut().push(Rc::clone(&node1));

        node3.neighbors.borrow_mut().push(Rc::clone(&node1));
        node3.neighbors.borrow_mut().push(Rc::clone(&node2));

        println!(\"간선 추가 후:\");
        println!(\"  node1의 이웃: {} 개\", node1.neighbors.borrow().len());
        println!(\"  node2의 이웃: {} 개\", node2.neighbors.borrow().len());
        println!(\"  node3의 이웃: {} 개\", node3.neighbors.borrow().len());
        println!();\
    }

    // ==================== 섹션 3: 링크드 리스트 ====================
    println!("📌 섹션 3: 링크드 리스트 (Doubly Linked)\\n");
    {
        #[derive(Debug)]
        struct ListNode {
            data: i32,
            next: RefCell<Option<Rc<ListNode>>>,
            prev: RefCell<Option<Rc<ListNode>>>,  // 양방향
        }

        impl ListNode {
            fn new(data: i32) -> Self {
                Self {
                    data,
                    next: RefCell::new(None),
                    prev: RefCell::new(None),
                }
            }
        }

        println!("양방향 링크드 리스트:");
        let node1 = Rc::new(ListNode::new(1));
        let node2 = Rc::new(ListNode::new(2));
        let node3 = Rc::new(ListNode::new(3));

        // Forward 링크
        *node1.next.borrow_mut() = Some(Rc::clone(&node2));
        *node2.next.borrow_mut() = Some(Rc::clone(&node3));

        // Backward 링크
        *node2.prev.borrow_mut() = Some(Rc::clone(&node1));
        *node3.prev.borrow_mut() = Some(Rc::clone(&node2));

        println!(\"리스트: node1 ↔ node2 ↔ node3\");
        println!();\

        // Forward 순회
        println!(\"Forward 순회:\");
        let mut current = Some(Rc::clone(&node1));
        while let Some(node) = current {
            print!("{} → ", node.data);
            current = node.next.borrow().as_ref().map(Rc::clone);
        }
        println!(\"끝\");
        println!();\
    }

    // ==================== 섹션 4: 게임 엔티티 ====================
    println!("📌 섹션 4: 게임 엔티티 (Game Entity)\\n");
    {
        #[derive(Debug, Clone)]
        struct GameState {
            health: i32,
            mana: i32,
            level: usize,
        }

        struct GameEntity {
            name: String,
            state: Rc<RefCell<GameState>>,
        }

        impl GameEntity {
            fn new(name: &str, health: i32, mana: i32) -> Self {
                Self {
                    name: name.to_string(),
                    state: Rc::new(RefCell::new(GameState {
                        health,
                        mana,
                        level: 1,
                    })),
                }
            }

            fn take_damage(&self, damage: i32) {
                let mut state = self.state.borrow_mut();
                state.health = (state.health - damage).max(0);
            }

            fn cast_spell(&self, cost: i32) -> bool {
                let mut state = self.state.borrow_mut();
                if state.mana >= cost {
                    state.mana -= cost;
                    true
                } else {
                    false
                }
            }

            fn level_up(&self) {
                let mut state = self.state.borrow_mut();
                state.level += 1;
                state.health += 10;
                state.mana += 5;
            }

            fn status(&self) -> String {
                let state = self.state.borrow();
                format!(
                    "{}: HP={}, Mana={}, Lv={}",
                    self.name, state.health, state.mana, state.level
                )
            }
        }

        println!("게임 엔티티:");
        let player = GameEntity::new("Hero", 100, 50);
        let enemy = GameEntity::new("Goblin", 30, 10);

        println!("초기 상태:");
        println!("  {}", player.status());
        println!("  {}", enemy.status());
        println!();\

        println!("전투 시뮬레이션:");
        player.take_damage(15);
        println!("  Hero가 15 데미지 받음");

        if player.cast_spell(20) {
            println!("  Hero가 20 마나로 스펠 시전");
        }

        enemy.take_damage(25);
        println!("  Goblin이 25 데미지 받음");

        println!();\
        println!("최종 상태:");
        println!("  {}", player.status());
        println!("  {}", enemy.status());
        println!();\
    }

    // ==================== 섹션 5: 트리 구조 ====================
    println!("📌 섹션 5: 트리 구조 (Tree with Parent)\\n");
    {
        struct TreeNode {
            value: i32,
            children: RefCell<Vec<Rc<TreeNode>>>,
        }

        impl TreeNode {
            fn new(value: i32) -> Self {
                Self {
                    value,
                    children: RefCell::new(vec![]),
                }
            }

            fn add_child(&self, child: Rc<TreeNode>) {
                self.children.borrow_mut().push(child);
            }

            fn count_descendants(&self) -> usize {
                let children = self.children.borrow();
                children.len() + children.iter().map(|c| c.count_descendants()).sum::<usize>()
            }
        }

        println!("트리 구조:");
        let root = Rc::new(TreeNode::new(1));
        let child1 = Rc::new(TreeNode::new(2));
        let child2 = Rc::new(TreeNode::new(3));
        let grandchild1 = Rc::new(TreeNode::new(4));
        let grandchild2 = Rc::new(TreeNode::new(5));

        root.add_child(Rc::clone(&child1));
        root.add_child(Rc::clone(&child2));
        child1.add_child(Rc::clone(&grandchild1));
        child1.add_child(Rc::clone(&grandchild2));

        println!(\"    1\");
        println!(\"   / \\\\\");
        println!(\"  2   3\");
        println!(\" / \\\\\");
        println!(\"4   5\");
        println!();\

        println!(\"자손 개수: {}\", root.count_descendants());
        println!();\
    }

    // ==================== 섹션 6: 상태 공유 ====================
    println!("📌 섹션 6: 상태 공유 (Shared State)\\n");
    {
        struct SharedCounter {
            count: Rc<RefCell<usize>>,
        }

        impl SharedCounter {
            fn new() -> Self {
                Self {
                    count: Rc::new(RefCell::new(0)),
                }
            }

            fn clone_shared(&self) -> Self {
                Self {
                    count: Rc::clone(&self.count),
                }
            }

            fn increment(&self) {
                *self.count.borrow_mut() += 1;
            }

            fn value(&self) -> usize {
                *self.count.borrow()
            }
        }

        println!("여러 소유자가 같은 상태 공유:");
        let counter1 = SharedCounter::new();
        let counter2 = counter1.clone_shared();
        let counter3 = counter1.clone_shared();

        println!(\"counter1.increment()\");
        counter1.increment();

        println!(\"counter2.increment()\");
        counter2.increment();

        println!(\"counter3.increment()\");
        counter3.increment();

        println!();\
        println!(\"모든 카운터가 같은 값을 가짐:\");
        println!(\"  counter1: {}\", counter1.value());
        println!(\"  counter2: {}\", counter2.value());
        println!(\"  counter3: {}\", counter3.value());
        println!();\
    }

    // ==================== 섹션 7: 순환 참조 경고 ====================
    println!("📌 섹션 7: 순환 참조 경고 (Circular Reference)\\n");
    {
        println!(\"주의: Rc<RefCell<T>>는 순환 참조 가능!\");
        println!();\

        println!(\"문제 상황:\");
        println!(\"struct Node {{\");
        println!(\"    next: RefCell<Option<Rc<Node>>>,\");
        println!(\"    prev: RefCell<Option<Rc<Node>>>,  // A ↔ B 순환 가능\");
        println!(\"}} \");
        println!();\

        println!(\"해결책: Weak<T> 사용\");
        println!(\"struct Node {{\");
        println!(\"    next: RefCell<Option<Rc<Node>>>,\");
        println!(\"    prev: RefCell<Option<Weak<Node>>>,  // Weak는 순환 참조 차단\");
        println!(\"}} \");
        println!();\
    }

    // ==================== 섹션 8: 성능 특성 ====================
    println!("📌 섹션 8: 성능 특성\\n");
    {
        println!("Rc<RefCell<T>>의 오버헤드:");
        println!("  1. Rc: 참조 카운팅 (원자적 연산 아님)");
        println!("  2. RefCell: 런타임 대여 검사");
        println!("  3. 각 borrow() 호출마다 검사");
        println!();\

        println!("최적화 팁:");
        println!("  ✅ 필요한 범위만 borrow_mut() 유지");
        println!("  ✅ 루프 안에서 borrow_mut() 반복 피하기");
        println!("  ✅ 가능하면 &T 빌림 사용");
        println!();\
    }

    // ==================== 섹션 9: 실무 패턴 ====================
    println!("📌 섹션 9: 실무 패턴\\n");
    {
        println!("패턴 1: 그래프/네트워크");
        println!("  Rc<RefCell<GraphNode>>\");
        println!();\

        println!("패턴 2: UI 위젯");
        println!("  Rc<RefCell<Widget>>\");
        println!();\

        println!("패턴 3: 게임 엔티티");
        println!("  Rc<RefCell<GameState>>\");
        println!();\

        println!("패턴 4: 캐시");
        println!("  Rc<RefCell<HashMap<K, V>>>\");
        println!();\

        println!("패턴 5: 설정 공유");
        println!("  Rc<RefCell<Config>>\");
        println!();\
    }

    // ==================== 섹션 10: 언제 사용할 것인가 ====================
    println!("📌 섹션 10: 언제 Rc<RefCell<T>>를 사용할까\\n");
    {
        println!("✅ 사용해야 할 경우:");
        println!("  1. 여러 경로가 같은 데이터 공유");
        println!("  2. 불변 인터페이스로 내부 수정");
        println!("  3. 동적 그래프/트리 구조");
        println!("  4. 싱글 스레드 환경");
        println!();\

        println!(\"❌ 사용하면 안 되는 경우:\");
        println!(\"  1. 멀티 스레드 (Arc<Mutex<T>> 사용)\");
        println!(\"  2. 성능이 매우 중요함\");
        println!(\"  3. 단일 소유권으로 충분\");
        println!();\
    }

    // ==================== 섹션 11: 메모리 안전성 ====================
    println!("📌 섹션 11: 메모리 안전성\\n");
    {
        println!("Rc<RefCell<T>>의 안전성:");
        println!();\

        println!("✅ 메모리 누수 방지:");
        println!("  - 순환 참조 제외하고 자동 해제");
        println!();\

        println!("✅ 데이터 레이스 방지:");
        println!("  - RefCell의 런타임 검사로 보호");
        println!("  - 단, panic! 가능성 존재");
        println!();\

        println!("⚠️ 순환 참조:");
        println!("  - A → B, B → A 순환 구조");
        println!("  - Weak<T>로 해결");
        println!();\
    }

    // ==================== 섹션 12: 다음 단계 ====================
    println!("📌 섹션 12: 다음 단계\\n");
    {
        println!("v9.4: Weak<T>");
        println!("  - 순환 참조 방지");
        println!("  - 부모-자식 관계");
        println!();\

        println!("v9.5: Arc<Mutex<T>>");
        println!("  - 멀티 스레드 지원");
        println!("  - 동시성");
        println!();\

        println!("v10: 고급 메모리 패턴");
        println!("  - Cow<T>");
        println!("  - Pin<T>");
        println!();\
    }

    println!(\\\"═══════════════════════════════════════════════════════════\\\");
    println!(\\\"🎓 v9.3 완료: 스마트 포인터의 완벽한 조합\\\");
    println!();\
    println!(\\\"당신은 이제:\\\");
    println!(\\\"✅ Rc<RefCell<T>>로 여러 소유자가 내부 데이터를 수정한다\\\");
    println!(\\\"✅ 동적 그래프 구조를 설계할 수 있다\\\");
    println!(\\\"✅ 게임 엔티티 같은 복잡한 구조를 구현한다\\\");
    println!(\\\"✅ 실무 패턴을 이해하고 적용한다\\\");
    println!();\
    println!(\\\"저장 필수 너는 기록이 증명이다 gogs\\\");
}
