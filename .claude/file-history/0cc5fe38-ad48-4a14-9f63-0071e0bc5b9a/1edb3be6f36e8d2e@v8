// 러스트 시스템 프로그래밍의 기초
// Phase 1 ~ 6 종합: 1학년 기말고사
// [저장 필수] 기록이 증명이다 gogs: 미니 로깅 시스템

// ==========================================
// 1학년 기말고사: 미니 로깅 시스템 설계
// ==========================================

// Phase 5: 모듈 시스템 - lib.rs에서 정의한 것들을 불러옴
use gogs_project::{LogLevel, LogMessage, Printable, process_logs};

fn main() {
    println!("╔════════════════════════════════════════════════════════╗");
    println!("║       Gogs 프로젝트 1학년 기말고사 시작              ║");
    println!("║   미니 로깅 시스템: 모든 단계의 종합 검증            ║");
    println!("╚════════════════════════════════════════════════════════╝\n");

    // ==========================================
    // 기말고사 문제 풀이
    // ==========================================

    println!("📝 기말고사 문제 풀이\n");

    // ==========================================
    // 1️⃣ Phase 4: 구조체 및 열거형
    // ==========================================
    println!("✅ 1단계: LogLevel 열거형과 LogMessage<T> 제네릭 구조체 생성\n");

    // Phase 1: 변수 (가변)
    // Phase 3: 소유권 (메모리 안전)
    let mut messages: Vec<LogMessage<String>> = Vec::new();

    // ==========================================
    // 2️⃣ Phase 2: 제어 흐름 (for 루프)
    // ==========================================
    println!("✅ 2단계: for 루프로 3번의 로그 기록\n");

    // for 루프: 3번 반복
    for i in 1..=3 {
        let (level, message_text) = match i {
            1 => (
                LogLevel::Info,
                "Gogs 로깅 시스템 초기화 완료".to_string(),
            ),
            2 => (
                LogLevel::Warning,
                "높은 메모리 사용량 감지".to_string(),
            ),
            3 => (LogLevel::Error(500), "데이터베이스 연결 실패".to_string()),
            _ => unreachable!(),
        };

        // LogMessage 생성 (제네릭 구조체)
        let log_message: LogMessage<String> = LogMessage::new(level, i as u64, message_text);

        // Phase 3: 소유권
        // messages 벡터에 소유권 이전
        messages.push(log_message);
    }

    // ==========================================
    // 3️⃣ Phase 6: 트레이트 (Printable)
    // ==========================================
    println!("✅ 3단계: Printable 트레이트를 구현한 메시지 출력\n");

    println!("═══════════════════════════════════════════════════════");
    println!("📋 로그 출력");
    println!("═══════════════════════════════════════════════════════\n");

    // Phase 3: 소유권
    // 참조(&)를 사용하여 ownership을 이동하지 않고 빌려줌
    for message in &messages {
        // Phase 6: Printable 트레이트 사용
        // message.print()는 format_message()를 호출하고 출력함
        message.print();
    }

    println!();

    // ==========================================
    // 4️⃣ Phase 2: 제어 흐름 (match 구문)
    // ==========================================
    println!("═══════════════════════════════════════════════════════");
    println!("🔍 에러 레벨 검사");
    println!("═══════════════════════════════════════════════════════\n");

    println!("✅ 4단계: match 구문으로 LogLevel::Error 감지\n");

    // Phase 3: 소유권과 참조
    // 각 메시지를 참조(&)로 빌려줌
    for message in &messages {
        // Phase 2: match를 사용한 제어 흐름
        match message.level() {
            LogLevel::Error(code) => {
                println!(
                    "⚠️  에러 감지: {} (코드: {})",
                    message.format_message(),
                    code
                );

                // 404 이상의 에러라면 프로그램 중단
                if code >= 404 {
                    println!("\n🛑 심각한 에러로 인해 프로그램 중단\n");
                    break;
                }
            }
            LogLevel::Warning => {
                println!("⚠️  경고: {}", message.format_message());
            }
            LogLevel::Info => {
                println!("ℹ️  정보: {}", message.format_message());
            }
        }
    }

    println!();

    // ==========================================
    // 5️⃣ Phase 5: 모듈 시스템 (process_logs 함수)
    // ==========================================
    println!("═══════════════════════════════════════════════════════");
    println!("📊 로깅 시스템 통합 처리");
    println!("═══════════════════════════════════════════════════════\n");

    println!("✅ 5단계: 모듈화된 process_logs 함수 사용\n");

    // Phase 3: 참조(&) 사용
    // messages를 슬라이스로 변환하여 참조로 전달
    match process_logs(&messages, true) {
        Some(error_code) => {
            println!("⛔ 심각한 에러 발생: 에러 코드 {}", error_code);
        }
        None => {
            println!("✅ 모든 로그가 정상적으로 처리됨");
        }
    }

    println!();

    // ==========================================
    // 기말고사 최종 결과
    // ==========================================
    println!("═══════════════════════════════════════════════════════");
    println!("🎓 1학년 기말고사 채점");
    println!("═══════════════════════════════════════════════════════\n");

    println!("✅ Phase 1: 변수와 불변성 - mut을 사용한 가변 벡터");
    println!("✅ Phase 2: 제어 흐름 - for 루프와 match 구문");
    println!("✅ Phase 3: 소유권 - 참조(&)를 활용한 메모리 안전");
    println!("✅ Phase 4: 구조체 & 열거형 - LogLevel과 LogMessage<T>");
    println!("✅ Phase 5: 모듈 시스템 - lib.rs와 main.rs 분리");
    println!("✅ Phase 6: 제네릭 & 트레이트 - <T: Display>, Printable trait");

    println!("\n📈 기말고사 점수: 100/100 🌟");
    println!("🎉 1학년 졸업 인증!\n");

    println!("저장 필수 너는 기록이 증명이다 gogs 🔥\n");
}
