// ===================================================================
// Section 1: 복잡한 열거형 정의 (Complex Enum Definition)
// ===================================================================
//
// 열거형은 유닛, 튜플, 구조체 데이터를 모두 품을 수 있으며,
// 다른 열거형을 중첩할 수도 있습니다.
//
fn section_1_complex_enums() {
    println!("▶ Section 1: 복잡한 열거형 정의");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 1-1. 다양한 형태의 데이터를 품은 열거형
    // ─────────────────────────────────────────
    println!("  [1-1] 다양한 형태의 열거형");

    #[derive(Debug)]
    enum GogsTask {
        Initialize,                           // 유닛 variant
        Print(String),                        // 튜플 variant (단일)
        Execute(String, Vec<String>),         // 튜플 variant (복수)
        Move { x: i32, y: i32 },             // 구조체 variant
        ChangeStatus(SystemStatus),           // 다른 열거형 포함
    }

    #[derive(Debug)]
    enum SystemStatus {
        Online,
        Offline,
        Maintenance { duration: u32 },       // 구조체 variant
    }

    let tasks = vec![
        GogsTask::Initialize,
        GogsTask::Print(String::from("시스템 시작")),
        GogsTask::Execute(
            String::from("compile"),
            vec![String::from("--release"), String::from("--verbose")],
        ),
        GogsTask::Move { x: 100, y: 200 },
        GogsTask::ChangeStatus(SystemStatus::Online),
        GogsTask::ChangeStatus(SystemStatus::Maintenance { duration: 30 }),
    ];

    println!("    작업 목록:");
    for task in tasks {
        println!("      {:?}", task);
    }
    println!("    → 각 variant가 서로 다른 형태의 데이터를 담을 수 있음\n");

    // ─────────────────────────────────────────
    // 1-2. 도메인 모델링의 복합 열거형
    // ─────────────────────────────────────────
    println!("  [1-2] 도메인 모델링: API 응답");

    #[derive(Debug)]
    enum ApiResponse<T> {
        Success(T),                          // 성공 응답
        NotFound { resource: String },       // 404 에러
        ServerError { code: u32, message: String },  // 500 에러
        ValidationError(Vec<String>),        // 검증 실패 목록
        RateLimited { retry_after: u64 },   // 요청 제한
    }

    let responses: Vec<ApiResponse<String>> = vec![
        ApiResponse::Success(String::from("Data fetched successfully")),
        ApiResponse::NotFound {
            resource: String::from("user/123"),
        },
        ApiResponse::ServerError {
            code: 500,
            message: String::from("Internal Server Error"),
        },
        ApiResponse::ValidationError(vec![
            String::from("Invalid email"),
            String::from("Password too short"),
        ]),
        ApiResponse::RateLimited { retry_after: 60 },
    ];

    println!("    API 응답 타입:");
    for response in responses {
        println!("      {:?}", response);
    }
    println!("    → 모든 응답 상황을 명시적으로 표현\n");

    println!("  💡 핵심: 데이터 구조가 시스템의 모든 상태를 명확하게 표현합니다.\n");
}

// ===================================================================
// Section 2: 기본 구조분해 (Basic Destructuring)
// ===================================================================
//
// 패턴 매칭을 통해 열거형의 데이터를 추출합니다.
//
fn section_2_destructuring() {
    println!("▶ Section 2: 기본 구조분해");
    println!("─────────────────────────────────────────\n");

    #[derive(Debug)]
    enum Command {
        Quit,
        Move { x: i32, y: i32 },
        Say(String),
        SetColor(u8, u8, u8),
    }

    // ─────────────────────────────────────────
    // 2-1. 튜플 variant 구조분해
    // ─────────────────────────────────────────
    println!("  [2-1] 튜플 variant 구조분해");

    let cmd1 = Command::Say(String::from("Hello, World!"));

    match cmd1 {
        Command::Say(message) => {
            println!("    메시지: {}", message);
        }
        _ => {}
    }
    println!();

    // ─────────────────────────────────────────
    // 2-2. 구조체 variant 구조분해
    // ─────────────────────────────────────────
    println!("  [2-2] 구조체 variant 구조분해");

    let cmd2 = Command::Move { x: 50, y: 100 };

    match cmd2 {
        Command::Move { x, y } => {
            println!("    이동: ({}, {})", x, y);
            println!("    거리: {}", ((x * x + y * y) as f64).sqrt());
        }
        _ => {}
    }
    println!();

    // ─────────────────────────────────────────
    // 2-3. 복수 데이터 구조분해
    // ─────────────────────────────────────────
    println!("  [2-3] 복수 데이터 구조분해");

    let cmd3 = Command::SetColor(255, 128, 64);

    match cmd3 {
        Command::SetColor(r, g, b) => {
            println!("    색상 설정: RGB({}, {}, {})", r, g, b);
            println!("    16진수: #{:02X}{:02X}{:02X}", r, g, b);
        }
        _ => {}
    }
    println!();

    println!("  💡 핵심: 패턴 매칭은 데이터 추출과 조건 확인을 동시에 수행합니다.\n");
}

// ===================================================================
// Section 3: 중첩 패턴 매칭 (Nested Pattern Matching)
// ===================================================================
//
// 열거형 안에 다른 열거형이 있을 때 중첩된 match를 사용합니다.
//
fn section_3_nested_patterns() {
    println!("▶ Section 3: 중첩 패턴 매칭");
    println!("─────────────────────────────────────────\n");

    #[derive(Debug)]
    enum Event {
        UserAction(UserAction),
        SystemEvent(SystemEvent),
        NetworkEvent(NetworkEvent),
    }

    #[derive(Debug)]
    enum UserAction {
        Click { x: i32, y: i32 },
        KeyPress(char),
        Close,
    }

    #[derive(Debug)]
    enum SystemEvent {
        Startup,
        Shutdown,
        Error(String),
    }

    #[derive(Debug)]
    enum NetworkEvent {
        Connected { server: String },
        Disconnected { reason: String },
        DataReceived { size: usize },
    }

    // ─────────────────────────────────────────
    // 3-1. 단계별 중첩 처리
    // ─────────────────────────────────────────
    println!("  [3-1] 중첩된 열거형 처리");

    let events = vec![
        Event::UserAction(UserAction::Click { x: 100, y: 50 }),
        Event::SystemEvent(SystemEvent::Error(String::from("Connection failed"))),
        Event::NetworkEvent(NetworkEvent::Connected {
            server: String::from("gogs.dclub.kr"),
        }),
        Event::UserAction(UserAction::KeyPress('A')),
    ];

    println!("    이벤트 처리:");
    for event in events {
        match event {
            Event::UserAction(action) => {
                match action {
                    UserAction::Click { x, y } => {
                        println!("      🖱️  클릭 @ ({}, {})", x, y);
                    }
                    UserAction::KeyPress(ch) => {
                        println!("      ⌨️  키 입력 @ '{}'", ch);
                    }
                    UserAction::Close => {
                        println!("      ❌ 종료");
                    }
                }
            }
            Event::SystemEvent(event) => {
                match event {
                    SystemEvent::Startup => println!("      🚀 시작"),
                    SystemEvent::Shutdown => println!("      ⏹️  종료"),
                    SystemEvent::Error(msg) => println!("      ⚠️  에러: {}", msg),
                }
            }
            Event::NetworkEvent(event) => {
                match event {
                    NetworkEvent::Connected { server } => {
                        println!("      🌐 연결됨: {}", server);
                    }
                    NetworkEvent::Disconnected { reason } => {
                        println!("      📴 연결 끊김: {}", reason);
                    }
                    NetworkEvent::DataReceived { size } => {
                        println!("      📥 데이터 수신: {} bytes", size);
                    }
                }
            }
        }
    }
    println!();

    // ─────────────────────────────────────────
    // 3-2. 단일 match로 압축
    // ─────────────────────────────────────────
    println!("  [3-2] 중첩을 패턴으로 압축");

    let event = Event::UserAction(UserAction::Click { x: 200, y: 150 });

    match event {
        Event::UserAction(UserAction::Click { x, y }) => {
            println!("    🖱️  클릭: ({}, {})", x, y);
        }
        Event::SystemEvent(SystemEvent::Error(msg)) => {
            println!("    ⚠️  시스템 에러: {}", msg);
        }
        Event::NetworkEvent(NetworkEvent::Connected { server }) => {
            println!("    🌐 서버 연결: {}", server);
        }
        _ => println!("    기타 이벤트"),
    }
    println!();

    println!("  💡 핵심: 중첩 패턴으로 깊은 데이터 구조를 우아하게 처리합니다.\n");
}

// ===================================================================
// Section 4: Guard 패턴 (Pattern Guards)
// ===================================================================
//
// match 패턴에 추가 조건을 지정합니다.
//
fn section_4_guard_patterns() {
    println!("▶ Section 4: Guard 패턴");
    println!("─────────────────────────────────────────\n");

    #[derive(Debug)]
    enum Temperature {
        Celsius(f64),
        Fahrenheit(f64),
    }

    // ─────────────────────────────────────────
    // 4-1. guard로 범위 조건 추가
    // ─────────────────────────────────────────
    println!("  [4-1] Guard로 범위 조건 추가");

    let temps = vec![
        Temperature::Celsius(-20.0),
        Temperature::Celsius(0.0),
        Temperature::Celsius(37.0),
        Temperature::Celsius(100.0),
        Temperature::Fahrenheit(32.0),
        Temperature::Fahrenheit(98.6),
    ];

    println!("    온도 분석:");
    for temp in temps {
        match temp {
            Temperature::Celsius(c) if c < 0.0 => {
                println!("      ❄️  매우 추움 ({}°C)", c);
            }
            Temperature::Celsius(c) if c < 10.0 => {
                println!("      🥶 추움 ({}°C)", c);
            }
            Temperature::Celsius(c) if c < 25.0 => {
                println!("      😊 쾌적함 ({}°C)", c);
            }
            Temperature::Celsius(c) if c < 40.0 => {
                println!("      😅 더움 ({}°C)", c);
            }
            Temperature::Celsius(c) => {
                println!("      🔥 매우 더움 ({}°C)", c);
            }
            Temperature::Fahrenheit(f) if f < 32.0 => {
                println!("      ❄️  어는점 이하 ({}°F)", f);
            }
            Temperature::Fahrenheit(f) => {
                println!("      🌡️  {}°F", f);
            }
        }
    }
    println!();

    // ─────────────────────────────────────────
    // 4-2. 구조체와 guard 결합
    // ─────────────────────────────────────────
    println!("  [4-2] 구조체와 guard 결합");

    #[derive(Debug)]
    enum Account {
        Free { balance: f64 },
        Premium { balance: f64, tier: u32 },
    }

    let accounts = vec![
        Account::Free { balance: 50.0 },
        Account::Free { balance: 5000.0 },
        Account::Premium {
            balance: 10000.0,
            tier: 3,
        },
    ];

    println!("    계정 권한 확인:");
    for account in accounts {
        match account {
            Account::Free { balance } if balance > 1000.0 => {
                println!("      💎 무료 계정이지만 잔액이 풍부함 (${:.2})", balance);
            }
            Account::Free { balance } => {
                println!("      💰 무료 계정 (${:.2})", balance);
            }
            Account::Premium { balance, tier } if tier >= 2 => {
                println!("      👑 프리미엄 {{} (${:.2}, Tier {})", 'P', balance, tier);
            }
            Account::Premium { balance, tier } => {
                println!("      ⭐ 프리미엄 계정 (${:.2}, Tier {})", balance, tier);
            }
        }
    }
    println!();

    println!("  💡 핵심: Guard로 추가 조건을 표현하여 더 세밀한 제어가 가능합니다.\n");
}

// ===================================================================
// Section 5: 바인딩 패턴 (@) (Binding Patterns)
// ===================================================================
//
// @ 연산자로 특정 범위의 값을 매칭하면서 그 값을 변수에 바인딩합니다.
//
fn section_5_binding_patterns() {
    println!("▶ Section 5: 바인딩 패턴 (@)");
    println!("─────────────────────────────────────────\n");

    #[derive(Debug)]
    enum Response {
        Ok(u32),
        Err(String),
    }

    // ─────────────────────────────────────────
    // 5-1. @ 연산자로 범위와 값 동시 캡처
    // ─────────────────────────────────────────
    println!("  [5-1] @ 연산자로 범위 매칭과 값 캡처");

    let responses = vec![
        Response::Ok(200),
        Response::Ok(404),
        Response::Ok(500),
        Response::Err(String::from("Timeout")),
    ];

    println!("    HTTP 상태 코드 처리:");
    for response in responses {
        match response {
            Response::Ok(code @ 200..=299) => {
                println!("      ✅ 성공 [{}]", code);
            }
            Response::Ok(code @ 300..=399) => {
                println!("      🔄 리다이렉트 [{}]", code);
            }
            Response::Ok(code @ 400..=499) => {
                println!("      ❌ 클라이언트 오류 [{}]", code);
            }
            Response::Ok(code @ 500..=599) => {
                println!("      💥 서버 오류 [{}]", code);
            }
            Response::Ok(code) => {
                println!("      ❓ 미분류 [{}]", code);
            }
            Response::Err(msg) => {
                println!("      🚨 에러: {}", msg);
            }
        }
    }
    println!();

    // ─────────────────────────────────────────
    // 5-2. 구조체 필드에서 @ 활용
    // ─────────────────────────────────────────
    println!("  [5-2] 구조체 필드와 @ 결합");

    #[derive(Debug)]
    enum Action {
        Move { distance: i32 },
        Resize { width: u32, height: u32 },
    }

    let actions = vec![
        Action::Move { distance: 0 },
        Action::Move { distance: 50 },
        Action::Move { distance: 1000 },
        Action::Resize {
            width: 800,
            height: 600,
        },
    ];

    println!("    동작 분류:");
    for action in actions {
        match action {
            Action::Move { distance: 0 } => {
                println!("      🚫 이동하지 않음");
            }
            Action::Move { distance: d @ 1..=100 } => {
                println!("      📍 짧은 이동: {} 픽셀", d);
            }
            Action::Move { distance: d @ 101..=1000 } => {
                println!("      🚗 중간 이동: {} 픽셀", d);
            }
            Action::Move { distance: d } => {
                println!("      🚀 긴 이동: {} 픽셀", d);
            }
            Action::Resize { width, height } => {
                println!("      📐 크기 조정: {}x{}", width, height);
            }
        }
    }
    println!();

    println!("  💡 핵심: @는 범위 매칭과 값 캡처를 동시에 수행합니다.\n");
}

// ===================================================================
// Section 6: ref와 mut 패턴 (Reference and Mutable Patterns)
// ===================================================================
//
// 패턴 매칭에서 참조와 가변성을 다루는 방법입니다.
//
fn section_6_ref_and_mut_patterns() {
    println!("▶ Section 6: ref와 mut 패턴");
    println!("─────────────────────────────────────────\n");

    #[derive(Debug)]
    enum Asset {
        Money(f64),
        Item { name: String, count: u32 },
    }

    // ─────────────────────────────────────────
    // 6-1. ref 패턴: 소유권 이동 방지
    // ─────────────────────────────────────────
    println!("  [6-1] ref 패턴으로 소유권 이동 방지");

    let asset = Asset::Item {
        name: String::from("Gold"),
        count: 100,
    };

    // ref를 사용하지 않으면 소유권이 이동됨
    // match asset {
    //     Asset::Item { name, count } => { /* name 소유권 이동 */ }
    // }
    // println!("{:?}", asset);  // ❌ 오류!

    // ref를 사용하면 참조만 얻음
    match &asset {
        Asset::Item { name, count } => {
            println!("      아이템: {} × {}", name, count);
        }
        _ => {}
    }

    println!("      asset은 여전히 소유권 유지: {:?}", asset);
    println!();

    // ─────────────────────────────────────────
    // 6-2. ref mut 패턴: 가변 참조
    // ─────────────────────────────────────────
    println!("  [6-2] ref mut 패턴으로 수정");

    let mut money = Asset::Money(1000.0);

    match &mut money {
        Asset::Money(amount) => {
            *amount *= 2.0;
            println!("      자산 두 배 증가: ${:.2}", amount);
        }
        _ => {}
    }

    println!("      최종 자산: {:?}", money);
    println!();

    println!("  💡 핵심: ref와 ref mut은 소유권을 다루는 미세한 제어를 제공합니다.\n");
}

// ===================================================================
// Section 7: 실전 예제 - 다층 메시지 프로세서 (Advanced Real-World)
// ===================================================================
//
// 모든 패턴을 종합한 실제 시스템 구현
//
fn section_7_advanced_real_world() {
    println!("▶ Section 7: 실전 예제 - 다층 메시지 프로세서");
    println!("─────────────────────────────────────────\n");

    #[derive(Debug, Clone)]
    enum Message {
        Text(String),
        Image { url: String, size: usize },
        File {
            path: String,
            permissions: FilePermissions,
        },
        Command {
            name: String,
            args: Vec<String>,
        },
    }

    #[derive(Debug, Clone)]
    enum FilePermissions {
        ReadOnly,
        ReadWrite,
        Execute,
        Custom(u32),
    }

    #[derive(Debug)]
    enum ProcessResult {
        Success(String),
        Warning { message: String, code: u32 },
        Error { message: String, recoverable: bool },
    }

    // ─────────────────────────────────────────
    // 7-1. 메시지 프로세서 구현
    // ─────────────────────────────────────────
    println!("  [7-1] 메시지 처리 엔진");

    fn process_message(msg: &Message) -> ProcessResult {
        match msg {
            Message::Text(content) if content.len() > 1000 => {
                ProcessResult::Warning {
                    message: String::from("메시지가 너무 깁니다"),
                    code: 1001,
                }
            }
            Message::Text(content) => {
                ProcessResult::Success(format!("텍스트 처리됨: {} 글자", content.len()))
            }
            Message::Image { url, size } if size > 10_000_000 => {
                ProcessResult::Error {
                    message: format!("이미지 파일이 너무 큽니다 ({}MB)", size / 1_000_000),
                    recoverable: false,
                }
            }
            Message::Image { url, size } => {
                ProcessResult::Success(format!("이미지 로드됨: {} ({}KB)", url, size / 1024))
            }
            Message::File { path, permissions } => {
                match permissions {
                    FilePermissions::ReadOnly => {
                        ProcessResult::Success(format!("파일 읽음: {}", path))
                    }
                    FilePermissions::ReadWrite => {
                        ProcessResult::Success(format!("파일 수정: {}", path))
                    }
                    FilePermissions::Execute => {
                        ProcessResult::Success(format!("파일 실행: {}", path))
                    }
                    FilePermissions::Custom(perms) => {
                        ProcessResult::Success(format!("파일 처리 [{}]: {}", perms, path))
                    }
                }
            }
            Message::Command { name, args } if args.is_empty() => {
                ProcessResult::Success(format!("명령 실행: {}", name))
            }
            Message::Command { name, args } => {
                ProcessResult::Success(format!("명령 실행: {} {:?}", name, args))
            }
        }
    }

    let messages = vec![
        Message::Text(String::from("Hello, v5.4!")),
        Message::Text(String::from("a".repeat(2000))),
        Message::Image {
            url: String::from("https://example.com/image.jpg"),
            size: 5_000_000,
        },
        Message::Image {
            url: String::from("https://example.com/huge.jpg"),
            size: 50_000_000,
        },
        Message::File {
            path: String::from("/data/config.txt"),
            permissions: FilePermissions::ReadOnly,
        },
        Message::Command {
            name: String::from("deploy"),
            args: vec![String::from("--production"), String::from("--force")],
        },
    ];

    println!("    메시지 처리:");
    for msg in messages {
        let result = process_message(&msg);
        match result {
            ProcessResult::Success(msg) => println!("      ✅ {}", msg),
            ProcessResult::Warning { message, code } => {
                println!("      ⚠️  경고 [{}]: {}", code, message)
            }
            ProcessResult::Error {
                message,
                recoverable,
            } => {
                if recoverable {
                    println!("      🔧 복구 가능한 에러: {}", message);
                } else {
                    println!("      ❌ 치명적 에러: {}", message);
                }
            }
        }
    }
    println!();

    // ─────────────────────────────────────────
    // 7-2. 상태 머신 구현
    // ─────────────────────────────────────────
    println!("  [7-2] 상태 머신: 주문 처리 흐름");

    #[derive(Debug, Clone, PartialEq)]
    enum OrderState {
        Created { items: u32 },
        Confirmed { items: u32, total: f64 },
        Shipped { tracking: String, delivery_date: u32 },
        Delivered,
        Cancelled { reason: String },
    }

    struct OrderProcessor;

    impl OrderProcessor {
        fn process_transition(state: OrderState, action: &str) -> Result<OrderState, String> {
            match (state, action) {
                (OrderState::Created { items }, "confirm") => {
                    Ok(OrderState::Confirmed {
                        items,
                        total: items as f64 * 99.99,
                    })
                }
                (OrderState::Confirmed { items, total }, "ship") => {
                    Ok(OrderState::Shipped {
                        tracking: String::from("TRK123456"),
                        delivery_date: 5,
                    })
                }
                (OrderState::Shipped { .. }, "deliver") => Ok(OrderState::Delivered),
                (OrderState::Created { .. } | OrderState::Confirmed { .. }, "cancel") => {
                    Ok(OrderState::Cancelled {
                        reason: String::from("User cancelled"),
                    })
                }
                (state, action) => Err(format!("Invalid action '{}' for state {:?}", action, state)),
            }
        }
    }

    let mut order = OrderState::Created { items: 3 };
    println!("    주문 상태: {:?}", order);

    for action in &["confirm", "ship", "deliver"] {
        match OrderProcessor::process_transition(order.clone(), action) {
            Ok(new_state) => {
                println!("    → 액션 '{}' 수행", action);
                println!("      상태: {:?}", new_state);
                order = new_state;
            }
            Err(e) => println!("    ❌ {}", e),
        }
    }
    println!();

    println!("  💡 핵심: 복잡한 로직을 데이터 구조와 패턴 매칭으로 우아하게 표현합니다.\n");
}

