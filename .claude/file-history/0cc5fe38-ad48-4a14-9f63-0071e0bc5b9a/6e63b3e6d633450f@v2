### 5. 검증과 무결성

```rust
struct Validator;

impl Validator {
    // 데이터 유효성 검사
    fn validate_id(id: u32) -> Result<(), String> {
        match id {
            0 => Err("ID는 0이 될 수 없음".into()),
            1..=10000 => Ok(()),
            _ => Err("ID는 10000 이하여야 함".into()),
        }
    }

    fn validate_location(loc: &str) -> Result<(), String> {
        match loc.len() {
            0 => Err("위치는 비워둘 수 없음".into()),
            1..=100 => Ok(()),
            _ => Err("위치는 100자 이하여야 함".into()),
        }
    }
}

// 메서드에서 활용
impl Center {
    fn register_node(&mut self, id: u32, loc: &str) -> Result<(), String> {
        Validator::validate_id(id)?;
        Validator::validate_location(loc)?;
        // ... 실제 등록
        Ok(())
    }
}
```

### 6. 고급 쿼리 (함수형 스타일)

```rust
// 조건부 필터링
fn get_warning_nodes(&self) -> Vec<&Node> {
    self.nodes
        .values()
        .filter(|node| matches!(node.status, NodeStatus::Warning(_)))
        .collect()
}

// 변환과 수집
fn get_node_ids(&self) -> Vec<u32> {
    self.nodes
        .keys()
        .copied()
        .collect()
}

// filter_map으로 추출
fn get_warnings(&self) -> Vec<String> {
    self.nodes
        .values()
        .filter_map(|node| match &node.status {
            NodeStatus::Warning(msg) => Some(msg.clone()),
            _ => None,
        })
        .collect()
}

// 통계 계산
fn health_score(&self) -> i32 {
    let total = self.nodes.len() as i32;
    if total == 0 { return 100; }
    let active = self.nodes.values()
        .filter(|n| matches!(n.status, NodeStatus::Active))
        .count() as i32;
    (active * 100) / total
}
```

