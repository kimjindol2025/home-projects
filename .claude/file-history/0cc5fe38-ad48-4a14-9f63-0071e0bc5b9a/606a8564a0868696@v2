// ══════════════════════════════════════════════════════════════
// [v3.7 설계: 상태 정의]
// ══════════════════════════════════════════════════════════════
// 시스템이 가질 수 있는 모든 상태를 enum으로 정의합니다.
// 각 상태는 필요한 데이터를 함께 가집니다.

#[derive(Debug, Clone, PartialEq)]
enum SystemState {
    Idle,              // 대기 상태: 명령 대기 중
    Running(u8),       // 가동 상태: 현재 출력 수치
    Error(String),     // 에러 상태: 에러 메시지
}

// ══════════════════════════════════════════════════════════════
// [v3.7 설계: 상태 전이 엔진]
// ══════════════════════════════════════════════════════════════
// 현재 상태와 명령을 받아 다음 상태를 결정합니다.
// match를 통해 모든 경로가 처리됨을 컴파일러가 검증합니다.

fn transition(current: SystemState, command: &str) -> SystemState {
    match current {
        // [상태 1] Idle (대기)
        SystemState::Idle => {
            match command {
                "START" => {
                    println!("  ✅ [전이] Idle → Running(초기화 시작)");
                    SystemState::Running(10)
                }
                "STOP" => {
                    println!("  ℹ️  [상태유지] 이미 대기 상태입니다");
                    SystemState::Idle
                }
                "RESET" => {
                    println!("  ℹ️  [상태유지] 대기 상태는 이미 초기화되어 있습니다");
                    SystemState::Idle
                }
                _ => {
                    println!("  ⚠️  [무시] 대기 상태에서는 '{}' 명령을 처리할 수 없습니다", command);
                    SystemState::Idle
                }
            }
        }

        // [상태 2] Running (가동)
        SystemState::Running(power) => {
            match command {
                "POWER_UP" => {
                    let new_power = (power + 20).min(100);
                    println!("  ✅ [갱신] Running({}) → Running({}) (출력 증가)", power, new_power);
                    SystemState::Running(new_power)
                }
                "POWER_DOWN" => {
                    if power <= 20 {
                        println!("  ✅ [전이] Running({}) → Idle (출력 차단, 대기로 전환)", power);
                        SystemState::Idle
                    } else {
                        let new_power = power - 20;
                        println!("  ✅ [갱신] Running({}) → Running({}) (출력 감소)", power, new_power);
                        SystemState::Running(new_power)
                    }
                }
                "ERROR_TRIGGER" => {
                    println!("  🔴 [전이] Running({}) → Error(과부하 감지!) (비정상 종료)", power);
                    SystemState::Error("과부하로 인한 자동 종료".to_string())
                }
                "STOP" => {
                    println!("  ✅ [전이] Running({}) → Idle (정상 종료)", power);
                    SystemState::Idle
                }
                "START" => {
                    println!("  ⚠️  [무시] 이미 가동 중입니다. START 명령은 불가능합니다");
                    SystemState::Running(power)
                }
                _ => {
                    println!("  ⚠️  [무시] Running 상태에서는 '{}' 명령을 인식할 수 없습니다", command);
                    SystemState::Running(power)
                }
            }
        }

        // [상태 3] Error (에러)
        SystemState::Error(ref msg) => {
            match command {
                "RECOVER" => {
                    println!("  ✅ [전이] Error('{}') → Idle (시스템 복구 완료)", msg);
                    SystemState::Idle
                }
                "RESET" => {
                    println!("  ✅ [전이] Error('{}') → Idle (강제 리셋)", msg);
                    SystemState::Idle
                }
                _ => {
                    println!("  🔴 [차단] Error 상태에서는 '{}' 명령을 실행할 수 없습니다", command);
                    println!("         (현재 에러: {})", msg);
                    SystemState::Error(msg.clone())
                }
            }
        }
    }
}

