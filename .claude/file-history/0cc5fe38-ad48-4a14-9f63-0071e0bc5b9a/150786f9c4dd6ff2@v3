fn main() {
    println!("╔════════════════════════════════════════════════════════════╗");
    println!("║ v7.0: 수명(Lifetimes)의 심연                             ║");
    println!("║     \"안전한 시간의 경계 설정\"                           ║");
    println!("╚════════════════════════════════════════════════════════════╝\n");

    // ─────────────────────────────────────────
    // [기본 수명 이해]
    // ─────────────────────────────────────────
    println!("▶ Step 1-1: 기본 수명 개념\n");

    let string1 = "GOGS-Protocol-Alpha";
    let string2 = "Beta";

    let result = longest(string1, string2);
    println!("더 긴 문자열: {}", result);
    println!("설명: longest() 함수는 'a 수명을 사용하여");
    println!("      반환값이 두 입력값의 수명만큼 유효함을 보장합니다.\n");

    // ─────────────────────────────────────────
    // [구조체 내 수명]
    // ─────────────────────────────────────────
    println!("▶ Step 1-2: 구조체의 수명\n");

    let novel = String::from("원본 보안 문서의 내용...");
    let first_sentence = novel.split('.').next().expect("Could not find a '.'");

    let excerpt = ImportantExcerpt {
        part: first_sentence,
    };

    println!("중요한 발췌: {}", excerpt.part);
    println!("공지: 이는 원본 데이터 기반입니다");
    let returned = excerpt.announce_and_return_part("이 부분을 처리 중입니다");
    println!("반환된 부분: {}\n", returned);

    // ─────────────────────────────────────────
    // [수명의 스코프]
    // ─────────────────────────────────────────
    println!("▶ Step 1-3: 수명과 스코프의 관계\n");

    let string1 = "GOGS-Alpha-Protocol";
    let result;

    {
        let string2 = "Beta";
        // string2의 수명이 여기서 시작됩니다.
        result = longest(string1.as_str(), string2.as_str());

        // string2가 아직 살아있으므로 result 사용이 안전합니다.
        println!("블록 안: 가장 긴 문자열: {}", result);
    }
    // string2의 수명이 여기서 끝납니다.

    // 이 위치에서 result 사용이 안전합니다.
    // (result는 string1을 기반으로 하므로)
    println!("블록 밖: 가장 긴 문자열: {}\n", result);

    // ─────────────────────────────────────────
    // [보안 메시지 추적 시스템]
    // ─────────────────────────────────────────
    println!("▶ Step 1-4: 실전 예제 - 보안 메시지 추적\n");

    let primary_msg = "암호화 키 생성 완료";
    let backup_msg = "백업";
    let mut tracker = MessageTracker::new(primary_msg, backup_msg, 8);

    tracker.report();

    // 외부 메시지 처리
    let external = "새로운 보안 알람";
    let processed = tracker.process_secure_message(external);
    println!("처리된 외부 메시지: {}\n", processed);

    // ─────────────────────────────────────────
    // [서로 다른 수명]
    // ─────────────────────────────────────────
    println!("▶ Step 1-5: 여러 수명의 활용\n");

    let msg1 = "장기 데이터";
    let result1;

    {
        let msg2 = "단기";
        result1 = get_first(msg1, msg2.as_str());
        println!("get_first 결과: {}", result1);
    }

    // msg2는 사라졌지만, result1은 msg1을 기반으로 하므로 안전합니다.
    println!("블록 후: {}\n", result1);

    // ─────────────────────────────────────────
    // [Lifetime Elision (생략)]
    // ─────────────────────────────────────────
    println!("▶ Step 1-6: 수명 생략 규칙\n");

    let text = "안녕 세상";
    let word = first_word(text);
    println!("첫 단어: {}", word);
    println!("설명: first_word는 단일 참조만 가지므로");
    println!("      수명을 명시할 필요가 없습니다.\n");

    // ─────────────────────────────────────────
    // [핵심 요점 정리]
    // ─────────────────────────────────────────
    println!("╔════════════════════════════════════════════════════════════╗");
    println!("║ 수명(Lifetimes)의 핵심");
    println!("╚════════════════════════════════════════════════════════════╝\n");

    println!("📌 수명의 의미:");
    println!("   &'a str: '이 참조는 적어도 'a 기간 동안 유효하다'\n");

    println!("📌 수명의 목적:");
    println!("   - 허상 참조(Dangling Pointer) 방지");
    println!("   - 여러 참조의 관계 명확히");
