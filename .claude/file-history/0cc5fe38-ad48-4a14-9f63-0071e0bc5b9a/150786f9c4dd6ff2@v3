/*

[수명이란 무엇인가?]
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

수명은 "시간의 범위"입니다.

'a는 이름을 붙인 수명입니다.
&'a str은 "이 문자열 참조는 최소한 'a 기간 동안 유효하다"는 의미입니다.


[왜 수명이 필요한가?]
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

허상 참조(Dangling Pointer)를 방지하기 위해:

fn bad_example() -> &str {
    let s = String::from("hello");
    &s  // ❌ 에러! s의 수명은 함수 끝에서 끝나는데,
        // 함수 밖에서 참조를 사용하려고 함
}

수명이 없으면 컴파일러는 이 위험을 감지할 수 없습니다.
하지만 수명을 명시하면 컴파일러가 자동으로 감지합니다!


[수명의 세 가지 규칙]
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

규칙 1: 각 참조는 고유한 수명을 받습니다
fn example(x: &str, y: &str)
↓
fn example<'a, 'b>(x: &'a str, y: &'b str)

규칙 2: 반환값이 입력과 같으면 수명도 같습니다
fn example(x: &str) -> &str
↓
fn example<'a>(x: &'a str) -> &'a str

규칙 3: &mut self가 있으면 그 수명이 반환값에 적용됩니다
impl MyStruct {
    fn method(&mut self) -> &str { ... }
}
↓
impl<'a> MyStruct {
    fn method<'a>(&'a mut self) -> &'a str { ... }
}


[수명은 시간을 늘리지 않습니다]
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

