// ===================================================================
// 기본 개념: 허상 참조(Dangling Pointer)의 방지
// ===================================================================

/// [예제 1] 수명 없이는 불가능한 함수
///
/// 두 참조자 중 더 긴 것을 반환하는 함수.
/// 반환하는 참조자가 입력 참조자 중 어느 것을 기반으로 하는지,
/// 컴파일러가 알 수 없습니다.
///
/// 따라서 'a라는 이름의 수명을 사용하여
/// "반환값의 수명은 두 입력값의 수명과 같다"고 명시합니다.
fn longest<'a>(x: &'a str, y: &'a str) -> &'a str {
    if x.len() > y.len() {
        x
    } else {
        y
    }
}

// ===================================================================
// 기본 개념: 수명의 의미
// ===================================================================

/// [수명의 시각화]
///
/// 스코프와 수명의 관계:
///
/// {                        // string1의 수명 시작
///     {                    // string2의 수명 시작
///         longest(...)     // 둘 다 유효함
///     }                    // string2의 수명 끝
/// }                        // string1의 수명 끝
///
/// 'a가 두 참조를 모두 포함해야 하므로,
/// 'a의 범위는 더 짧은 쪽(string2)까지만입니다.

/// [예제 2] 수명이 명시된 구조체
///
/// 참조자를 필드로 가지려면 수명을 명시해야 합니다.
struct ImportantExcerpt<'a> {
    part: &'a str,
}

impl<'a> ImportantExcerpt<'a> {
    fn announce_and_return_part(&self, announcement: &str) -> &str {
        println!("주의: {}", announcement);
        self.part
    }
}

// ===================================================================
// [Step 1-1] 기본 수명: 단순한 참조
// ===================================================================

/// 단일 참조자: 수명 명시 불필요 (생략 가능)
fn first_word(s: &str) -> &str {
    let bytes = s.as_bytes();
    for (i, &item) in bytes.iter().enumerate() {
        if item == b' ' {
            return &s[0..i];
        }
    }
    &s[..]
}

// ===================================================================
// [Step 1-2] 다중 참조: 수명 명시 필수
// ===================================================================

/// 여러 참조자가 입력되고 하나를 반환할 때
/// 반환값의 수명이 어느 입력값과 같은지 명시해야 합니다.
fn combine_messages<'a>(msg1: &'a str, msg2: &'a str) -> &'a str {
    if msg1.len() > msg2.len() {
        msg1
    } else {
        msg2
    }
}

// ===================================================================
// [Step 1-3] 서로 다른 수명
// ===================================================================

/// 여러 참조자가 서로 다른 수명을 가질 수 있습니다.
fn get_first<'a, 'b>(x: &'a str, y: &'b str) -> &'a str {
    // 이 함수는 x를 반환합니다.
    // x의 수명은 'a이고, y의 수명은 'b입니다.
    // 반환값은 'a를 따릅니다.
    x
}

// ===================================================================
// [Step 1-4] 구조체의 수명
// ===================================================================

/// 구조체가 참조자를 필드로 가지려면 수명을 명시해야 합니다.
struct SecurityLog<'a> {
    message: &'a str,
    level: u32,
}

impl<'a> SecurityLog<'a> {
    fn new(message: &'a str, level: u32) -> Self {
        SecurityLog { message, level }
    }

    fn get_message(&self) -> &str {
        self.message
    }

    fn log(&self) {
        println!("[Level {}] {}", self.level, self.message);
    }
}

// ===================================================================
// [Step 1-5] 수명 경계 (Lifetime Bounds)
// ===================================================================

/// 제네릭과 수명을 결합할 수 있습니다.
fn print_length<'a, T: std::fmt::Display>(x: &'a T, y: &'a T) -> &'a T {
    println!("Comparing");
    if std::mem::size_of_val(x) > std::mem::size_of_val(y) {
        x
    } else {
        y
    }
}

// ===================================================================
// [Step 1-6] Lifetime Elision (생략)
// ===================================================================

/// 러스트는 때로 수명을 자동으로 유추합니다.
/// 세 가지 규칙이 있습니다:
///
/// 규칙 1: 각 입력 참조는 고유한 수명을 받습니다.
fn rule1(x: &str) -> &str {
    // &str -> &'a str (자동 추가)
    x
}

/// 규칙 2: 입력이 하나의 수명을 가지면, 출력도 같은 수명을 받습니다.
fn rule2(x: &str) -> &str {
    // &'a str -> &'a str (자동 추가)
    x
}

/// 규칙 3: &mut self를 가지면, 그 수명이 출력에 적용됩니다.
struct Handler<'a> {
    data: &'a str,
}

impl<'a> Handler<'a> {
    fn process(&mut self) -> &'a str {
        // 자동으로 &'a str이 반환됨
        self.data
    }
}

// ===================================================================
// [실전 예제] 보안 메시지 추적 시스템
// ===================================================================

/// 보안 메시지를 저장하고 추적하는 시스템
struct MessageTracker<'a> {
    current_message: &'a str,
    backup_message: &'a str,
    sensitivity: u32,
}

impl<'a> MessageTracker<'a> {
    fn new(current: &'a str, backup: &'a str, sensitivity: u32) -> Self {
        MessageTracker {
            current_message: current,
            backup_message: backup,
            sensitivity,
        }
    }

    /// 더 긴 메시지를 반환합니다.
    fn get_primary_message(&self) -> &'a str {
        if self.current_message.len() > self.backup_message.len() {
            self.current_message
        } else {
            self.backup_message
        }
    }

    /// 메시지를 안전하게 처리합니다.
    fn process_secure_message<'b>(&self, external: &'b str) -> &'b str {
        // 외부 메시지는 다른 수명을 가집니다.
        // 따라서 'a와 'b로 구분합니다.
        println!("Processing: {}", external);
        external
    }

    /// 메시지 정보를 출력합니다.
    fn report(&self) {
        println!("╔═════════════════════════════════════╗");
        println!("║ 보안 메시지 추적 시스템");
        println!("╚═════════════════════════════════════╝");
        println!("현재 메시지: {}", self.current_message);
        println!("백업 메시지: {}", self.backup_message);
        println!("민감도 수준: {}", self.sensitivity);
        println!("사용할 메시지: {}", self.get_primary_message());
        println!();
    }
}

