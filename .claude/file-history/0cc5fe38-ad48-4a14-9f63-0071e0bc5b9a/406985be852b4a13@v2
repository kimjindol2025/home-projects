### 4단계: 제네릭 열거형

```rust
enum Status<T> {
    Success(T),
    Error(String),
    Pending,
}

impl<T> Status<T> {
    fn is_success(&self) -> bool {
        matches!(self, Status::Success(_))
    }

    fn get_value(&self) -> Option<&T> {
        match self {
            Status::Success(val) => Some(val),
            _ => None,
        }
    }
}

// 사용
let success: Status<i32> = Status::Success(42);
let error: Status<i32> = Status::Error("Failed".to_string());

println!("{}", success.is_success());  // true
println!("{:?}", success.get_value()); // Some(42)
```

### 5단계: 제네릭 함수

```rust
// 제네릭 함수 (T는 어떤 타입이든)
fn print_value<T: std::fmt::Display>(value: T) {
    println!("값: {}", value);
}

// 제약이 있는 제네릭 함수
fn find_max<T: PartialOrd>(a: T, b: T) -> T {
    if a > b { a } else { b }
}

// Clone 제약
fn duplicate<T: Clone>(value: T) -> (T, T) {
    (value.clone(), value)
}

// 사용
print_value(42);        // 값: 42
print_value("hello");   // 값: hello

let max = find_max(10, 20);
println!("{}", max);    // 20

let (v1, v2) = duplicate("hello".to_string());
println!("{}, {}", v1, v2);  // hello, hello
```

