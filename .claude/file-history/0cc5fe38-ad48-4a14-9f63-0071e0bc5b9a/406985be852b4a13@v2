## 📝 설계 패턴

### 패턴 1: 범용 Container

```rust
struct Container<T> {
    data: T,
}

impl<T> Container<T> {
    fn new(data: T) -> Self {
        Container { data }
    }

    fn get(&self) -> &T {
        &self.data
    }

    fn get_mut(&mut self) -> &mut T {
        &mut self.data
    }

    fn into_data(self) -> T {
        self.data
    }

    fn map<U, F>(self, f: F) -> Container<U>
    where
        F: FnOnce(T) -> U,
    {
        Container {
            data: f(self.data),
        }
    }
}

// 사용
let container = Container::new(42);
let mapped = container.map(|x| x * 2);
println!("{}", mapped.get());  // 84
```

### 패턴 2: 제네릭 스택

```rust
struct Stack<T> {
    items: Vec<T>,
}

impl<T> Stack<T> {
    fn new() -> Self {
        Stack { items: Vec::new() }
    }

    fn push(&mut self, item: T) {
        self.items.push(item);
    }

    fn pop(&mut self) -> Option<T> {
        self.items.pop()
    }

    fn peek(&self) -> Option<&T> {
        self.items.last()
    }

    fn is_empty(&self) -> bool {
        self.items.is_empty()
    }

    fn size(&self) -> usize {
        self.items.len()
    }
}

// 사용
let mut stack = Stack::new();
stack.push(1);
stack.push(2);
stack.push(3);

while let Some(val) = stack.pop() {
    println!("{}", val);  // 3, 2, 1
}
```

### 패턴 3: 제네릭 Wrapper

```rust
struct Wrapper<T> {
    inner: T,
}

impl<T> Wrapper<T> {
    fn new(inner: T) -> Self {
        Wrapper { inner }
    }

    fn get_ref(&self) -> &T {
        &self.inner
    }

    fn get_mut(&mut self) -> &mut T {
        &mut self.inner
    }

    fn unwrap(self) -> T {
        self.inner
    }

    fn map<U, F>(self, f: F) -> Wrapper<U>
    where
        F: FnOnce(T) -> U,
    {
        Wrapper {
            inner: f(self.inner),
        }
    }
}

// Clone 제약
impl<T: Clone> Wrapper<T> {
    fn clone_inner(&self) -> T {
        self.inner.clone()
    }
}

// Display 제약
impl<T: std::fmt::Display> Wrapper<T> {
    fn display(&self) {
        println!("{}", self.inner);
    }
}

// 사용
let w = Wrapper::new(42);
let w2 = w.map(|x| x * 2);
println!("{}", w2.unwrap());  // 84
```

### 패턴 4: 조건부 메서드 구현

```rust
struct Processor<T> {
    value: T,
}

impl<T> Processor<T> {
    fn new(value: T) -> Self {
        Processor { value }
    }
}

// T: Clone인 경우만
impl<T: Clone> Processor<T> {
    fn duplicate(&self) -> (T, T) {
        (self.value.clone(), self.value.clone())
    }
}

// T: Display인 경우만
impl<T: std::fmt::Display> Processor<T> {
    fn show(&self) {
        println!("값: {}", self.value);
    }
}

// T: Clone + Display인 경우만
impl<T: Clone + std::fmt::Display> Processor<T> {
    fn clone_and_show(&self) {
        self.show();
        let _ = self.duplicate();
    }
}

// 사용
let p = Processor::new(42);
p.show();  // 값: 42
```

