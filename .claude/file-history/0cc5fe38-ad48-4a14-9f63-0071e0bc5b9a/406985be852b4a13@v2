    if id > 0 {
        Ok(format!("User {}", id))
    } else {
        Err("Invalid ID".to_string())
    }
}

match process_user(42) {
    Ok(name) => println!("성공: {}", name),
    Err(e) => println!("실패: {}", e),
}
```

