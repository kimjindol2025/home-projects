// ===================================================================
// Section 1: String (소유) - 동적 텍스트
// ===================================================================
//
// String은 Vec<u8>의 래퍼로, UTF-8 인코딩된 바이트를 소유합니다.
//
fn section_1_string_owned() {
    println!("▶ Section 1: String (소유) - 동적 텍스트");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 1-1. String 생성
    // ─────────────────────────────────────────
    println!("  [1-1] String 생성 방법");

    // 방법 1: 빈 String
    let mut s1 = String::new();
    println!("    String::new(): {:?}", s1);

    // 방법 2: 리터럴에서
    let s2 = String::from("Hello, Rust!");
    println!("    String::from(): {}", s2);

    // 방법 3: 리터럴의 to_string()
    let s3 = "Hello".to_string();
    println!("    to_string(): {}", s3);

    // 방법 4: with_capacity (사전 할당)
    let mut s4 = String::with_capacity(20);
    println!("    with_capacity(20): len={}, capacity={}\n", s4.len(), s4.capacity());

    // ─────────────────────────────────────────
    // 1-2. String 수정
    // ─────────────────────────────────────────
    println!("  [1-2] String 수정");

    let mut system_id = String::from("GOGS-Core");
    println!("    초기: {}", system_id);

    system_id.push_str("-Alpha");
    println!("    push_str(\"-Alpha\"): {}", system_id);

    system_id.push('!');
    println!("    push('!'): {}", system_id);

    system_id.pop();
    println!("    pop(): {}", system_id);

    println!();

    // ─────────────────────────────────────────
    // 1-3. String의 메모리 구조
    // ─────────────────────────────────────────
    println!("  [1-3] String의 메모리 구조");

    let text = String::from("Hello, 세계!");
    println!("    문자열: {}", text);
    println!("    길이(바이트): {}", text.len());
    println!("    용량: {}", text.capacity());
    println!("    → String = Vec<u8>의 래퍼");
    println!("    → 항상 유효한 UTF-8 보장\n");

    // ─────────────────────────────────────────
    // 1-4. String 재할당
    // ─────────────────────────────────────────
    println!("  [1-4] String의 성장");

    let mut s = String::new();
    for i in 0..5 {
        s.push_str("A");
        if i == 0 || i == 2 || i == 4 {
            println!("    i={}: len={}, capacity={}", i, s.len(), s.capacity());
        }
    }
    println!("    → Vec처럼 필요시 자동 재할당\n");

    println!("  💡 핵심: String은 힙의 UTF-8 텍스트를 소유하고 수정할 수 있습니다.\n");
}

// ===================================================================
// Section 2: &str (참조) - 텍스트 슬라이스
// ===================================================================
//
// &str은 유효한 UTF-8 바이트 시퀀스의 참조입니다.
// 메모리를 빌려 사용하며, 불변입니다.
//
fn section_2_str_borrowed() {
    println!("▶ Section 2: &str (참조) - 텍스트 슬라이스");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 2-1. &str 리터럴
    // ─────────────────────────────────────────
    println!("  [2-1] &str 리터럴");

    let literal: &str = "Hello, World!";
    println!("    리터럴: {}", literal);
    println!("    타입: &str");
    println!("    저장: 바이너리에 고정 (컴파일 타임)\n");

    // ─────────────────────────────────────────
    // 2-2. String에서 슬라이스
    // ─────────────────────────────────────────
    println!("  [2-2] String에서 &str 슬라이스");

    let full = String::from("GOGS-Core-System");
    println!("    원본: {}", full);

    let slice1 = &full[0..4];
    println!("    [0..4]: {}", slice1);

    let slice2 = &full[5..9];
    println!("    [5..9]: {}", slice2);

    let slice3 = &full[10..];
    println!("    [10..]: {}\n", slice3);

    // ─────────────────────────────────────────
    // 2-3. 전체 문자열 참조
    // ─────────────────────────────────────────
    println!("  [2-3] 전체 문자열 참조");

    let s = String::from("Hello, Rust!");
    let full_slice: &str = &s;
    println!("    전체 참조: {}", full_slice);
    println!("    → &String은 &str로 자동 변환 (deref coercion)\n");

    // ─────────────────────────────────────────
    // 2-4. &str의 메서드
    // ─────────────────────────────────────────
    println!("  [2-4] &str의 메서드");

    let text = "Hello, 세계!";
    println!("    문자열: {}", text);
    println!("    길이(바이트): {}", text.len());
    println!("    contains(\"세계\"): {}", text.contains("세계"));
    println!("    starts_with(\"Hello\"): {}", text.starts_with("Hello"));
    println!("    is_empty(): {}\n", text.is_empty());

    println!("  💡 핵심: &str은 메모리를 빌려 사용하며, UTF-8 안전성을 보장합니다.\n");
}

// ===================================================================
// Section 3: String과 &str 변환
// ===================================================================
//
// String과 &str 사이의 변환은 설계자의 기술입니다.
//
fn section_3_string_str_conversion() {
    println!("▶ Section 3: String과 &str 변환");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 3-1. &str → String
    // ─────────────────────────────────────────
    println!("  [3-1] &str → String");

    let literal = "Hello";
    let s1 = literal.to_string();
    println!("    to_string(): {}", s1);

    let s2 = String::from(literal);
    println!("    String::from(): {}", s2);

    let s3 = literal.to_owned();
    println!("    to_owned(): {}\n", s3);

    // ─────────────────────────────────────────
    // 3-2. String → &str
    // ─────────────────────────────────────────
    println!("  [3-2] String → &str");

    let owned = String::from("Hello");
    let borrowed: &str = &owned;
    println!("    &String: {}", borrowed);

    let borrowed2: &str = owned.as_str();
    println!("    as_str(): {}\n", borrowed2);

    // ─────────────────────────────────────────
    // 3-3. 규칙: String → &str는 무료, &str → String은 비용
    // ─────────────────────────────────────────
    println!("  [3-3] 변환의 비용");

    let s = String::from("expensive");
    let _r1 = &s;              // 무료: 참조만 생성
    let _r2 = s.as_str();      // 무료: 참조만 생성
    let _s = "cheap".to_string(); // 비용: 새 메모리 할당

    println!("    &String → &str: 무료 (참조)");
    println!("    &str → String: 비용 (메모리 할당)\n");

    // ─────────────────────────────────────────
    // 3-4. into() 변환
    // ─────────────────────────────────────────
    println!("  [3-4] into() 암시적 변환");

    fn example_takes_string(_s: String) {}
    fn example_takes_str(_s: &str) {}

    let text = "Hello";
    example_takes_str(text);              // &str 전달 가능

    let owned = String::from("World");
    example_takes_str(&owned);            // &String은 &str로 자동 변환

    println!("    &str과 String의 자동 변환으로 유연성 확보\n");

    println!("  💡 핵심: 가능하면 &str 사용, 필요할 때만 String으로 변환합니다.\n");
}

// ===================================================================
// Section 4: 안전한 접근 - 바이트 vs 문자
// ===================================================================
//
// UTF-8은 문자마다 1~4바이트를 차지하므로,
// 인덱싱으로 문자에 접근하는 것은 위험합니다.
//
fn section_4_safe_access() {
    println!("▶ Section 4: 안전한 접근 - 바이트 vs 문자");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 4-1. 위험한 인덱싱
    // ─────────────────────────────────────────
    println!("  [4-1] 위험한 인덱싱 ⚠️");

    let text = "Hello";
    println!("    \"Hello\"의 바이트: {:?}", text.as_bytes());
    println!("    text.len(): {} (바이트 수)", text.len());

    // 문자 인덱싱은 불가능!
    // let c = text[0];  // 컴파일 오류! &str은 인덱싱 불가

    println!("    → &str[index]는 컴파일 불가능\n");

    // ─────────────────────────────────────────
    // 4-2. UTF-8 다바이트 문자
    // ─────────────────────────────────────────
    println!("  [4-2] UTF-8 다바이트 문자");

    let text = "Hëllo";  // ë는 2바이트
    println!("    \"{}\"의 바이트 수: {}", text, text.len());
    println!("    바이트: {:?}", text.as_bytes());

    let text2 = "안녕";  // 한글은 각 3바이트
    println!("    \"{}\"의 바이트 수: {}", text2, text2.len());
    println!("    → 문자마다 바이트 수가 다름!\n");

    // ─────────────────────────────────────────
    // 4-3. 안전한 접근: chars()
    // ─────────────────────────────────────────
    println!("  [4-3] 안전한 접근: chars() 이터레이터");

    let text = "Hello, 세계!";
    println!("    문자열: {}", text);
    println!("    chars()로 순회:");

    for (i, ch) in text.chars().enumerate() {
        if i < 5 {  // 처음 5개만
            println!("      [{}]: '{}' (바이트 수: {})", i, ch, ch.len_utf8());
        }
    }
    println!();

    // ─────────────────────────────────────────
    // 4-4. 바이트 접근
    // ─────────────────────────────────────────
    println!("  [4-4] 바이트 접근: bytes()");

    let text = "ABC";
    println!("    \"{}\"의 바이트:", text);
    for (i, byte) in text.bytes().enumerate() {
        println!("      [{}]: {} ('{}')", i, byte, byte as char);
    }
    println!();

    // ─────────────────────────────────────────
    // 4-5. 첫 문자 안전하게 가져오기
    // ─────────────────────────────────────────
    println!("  [4-5] 첫 문자 가져오기");

    fn get_first_char(s: &str) -> Option<char> {
        s.chars().next()
    }

    println!("    get_first_char(\"Hello\"): {:?}", get_first_char("Hello"));
    println!("    get_first_char(\"안녕\"): {:?}", get_first_char("안녕"));
    println!("    get_first_char(\"\"): {:?}\n", get_first_char(""));

    println!("  💡 핵심: 인덱싱 대신 chars()나 bytes()를 사용하세요.\n");
}

// ===================================================================
// Section 5: 함수 인터페이스 설계 - &str의 유연성
// ===================================================================
//
// 매개변수 타입을 &str로 지정하면,
// String과 리터럴 모두를 전달받을 수 있습니다.
//
fn section_5_function_interface() {
    println!("▶ Section 5: 함수 인터페이스 설계");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 5-1. &str 매개변수의 유연성
    // ─────────────────────────────────────────
    println!("  [5-1] &str 매개변수");

    process_message("시스템 시작");                 // 리터럴
    process_message(&String::from("상태 확인"));    // String

    let system_id = String::from("GOGS-Core");
    process_message(&system_id);                   // String의 참조
    println!();

    // ─────────────────────────────────────────
    // 5-2. 잘못된 설계 vs 올바른 설계
    // ─────────────────────────────────────────
    println!("  [5-2] 설계 비교");

    println!("    ❌ 나쁜 설계:");
    println!("      fn log(msg: String) - 리터럴 사용 불가");
    println!("      호출: log(\"msg\".to_string()) - 매번 할당");

    println!("    ✅ 좋은 설계:");
    println!("      fn log(msg: &str) - 리터럴도 String도 가능");
    println!("      호출: log(\"msg\") 또는 log(&string)\n");

    // ─────────────────────────────────────────
    // 5-3. 함수 반환 타입
    // ─────────────────────────────────────────
    println!("  [5-3] 반환 타입");

    fn get_version() -> &'static str {
        "1.0.0"  // 컴파일 타임 상수
    }

    fn create_message() -> String {
        String::from("동적 생성 메시지")
    }

    println!("    get_version(): {}", get_version());
    println!("    create_message(): {}\n", create_message());

    // ─────────────────────────────────────────
    // 5-4. Cow (Clone on Write)
    // ─────────────────────────────────────────
    println!("  [5-4] Cow로 조건부 소유권");

    use std::borrow::Cow;

    fn normalize_path(path: Cow<str>) -> Cow<str> {
        if path.contains("//") {
            Cow::Owned(path.replace("//", "/"))
        } else {
            path
        }
    }

    let literal = normalize_path(Cow::Borrowed("/home//user"));
    println!("    normalize_path: {}", literal);
    println!("    → 필요할 때만 소유권 획득\n");

    println!("  💡 핵심: 매개변수는 &str, 반환이 필요하면 String을 사용합니다.\n");
}

// 지원 함수
fn process_message(msg: &str) {
    println!("    [MSG] {}", msg);
}

// ===================================================================
// Section 6: 문자열 수정과 결합
// ===================================================================
//
// String을 수정하고 여러 문자열을 결합하는 방법들을 배웁니다.
//
fn section_6_string_modification() {
    println!("▶ Section 6: 문자열 수정과 결합");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 6-1. 문자열 추가
    // ─────────────────────────────────────────
    println!("  [6-1] 문자열 추가");

    let mut s = String::from("Hello");
    s.push_str(", ");
    s.push_str("Rust");
    println!("    push_str: {}", s);

    let mut s = String::from("Hello");
    s.push('!');
    println!("    push: {}\n", s);

    // ─────────────────────────────────────────
    // 6-2. format! 매크로 (권장)
    // ─────────────────────────────────────────
    println!("  [6-2] format! 매크로");

    let name = "Rust";
    let version = "1.75";

    let result = format!("Language: {}, Version: {}", name, version);
    println!("    {}", result);

    let result2 = format!("{:?}", vec![1, 2, 3]);
    println!("    Debug 출력: {}\n", result2);

    // ─────────────────────────────────────────
    // 6-3. 이음 (Concatenation) 방법 비교
    // ─────────────────────────────────────────
    println!("  [6-3] 이음 방법 비교");

    // 방법 1: format! (권장)
    let s1 = "Hello".to_string();
    let s2 = "World".to_string();
    let result = format!("{} {}", s1, s2);
    println!("    format!: {}", result);

    // 방법 2: + 연산자
    let s1 = String::from("Hello");
    let s2 = " World";
    let result = s1 + s2;  // s1의 소유권 이동
    println!("    +: {}", result);

    // 방법 3: join
    let parts = vec!["Hello", "Rust", "World"];
    let result = parts.join(" ");
    println!("    join: {}\n", result);

    // ─────────────────────────────────────────
    // 6-4. 문자열 변환 (replace, to_uppercase 등)
    // ─────────────────────────────────────────
    println!("  [6-4] 문자열 변환");

    let text = "Hello, World!";
    println!("    원본: {}", text);
    println!("    replace: {}", text.replace("World", "Rust"));
    println!("    to_uppercase: {}", text.to_uppercase());
    println!("    to_lowercase: {}", text.to_lowercase());
    println!("    trim: '{}'", "  hello  ".trim());
    println!("    split: {:?}\n", text.split(",").collect::<Vec<_>>());

    // ─────────────────────────────────────────
    // 6-5. 반복자 체인
    // ─────────────────────────────────────────
    println!("  [6-5] 반복자로 변환");

    let text = "hello world";
    let result: String = text
        .chars()
        .map(|c| c.to_uppercase().to_string())
        .collect();
    println!("    to_uppercase: {}", result);

    let text = "rust";
    let result: String = text.chars().rev().collect();
    println!("    reverse: {}\n", result);

    println!("  💡 핵심: format!은 가독성 좋고, join은 컬렉션 처리에 효과적입니다.\n");
}

// ===================================================================
// Section 7: 실전 예제 - 텍스트 처리 엔진
// ===================================================================
//
// 텍스트 로그를 처리하는 실제 사례입니다.
//
fn section_7_advanced_real_world() {
    println!("▶ Section 7: 실전 예제 - 텍스트 처리 엔진");
    println!("─────────────────────────────────────────\n");

    // ─────────────────────────────────────────
    // 실전 예제: 로그 분석
    // ─────────────────────────────────────────
    println!("  [예제] 로그 분석 시스템");

    let log_data = vec![
        "[ERROR] Connection timeout",
        "[INFO] Server started",
        "[ERROR] Database error",
        "[WARN] Memory usage high",
        "[INFO] Request processed",
    ];

    // 에러 필터링
    let errors: Vec<&str> = log_data
        .iter()
        .filter(|log| log.contains("[ERROR]"))
        .map(|log| log.trim_start_matches("[ERROR] "))
        .collect();

    println!("    에러 목록:");
    for (i, err) in errors.iter().enumerate() {
        println!("      {}: {}", i + 1, err);
    }
    println!();

    // ─────────────────────────────────────────
    // 실전 예제: 커맨드 파싱
    // ─────────────────────────────────────────
    println!("  [예제] 커맨드 파싱");

    fn parse_command(input: &str) -> (String, Vec<String>) {
        let mut parts = input.split_whitespace();
        let cmd = parts.next().unwrap_or("").to_string();
        let args: Vec<String> = parts.map(|s| s.to_string()).collect();
        (cmd, args)
    }

    let input = "start --port 3000 --debug";
    let (cmd, args) = parse_command(input);
    println!("    명령: {}", cmd);
    println!("    인자: {:?}", args);
    println!();

    // ─────────────────────────────────────────
    // 실전 예제: 텍스트 검색 및 치환
    // ─────────────────────────────────────────
    println!("  [예제] 검색 및 치환");

    struct TextProcessor {
        content: String,
    }

    impl TextProcessor {
        fn new(content: String) -> Self {
            TextProcessor { content }
        }

        fn search(&self, pattern: &str) -> Vec<usize> {
            self.content
                .match_indices(pattern)
                .map(|(i, _)| i)
                .collect()
        }

        fn replace(&mut self, from: &str, to: &str) {
            self.content = self.content.replace(from, to);
        }

        fn word_count(&self) -> usize {
            self.content.split_whitespace().count()
        }
    }

    let mut doc = TextProcessor::new(String::from(
        "Rust is fast. Rust is safe. Rust is productive."
    ));

    println!("    원본: {}", doc.content);
    println!("    'Rust' 위치: {:?}", doc.search("Rust"));
    println!("    단어 수: {}", doc.word_count());

    doc.replace("Rust", "Cargo");
    println!("    치환 후: {}", doc.content);
    println!();

    // ─────────────────────────────────────────
    // 실전 예제: URL 파싱
    // ─────────────────────────────────────────
    println!("  [예제] URL 파싱");

    fn parse_url(url: &str) -> Option<(&str, &str, &str)> {
        if let Some(protocol_end) = url.find("://") {
            let protocol = &url[0..protocol_end];
            let rest = &url[protocol_end + 3..];

            if let Some(path_start) = rest.find("/") {
                let host = &rest[0..path_start];
                let path = &rest[path_start..];
                return Some((protocol, host, path));
            } else {
                return Some((protocol, rest, ""));
            }
        }
        None
    }

    let urls = vec![
        "https://gogs.dclub.kr/kim/projects",
        "http://localhost:3000/api",
        "ftp://files.example.com/data",
    ];

    for url in urls {
        if let Some((proto, host, path)) = parse_url(url) {
            println!("    URL: {}", url);
            println!("      프로토콜: {}", proto);
            println!("      호스트: {}", host);
            println!("      경로: {}", path);
        }
    }
    println!();

    println!("  💡 핵심: &str을 사용하면 메모리 효율적으로 텍스트를 처리할 수 있습니다.\n");
}

