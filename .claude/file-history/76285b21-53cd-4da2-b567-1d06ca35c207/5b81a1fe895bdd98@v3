## Step 2: Parser 확장 (`src/parser.ts`)

### parseAnnotations() 신규 함수

`parseFnStmt()`의 `expect(T.RParen)` (줄 107) 직후에 삽입:

```typescript
function parseAnnotations(): CapabilityAnnotation[] {
  if (!at(T.LBracket)) return []    // [] 없으면 빈 배열
  advance()                          // [
  const annotations: CapabilityAnnotation[] = []

  while (!at(T.RBracket) && !at(T.EOF)) {
    const name = expect(T.Ident).value   // "allow" or "limit"

    if (name === "allow") {
      expect(T.LParen)
      const capName = expect(T.Ident).value as CapabilityKind
      let arg: string | undefined
      if (match(T.LParen)) {             // allow(read_file("/tmp"))
        // 이미 (를 소비, 다음은 문자열 인자
        arg = expect(T.String).value
        expect(T.RParen)
      } else if (match(T.Comma) || at(T.String)) {
        arg = expect(T.String).value     // allow(read_file, "/tmp")
      }
      expect(T.RParen)
      annotations.push({ kind: "allow", cap: capName, arg })

    } else if (name === "limit") {
      expect(T.LParen)
      // limit(cpu=5000, memory=512000000)
      while (!at(T.RParen) && !at(T.EOF)) {
        const res = expect(T.Ident).value as "cpu" | "memory" | "io"
        expect(T.Assign)   // =
        const val = Number(expect(T.Number).value)
        annotations.push({ kind: "limit", resource: res, value: val })
        match(T.Comma)
      }
      expect(T.RParen)
    }

    match(T.Comma)
  }

  expect(T.RBracket)   // ]
  return annotations
}
```

### parseFnStmt 수정

```typescript
// 줄 107 (expect RParen) 직후:
expect(T.RParen)
const annotations = parseAnnotations()    // ← 추가
if (match(T.Arrow)) { ... }               // 기존
// ...
return { kind: "fn", name, params, body, annotations }   // ← annotations 추가
