### 4-3: registerFunctionType() 수정 (줄 66-87)

AST의 annotations에서 capabilities 추출하여 저장:

```typescript
private registerFunctionType(stmt: Stmt): void {
  if (stmt.kind === "fn") {
    const fnStmt = stmt as any

    // 기존 paramTypes, returnType 생성 ...

    // [Phase 6 추가] annotation → capabilities 변환
    const capabilities: Capability[] = (fnStmt.annotations || [])
      .filter((a: any) => a.kind === "allow")
      .map((a: any) => ({ cap: a.cap, arg: a.arg }))

    const fnType: Type = {
      kind: "fn",
      paramTypes,
      returnType,
      capabilities,          // ← 추가
    }
    this.functionTypes.set(fnStmt.name, fnType)
  }
}
```

### 4-4: case "fn" stmt 수정 (줄 105-147)

