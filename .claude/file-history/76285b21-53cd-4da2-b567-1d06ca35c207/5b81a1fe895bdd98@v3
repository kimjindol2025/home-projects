export type CapabilityKind =
  | "read_file"
  | "write_file"
  | "network"
  | "spawn_process"
  | "execute_code"

// Capability 선언 (allow/limit)
export type CapabilityAnnotation =
  | { kind: "allow"; cap: CapabilityKind; arg?: string }
  | { kind: "limit"; resource: "cpu" | "memory" | "io"; value: number }

// 내장 함수 Required Capability
