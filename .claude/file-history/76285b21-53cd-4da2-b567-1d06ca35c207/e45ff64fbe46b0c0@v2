#!/bin/bash
cd /data/data/com.termux/files/home/freelang-agent-gogs/freelang-core

echo "════════════════════════════════════════════════════════════════════"
echo "  🚀 FreeLang v6 — 전체 테스트 스위트 실행"
echo "════════════════════════════════════════════════════════════════════"
echo ""

tests=(
  "vm-capability-test.js"
  "vm-function-types-test.js"
  "vm-typed-arithmetic-test.js"
  "vm-types-test.js"
  "vm-inference-test.js"
  "vm-optimizer-test.js"
  "vm-gc-test.js"
  "vm-compatibility-test.js"
  "vm-heap-validation.js"
)

total_pass=0
total_fail=0

for test in "${tests[@]}"; do
  if [ -f "dist/$test" ]; then
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "📊 Running: $test"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    
    output=$(node "dist/$test" 2>&1)
    echo "$output"
    
    # Count passes and fails
    passes=$(echo "$output" | grep -o "✓" | wc -l)
    fails=$(echo "$output" | grep -o "✗" | wc -l)
    
    total_pass=$((total_pass + passes))
    total_fail=$((total_fail + fails))
    
    echo ""
  fi
done

echo "════════════════════════════════════════════════════════════════════"
echo "  📈 최종 통계"
echo "════════════════════════════════════════════════════════════════════"
echo ""
echo "✅ 총 통과: $total_pass"
echo "❌ 총 실패: $total_fail"
echo ""

if [ $total_fail -eq 0 ]; then
  echo "🎉 모든 테스트 통과! (100%)"
else
  echo "⚠️  $total_fail 개 테스트 실패"
fi

echo ""
echo "════════════════════════════════════════════════════════════════════"
