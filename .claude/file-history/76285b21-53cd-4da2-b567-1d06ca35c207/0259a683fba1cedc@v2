// Phase 5.5.4: Full Generic (TypeVar) Type System (15개)

import { TypeChecker } from "./type-checker";
import { parse } from "./parser";
import { lex } from "./lexer";

function checkTypes(code: string) {
  const tokens = lex(code);
  const program = parse(tokens);
  const checker = new TypeChecker();
  return checker.check(program);
}

function test(name: string, fn: () => void) {
  try {
    fn();
    console.log(`✓ ${name}`);
  } catch (e) {
    console.log(`✗ ${name}`);
    if (e instanceof Error) {
      console.log(`  Error: ${e.message}`);
    }
  }
}

function assert(condition: boolean, message: string) {
  if (!condition) throw new Error(message);
}

console.log("\n🧪 Suite A: 제네릭 함수 정의 (5개)");
console.log("═══════════════════════════════════════════════════════════");

test("TEST A-1: fn identity<T>(x: T) { x } 정의 → 컴파일 성공", () => {
  const result = checkTypes(`
    fn identity<T>(x: T) {
      return x;
    }
  `);
  assert(result.success, "제네릭 함수 정의 성공");
});

test("TEST A-2: fn pair<A, B>(a: A, b: B) { a } 다중 TypeVar → 성공", () => {
  const result = checkTypes(`
    fn pair<A, B>(a: A, b: B) {
      return a;
    }
  `);
  assert(result.success, "다중 TypeVar 정의 성공");
});

test("TEST A-3: 단일 대문자 TypeVar T 파싱 확인", () => {
  const result = checkTypes(`
    fn single<T>(x: T) {
      return x;
    }
    let z = single(42);
  `);
  assert(result.success, "T 파싱 확인");
});

test("TEST A-4: 다중 TypeVar 선언 <T, U, V> 확인", () => {
  const result = checkTypes(`
    fn triple<T, U, V>(x: T, y: U, z: V) {
      return x;
    }
  `);
  assert(result.success, "다중 TypeVar 선언 확인");
});

test("TEST A-5: typeParams 없는 일반 함수 → 호환성 유지", () => {
  const result = checkTypes(`
    fn normal(x, y) {
      return x + y;
    }
    let z = normal(10, 20);
  `);
  assert(result.success, "기존 함수 형식 호환성");
});

console.log("\n🧪 Suite B: 호출 시 타입 인스턴스화 (5개)");
console.log("═══════════════════════════════════════════════════════════");

test("TEST B-6: identity(42) → num 타입 반환 추론", () => {
  const result = checkTypes(`
    fn identity<T>(x: T) {
      return x;
    }
    let n = identity(42);
  `);
  assert(result.success, "num 타입 반환");
});

test("TEST B-7: identity(\"hi\") → str 타입 반환 추론", () => {
  const result = checkTypes(`
    fn identity<T>(x: T) {
      return x;
    }
    let s = identity("hello");
  `);
  assert(result.success, "str 타입 반환");
});

test("TEST B-8: identity(42) + identity(\"hi\") 연속 호출 → 모두 성공", () => {
  const result = checkTypes(`
    fn identity<T>(x: T) {
      return x;
    }
    let n = identity(42);
    let s = identity("world");
  `);
  assert(result.success, "연속 호출 성공");
});

test("TEST B-9: 어노테이션 없는 fn → UNKNOWN 기존 동작 유지", () => {
  const result = checkTypes(`
    fn untyped(x) {
      return x;
    }
    let z = untyped(100);
  `);
  assert(result.success, "UNKNOWN 처리");
});

test("TEST B-10: typeParams 없는 fn 호출 → substitution 없이 정상", () => {
  const result = checkTypes(`
    fn add(a: num, b: num) {
      return a + b;
    }
    let z = add(10, 20);
  `);
  assert(result.success, "typeParams 없는 호출");
});

console.log("\n🧪 Suite C: 통합 & 호환성 (5개)");
console.log("═══════════════════════════════════════════════════════════");

test("TEST C-11: 기존 177개 테스트 패턴 호환성 유지", () => {
  const result = checkTypes(`
    fn add(a, b) { a + b }
    fn mul(x, y) { x * y }
    print(add(10, mul(3, 4)));
  `);
  assert(result.success, "기존 패턴 호환성");
});

test("TEST C-12: fn swap<A, B>(a: A, b: B) → 각각 TypeVar 바인딩", () => {
  const result = checkTypes(`
    fn swap<A, B>(a: A, b: B) {
      return b;
    }
    let x = swap(42, "hello");
  `);
  assert(result.success, "TypeVar 각각 바인딩");
});

test("TEST C-13: 제네릭 + num 어노테이션 혼합 fn", () => {
  const result = checkTypes(`
    fn process<T>(value: num, data: T) {
      return data;
    }
    let result = process(10, "mixed");
  `);
  assert(result.success, "혼합 어노테이션");
});

test("TEST C-14: 빈 body 제네릭 fn → null 반환", () => {
  const result = checkTypes(`
    fn empty<T>(x: T) {
    }
    let z = empty(42);
  `);
  assert(result.success, "빈 body 제네릭");
});

test("TEST C-15: end-to-end: 제네릭 선언 + 호출 + 타입 전파", () => {
  const result = checkTypes(`
    fn process<T>(input: T) {
      let doubled = input;
      return doubled;
    }
    let final = process(5);
  `);
  assert(result.success, "end-to-end 제네릭");
});

