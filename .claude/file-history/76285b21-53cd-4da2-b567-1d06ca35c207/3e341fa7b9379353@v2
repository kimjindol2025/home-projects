test("TEST B-6: 권한 없이 readData() 호출 → 에러", () => {
  const code = `
    fn readData() [allow(read_file("/tmp"))] {
      let x = 42
    }

    fn main() {
      readData()
    }
  `
  const result = checkTypes(code)
  // main()은 read_file capability가 없으므로 readData() 호출 불가 → 에러
  assert(!result.success, "capability 검증 실패 (에러 있어야 함)")
  assert(result.errors.length > 0, "에러 메시지 없음")
})

test("TEST B-7: 권한 있는 함수 호출 → 통과", () => {
  const code = `
    fn readData() [allow(read_file("/tmp"))] {
      let x = 42
    }

    fn main() [allow(read_file("/tmp"))] {
      readData()
    }
  `
  const result = checkTypes(code)
  assert(result.success, "capability 검증 실패 (통과해야 함)")
})

test("TEST B-8: Strict Propagation - caller도 선언 필요 → 에러", () => {
  const code = `
    fn writeFile() [allow(write_file("/etc"))] {
      let x = 1
    }

    fn deploy() [allow(read_file("/home"))] {
      writeFile()
    }
  `
  const result = checkTypes(code)
  // deploy는 read_file만 선언했는데 write_file을 요구하는 함수 호출 → 에러
  assert(!result.success, "Strict Propagation 검증 실패")
})

test("TEST B-9: 중첩 함수 독립 컨텍스트 → 외부 권한 영향 없음", () => {
  const code = `
    fn outer() [allow(read_file("/home"))] {
      fn inner() [allow(write_file("/tmp"))] {
        let x = 1
      }
    }

    fn main() {
      outer()
    }
  `
  const result = checkTypes(code)
  // main은 아무 capability도 없으므로 outer 호출 불가 → 에러
  assert(!result.success, "중첩 함수도 capability 전파되어야 함")
})

test("TEST B-10: Path escape \"..\" 포함 → 에러", () => {
  const code = `
    fn readSecure() [allow(read_file("/tmp"))] {
      let x = 42
    }

    fn exploit() [allow(read_file("/tmp/../etc"))] {
      readSecure()
