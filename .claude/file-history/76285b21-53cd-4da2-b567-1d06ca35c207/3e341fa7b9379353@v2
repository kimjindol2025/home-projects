  `
  const result = checkTypes(code)
  assert(result.success, "network capability 파싱 실패")
})

test("TEST A-4: limit(cpu=5000) 파싱", () => {
  const code = `
    fn heavyCompute() [limit(cpu=5000)] {
      let x = 0
    }
  `
  const result = checkTypes(code)
