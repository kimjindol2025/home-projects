test("TEST A-1: annotation 없는 함수 → capabilities: []", () => {
  const code = `
    fn greet(name) {
      print(name);
    }
  `
  const result = checkTypes(code)
  assert(result.success, "타입 체크 실패")
  // annotation이 없으면 빈 배열이어야 함
})

test("TEST A-2: allow(read_file(\"/tmp\")) 파싱 → cap: read_file, arg: /tmp", () => {
  const code = `
    fn readTemp() [allow(read_file("/tmp"))] {
      let x = 42
    }
  `
  const result = checkTypes(code)
  assert(result.success, "capability 파싱 실패")
})

test("TEST A-3: allow(network(\"api.openai.com\")) 파싱", () => {
