test("TEST C-11: annotation 없는 재귀 함수 → 정상", () => {
  const code = `
    fn fib(n) {
      if n <= 1 { n } else { fib(n - 1) + fib(n - 2) }
    }
    print(fib(7));
  `;
  const result = run(code);
  assert(result.includes("13"), "annotation 없으면 제한 없음");
});

test("TEST C-12: 다중 호출에서 capabilities 일관성", () => {
  const code = `
    fn readFileA() [allow(read_file("/home"))] {
      "a";
    }
    fn readFileB() [allow(read_file("/tmp"))] {
      "b";
    }
    print(readFileA());
    print(readFileB());
  `;
  const result = run(code);
  assert(result === "ab", "각 함수 capability 독립");
});

test("TEST C-13: 기존 132개 테스트 호환성 유지", () => {
  const code = `
    fn add(a, b) { a + b }
    fn mul(x, y) { x * y }
    print(add(10, mul(3, 4)));
  `;
  const result = run(code);
  assertEqual(result, "22", "기존 기능 정상");
});

test("TEST C-14: network wildcard 패턴 매칭", () => {
  const code = `
    fn api() [allow(network("*.api.example.com"))] {
      http_get("https://v1.api.example.com/data");
    }
    print(api());
  `;
  const result = run(code);
  assert(result.includes("HTTP GET stub"), "wildcard 패턴 매칭");
});

test("TEST C-15: end-to-end 전체 capability 시스템 통합", () => {
  const code = `
    fn process() [allow(read_file("/data")), limit(cpu=50)] {
      let result = "processed";
      print(result);
    }
    process();
  `;
  const result = run(code);
  assertEqual(result, "processed", "capability + limit 통합");
});

function assertEqual(actual: string, expected: string, message: string) {
  if (actual !== expected) {
    throw new Error(`${message}: expected "${expected}", got "${actual}"`);
  }
}

