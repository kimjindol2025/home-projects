// Phase 6.4: VM Integration Tests (15개)

import { compile } from "./compiler";
import { VM } from "./vm";
import { lex } from "./lexer";
import { parse } from "./parser";

function run(code: string): string {
  try {
    const tokens = lex(code);
    const program = parse(tokens);
    const chunk = compile(program);
    const vm = new VM(chunk);
    const { output } = vm.run();
    return output.join("");
  } catch (e) {
    if (e instanceof Error) {
      return `ERROR: ${e.message}`;
    }
    return `ERROR: ${e}`;
  }
}

function test(name: string, fn: () => void) {
  try {
    fn();
    console.log(`✓ ${name}`);
  } catch (e) {
    console.log(`✗ ${name}`);
    if (e instanceof Error) {
      console.log(`  Error: ${e.message}`);
    }
  }
}

function assert(condition: boolean, message: string) {
  if (!condition) throw new Error(message);
}

function assertContains(actual: string, substring: string, message: string) {
  if (!actual.includes(substring)) {
    throw new Error(`${message}: expected to contain "${substring}", got "${actual}"`);
  }
}

console.log("\n🧪 Suite A: Path/Network Runtime Check (5개)");
console.log("═══════════════════════════════════════════════════════════");

test("TEST A-1: file_read에 '..' 포함 경로 → CapabilityError", () => {
  const code = `
    fn readFile() [allow(read_file("/tmp"))] {
      file_read("../etc/passwd");
    }
    readFile();
  `;
  const result = run(code);
  assertContains(result, "CapabilityError", "path traversal 차단");
});

test("TEST A-2: file_read에 허용 경로 prefix → 정상", () => {
  const code = `
    fn readFile() [allow(read_file("/tmp"))] {
      "safe";
    }
    print(readFile());
  `;
  const result = run(code);
  assert(result.includes("safe"), "권한 있는 경로는 정상");
});

test("TEST A-3: file_read에 비허용 경로 → CapabilityError", () => {
  const code = `
    fn readFile() [allow(read_file("/tmp"))] {
      file_read("/etc/shadow");
    }
    readFile();
  `;
  const result = run(code);
  assertContains(result, "CapabilityError", "비허용 경로 거부");
});

test("TEST A-4: http_get에 허용 도메인 → 정상", () => {
  const code = `
