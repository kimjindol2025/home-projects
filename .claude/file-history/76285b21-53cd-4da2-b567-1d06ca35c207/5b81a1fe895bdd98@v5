### 3-4: execOp() 첫 부분에서 CPU 체크

```typescript
private execOp(op: number): void {
  // Phase 6.4: Resource limit 체크 (CPU + Memory + IO)
  if (this.frames.length > 0) {
    const frame = this.frames[this.frames.length - 1];
    frame.opCount++;

    // CPU: opcode 실행 횟수로 측정
    if (frame.resourceLimits.cpu && frame.opCount > frame.resourceLimits.cpu) {
      this.runtimeError(
        `[ResourceLimitError] CPU limit exceeded (${frame.resourceLimits.cpu} ops)`
      );
    }

    // Memory: heapManager.allocated로 측정 (값 단위)
    if (frame.resourceLimits.memory) {
      const heapUsed = this.heapManager.getAllocated();
      if (heapUsed > frame.resourceLimits.memory) {
        this.runtimeError(
          `[ResourceLimitError] Memory limit exceeded (${frame.resourceLimits.memory} slots)`
        );
      }
    }
  }
  // ... 기존 switch(op) ...
}
```

