### 1-2: checkBuiltinCapability() 시그니처 변경

```typescript
private checkBuiltinCapability(builtinName: string, args: Value[] = []): void {
  const required = this.BUILTIN_REQUIRED_CAPABILITIES.get(builtinName);
  if (!required) return;

  const caps = this.getCurrentCapabilities();
  const hasCapability = caps.some(c => c.cap === required);

  if (!hasCapability) {
    this.runtimeError(
      `[CapabilityError] '${builtinName}' requires capability '${required}', ` +
      `but current function does not declare it`
    );
  }

  // Phase 6.4: Path/Network 상세 검증
  if (required === "read_file" || required === "write_file") {
    const pathArg = args[0]?.tag === "str" ? args[0].val : null;
    if (pathArg !== null) {
      const allowedCaps = caps.filter(c => c.cap === required);
      const allowed = allowedCaps.some(c => !c.arg || this.pathIsUnder(pathArg, c.arg));
      if (!allowed) {
        const allowedPaths = allowedCaps.map(c => c.arg ?? "*").join(", ");
        this.runtimeError(
          `[CapabilityError] Access to '${pathArg}' denied. ` +
          `Allowed paths: [${allowedPaths}]`
        );
      }
    }
  }

  if (required === "network") {
    const urlArg = args[0]?.tag === "str" ? args[0].val : null;
    if (urlArg !== null) {
      const domain = this.extractDomain(urlArg);
      const allowedCaps = caps.filter(c => c.cap === "network");
      const allowed = allowedCaps.some(c => !c.arg || this.hostMatches(domain, c.arg));
      if (!allowed) {
        const allowedHosts = allowedCaps.map(c => c.arg ?? "*").join(", ");
        this.runtimeError(
          `[CapabilityError] Network access to '${domain}' denied. ` +
          `Allowed hosts: [${allowedHosts}]`
        );
      }
    }
  }
}
```

### 1-3: 헬퍼 메서드 추가

```typescript
private pathIsUnder(target: string, allowedPrefix: string): boolean {
  if (target.includes("..")) return false;  // path traversal 즉시 거부
  const normalize = (p: string) => p.replace(/\/+/g, "/").replace(/\/$/, "");
  const t = normalize(target);
  const p = normalize(allowedPrefix);
  return t === p || t.startsWith(p + "/");
}

private extractDomain(url: string): string {
  try {
    // "https://api.openai.com/v1/chat" → "api.openai.com"
    const match = url.match(/^(?:https?:\/\/)?([^\/\?#:]+)/);
    return match ? match[1] : url;
  } catch {
    return url;
  }
}

private hostMatches(target: string, pattern: string): boolean {
  if (pattern === target) return true;
  if (pattern.startsWith("*.")) {
    const base = pattern.slice(2);
    return target.endsWith("." + base) &&
           !target.slice(0, -base.length - 1).includes(".");
  }
  return false;
}
```

