## Step 2: parser.ts — 타입 어노테이션 수집

### 2-1: Import에 Param 추가

```typescript
import { Expr, Stmt, Program, MatchArm, Param } from "./ast";
```

### 2-2: parseParams() 함수 변경 (Line 671-691)

```typescript
function parseParams(): Param[] {
  const params: Param[] = [];
  while (!at(T.RParen) && !at(T.EOF)) {
    const paramName = expect(T.Ident, "Expected parameter name").value;
    let typeAnnotation: string | undefined;
    // Phase 5.5.3: 타입 어노테이션 수집 (버리지 않고 저장)
    if (match(T.Colon)) {
      const typeParts: string[] = [];
      let depth = 0;
      while (!at(T.Comma) && !at(T.RParen) && !at(T.EOF)) {
        const tok = advance();
        if (tok.type === T.LBracket) depth++;
        if (tok.type === T.RBracket) depth--;
        if (depth < 0) break;
        typeParts.push(tok.value);
      }
      typeAnnotation = typeParts.join("").toLowerCase();
    }
    params.push({ name: paramName, typeAnnotation });
    match(T.Comma);
  }
  return params;
}
```

