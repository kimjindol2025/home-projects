    fn add(a, b) {
      a + b
    }
    print(add(10, 20));
  `;
  const result = run(code);
  assertEqual(result, "30", "annotation 없는 기존 코드 정상");
});

test("TEST C-12: 기존 산술 연산 정상", () => {
  const code = `
    let x = 10;
    let y = 20;
    print(x + y);
    print(x * y);
    print(y - x);
  `;
  const result = run(code);
  assert(result.includes("30"), "add 결과");
  assert(result.includes("200"), "mul 결과");
  assert(result.includes("10"), "sub 결과");
});

test("TEST C-13: 재귀 함수 capability 자기 참조", () => {
  const code = `
    fn fib(n) [allow(execute_code("fib"))] {
      if n <= 1 {
        n
      } else {
        fib(n - 1) + fib(n - 2)
      }
    }
    print(fib(5));
  `;
  const result = run(code);
  assertEqual(result, "5", "재귀 함수 capability 자체 참조 정상");
});

test("TEST C-14: CapabilityError는 RuntimeError 형태로 발생", () => {
  const code = `
    fn test() {
      file_read("test.txt");
    }
    test();
  `;
  const result = run(code);
  assertContains(result, "ERROR", "CapabilityError가 발생");
  assertContains(result, "CapabilityError", "CapabilityError 명시");
});

test("TEST C-15: 전체 기존 테스트 호환성 유지", () => {
  const code = `
    fn multiply(x, y) {
      x * y
    }
    let result = multiply(7, 8);
    print(result);
    print(result > 50);
  `;
  const result = run(code);
  assertEqual(result, "56true", "기존 기능 모두 정상");
});

