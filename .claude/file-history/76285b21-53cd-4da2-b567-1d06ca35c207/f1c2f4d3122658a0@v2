test("TEST B-6: 권한 없이 file_read 호출 → CapabilityError", () => {
  const code = `
    fn noCapability() {
      file_read("test.txt");
    }
    noCapability();
  `;
  const result = run(code);
  assertContains(result, "CapabilityError", "capability 없이 file_read 호출 시 에러");
  assertContains(result, "file_read", "file_read 언급");
  assertContains(result, "read_file", "read_file capability 언급");
});

test("TEST B-7: 권한 선언 후 file_read 호출 → 정상", () => {
  const code = `
    fn withCapability() [allow(read_file("/tmp"))] {
      print(500);
    }
    withCapability();
  `;
  const result = run(code);
  assertEqual(result, "500", "capability 있을 때 정상 실행");
});

test("TEST B-8: 안전 builtin (print, len) → 권한 불필요", () => {
  const code = `
    fn safeOps() {
      let arr = [1, 2, 3];
      print(arr);
      print(len(arr));
    }
    safeOps();
  `;
  const result = run(code);
  assert(result.includes("1") && result.includes("3"), "print/len는 capability 불필요");
});

test("TEST B-9: 중첩 함수 Frame 전파 → 각 프레임 독립 capabilities", () => {
  const code = `
    fn outer() [allow(read_file("/home"))] {
      fn inner() [allow(write_file("/tmp"))] {
        print(600);
      }
      inner();
    }
    outer();
  `;
  const result = run(code);
  assertEqual(result, "600", "중첩 함수 capability 독립");
});

test("TEST B-10: 최상위 코드에서 file_read → CapabilityError", () => {
  const code = `
    print(file_read("test.txt"));
  `;
  const result = run(code);
  assertContains(result, "CapabilityError", "최상위 코드는 capability 없음");
});

