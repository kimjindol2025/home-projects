test("TEST A-1: annotation 없는 fn → capabilities: []", () => {
  const code = `
    fn greet() {
      print(42);
    }
    greet();
  `;
  const result = run(code);
  assertEqual(result, "42", "함수 정상 실행");
});

test("TEST A-2: allow(read_file(\"/tmp\")) → 임베딩 확인", () => {
  const code = `
    fn readData() [allow(read_file("/tmp"))] {
      print(100);
    }
    readData();
  `;
  const result = run(code);
  assertEqual(result, "100", "capability 있는 함수 정상 실행");
});

test("TEST A-3: allow(network(\"api.openai.com\")) → 임베딩 확인", () => {
  const code = `
    fn callAPI() [allow(network("api.openai.com"))] {
      print(200);
    }
    callAPI();
  `;
  const result = run(code);
  assertEqual(result, "200", "network capability 함수 정상 실행");
});

test("TEST A-4: 다중 annotation → capabilities 배열", () => {
  const code = `
    fn multiCap() [allow(read_file("/home")), allow(write_file("/tmp"))] {
      print(300);
    }
    multiCap();
  `;
  const result = run(code);
  assertEqual(result, "300", "다중 capability 함수 정상 실행");
});

test("TEST A-5: limit(cpu=5000) → capabilities에 미포함", () => {
  const code = `
    fn limitCPU() [limit(cpu=5000)] {
      print(400);
    }
    limitCPU();
  `;
  const result = run(code);
  assertEqual(result, "400", "limit annotation은 capabilities에 미포함");
});

