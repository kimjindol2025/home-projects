test("TEST 1: num 반환 함수 → returnType = num 추론", () => {
  const result = checkTypes(`
    fn getNumber() {
      return 42
    }
  `)
  assert(result.success, "타입 체크 실패")
  const fnType = (result as any).checker?.getFunctionType?.("getNumber")
  // 더 직접적으로 함수 타입 검증
  const code = `
    fn test() {
      return 100
    }
    let x = test()
  `
  const result2 = checkTypes(code)
  assert(result2.success, "num 반환 함수 호출 실패")
})

