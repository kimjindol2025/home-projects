// Phase 5.5.3: Parameter Type Inference (15개)

import { TypeChecker } from "./type-checker";
import { parse } from "./parser";
import { lex } from "./lexer";

function checkTypes(code: string) {
  const tokens = lex(code);
  const program = parse(tokens);
  const checker = new TypeChecker();
  return checker.check(program);
}

function test(name: string, fn: () => void) {
  try {
    fn();
    console.log(`✓ ${name}`);
  } catch (e) {
    console.log(`✗ ${name}`);
    if (e instanceof Error) {
      console.log(`  Error: ${e.message}`);
    }
  }
}

function assert(condition: boolean, message: string) {
  if (!condition) throw new Error(message);
}

console.log("\n🧪 Suite A: 명시적 파라미터 타입 어노테이션 (5개)");
console.log("═══════════════════════════════════════════════════════════");

test("TEST A-1: fn add(a: num, b: num) → num 인자 통과", () => {
  const result = checkTypes(`
    fn add(a: num, b: num) {
      return a + b;
    }
    let z = add(10, 20);
  `);
  assert(result.success, "타입 검증 통과");
});

test("TEST A-2: num 파라미터에 str 인자 전달 → TypeError", () => {
  const result = checkTypes(`
    fn add(a: num, b: num) {
      return a + b;
    }
    let z = add("hello", 1);
  `);
  assert(!result.success, "타입 불일치 에러 감지");
  assert(result.errors.length > 0, "에러 메시지 생성");
  assert(result.errors.some(e => e.message.includes("str") || e.message.includes("parameter")),
         "str 타입 관련 에러");
});

test("TEST A-3: str 파라미터에 str 인자 → 정상", () => {
  const result = checkTypes(`
    fn greet(name: str) {
      return "Hello " + name;
    }
    let msg = greet("Alice");
  `);
  assert(result.success, "str 타입 일치 통과");
});

test("TEST A-4: bool 파라미터에 true 전달 → 정상", () => {
  const result = checkTypes(`
    fn toggle(flag: bool) {
      return !flag;
    }
    let result = toggle(true);
  `);
  assert(result.success, "bool 타입 일치 통과");
});

test("TEST A-5: 어노테이션 파라미터 + 반환 타입 추론 연계", () => {
  const result = checkTypes(`
    fn mul(x: num, y: num) {
      return x * y;
    }
    fn square(n: num) {
      return mul(n, n);
    }
    let result = square(5);
  `);
  assert(result.success, "파라미터 타입 + 반환 타입 추론 연계");
});

console.log("\n🧪 Suite B: 후방 호환성 (5개)");
console.log("═══════════════════════════════════════════════════════════");

test("TEST B-6: 어노테이션 없는 파라미터 → UNKNOWN (기존 동작 유지)", () => {
  const result = checkTypes(`
    fn add(a, b) {
      return a + b;
    }
    let z = add(10, 20);
  `);
  assert(result.success, "어노테이션 없으면 UNKNOWN으로 처리");
});

test("TEST B-7: 기존 fn add(a, b) 형식 → 정상 동작", () => {
  const result = checkTypes(`
    fn multiply(x, y) {
      return x * y;
    }
    print(multiply(3, 4));
  `);
  assert(result.success, "기존 형식 호환성");
});

test("TEST B-8: 재귀 함수 파라미터 → UNKNOWN 허용", () => {
  const result = checkTypes(`
    fn fib(n) {
      if (n <= 1) { n } else { fib(n - 1) + fib(n - 2) }
    }
    print(fib(7));
  `);
  assert(result.success, "재귀 함수도 UNKNOWN으로 처리");
});

test("TEST B-9: fn 표현식 (람다) 파라미터 → UNKNOWN 허용", () => {
  const result = checkTypes(`
    let double = (x) => x * 2;
  `);
  // 람다 표현식만 정의하면 사용 기반 타입 추론은 아직 구현되지 않으므로 UNKNOWN으로 처리됨
  assert(result.success, "람다 표현식 파라미터 정의");
});

test("TEST B-10: 일부만 어노테이션 → 어노테이션 있는 것만 검증", () => {
  const result = checkTypes(`
    fn mixed(a: num, b) {
      return a + b;
    }
    let z = mixed(10, 20);
  `);
  assert(result.success, "a는 num으로 검증, b는 UNKNOWN");
});

console.log("\n🧪 Suite C: 통합 (5개)");
console.log("═══════════════════════════════════════════════════════════");

test("TEST C-11: 기존 147개 테스트 호환성 유지", () => {
  const result = checkTypes(`
    fn add(a, b) { a + b }
    fn mul(x, y) { x * y }
    print(add(10, mul(3, 4)));
  `);
  assert(result.success, "기존 코드 정상 동작");
});

test("TEST C-12: 어노테이션 파라미터 + 다중 인자 검증", () => {
  const result = checkTypes(`
    fn concat(a: str, b: str, c: str) {
      return a + b + c;
    }
    let result = concat("A", "B", "C");
  `);
  assert(result.success, "다중 파라미터 타입 검증");
});

test("TEST C-13: 상호 함수 호출에서 파라미터 타입 검증", () => {
  const result = checkTypes(`
    fn isPositive(value: num) {
      return value > 0;
    }
    fn checkNumber(num: num) {
      return isPositive(num);
    }
    let result = checkNumber(42);
  `);
  // 함수 간 호출에서 타입 검증이 정상 작동
  assert(result.success, "함수 간 타입 검증");
});

test("TEST C-14: num 파라미터에 num 표현식 인자 → 정상", () => {
  const result = checkTypes(`
    fn process(value: num) {
      return value * 2;
    }
    let x = 5;
    let y = 10;
    let result = process(x + y);
  `);
  assert(result.success, "표현식 인자 타입 호환성");
});

test("TEST C-15: end-to-end: fn 선언 + 호출 + 반환 타입 추론 연계", () => {
  const result = checkTypes(`
    fn process(input: num) {
      let doubled = input * 2;
      let squared = doubled * doubled;
      return squared;
    }
    let final = process(5);
  `);
  assert(result.success, "파라미터 타입 + 본문 처리 + 반환 타입 전체 연계");
});

