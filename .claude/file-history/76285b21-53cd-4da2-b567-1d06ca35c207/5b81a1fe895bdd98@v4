## Step 2: vm.ts — Frame에 capabilities + builtin 검사

### 2-1: Frame 타입 수정
```typescript
type Frame = {
  retAddr: number; baseSlot: number; fn: string; upvalues: Value[];
  capabilities: Array<{cap: string; arg?: string}>  // ← 추가
}
```

### 2-2: Op.Call에서 capabilities Frame에 전달
```typescript
case Op.Call: {
  if (callee.tag === "fn") {
    this.frames.push({
      ...,
      capabilities: callee.capabilities || []   // ← 추가
    });
  } else if (callee.tag === "builtin") {
    this.checkBuiltinCapability(callee.name);   // ← 검사 후 실행
    // ...builtin 실행 로직...
  }
}
```

### 2-3: BUILTIN_REQUIRED_CAPABILITIES + 검사 메서드

```typescript
// 클래스 필드
private readonly BUILTIN_REQUIRED_CAPABILITIES = new Map([
  ["file_read", "read_file"], ["file_write", "write_file"],
  ["http_request", "network"], ["http_get", "network"],
  ["process_spawn", "spawn_process"], ["eval", "execute_code"],
])

// 메서드
private checkBuiltinCapability(name: string): void {
  const required = this.BUILTIN_REQUIRED_CAPABILITIES.get(name)
  if (!required) return  // print, len 등 안전 builtin은 통과
  const caps = this.getCurrentCapabilities()
  if (!caps.some(c => c.cap === required)) {
    this.runtimeError(`[CapabilityError] '${name}' requires '${required}', not declared`)
  }
}

private getCurrentCapabilities() {
  return this.frames.length ? this.frames[this.frames.length - 1].capabilities : []
}
```

