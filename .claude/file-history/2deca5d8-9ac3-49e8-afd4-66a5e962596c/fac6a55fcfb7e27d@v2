/// ============================================================================
/// Section 2: 정수 연산 실행
/// ============================================================================
fn section_2_integer_arithmetic() {
    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
    println!("Section 2: 정수 연산 실행 - 5 + 3");
    println!("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n");

    let program = Program::new(vec![Statement::Expression(Expression::Infix(
        "+".to_string(),
        Box::new(Expression::Integer(5)),
        Box::new(Expression::Integer(3)),
    ))]);

    match compile_and_run(&program) {
        Ok(val) => {
            println!("🧮 5 + 3 = {}\n", val);
            assert_eq!(val, Value::Int(8));
        }
        Err(e) => println!("❌ Error: {}\n", e),
    }
}

