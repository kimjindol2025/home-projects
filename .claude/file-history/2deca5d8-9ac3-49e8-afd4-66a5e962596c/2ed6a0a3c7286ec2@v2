## VM 실행 흐름

### 단계별 실행

```rust
pub fn run(&mut self) -> Result<Value, String> {
    // 1. IP 초기화
    self.ip = 0;

    // 2. 바이트코드 순회
    while self.ip < self.bytecode.instructions.len() {
        // 3. OpCode 읽기
        let op_byte = self.bytecode.instructions[self.ip];
        self.ip += 1;

        let op = OpCode::from_byte(op_byte)?;

        // 4. OpCode 실행
        match op {
            OpCode::OpConstant => {
                let idx = self.read_u16() as usize;
                let val = self.bytecode.get_constant(idx)?;
                self.stack.push(Value::Int(val));
            }
            OpCode::OpAdd => {
                let right = self.stack_pop()?;
                let left = self.stack_pop()?;
                self.stack.push(Value::Int(left + right));
            }
            OpCode::OpJump => {
                let target = self.read_u16() as usize;
                self.ip = target;  // ← IP 덮어씀!
            }
            ...
        }
    }

    // 5. 최종 결과
    self.stack_pop()
}
```

