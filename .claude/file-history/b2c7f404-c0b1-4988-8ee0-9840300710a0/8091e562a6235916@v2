### 5가지 Adaptive Attack Injectors

#### Attack 1: RMC (Reconnecting Malicious Client)
```python
def inject_rmc_attack(gradients: List[Gradient],
                      client_ids: List[str],
                      round_num: int,
                      quarantined_clients: Set[str],
                      release_rounds: Dict[str, int],
                      reconnect_probability: float = 0.8) -> Tuple[List[Gradient], Set[str]]:
    """
    RMC: Quarantined client attempts rejoining after 3~5 rounds
    Strategy: Use modified gradient (flip ratio +5~10%) to evade re-detection

    AIOps Impact: Peak-time re-infiltration, sustained alert fatigue
    """
    poisoned_grads = gradients.copy()
    active_rmc_clients = set()

    for i, client_id in enumerate(client_ids):
        if client_id in quarantined_clients:
            release_round = release_rounds.get(client_id, float('inf'))
            if round_num >= release_round and random.random() < reconnect_probability:
                # Rejoin + modify gradient slightly
                active_rmc_clients.add(client_id)
                perturbation = 1.0 + random.uniform(0.05, 0.1)
                poisoned_grads[i] = [g * perturbation for g in gradients[i]]

    return poisoned_grads, active_rmc_clients
```

#### Attack 2: Delayed Poisoning
```python
def inject_delayed_poisoning(gradients: List[Gradient],
                            client_ids: List[str],
                            malicious_clients: Set[str],
                            round_num: int,
                            trigger_round: int = 100,
                            poison_type: str = "label_flip") -> List[Gradient]:
    """
    Delayed Poisoning: Honest behavior → trigger_round → attack starts

    Phases:
      - Round 1~trigger-1: All honest gradients
      - Round trigger+: Start poisoning (label flip or sign flip)

    AIOps Impact: Undetected drift during normal operation, sudden failure

    Args:
        poison_type: "label_flip" or "sign_flip"
    """
    poisoned_grads = gradients.copy()

    if round_num >= trigger_round:
        for client_id in malicious_clients:
            try:
                idx = client_ids.index(client_id)
            except ValueError:
                continue

            if poison_type == "label_flip":
                # Flip sign of entire gradient
                poisoned_grads[idx] = [-g for g in gradients[idx]]
            elif poison_type == "sign_flip":
                # Randomly flip subset of coordinates
                flip_ratio = 0.3
                for i in range(len(poisoned_grads[idx])):
                    if random.random() < flip_ratio:
                        poisoned_grads[idx][i] *= -1

    return poisoned_grads
```

#### Attack 3: Strategy-Evolution
```python
def inject_strategy_evolution(gradients: List[Gradient],
                             client_ids: List[str],
                             malicious_clients: Set[str],
                             round_num: int,
                             evolution_interval: int = 20) -> List[Gradient]:
    """
    Strategy-Evolution: Attacker observes model state, adapts attack vector dynamically

    Evolution phases (every evolution_interval rounds):
      - Phase 1 (0~20): Gaussian noise (high variance, easy to detect)
      - Phase 2 (20~40): Sign-flip (different evasion technique)
      - Phase 3 (40~60): Adaptive magnitude scaling (matches honest gradient scale)
      - Phase 4+ (60~): Random strategy switching

    AIOps Impact: Evasion of fixed-threshold detection, detection accuracy degradation
    """
    poisoned_grads = gradients.copy()

    phase = (round_num // evolution_interval) % 4

    for client_id in malicious_clients:
        try:
            idx = client_ids.index(client_id)
        except ValueError:
            continue

        if phase == 0:
            # High-variance Gaussian
            poisoned_grads[idx] = [g + random.gauss(0, 1.0) for g in gradients[idx]]
        elif phase == 1:
            # Sign-flip
            poisoned_grads[idx] = [-g for g in gradients[idx]]
        elif phase == 2:
            # Adaptive magnitude (scale to match others)
            honest_magnitude = sum(gradients[i]**2 for i, cid in enumerate(client_ids)
                                  if cid not in malicious_clients) ** 0.5
            current_magnitude = sum(g**2 for g in gradients[idx]) ** 0.5
            scale = honest_magnitude / (current_magnitude + 1e-10)
            poisoned_grads[idx] = [g * scale for g in gradients[idx]]
        else:
            # Random perturbation
            poisoned_grads[idx] = [g * random.uniform(0.9, 1.1) for g in gradients[idx]]

    return poisoned_grads
```

#### Attack 4: Collusion + Sybil
```python
def inject_collusion_sybil(gradients: List[Gradient],
                          client_ids: List[str],
                          malicious_group: Set[str],
                          sybil_multiplier: int = 3) -> Tuple[List[Gradient], List[str]]:
    """
    Collusion+Sybil: Coordinated malicious group + fake client IDs

    Strategy:
      - Malicious group (15% of clients) coordinates poisoning
      - Each quarantined malicious client spawns 2-3 Sybil (fake) identities
      - Sybils use coordinated poisoning gradients

    AIOps Impact: Amplified model poisoning, distributed attack nodes

    Returns:
        (augmented_gradients, augmented_client_ids)
    """
    poisoned_grads = gradients.copy()
    poisoned_ids = client_ids.copy()

    # Coordinated attack: amplify malicious gradient
    coordinated_scale = 1.5 + len(malicious_group) * 0.1

    for client_id in malicious_group:
        try:
            idx = client_ids.index(client_id)
        except ValueError:
            continue

        poisoned_grads[idx] = [g * coordinated_scale for g in gradients[idx]]

        # Add Sybil identities
        for sybil_num in range(sybil_multiplier):
            sybil_id = f"{client_id}_sybil_{sybil_num}"
            poisoned_ids.append(sybil_id)
            # Sybils use slightly perturbed poisoned gradient
            perturbation = random.uniform(0.95, 1.05)
            poisoned_grads.append([g * perturbation for g in poisoned_grads[idx]])

    return poisoned_grads, poisoned_ids
```

#### Attack 5: Task-Specific Poisoning with Cross-Task Propagation
```python
def inject_task_specific_attack(task_gradients: Dict[str, List[Gradient]],
                                client_ids: List[str],
                                malicious_clients: Set[str],
                                target_task: str = "rca",
                                cross_task_leak_ratio: float = 0.15) -> Dict[str, List[Gradient]]:
    """
    Task-Specific: Poison only RCA task, leak to other tasks via gradient mixing

    Strategy:
      - Malicious clients: Poison RCA (anomaly detection task) with high amplitude
      - Gradient mixing: 15% of poisoned RCA gradient leaks to forecasting/detection tasks
      - Bypass: Multi-task quarantine may not catch task-specific bias

    AIOps Impact: Compromised root cause analysis → wrong remediation, cascading failures
    """
    poisoned_task_grads = {task: grads.copy() for task, grads in task_gradients.items()}

    # Poison target task (e.g., RCA)
    if target_task in poisoned_task_grads:
        target_grads = poisoned_task_grads[target_task]
        for client_id in malicious_clients:
            try:
                idx = client_ids.index(client_id)
                # Amplify target task gradient
                target_grads[idx] = [g * 2.0 for g in target_grads[idx]]
            except ValueError:
                continue

    # Cross-task leakage
    for task in poisoned_task_grads:
        if task != target_task:
            target_task_grads = poisoned_task_grads[target_task]
            for i in range(len(poisoned_task_grads[task])):
                if client_ids[i] in malicious_clients:
                    # Mix target task poison into other tasks
                    leak = [g * cross_task_leak_ratio for g in target_task_grads[i]]
                    poisoned_task_grads[task][i] = [
                        orig + leak_val
                        for orig, leak_val in zip(poisoned_task_grads[task][i], leak)
                    ]

    return poisoned_task_grads
```

