#### 1️⃣ FedAvg
```python
def fedavg_aggregate(client_gradients: List[Gradient], weights: List[float] = None) -> Gradient:
    """
    Simple average aggregation (no Byzantine defense)

    Args:
        client_gradients: List of client gradient vectors
        weights: Optional client weights (default: uniform)

    Returns:
        Aggregated gradient (simple average)
    """
    if not weights:
        weights = [1.0 / len(client_gradients)] * len(client_gradients)

    agg = [sum(w * g[i] for w, g in zip(weights, client_gradients))
           for i in range(len(client_gradients[0]))]
    return agg
```

#### 2️⃣ Krum
```python
def krum_aggregate(client_gradients: List[Gradient], byzantine_count: int) -> Gradient:
    """
    Krum: select gradient closest to mean of its k nearest neighbors

    Complexity: O(n² × d)
    - n: number of clients
    - d: gradient dimension

    Args:
        client_gradients: gradients
        byzantine_count: max Byzantine clients (determines k)

    Returns:
        Selected gradient (most Byzantine-robust)
    """
    n = len(client_gradients)
    k = n - byzantine_count - 2  # neighbors to consider

    distances = {}
    for i, grad_i in enumerate(client_gradients):
        # Euclidean distance to all others
        dists = [euclidean_dist(grad_i, grad_j)
                 for j, grad_j in enumerate(client_gradients) if j != i]
        dists.sort()
        distances[i] = sum(dists[:k])  # sum of k nearest

    # Return gradient with smallest score
    selected_idx = min(distances, key=distances.get)
    return client_gradients[selected_idx]

def euclidean_dist(g1, g2):
    return sum((a - b) ** 2 for a, b in zip(g1, g2)) ** 0.5
```

#### 3️⃣ Multi-Krum
```python
def multi_krum_aggregate(client_gradients: List[Gradient],
                        byzantine_count: int,
                        m: int = 2) -> Gradient:
    """
    Multi-Krum: select top-m candidates via Krum, then average

    Args:
        client_gradients: gradients
        byzantine_count: max Byzantine clients
        m: number of candidates to select (default: 2)

    Returns:
        Average of top-m Krum-selected gradients
    """
    n = len(client_gradients)
    k = n - byzantine_count - 2

    # Score each client
    scores = {}
    for i, grad_i in enumerate(client_gradients):
        dists = [euclidean_dist(grad_i, grad_j)
                 for j, grad_j in enumerate(client_gradients) if j != i]
        dists.sort()
        scores[i] = sum(dists[:k])

    # Select top-m
    selected_indices = sorted(scores.keys(), key=lambda x: scores[x])[:m]
    selected_grads = [client_gradients[i] for i in selected_indices]

    # Average
    return fedavg_aggregate(selected_grads)
```

#### 4️⃣ Trimmed Mean
```python
def trimmed_mean_aggregate(client_gradients: List[Gradient],
                          byzantine_count: int) -> Gradient:
    """
    Coordinate-wise trimmed mean: remove top/bottom β fraction per dimension

    Args:
        client_gradients: gradients (n_clients × d)
        byzantine_count: max Byzantine clients

    Returns:
        Aggregated gradient (trimmed per coordinate)
    """
    n = len(client_gradients)
    d = len(client_gradients[0])
    beta = (byzantine_count + 1) / n  # fraction to trim per side
    trim_count = int(beta * n)  # how many to remove

    aggregated = []
    for coord_idx in range(d):
        values = [g[coord_idx] for g in client_gradients]
        values.sort()
        trimmed = values[trim_count:-trim_count if trim_count > 0 else None]
        aggregated.append(sum(trimmed) / len(trimmed) if trimmed else 0)

    return aggregated
```

#### 5️⃣ FLGuard
```python
def flguard_aggregate(client_gradients: List[Gradient],
                     client_states: Dict[str, ClientState],
                     detection_threshold: float = 0.7) -> Tuple[Gradient, Set[str]]:
    """
    FLGuard: Multi-signal anomaly detection (gradient magnitude + cosine similarity + variance)

    Args:
        client_gradients: gradients
        client_states: client historical data for pattern analysis
        detection_threshold: anomaly score threshold

    Returns:
        (aggregated_gradient, detected_malicious_set)
    """
    n = len(client_gradients)

    # Signal 1: Gradient magnitude (L2 norm)
    magnitudes = [sum(g**2 for g in grad) ** 0.5 for grad in client_gradients]
    mag_mean = sum(magnitudes) / n
    mag_std = (sum((m - mag_mean)**2 for m in magnitudes) / n) ** 0.5

    # Signal 2: Cosine similarity to global mean
    global_mean = fedavg_aggregate(client_gradients)
    cosines = []
    for grad in client_gradients:
        dot = sum(g * m for g, m in zip(grad, global_mean))
        norm_g = sum(g**2 for g in grad) ** 0.5
        norm_m = sum(m**2 for m in global_mean) ** 0.5
        cosine = dot / (norm_g * norm_m + 1e-10)
        cosines.append(cosine)

    cosine_mean = sum(cosines) / n
    cosine_std = (sum((c - cosine_mean)**2 for c in cosines) / n) ** 0.5

    # Anomaly scores
    detected = set()
    for i, (mag, cos) in enumerate(zip(magnitudes, cosines)):
        mag_zscore = abs((mag - mag_mean) / (mag_std + 1e-10))
        cos_zscore = abs((cos - cosine_mean) / (cosine_std + 1e-10))
        anomaly_score = (mag_zscore + cos_zscore) / 2

        if anomaly_score > detection_threshold:
            detected.add(f"client_{i}")

    # Aggregate (exclude detected)
    honest_grads = [g for i, g in enumerate(client_gradients)
                    if f"client_{i}" not in detected]
    agg = fedavg_aggregate(honest_grads) if honest_grads else global_mean

    return agg, detected
```

#### 6️⃣ OptiGradTrust (2025 SOTA - 간단 구현)
```python
def optgradtrust_aggregate(client_gradients: List[Gradient],
                          client_history: Dict[str, List[Gradient]],
                          trust_decay: float = 0.95) -> Tuple[Gradient, Dict[str, float]]:
    """
    OptiGradTrust: RL-based trust weighting with gradient analysis
    (Simplified version: gradient consistency + historical trust)

    Args:
        client_gradients: current round gradients
        client_history: past gradients for each client
        trust_decay: exponential moving average decay factor

    Returns:
        (weighted_aggregate, trust_scores)
    """
    n = len(client_gradients)
    trust_scores = {}

    # Trust signal 1: Gradient consistency (low variance across rounds)
    for i, client_id in enumerate(range(n)):
        if client_history:
            # Calculate variance of gradient norms over time
            historical_norms = [sum(g**2 for g in hist) ** 0.5
                               for hist in client_history.get(f"client_{i}", [])]
            current_norm = sum(client_gradients[i]**2 for g in client_gradients[i]) ** 0.5

            if historical_norms:
                consistency = 1.0 / (1.0 + sum((n - current_norm)**2 for n in historical_norms))
            else:
                consistency = 0.5
        else:
            consistency = 0.5

        # Trust signal 2: Alignment with peer gradients
        alignment = 0.0
        for j, other_grad in enumerate(client_gradients):
            if i != j:
                cos_sim = (sum(g * o for g, o in zip(client_gradients[i], other_grad)) /
                          (sum(g**2 for g in client_gradients[i])**0.5 *
                           sum(o**2 for o in other_grad)**0.5 + 1e-10))
                alignment += cos_sim
        alignment /= (n - 1) if n > 1 else 1
        alignment = max(0, min(1, (alignment + 1) / 2))  # Normalize to [0,1]

        # Combined trust score
        trust_scores[f"client_{i}"] = 0.6 * consistency + 0.4 * alignment

    # Normalize trust scores
    total_trust = sum(trust_scores.values())
    normalized_trust = {k: v / total_trust for k, v in trust_scores.items()}

    # Weighted aggregation
    weights = list(normalized_trust.values())
    agg = [sum(w * g[i] for w, g in zip(weights, client_gradients))
           for i in range(len(client_gradients[0]))]

    return agg, trust_scores
```

