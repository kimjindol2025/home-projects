def simulate_mixed_attacks(
    client_gradients: Dict[str, List[float]],
    client_ids: List[str],
    malicious_ratio: float = 0.2,
    round_num: int = 0,
    attack_schedule: Dict[str, int] = None
) -> Dict[str, List[float]]:
    """
    Simulate mixed/sequential adaptive attacks across a federated round.

    Args:
        client_gradients: Initial gradients
        client_ids: List of client IDs
        malicious_ratio: Fraction of malicious clients (0.1 ~ 0.4)
        round_num: Current round
        attack_schedule: Dict[round -> attack_type]

    Returns:
        Poisoned gradients after all attacks applied
    """
    num_malicious = max(1, int(len(client_ids) * malicious_ratio))
    malicious_clients = set(random.sample(client_ids, num_malicious))

    if attack_schedule and round_num in attack_schedule:
        attack_type = attack_schedule[round_num]
        client_gradients, _ = apply_adaptive_attack(
            client_gradients, attack_type, client_ids, malicious_clients, round_num, {}
        )

    return client_gradients


