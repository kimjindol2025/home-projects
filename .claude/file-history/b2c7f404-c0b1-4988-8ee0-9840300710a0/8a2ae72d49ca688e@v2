class IsolationForest:
    """
    Anomaly detection using Isolation Forest
    (Simplified implementation without full tree building)
    """

    def __init__(self, num_trees: int = 100, sample_size: int = 256,
                 contamination: float = 0.1, random_state: int = 42):
        self.num_trees = num_trees
        self.sample_size = sample_size
        self.contamination = contamination
        random.seed(random_state)

    def compute_anomaly_score(self, gradient_vectors: List[List[float]]) -> List[float]:
        """
        Compute anomaly scores for gradient vectors
        Returns: List of scores in [0, 1] where 1 = definitely anomaly
        """
        n_samples = len(gradient_vectors)
        if n_samples == 0:
            return []

        # Convert to numeric
        X = [g if isinstance(g, list) else list(g) for g in gradient_vectors]
        n_features = len(X[0]) if X else 1

        scores = [0.0] * n_samples

        # Build ensemble of trees
        for _ in range(self.num_trees):
            # Random sample
            sample_idx = random.sample(range(n_samples), min(self.sample_size, n_samples))
            sample = [X[i] for i in sample_idx]

            # Compute path lengths for each sample
            for i in range(n_samples):
                path_length = self._path_length(X[i], sample)
                scores[i] += path_length

        # Average
        avg_path_lengths = [s / self.num_trees for s in scores]

        # Normalize to [0, 1]
        c = self._c_factor(self.sample_size)
        anomaly_scores = [2.0 ** (-l / c) for l in avg_path_lengths]

        return anomaly_scores

    def _path_length(self, x: List[float], sample: List[List[float]]) -> float:
        """Compute average path length"""
        if not sample:
            return 0.0

        # Simplified: distance-based anomaly
        # Anomalies are far from sample center
        center = [sum(s[i] for s in sample) / len(sample) for i in range(len(x))]
        distance = math.sqrt(sum((x[i] - center[i])**2 for i in range(len(x))))

        # Normalize
        max_dist = max([math.sqrt(sum((s[i] - center[i])**2 for i in range(len(s))))
                       for s in sample]) + 1e-8

        return distance / max_dist

    def _c_factor(self, sample_size: int) -> float:
        """Normalization factor"""
        if sample_size <= 1:
            return 0.0
        return 2.0 * (math.log(sample_size - 1) + 0.5772156649) - 2.0 * (sample_size - 1) / sample_size

