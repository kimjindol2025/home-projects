class DPoSQuarantine:
    """
    Module 3: DPoS-Linked Dynamic Quarantine & Slashing
    """

    def __init__(self, num_validators: int = 21, slash_rate: float = 0.05,
                 quarantine_duration: int = 3):
        self.num_validators = num_validators
        self.slash_rate = slash_rate
        self.quarantine_duration = quarantine_duration

        # Validator list
        self.validators = [f"validator_{i}" for i in range(num_validators)]

        # Quarantine records
        self.quarantine_records: Dict[str, QuarantineRecord] = {}

        # Slashing events (audit trail)
        self.slashing_events: List[Dict] = []

    def quarantine_and_slash(self,
                            detected_malicious: Set[str],
                            current_epoch: int,
                            client_stakes: Dict[str, float]) -> Dict[str, Any]:
        """
        Apply DPoS-based quarantine and slashing
        """
        quarantine_updates = {}
        stake_changes = {}

        for client_id in detected_malicious:
            # DPoS voting (simplified: majority of validators vote for quarantine)
            votes_for = random.randint(self.num_validators * 2 // 3, self.num_validators)
            votes_total = self.num_validators
            quorum = math.ceil(self.num_validators * 2 / 3) + 1

            if votes_for >= quorum:
                # Approved: slash stake
                original_stake = client_stakes.get(client_id, 0.0)
                slashed_amount = original_stake * self.slash_rate
                new_stake = original_stake - slashed_amount

                stake_changes[client_id] = {
                    'original': original_stake,
                    'slashed': slashed_amount,
                    'new_stake': new_stake
                }

                # Set quarantine epoch
                release_epoch = current_epoch + self.quarantine_duration

                record = QuarantineRecord(
                    client_id=client_id,
                    reason="Byzantine_detection",
                    quarantine_epoch=current_epoch,
                    release_epoch=release_epoch,
                    slashed_amount=slashed_amount,
                    votes_for=votes_for,
                    votes_total=votes_total,
                    status=QuarantineStatus.QUARANTINED
                )

                self.quarantine_records[client_id] = record
                quarantine_updates[client_id] = record

                # Log slashing event
                self.slashing_events.append({
                    'timestamp': time.time(),
                    'client_id': client_id,
                    'slashed_amount': slashed_amount,
                    'epoch': current_epoch,
                    'votes_for': votes_for,
                    'votes_total': votes_total
                })

        return {
            'quarantine_updates': quarantine_updates,
            'stake_changes': stake_changes,
            'slashing_events': self.slashing_events
        }

    def advance_epoch(self, current_epoch: int, client_stakes: Dict[str, float]) -> Dict[str, Any]:
        """
        Advance epoch and check for release eligibility
        """
        updated_records = {}

        for client_id, record in self.quarantine_records.items():
            if record.status == QuarantineStatus.QUARANTINED:
                if current_epoch >= record.release_epoch:
                    record.status = QuarantineStatus.RELEASE_ELIGIBLE

            updated_records[client_id] = record

        self.quarantine_records = updated_records

        return {'updated_records': updated_records}

