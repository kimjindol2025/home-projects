    print(f"✓ Initialized: {num_clients} clients, {num_tasks} tasks, {len(system.byzantine_clients)} Byzantine")
    print(f"  Byzantine clients: {list(system.byzantine_clients)[:5]}...")
    print()

    # Section 2: Run simulation
    print("【 Section 2: Run Federated Learning Rounds 】")
    print("-" * 80)

    num_rounds = 20
    sim_result = system.simulate(num_rounds=num_rounds)

    print()
    print("✓ Simulation completed!")
    print()

    # Section 3: Results
    print("【 Section 3: Simulation Results 】")
    print("-" * 80)

    print(f"Total Rounds: {sim_result['total_rounds']}")
    print(f"Total Detected: {sim_result['total_detected']} malicious clients")
    print(f"Average Detection Rate: {sim_result['avg_detection_rate']:.1%}")
    print()

    # Section 4: Per-round statistics
    print("【 Section 4: Per-Round Statistics 】")
    print("-" * 80)

    for i, result in enumerate(sim_result['results']):
        if i % 5 == 0:
            print(f"Round {result['round']:2d}: "
                  f"Detected {result['detected_malicious']:2d}, "
                  f"Detection {result['detection_rate']:.1%}, "
                  f"Epoch {result['epoch']}")

    print()

    # Section 5: Quarantine & Slashing
    print("【 Section 5: DPoS Quarantine & Slashing 】")
    print("-" * 80)

    print(f"Total Quarantine Records: {len(system.dpos.quarantine_records)}")
    print(f"Total Slashing Events: {len(system.dpos.slashing_events)}")

    total_slashed = sum(e['slashed_amount'] for e in system.dpos.slashing_events)
    print(f"Total Slashed Stake: {total_slashed:.2f}")
    print()

    if system.dpos.slashing_events:
        print("Top 5 Slashing Events:")
        for event in sorted(system.dpos.slashing_events,
                          key=lambda x: x['slashed_amount'], reverse=True)[:5]:
            print(f"  - {event['client_id']}: {event['slashed_amount']:.2f} "
                  f"(Epoch {event['epoch']}, Votes {event['votes_for']}/{event['votes_total']})")

    print()

    # Section 6: Credibility Scores
    print("【 Section 6: Final Credibility Scores 】")
    print("-" * 80)

    sorted_creds = sorted(system.credibility_scores.items(), key=lambda x: x[1], reverse=True)

    print("Top 10 Most Credible Clients:")
    for client_id, cred in sorted_creds[:10]:
        status = "✓ Honest" if client_id not in system.byzantine_clients else "✗ Byzantine"
        print(f"  {client_id}: {cred:.2f} [{status}]")

    print()

    # Section 7: Summary & Metrics
    print("【 Section 7: Summary Metrics 】")
    print("-" * 80)

    true_positives = len([c for c in system.byzantine_clients if
                         c in [r['client_id'] for r in system.dpos.slashing_events]])
    false_positives = len([c for c in system.client_ids if
                          c not in system.byzantine_clients and
                          c in [r['client_id'] for r in system.dpos.slashing_events]])

    print(f"True Positives (Correctly Detected Byzantine): {true_positives}/{len(system.byzantine_clients)}")
    print(f"False Positives (Wrongly Quarantined Honest): {false_positives}/{num_clients - len(system.byzantine_clients)}")
    print(f"Detection Rate: {true_positives / max(1, len(system.byzantine_clients)):.1%}")
    print(f"False Positive Rate: {false_positives / max(1, num_clients - len(system.byzantine_clients)):.1%}")

    print()
    print("=" * 80)
    print("✓ BR-AIOpsFL simulation completed successfully!")
    print("=" * 80)

if __name__ == "__main__":
    main()
