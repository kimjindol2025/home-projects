class TaskAwareAggregator:
    """
    Module 2: Task-Aware Multi-task Robust Aggregation
    """

    def __init__(self, aggregation_method: AggregationMethod = AggregationMethod.WEIGHTED_MEAN,
                 cross_task_threshold: float = 0.6):
        self.aggregation_method = aggregation_method
        self.cross_task_threshold = cross_task_threshold

    def aggregate(self,
                  task_gradients: Dict[str, List[ClientGradient]],
                  credibility_scores: Dict[str, float],
                  detected_malicious_all_tasks: Dict[str, Set[str]]) -> Dict[str, List[float]]:
        """
        Aggregate gradients per task with task-aware strategy

        Returns:
            aggregated_updates: Dict[task_id -> aggregated_gradient]
        """
        tasks = list(task_gradients.keys())
        aggregated_updates = {}

        # Compute task correlation matrix
        correlation_matrix = self._compute_correlation_matrix(task_gradients)

        # Per-task aggregation
        for task_id in tasks:
            gradients = task_gradients[task_id]

            if not gradients:
                aggregated_updates[task_id] = []
                continue

            # Get malicious set for this task
            detected_malicious = detected_malicious_all_tasks.get(task_id, set())

            # Compute weights
            weights = []
            for gradient in gradients:
                if gradient.client_id in detected_malicious:
                    weights.append(0.0)
                else:
                    cred = credibility_scores.get(gradient.client_id, 0.5)
                    weights.append(cred)

            # Normalize weights
            total_weight = sum(weights)
            if total_weight > 0:
                weights = [w / total_weight for w in weights]
            else:
                weights = [1.0 / len(weights)] * len(weights)

            # Aggregate
            gradient_vectors = [g.vector for g in gradients]

            if self.aggregation_method == AggregationMethod.WEIGHTED_MEAN:
                aggregated = self._weighted_mean(gradient_vectors, weights)
            elif self.aggregation_method == AggregationMethod.MEDIAN:
                aggregated = self._median(gradient_vectors)
            else:
                aggregated = self._weighted_mean(gradient_vectors, weights)

            aggregated_updates[task_id] = aggregated

        return aggregated_updates

    def _compute_correlation_matrix(self, task_gradients: Dict[str, List[ClientGradient]]) -> List[List[float]]:
        """Compute task correlation matrix"""
        tasks = list(task_gradients.keys())
        n = len(tasks)
        correlation = [[0.0] * n for _ in range(n)]

        for i, task_i in enumerate(tasks):
            for j, task_j in enumerate(tasks):
                if i == j:
                    correlation[i][j] = 1.0
                else:
                    grads_i = [g.vector for g in task_gradients[task_i]]
                    grads_j = [g.vector for g in task_gradients[task_j]]

                    if grads_i and grads_j:
                        corr = self._pearson_correlation(grads_i, grads_j)
                        correlation[i][j] = max(0, corr)

        return correlation

    def _pearson_correlation(self, grads_i: List[List[float]], grads_j: List[List[float]]) -> float:
        """Compute Pearson correlation"""
        if not grads_i or not grads_j:
            return 0.0

        # Average gradients
        avg_i = [sum(g[k] for g in grads_i) / len(grads_i) for k in range(len(grads_i[0]))]
        avg_j = [sum(g[k] for g in grads_j) / len(grads_j) for k in range(len(grads_j[0]))]

        # Compute correlation
        mean_i = sum(avg_i) / len(avg_i)
        mean_j = sum(avg_j) / len(avg_j)

        numerator = sum((avg_i[k] - mean_i) * (avg_j[k] - mean_j) for k in range(len(avg_i)))
        denom_i = math.sqrt(sum((avg_i[k] - mean_i) ** 2 for k in range(len(avg_i))) + 1e-10)
        denom_j = math.sqrt(sum((avg_j[k] - mean_j) ** 2 for k in range(len(avg_j))) + 1e-10)

        correlation = numerator / (denom_i * denom_j + 1e-10)

        return max(-1, min(1, correlation))

    def _weighted_mean(self, vectors: List[List[float]], weights: List[float]) -> List[float]:
        """Weighted mean aggregation"""
        if not vectors:
            return []

        result = [0.0] * len(vectors[0])
        for v, w in zip(vectors, weights):
            for i, val in enumerate(v):
                result[i] += w * val

        return result

    def _median(self, vectors: List[List[float]]) -> List[float]:
        """Median aggregation"""
        if not vectors:
            return []

        result = []
        for dim in range(len(vectors[0])):
            values = sorted([v[dim] for v in vectors])
            median = values[len(values) // 2]
            result.append(median)

        return result

