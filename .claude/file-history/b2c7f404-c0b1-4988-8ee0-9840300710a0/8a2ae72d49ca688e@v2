class BRAAIOpsFL:
    """
    Main BR-AIOpsFL system combining all 3 modules
    """

    def __init__(self, num_clients: int = 30, num_tasks: int = 3,
                 byzantine_fraction: float = 0.2):
        self.num_clients = num_clients
        self.num_tasks = num_tasks
        self.byzantine_fraction = byzantine_fraction

        # Generate client IDs and task IDs
        self.client_ids = [f"client_{i}" for i in range(num_clients)]
        self.task_ids = [f"task_{i}" for i in range(num_tasks)]

        # Select Byzantine clients
        num_byzantine = max(1, int(num_clients * byzantine_fraction))
        self.byzantine_clients = set(random.sample(self.client_ids, num_byzantine))

        # Initialize client states
        self.client_states: Dict[str, ClientState] = {}
        self.client_stakes: Dict[str, float] = {}

        for client_id in self.client_ids:
            self.client_states[client_id] = ClientState(
                client_id=client_id,
                task_ids=self.task_ids
            )
            self.client_stakes[client_id] = 100.0

        # Compute credibility scores
        self.credibility_scores: Dict[str, float] = {cid: 0.5 for cid in self.client_ids}

        # Initialize modules
        self.detector = TrajectoryDetector(trajectory_window_size=5, detection_threshold=0.7)
        self.aggregator = TaskAwareAggregator(aggregation_method=AggregationMethod.WEIGHTED_MEAN)
        self.dpos = DPoSQuarantine(num_validators=21, slash_rate=0.05, quarantine_duration=3)

        # Global models
        self.global_models: Dict[str, List[float]] = {
            task_id: [random.random() for _ in range(10)] for task_id in self.task_ids
        }

        # Metrics
        self.metrics = {
            'accuracy': [],
            'detection_rate': [],
            'false_positive_rate': [],
            'byzantine_evasion_rate': []
        }

    def generate_gradients(self, round_num: int) -> Dict[str, List[ClientGradient]]:
        """Generate gradients from clients"""
        task_gradients: Dict[str, List[ClientGradient]] = {task_id: [] for task_id in self.task_ids}

        for client_id in self.client_ids:
            # Check quarantine status
            if client_id in self.dpos.quarantine_records:
                record = self.dpos.quarantine_records[client_id]
                if record.status == QuarantineStatus.QUARANTINED:
                    continue  # Skip quarantined clients

            # Generate gradients for each task
            for task_id in self.task_ids:
                if client_id in self.byzantine_clients:
                    # Byzantine: add noise/poison
                    if random.random() < 0.6:  # 60% of time
                        gradient = [random.gauss(0, 2.0) for _ in range(10)]  # High variance
                    else:
                        gradient = [random.gauss(0, 0.1) for _ in range(10)]  # Normal
                else:
                    # Honest: normal gradient
                    gradient = [random.gauss(0, 0.1) for _ in range(10)]

                task_gradients[task_id].append(ClientGradient(
                    client_id=client_id,
                    task_id=task_id,
                    vector=gradient,
                    timestamp=time.time()
                ))

        return task_gradients

    def run_round(self, round_num: int, current_epoch: int) -> Dict[str, Any]:
        """Execute one federated learning round"""

        # Step 1: Collect gradients
        task_gradients = self.generate_gradients(round_num)

        # Flatten gradients for detection
        all_gradients = []
        for task_id in self.task_ids:
            all_gradients.extend(task_gradients[task_id])

        # Step 2: Module 1 - Trajectory Detection
        detected_malicious_set, anomaly_scores = self.detector.detect_malicious(all_gradients)

        # Group detected malicious by task
        detected_by_task = {}
        for task_id in self.task_ids:
            detected_by_task[task_id] = {g.client_id for g in task_gradients[task_id]
                                        if g.client_id in detected_malicious_set}

        # Step 3: Module 3 - DPoS Quarantine
        quarantine_result = self.dpos.quarantine_and_slash(
            detected_malicious=detected_malicious_set,
            current_epoch=current_epoch,
            client_stakes=self.client_stakes
        )

        # Update stakes
        for client_id, changes in quarantine_result['stake_changes'].items():
            self.client_stakes[client_id] = changes['new_stake']

        # Step 4: Module 2 - Task-Aware Aggregation
        aggregated_updates = self.aggregator.aggregate(
            task_gradients=task_gradients,
            credibility_scores=self.credibility_scores,
            detected_malicious_all_tasks=detected_by_task
        )

        # Step 5: Update global models
        learning_rate = 0.01
        for task_id in self.task_ids:
            if aggregated_updates[task_id]:
                for i, update in enumerate(aggregated_updates[task_id]):
                    self.global_models[task_id][i] -= learning_rate * update

        # Step 6: Update credibility scores
        for client_id in self.client_ids:
            if client_id not in detected_malicious_set:
                # Increase credibility for honest clients
                self.credibility_scores[client_id] = min(1.0,
                    self.credibility_scores[client_id] + 0.05)
            else:
                # Decrease for malicious
                self.credibility_scores[client_id] = max(0.0,
                    self.credibility_scores[client_id] - 0.2)

        # Step 7: Advance epoch if needed
        if round_num % 5 == 0:
            current_epoch += 1
            self.dpos.advance_epoch(current_epoch, self.client_stakes)

        # Compute metrics
        detection_rate = len(detected_malicious_set & self.byzantine_clients) / max(1, len(self.byzantine_clients))
        evasion_rate = 1.0 - detection_rate

        return {
            'round': round_num,
            'epoch': current_epoch,
            'detected_malicious': len(detected_malicious_set),
            'detection_rate': detection_rate,
            'evasion_rate': evasion_rate,
            'aggregated_updates': aggregated_updates,
            'slashing_count': len(quarantine_result['slashing_events'])
        }

    def simulate(self, num_rounds: int = 20) -> Dict[str, Any]:
        """Run full simulation"""
        results = []
        current_epoch = 0

        print(f"Starting BR-AIOpsFL simulation...")
        print(f"  Clients: {self.num_clients}")
        print(f"  Byzantine: {len(self.byzantine_clients)} ({self.byzantine_fraction*100:.0f}%)")
        print(f"  Tasks: {self.num_tasks}")
        print(f"  Rounds: {num_rounds}\n")

        for round_num in range(num_rounds):
            result = self.run_round(round_num, current_epoch)
            results.append(result)

            if round_num % 5 == 0:
                print(f"Round {round_num}: Detected {result['detected_malicious']}, "
                      f"Detection rate {result['detection_rate']:.1%}, "
                      f"Evasion {result['evasion_rate']:.1%}")

        return {
            'total_rounds': num_rounds,
            'results': results,
            'final_byzantine_clients': list(self.byzantine_clients),
            'total_detected': sum(r['detected_malicious'] for r in results),
            'avg_detection_rate': sum(r['detection_rate'] for r in results) / num_rounds
        }

