class TrajectoryDetector:
    """
    Trajectory-based Byzantine detection
    Module 1: Isolation Forest + LSTM pattern learning
    """

    def __init__(self, trajectory_window_size: int = 5, detection_threshold: float = 0.7):
        self.trajectory_window_size = trajectory_window_size
        self.detection_threshold = detection_threshold
        self.iso_forest = IsolationForest(num_trees=100, contamination=0.1)

        # Trajectory storage: client_id -> deque of (score, timestamp)
        self.trajectories: Dict[str, deque] = {}
        self.detection_logs: Dict[str, List[Dict]] = {}

    def detect_malicious(self, gradients: List[ClientGradient]) -> Tuple[Set[str], Dict[str, AnomalyScore]]:
        """
        Detect malicious clients using trajectory

        Returns:
            (detected_malicious_ids, anomaly_scores_dict)
        """
        if not gradients:
            return set(), {}

        detected_malicious = set()
        anomaly_scores_dict = {}

        # Step 1: Compute Isolation Forest scores
        gradient_vectors = [g.vector for g in gradients]
        iso_scores = self.iso_forest.compute_anomaly_score(gradient_vectors)

        # Step 2: For each client, maintain trajectory
        for idx, gradient in enumerate(gradients):
            client_id = gradient.client_id
            iso_score = iso_scores[idx]

            # Initialize trajectory if needed
            if client_id not in self.trajectories:
                self.trajectories[client_id] = deque(maxlen=self.trajectory_window_size)
                self.detection_logs[client_id] = []

            # Add current score
            self.trajectories[client_id].append(iso_score)

            # Step 3: LSTM-like pattern detection (simplified)
            # In real implementation, this would use pre-trained LSTM
            # Here we simulate with heuristic: high variance + high mean = malicious
            trajectory_seq = list(self.trajectories[client_id])

            if len(trajectory_seq) >= self.trajectory_window_size:
                lstm_prob = self._estimate_malicious_probability(trajectory_seq)
            else:
                lstm_prob = iso_score

            # Step 4: Combined decision
            combined_score = 0.5 * iso_score + 0.5 * lstm_prob

            anomaly_score = AnomalyScore(
                client_id=client_id,
                iso_forest_score=iso_score,
                lstm_prob=lstm_prob,
                combined_score=combined_score
            )
            anomaly_scores_dict[client_id] = anomaly_score

            # Step 5: Decision
            if combined_score > self.detection_threshold:
                detected_malicious.add(client_id)
                decision = "QUARANTINE"
            else:
                decision = "ACCEPT"

            # Log
            log_entry = {
                'iso_score': iso_score,
                'lstm_prob': lstm_prob,
                'combined': combined_score,
                'trajectory': trajectory_seq,
                'decision': decision,
                'timestamp': gradient.timestamp
            }
            self.detection_logs[client_id].append(log_entry)

        return detected_malicious, anomaly_scores_dict

    def _estimate_malicious_probability(self, trajectory: List[float]) -> float:
        """
        Estimate malicious probability from trajectory
        Simplified LSTM simulation
        """
        if len(trajectory) == 0:
            return 0.0

        mean = sum(trajectory) / len(trajectory)
        variance = sum((x - mean) ** 2 for x in trajectory) / len(trajectory) if len(trajectory) > 1 else 0

        # High mean + high variance = suspicious
        prob = min(1.0, mean + 0.2 * math.sqrt(variance))

        return prob

