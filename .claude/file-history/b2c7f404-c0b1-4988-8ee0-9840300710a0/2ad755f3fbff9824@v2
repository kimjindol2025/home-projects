### 3.5 **Epoch Progression & Release Logic**

```python
def advance_epoch(current_epoch, quarantine_records, client_stakes):
    """
    Called every N rounds to:
    1. Check if any quarantined nodes can be released
    2. Apply reputation recovery
    3. Update delegation power
    """

    updated_quarantine_records = {}

    for client_id, record in quarantine_records.items():

        if record['status'] == 'QUARANTINED':
            release_epoch = record['release_epoch']

            if current_epoch >= release_epoch:
                # STEP 1: Can attempt re-entry
                # But requires:
                # - Time lock passed (✓)
                # - Pay bond (to prevent Sybil) (implementation detail)
                # - Prove good faith (optional: contribute small stake)

                record['status'] = 'RELEASE_ELIGIBLE'
                record['release_epoch_reached'] = current_epoch

                # STEP 2: Reputation begins recovery
                old_reputation = record.get('reputation_before_slashing', 0.5)
                recovered_reputation = old_reputation * record.get('reputation_decay', 0.8)
                record['reputation_current'] = recovered_reputation

            updated_quarantine_records[client_id] = record

        elif record['status'] == 'RELEASE_ELIGIBLE':
            # Node tried to re-enter and was accepted
            if record.get('reentry_verified'):
                record['status'] = 'ACTIVE'
                record['reputation_current'] *= 1.2  # 20% boost for successful re-entry

                # Restore some stake over time (gradual, not immediate)
                # recovery_rate = 0.01 per epoch
                current_stake = client_stakes.get(client_id, 0)
                original_stake = record.get('original_stake', current_stake)
                recovery_rate = min(0.01, (original_stake - current_stake) / 100)
                new_stake = current_stake * (1 + recovery_rate)

                client_stakes[client_id] = new_stake

            updated_quarantine_records[client_id] = record

    return updated_quarantine_records, client_stakes
