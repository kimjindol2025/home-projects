### 2.4 **Task Correlation 계산**

```python
"""
Task Correlation: Pearson Correlation Coefficient
Measures degree of linear relationship between task gradients
"""

def compute_task_correlation(gradients_task_a, gradients_task_b):
    """
    Inputs:
      - gradients_task_a: List of gradient vectors from task A
      - gradients_task_b: List of gradient vectors from task B

    Output:
      - correlation: float ∈ [-1, 1]
        -1: perfect negative correlation
         0: no correlation
        +1: perfect positive correlation
    """
    # Average gradients per task
    avg_grad_a = np.mean(np.array(gradients_task_a), axis=0)
    avg_grad_b = np.mean(np.array(gradients_task_b), axis=0)

    # Flatten
    flat_a = avg_grad_a.flatten()
    flat_b = avg_grad_b.flatten()

    # Pearson correlation
    if len(flat_a) != len(flat_b):
        return 0.0  # Different dimensions

    mean_a = np.mean(flat_a)
    mean_b = np.mean(flat_b)

    numerator = np.sum((flat_a - mean_a) * (flat_b - mean_b))
    denominator = np.sqrt(np.sum((flat_a - mean_a)**2) * np.sum((flat_b - mean_b)**2))

    if denominator < 1e-10:
        return 0.0  # Degenerate case

    correlation = numerator / denominator
    return max(-1, min(1, correlation))  # Clip to [-1,1]
```

