### 1.4 **Isolation Forest 상세**

```python
"""
Isolation Forest: Tree-based anomaly detection
- Randomly select feature → Randomly select split value
- Isolate anomalies faster than normal points (fewer splits)
- Anomaly score = average path length to leaf
"""

class IsolationForest:
    def __init__(self, num_trees=100, sample_size=256, contamination=0.1):
        self.num_trees = num_trees
        self.sample_size = sample_size
        self.contamination = contamination  # Expected % of anomalies

    def fit_predict(self, X):
        """
        X: numpy array (n_samples, n_features)
        Output: anomaly_scores ∈ [-1, 1]

        -1 = certain anomaly
        +1 = certain normal
        """
        n_samples = X.shape[0]
        scores = np.zeros(n_samples)

        for _ in range(self.num_trees):
            # Randomly sample
            sample_idx = np.random.choice(n_samples, self.sample_size, replace=False)
            sample = X[sample_idx]

            # Build isolation tree
            tree = self._build_tree(sample, depth=0)

            # Compute path lengths
            path_lengths = np.array([self._path_length(tree, X[i])
                                     for i in range(n_samples)])
            scores += path_lengths

        # Average path length
        avg_path_lengths = scores / self.num_trees

        # Normalize to [-1, 1]
        c = self._c_factor(self.sample_size)
        anomaly_scores = 2 ** (-avg_path_lengths / c)

        return anomaly_scores

    def _build_tree(self, X, depth, max_depth=8):
        """Build a single isolation tree"""
        if depth >= max_depth or X.shape[0] <= 1:
            return {'type': 'leaf', 'samples': X.shape[0]}

        # Random feature
        feature = np.random.randint(X.shape[1])
        # Random split value
        split_val = np.random.uniform(X[:, feature].min(), X[:, feature].max())

        # Split
        left_mask = X[:, feature] < split_val
        left = X[left_mask]
        right = X[~left_mask]

        if left.shape[0] == 0 or right.shape[0] == 0:
            return {'type': 'leaf', 'samples': X.shape[0]}

        return {
            'type': 'node',
            'feature': feature,
            'split': split_val,
            'left': self._build_tree(left, depth+1, max_depth),
            'right': self._build_tree(right, depth+1, max_depth)
        }
```

