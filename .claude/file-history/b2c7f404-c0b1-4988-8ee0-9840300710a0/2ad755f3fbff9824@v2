### 3.4 **Sybil Attack Prevention**

```python
"""
Sybil Attack Prevention: Preventing re-entry under new identity
"""

def prevent_sybil_reentry(new_node_info, previous_quarantine_records):
    """
    Check if new node is actually quarantined node trying to re-enter

    Signals:
    1. Same IP address but different device_id
    2. Same wallet address but different client_id
    3. Correlated gradient patterns (same network signature)
    """

    new_ip = new_node_info['ip_address']
    new_device_id = new_node_info['device_id']
    new_wallet = new_node_info['wallet_address']

    for quarantined_id, record in previous_quarantine_records.items():
        if record['status'] == 'QUARANTINED':
            quarantined_ip = record.get('ip_address')
            quarantined_device = record.get('device_id')
            quarantined_wallet = record.get('wallet_address')

            # Check 1: Same IP, different device_id (Sybil!)
            if new_ip == quarantined_ip and new_device_id != quarantined_device:
                return {
                    'is_sybil': True,
                    'sybil_type': 'IP_reuse',
                    'quarantined_node': quarantined_id,
                    'action': 'PERMANENT_BAN'
                }

            # Check 2: Same wallet, different device_id
            if new_wallet == quarantined_wallet and new_device_id != quarantined_device:
                return {
                    'is_sybil': True,
                    'sybil_type': 'wallet_reuse',
                    'quarantined_node': quarantined_id,
                    'action': 'PERMANENT_BAN'
                }

    return {'is_sybil': False, 'action': 'ACCEPT'}


def handle_sybil_attempt(sybil_result, new_node_info):
    """Handle detected Sybil attack"""

    if sybil_result['is_sybil']:
        # Apply permanent ban
        new_stake = new_node_info.get('stake', 0)

        ban_record = {
            'device_id': new_node_info['device_id'],
            'wallet': new_node_info['wallet_address'],
            'ip': new_node_info['ip_address'],
            'reason': 'Sybil_reentry_attempt',
            'timestamp': time.time(),
            'lockup_epochs': 10,
            'slashed_amount': new_stake * 0.1,  # 10% immediate slash
            'action': 'REJECT_PARTICIPATION'
        }

        return ban_record

    else:
        return None  # Normal node, accept
