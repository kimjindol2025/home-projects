### 1.5 **LSTM 구조**

```python
"""
LSTM for Trajectory Pattern Learning
Input: [anomaly_score_t-4, ..., anomaly_score_t] (length=5)
Output: P(malicious | trajectory) ∈ [0,1]
"""

import tensorflow as tf
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import LSTM, Dense, Dropout

def build_trajectory_lstm(input_length=5):
    """
    Build LSTM for trajectory-based detection
    """
    model = Sequential([
        LSTM(64, activation='relu', input_shape=(input_length, 1)),
        Dropout(0.2),
        Dense(32, activation='relu'),
        Dropout(0.2),
        Dense(1, activation='sigmoid')  # Binary classification: malicious or not
    ])
    model.compile(optimizer='adam', loss='binary_crossentropy', metrics=['accuracy'])
    return model

# Training data generation (simulation)
def generate_trajectory_training_data(num_normal=1000, num_malicious=500):
    """
    Generate synthetic trajectories for training
    - Normal: gradual, consistent anomaly scores (~0.1-0.3)
    - Malicious: high spikes (0.7-1.0) or patterns
    """
    X_normal = np.random.normal(0.15, 0.05, (num_normal, 5, 1))
    X_normal = np.clip(X_normal, 0, 1)
    y_normal = np.zeros(num_normal)

    # Malicious: sudden spikes or consistent high scores
    X_malicious = np.random.uniform(0.6, 1.0, (num_malicious, 5, 1))
    y_malicious = np.ones(num_malicious)

    X = np.vstack([X_normal, X_malicious])
    y = np.hstack([y_normal, y_malicious])

    return X, y

# Pre-train on synthetic data
X_train, y_train = generate_trajectory_training_data()
lstm_model = build_trajectory_lstm()
lstm_model.fit(X_train, y_train, epochs=10, batch_size=32, validation_split=0.2)
