### 2.3 **Pseudo-Code: Task-Aware Aggregation**

```python
"""
ALGORITHM 2: Task-Aware Multi-task Robust Aggregation
Input:
  - task_gradients: Dict[task_id → List[gradient_vectors]]
  - credibility_scores: Dict[client_id → float ∈ [0,1]]
  - detected_malicious_all_tasks: Dict[task_id → Set[client_id]]
  - aggregation_method: str = "weighted_mean" or "median"
  - cross_task_threshold: float = 0.6 (correlation threshold)

Output:
  - aggregated_updates: Dict[task_id → aggregated_gradient]
  - cross_task_recommendations: Dict[task_pair → recommendation]
"""

def task_aware_aggregation(task_gradients, credibility_scores,
                          detected_malicious_all_tasks,
                          aggregation_method="weighted_mean",
                          cross_task_threshold=0.6):

    tasks = list(task_gradients.keys())
    num_tasks = len(tasks)
    aggregated_updates = {}
    cross_task_recommendations = {}

    # STEP 1: Compute Task Correlation Matrix
    correlation_matrix = np.zeros((num_tasks, num_tasks))

    for i, task_i in enumerate(tasks):
        for j, task_j in enumerate(tasks):
            if i == j:
                correlation_matrix[i,j] = 1.0
            else:
                # Stack all gradients from both tasks
                grads_i = np.vstack(task_gradients[task_i])
                grads_j = np.vstack(task_gradients[task_j])

                # Compute Pearson correlation (average across clients)
                flat_i = grads_i.mean(axis=0)  # Average gradient
                flat_j = grads_j.mean(axis=0)  # Average gradient

                corr = np.corrcoef(flat_i, flat_j)[0, 1]
                correlation_matrix[i,j] = max(0, corr)  # Clip negative

    # STEP 2: Per-task aggregation with cross-task awareness
    for task_id in tasks:
        gradients_task = task_gradients[task_id]

        # Get clients in this task
        client_ids_task = [g['client_id'] for g in gradients_task]

        # Filter out detected malicious
        detected_malicious_this_task = detected_malicious_all_tasks.get(task_id, set())

        # STEP 3: Compute weights (credibility + normal status)
        weights = []
        for client_id in client_ids_task:
            if client_id in detected_malicious_this_task:
                weight = 0.0  # Exclude malicious
            else:
                cred = credibility_scores.get(client_id, 0.5)
                weight = cred  # Higher credibility → higher weight

            weights.append(weight)

        # Normalize weights
        total_weight = sum(weights)
        if total_weight == 0:
            weights = [1/len(weights)] * len(weights)  # Uniform fallback
        else:
            weights = [w / total_weight for w in weights]

        # STEP 4: Aggregate using selected method
        gradient_vectors = np.array([g['vector'] for g in gradients_task])

        if aggregation_method == "weighted_mean":
            aggregated = np.average(gradient_vectors, axis=0, weights=weights)

        elif aggregation_method == "median":
            aggregated = np.median(gradient_vectors, axis=0)

        elif aggregation_method == "trimmed_mean":
            # Remove top/bottom 10%
            trim_idx = int(0.1 * len(gradients_task))
            sorted_idx = np.argsort(weights)
            keep_idx = sorted_idx[trim_idx:-trim_idx] if trim_idx > 0 else sorted_idx
            aggregated = np.mean(gradient_vectors[keep_idx], axis=0)

        aggregated_updates[task_id] = aggregated

        # STEP 5: Cross-task contamination check
        for other_task_id in tasks:
            if task_id != other_task_id:
                task_idx_i = tasks.index(task_id)
                task_idx_j = tasks.index(other_task_id)
                corr = correlation_matrix[task_idx_i, task_idx_j]

                # If correlation is high and this task has malicious,
                # recommend heightened scrutiny in other task
                if corr > cross_task_threshold:
                    malicious_count = len(detected_malicious_this_task)
                    if malicious_count > 0:
                        cross_task_recommendations[(task_id, other_task_id)] = {
                            'correlation': corr,
                            'contamination_risk': min(1.0, malicious_count / len(client_ids_task)),
                            'recommendation': 'HEIGHTENED_SCRUTINY'
                        }

    return {
        'aggregated_updates': aggregated_updates,
        'cross_task_correlation': correlation_matrix,
        'cross_task_recommendations': cross_task_recommendations
    }
```

