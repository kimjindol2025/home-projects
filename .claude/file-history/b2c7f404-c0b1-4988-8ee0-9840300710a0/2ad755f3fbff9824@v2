### 1.3 **Pseudo-Code: Isolation Forest + LSTM Detection**

```python
"""
ALGORITHM 1: Trajectory-Based Byzantine Detection
Input:
  - gradients: List[Dict] = [{client_id, gradient_vector}] (round t)
  - trajectory_window: Dict[client_id → List[anomaly_score]] (길이=5)
  - lstm_model: Pre-trained LSTM on normal trajectories
  - threshold: float = 0.7 (malicious probability threshold)

Output:
  - detected_malicious: Set[client_id]
  - trajectory_window: Updated
  - logs: Dict with detection details
"""

def trajectory_based_detection(gradients, trajectory_window, lstm_model, threshold=0.7):

    # STEP 1: Compute anomaly scores using Isolation Forest
    iso_forest = IsolationForest(contamination=0.1, random_state=42)
    gradient_vectors = np.array([g['vector'] for g in gradients])

    # 정규화 (각 클라이언트의 gradient 크기에 무관하게)
    norm_gradients = gradient_vectors / (np.linalg.norm(gradient_vectors, axis=1, keepdims=True) + 1e-8)

    anomaly_scores = iso_forest.fit_predict(norm_gradients)
    # Convert predictions to probabilities [0, 1]
    anomaly_probs = (anomaly_scores + 1) / 2  # rescale [-1,1] → [0,1]

    detected_malicious = set()

    # STEP 2: For each client, maintain trajectory and predict
    for idx, gradient_record in enumerate(gradients):
        client_id = gradient_record['client_id']
        score_t = anomaly_probs[idx]

        # Initialize trajectory if not exists
        if client_id not in trajectory_window:
            trajectory_window[client_id] = deque([0.0]*5, maxlen=5)

        # Append current score
        trajectory_window[client_id].append(score_t)
        trajectory_seq = list(trajectory_window[client_id])  # length = 5

        # STEP 3: LSTM prediction on trajectory
        # Input shape: (1, 5, 1) → [1 sample, 5 timesteps, 1 feature]
        trajectory_tensor = np.array(trajectory_seq).reshape(1, 5, 1)

        # LSTM output: malicious_probability ∈ [0, 1]
        malicious_prob = lstm_model.predict(trajectory_tensor, verbose=0)[0][0]

        # STEP 4: Decision making
        if malicious_prob > threshold:
            detected_malicious.add(client_id)
            decision = "QUARANTINE"
        else:
            decision = "ACCEPT"

        # Log
        logs[client_id] = {
            'round': current_round,
            'iso_score': score_t,
            'trajectory': trajectory_seq,
            'lstm_prob': malicious_prob,
            'decision': decision,
            'timestamp': time.time()
        }

    return {
        'detected_malicious': detected_malicious,
        'trajectory_window': trajectory_window,
        'logs': logs
    }
```

