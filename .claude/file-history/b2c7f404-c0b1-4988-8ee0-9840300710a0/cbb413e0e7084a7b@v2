echo "[ ] 최종 프루프읽기 완료"
echo ""

# Step 7: 제출 지시사항
echo "📝 Step 7: 제출 지시사항"
echo ""
case "$VENUE" in
    tdsc)
        echo "🔗 IEEE TDSC 제출:"
        echo "   1. https://mc.manuscriptcentral.com/tdsc 접속"
        echo "   2. 'Create an Account' (계정 없으면) 또는 로그인"
