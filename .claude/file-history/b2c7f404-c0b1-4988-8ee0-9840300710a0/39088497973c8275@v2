    """Metrics collected per round"""
    round_num: int
    method: str
    attack_type: str
    byzantine_fraction: float
    seed: int

    # Model performance
    model_accuracy: float = 0.0
    model_f1: float = 0.0
    model_mae: float = 0.0

    # Detection performance
    detected_byzantine: int = 0
    true_byzantine: int = 0
    detection_precision: float = 0.0
    detection_recall: float = 0.0
    detection_f1: float = 0.0

    # Recovery metrics
    mttr_rounds: int = 0  # Rounds to recovery
    evasion_count: int = 0

    # Computational
    aggregation_time_ms: float = 0.0
    communication_bytes: int = 0

    # Additional metadata
    detected_indices: List[int] = None
    true_byzantine_indices: List[int] = None

    def __post_init__(self):
        if self.detected_indices is None:
            self.detected_indices = []
        if self.true_byzantine_indices is None:
            self.true_byzantine_indices = []


