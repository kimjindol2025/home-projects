def run_experiments(output_dir: str = "results"):
    """Run full experiment suite"""
    os.makedirs(output_dir, exist_ok=True)

    print("=" * 80)
    print("PHASE 3 EXPERIMENTS: Byzantine-Resilient FL with Adaptive Attacks")
    print("=" * 80)
    print(f"\nStarted: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n")

    simulator = FederatedLearningSimulator(EXPERIMENT_CONFIG)
    all_results = []

    total_runs = (
        EXPERIMENT_CONFIG["num_seeds"] *
        len(EXPERIMENT_CONFIG["byzantine_fractions"]) *
        len(EXPERIMENT_CONFIG["baselines"]) *
        len(EXPERIMENT_CONFIG["attacks"]) *
        EXPERIMENT_CONFIG["num_rounds"]
    )

    run_count = 0

    # Iterate over experiment configurations
    for seed in range(EXPERIMENT_CONFIG["num_seeds"]):
        for byz_frac in EXPERIMENT_CONFIG["byzantine_fractions"]:
            for baseline in EXPERIMENT_CONFIG["baselines"]:
                for attack in EXPERIMENT_CONFIG["attacks"]:
                    # Determine Byzantine clients for this configuration
                    num_byzantine = max(1, int(EXPERIMENT_CONFIG["num_clients"] * byz_frac))
                    byzantine_indices = random.sample(
                        range(EXPERIMENT_CONFIG["num_clients"]), num_byzantine
                    )

                    print(f"Running: seed={seed}, byz_frac={byz_frac:.0%}, "
                          f"baseline={baseline}, attack={attack}")

                    # Run rounds
                    for round_num in range(EXPERIMENT_CONFIG["num_rounds"]):
                        metrics = simulator.run_round(
                            round_num, baseline, attack, byzantine_indices, seed
                        )
                        all_results.append(metrics)

                        run_count += 1
                        if run_count % 50 == 0:
                            print(f"  Progress: {run_count}/{total_runs} ({100*run_count/total_runs:.1f}%)")

    # Save results
    results_file = os.path.join(output_dir, "experiments.csv")
    with open(results_file, "w", newline="") as f:
        writer = csv.DictWriter(f, fieldnames=[
            "round_num", "method", "attack_type", "byzantine_fraction", "seed",
            "model_accuracy", "model_f1", "model_mae",
            "detected_byzantine", "true_byzantine", "detection_precision", "detection_recall", "detection_f1",
            "mttr_rounds", "evasion_count", "aggregation_time_ms", "communication_bytes"
        ])
        writer.writeheader()
        for metrics in all_results:
            row = {
                "round_num": metrics.round_num,
                "method": metrics.method,
                "attack_type": metrics.attack_type,
                "byzantine_fraction": metrics.byzantine_fraction,
                "seed": metrics.seed,
                "model_accuracy": f"{metrics.model_accuracy:.4f}",
                "model_f1": f"{metrics.model_f1:.4f}",
                "model_mae": f"{metrics.model_mae:.4f}",
                "detected_byzantine": metrics.detected_byzantine,
                "true_byzantine": metrics.true_byzantine,
                "detection_precision": f"{metrics.detection_precision:.4f}",
                "detection_recall": f"{metrics.detection_recall:.4f}",
                "detection_f1": f"{metrics.detection_f1:.4f}",
                "mttr_rounds": metrics.mttr_rounds,
                "evasion_count": metrics.evasion_count,
                "aggregation_time_ms": f"{metrics.aggregation_time_ms:.2f}",
                "communication_bytes": metrics.communication_bytes,
            }
            writer.writerow(row)

    print(f"\n✅ Results saved to: {results_file}")
    print(f"📊 Total rounds: {len(all_results)}")
    print(f"\nCompleted: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    print("=" * 80)

    return all_results


if __name__ == "__main__":
    results = run_experiments()
