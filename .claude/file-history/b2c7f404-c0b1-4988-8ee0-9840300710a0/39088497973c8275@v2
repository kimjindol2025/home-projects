# ============================================================================
# Simulation Framework
# ============================================================================

class FederatedLearningSimulator:
    """Simulates federated learning with Byzantine attacks"""

    def __init__(self, config: Dict):
        self.config = config
        self.num_clients = config["num_clients"]
        self.num_tasks = config["num_tasks"]
        self.num_rounds = config["num_rounds"]
        self.grad_dim = config["gradient_dimension"]

    def generate_honest_gradient(self) -> List[float]:
        """Generate honest gradient (small perturbations around 0.1)"""
        return [0.1 + random.gauss(0, 0.02) for _ in range(self.grad_dim)]

    def generate_byzantine_gradient(self) -> List[float]:
        """Generate Byzantine gradient (opposite direction, higher magnitude)"""
        return [-0.5 + random.gauss(0, 0.1) for _ in range(self.grad_dim)]

    def run_round(
        self,
        round_num: int,
        baseline_method: str,
        attack_type: str,
        byzantine_indices: List[int],
        seed: int
    ) -> RoundMetrics:
        """
        Run single federated learning round with attack injection.

        Returns:
            RoundMetrics object
        """
        random.seed(seed + round_num)  # Vary seed per round

        n_clients = self.num_clients
        n_byzantine = len(byzantine_indices)

        # Generate gradients
        client_grads = {}
        for i in range(n_clients):
            if i in byzantine_indices:
                client_grads[i] = self.generate_byzantine_gradient()
            else:
                client_grads[i] = self.generate_honest_gradient()

        # Apply attack
        if attack_type != "no_attack":
            client_grads = self._apply_attack(
                client_grads, attack_type, round_num, byzantine_indices
            )

        # Aggregate using baseline method
        grads_list = [client_grads[i] for i in range(n_clients)]
        agg_grad, agg_meta = aggregate(
            grads_list, method=baseline_method, byzantine_count=n_byzantine
        )

        # Simulate detection (simple heuristic: FLGuard-like anomaly detection)
        detected_indices = self._simulate_detection(grads_list, byzantine_indices)

        # Calculate metrics
        metrics = RoundMetrics(
            round_num=round_num,
            method=baseline_method,
            attack_type=attack_type,
            byzantine_fraction=n_byzantine / n_clients,
            seed=seed,

            # Model performance (simulated)
            model_accuracy=self._simulate_accuracy(attack_type, baseline_method, len(detected_indices)),
            model_f1=0.85,  # Placeholder
            model_mae=0.15,  # Placeholder

            # Detection
            detected_byzantine=len(detected_indices),
            true_byzantine=n_byzantine,
            detection_precision=self._calc_precision(detected_indices, byzantine_indices),
            detection_recall=self._calc_recall(detected_indices, byzantine_indices),
            detection_f1=0.0,  # Will be calculated from precision/recall

            # Recovery (simulated)
            mttr_rounds=self._simulate_mttr(attack_type, baseline_method),
            evasion_count=n_byzantine - len([i for i in detected_indices if i in byzantine_indices]),

            # Computational
            aggregation_time_ms=random.uniform(10, 50),
            communication_bytes=n_clients * self.grad_dim * 4,

            detected_indices=list(detected_indices),
            true_byzantine_indices=byzantine_indices,
        )

        # Calculate F1
        if metrics.detection_precision + metrics.detection_recall > 0:
            metrics.detection_f1 = 2 * (metrics.detection_precision * metrics.detection_recall) / (
                metrics.detection_precision + metrics.detection_recall
            )

        return metrics

    def _apply_attack(
        self, grads: Dict, attack_type: str, round_num: int, byzantine_indices: List[int]
    ) -> Dict:
        """Apply attack to gradients"""
        byzantine_set = set(byzantine_indices)

        if attack_type == "rmc":
            cfg = self.config["attack_config"]["rmc"]
            grads, _ = inject_rmc_attack(
                grads, list(range(len(grads))), round_num,
                byzantine_set, {i: max(0, round_num - 5) for i in byzantine_set},
                cfg["reconnect_probability"], cfg["perturbation_range"]
            )

        elif attack_type == "delayed":
            cfg = self.config["attack_config"]["delayed"]
            grads = inject_delayed_poisoning(
                grads, list(range(len(grads))), byzantine_set, round_num,
                cfg["trigger_round"], cfg["poison_type"]
            )

        elif attack_type == "str_evo":
            cfg = self.config["attack_config"]["str_evo"]
            grads = inject_strategy_evolution(
                grads, list(range(len(grads))), byzantine_set, round_num,
                cfg["evolution_interval"]
            )

        elif attack_type == "collusion_sybil":
            cfg = self.config["attack_config"]["collusion_sybil"]
            grads, _ = inject_collusion_sybil(
                grads, list(range(len(grads))), byzantine_set,
                cfg["sybil_multiplier"], cfg["coordination_scale"]
            )

        return grads

    def _simulate_detection(self, grads: List, true_byzantine: List) -> List[int]:
        """Simulate Byzantine detection (heuristic)"""
        detected = []
        true_set = set(true_byzantine)

        for i, grad in enumerate(grads):
            # Simple heuristic: Check gradient magnitude
            magnitude = sum(g ** 2 for g in grad) ** 0.5
            if magnitude > 0.3:  # Threshold
                detected.append(i)

        return detected

    def _simulate_accuracy(self, attack_type: str, method: str, detected_count: int) -> float:
        """Simulate model accuracy based on attack + method + detection"""
        # Base accuracy
        base_acc = 0.92

        # Attack impact
        attack_impact = {
            "no_attack": 0.0,
            "rmc": -0.08,
            "delayed": -0.10,
            "str_evo": -0.12,
            "collusion_sybil": -0.15,
            "task_specific": -0.05,
        }

        # Method robustness
        method_bonus = {
            "fedavg": 0.0,
            "krum": 0.05,
            "multi_krum": 0.06,
            "trimmed_mean": 0.07,
            "flguard": 0.08,
            "optgradtrust": 0.10,
        }

        # Detection bonus (0.02 per detected Byzantine, max +0.1)
        detection_bonus = min(0.1, detected_count * 0.02)

        accuracy = base_acc + attack_impact.get(attack_type, 0) + method_bonus.get(method, 0) + detection_bonus
        return max(0.5, min(0.95, accuracy))

    def _simulate_mttr(self, attack_type: str, method: str) -> int:
        """Simulate MTTR (mean time to recovery)"""
        # Base MTTR
        mttr_base = {
            "no_attack": 0,
            "rmc": 15,
            "delayed": 20,
            "str_evo": 18,
            "collusion_sybil": 25,
            "task_specific": 12,
        }

        # Method efficiency
        mttr_factor = {
            "fedavg": 2.0,
            "krum": 1.5,
            "multi_krum": 1.4,
            "trimmed_mean": 1.3,
            "flguard": 1.2,
            "optgradtrust": 0.8,
        }

        mttr = mttr_base.get(attack_type, 0) * mttr_factor.get(method, 1.0)
        return int(max(0, mttr + random.gauss(0, 2)))

    def _calc_precision(self, detected: List[int], true_byzantine: List[int]) -> float:
        """Calculate detection precision"""
        detected_set = set(detected)
        true_set = set(true_byzantine)

        tp = len(detected_set & true_set)
        fp = len(detected_set - true_set)

        if tp + fp == 0:
            return 1.0 if len(true_set) == 0 else 0.0
        return tp / (tp + fp)

    def _calc_recall(self, detected: List[int], true_byzantine: List[int]) -> float:
        """Calculate detection recall"""
        detected_set = set(detected)
        true_set = set(true_byzantine)

        tp = len(detected_set & true_set)
        fn = len(true_set - detected_set)

        if tp + fn == 0:
            return 1.0
        return tp / (tp + fn)


