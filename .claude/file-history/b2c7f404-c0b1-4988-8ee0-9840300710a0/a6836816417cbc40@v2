#!/usr/bin/env python3
"""
Statistical Analysis for BR-AIOpsFL Experiments
================================================
Computes:
- Wilcoxon signed-rank test (pairwise baseline vs OptiGradTrust)
- 95% Confidence Intervals
- ANOVA across Byzantine fractions
- Generates publication-ready tables with p-values
"""

import csv
import json
import statistics
import math
from pathlib import Path
from typing import List, Dict, Tuple
from scipy import stats
import pandas as pd

class StatsAnalyzer:
    def __init__(self, csv_file: str = "results/experiments.csv"):
        self.csv_file = Path(csv_file)
        self.data = pd.read_csv(self.csv_file)
        self.results = {}

    def compute_wilcoxon_pairwise(self):
        """
        Compute Wilcoxon signed-rank test comparing each baseline vs OptiGradTrust.
        Returns dictionary of p-values and effect sizes.
        """
        print("🔬 Wilcoxon Signed-Rank Test (Baseline vs OptiGradTrust)")
        print("─" * 80)

        baselines = ['FedAvg', 'Krum', 'Multi-Krum', 'Trimmed Mean', 'FLGuard', 'OptiGradTrust']
        results = {}

        for baseline in baselines:
            if baseline == 'OptiGradTrust':
                continue

            # Extract accuracy values for baseline and OptiGradTrust
            baseline_acc = self.data[self.data['method'] == baseline]['model_accuracy'].values
            optiguradtrust_acc = self.data[self.data['method'] == 'OptiGradTrust']['model_accuracy'].values

            if len(baseline_acc) > 0 and len(optiguradtrust_acc) > 0:
                # Ensure paired data (same length or match by index)
                min_len = min(len(baseline_acc), len(optiguradtrust_acc))
                baseline_acc = baseline_acc[:min_len]
                optiguradtrust_acc = optiguradtrust_acc[:min_len]

                # Wilcoxon signed-rank test (non-parametric, paired)
                statistic, p_value = stats.wilcoxon(baseline_acc, optiguradtrust_acc, alternative='two-sided')

                # Effect size: Cohen's d
                mean_diff = optiguradtrust_acc.mean() - baseline_acc.mean()
                pooled_std = math.sqrt((baseline_acc.std()**2 + optiguradtrust_acc.std()**2) / 2)
                cohens_d = mean_diff / pooled_std if pooled_std > 0 else 0

                results[baseline] = {
                    'p_value': p_value,
                    'statistic': statistic,
                    'cohens_d': cohens_d,
                    'baseline_mean': baseline_acc.mean(),
                    'baseline_std': baseline_acc.std(),
                    'optiguradtrust_mean': optiguradtrust_acc.mean(),
                    'optiguradtrust_std': optiguradtrust_acc.std(),
                    'mean_diff': mean_diff
                }

                significance = "✓✓ (p<0.001)" if p_value < 0.001 else \
                              "✓ (p<0.05)" if p_value < 0.05 else \
                              "n.s. (p≥0.05)"

                print(f"  {baseline:20} vs OptiGradTrust:")
                print(f"    Accuracy: {baseline_acc.mean():.4f}±{baseline_acc.std():.4f} vs {optiguradtrust_acc.mean():.4f}±{optiguradtrust_acc.std():.4f}")
                print(f"    Wilcoxon p-value: {p_value:.3e} {significance}")
                print(f"    Cohen's d: {cohens_d:.4f} (effect size)")
                print()

        self.results['wilcoxon'] = results
        return results

    def compute_confidence_intervals(self, confidence_level: float = 0.95):
        """
        Compute 95% confidence intervals for all methods and metrics.
        """
        print("📊 95% Confidence Intervals (by Method & Metric)")
        print("─" * 80)

        baselines = self.data['method'].unique()
        results = {}

        for baseline in baselines:
            baseline_data = self.data[self.data['method'] == baseline]

            accuracy_values = baseline_data['model_accuracy'].values
            detection_f1_values = baseline_data['detection_f1'].values
            mttr_values = baseline_data['mttr_rounds'].values

            # Compute CI for each metric
            accuracy_ci = self._compute_ci(accuracy_values, confidence_level)
            f1_ci = self._compute_ci(detection_f1_values, confidence_level)
            mttr_ci = self._compute_ci(mttr_values, confidence_level)

            results[baseline] = {
                'accuracy': accuracy_ci,
                'detection_f1': f1_ci,
                'mttr': mttr_ci
            }

            print(f"  {baseline}:")
            print(f"    Accuracy:  {accuracy_values.mean():.4f} [{accuracy_ci['lower']:.4f}, {accuracy_ci['upper']:.4f}]")
            print(f"    Detection F1: {detection_f1_values.mean():.4f} [{f1_ci['lower']:.4f}, {f1_ci['upper']:.4f}]")
            print(f"    MTTR:      {mttr_values.mean():.1f} [{mttr_ci['lower']:.1f}, {mttr_ci['upper']:.1f}] rounds")
            print()

        self.results['confidence_intervals'] = results
        return results

    def compute_anova_by_byzantine_fraction(self):
        """
        Compute one-way ANOVA comparing accuracy across Byzantine fractions (10%, 20%, 30%).
        Tests null hypothesis: all Byzantine fractions have equal mean accuracy.
        """
        print("📈 One-Way ANOVA: Accuracy Stability Across Byzantine Fractions")
        print("─" * 80)

        fractions = self.data['byzantine_fraction'].unique()
        fractions = sorted([f for f in fractions if f is not None and f > 0])

        groups = {}
        for frac in fractions:
            frac_data = self.data[self.data['byzantine_fraction'] == frac]
            accuracy_values = frac_data['model_accuracy'].values
            groups[frac] = accuracy_values

            print(f"  Byzantine Fraction {frac*100:.0f}%:")
            print(f"    Mean Accuracy: {accuracy_values.mean():.4f} ± {accuracy_values.std():.4f}")
            print(f"    N: {len(accuracy_values)} samples")
            print()

        # ANOVA
        if len(groups) > 1:
            f_stat, p_value = stats.f_oneway(*groups.values())
            print(f"  ANOVA Results:")
            print(f"    F-statistic: {f_stat:.4f}")
            print(f"    p-value: {p_value:.3e}")

            if p_value > 0.05:
                print(f"    ✓ Conclusion: NO significant difference across Byzantine fractions (p≥0.05)")
                print(f"      → Baseline methods scale robustly to Byzantine ratio increases")
            else:
                print(f"    ✗ Conclusion: Significant difference detected (p<0.05)")

            self.results['anova'] = {'f_stat': f_stat, 'p_value': p_value}

    def compute_attack_impact_statistics(self):
        """
        Compute statistics for each attack type relative to No Attack control.
        """
        print("🎯 Attack Impact Analysis (vs No Attack Control)")
        print("─" * 80)

        attacks = self.data['attack_type'].unique()
        results = {}

        control_acc = self.data[self.data['attack_type'] == 'No Attack']['model_accuracy'].values
        control_mean = control_acc.mean() if len(control_acc) > 0 else 0.95

        for attack in attacks:
            attack_data = self.data[self.data['attack_type'] == attack]
            accuracy_values = attack_data['model_accuracy'].values

            if len(accuracy_values) == 0:
                continue

            attack_mean = accuracy_values.mean()
            attack_std = accuracy_values.std()
            accuracy_drop = control_mean - attack_mean
            drop_pct = (accuracy_drop / control_mean) * 100 if control_mean > 0 else 0

            # t-test: attack vs control
            if len(control_acc) > 0:
                t_stat, p_value = stats.ttest_ind(control_acc, accuracy_values)
            else:
                p_value = 1.0

            significance = "p<0.001 ✓✓" if p_value < 0.001 else \
                          "p<0.05 ✓" if p_value < 0.05 else \
                          "n.s. (p≥0.05)"

            results[attack] = {
                'mean': attack_mean,
                'std': attack_std,
                'drop': accuracy_drop,
                'drop_pct': drop_pct,
                'p_value': p_value
            }

            print(f"  {attack}:")
            print(f"    Accuracy: {attack_mean:.4f} ± {attack_std:.4f}")
            print(f"    Drop vs Control: {accuracy_drop:.4f} ({drop_pct:.1f}%)")
            print(f"    Significance: {significance}")
            print()

        self.results['attack_impact'] = results

    def _compute_ci(self, values: List[float], confidence_level: float = 0.95) -> Dict:
        """
        Compute confidence interval for a set of values.
        Uses t-distribution for small samples.
        """
        if len(values) < 2:
            return {'lower': values[0] if len(values) > 0 else 0,
                    'upper': values[0] if len(values) > 0 else 0}

        mean = statistics.mean(values)
        std = statistics.stdev(values)
        n = len(values)

        # t-critical value for 95% CI
        alpha = 1 - confidence_level
        t_critical = stats.t.ppf(1 - alpha/2, df=n-1)

        margin_of_error = t_critical * std / math.sqrt(n)

        return {
            'mean': mean,
            'std': std,
            'lower': mean - margin_of_error,
            'upper': mean + margin_of_error,
            'margin_of_error': margin_of_error
        }

    def generate_publication_table(self, output_file: str = "results/stats_summary.json"):
        """
        Generate a publication-ready summary table with all statistics.
        """
        print("\n" + "="*80)
        print("📄 Generating Publication-Ready Summary Table")
        print("="*80)

        summary = {
            'wilcoxon_results': self.results.get('wilcoxon', {}),
            'confidence_intervals': self.results.get('confidence_intervals', {}),
            'anova_results': self.results.get('anova', {}),
            'attack_impact': self.results.get('attack_impact', {})
        }

        with open(output_file, 'w') as f:
            json.dump(summary, f, indent=2, default=str)

        print(f"✅ Summary written to {output_file}")


def main():
    """Main entry point."""
    print("🔬 BR-AIOpsFL Statistical Analysis")
    print("="*80)
    print()

    analyzer = StatsAnalyzer(csv_file="results/experiments.csv")

    # Run all analyses
    analyzer.compute_wilcoxon_pairwise()
    analyzer.compute_confidence_intervals()
    analyzer.compute_anova_by_byzantine_fraction()
    analyzer.compute_attack_impact_statistics()
    analyzer.generate_publication_table()

    print("\n✅ All statistical analyses complete!")


if __name__ == "__main__":
    main()
