class TestTrajectoryDetector(unittest.TestCase):
    """Test Suite B: Trajectory Detection"""

    def test_B01_trajectory_detector_basic(self):
        """Test B01: Basic trajectory detection"""
        detector = TrajectoryDetector(trajectory_window_size=5, detection_threshold=0.7)

        gradients = [
            ClientGradient(f"client_{i}", f"task_0", [random.gauss(0, 0.1) for _ in range(10)])
            for i in range(10)
        ]

        detected, scores = detector.detect_malicious(gradients)

        self.assertIsInstance(detected, set)
        self.assertIsInstance(scores, dict)
        self.assertEqual(len(scores), len(gradients))

    def test_B02_trajectory_detector_identifies_malicious_pattern(self):
        """Test B02: Trajectory detector identifies malicious pattern"""
        detector = TrajectoryDetector(trajectory_window_size=5, detection_threshold=0.5)

        # Create client with anomalous pattern (high variance)
        malicious_gradients = [
            ClientGradient("malicious_client", "task_0", [random.gauss(3, 2) for _ in range(10)])
            for _ in range(10)
        ]

        detected, _ = detector.detect_malicious(malicious_gradients)

        # Should detect malicious pattern
        self.assertIn("malicious_client", detected)

    def test_B03_trajectory_detector_window_size(self):
        """Test B03: Trajectory window size enforcement"""
        detector = TrajectoryDetector(trajectory_window_size=3, detection_threshold=0.7)

        # Run 5 rounds
        for round_num in range(5):
            gradients = [
                ClientGradient(f"client_{i}", "task_0", [random.gauss(0, 0.1) for _ in range(10)])
                for i in range(5)
            ]
            detector.detect_malicious(gradients)

        # Check window size
        for client_id, trajectory in detector.trajectories.items():
            self.assertLessEqual(len(trajectory), 3)

    def test_B04_trajectory_detector_logging(self):
        """Test B04: Trajectory detection logging"""
        detector = TrajectoryDetector()

        gradients = [ClientGradient("client_0", "task_0", [0.5] * 10)]
        detected, scores = detector.detect_malicious(gradients)

        # Check logs
        self.assertIn("client_0", detector.detection_logs)
        self.assertGreater(len(detector.detection_logs["client_0"]), 0)

