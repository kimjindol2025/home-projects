class TestIsolationForest(unittest.TestCase):
    """Test Suite A: Isolation Forest"""

    def test_A01_isolation_forest_basic(self):
        """Test A01: Isolation Forest basic anomaly detection"""
        iso_forest = IsolationForest(num_trees=10, contamination=0.1)

        # Create normal and anomalous vectors
        normal_vectors = [[random.gauss(0, 0.1) for _ in range(10)] for _ in range(20)]
        anomalous_vectors = [[random.gauss(5, 0.5) for _ in range(10)] for _ in range(5)]

        all_vectors = normal_vectors + anomalous_vectors
        scores = iso_forest.compute_anomaly_score(all_vectors)

        self.assertEqual(len(scores), 25)
        self.assertTrue(all(0 <= s <= 1 for s in scores))

        # Anomalies should have higher scores
        avg_normal_score = sum(scores[:20]) / 20
        avg_anomaly_score = sum(scores[20:]) / 5

        self.assertGreater(avg_normal_score, avg_anomaly_score)

    def test_A02_isolation_forest_empty_input(self):
        """Test A02: Isolation Forest with empty input"""
        iso_forest = IsolationForest()
        scores = iso_forest.compute_anomaly_score([])
        self.assertEqual(scores, [])

    def test_A03_isolation_forest_single_sample(self):
        """Test A03: Isolation Forest with single sample"""
        iso_forest = IsolationForest()
        vectors = [[1.0, 2.0, 3.0]]
        scores = iso_forest.compute_anomaly_score(vectors)
        self.assertEqual(len(scores), 1)
        self.assertTrue(0 <= scores[0] <= 1)

    def test_A04_isolation_forest_deterministic(self):
        """Test A04: Isolation Forest produces deterministic scores"""
        iso_forest1 = IsolationForest(random_state=42)
        iso_forest2 = IsolationForest(random_state=42)

        vectors = [[random.gauss(0, 1) for _ in range(10)] for _ in range(10)]

        scores1 = iso_forest1.compute_anomaly_score(vectors)
        scores2 = iso_forest2.compute_anomaly_score(vectors)

        self.assertEqual(scores1, scores2)

