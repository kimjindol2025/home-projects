class TestBRAAIOpsFL(unittest.TestCase):
    """Test Suite E: Integration Tests"""

    def test_E01_braiopsfl_initialization(self):
        """Test E01: BR-AIOpsFL initialization"""
        system = BRAAIOpsFL(num_clients=30, num_tasks=3, byzantine_fraction=0.2)

        self.assertEqual(len(system.client_ids), 30)
        self.assertEqual(len(system.task_ids), 3)
        self.assertEqual(len(system.byzantine_clients), 6)

    def test_E02_braiopsfl_gradient_generation(self):
        """Test E02: Gradient generation in system"""
        system = BRAAIOpsFL(num_clients=20, num_tasks=2)

        gradients = system.generate_gradients(round_num=0)

        self.assertEqual(len(gradients), 2)
        for task_id in system.task_ids:
            self.assertIn(task_id, gradients)

    def test_E03_braiopsfl_single_round(self):
        """Test E03: Single round execution"""
        system = BRAAIOpsFL(num_clients=15, num_tasks=2, byzantine_fraction=0.2)

        result = system.run_round(round_num=0, current_epoch=0)

        self.assertIn('round', result)
        self.assertIn('detected_malicious', result)
        self.assertIn('detection_rate', result)

    def test_E04_braiopsfl_multi_round_simulation(self):
        """Test E04: Multi-round simulation"""
        system = BRAAIOpsFL(num_clients=20, num_tasks=2)

        sim_result = system.simulate(num_rounds=5)

        self.assertEqual(sim_result['total_rounds'], 5)
        self.assertEqual(len(sim_result['results']), 5)
        self.assertGreater(sim_result['avg_detection_rate'], 0.0)

    def test_E05_braiopsfl_credibility_update(self):
        """Test E05: Credibility score updates"""
        system = BRAAIOpsFL(num_clients=20, num_tasks=2)

        initial_creds = system.credibility_scores.copy()

        system.run_round(0, 0)

        # Some credibility scores should change
        changed = sum(1 for cid in system.client_ids
                     if system.credibility_scores[cid] != initial_creds[cid])
        self.assertGreater(changed, 0)

    def test_E06_braiopsfl_model_update(self):
        """Test E06: Global model parameters updated"""
        system = BRAAIOpsFL(num_clients=20, num_tasks=2)

        initial_models = {task: model[:] for task, model in system.global_models.items()}

        system.run_round(0, 0)

        # Models should change
        changed_tasks = sum(1 for task in system.task_ids
                           if system.global_models[task] != initial_models[task])
        self.assertGreater(changed_tasks, 0)

    def test_E07_braiopsfl_detection_accuracy(self):
        """Test E07: Detection accuracy metrics"""
        system = BRAAIOpsFL(num_clients=30, num_tasks=3, byzantine_fraction=0.2)

        system.simulate(num_rounds=10)

        # Check detection rate is reasonable
        # (Should be between 0% and 100%)
        self.assertGreaterEqual(len(system.dpos.slashing_events), 0)

    def test_E08_braiopsfl_quarantine_records(self):
        """Test E08: Quarantine records maintained"""
        system = BRAAIOpsFL(num_clients=20, num_tasks=2)

        system.run_round(0, 0)

        # Quarantine records should exist
        self.assertIsInstance(system.dpos.quarantine_records, dict)

    def test_E09_braiopsfl_stake_changes(self):
        """Test E09: Stake changes from slashing"""
        system = BRAAIOpsFL(num_clients=20, num_tasks=2)

        initial_total_stake = sum(system.client_stakes.values())

        system.run_round(0, 0)

        final_total_stake = sum(system.client_stakes.values())

        # Total stake should not increase (only slashing happens)
        self.assertLessEqual(final_total_stake, initial_total_stake)

    def test_E10_braiopsfl_end_to_end(self):
        """Test E10: End-to-end full system test"""
        print("\n  Running E10: End-to-end test...")

        system = BRAAIOpsFL(num_clients=25, num_tasks=3, byzantine_fraction=0.15)

        result = system.simulate(num_rounds=15)

        # Verify output
        self.assertEqual(result['total_rounds'], 15)
        self.assertGreater(result['avg_detection_rate'], 0.0)
        self.assertGreaterEqual(len(system.dpos.quarantine_records), 0)

        print(f"  ✓ E10 passed: {result['total_rounds']} rounds, "
              f"avg detection {result['avg_detection_rate']:.1%}")

