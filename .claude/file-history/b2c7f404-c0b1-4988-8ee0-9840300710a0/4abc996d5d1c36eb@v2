class TestTaskAwareAggregator(unittest.TestCase):
    """Test Suite C: Task-Aware Aggregation"""

    def test_C01_aggregator_weighted_mean(self):
        """Test C01: Weighted mean aggregation"""
        aggregator = TaskAwareAggregator(aggregation_method=AggregationMethod.WEIGHTED_MEAN)

        task_gradients = {
            "task_0": [
                ClientGradient("client_0", "task_0", [1.0, 2.0, 3.0]),
                ClientGradient("client_1", "task_0", [2.0, 3.0, 4.0])
            ]
        }

        credibility = {"client_0": 0.6, "client_1": 0.4}
        detected = {"task_0": set()}

        result = aggregator.aggregate(task_gradients, credibility, detected)

        self.assertIn("task_0", result)
        self.assertEqual(len(result["task_0"]), 3)

    def test_C02_aggregator_excludes_malicious(self):
        """Test C02: Aggregator excludes malicious clients"""
        aggregator = TaskAwareAggregator()

        task_gradients = {
            "task_0": [
                ClientGradient("honest_0", "task_0", [1.0, 2.0, 3.0]),
                ClientGradient("malicious_0", "task_0", [10.0, 20.0, 30.0])
            ]
        }

        credibility = {"honest_0": 0.8, "malicious_0": 0.1}
        detected = {"task_0": {"malicious_0"}}

        result = aggregator.aggregate(task_gradients, credibility, detected)

        # Aggregated result should be closer to honest client's gradient
        self.assertLess(result["task_0"][0], 6.0)

    def test_C03_aggregator_multi_task(self):
        """Test C03: Multi-task aggregation"""
        aggregator = TaskAwareAggregator()

        task_gradients = {
            "task_0": [ClientGradient(f"client_{i}", "task_0", [float(i)] * 5) for i in range(3)],
            "task_1": [ClientGradient(f"client_{i}", "task_1", [float(i)*2] * 5) for i in range(3)]
        }

        credibility = {f"client_{i}": 0.5 for i in range(3)}
        detected = {"task_0": set(), "task_1": set()}

        result = aggregator.aggregate(task_gradients, credibility, detected)

        self.assertEqual(len(result), 2)
        self.assertIn("task_0", result)
        self.assertIn("task_1", result)

    def test_C04_aggregator_task_correlation(self):
        """Test C04: Task correlation computation"""
        aggregator = TaskAwareAggregator()

        task_gradients = {
            "task_0": [ClientGradient("c0", "task_0", [1.0, 2.0, 3.0])],
            "task_1": [ClientGradient("c0", "task_1", [1.0, 2.0, 3.0])]
        }

        correlation = aggregator._compute_correlation_matrix(task_gradients)

        # Same task should have perfect correlation
        self.assertEqual(correlation[0][0], 1.0)
        self.assertEqual(correlation[1][1], 1.0)

