class TestDPoSQuarantine(unittest.TestCase):
    """Test Suite D: DPoS Quarantine & Slashing"""

    def test_D01_dpos_quarantine_basic(self):
        """Test D01: Basic DPoS quarantine"""
        dpos = DPoSQuarantine(num_validators=21, slash_rate=0.05)

        detected = {"client_0", "client_1"}
        stakes = {"client_0": 100.0, "client_1": 100.0}

        result = dpos.quarantine_and_slash(detected, current_epoch=0, client_stakes=stakes)

        self.assertIn("quarantine_updates", result)
        self.assertIn("stake_changes", result)
        self.assertIn("slashing_events", result)

    def test_D02_dpos_slashing_amount(self):
        """Test D02: Slashing amount calculation"""
        dpos = DPoSQuarantine(slash_rate=0.1)

        detected = {"client_0"}
        stakes = {"client_0": 100.0}

        result = dpos.quarantine_and_slash(detected, 0, stakes)

        if "client_0" in result["stake_changes"]:
            changes = result["stake_changes"]["client_0"]
            expected_slashed = 100.0 * 0.1
            self.assertAlmostEqual(changes["slashed"], expected_slashed, places=2)

    def test_D03_dpos_quarantine_duration(self):
        """Test D03: Quarantine release epoch calculation"""
        dpos = DPoSQuarantine(quarantine_duration=3)

        detected = {"client_0"}
        stakes = {"client_0": 100.0}

        result = dpos.quarantine_and_slash(detected, current_epoch=5, client_stakes=stakes)

        if "client_0" in result["quarantine_updates"]:
            record = result["quarantine_updates"]["client_0"]
            expected_release = 5 + 3
            self.assertEqual(record.release_epoch, expected_release)

    def test_D04_dpos_epoch_advance(self):
        """Test D04: Epoch advancement and release eligibility"""
        dpos = DPoSQuarantine(quarantine_duration=2)

        detected = {"client_0"}
        stakes = {"client_0": 100.0}

        # Quarantine at epoch 0
        dpos.quarantine_and_slash(detected, 0, stakes)

        # Advance to epoch 2
        dpos.advance_epoch(2, stakes)

        # Check if release eligible
        record = dpos.quarantine_records.get("client_0")
        if record:
            self.assertEqual(record.status, QuarantineStatus.RELEASE_ELIGIBLE)

