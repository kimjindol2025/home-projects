    detector = TrajectoryDetector(window_size=5)

    # Round 1-4: 정상 점수
    # Round 5: 갑자기 높은 점수 (재연결)

    # 5-round 윈도우가 이 패턴을 감지해야 함
    detected = detector.detect_malicious(trajectory)
