```python
# test_E10: End-to-end 시뮬레이션
def test_E10_braiopsfl_end_to_end():
    system = BRAAIOpsFL(num_clients=100, num_tasks=3)

    # 10 라운드 시뮬레이션 + 20% Byzantine
    results = system.run_simulation(rounds=10, byzantine_fraction=0.2)

    # 검증 항목:
    # - 정확도 > 90%
    # - Byzantine 탐지율 > 70%
    # - MTTR < 5 라운드

    assert results['accuracy'] > 0.9
    assert results['detection_f1'] > 0.7
    assert results['mttr'] < 5
```

