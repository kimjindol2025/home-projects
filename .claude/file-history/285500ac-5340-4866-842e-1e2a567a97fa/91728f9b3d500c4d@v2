CC        := gcc
CSTD      := -std=c11
WARNINGS  := -Wall -Wextra -Wpedantic
DEBUG     := -g3 -fno-omit-frame-pointer
PLATFORM  := -fPIC -pthread -D_GNU_SOURCE

# 환경별 최적화 레벨
ifdef DEBUG_MODE
  OPTIMIZE := -Og
else
  OPTIMIZE := -O2
endif

CFLAGS    := $(CSTD) $(WARNINGS) $(DEBUG) $(OPTIMIZE) $(PLATFORM)
LDFLAGS   := -lm -lpthread

SRCDIR = src
OBJDIR = build
TARGET = build/main

SOURCES = $(wildcard $(SRCDIR)/*.c)
OBJECTS = $(SOURCES:$(SRCDIR)/%.c=$(OBJDIR)/%.o)

all: $(OBJDIR) $(TARGET)

$(OBJDIR):
	@mkdir -p $(OBJDIR)

$(TARGET): $(OBJECTS)
	@echo "🔗 링킹: $@"
	$(CC) $(CFLAGS) $(LDFLAGS) -o $@ $^

$(OBJDIR)/%.o: $(SRCDIR)/%.c
	@echo "🔨 컴파일: $< (std=c11, O2)"
	$(CC) $(CFLAGS) -c $< -o $@

clean:
	@echo "🧹 정리..."
	@rm -rf $(OBJDIR) $(TARGET)

run: $(TARGET)
	@echo "▶️ 실행..."
	@./$(TARGET)

debug: clean
	@make DEBUG_MODE=1 all

.PHONY: all clean run debug
