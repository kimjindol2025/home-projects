/// benchmark.zig - Zig Learning 벤치마크
///
/// 성능 벤치마킹 도구

const std = @import("std");
const template = @import("template.zig");

pub fn main() !void {
    var gpa = std.heap.GeneralPurposeAllocator(.{}){};
    defer _ = gpa.deinit();
    const allocator = gpa.allocator();

    const stdout = std.io.getStdOut().writer();

    try stdout.print("🔬 Zig Learning 벤치마크 v1.1\n\n", .{});

    // ============================================================================
    // 1️⃣ add 함수 벤치마크
    // ============================================================================

    try stdout.print("1️⃣ add 함수 벤치마크\n", .{});
    var timer = try std.time.Timer.start();

    for (0..1_000_000) |_| {
        _ = template.add(2, 3);
    }

    const add_time = timer.read();
    try stdout.print("  - 1,000,000 calls: {}ns\n", .{add_time});
    try stdout.print("  - 평균: {}ns/call\n\n", .{add_time / 1_000_000});

    // ============================================================================
    // 2️⃣ sum 함수 벤치마크
    // ============================================================================

    try stdout.print("2️⃣ sum 함수 벤치마크\n", .{});
    const arr = [_]i32{ 1, 2, 3, 4, 5 };
    timer = try std.time.Timer.start();

    for (0..100_000) |_| {
        _ = template.sum(&arr);
    }

    const sum_time = timer.read();
    try stdout.print("  - 100,000 calls: {}ns\n", .{sum_time});
    try stdout.print("  - 평균: {}ns/call\n\n", .{sum_time / 100_000});

    // ============================================================================
    // 3️⃣ TaskResult 벤치마크
    // ============================================================================

    try stdout.print("3️⃣ TaskResult 벤치마크\n", .{});
    timer = try std.time.Timer.start();

    for (0..10_000) |i| {
        var id_buf: [32]u8 = undefined;
        const id_str = try std.fmt.bufPrint(&id_buf, "task-{}", .{i});

        var result = try template.TaskResult.init(allocator, id_str, .pending);
        result.status = .completed;
        result.duration_ms = 100;
        result.deinit(allocator);
    }

    const task_result_time = timer.read();
    try stdout.print("  - 10,000 allocations: {}ns\n", .{task_result_time});
    try stdout.print("  - 평균: {}ns/allocation\n\n", .{task_result_time / 10_000});

    // ============================================================================
    // 4️⃣ DefaultProcessor 벤치마크
    // ============================================================================

    try stdout.print("4️⃣ DefaultProcessor 벤치마크\n", .{});
    const processor = template.DefaultProcessor.init(4);

    timer = try std.time.Timer.start();

    for (0..1_000) |i| {
        var id_buf: [32]u8 = undefined;
        const id_str = try std.fmt.bufPrint(&id_buf, "proc-{}", .{i});

        var result = try processor.process(allocator, id_str, "test-data");
        result.deinit(allocator);
    }

    const processor_time = timer.read();
    try stdout.print("  - 1,000 processings: {}ns\n", .{processor_time});
    try stdout.print("  - 평균: {}ns/processing\n\n", .{processor_time / 1_000});

    // ============================================================================
    // 5️⃣ TaskQueue 벤치마크
    // ============================================================================

    try stdout.print("5️⃣ TaskQueue 벤치마크\n", .{});
    var queue = template.TaskQueue(i32).init(allocator, 1000);
    defer queue.deinit();

    timer = try std.time.Timer.start();

    for (0..1_000) |i| {
        try queue.enqueue(@intCast(i));
    }

    const enqueue_time = timer.read();
    try stdout.print("  - 1,000 enqueues: {}ns\n", .{enqueue_time});
    try stdout.print("  - 평균: {}ns/enqueue\n", .{enqueue_time / 1_000});

    timer = try std.time.Timer.start();

    while (queue.dequeue()) |_| {}

    const dequeue_time = timer.read();
    try stdout.print("  - 1,000 dequeues: {}ns\n", .{dequeue_time});
    try stdout.print("  - 평균: {}ns/dequeue\n\n", .{dequeue_time / 1_000});

    // ============================================================================
    // 6️⃣ filter 벤치마크
    // ============================================================================

    try stdout.print("6️⃣ filter 함수 벤치마크\n", .{});
    const is_even = struct {
        fn call(x: i32) bool {
            return x % 2 == 0;
        }
    }.call;

    const large_arr: [100]i32 = undefined;
    timer = try std.time.Timer.start();

    for (0..10_000) |_| {
        var result = try template.filter(allocator, &large_arr, is_even);
        result.deinit();
    }

    const filter_time = timer.read();
    try stdout.print("  - 10,000 filter calls: {}ns\n", .{filter_time});
    try stdout.print("  - 평균: {}ns/filter\n\n", .{filter_time / 10_000});

    // ============================================================================
    // 7️⃣ 완료
    // ============================================================================

    try stdout.print("🎉 벤치마크 완료!\n", .{});
    try stdout.print("기록이 증명이다 - Zig 성능\n", .{});
}
