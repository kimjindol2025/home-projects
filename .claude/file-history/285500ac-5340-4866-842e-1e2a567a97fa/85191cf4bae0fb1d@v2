### 단위 테스트

```typescript
import { Parser } from "../src/compiler/parser";
import { Token } from "../src/types";

describe("Parser", () => {
  let parser: Parser;

  beforeEach(() => {
    const tokens: Token[] = [
      { type: "keyword", value: "define", line: 1, column: 0 },
      { type: "identifier", value: "myFunc", line: 1, column: 7 },
    ];
    parser = new Parser(tokens);
  });

  test("should parse function definition", () => {
    const result = parser.parse();
    expect(result.bytecode).toBeInstanceOf(Uint8Array);
  });

  test("should extract symbols from tokens", () => {
    const result = parser.parse();
    expect(result.symbols.size).toBeGreaterThan(0);
  });

  test("should handle empty token list", () => {
    const emptyParser = new Parser([]);
    expect(() => emptyParser.parse()).not.toThrow();
  });
});
```

### 통합 테스트

```typescript
describe("Compiler Integration", () => {
  test("should compile and execute valid program", async () => {
    const source = `
      (define myFunc (+ 1 2))
    `;
    const program = compiler.compile(source);
    const result = executor.execute(program);
    expect(result).toBe(3);
  });

  test("should catch syntax errors", () => {
    const invalidSource = `(define`;
    expect(() => {
      compiler.compile(invalidSource);
    }).toThrow(CompilationError);
  });
});
