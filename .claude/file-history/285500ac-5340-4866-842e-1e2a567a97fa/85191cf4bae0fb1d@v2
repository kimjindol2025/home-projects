// ✅ 완벽한 타입 힌팅
interface Token {
  type: "identifier" | "keyword" | "operator";
  value: string;
  line: number;
  column: number;
}

interface ParsingContext {
  tokens: Token[];
  position: number;
  errors: CompilationError[];
}

interface CompiledProgram {
  bytecode: Uint8Array;
  symbols: Map<string, Symbol>;
  sourceMap?: SourceMap;
}

class Parser {
  private context: ParsingContext;

  constructor(tokens: Token[]) {
    this.context = {
      tokens,
      position: 0,
      errors: [],
    };
  }

  public parse(): CompiledProgram {
    const bytecode = this.parseTokens();
    return {
      bytecode,
      symbols: this.extractSymbols(),
    };
  }

  private parseTokens(): Uint8Array {
    const buffer: number[] = [];
    // 파싱 로직
    return new Uint8Array(buffer);
  }

  private extractSymbols(): Map<string, Symbol> {
    return new Map();
  }
}

