## 📋 체크리스트 예제

```rust
// ✅ 완벽한 모듈

/// 양자 회로를 정의합니다.
#[derive(Debug, Clone)]
pub struct QuantumCircuit {
    gates: Vec<Gate>,
}

impl QuantumCircuit {
    /// 새로운 회로를 생성합니다.
    pub fn new() -> Self {
        Self { gates: Vec::new() }
    }

    /// 게이트를 추가합니다.
    ///
    /// # Errors
    ///
    /// 게이트가 유효하지 않으면 오류를 반환합니다.
    pub fn add_gate(&mut self, gate: Gate) -> Result<(), CircuitError> {
        self.gates.push(gate);
        Ok(())
    }
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_circuit_creation() {
        let circuit = QuantumCircuit::new();
        assert!(circuit.gates.is_empty());
    }

    #[test]
    fn test_add_gate() {
        let mut circuit = QuantumCircuit::new();
        let gate = Gate::H(0);
        assert!(circuit.add_gate(gate).is_ok());
    }
}

// ❌ 나쁜 모듈
pub struct Circuit {
    g: Vec<u32>,  // 약자 사용
}

impl Circuit {
    pub fn new() -> Self {  // 문서화 없음
        Self { g: Vec::new() }
    }

    pub fn add_gate(&mut self, gate: u32) {  // 에러 처리 없음
        self.g.push(gate);
    }
}
```

