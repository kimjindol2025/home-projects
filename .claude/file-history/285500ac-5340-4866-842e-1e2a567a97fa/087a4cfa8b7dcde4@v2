## 4️⃣ **에러 처리**

### Custom Error Type

```rust
use std::fmt;

#[derive(Debug)]
pub enum QuantumError {
    InvalidQubitCount { requested: usize, available: usize },
    CircuitError(String),
    ExecutionFailed(String),
}

impl fmt::Display for QuantumError {
    fn fmt(&self, f: &mut fmt::Formatter) -> fmt::Result {
        match self {
            Self::InvalidQubitCount { requested, available } => {
                write!(f, "Requested {} qubits, but only {} available",
                       requested, available)
            }
            Self::CircuitError(msg) => write!(f, "Circuit error: {}", msg),
            Self::ExecutionFailed(msg) => write!(f, "Execution failed: {}", msg),
        }
    }
}

impl std::error::Error for QuantumError {}

// 사용
pub fn create_processor(qubit_count: usize) -> Result<QuantumProcessor, QuantumError> {
    if qubit_count > MAX_QUBITS {
        return Err(QuantumError::InvalidQubitCount {
            requested: qubit_count,
            available: MAX_QUBITS,
        });
    }
    Ok(QuantumProcessor { qubit_count })
}
```

