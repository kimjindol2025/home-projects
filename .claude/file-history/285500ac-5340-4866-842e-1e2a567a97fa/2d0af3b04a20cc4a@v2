/// main.zig - Zig Learning 프로젝트 메인 엔트리 포인트
///
/// 기록이 증명이다 - 표준화된 Zig 코드는 협업을 쉽게 합니다.
///
/// 버전: 1.1

const std = @import("std");
const template = @import("template.zig");

pub fn main() !void {
    // 메모리 할당자 설정
    var gpa = std.heap.GeneralPurposeAllocator(.{}){};
    defer _ = gpa.deinit();
    const allocator = gpa.allocator();

    // 표준 출력 설정
    const stdout = std.io.getStdOut().writer();

    try stdout.print("🦎 Zig Learning Project v1.1\n", .{});
    try stdout.print("기록이 증명이다 - Zig 표준화\n\n", .{});

    // ============================================================================
    // 1️⃣ TaskStatus 테스트
    // ============================================================================

    try stdout.print("1️⃣ TaskStatus 열거형\n", .{});
    const statuses = [_]template.TaskStatus{
        .pending,
        .in_progress,
        .completed,
        .failed,
    };
    for (statuses) |status| {
        try stdout.print("  - {s}\n", .{status.toString()});
    }
    try stdout.print("\n", .{});

    // ============================================================================
    // 2️⃣ TaskResult 테스트
    // ============================================================================

    try stdout.print("2️⃣ TaskResult 구조체\n", .{});
    var task_result = try template.TaskResult.init(allocator, "task-001", .pending);
    defer task_result.deinit(allocator);

    task_result.status = .in_progress;
    task_result.result = try allocator.dupe(u8, "Processing...");
    task_result.duration_ms = 50;

    try stdout.print("  - Task ID: {s}\n", .{task_result.task_id});
    try stdout.print("  - Status: {s}\n", .{task_result.status.toString()});
    if (task_result.result) |result| {
        try stdout.print("  - Result: {s}\n", .{result});
    }
    try stdout.print("  - Duration: {}ms\n\n", .{task_result.duration_ms});

    // ============================================================================
    // 3️⃣ DefaultProcessor 테스트
    // ============================================================================

    try stdout.print("3️⃣ DefaultProcessor\n", .{});
    const processor = template.DefaultProcessor.init(4);
    processor.printInfo();

    var processed = try processor.process(allocator, "task-002", "sample-data");
    defer processed.deinit(allocator);

    try stdout.print("  - Processed task: {s}\n", .{processed.task_id});
    try stdout.print("  - Status: {s}\n", .{processed.status.toString()});
    if (processed.result) |result| {
        try stdout.print("  - Result: {s}\n", .{result});
    }
    try stdout.print("\n", .{});

    // ============================================================================
    // 4️⃣ 유틸리티 함수 테스트
    // ============================================================================

    try stdout.print("4️⃣ 유틸리티 함수\n", .{});
    try stdout.print("  - add(2, 3) = {}\n", .{template.add(2, 3)});

    const arr = [_]i32{ 1, 2, 3, 4, 5 };
    try stdout.print("  - sum([1,2,3,4,5]) = {}\n", .{template.sum(&arr)});

    const is_even = struct {
        fn call(x: i32) bool {
            return x % 2 == 0;
        }
    }.call;

    var even_numbers = try template.filter(allocator, &arr, is_even);
    defer even_numbers.deinit();

    try stdout.print("  - even numbers: ", .{});
    for (even_numbers.items) |num| {
        try stdout.print("{} ", .{num});
    }
    try stdout.print("\n\n", .{});

    // ============================================================================
    // 5️⃣ TaskQueue 테스트
    // ============================================================================

    try stdout.print("5️⃣ TaskQueue (제네릭)\n", .{});
    var queue = template.TaskQueue(i32).init(allocator, 10);
    defer queue.deinit();

    try queue.enqueue(100);
    try queue.enqueue(200);
    try queue.enqueue(300);

    try stdout.print("  - Queue size: {}\n", .{queue.size()});

    while (queue.dequeue()) |item| {
        try stdout.print("  - Dequeue: {}\n", .{item});
    }
    try stdout.print("\n", .{});

    // ============================================================================
    // 6️⃣ 데이터 처리
    // ============================================================================

    try stdout.print("6️⃣ 데이터 처리\n", .{});
    const input_data = "hello-world";
    var processed_data = try template.processData(allocator, input_data);
    defer allocator.free(processed_data);

    try stdout.print("  - Input: {s}\n", .{input_data});
    try stdout.print("  - Output: {s}\n\n", .{processed_data});

    // ============================================================================
    // 7️⃣ 완료 메시지
    // ============================================================================

    try stdout.print("🎉 모든 테스트 완료!\n", .{});
    try stdout.print("기록이 증명이다 - Zig 표준화\n", .{});
}
