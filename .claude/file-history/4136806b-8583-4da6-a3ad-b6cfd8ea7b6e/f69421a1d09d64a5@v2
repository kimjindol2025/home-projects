# ============================================================================
# Type Definitions
# ============================================================================

struct LLMConfig
  model: string           # "claude-haiku-4-5" (권장), "claude-opus"
  apiKey: string          # Anthropic API 키
  maxTokens: number       # 기본 1024
  temperature: number     # 기본 0.3 (RAG는 낮은 온도 권장)
  systemPrompt: string    # RAG 특화 시스템 프롬프트

struct Message
  role: string            # "user" | "assistant" | "system"
  content: string

struct LLMRequest
  model: string
  messages: array<Message>
  maxTokens: number
  temperature: number

struct LLMResponse
  content: string
  model: string
  inputTokens: number
  outputTokens: number
  timeMs: number

struct RagResponse
  answer: string
  sources: array<string>  # 참조된 청크 ID
  confidence: number      # 0.0 ~ 1.0
  searchTimeMs: number
  llmTimeMs: number
  totalTimeMs: number

# ============================================================================
# LLM Configuration
# ============================================================================

fn newLLMConfig
  input: (model: string, apiKey: string, maxTokens: number, temperature: number)
  output: LLMConfig
  intent: "LLM 설정 생성"
  do
    let systemPrompt = buildDefaultSystemPrompt()
    return {
      model: model,
      apiKey: apiKey,
      maxTokens: maxTokens,
      temperature: temperature,
      systemPrompt: systemPrompt
    }

fn newLLMConfigDefault
  input: none
  output: LLMConfig
  intent: "기본 LLM 설정 (Haiku)"
  do
    return {
      model: "claude-haiku-4-5-20251001",
      apiKey: "",  # 환경변수에서 로드
      maxTokens: 1024,
      temperature: 0.3,
      systemPrompt: buildDefaultSystemPrompt()
    }

fn buildDefaultSystemPrompt
  input: none
  output: string
  intent: "RAG용 기본 시스템 프롬프트"
  do
    let prompt = ""
    prompt = prompt + "당신은 정확하고 도움이 되는 AI 어시스턴트입니다.\n"
    prompt = prompt + "주어진 문맥(Context)을 바탕으로 사용자의 질문에 답하세요.\n"
    prompt = prompt + "만약 문맥에서 답을 찾을 수 없다면, 그렇게 명시하세요.\n"
    prompt = prompt + "항상 출처를 명시하고, 정직하게 답하세요.\n"
    return prompt

# ============================================================================
# RAG Message Building
# ============================================================================

fn buildRagMessages
  input: (systemPrompt: string, question: string, context: string)
  output: array<Message>
  intent: "System, Context, Question으로 구성된 메시지 배열 생성"
  do
    let messages = []

    # System 메시지
    let systemMsg = {
      role: "system",
      content: systemPrompt
    }
    messages = arrayPush(messages, systemMsg)

    # User 메시지 (Context + Question)
    let userContent = buildUserPrompt(question, context)
    let userMsg = {
      role: "user",
      content: userContent
    }
    messages = arrayPush(messages, userMsg)

    return messages

fn buildUserPrompt
  input: (question: string, context: string)
  output: string
  intent: "질문과 컨텍스트로부터 최종 프롬프트 생성"
  do
    let prompt = ""
    prompt = prompt + "### 문맥\n"
    prompt = prompt + context + "\n\n"
    prompt = prompt + "### 질문\n"
    prompt = prompt + question + "\n\n"
    prompt = prompt + "### 답변\n"
    return prompt

# ============================================================================
# LLM API Call
# ============================================================================

fn callLLM
  input: (config: LLMConfig, messages: array<Message>)
  output: Result<LLMResponse, string>
  intent: "Claude API에 요청을 보내고 응답 받기"
  do
    # Step 1: API 요청 객체 생성
    let request = {
      model: config.model,
      messages: messages,
      maxTokens: config.maxTokens,
      temperature: config.temperature
    }

    # Step 2: API 호출 (실제 구현에서는 HTTP 요청)
    # 현재: 시뮬레이션
    let startTime = getCurrentTimeMs()

    let response = simulateLLMCall(request)  # 나중에 실제 API 호출로 변경

    let elapsedTime = getCurrentTimeMs() - startTime

    # Step 3: 응답 파싱
    match response
      Ok(resp) => {
        return Ok({
          content: resp.content,
          model: config.model,
          inputTokens: resp.inputTokens,
          outputTokens: resp.outputTokens,
          timeMs: elapsedTime
        })
      }
      Err(e) => {
        return Err("LLM API 호출 실패: " + e)
      }

fn simulateLLMCall
  input: request: LLMRequest
  output: Result<LLMResponse, string>
  intent: "테스트용 LLM 응답 시뮬레이션"
  do
    # 실제 환경에서는 HTTP POST 요청
    # POST https://api.anthropic.com/v1/messages
    # Headers: x-api-key: API_KEY, content-type: application/json
    # Body: request

    let mockResponse = {
      content: "FreeLang은 정적 타입 시스템과 고성능 런타임을 가진 프로그래밍 언어입니다.",
      inputTokens: 250,
      outputTokens: 45,
      model: request.model
    }

    return Ok(mockResponse)

# ============================================================================
# Response Parsing & Processing
# ============================================================================

fn parseRagResponse
  input: (llmResp: LLMResponse, searchResults: array<ScoredVector>, question: string)
  output: RagResponse
  intent: "LLM 응답을 RAG 형식으로 파싱"
  do
    # Step 1: 답변 추출
    let answer = llmResp.content

    # Step 2: 소스 정보 추출 (검색 결과의 청크 ID)
    let sources = extractSourceIds(searchResults)

    # Step 3: 신뢰도 계산
    let confidence = estimateConfidence(searchResults, question)

    # Step 4: 최종 응답 생성
    return {
      answer: answer,
      sources: sources,
      confidence: confidence,
      searchTimeMs: 0,  # 호출자가 설정
      llmTimeMs: llmResp.timeMs,
      totalTimeMs: 0    # 호출자가 설정
    }

fn extractSourceIds
  input: searchResults: array<ScoredVector>
  output: array<string>
  intent: "검색 결과에서 청크 ID 추출"
  do
    let sources = []
    let i = 0
    for i in 0..arrayLen(searchResults)
      let result = arrayGet(searchResults, i)
      # result.id는 청크 ID (예: "doc_123_chunk_0")
      sources = arrayPush(sources, result.id)

    return sources

fn estimateConfidence
  input: (searchResults: array<ScoredVector>, question: string)
  output: number
  intent: "검색 결과 점수를 기반으로 신뢰도 추정 (0.0~1.0)"
  do
    if arrayLen(searchResults) == 0
      return 0.0

    # 첫 번째 결과의 점수를 신뢰도로 사용
    let topResult = arrayGet(searchResults, 0)

    # 점수 범위: 0.5 ~ 1.0 (점수가 낮으면 신뢰도도 낮음)
    if topResult.score < 0.5
      return 0.3  # 낮은 신뢰도
    else if topResult.score < 0.7
      return 0.6  # 중간 신뢰도
    else if topResult.score < 0.85
      return 0.8  # 높은 신뢰도
    else
      return 0.95  # 매우 높은 신뢰도

fn postProcessResponse
  input: llmResp: string
  output: string
  intent: "LLM 응답 후처리 (형식 정리)"
  do
    # 1. 양쪽 공백 제거
    let cleaned = trim(llmResp)

    # 2. 과도한 개행 제거
    cleaned = replaceAll(cleaned, "\n\n\n", "\n\n")

    # 3. 마크다운 정리 (필요시)
    # cleaned = normalizeMarkdown(cleaned)

    return cleaned

