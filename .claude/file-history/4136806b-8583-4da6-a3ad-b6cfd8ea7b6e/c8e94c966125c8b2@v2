fn newFlatIndex
  input: dimension: number
  output: FlatIndex
  intent: "FlatIndex 생성 (index.fl 참조)"
  do
    return {
      vectors: [],
      dimension: dimension,
      count: 0,
      vectorMap: {}
    }

fn flatIndexInsert
  input: (idx: FlatIndex, v: Vector)
  output: Result<FlatIndex, string>
  intent: "FlatIndex 삽입 (index.fl 참조)"
  do
    if v.dimension != idx.dimension
      return Err("차원 불일치")
    let updated = idx
    updated.vectors = arrayPush(idx.vectors, v)
    updated.count = idx.count + 1
    return Ok(updated)

fn flatIndexDelete
  input: (idx: FlatIndex, vectorId: string)
  output: Result<FlatIndex, string>
  intent: "FlatIndex 삭제 (index.fl 참조)"
  do
    let newVectors = []
    for i in 0..arrayLen(idx.vectors)
      let v = arrayGet(idx.vectors, i)
      if v.id != vectorId
        newVectors = arrayPush(newVectors, v)
    let updated = idx
    updated.vectors = newVectors
    updated.count = idx.count - 1
    return Ok(updated)

fn newLSHIndex
  input: (dimension: number, config: VectorDBConfig)
  output: LSHIndex
  intent: "LSHIndex 생성 (index.fl 참조)"
  do
    let hashFunctions = []
    for i in 0..8
      hashFunctions = arrayPush(hashFunctions, {
        hyperplane: { id: "hp_" + str(i), values: [], dimension: dimension, metadata: {} },
        bias: 0
      })
    return {
      hashFunctions: hashFunctions,
      buckets: {},
      vectorStore: {},
      numHashFunctions: 8,
      dimension: dimension,
      count: 0
    }

fn lshIndexInsert
  input: (idx: LSHIndex, v: Vector)
  output: Result<LSHIndex, string>
  intent: "LSHIndex 삽입 (index.fl 참조)"
  do
    if v.dimension != idx.dimension
      return Err("차원 불일치")
    let updated = idx
    updated.vectorStore.set(v.id, v)
    updated.count = idx.count + 1
    return Ok(updated)

fn lshIndexDelete
  input: (idx: LSHIndex, vectorId: string)
  output: Result<LSHIndex, string>
  intent: "LSHIndex 삭제 (index.fl 참조)"
  do
    let updated = idx
    updated.count = idx.count - 1
    return Ok(updated)
