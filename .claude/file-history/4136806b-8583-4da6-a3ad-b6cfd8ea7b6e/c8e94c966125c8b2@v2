# ============================================================================
# Type Definitions
# ============================================================================

struct VectorDocument
  id: string
  vector: Vector
  rawText: Option<string>
  metadata: map<string, string>
  createdAt: string
  updatedAt: string

struct CollectionStats
  totalDocs: number
  dimension: number
  indexType: number
  avgSearchTime: number
  totalSearches: number

struct Collection
  name: string
  dimension: number
  indexType: number
  flatIndex: Option<FlatIndex>
  lshIndex: Option<LSHIndex>
  documents: map<string, VectorDocument>
  stats: CollectionStats
  createdAt: string

struct VectorDB
  collections: map<string, Collection>
  totalCollections: number
  config: VectorDBConfig

struct VectorDBConfig
  defaultDimension: number
  defaultIndexType: number
  maxCollections: number
  maxDocsPerCollection: number

