fn updateDocumentMetadata
  input: (db: VectorDB, collectionName: string, docId: string, metadata: map<string, string>)
  output: Result<VectorDB, string>
  intent: "문서 메타데이터 업데이트"
  do
    match db.collections.get(collectionName)
      Some(coll) => {
        match coll.documents.get(docId)
          Some(doc) => {
            let updatedDoc = doc
            updatedDoc.metadata = metadata
            updatedDoc.updatedAt = getCurrentTimestamp()

            let updatedColl = coll
            updatedColl.documents.set(docId, updatedDoc)

            let updated = db
            updated.collections.set(collectionName, updatedColl)

            return Ok(updated)
          }
          None => return Err("문서 찾기 실패")
      }
      None => return Err("컬렉션 찾기 실패")

