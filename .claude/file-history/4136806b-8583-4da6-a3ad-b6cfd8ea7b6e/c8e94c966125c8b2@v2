# Collection CRUD
# ============================================================================

fn createCollection
  input: (db: VectorDB, name: string, dimension: number, indexType: number)
  output: Result<VectorDB, string>
  intent: "새 컬렉션 생성"
  do
    # 이름 중복 확인
    match db.collections.get(name)
      Some(_) => return Err("컬렉션 이미 존재: " + name)
      None => pass

    # maxCollections 한도 확인
    if db.totalCollections >= db.config.maxCollections
      return Err("컬렉션 수 초과")

    # dimension 유효성
    if dimension < 1 || dimension > 4096
      return Err("차원 범위 초과: 1~4096")

    # 인덱스 초기화
    let flatIdx = newFlatIndex(dimension)
    let lshConfig = {
      indexType: indexType,
      lshNumHashFunctions: 8,
      lshSeed: 42
    }
    let lshIdx = newLSHIndex(dimension, lshConfig)

    # Collection 생성
    let stats = {
      totalDocs: 0,
      dimension: dimension,
      indexType: indexType,
      avgSearchTime: 0,
      totalSearches: 0
    }

    let collection = {
      name: name,
      dimension: dimension,
      indexType: indexType,
      flatIndex: Some(flatIdx),
      lshIndex: Some(lshIdx),
      documents: {},
      stats: stats,
      createdAt: getCurrentTimestamp()
    }

    let updated = db
    updated.collections.set(name, collection)
    updated.totalCollections = db.totalCollections + 1

    return Ok(updated)

fn getCollection
  input: (db: VectorDB, name: string)
  output: Result<Collection, string>
  intent: "이름으로 컬렉션 조회"
  do
    match db.collections.get(name)
      Some(coll) => return Ok(coll)
      None => return Err("컬렉션 찾기 실패: " + name)

fn deleteCollection
  input: (db: VectorDB, name: string)
  output: Result<VectorDB, string>
  intent: "컬렉션 및 모든 문서 삭제"
  do
    match db.collections.get(name)
      Some(_) => {
        let updated = db
        updated.collections.set(name, {
          name: "",
          dimension: 0,
          indexType: 0,
          flatIndex: None,
          lshIndex: None,
          documents: {},
          stats: {
            totalDocs: 0,
            dimension: 0,
            indexType: 0,
            avgSearchTime: 0,
            totalSearches: 0
