      createdAt: getCurrentTimestamp(),
      updatedAt: getCurrentTimestamp()
    }

fn insertDocument
  input: (db: VectorDB, collectionName: string, doc: VectorDocument)
  output: Result<VectorDB, string>
  intent: "컬렉션에 문서 삽입"
  do
    # 컬렉션 존재 확인
    match db.collections.get(collectionName)
      Some(coll) => {
        # 차원 확인
        if doc.vector.dimension != coll.dimension
          return Err("벡터 차원 불일치")

        # ID 중복 확인
        match coll.documents.get(doc.id)
          Some(_) => return Err("문서 ID 중복: " + doc.id)
          None => pass

        # maxDocsPerCollection 한도 확인
        if coll.stats.totalDocs >= db.config.maxDocsPerCollection
          return Err("컬렉션 문서 수 초과")

        # 인덱스에 벡터 추가
        let updatedColl = coll

        # FlatIndex에 추가
        match coll.flatIndex
          Some(flatIdx) => {
            match flatIndexInsert(flatIdx, doc.vector)
              Ok(newIdx) => updatedColl.flatIndex = Some(newIdx)
              Err(_) => pass
          }
          None => pass

        # LSHIndex에 추가
        match coll.lshIndex
          Some(lshIdx) => {
            match lshIndexInsert(lshIdx, doc.vector)
              Ok(newIdx) => updatedColl.lshIndex = Some(newIdx)
              Err(_) => pass
          }
          None => pass

        # 문서 저장
        updatedColl.documents.set(doc.id, doc)
        updatedColl.stats.totalDocs = coll.stats.totalDocs + 1

        let updated = db
        updated.collections.set(collectionName, updatedColl)

        return Ok(updated)
      }
      None => return Err("컬렉션 찾기 실패")

fn deleteDocument
  input: (db: VectorDB, collectionName: string, docId: string)
  output: Result<VectorDB, string>
  intent: "특정 문서 삭제"
  do
    match db.collections.get(collectionName)
      Some(coll) => {
        match coll.documents.get(docId)
          Some(_) => {
            let updatedColl = coll

            # 인덱스에서 삭제
            match coll.flatIndex
              Some(flatIdx) => {
                match flatIndexDelete(flatIdx, docId)
                  Ok(newIdx) => updatedColl.flatIndex = Some(newIdx)
                  Err(_) => pass
              }
              None => pass

            match coll.lshIndex
              Some(lshIdx) => {
                match lshIndexDelete(lshIdx, docId)
                  Ok(newIdx) => updatedColl.lshIndex = Some(newIdx)
                  Err(_) => pass
              }
              None => pass

            # 문서 삭제
            updatedColl.documents.set(docId, {
              id: "",
              vector: { id: "", values: [], dimension: 0, metadata: {} },
              rawText: None,
              metadata: {},
              createdAt: "",
              updatedAt: ""
            })
            updatedColl.stats.totalDocs = coll.stats.totalDocs - 1

            let updated = db
            updated.collections.set(collectionName, updatedColl)

            return Ok(updated)
          }
          None => return Err("문서 찾기 실패")
      }
      None => return Err("컬렉션 찾기 실패")

fn getDocument
  input: (db: VectorDB, collectionName: string, docId: string)
