// OpType: 벡터 연산 종류
type OpType int

const (
	OpDotProduct       OpType = iota // 내적
	OpCosineSimilarity               // 코사인 유사도
	OpL2Distance                     // L2 거리
	OpManhattan                      // 맨해튼 거리
)

func (op OpType) String() string {
	switch op {
	case OpDotProduct:
		return "dotProduct"
	case OpCosineSimilarity:
		return "cosineSimilarity"
	case OpL2Distance:
		return "l2Distance"
	case OpManhattan:
		return "manhattanDistance"
	default:
		return "unknown"
	}
}

