fn runAllHybridTests
  input: none
  output: map<string, bool>
  intent: "모든 하이브리드 테스트 실행 (20+개)"
  do
    let results = {}

    # Group A: Smart Routing
    results.set("testSmartRouteFlat", testSmartRouteFlat())
    results.set("testSmartRouteLSH", testSmartRouteLSH())
    results.set("testSmartRouteHybrid", testSmartRouteHybrid())
    results.set("testSmartRouteHighAccuracy", testSmartRouteHighAccuracy())
    results.set("testSmartRouteBoundary", testSmartRouteBoundary())

    # Group B: Re-ranking Score
    results.set("testReRankScoreFullLSH", testReRankScoreFullLSH())
    results.set("testReRankScoreFullExact", testReRankScoreFullExact())
    results.set("testReRankScoreBalanced", testReRankScoreBalanced())
    results.set("testReRankScoreDefault", testReRankScoreDefault())
    results.set("testReRankScoreZero", testReRankScoreZero())

    # Group C: Initialization
    results.set("testNewHybridIndex", testNewHybridIndex())
    results.set("testHybridIndexConfig", testHybridIndexConfig())
    results.set("testHybridIndexStats", testHybridIndexStats())

    # Group D: Vector Operations
    results.set("testHybridInsertSingle", testHybridInsertSingle())
    results.set("testHybridInsertMultiple", testHybridInsertMultiple())
    results.set("testHybridInsertDimensionMismatch", testHybridInsertDimensionMismatch())
    results.set("testHybridInsertDuplicate", testHybridInsertDuplicate())

    # Group E: Re-ranking Accuracy
    results.set("testReRankCandidateScoring", testReRankCandidateScoring())
    results.set("testReRankSort", testReRankSort())
    results.set("testReRankTopK", testReRankTopK())

    # Group F: Performance
    results.set("testPerformanceFlatVsHybrid", testPerformanceFlatVsHybrid())
    results.set("testPerformanceLargeScaleHybrid", testPerformanceLargeScaleHybrid())
    results.set("testAccuracyImprovement", testAccuracyImprovement())

    # Group G: Statistics
    results.set("testStatisticsCollection", testStatisticsCollection())
    results.set("testReportGeneration", testReportGeneration())

    return results
