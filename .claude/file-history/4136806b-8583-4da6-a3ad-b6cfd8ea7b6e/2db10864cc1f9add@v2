fn testHybridInsertSingle
  input: none
  output: Result<bool, string>
  intent: "단일 벡터 삽입"
  do
    let idx = newHybridIndex(128, 500)
    let v = {
      id: "v1",
      values: [0.1, 0.2, 0.3],
      dimension: 3
    }
    let result = hybridInsert(idx, v)
    match result
      Ok(newIdx) => {
        if newIdx.count == 1
          return Ok(true)
        else
          return Err("삽입 후 카운트 실패")
      }
      Err(e) => return Err(e)

fn testHybridInsertMultiple
  input: none
  output: Result<bool, string>
  intent: "다중 벡터 삽입 (10개)"
  do
    let idx = newHybridIndex(3, 500)
    let current = idx
    let i = 0
    for i in 0..10
      let v = {
        id: "v" + stringFromNumber(i),
        values: [0.1 * i, 0.2 * i, 0.3 * i],
        dimension: 3
      }
      let result = hybridInsert(current, v)
      match result
        Ok(newIdx) => current = newIdx
        Err(e) => return Err(e)

    if current.count == 10
      return Ok(true)
    else
      return Err("다중 삽입 실패: " + stringFromNumber(current.count))

fn testHybridInsertDimensionMismatch
  input: none
  output: Result<bool, string>
  intent: "차원 불일치 → 에러"
  do
    let idx = newHybridIndex(128, 500)
    let v = {
      id: "v1",
      values: [0.1, 0.2],  # 128 아님, 2
      dimension: 2
    }
    let result = hybridInsert(idx, v)
    match result
      Ok(_) => return Err("차원 확인 실패해야 함")
      Err(e) => return Ok(true)

fn testHybridInsertDuplicate
  input: none
  output: Result<bool, string>
  intent: "같은 ID 두 번 삽입 → 두 번 추가됨 (현재 구현)"
  do
    let idx = newHybridIndex(3, 500)
    let v = {
      id: "v1",
      values: [0.1, 0.2, 0.3],
      dimension: 3
    }
    let result1 = hybridInsert(idx, v)
    match result1
      Ok(idx2) => {
        let result2 = hybridInsert(idx2, v)
        match result2
          Ok(idx3) => {
            if idx3.count == 2
              return Ok(true)
            else
              return Err("중복 삽입 카운트 실패")
          }
          Err(e) => return Err(e)
      }
      Err(e) => return Err(e)

