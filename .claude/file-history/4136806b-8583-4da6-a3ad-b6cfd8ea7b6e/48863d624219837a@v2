# ============================================================================
# Type Definitions
# ============================================================================

struct ServerConfig
  host: string           # 기본 "localhost"
  port: number           # 기본 8080
  corsEnabled: boolean   # CORS 활성화 여부
  maxBodySize: number    # 최대 요청 본문 크기 (기본 1MB = 1048576)
  version: string        # API 버전 "1.0.0"

struct SemanticSearchServer
  hybridSystem: HybridIndexSystem
  config: ServerConfig
  isRunning: boolean
  requestCount: number   # 총 요청 수

struct HttpRequest
  method: string         # GET, POST, DELETE, PUT
  path: string           # /api/v1/search
  queryParams: map<string, string>
  headers: map<string, string>
  body: string           # 요청 본문 (JSON)

struct HttpResponse
  status: number         # 200, 400, 404, 500
  headers: map<string, string>
  body: string           # 응답 본문 (JSON)

struct ErrorResponse
  error: string
  code: string           # API_ERROR, VALIDATION_ERROR, NOT_FOUND
  message: string
  timestamp: string      # ISO 8601

# ============================================================================
# Server Initialization
# ============================================================================

fn newServerConfig
  input: (host: string, port: number, corsEnabled: boolean)
  output: ServerConfig
  intent: "서버 설정 생성"
  do
    return {
      host: host,
      port: port,
      corsEnabled: corsEnabled,
      maxBodySize: 1048576,  # 1MB
      version: "1.0.0"
    }

fn newServerConfigDefault
  input: none
  output: ServerConfig
  intent: "기본 설정으로 서버 설정 생성"
  do
    return {
      host: "0.0.0.0",
      port: 8080,
      corsEnabled: true,
      maxBodySize: 1048576,
      version: "1.0.0"
    }

fn newSemanticSearchServer
  input: (hybridSystem: HybridIndexSystem, config: ServerConfig)
  output: SemanticSearchServer
  intent: "Semantic Search 서버 생성"
  do
    return {
      hybridSystem: hybridSystem,
      config: config,
      isRunning: false,
      requestCount: 0
    }

# ============================================================================
# Server Lifecycle
# ============================================================================

fn startServer
  input: server: SemanticSearchServer
  output: Result<SemanticSearchServer, string>
  intent: "HTTP 서버 시작 (포트 바인딩)"
  do
    # 실제 구현: HTTP 소켓 바인딩
    # 여기서는 상태만 업데이트하고 OK 반환
    let updatedServer = server
    updatedServer.isRunning = true
    return Ok(updatedServer)

fn stopServer
  input: server: SemanticSearchServer
  output: Result<SemanticSearchServer, string>
  intent: "HTTP 서버 종료"
  do
    let updatedServer = server
    updatedServer.isRunning = false
    return Ok(updatedServer)

fn getServerInfo
  input: server: SemanticSearchServer
  output: string
  intent: "서버 정보 조회"
  do
    let info = ""
    info = info + "MindLang API v" + server.config.version + "\n"
    info = info + "Host: " + server.config.host + ":" + stringFromNumber(server.config.port) + "\n"
    info = info + "CORS: " + boolToString(server.config.corsEnabled) + "\n"
    info = info + "Running: " + boolToString(server.isRunning) + "\n"
    info = info + "Requests: " + stringFromNumber(server.requestCount) + "\n"
    return info

# ============================================================================
# Request Routing
# ============================================================================

fn routeRequest
  input: (server: SemanticSearchServer, request: HttpRequest)
  output: Result<HttpResponse, string>
  intent: "HTTP 요청을 적절한 핸들러로 라우팅"
  do
    # Step 1: 경로 파싱
    let pathParts = splitPath(request.path)

    # Step 2: 메서드 + 경로 매칭
    # 형식: /api/v1/{resource}/{action}

    # GET /api/v1/health
    if request.method == "GET" && pathContains(pathParts, "health")
      return Ok(buildSuccessResponse(200, "{\"status\": \"ok\", \"version\": \"1.0.0\"}"))

    # GET /api/v1/stats
    if request.method == "GET" && pathContains(pathParts, "stats")
      let stats = getHybridSystemStats(server.hybridSystem)
      let body = serializeStats(stats)
      return Ok(buildSuccessResponse(200, body))

    # POST /api/v1/insert
    if request.method == "POST" && pathContains(pathParts, "insert")
      # 배치 여부 확인
      if pathContains(pathParts, "batch")
        return handleBatchInsert(server, request)
      else
        return handleInsert(server, request)

    # POST /api/v1/search
    if request.method == "POST" && pathContains(pathParts, "search")
      if pathContains(pathParts, "vector")
        return handleSearchByVector(server, request)
      else
        return handleSearch(server, request)

    # 404 Not Found
    return Ok(buildErrorResponse(404, "API_NOT_FOUND", "엔드포인트를 찾을 수 없습니다"))

# ============================================================================
# HTTP Response Building
# ============================================================================

fn buildSuccessResponse
  input: (status: number, body: string)
  output: HttpResponse
  intent: "성공 응답 생성"
  do
    let headers = {
      "Content-Type": "application/json",
      "Content-Length": stringFromNumber(stringLength(body))
    }
    return {
      status: status,
      headers: headers,
      body: body
    }

fn buildErrorResponse
  input: (status: number, code: string, message: string)
  output: HttpResponse
  intent: "에러 응답 생성"
  do
    let errorObj = {
      error: code,
      message: message,
      timestamp: getCurrentTimestamp()
    }
    let body = serializeJson(errorObj)
    return buildSuccessResponse(status, body)

fn buildJsonResponse
  input: (status: number, data: map<string, string>)
  output: HttpResponse
  intent: "JSON 응답 생성"
  do
    let body = serializeJson(data)
    return buildSuccessResponse(status, body)

fn buildCorsHeaders
  input: corsEnabled: boolean
  output: map<string, string>
  intent: "CORS 헤더 생성"
  do
    if corsEnabled
      return {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET, POST, OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type",
        "Access-Control-Max-Age": "86400"
      }
    else
      return {}

