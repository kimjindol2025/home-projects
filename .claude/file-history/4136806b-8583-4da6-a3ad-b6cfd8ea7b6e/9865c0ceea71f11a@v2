# Phase 3: 분산 벡터 인덱스
# 작성: 2026-03-02
# 책임: 노드 생명주기, 모니터링, 재평형, 라우팅 (HybridIndex 통합)

struct ClusterNode
  id: number
  address: string
  port: number
  state: string                   # "ACTIVE" | "SUSPECT" | "DEAD"
  joinedAt: number
  lastHeartbeatAt: number
  vectorCount: number

enum ClusterNodeStatus
  ACTIVE = 0
  SUSPECT = 1
  DEAD = 2

struct ClusterTopology
  nodes: map<number, ClusterNode>
  activeNodeCount: number
  totalPartitions: number
  replicationFactor: number
  version: number

struct ClusterHealthReport
  totalNodes: number
  activeNodes: number
  suspectNodes: number
  deadNodes: number
  partitionsHealthy: number
  overallHealth: string           # "HEALTHY" | "DEGRADED" | "CRITICAL"
  issues: array<string>

struct CoordinatorConfig
  heartbeatIntervalMs: number
  suspectTimeoutMs: number
  deadTimeoutMs: number
  rebalanceThresholdPct: number
  maxConcurrentMigrations: number

struct Coordinator
  topology: ClusterTopology
  config: CoordinatorConfig
  shardRouter: ShardRouter
  replicationMgr: ReplicationManager
  pendingMigrations: array<PartitionMigration>
  stats: CoordinatorStats

struct CoordinatorStats
  nodesAdded: number
  nodesRemoved: number
  rebalancesTriggered: number
  migrationsCompleted: number

# ============================================================================
# 초기화
# ============================================================================

fn newCoordinator
  input: (nodes: array<ClusterNode>, config: CoordinatorConfig, ring: ConsistentHashRing, replicationMgr: ReplicationManager)
  output: Result<Coordinator, string>
  intent: "코디네이터 초기화"
  do
    let topology = {
      nodes: buildNodeMap(nodes),
      activeNodeCount: arrayLen(nodes),
      totalPartitions: 16,
      replicationFactor: 3,
      version: 1
    }

    let router = {
      ring: ring,
      partitions: {},
      replicationFactor: 3,
      stats: {
        totalVectors: 0,
        partitionDistribution: {},
        nodeLoad: {},
        balanceScore: 0.0
      }
    }

    return Ok({
      topology: topology,
      config: config,
      shardRouter: router,
      replicationMgr: replicationMgr,
      pendingMigrations: [],
      stats: {
        nodesAdded: 0,
        nodesRemoved: 0,
        rebalancesTriggered: 0,
        migrationsCompleted: 0
      }
    })

fn buildNodeMap
  input: nodes: array<ClusterNode>
  output: map<number, ClusterNode>
  intent: "노드 배열을 맵으로 변환"
  do
    let m = {}
    let i = 0
    for i in 0..arrayLen(nodes)
      let node = arrayGet(nodes, i)
      m = mapSet(m, node.id, node)
    return m

# ============================================================================
# 노드 생명주기
# ============================================================================

fn addNode
  input: (coord: Coordinator, node: ClusterNode)
  output: Result<Coordinator, string>
  intent: "새 노드를 클러스터에 추가"
  do
    # 1. 링에 추가
    coord.shardRouter.ring = addNodeToRing(coord.shardRouter.ring, node.id)

    # 2. 토폴로지 업데이트
    coord.topology.nodes = mapSet(coord.topology.nodes, node.id, node)
    coord.topology.activeNodeCount = coord.topology.activeNodeCount + 1
    coord.topology.version = coord.topology.version + 1

    # 3. 재평형 계획 수립
    match computeRebalancePlan(coord.shardRouter, Some(node.id), None)
      migrations => {
        coord.pendingMigrations = migrations
        coord.stats.rebalancesTriggered = coord.stats.rebalancesTriggered + 1
      }

    coord.stats.nodesAdded = coord.stats.nodesAdded + 1
    return Ok(coord)

fn markNodeSuspect
  input: (coord: Coordinator, nodeId: number)
  output: Coordinator
  intent: "노드를 의심 상태로 표시"
  do
    match mapGet(coord.topology.nodes, nodeId)
      Some(node) => {
        let suspectNode = node
        suspectNode.state = "SUSPECT"
        coord.topology.nodes = mapSet(coord.topology.nodes, nodeId, suspectNode)
      }
      None => {}
    return coord

fn markNodeDead
  input: (coord: Coordinator, nodeId: number, cluster: RaftIndexCluster)
  output: Result<Coordinator, string>
  intent: "노드를 Dead로 판정하고 장애 복구 시작"
  do
    match mapGet(coord.topology.nodes, nodeId)
      Some(node) => {
        let deadNode = node
        deadNode.state = "DEAD"

        let newCoord = coord
        newCoord.topology.nodes = mapSet(newCoord.topology.nodes, nodeId, deadNode)
        newCoord.topology.activeNodeCount = newCoord.topology.activeNodeCount - 1

        # 링에서 제거
        newCoord.shardRouter.ring = removeNodeFromRing(newCoord.shardRouter.ring, nodeId)

        # 복제 관리자에서 장애 복구 시작
        match initiateFailover(newCoord.replicationMgr, nodeId, cluster)
          Ok(updatedReplicationMgr) => {
            newCoord.replicationMgr = updatedReplicationMgr
            newCoord.stats.nodesRemoved = newCoord.stats.nodesRemoved + 1
            return Ok(newCoord)
          }
          Err(e) => return Err("Failover failed: " + e)
      }
      None => return Err("Node not found")

# ============================================================================
# 모니터링
# ============================================================================

fn monitorHeartbeats
  input: (coord: Coordinator, currentTimeMs: number)
  output: Coordinator
  intent: "하트비트 타임아웃 확인"
  do
    let newCoord = coord
    let i = 0

    for i in 0..mapSize(coord.topology.nodes)
      let nodeIdStr = stringFromNumber(i)
      match mapGet(coord.topology.nodes, i)
        Some(node) => {
          let timeSinceHeartbeat = currentTimeMs - node.lastHeartbeatAt

          if timeSinceHeartbeat > newCoord.config.deadTimeoutMs
            # Dead로 전환 (장애 복구는 별도)
            newCoord = markNodeSuspect(newCoord, i)
          else if timeSinceHeartbeat > newCoord.config.suspectTimeoutMs
            newCoord = markNodeSuspect(newCoord, i)
        }
        None => {}

    return newCoord

fn collectHealthReport
  input: coord: Coordinator
  output: ClusterHealthReport
  intent: "클러스터 건강도 리포트"
  do
    let totalNodes = mapSize(coord.topology.nodes)
    let activeNodes = 0
    let suspectNodes = 0
    let deadNodes = 0
    let issues = []
    let i = 0

    for i in 0..mapSize(coord.topology.nodes)
      match mapGet(coord.topology.nodes, i)
        Some(node) => {
          match node.state
            "ACTIVE" => activeNodes = activeNodes + 1
            "SUSPECT" => {
              suspectNodes = suspectNodes + 1
              issues = arrayPush(issues, "Node " + stringFromNumber(i) + " suspected")
            }
            "DEAD" => {
              deadNodes = deadNodes + 1
              issues = arrayPush(issues, "Node " + stringFromNumber(i) + " dead")
            }
            _ => {}
        }
        None => {}

    let overallHealth = if deadNodes > 0 then "CRITICAL"
                        else if suspectNodes > 0 then "DEGRADED"
                        else "HEALTHY"

    return {
      totalNodes: totalNodes,
      activeNodes: activeNodes,
      suspectNodes: suspectNodes,
      deadNodes: deadNodes,
      partitionsHealthy: 16 - deadNodes,
      overallHealth: overallHealth,
      issues: issues
    }

# ============================================================================
# 재평형
# ============================================================================

fn triggerRebalanceIfNeeded
  input: coord: Coordinator
  output: Result<Coordinator, string>
  intent: "불균형 감지 시 재평형 트리거"
  do
    let stats = computeShardingStats(coord.shardRouter)

    # balanceScore < threshold 확인 (기본 0.8)
    if stats.balanceScore < 0.8
      match computeRebalancePlan(coord.shardRouter, None, None)
        migrations => {
          let newCoord = coord
          newCoord.pendingMigrations = migrations
          newCoord.stats.rebalancesTriggered = newCoord.stats.rebalancesTriggered + 1
          return Ok(newCoord)
        }
    else
      return Ok(coord)

fn executePendingMigrations
  input: (coord: Coordinator, cluster: RaftIndexCluster)
  output: Result<Coordinator, string>
  intent: "대기 중인 마이그레이션 실행"
  do
    let newCoord = coord
    let count = 0
    let i = 0

    for i in 0..arrayLen(coord.pendingMigrations)
      if count >= coord.config.maxConcurrentMigrations
        break

      let migration = arrayGet(coord.pendingMigrations, i)
      # 마이그레이션 실행 (시뮬레이션)
      count = count + 1
      newCoord.stats.migrationsCompleted = newCoord.stats.migrationsCompleted + 1

    newCoord.pendingMigrations = []
    return Ok(newCoord)

