fn routeInsertRequest
  input: (coord: Coordinator, vectorId: string, vector: Vector)
  output: Result<array<number>, string>
  intent: "INSERT 요청을 올바른 노드들로 라우팅"
  do
    let partitionInfo = routeVectorInsert(coord.shardRouter, vectorId)

    # quorumWrite를 통해 복제
    let req = {
      vectorId: vectorId,
      partitionId: partitionInfo.partitionId,
      commandType: "INSERT",
      payload: serializeVector(vector),
      requestId: generateRequestId(),
      term: 0
    }

    # 실제 구현에서는 cluster를 전달받아 quorumWrite 호출
    return Ok(partitionInfo.replicaNodeIds)

fn routeSearchRequest
  input: (coord: Coordinator, query: Vector, topK: number)
  output: Result<array<PartitionInfo>, string>
  intent: "SEARCH 요청을 모든 파티션에 분산"
  do
    let partitions = routeVectorSearch(coord.shardRouter, None)
    return Ok(partitions)

fn aggregateSearchResults
  input: (partialResults: array<array<ScoredVector>>, topK: number)
  output: array<ScoredVector>
  intent: "여러 파티션의 검색 결과를 글로벌 Top-K로 병합"
  do
    # 모든 결과를 하나의 배열로 병합
    let merged = []
    let i = 0
    for i in 0..arrayLen(partialResults)
      let results = arrayGet(partialResults, i)
      let j = 0
      for j in 0..arrayLen(results)
        merged = arrayPush(merged, arrayGet(results, j))

    # 점수 기준 정렬 (내림차순)
    merged = sortScoredVectorsByScore(merged)

    # Top-K 추출
    if arrayLen(merged) > topK
      return arraySlice(merged, 0, topK)
    else
      return merged

fn sortScoredVectorsByScore
  input: vectors: array<ScoredVector>
  output: array<ScoredVector>
  intent: "ScoredVector를 점수 기준으로 정렬"
  do
    # 버블 정렬 (내림차순)
    let result = vectors
    let i = 0
    let j = 0
    let n = arrayLen(result)

    for i in 0..n
      for j in 0..n - i - 1
        let curr = arrayGet(result, j)
        let next = arrayGet(result, j + 1)
        if curr.score < next.score
          arraySet(result, j, next)
          arraySet(result, j + 1, curr)

    return result

