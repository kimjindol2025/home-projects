fn reportCoordinatorStats
  input: coord: Coordinator
  output: string
  intent: "코디네이터 통계 리포트"
  do
    let report = ""
    report = report + "=== Coordinator Status ===\n"
    report = report + "Active Nodes: " + stringFromNumber(coord.topology.activeNodeCount) + "\n"
    report = report + "Nodes Added: " + stringFromNumber(coord.stats.nodesAdded) + "\n"
    report = report + "Nodes Removed: " + stringFromNumber(coord.stats.nodesRemoved) + "\n"
    report = report + "Rebalances Triggered: " + stringFromNumber(coord.stats.rebalancesTriggered) + "\n"
    report = report + "Migrations Completed: " + stringFromNumber(coord.stats.migrationsCompleted) + "\n"
    report = report + "Topology Version: " + stringFromNumber(coord.topology.version) + "\n"

    return report

