      }

# ============================================================================
# Hybrid Search API (Level 3: Re-ranking)
# ============================================================================

fn searchByTextHybrid
  input: (sys: HybridIndexSystem, queryText: string, k: number)
  output: Result<array<ScoredVector>, string>
  intent: "텍스트 쿼리로 하이브리드 검색 (95% 정확도, 11배 속도)"
  do
    # 1. embedText로 쿼리 벡터화
    match embedText(queryText, sys.vocab, sys.embeddingConfig)
      Err(e) => return Err(e)
      Ok(embedResult) => {
        # 2. hybridSearch 호출 (Smart Routing + Re-ranking)
        match hybridSearch(sys.hybridIndex, embedResult.vector, k)
          Ok(results) => return Ok(results)
          Err(e) => return Err(e)
      }

fn searchByVectorHybrid
  input: (sys: HybridIndexSystem, queryVec: Vector, k: number)
  output: Result<array<ScoredVector>, string>
  intent: "벡터로 직접 하이브리드 검색"
  do
    return hybridSearch(sys.hybridIndex, queryVec, k)

fn insertTextHybrid
  input: (sys: HybridIndexSystem, text: string, metadata: map<string, string>)
  output: Result<HybridIndexSystem, string>
  intent: "텍스트를 임베딩 후 하이브리드 인덱스에 삽입"
  do
    # 1. embedText
    match embedText(text, sys.vocab, sys.embeddingConfig)
      Err(e) => return Err(e)
      Ok(embedResult) => {
        # 2. newVectorDocument 생성
        let doc = newVectorDocument(embedResult.vector, Some(text), metadata)

        # 3. hybridInsert
        match hybridInsert(sys.hybridIndex, doc.vector)
          Ok(newHybridIdx) => {
            # 4. 어휘 사전 업데이트
            let newVocab = updateVocabulary(sys.vocab, embedResult.tokens)

            return Ok({
              hybridIndex: newHybridIdx,
              vocab: newVocab,
              embeddingConfig: sys.embeddingConfig,
              indexingMode: sys.indexingMode
            })
          }
          Err(e) => return Err(e)
      }

fn insertTextsHybrid
  input: (sys: HybridIndexSystem, texts: array<string>)
  output: Result<HybridIndexSystem, string>
  intent: "텍스트 배열을 하이브리드 인덱스에 일괄 삽입"
  do
    let currentSys = sys

    for i in 0..arrayLen(texts)
      let text = arrayGet(texts, i)
      match insertTextHybrid(currentSys, text, {})
        Ok(updatedSys) => currentSys = updatedSys
        Err(e) => return Err(e)

    return Ok(currentSys)

