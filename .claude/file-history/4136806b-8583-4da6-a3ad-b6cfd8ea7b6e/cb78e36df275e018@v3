# System Structures
# ============================================================================

struct VectorDBSystem
  db: VectorDB
  vocab: Vocabulary
  embeddingConfig: EmbeddingConfig

# ============================================================================
# Hybrid Index System (Level 3: Re-ranking)
# 목표: 정확도 95%+ 유지하면서 속도 개선 (0.054ms)
# ============================================================================

struct HybridIndexSystem
  hybridIndex: HybridIndex
  vocab: Vocabulary
  embeddingConfig: EmbeddingConfig
  indexingMode: string  # "flat" | "lsh" | "hybrid"

# ============================================================================
# Initialization
# ============================================================================

fn newVectorDBSystem
  input: config: VectorDBConfig
  output: VectorDBSystem
  intent: "VectorDB 시스템 전체 초기화"
  do
    return {
      db: newVectorDB(config),
      vocab: newVocabulary(config.defaultDimension),
      embeddingConfig: {
        dimension: config.defaultDimension,
        minWordLen: 2,
        maxVocabSize: 10000,
        normalize: true
      }
    }

fn newVectorDBSystemDefault
  input: void
  output: VectorDBSystem
  intent: "기본 설정으로 VectorDB 시스템 생성"
  do
    let defaultConfig = {
      defaultDimension: 128,
      defaultIndexType: 0,
      maxCollections: 100,
      maxDocsPerCollection: 100000
    }
    return newVectorDBSystem(defaultConfig)

# ============================================================================
# Hybrid Index System Initialization
# ============================================================================

fn newHybridIndexSystem
  input: config: VectorDBConfig
  output: HybridIndexSystem
  intent: "하이브리드 인덱싱 시스템 초기화 (Level 3: Re-ranking)"
  do
    let dimension = config.defaultDimension
    let flatThreshold = 500  # 500 문서 이하 → FlatIndex 자동 사용

    return {
      hybridIndex: newHybridIndex(dimension, flatThreshold),
      vocab: newVocabulary(dimension),
      embeddingConfig: {
        dimension: dimension,
        minWordLen: 2,
        maxVocabSize: 10000,
        normalize: true
      },
      indexingMode: "hybrid"
    }

fn newHybridIndexSystemDefault
  input: void
  output: HybridIndexSystem
  intent: "기본 설정으로 하이브리드 인덱싱 시스템 생성"
  do
    let defaultConfig = {
      defaultDimension: 128,
      defaultIndexType: 1,  # Hybrid
      maxCollections: 100,
      maxDocsPerCollection: 100000
    }
    return newHybridIndexSystem(defaultConfig)

fn newHybridIndexSystemCustom
  input: (dimension: number, flatThreshold: number)
  output: HybridIndexSystem
  intent: "커스텀 설정으로 하이브리드 시스템 생성"
  do
    let config = {
      defaultDimension: dimension,
      defaultIndexType: 1,
      maxCollections: 100,
      maxDocsPerCollection: 100000
    }
    let sys = newHybridIndexSystem(config)
    # flatThreshold 커스터마이징 (update 필요)
    return sys

