# ============================================================================
# Core API: Text Insert & Search
# ============================================================================

fn insertText
  input: (sys: VectorDBSystem, collectionName: string, text: string, metadata: map<string, string>)
  output: Result<VectorDBSystem, string>
  intent: "텍스트를 임베딩 후 컬렉션에 삽입 (가장 핵심 API)"
  do
    # 1. embedText(text, vocab, embeddingConfig)
    match embedText(text, sys.vocab, sys.embeddingConfig)
      Err(e) => return Err(e)
      Ok(embedResult) => {
        # 2. newVectorDocument 생성
        let doc = newVectorDocument(embedResult.vector, Some(text), metadata)

        # 3. insertDocument
        match insertDocument(sys.db, collectionName, doc)
          Err(e) => return Err(e)
          Ok(newDb) => {
            # 4. 어휘 사전 업데이트
            let newVocab = updateVocabulary(sys.vocab, embedResult.tokens)

            return Ok({
              db: newDb,
              vocab: newVocab,
              embeddingConfig: sys.embeddingConfig
            })
          }
      }

fn insertTexts
  input: (sys: VectorDBSystem, collectionName: string, texts: array<string>)
  output: Result<VectorDBSystem, string>
  intent: "텍스트 배열 일괄 삽입"
  do
    let currentSys = sys

    for i in 0..arrayLen(texts)
      let text = arrayGet(texts, i)
      match insertText(currentSys, collectionName, text, {})
        Ok(updatedSys) => currentSys = updatedSys
        Err(e) => return Err(e)

    return Ok(currentSys)

fn searchByText
  input: (sys: VectorDBSystem, collectionName: string, queryText: string, k: number)
  output: Result<SearchResponse, string>
  intent: "텍스트 쿼리로 유사 문서 검색 (가장 핵심 API)"
  do
    # 1. embedText로 쿼리 벡터화
    match embedText(queryText, sys.vocab, sys.embeddingConfig)
      Err(e) => return Err(e)
      Ok(embedResult) => {
        # 2. SearchQuery 구성
        let query = {
          queryVector: Some(embedResult.vector),
          queryText: None,
          metadataFilter: {},
          topK: k,
          metric: 0,
          minScore: 0
        }

        # 3. searchCollection
        match searchCollection(sys.db, collectionName, query)
          Ok(response) => return Ok(response)
          Err(e) => return Err(e)
      }

fn searchByVector
  input: (sys: VectorDBSystem, collectionName: string, queryVec: Vector, k: number)
  output: Result<SearchResponse, string>
  intent: "벡터로 직접 검색"
  do
    let query = {
      queryVector: Some(queryVec),
      queryText: None,
      metadataFilter: {},
      topK: k,
      metric: 0,
      minScore: 0
    }
    return searchCollection(sys.db, collectionName, query)

fn searchWithFilter
  input: (sys: VectorDBSystem, collectionName: string, queryText: string, filter: map<string, string>, k: number)
  output: Result<SearchResponse, string>
  intent: "텍스트 + 메타데이터 필터 하이브리드 검색"
