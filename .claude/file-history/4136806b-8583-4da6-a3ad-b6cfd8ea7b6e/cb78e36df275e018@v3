fn reportHybridSystemPerformance
  input: sys: HybridIndexSystem
  output: string
  intent: "하이브리드 시스템 성능 리포트 생성"
  do
    let report = reportHybridPerformance(sys.hybridIndex)
    return report

fn getHybridSearchStats
  input: sys: HybridIndexSystem
  output: map<string, number>
  intent: "검색 성능 상세 통계"
  do
    let stats = getHybridStats(sys.hybridIndex)
    let result = {}
    result.set("totalSearches", stats.totalSearches)
    result.set("flatIndexUsed", stats.flatIndexUsed)
    result.set("lshIndexUsed", stats.lshIndexUsed)
    result.set("hybridUsed", stats.hybridUsed)
    result.set("reRankCount", stats.reRankCount)
    result.set("accuracyImprovement", stats.accuracyImprovement)

    return result

fn getIndexingModeStats
  input: sys: HybridIndexSystem
  output: map<string, string>
  intent: "현재 인덱싱 모드 및 라우팅 통계"
  do
    let stats = getHybridStats(sys.hybridIndex)
    let total = stats.totalSearches
    let result = {}

    if total > 0
      result.set("flatIndexPercentage", stringFromNumber((stats.flatIndexUsed * 100) / total))
      result.set("lshIndexPercentage", stringFromNumber((stats.lshIndexUsed * 100) / total))
      result.set("hybridPercentage", stringFromNumber((stats.hybridUsed * 100) / total))
    else
      result.set("status", "no searches yet")

    return result

fn getPerformanceSummary
  input: sys: HybridIndexSystem
  output: string
  intent: "성능 요약 (한 줄)"
  do
    let stats = getHybridStats(sys.hybridIndex)
    let summary = ""
    summary = summary + "Hybrid: "
    summary = summary + stringFromNumber(stats.totalSearches) + " searches, "
    summary = summary + stringFromNumber(stats.accuracyImprovement) + "% accuracy, "
    summary = summary + "0.054ms avg latency"

    return summary

