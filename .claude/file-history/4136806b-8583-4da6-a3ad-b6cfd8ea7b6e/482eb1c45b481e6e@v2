# ============================================================================
# Type Definitions
# ============================================================================

struct FlatIndex
  vectors: array<Vector>
  dimension: number
  count: number
  vectorMap: map<string, number>

struct LSHBucket
  hashKey: string
  vectorIds: array<string>

struct LSHHashFunction
  hyperplane: Vector
  bias: number

struct LSHIndex
  hashFunctions: array<LSHHashFunction>
  buckets: map<string, LSHBucket>
  vectorStore: map<string, Vector>
  numHashFunctions: number
  dimension: number
  count: number

struct ScoredVector
  vector: Vector
  score: number
  rank: number

enum IndexType
  FLAT = 0
  LSH = 1

struct IndexConfig
  indexType: IndexType
  lshNumHashFunctions: number
  lshSeed: number

# ============================================================================
# FlatIndex Operations
# ============================================================================

fn newFlatIndex
  input: dimension: number
  output: FlatIndex
  intent: "플랫 인덱스 초기화"
  do
    return {
      vectors: [],
      dimension: dimension,
      count: 0,
      vectorMap: {}
    }

fn flatIndexInsert
  input: (idx: FlatIndex, v: Vector)
  output: Result<FlatIndex, string>
  intent: "벡터를 플랫 인덱스에 추가"
  do
    if v.dimension != idx.dimension
      return Err("차원 불일치")

    let updated = idx
    updated.vectors = arrayPush(idx.vectors, v)
    updated.vectorMap.set(v.id, idx.count)
    updated.count = idx.count + 1

    return Ok(updated)

fn flatIndexDelete
  input: (idx: FlatIndex, vectorId: string)
  output: Result<FlatIndex, string>
  intent: "ID로 벡터 삭제"
  do
    # vectorMap에서 찾기
    match idx.vectorMap.get(vectorId)
      Some(posIdx) => {
        # 벡터 배열에서 해당 위치 제거 (새 배열 재구성)
        let newVectors = []
        for i in 0..arrayLen(idx.vectors)
          if i != posIdx
            newVectors = arrayPush(newVectors, arrayGet(idx.vectors, i))

        let updated = idx
        updated.vectors = newVectors
        updated.vectorMap.set(vectorId, -1)  # 삭제 표시
        updated.count = idx.count - 1

        return Ok(updated)
      }
      None => return Err("벡터 찾기 실패")

fn flatIndexGet
  input: (idx: FlatIndex, vectorId: string)
  output: Result<Vector, string>
  intent: "ID로 벡터 조회"
  do
    for i in 0..arrayLen(idx.vectors)
      let v = arrayGet(idx.vectors, i)
      if v.id == vectorId
        return Ok(v)
    return Err("벡터 찾기 실패")

fn flatIndexSize
  input: idx: FlatIndex
  output: number
  intent: "인덱스 내 벡터 수 반환"
  do
    return idx.count

# ============================================================================
# FlatIndex Search (Brute Force)
# ============================================================================

fn flatIndexSearch
  input: (idx: FlatIndex, query: Vector, k: number, metric: number)
  output: Result<array<ScoredVector>, string>
  intent: "완전탐색으로 Top-K 유사 벡터 반환"
  do
    # 알고리즘:
    # 1. 모든 vectors에 대해 distance(query, v, metric) 계산
    # 2. (score, vector) 쌍 배열 생성
    # 3. score 기준 정렬
    # 4. 상위 k개 반환

    if arrayLen(idx.vectors) == 0
      return Ok([])

    let scored = []

    # 모든 벡터에 대해 거리 계산
    for i in 0..arrayLen(idx.vectors)
      let v = arrayGet(idx.vectors, i)
      match vectorDistance(query, v, metric)
        Ok(dist) => {
          let scored_v = {
            vector: v,
            score: dist,
            rank: 0
          }
          scored = arrayPush(scored, scored_v)
        }
        Err(_) => pass

    # 정렬 (버블 정렬)
    scored = sortScoredVectors(scored, metric)

    # Top-K 추출
    let topK = []
    let limit = if k > arrayLen(scored) then arrayLen(scored) else k
    for i in 0..limit
      let sv = arrayGet(scored, i)
      let ranked = {
        vector: sv.vector,
        score: sv.score,
        rank: i + 1
      }
      topK = arrayPush(topK, ranked)

    return Ok(topK)

# ============================================================================
# LSH Operations
# ============================================================================

fn generateRandomHyperplane
  input: (dimension: number, seed: number, index: number)
  output: LSHHashFunction
  intent: "결정론적 랜덤 하이퍼플레인 생성"
  do
    # LCG 의사난수: state = (a * state + c) mod m
    let state = seed
    let a = 1664525
    let c = 1013904223
    let m = 4294967296  # 2^32

    let hyperplaneVals = []

    # 각 차원마다 난수 생성
    for i in 0..dimension
      state = (a * state + c) % m
      let normalized = (state % 1000000) / 1000000 * 2 - 1
      hyperplaneVals = arrayPush(hyperplaneVals, normalized)

    let hyperplane = {
      id: "lsh_hyperplane_" + str(index),
      values: hyperplaneVals,
      dimension: dimension,
      metadata: {}
    }

    # 바이어스도 난수
    state = (a * state + c) % m
    let bias = (state % 1000000) / 1000000 * 2 - 1

    return {
      hyperplane: hyperplane,
      bias: bias
    }

fn lshHash
  input: (v: Vector, hashFn: LSHHashFunction)
  output: Result<number, string>
  intent: "하이퍼플레인 기준 벡터 이진 해시 계산"
  do
    # dot = dotProduct(v, hyperplane) + bias
    match dotProduct(v, hashFn.hyperplane)
      Ok(dot) => {
        let hashValue = if (dot + hashFn.bias) >= 0 then 1 else 0
        return Ok(hashValue)
      }
      Err(e) => return Err(e)

fn computeLSHKey
  input: (v: Vector, hashFunctions: array<LSHHashFunction>)
  output: Result<string, string>
  intent: "모든 해시 함수의 결과를 연결한 해시 키 생성"
  do
    # 각 해시 함수에 대해 lshHash 계산
    # [0, 1, 1, 0, 1, 0, 0, 1] -> "01101001"
    let keyStr = ""

    for i in 0..arrayLen(hashFunctions)
      let fn = arrayGet(hashFunctions, i)
      match lshHash(v, fn)
        Ok(hashVal) => {
          let charVal = if hashVal == 1 then "1" else "0"
          keyStr = keyStr + charVal
        }
        Err(e) => return Err(e)

    return Ok(keyStr)

fn newLSHIndex
  input: (dimension: number, config: IndexConfig)
  output: LSHIndex
  intent: "LSH 인덱스 초기화, 해시 함수 생성"
  do
    let hashFunctions = []

    # 해시 함수 생성
    for i in 0..config.lshNumHashFunctions
      let fn = generateRandomHyperplane(dimension, config.lshSeed, i)
      hashFunctions = arrayPush(hashFunctions, fn)

    return {
      hashFunctions: hashFunctions,
      buckets: {},
      vectorStore: {},
      numHashFunctions: config.lshNumHashFunctions,
      dimension: dimension,
      count: 0
    }

fn lshIndexInsert
  input: (idx: LSHIndex, v: Vector)
  output: Result<LSHIndex, string>
  intent: "벡터를 LSH 인덱스에 삽입"
  do
    if v.dimension != idx.dimension
      return Err("차원 불일치")

    # 해시 키 계산
    match computeLSHKey(v, idx.hashFunctions)
      Ok(key) => {
        let updated = idx

        # 버킷에 추가
        match updated.buckets.get(key)
          Some(bucket) => {
            let newIds = arrayPush(bucket.vectorIds, v.id)
            updated.buckets.set(key, {
              hashKey: key,
              vectorIds: newIds
            })
          }
          None => {
            updated.buckets.set(key, {
              hashKey: key,
              vectorIds: [v.id]
            })
          }

        # 벡터 저장소에 추가
        updated.vectorStore.set(v.id, v)
        updated.count = idx.count + 1

        return Ok(updated)
      }
      Err(e) => return Err(e)

