# ============================================================================
# Utility Functions
# ============================================================================

fn vectorDistance
  input: (a: Vector, b: Vector, metric: number)
  output: Result<number, string>
  intent: "거리 계산"
  do
    match metric
      0 => {
        # COSINE: 유사도 반환 (1 - 유사도 = 거리)
        match cosineSimilarity(a, b)
          Ok(sim) => return Ok(1 - sim)
          Err(e) => return Err(e)
      }
      1 => l2Distance(a, b)
      2 => dotProduct(a, b)
      3 => manhattanDistance(a, b)
      _ => return Err("알 수 없는 메트릭")

fn dotProduct
  input: (a: Vector, b: Vector)
  output: Result<number, string>
  intent: "내적 계산"
  do
    if a.dimension != b.dimension
      return Err("차원 불일치")
    let result = 0
    for i in 0..a.dimension
      result = result + arrayGet(a.values, i) * arrayGet(b.values, i)
    return Ok(result)

fn cosineSimilarity
  input: (a: Vector, b: Vector)
  output: Result<number, string>
  intent: "코사인 유사도"
  do
    match dotProduct(a, b)
      Ok(dot) => {
        match vectorNorm(a)
          Ok(normA) => {
            match vectorNorm(b)
              Ok(normB) => {
                if normA == 0 || normB == 0
                  return Err("영벡터")
                return Ok(dot / (normA * normB))
              }
              Err(e) => return Err(e)
          }
          Err(e) => return Err(e)
      }
      Err(e) => return Err(e)

fn l2Distance
  input: (a: Vector, b: Vector)
  output: Result<number, string>
  intent: "L2 거리"
  do
    if a.dimension != b.dimension
      return Err("차원 불일치")
    let sumSq = 0
    for i in 0..a.dimension
      let diff = arrayGet(a.values, i) - arrayGet(b.values, i)
      sumSq = sumSq + diff * diff
    return Ok(sqrt(sumSq))

fn manhattanDistance
  input: (a: Vector, b: Vector)
  output: Result<number, string>
  intent: "맨해튼 거리"
  do
    if a.dimension != b.dimension
      return Err("차원 불일치")
    let total = 0
    for i in 0..a.dimension
      total = total + abs(arrayGet(a.values, i) - arrayGet(b.values, i))
    return Ok(total)

fn vectorNorm
  input: v: Vector
  output: Result<number, string>
  intent: "L2 노름"
  do
    let sumSq = 0
    for i in 0..v.dimension
      let val = arrayGet(v.values, i)
      sumSq = sumSq + val * val
    return Ok(sqrt(sumSq))
