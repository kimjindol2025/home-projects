  output: Result<array<ScoredVector>, string>
  intent: "LSH 근사 Top-K 검색"
  do
    # 쿼리 해시 키 계산
    match computeLSHKey(query, idx.hashFunctions)
      Ok(queryKey) => {
        let candidates = []

        # 정확한 버킷 찾기
        match idx.buckets.get(queryKey)
          Some(bucket) => {
            # 후보 벡터 ID 수집
            candidates = bucket.vectorIds
          }
          None => {
            # 빈 결과 (필요시 인접 버킷 탐색)
            pass
          }

        # 후보에 대해 실제 거리 계산
        let scored = []
        for i in 0..arrayLen(candidates)
          let candId = arrayGet(candidates, i)
          match idx.vectorStore.get(candId)
            Some(candVec) => {
              match vectorDistance(query, candVec, metric)
                Ok(dist) => {
                  let sv = {
                    vector: candVec,
                    score: dist,
                    rank: 0
                  }
                  scored = arrayPush(scored, sv)
                }
                Err(_) => pass
            }
            None => pass

        # 정렬
        scored = sortScoredVectors(scored, metric)

        # Top-K 추출
        let topK = []
        let limit = if k > arrayLen(scored) then arrayLen(scored) else k
        for i in 0..limit
          let sv = arrayGet(scored, i)
          let ranked = {
            vector: sv.vector,
            score: sv.score,
            rank: i + 1
          }
          topK = arrayPush(topK, ranked)

        return Ok(topK)
      }
      Err(e) => return Err(e)

