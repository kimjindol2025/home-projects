# ============================================================================
# Type Definitions
# ============================================================================

struct Vector
  id: string
  values: array<number>
  dimension: number
  metadata: map<string, string>

struct VectorStats
  mean: number
  variance: number
  norm: number
  minVal: number
  maxVal: number

enum DistanceMetric
  COSINE = 0
  L2 = 1
  DOT_PRODUCT = 2
  MANHATTAN = 3

enum VectorError
  DimensionMismatch(string)
  EmptyVector(string)
  InvalidNorm(string)
  IndexOutOfBounds(string)

# ============================================================================
# Vector Creation & Validation
# ============================================================================

fn newVector
  input: (id: string, values: array<number>)
  output: Result<Vector, string>
  intent: "Vector 생성 및 유효성 검사"
  do
    if arrayLen(values) == 0
      return Err("벡터 값이 비어있음")
    return Ok({
      id: id,
      values: values,
      dimension: arrayLen(values),
      metadata: {}
    })

fn newVectorWithMetadata
  input: (id: string, values: array<number>, metadata: map<string, string>)
  output: Result<Vector, string>
  intent: "메타데이터 포함 Vector 생성"
  do
    match newVector(id, values)
      Ok(v) => return Ok({ ...v, metadata: metadata })
      Err(e) => return Err(e)

fn isValidVector
  input: v: Vector
  output: bool
  intent: "벡터 유효성 검사"
  do
    if arrayLen(v.values) == 0
      return false
    if v.dimension != arrayLen(v.values)
      return false
    return true

# ============================================================================
# Distance & Similarity Metrics
# ============================================================================

fn dotProduct
  input: (a: Vector, b: Vector)
  output: Result<number, string>
  intent: "내적 계산: sum(a[i] * b[i])"
  do
    if a.dimension != b.dimension
      return Err("차원 불일치: " + str(a.dimension) + " vs " + str(b.dimension))
    let result = 0
    for i in 0..a.dimension
      result = result + arrayGet(a.values, i) * arrayGet(b.values, i)
    return Ok(result)

fn vectorNorm
  input: v: Vector
  output: Result<number, string>
  intent: "L2 노름(크기) 계산: sqrt(sum(v[i]^2))"
  do
    if arrayLen(v.values) == 0
      return Err("빈 벡터")
    let sumSq = 0
    for i in 0..v.dimension
      let val = arrayGet(v.values, i)
      sumSq = sumSq + val * val
    return Ok(sqrt(sumSq))

fn cosineSimilarity
  input: (a: Vector, b: Vector)
  output: Result<number, string>
  intent: "코사인 유사도: dot(a,b) / (|a| * |b|)"
  do
    if a.dimension != b.dimension
      return Err("차원 불일치")
    match dotProduct(a, b)
      Err(e) => return Err(e)
      Ok(dot) => {
        match vectorNorm(a)
          Err(e) => return Err(e)
          Ok(normA) => {
            match vectorNorm(b)
              Err(e) => return Err(e)
              Ok(normB) => {
                if normA == 0 || normB == 0
                  return Err("영벡터로 코사인 유사도 불가")
                return Ok(dot / (normA * normB))
              }
          }
      }

fn l2Distance
  input: (a: Vector, b: Vector)
  output: Result<number, string>
  intent: "유클리드 거리: sqrt(sum((a[i]-b[i])^2))"
  do
    if a.dimension != b.dimension
      return Err("차원 불일치")
    let sumSq = 0
    for i in 0..a.dimension
      let diff = arrayGet(a.values, i) - arrayGet(b.values, i)
      sumSq = sumSq + diff * diff
    return Ok(sqrt(sumSq))

fn manhattanDistance
  input: (a: Vector, b: Vector)
  output: Result<number, string>
  intent: "맨해튼 거리: sum(|a[i]-b[i]|)"
  do
    if a.dimension != b.dimension
      return Err("차원 불일치")
    let total = 0
    for i in 0..a.dimension
      total = total + abs(arrayGet(a.values, i) - arrayGet(b.values, i))
    return Ok(total)

fn vectorDistance
  input: (a: Vector, b: Vector, metric: DistanceMetric)
  output: Result<number, string>
  intent: "지정 메트릭으로 거리 계산 (디스패처)"
  do
    match metric
      0 => {
        match cosineSimilarity(a, b)
          Ok(sim) => return Ok(1 - sim)
          Err(e) => return Err(e)
      }
      1 => l2Distance(a, b)
      2 => dotProduct(a, b)
      3 => manhattanDistance(a, b)
      _ => return Err("알 수 없는 메트릭")

# ============================================================================
# Vector Operations
# ============================================================================

fn normalizeVector
  input: v: Vector
  output: Result<Vector, string>
  intent: "단위 벡터로 정규화: v / |v|"
  do
    match vectorNorm(v)
      Err(e) => return Err(e)
      Ok(norm) => {
        if norm == 0
          return Err("영벡터는 정규화 불가")
        let normalized = []
        for i in 0..v.dimension
          let val = arrayGet(v.values, i) / norm
          normalized = arrayPush(normalized, val)
        return Ok({
          id: v.id,
          values: normalized,
          dimension: v.dimension,
          metadata: v.metadata
        })
      }

fn vectorAdd
  input: (a: Vector, b: Vector)
  output: Result<Vector, string>
  intent: "벡터 덧셈: a[i] + b[i]"
  do
    if a.dimension != b.dimension
      return Err("차원 불일치")
    let result = []
    for i in 0..a.dimension
      let sum = arrayGet(a.values, i) + arrayGet(b.values, i)
      result = arrayPush(result, sum)
    return Ok({
      id: a.id + "_add_" + b.id,
      values: result,
      dimension: a.dimension,
      metadata: a.metadata
    })

fn vectorSubtract
  input: (a: Vector, b: Vector)
  output: Result<Vector, string>
  intent: "벡터 뺄셈: a[i] - b[i]"
  do
    if a.dimension != b.dimension
      return Err("차원 불일치")
    let result = []
    for i in 0..a.dimension
      let diff = arrayGet(a.values, i) - arrayGet(b.values, i)
      result = arrayPush(result, diff)
    return Ok({
      id: a.id + "_sub_" + b.id,
      values: result,
      dimension: a.dimension,
      metadata: a.metadata
    })

fn vectorScale
  input: (v: Vector, scalar: number)
  output: Vector
  intent: "스칼라 곱: v[i] * scalar"
  do
    let scaled = []
    for i in 0..v.dimension
      let val = arrayGet(v.values, i) * scalar
      scaled = arrayPush(scaled, val)
    return {
      id: v.id + "_scaled",
      values: scaled,
      dimension: v.dimension,
      metadata: v.metadata
    }

# ============================================================================
# Vector Statistics
# ============================================================================

fn computeStats
  input: v: Vector
  output: VectorStats
  intent: "평균, 분산, 노름, 최솟값, 최댓값 계산"
  do
    if arrayLen(v.values) == 0
      return {
        mean: 0,
        variance: 0,
        norm: 0,
        minVal: 0,
        maxVal: 0
      }

    let sum = 0
    let minVal = arrayGet(v.values, 0)
    let maxVal = arrayGet(v.values, 0)

    for i in 0..v.dimension
      let val = arrayGet(v.values, i)
      sum = sum + val
      if val < minVal
        minVal = val
      if val > maxVal
        maxVal = val

    let mean = sum / v.dimension

    let sumSqDiff = 0
    for i in 0..v.dimension
      let diff = arrayGet(v.values, i) - mean
      sumSqDiff = sumSqDiff + diff * diff

    let variance = sumSqDiff / v.dimension

    match vectorNorm(v)
      Ok(norm) => {
        return {
          mean: mean,
          variance: variance,
          norm: norm,
          minVal: minVal,
          maxVal: maxVal
        }
      }
      Err(_) => {
        return {
          mean: mean,
          variance: variance,
          norm: 0,
          minVal: minVal,
          maxVal: maxVal
        }
      }

# ============================================================================
# Utility Functions
# ============================================================================

fn vectorToString
  input: v: Vector
  output: string
  intent: "디버깅용 문자열 변환"
  do
    let valuesStr = "["
    for i in 0..v.dimension
      if i > 0
        valuesStr = valuesStr + ", "
      let val = arrayGet(v.values, i)
      valuesStr = valuesStr + str(val)
    valuesStr = valuesStr + "]"
    return "Vector(id=" + v.id + ", dim=" + str(v.dimension) + ", values=" + valuesStr + ")"

fn vectorsCombined
  input: (vectors: array<Vector>, weights: array<number>)
  output: Result<Vector, string>
  intent: "가중치 기반 벡터 조합: sum(w[i] * vectors[i])"
  do
    if arrayLen(vectors) == 0
      return Err("벡터 배열 비어있음")
    if arrayLen(weights) != arrayLen(vectors)
      return Err("가중치 길이 불일치")

    let dim = arrayGet(vectors, 0).dimension
    for i in 0..arrayLen(vectors)
      if arrayGet(vectors, i).dimension != dim
        return Err("벡터 차원 불일치")

    let combined = []
    for j in 0..dim
      combined = arrayPush(combined, 0)

    for i in 0..arrayLen(vectors)
      let vec = arrayGet(vectors, i)
      let weight = arrayGet(weights, i)
      for j in 0..dim
        let val = arrayGet(combined, j) + weight * arrayGet(vec.values, j)
        # FreeLang: 배열 업데이트는 배열 재구성

    return Ok({
      id: "combined_vector",
      values: combined,
      dimension: dim,
      metadata: {}
    })
