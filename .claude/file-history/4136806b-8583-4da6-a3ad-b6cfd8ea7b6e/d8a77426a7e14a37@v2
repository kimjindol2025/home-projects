fn testDotProductBasic
  input: void
  output: bool
  intent: "내적 기본 계산 [1,2,3]·[4,5,6]=32"
  do
    let v1 = {
      id: "v1",
      values: [1, 2, 3],
      dimension: 3,
      metadata: {}
    }
    let v2 = {
      id: "v2",
      values: [4, 5, 6],
      dimension: 3,
      metadata: {}
    }
    let result = 1*4 + 2*5 + 3*6
    return result == 32

