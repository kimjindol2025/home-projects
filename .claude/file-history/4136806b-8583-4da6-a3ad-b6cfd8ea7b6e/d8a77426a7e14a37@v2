fn testVectorAddSub
  input: void
  output: bool
  intent: "벡터 덧셈/뺄셈"
  do
    # [1,2] + [3,4] = [4,6]
    # [4,6] - [3,4] = [1,2]
    let add1 = 1 + 3
    let add2 = 2 + 4
    let sub1 = add1 - 3
    let sub2 = add2 - 4
    return add1 == 4 && add2 == 6 && sub1 == 1 && sub2 == 2

