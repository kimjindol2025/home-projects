fn runAllVectorDBTests
  input: void
  output: number
  intent: "모든 테스트 실행, 통과 수 반환"
  do
    let passed = 0
    let failed = 0

    # Group A: Vector Math (10)
    if testDotProductBasic() passed = passed + 1 else failed = failed + 1
    if testDotProductDimensionMismatch() passed = passed + 1 else failed = failed + 1
    if testVectorNorm() passed = passed + 1 else failed = failed + 1
    if testCosineSimilaritySameVector() passed = passed + 1 else failed = failed + 1
    if testCosineSimilarityOrthogonal() passed = passed + 1 else failed = failed + 1
    if testL2DistanceSameVector() passed = passed + 1 else failed = failed + 1
    if testL2DistanceKnownCase() passed = passed + 1 else failed = failed + 1
    if testManhattanDistance() passed = passed + 1 else failed = failed + 1
    if testNormalizeVector() passed = passed + 1 else failed = failed + 1
    if testVectorAddSub() passed = passed + 1 else failed = failed + 1

    # Group B: Embedding (5)
    if testTokenizeBasic() passed = passed + 1 else failed = failed + 1
    if testTokenizeMinLen() passed = passed + 1 else failed = failed + 1
    if testTermFrequency() passed = passed + 1 else failed = failed + 1
    if testEmbedTextDimension() passed = passed + 1 else failed = failed + 1
    if testEmbedSimilarTexts() passed = passed + 1 else failed = failed + 1

    # Group C: Indexing (5)
    if testFlatIndexInsertAndSize() passed = passed + 1 else failed = failed + 1
    if testFlatIndexSearchTopK() passed = passed + 1 else failed = failed + 1
    if testFlatIndexDelete() passed = passed + 1 else failed = failed + 1
    if testLSHIndexInsertAndSearch() passed = passed + 1 else failed = failed + 1
    if testLSHHashConsistency() passed = passed + 1 else failed = failed + 1

    # Group D: Search (5)
    if testSearchTopKReturnsK() passed = passed + 1 else failed = failed + 1
    if testSearchResultsRanked() passed = passed + 1 else failed = failed + 1
    if testHybridSearchMetadataFilter() passed = passed + 1 else failed = failed + 1
    if testMinScoreFilter() passed = passed + 1 else failed = failed + 1
    if testSearchEmptyCollection() passed = passed + 1 else failed = failed + 1

    # Group E: Integration (5)
    if testFullTextSearchWorkflow() passed = passed + 1 else failed = failed + 1
    if testCollectionIsolation() passed = passed + 1 else failed = failed + 1
    if testVocabularyGrowth() passed = passed + 1 else failed = failed + 1
    if testMetadataFilteredSearch() passed = passed + 1 else failed = failed + 1
    if testDeleteAndReinsertion() passed = passed + 1 else failed = failed + 1

    print("VectorDB 테스트 결과:")
    print("통과: " + str(passed) + "/30")
    print("실패: " + str(failed) + "/30")

    return passed

