  output: PipelineStats
  intent: "파이프라인 통계 조회"
  do
    return pipeline.stats

fn reportPipelineStatus
  input: pipeline: RagPipeline
  output: string
  intent: "파이프라인 상태 리포트 생성"
  do
    let report = ""
    report = report + "=== RAG 파이프라인 상태 ===\n"
    report = report + "수집된 문서: " + stringFromNumber(pipeline.stats.totalDocuments) + "\n"
    report = report + "생성된 청크: " + stringFromNumber(pipeline.stats.totalChunks) + "\n"
    report = report + "처리된 질문: " + stringFromNumber(pipeline.stats.totalQueries) + "\n"
    report = report + "평균 검색 시간: " + stringFromNumber(pipeline.stats.avgSearchMs) + "ms\n"
    report = report + "평균 LLM 시간: " + stringFromNumber(pipeline.stats.avgLLMMs) + "ms\n"
    report = report + "평균 전체 시간: " + stringFromNumber(pipeline.stats.avgTotalMs) + "ms\n"
    return report

