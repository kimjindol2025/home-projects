# ============================================================================
# Document Ingestion
# ============================================================================

fn ingestDocument
  input: (pipeline: RagPipeline, docId: string, text: string, metadata: map<string, string>)
  output: Result<PipelineStats, string>
  intent: "단일 문서를 수집(청킹 → 임베딩 → 저장)"
  do
    # Step 1: 문서 청킹
    match chunkDocument(docId, text, pipeline.chunkConfig)
      Err(e) => return Err("청킹 실패: " + e)
      Ok(chunks) => {
        # Step 2: 배치 임베딩
        match embedChunkBatch(chunks, pipeline.hybridSys, pipeline.batchConfig)
          Err(e) => return Err("임베딩 실패: " + e)
          Ok(result) => {
            # Step 3: 통계 업데이트
            pipeline.stats.totalDocuments = pipeline.stats.totalDocuments + 1
            pipeline.stats.totalChunks = pipeline.stats.totalChunks + result.processedChunks

            return Ok(pipeline.stats)
          }
      }

fn ingestBatch
  input: (pipeline: RagPipeline, documents: array<Document>)
  output: Result<PipelineStats, string>
  intent: "여러 문서를 배치로 수집"
  do
    let currentPipeline = pipeline
    let totalProcessed = 0
    let totalFailed = 0

    let i = 0
    for i in 0..arrayLen(documents)
      let doc = arrayGet(documents, i)

      match ingestDocument(currentPipeline, doc.id, doc.text, doc.metadata)
        Ok(stats) => {
          currentPipeline.stats = stats
          totalProcessed = totalProcessed + 1
        }
        Err(e) => {
          # 로그: "문서 " + doc.id + " 수집 실패: " + e
          totalFailed = totalFailed + 1
        }

    return Ok(currentPipeline.stats)

# ============================================================================
# RAG Query
# ============================================================================

fn query
  input: (pipeline: RagPipeline, question: string)
  output: Result<RagResponse, string>
  intent: "질문을 받아서 검색 + LLM 호출 → 최종 답변 반환"
  do
    let startTime = getCurrentTimeMs()

    # Step 1: 하이브리드 검색
    let searchStartTime = getCurrentTimeMs()
    match searchByTextHybrid(pipeline.hybridSys, question, 5)
      Err(e) => return Err("검색 실패: " + e)
      Ok(searchResults) => {
        let searchTime = getCurrentTimeMs() - searchStartTime

        # Step 2: 컨텍스트 구성
        let context = buildContext(searchResults, 2000)  # 최대 2000자

        # Step 3: 프롬프트 생성
        let messages = buildRagMessages(pipeline.llmConfig.systemPrompt, question, context)

        # Step 4: LLM 호출
        let llmStartTime = getCurrentTimeMs()
        match callLLM(pipeline.llmConfig, messages)
          Err(e) => return Err("LLM 호출 실패: " + e)
          Ok(llmResp) => {
            let llmTime = getCurrentTimeMs() - llmStartTime

            # Step 5: 응답 파싱 및 포맷팅
            let ragResp = parseRagResponse(llmResp, searchResults, question)
            ragResp.searchTimeMs = searchTime
            ragResp.llmTimeMs = llmTime
            ragResp.totalTimeMs = getCurrentTimeMs() - startTime

            # Step 6: 통계 업데이트
            pipeline.stats.totalQueries = pipeline.stats.totalQueries + 1

            return Ok(ragResp)
          }
      }

# ============================================================================
# Context Building
# ============================================================================

fn buildContext
  input: (searchResults: array<ScoredVector>, maxChars: number)
  output: string
  intent: "검색 결과를 LLM 프롬프트로 사용할 컨텍스트로 변환"
  do
    if arrayLen(searchResults) == 0
      return "검색 결과가 없습니다."

    let context = ""
    let charCount = 0
    let i = 0

    for i in 0..arrayLen(searchResults)
      let result = arrayGet(searchResults, i)

      # 각 검색 결과에 점수와 ID 포함
      let item = "["
      item = item + stringFromNumber(i + 1)
      item = item + "] (점수: "
      item = item + stringFromNumber(result.score)
      item = item + ", ID: "
      item = item + result.id
      item = item + ")\n"
      item = item + result.id  # 실제로는 result의 텍스트 필드 사용
      item = item + "\n\n"

      # 길이 체크
      if charCount + stringLength(item) > maxChars
        break

      context = context + item
      charCount = charCount + stringLength(item)

    return context

fn buildPrompt
  input: (question: string, context: string)
  output: string
  intent: "질문과 컨텍스트로부터 최종 프롬프트 구성"
  do
    return buildUserPrompt(question, context)

