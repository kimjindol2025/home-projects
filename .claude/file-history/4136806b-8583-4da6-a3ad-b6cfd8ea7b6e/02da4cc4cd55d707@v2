## 📚 실전 예제

### 예제 1: 기술 문서 기반 QA
```freelang
# 1단계: 문서 준비
let techDocs = [
  {
    id: "py_basics_001",
    title: "Python 기초",
    text: "Python은...",
    metadata: {"category": "python", "level": "beginner"}
  },
  # ... 더 많은 문서
]

# 2단계: 수집
match ingestBatch(pipeline, techDocs)
  Ok(_) => print("기술 문서 수집 완료")
  Err(e) => print("오류: " + e)

# 3단계: 질문
let questions = [
  "Python의 for 루프는 어떻게 동작하나요?",
  "함수를 정의하는 방법은?",
  "리스트와 튜플의 차이는?"
]

let i = 0
for i in 0..arrayLen(questions)
  let q = arrayGet(questions, i)
  match query(pipeline, q)
    Ok(resp) => print(q + "\n→ " + resp.answer + "\n")
    Err(e) => print("오류: " + e)
```

### 예제 2: 회사 내부 wiki 검색
```freelang
# 1단계: 모든 wiki 문서 로드 (가상)
let wikiDocs = loadWikiDocuments()  # 10,000+ 문서

# 2단계: 배치 수집 (자동 진행률)
match ingestBatch(pipeline, wikiDocs)
  Ok(stats) => {
    print("Wiki 인덱싱 완료")
    print("총 문서: " + stringFromNumber(stats.totalDocuments))
    print("총 청크: " + stringFromNumber(stats.totalChunks))
  }
  Err(e) => print("오류: " + e)

# 3단계: 직원 질문 처리
let employeeQuery = "휴가 신청 절차는?"
match query(pipeline, employeeQuery)
  Ok(resp) => {
    print("답변: " + resp.answer)
    print("신뢰도: " + stringFromNumber(resp.confidence * 100) + "%")
    if resp.confidence < 0.7
      print("⚠️ 낮은 신뢰도 - HR팀에 문의하세요")
  }
  Err(e) => print("오류: " + e)
```

### 예제 3: 학습 자료 기반 튜토리얼
```freelang
# 지식 베이스 구축
let curriculum = loadCurriculum()  # FreeLang, Rust, Go 튜토리얼

match ingestBatch(pipeline, curriculum)
  Ok(_) => print("학습 자료 준비 완료")
  Err(e) => print("오류: " + e)

# 학습자 질문에 대답
let learnerQuestions = [
  "변수는 어떻게 선언하나요?",
  "함수의 매개변수와 반환값은?",
  "에러 처리는 어떻게 하나요?"
]

# 각 질문마다 정확한 학습 자료 기반 답변
let i = 0
for i in 0..arrayLen(learnerQuestions)
  let q = arrayGet(learnerQuestions, i)
  match query(pipeline, q)
    Ok(resp) => {
      print("Q: " + q)
      print("A: " + resp.answer)
      print("출처 청크: " + stringFromNumber(arrayLen(resp.sources)))
      print("---")
    }
    Err(e) => {}
```

