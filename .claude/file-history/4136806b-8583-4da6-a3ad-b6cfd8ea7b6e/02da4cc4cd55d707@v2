## 🚀 빠른 시작

### 1. 기본 초기화
```freelang
# HybridIndexSystem 생성
let hybridSys = newHybridIndexSystemDefault()

# LLM 설정
let llmConfig = newLLMConfigDefault()

# RAG 파이프라인 생성
let pipeline = newRagPipeline(hybridSys, llmConfig)
```

### 2. 문서 수집 (Ingestion)
```freelang
# 단일 문서
let docId = "wiki_freelang_001"
let text = "FreeLang은 정적 타입 프로그래밍 언어입니다..."
let metadata = {"source": "wiki", "date": "2026-03-02"}

match ingestDocument(pipeline, docId, text, metadata)
  Ok(stats) => {
    print("수집: " + stringFromNumber(stats.totalDocuments) + "개 문서")
    print("청크: " + stringFromNumber(stats.totalChunks) + "개 생성")
  }
  Err(e) => print("오류: " + e)

# 배치 수집
let documents = [
  {id: "doc1", title: "...", text: "...", metadata: {}},
  {id: "doc2", title: "...", text: "...", metadata: {}},
  {id: "doc3", title: "...", text: "...", metadata: {}}
]

match ingestBatch(pipeline, documents)
  Ok(stats) => print(stringFromNumber(stats.totalDocuments) + "개 문서 수집")
  Err(e) => print("오류: " + e)
```

### 3. 질문 (Query)
```freelang
# RAG 질문
match query(pipeline, "FreeLang의 특징은 무엇인가요?")
  Ok(response) => {
    print("=== 답변 ===")
    print(response.answer)
    print("\n=== 출처 ===")
    # response.sources에 참조된 청크 ID 목록
    print("신뢰도: " + stringFromNumber(response.confidence))
    print("검색: " + stringFromNumber(response.searchTimeMs) + "ms")
    print("LLM: " + stringFromNumber(response.llmTimeMs) + "ms")
  }
  Err(e) => print("오류: " + e)
```

