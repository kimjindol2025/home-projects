# ============================================================================
# Vector Search
# ============================================================================

fn vectorSearch
  input: (collection: Collection, query: Vector, k: number, metric: number)
  output: Result<array<ScoredVector>, string>
  intent: "인덱스 유형에 따라 적합한 검색 수행"
  do
    match collection.indexType
      0 => {
        match collection.flatIndex
          Some(flatIdx) => flatIndexSearch(flatIdx, query, k, metric)
          None => return Err("FlatIndex 초기화 실패")
      }
      1 => {
        match collection.lshIndex
          Some(lshIdx) => lshIndexSearch(lshIdx, query, k, metric)
          None => return Err("LSHIndex 초기화 실패")
      }
      _ => return Err("알 수 없는 인덱스 타입")

# ============================================================================
# Hybrid Search (Vector + Metadata)
# ============================================================================

fn hybridSearch
  input: (collection: Collection, query: Vector, filter: map<string, string>, k: number, metric: number)
  output: Result<array<ScoredVector>, string>
  intent: "메타데이터 필터 후 벡터 검색"
  do
    # 1. filterDocumentsByMetadata -> candidateDocs
    let candidateDocs = filterDocumentsByMetadata(collection, filter)

    if arrayLen(candidateDocs) == 0
      return Ok([])

    # 2. candidateDocs에서 벡터만 추출
    let candidateVectors = []
    for i in 0..arrayLen(candidateDocs)
      let doc = arrayGet(candidateDocs, i)
      candidateVectors = arrayPush(candidateVectors, doc.vector)

    # 3. 벡터 유사도 계산 (브루트 포스)
    let scored = []
    for i in 0..arrayLen(candidateVectors)
      let v = arrayGet(candidateVectors, i)
      match vectorDistance(query, v, metric)
        Ok(dist) => {
          let sv = {
            vector: v,
            score: dist,
            rank: 0
          }
          scored = arrayPush(scored, sv)
        }
        Err(_) => pass

    # 4. 정렬
    scored = sortScoredVectors(scored, metric)

    # 5. Top-K 반환
    let topK = []
    let limit = if k > arrayLen(scored) then arrayLen(scored) else k
    for i in 0..limit
      let sv = arrayGet(scored, i)
      let ranked = {
        vector: sv.vector,
        score: sv.score,
        rank: i + 1
      }
      topK = arrayPush(topK, ranked)

    return Ok(topK)

# ============================================================================
# Main Search Function
# ============================================================================

fn searchCollection
  input: (db: VectorDB, collectionName: string, query: SearchQuery)
  output: Result<SearchResponse, string>
  intent: "컬렉션에서 통합 검색 수행"
  do
    # 컬렉션 존재 확인
    match db.collections.get(collectionName)
      Some(coll) => {
        let startTime = getCurrentTimeMs()

        # queryVector 결정
        let queryVec = None
        match query.queryVector
          Some(qv) => queryVec = Some(qv)
          None => {
            match query.queryText
              Some(text) => {
                # 텍스트 임베딩 필요
                # 임시: 에러 반환
                return Err("텍스트 임베딩 필수")
              }
              None => return Err("쿼리 벡터 없음")
          }

        # 검색 모드 결정
        let searchMode = if mapLen(query.metadataFilter) > 0
                         then 1
                         else 0

        # 검색 수행
        let scored = []
        match queryVec
          Some(qv) => {
            if searchMode == 1
              match hybridSearch(coll, qv, query.metadataFilter, query.topK, query.metric)
                Ok(results) => scored = results
                Err(e) => return Err(e)
            else
              match vectorSearch(coll, qv, query.topK, query.metric)
                Ok(results) => scored = results
                Err(e) => return Err(e)
          }
          None => return Err("쿼리 벡터 결정 실패")

        # minScore 필터 적용
        let filtered = applyMinScoreFilter(scored, query.minScore, query.metric)

        # SearchResult로 변환
        let results = []
        for i in 0..arrayLen(filtered)
          let sv = arrayGet(filtered, i)
          let docId = sv.vector.id
          match getDocument(db, collectionName, docId)
            Ok(doc) => {
              let result = {
                docId: docId,
                score: sv.score,
                rank: i + 1,
                document: doc,
                explanation: "거리 메트릭: " + str(query.metric)
              }
              results = arrayPush(results, result)
            }
            Err(_) => pass

        let endTime = getCurrentTimeMs()
        let searchTime = endTime - startTime

        let response = {
          results: results,
          totalFound: arrayLen(results),
          searchTimeMs: searchTime,
          queryInfo: "metric=" + str(query.metric) + ", topK=" + str(query.topK)
        }

        return Ok(response)
      }
      None => return Err("컬렉션 찾기 실패")

# ============================================================================
# Result Processing
# ============================================================================

fn applyMinScoreFilter
  input: (results: array<ScoredVector>, minScore: number, metric: number)
  output: array<ScoredVector>
  intent: "최소 점수 미만 결과 제거"
  do
    let filtered = []

    for i in 0..arrayLen(results)
      let sv = arrayGet(results, i)
      let normalized = normalizeScore(sv.score, metric)

      if normalized >= minScore
        filtered = arrayPush(filtered, sv)

    return filtered

fn normalizeScore
  input: (score: number, metric: number)
  output: number
  intent: "점수를 0~1 범위로 정규화"
  do
    match metric
      0 => {
        # COSINE: 이미 -1~1, (score + 1) / 2로 0~1 변환
        return (score + 1) / 2
      }
      1 => {
        # L2: 1 / (1 + distance)로 변환
        if score >= 1000
          return 0
        else
          return 1 / (1 + score)
      }
      2 => {
        # DOT_PRODUCT: sigmoid 근사
        if score > 100
          return 1
        else if score < -100
          return 0
        else
          return 1 / (1 + abs(score))
      }
      3 => {
        # MANHATTAN: L2와 유사
        if score >= 1000
          return 0
        else
          return 1 / (1 + score)
      }
      _ => return 0

