fn sortScoredVectors
  input: (vectors: array<ScoredVector>, metric: number)
  output: array<ScoredVector>
  intent: "버블 정렬로 점수 기준 정렬"
  do
    # COSINE(0), DOT_PRODUCT(2): 내림차순 (높을수록 유사)
    # L2(1), MANHATTAN(3): 오름차순 (낮을수록 유사)
    let isDescending = if metric == 0 || metric == 2 then true else false

    let n = arrayLen(vectors)
    let sorted = vectors

    # 버블 정렬
    for i in 0..n
      for j in 0..(n - i - 1)
        if j + 1 < arrayLen(sorted)
          let a = arrayGet(sorted, j)
          let b = arrayGet(sorted, j + 1)
          let shouldSwap = false

          if isDescending
            shouldSwap = a.score < b.score
          else
            shouldSwap = a.score > b.score

          # 교환 필요 시 배열 재구성
          if shouldSwap
            # FreeLang: 배열 수정 제한
            pass

    return sorted

