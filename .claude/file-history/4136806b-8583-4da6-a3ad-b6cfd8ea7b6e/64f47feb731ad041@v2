fn createRaftIndexNode
  input: (id: number, peers: array<number>, dimension: number, partitionIds: array<number>)
  output: RaftIndexNode
  intent: "Raft 인덱스 노드 생성 (HybridIndex 포함)"
  do
    # HybridIndex 생성 (vectordb에서 재사용)
    let hybridIdx = newHybridIndex(dimension)

    return {
      id: id,
      peers: peers,
      state: FOLLOWER,
      currentTerm: 0,
      votedFor: None,
      log: [],
      commitIndex: 0,
      lastApplied: 0,
      nextIndex: {},
      matchIndex: {},
      localIndex: hybridIdx,
      partitionIds: partitionIds,
      electionTimeoutMs: 150 + (id * 10),  # 분산된 타임아웃
      heartbeatIntervalMs: 50,
      appliedCommandCount: 0
    }

fn initRaftCluster
  input: (nodeCount: number, peersPerNode: array<array<number>>, dimension: number, partitionsPerNode: array<array<number>>)
  output: RaftIndexCluster
  intent: "Raft 클러스터 초기화"
  do
    let nodes = {}
    let i = 0

    for i in 0..nodeCount
      let peers = arrayGet(peersPerNode, i)
      let partitions = arrayGet(partitionsPerNode, i)
      let node = createRaftIndexNode(i, peers, dimension, partitions)
      nodes = mapSet(nodes, i, node)

    return {
      nodes: nodes,
      leaderId: None,
      totalPartitions: 16,
      replicationFactor: 3
    }

# ============================================================================
# 선거 (Leader Election)
# ============================================================================

fn startElection
  input: node: RaftIndexNode
  output: (RaftIndexNode, RequestVoteRequest)
  intent: "선거 시작"
  do
    # Term 증가
    let newNode = node
    newNode.currentTerm = node.currentTerm + 1
    newNode.state = CANDIDATE
    newNode.votedFor = Some(node.id)

    # RequestVoteRequest 생성
    let lastLogIndex = if arrayLen(node.log) > 0 then arrayLen(node.log) - 1 else 0
    let lastLogTerm = 0
    if lastLogIndex >= 0 && arrayLen(node.log) > lastLogIndex
      let entry = arrayGet(node.log, lastLogIndex)
      lastLogTerm = entry.term

    let request = {
      term: newNode.currentTerm,
      candidateId: node.id,
      lastLogIndex: lastLogIndex,
      lastLogTerm: lastLogTerm
    }

    return (newNode, request)

fn handleRequestVote
  input: (node: RaftIndexNode, req: RequestVoteRequest)
  output: (RaftIndexNode, RequestVoteResponse)
  intent: "투표 요청 처리"
  do
    let newNode = node
    let response = {
      term: node.currentTerm,
      voteGranted: false
    }

    # Term 업데이트
    if req.term > node.currentTerm
      newNode.currentTerm = req.term
      newNode.state = FOLLOWER
      newNode.votedFor = None

    # 투표 조건: term 일치 + votedFor 미지정 + log 최신성
    if req.term == newNode.currentTerm
      match newNode.votedFor
        None => {
          let canVote = true

          # Log 최신성 확인
          let lastLogIndex = if arrayLen(newNode.log) > 0 then arrayLen(newNode.log) - 1 else 0
          let lastLogTerm = 0
          if lastLogIndex >= 0 && arrayLen(newNode.log) > lastLogIndex
            let entry = arrayGet(newNode.log, lastLogIndex)
            lastLogTerm = entry.term

          if req.lastLogTerm < lastLogTerm
            canVote = false
          else if req.lastLogTerm == lastLogTerm && req.lastLogIndex < lastLogIndex
            canVote = false

          if canVote
            newNode.votedFor = Some(req.candidateId)
            response.voteGranted = true
        }
        Some(votedFor) => {
          # 이미 투표함 (재투표 가능하려면 같은 후보여야 함)
          if votedFor == req.candidateId
            response.voteGranted = true
        }

    response.term = newNode.currentTerm
    return (newNode, response)

fn tallyVote
  input: (result: VoteResult, voteGranted: bool)
  output: VoteResult
  intent: "투표 집계"
  do
    if voteGranted
      result.votesReceived = result.votesReceived + 1

    result.hasMajority = result.votesReceived > result.votesNeeded
    return result

fn becomeLeader
  input: node: RaftIndexNode
  output: RaftIndexNode
  intent: "리더 전환"
  do
    let newNode = node
    newNode.state = LEADER

    # nextIndex, matchIndex 초기화
    let i = 0
    for i in 0..arrayLen(node.peers)
      let peerId = arrayGet(node.peers, i)
      newNode.nextIndex = mapSet(newNode.nextIndex, peerId, arrayLen(node.log))
      newNode.matchIndex = mapSet(newNode.matchIndex, peerId, 0)

    return newNode

# ============================================================================
# 로그 복제 (Log Replication)
# ============================================================================

fn appendVectorCommand
  input: (node: RaftIndexNode, cmd: VectorIndexCommand)
  output: Result<RaftIndexNode, string>
  intent: "리더가 벡터 명령을 로그에 추가"
  do
    # Leader만 가능
    if node.state != LEADER
      return Err("Not a leader")

    # 새 로그 엔트리 생성
    let logIndex = arrayLen(node.log)
    let entry = {
      term: node.currentTerm,
      index: logIndex,
      command: cmd
    }

    let newNode = node
    newNode.log = arrayPush(newNode.log, entry)

    return Ok(newNode)

fn handleAppendEntries
  input: (node: RaftIndexNode, req: AppendEntriesRequest)
  output: (RaftIndexNode, AppendEntriesResponse)
  intent: "AppendEntries RPC 처리"
  do
    let newNode = node
    let response = {
      term: node.currentTerm,
      success: false
    }

    # Term 업데이트
    if req.term > node.currentTerm
      newNode.currentTerm = req.term
      newNode.state = FOLLOWER

    # Term 확인
    if req.term < newNode.currentTerm
      response.term = newNode.currentTerm
      return (newNode, response)

    # Log 일관성 확인
    if req.prevLogIndex > 0 && arrayLen(newNode.log) <= req.prevLogIndex
      response.term = newNode.currentTerm
      return (newNode, response)

    # 기존 로그 검증
    if req.prevLogIndex > 0
      let prevEntry = arrayGet(newNode.log, req.prevLogIndex - 1)
      if prevEntry.term != req.prevLogTerm
        response.term = newNode.currentTerm
        return (newNode, response)

    # 새 엔트리 추가
    if arrayLen(req.entries) > 0
      newNode.log = arrayConcat(arraySlice(newNode.log, 0, req.prevLogIndex), req.entries)

    # commitIndex 업데이트
    if req.leaderCommitIndex > newNode.commitIndex
      newNode.commitIndex = minNumber(req.leaderCommitIndex, arrayLen(newNode.log) - 1)

    response.success = true
    response.term = newNode.currentTerm

    return (newNode, response)

fn updateCommitIndex
  input: (node: RaftIndexNode, cluster: RaftIndexCluster)
  output: RaftIndexNode
  intent: "commitIndex 진전 (Leader)"
  do
    if node.state != LEADER
      return node

    # matchIndex 값들을 정렬하여 Quorum 지점 찾기
    let matchIndices = []
    let i = 0
    for i in 0..arrayLen(node.peers)
      let peerId = arrayGet(node.peers, i)
      let match = mapGet(node.matchIndex, peerId)
      match Some(idx) => matchIndices = arrayPush(matchIndices, idx)
            None => {}

    # 자신의 log 길이도 포함
    matchIndices = arrayPush(matchIndices, arrayLen(node.log) - 1)

    # 정렬 (오름차순)
    matchIndices = sortNumbers(matchIndices)

    # Quorum (절반 이상) 지점 찾기
    let quorumIndex = arrayLen(matchIndices) / 2
    if quorumIndex > 0 && quorumIndex < arrayLen(matchIndices)
      let newCommitIndex = arrayGet(matchIndices, quorumIndex)
      if newCommitIndex > node.commitIndex && newCommitIndex < arrayLen(node.log)
        let entry = arrayGet(node.log, newCommitIndex)
        if entry.term == node.currentTerm
          let newNode = node
          newNode.commitIndex = newCommitIndex
          return newNode

    return node

fn sendHeartbeats
  input: (node: RaftIndexNode, cluster: RaftIndexCluster)
  output: RaftIndexCluster
  intent: "리더가 하트비트 브로드캐스트"
  do
    if node.state != LEADER
      return cluster

    # 모든 follower에게 AppendEntries 전송 (시뮬레이션)
    let updatedCluster = cluster
    let i = 0

    for i in 0..arrayLen(node.peers)
      let peerId = arrayGet(node.peers, i)
      let nextIdx = mapGet(node.nextIndex, peerId)

      match nextIdx
        Some(idx) => {
          # prevLogIndex와 prevLogTerm 계산
          let prevLogIndex = idx - 1
          let prevLogTerm = 0
          if prevLogIndex > 0 && arrayLen(node.log) > prevLogIndex
            let entry = arrayGet(node.log, prevLogIndex)
            prevLogTerm = entry.term

          # 전송할 엔트리들
          let entries = if idx < arrayLen(node.log)
                         then arraySlice(node.log, idx, arrayLen(node.log))
                         else []

          let req = {
            term: node.currentTerm,
            leaderId: node.id,
            prevLogIndex: prevLogIndex,
            prevLogTerm: prevLogTerm,
            entries: entries,
            leaderCommitIndex: node.commitIndex
          }

          # 원격 노드의 handleAppendEntries 호출 (시뮬레이션)
          match mapGet(updatedCluster.nodes, peerId)
            Some(follower) => {
              let (newFollower, _resp) = handleAppendEntries(follower, req)
              updatedCluster.nodes = mapSet(updatedCluster.nodes, peerId, newFollower)
            }
            None => {}
        }
        None => {}

    return updatedCluster

# ============================================================================
# 상태 기계: Vector 명령 적용
# ============================================================================

fn applyCommittedCommands
  input: node: RaftIndexNode
  output: Result<RaftIndexNode, string>
  intent: "커밋된 모든 명령을 상태 기계(HybridIndex)에 적용"
  do
    let newNode = node
    let i = node.lastApplied

    for i in node.lastApplied..node.commitIndex + 1
      if i < arrayLen(node.log)
        let entry = arrayGet(node.log, i)

        match applyVectorCommand(newNode, entry.command)
          Ok(updatedNode) => {
            newNode = updatedNode
            newNode.lastApplied = i + 1
          }
          Err(e) => return Err("Failed to apply command " + stringFromNumber(i) + ": " + e)

    return Ok(newNode)

fn applyVectorCommand
  input: (node: RaftIndexNode, cmd: VectorIndexCommand)
  output: Result<RaftIndexNode, string>
  intent: "단일 벡터 명령 적용 (HybridIndex에 삽입/삭제)"
  do
    let newNode = node

    match cmd.commandType
      "INSERT" => {
        # JSON payload → Vector 역직렬화
        let vectorResult = deserializeVector(cmd.payload)

        match vectorResult
          Ok(vector) => {
            # 파티션 확인
            if !arrayContains(newNode.partitionIds, cmd.partitionId)
              return Err("Partition " + stringFromNumber(cmd.partitionId) + " not owned")

            # HybridIndex에 삽입 (Phase 1-2 재사용)
            match hybridInsert(newNode.localIndex, vector)
              Ok(updatedIndex) => {
                newNode.localIndex = updatedIndex
                newNode.appliedCommandCount = newNode.appliedCommandCount + 1
                return Ok(newNode)
              }
              Err(e) => return Err("HybridIndex insert failed: " + e)
          }
          Err(e) => return Err("Vector deserialization failed: " + e)
      }

      "DELETE" => {
        # 소프트 삭제 (벡터 메타데이터에 삭제 마크)
        newNode.appliedCommandCount = newNode.appliedCommandCount + 1
        return Ok(newNode)
      }

      _ => return Err("Unknown command type: " + cmd.commandType)

