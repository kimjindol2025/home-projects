fn arrayConcat
  input: (arr1: array<any>, arr2: array<any>)
  output: array<any>
  intent: "두 배열 연결"
  do
    let result = arr1
    let i = 0
    for i in 0..arrayLen(arr2)
      result = arrayPush(result, arrayGet(arr2, i))
    return result

fn arraySlice
  input: (arr: array<any>, start: number, end: number)
  output: array<any>
  intent: "배열 부분 추출"
  do
    let result = []
    let i = start
    for i in start..end
      if i < arrayLen(arr)
        result = arrayPush(result, arrayGet(arr, i))
    return result

fn sortNumbers
  input: nums: array<number>
  output: array<number>
  intent: "숫자 배열 정렬 (오름차순)"
  do
    # 버블 정렬
    let result = nums
    let i = 0
    let j = 0
    let n = arrayLen(result)

    for i in 0..n
      for j in 0..n - i - 1
        if arrayGet(result, j) > arrayGet(result, j + 1)
          let temp = arrayGet(result, j)
          arraySet(result, j, arrayGet(result, j + 1))
          arraySet(result, j + 1, temp)

    return result

