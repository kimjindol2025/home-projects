# Type Definitions
# ============================================================================

enum NodeState
  FOLLOWER = 0
  CANDIDATE = 1
  LEADER = 2

struct VectorIndexCommand
  commandType: string             # "INSERT" | "DELETE" | "UPDATE_META"
  vectorId: string
  partitionId: number
  payload: string                 # JSON 직렬화 Vector
  timestamp: number

struct IndexLogEntry
  term: number
  index: number
  command: VectorIndexCommand

struct RaftIndexNode
  # 기본 정보
  id: number
  peers: array<number>
  state: NodeState

  # 영속성 상태 (persistent)
  currentTerm: number
  votedFor: Option<number>
  log: array<IndexLogEntry>

  # 휘발성 상태 (volatile)
  commitIndex: number
  lastApplied: number

  # Leader 전용
  nextIndex: map<number, number>
  matchIndex: map<number, number>

  # 벡터 인덱스 (상태 기계)
  localIndex: HybridIndex
  partitionIds: array<number>

  # 타이머
  electionTimeoutMs: number
  heartbeatIntervalMs: number

  # 통계
  appliedCommandCount: number

struct RaftIndexCluster
  nodes: map<number, RaftIndexNode>
  leaderId: Option<number>
  totalPartitions: number
  replicationFactor: number

struct VoteResult
  term: number
  votesReceived: number
  votesNeeded: number
  hasMajority: bool

struct RequestVoteRequest
  term: number
  candidateId: number
  lastLogIndex: number
  lastLogTerm: number

struct RequestVoteResponse
  term: number
  voteGranted: bool

struct AppendEntriesRequest
  term: number
  leaderId: number
  prevLogIndex: number
  prevLogTerm: number
  entries: array<IndexLogEntry>
  leaderCommitIndex: number

struct AppendEntriesResponse
  term: number
  success: bool

struct Snapshot
  lastIncludedIndex: number
  lastIncludedTerm: number
  vectorData: string             # 직렬화된 벡터 목록

struct RaftStats
  nodeId: number
  state: NodeState
  currentTerm: number
  commitIndex: number
  logSize: number
  appliedCount: number

