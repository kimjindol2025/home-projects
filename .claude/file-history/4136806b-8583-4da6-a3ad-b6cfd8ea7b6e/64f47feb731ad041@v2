fn shouldTakeSnapshot
  input: node: RaftIndexNode
  output: bool
  intent: "스냅샷 생성 필요 여부 판단"
  do
    # 로그 크기 > 500이면 스냅샷
    return arrayLen(node.log) > 500

fn takeIndexSnapshot
  input: node: RaftIndexNode
  output: Snapshot
  intent: "현재 상태의 스냅샷 생성"
  do
    let lastLogIndex = if arrayLen(node.log) > 0 then arrayLen(node.log) - 1 else 0
    let lastLogTerm = 0

    if lastLogIndex > 0
      let entry = arrayGet(node.log, lastLogIndex)
      lastLogTerm = entry.term

    # HybridIndex 벡터 목록 직렬화
    let vectorData = serializeHybridIndex(node.localIndex)

    return {
      lastIncludedIndex: lastLogIndex,
      lastIncludedTerm: lastLogTerm,
      vectorData: vectorData
    }

fn restoreFromIndexSnapshot
  input: (node: RaftIndexNode, snapshot: Snapshot)
  output: Result<RaftIndexNode, string>
  intent: "스냅샷으로부터 상태 복구"
  do
    # 새 HybridIndex 생성
    let newIndex = newHybridIndex(128)  # 차원은 원본과 동일해야 함

    # 벡터 데이터 역직렬화 및 재삽입
    match deserializeVectorList(snapshot.vectorData)
      Ok(vectors) => {
        let updatedIndex = newIndex
        let i = 0

        for i in 0..arrayLen(vectors)
          let vector = arrayGet(vectors, i)
          match hybridInsert(updatedIndex, vector)
            Ok(idx) => updatedIndex = idx
            Err(e) => return Err("Vector restore failed: " + e)

        let newNode = node
        newNode.localIndex = updatedIndex
        newNode.log = []  # 로그 초기화 (스냅샷이 모든 것을 대체)
        newNode.commitIndex = snapshot.lastIncludedIndex
        newNode.lastApplied = snapshot.lastIncludedIndex

        return Ok(newNode)
      }
      Err(e) => return Err("Vector list deserialization failed: " + e)

