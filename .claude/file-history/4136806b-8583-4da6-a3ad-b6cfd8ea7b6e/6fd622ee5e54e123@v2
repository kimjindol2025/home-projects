## 클러스터 초기화

### 1. 3-Node 클러스터 설정

```freelang
# 노드 정의
let nodes = [
  { id: 0, address: "10.0.0.1", port: 8001, state: "ACTIVE", ... },
  { id: 1, address: "10.0.0.2", port: 8002, state: "ACTIVE", ... },
  { id: 2, address: "10.0.0.3", port: 8003, state: "ACTIVE", ... }
]

# 일관된 해싱 링 생성 (16 파티션)
let ring = newConsistentHashRing([0, 1, 2], 150, 16)

# 복제 관리자 초기화
let partitions = []  # 각 파티션 정보
let replicationMgr = newReplicationManager(partitions, 3)

# 코디네이터 생성
let config = {
  heartbeatIntervalMs: 1000,
  suspectTimeoutMs: 3000,
  deadTimeoutMs: 10000,
  rebalanceThresholdPct: 20,
  maxConcurrentMigrations: 2
}

match newCoordinator(nodes, config, ring, replicationMgr)
  Ok(coordinator) => {
    print("클러스터 초기화 완료")
    print(reportCoordinatorStats(coordinator))
  }
  Err(e) => print("초기화 실패: " + e)
```

### 2. 5-Node 클러스터로 확장

```freelang
# 새 노드 추가
let newNode = {
  id: 3,
  address: "10.0.0.4",
  port: 8004,
  state: "ACTIVE",
  ...
}

match addNode(coordinator, newNode)
  Ok(updatedCoord) => {
    print("노드 추가됨")
    # 자동 재평형 시작
    match triggerRebalanceIfNeeded(updatedCoord)
      Ok(rebalancedCoord) => {
        print("파티션 마이그레이션 진행 중...")
      }
      Err(e) => print("재평형 실패: " + e)
  }
  Err(e) => print("노드 추가 실패: " + e)
```

