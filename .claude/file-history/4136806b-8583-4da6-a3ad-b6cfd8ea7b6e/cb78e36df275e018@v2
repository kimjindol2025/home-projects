fn getSystemStats
  input: sys: VectorDBSystem
  output: map<string, number>
  intent: "전체 시스템 통계 반환"
  do
    let stats = {}
    stats.set("totalCollections", sys.db.totalCollections)
    stats.set("defaultDimension", sys.embeddingConfig.dimension)
    stats.set("vocabSize", 0)  # map 크기 필요
    stats.set("totalDocuments", 0)  # 모든 컬렉션의 합 필요

    return stats

fn getCollectionInfo
  input: (sys: VectorDBSystem, collectionName: string)
  output: Result<CollectionStats, string>
  intent: "컬렉션 통계 반환"
  do
    match getCollection(sys.db, collectionName)
      Ok(coll) => return Ok(coll.stats)
      Err(e) => return Err(e)

fn getDocumentCountInCollection
  input: (sys: VectorDBSystem, collectionName: string)
  output: Result<number, string>
  intent: "컬렉션의 문서 수"
  do
    return getDocumentCount(sys.db, collectionName)

