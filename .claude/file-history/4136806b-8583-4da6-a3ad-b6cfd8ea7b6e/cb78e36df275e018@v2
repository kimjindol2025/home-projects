# ============================================================================
# Configuration Management
# ============================================================================

fn updateEmbeddingDimension
  input: (sys: VectorDBSystem, newDimension: number)
  output: Result<VectorDBSystem, string>
  intent: "임베딩 차원 변경"
  do
    if newDimension < 1 || newDimension > 4096
      return Err("차원 범위 초과")

    let newConfig = sys.embeddingConfig
    newConfig.dimension = newDimension

    let newVocab = newVocabulary(newDimension)

    return Ok({
      db: sys.db,
      vocab: newVocab,
      embeddingConfig: newConfig
    })

fn setMinWordLength
  input: (sys: VectorDBSystem, minLen: number)
  output: VectorDBSystem
  intent: "최소 단어 길이 설정"
  do
    let newConfig = sys.embeddingConfig
    newConfig.minWordLen = minLen

    return {
      db: sys.db,
      vocab: sys.vocab,
      embeddingConfig: newConfig
    }

fn setNormalization
  input: (sys: VectorDBSystem, normalize: bool)
  output: VectorDBSystem
  intent: "정규화 여부 설정"
  do
    let newConfig = sys.embeddingConfig
    newConfig.normalize = normalize

    return {
      db: sys.db,
      vocab: sys.vocab,
      embeddingConfig: newConfig
    }

