fn createVectorCollection
  input: (sys: VectorDBSystem, name: string)
  output: Result<VectorDBSystem, string>
  intent: "기본 설정으로 컬렉션 생성"
  do
    let dimension = sys.embeddingConfig.dimension
    match createCollection(sys.db, name, dimension, 0)
      Ok(newDb) => {
        return Ok({
          db: newDb,
          vocab: sys.vocab,
          embeddingConfig: sys.embeddingConfig
        })
      }
      Err(e) => return Err(e)

