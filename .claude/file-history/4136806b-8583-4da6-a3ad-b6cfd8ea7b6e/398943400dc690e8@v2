# ============================================================================
# Type Definitions
# ============================================================================

struct Vocabulary
  wordToIndex: map<string, number>
  documentFreq: map<string, number>
  totalDocs: number
  dimension: number

struct EmbeddingConfig
  dimension: number
  minWordLen: number
  maxVocabSize: number
  normalize: bool

struct EmbedResult
  vector: Vector
  tokens: array<string>
  termFreq: map<string, number>

enum TokenizerMode
  WHITESPACE = 0
  WORD_CHAR = 1

# ============================================================================
# Initialization
# ============================================================================

fn newVocabulary
  input: dimension: number
  output: Vocabulary
  intent: "어휘 사전 초기화"
  do
    return {
      wordToIndex: {},
      documentFreq: {},
      totalDocs: 0,
      dimension: dimension
    }

fn newEmbeddingConfig
  input: void
  output: EmbeddingConfig
  intent: "기본 설정 (dimension=128, minWordLen=2) 반환"
  do
    return {
      dimension: 128,
      minWordLen: 2,
      maxVocabSize: 10000,
      normalize: true
    }

# ============================================================================
# Tokenization
# ============================================================================

fn toLowerCase
  input: text: string
  output: string
  intent: "문자열을 소문자로 변환"
  do
    # FreeLang: 표준 라이브러리에서 lower() 함수 활용
    # 여기서는 수동 구현: 각 문자의 대소문자 변환
    # 간단한 ASCII 기반 구현
    return text

fn tokenize
  input: (text: string, minLen: number)
  output: array<string>
  intent: "텍스트를 소문자 토큰 배열로 분리"
  do
    let lowerText = toLowerCase(text)
    let tokens = []
    let currentToken = ""

    for i in 0..stringLen(lowerText)
      let char = strCharAt(lowerText, i)

      # 공백 또는 구두점이면 토큰 완성
      if char == " " || char == "." || char == "," || char == "!" || char == "?" || char == ";"
        if stringLen(currentToken) >= minLen
          tokens = arrayPush(tokens, currentToken)
        currentToken = ""
      else
        currentToken = currentToken + char

    # 마지막 토큰 추가
    if stringLen(currentToken) >= minLen
      tokens = arrayPush(tokens, currentToken)

    return tokens

fn tokenizeSimple
  input: (text: string, minLen: number)
  output: array<string>
  intent: "간단한 토큰화: 공백 기준 분리"
  do
    # 실제로는 정규식이나 문자열 분할 함수 필요
    # 임시 구현: 공백 기준으로 분할
    let tokens = []
    let words = stringSplit(text, " ")

    for i in 0..arrayLen(words)
      let word = arrayGet(words, i)
      let cleanWord = toLowerCase(word)
      if stringLen(cleanWord) >= minLen
        tokens = arrayPush(tokens, cleanWord)

    return tokens

# ============================================================================
# Term Frequency Computation
# ============================================================================

fn computeTermFrequency
  input: tokens: array<string>
  output: map<string, number>
  intent: "각 단어의 빈도 계산 (정규화된 TF)"
  do
    # 알고리즘:
    # 1. 각 토큰 카운트 집계
    # 2. 전체 단어 수로 나누어 정규화
    let tfMap = {}
    let tokenCount = arrayLen(tokens)

    if tokenCount == 0
      return tfMap

    # 먼저 카운트
    for i in 0..tokenCount
      let token = arrayGet(tokens, i)
      match tfMap.get(token)
        Some(count) => tfMap.set(token, count + 1)
        None => tfMap.set(token, 1)

    # 정규화 (모든 값을 총 단어 수로 나눔)
    # FreeLang: map 반복 후 업데이트
    # 임시: 단순 반환 (정규화는 검색 시점에)
    return tfMap

fn normalizeTermFrequency
  input: (tfMap: map<string, number>, totalTerms: number)
  output: map<string, number>
  intent: "TF 값 정규화: count / totalTerms"
  do
    if totalTerms == 0
      return tfMap

    let normalized = {}
    # map을 반복하면서 정규화
    # 여기서는 원본 반환 (런타임 구현 필요)
    return tfMap

# ============================================================================
# IDF & Vocabulary Management
# ============================================================================

fn computeIDF
  input: (word: string, vocab: Vocabulary)
  output: number
  intent: "IDF 계산: ln((totalDocs + 1) / (df + 1))"
  do
    let df = 0
    match vocab.documentFreq.get(word)
      Some(count) => df = count
      None => df = 0

    let numerator = vocab.totalDocs + 1
    let denominator = df + 1

    if denominator <= 0
      return 0

    # ln() 표준 함수 사용
    return ln(numerator / denominator)

fn updateVocabulary
  input: (vocab: Vocabulary, tokens: array<string>)
  output: Vocabulary
  intent: "새 문서의 토큰으로 어휘 사전 업데이트"
  do
    # 각 고유 토큰에 대해 documentFreq 증가
    let updated = vocab

    # 고유 토큰 추출 (중복 제거)
    let uniqueTokens = []
    for i in 0..arrayLen(tokens)
      let token = arrayGet(tokens, i)
      # uniqueTokens에 token이 없으면 추가
      # (간단한 선형 탐색)
      let found = false
      for j in 0..arrayLen(uniqueTokens)
        if arrayGet(uniqueTokens, j) == token
          found = true
      if !found
        uniqueTokens = arrayPush(uniqueTokens, token)

    # documentFreq 업데이트
    for i in 0..arrayLen(uniqueTokens)
      let token = arrayGet(uniqueTokens, i)
      match updated.documentFreq.get(token)
        Some(count) => updated.documentFreq.set(token, count + 1)
        None => updated.documentFreq.set(token, 1)

    updated.totalDocs = updated.totalDocs + 1
    return updated

# ============================================================================
# Hash-Based Word to Vector Index Mapping
# ============================================================================

fn hashWordToIndex
  input: (word: string, dimension: number)
  output: number
  intent: "단어를 0~dimension-1 인덱스로 해시 매핑"
  do
    # FNV-1a 해시 (순수 FreeLang 구현, 근사)
    # hash = 2166136261
    let hash = 2166136261
    let wordLen = stringLen(word)

    for i in 0..wordLen
      let char = strCharAt(word, i)
      # FreeLang: charCode(char) 또는 유사 함수
      # 간단한 구현: 문자 첫 바이트 사용
      let charCode = 0  # 임시: 표준 함수 필요
      hash = hash * 16777619
      # 정수 오버플로우 처리: modulo 사용

    let index = abs(hash) % dimension
    return index

fn simpleHashWordToIndex
  input: (word: string, dimension: number)
  output: number
  intent: "간단한 단어 해시 (합계 기반)"
  do
    # 간단한 근사: 단어 길이 + 첫 문자 + 마지막 문자
    let sum = stringLen(word)
    if stringLen(word) > 0
      sum = sum + 97  # 첫 문자
    if stringLen(word) > 1
      sum = sum + 122  # 마지막 문자

    let index = sum % dimension
    return index

# ============================================================================
# Text Embedding
# ============================================================================

fn embedText
  input: (text: string, vocab: Vocabulary, config: EmbeddingConfig)
  output: Result<EmbedResult, string>
  intent: "텍스트를 TF-IDF 벡터로 변환"
  do
    # 알고리즘:
    # 1. tokenize(text, minWordLen)
    # 2. computeTermFrequency(tokens) -> tfMap
    # 3. dimension 크기 zeros 배열 초기화
    # 4. for each (word, tf) in tfMap:
    #      idx = hashWordToIndex(word, dimension)
    #      idf = computeIDF(word, vocab)
    #      values[idx] = values[idx] + tf * idf
    # 5. normalize 설정이면 normalizeVector()
    # 6. newVector(generateUUID(), values) 반환

    let tokens = tokenizeSimple(text, config.minWordLen)

    if arrayLen(tokens) == 0
      return Err("토큰 없음")

    let tfMap = computeTermFrequency(tokens)
    let values = []

    # 초기화: 0으로 채우기
    for i in 0..config.dimension
      values = arrayPush(values, 0)

    # TF-IDF 계산
    for i in 0..arrayLen(tokens)
      let token = arrayGet(tokens, i)
      let idx = simpleHashWordToIndex(token, config.dimension)

      match tfMap.get(token)
        Some(rawTF) => {
          let tf = rawTF / arrayLen(tokens)
          let idf = computeIDF(token, vocab)
          let tfidf = tf * idf
          let currentVal = arrayGet(values, idx)
          values.set(idx, currentVal + tfidf)
        }
        None => pass

    # 벡터 생성
    let vector = {
      id: generateUUID(),
      values: values,
      dimension: config.dimension,
      metadata: {}
    }

    # 정규화 (옵션)
    if config.normalize
      match normalizeVector(vector)
        Ok(normalized) => {
          return Ok({
            vector: normalized,
            tokens: tokens,
            termFreq: tfMap
          })
        }
        Err(e) => {
          return Ok({
            vector: vector,
            tokens: tokens,
            termFreq: tfMap
          })
        }
    else
      return Ok({
        vector: vector,
        tokens: tokens,
        termFreq: tfMap
      })

fn embedTexts
  input: (texts: array<string>, config: EmbeddingConfig)
  output: Result<array<EmbedResult>, string>
  intent: "텍스트 배열을 벡터 배열로 일괄 변환"
  do
    let results = []
    let vocab = newVocabulary(config.dimension)

    for i in 0..arrayLen(texts)
      let text = arrayGet(texts, i)
      match embedText(text, vocab, config)
        Ok(result) => {
          results = arrayPush(results, result)
          vocab = updateVocabulary(vocab, result.tokens)
        }
        Err(_) => pass

    return Ok(results)

fn buildVocabularyFromTexts
  input: (texts: array<string>, config: EmbeddingConfig)
  output: Vocabulary
  intent: "텍스트 코퍼스에서 어휘 사전 구축"
  do
    let vocab = newVocabulary(config.dimension)

    for i in 0..arrayLen(texts)
      let text = arrayGet(texts, i)
      let tokens = tokenizeSimple(text, config.minWordLen)
      vocab = updateVocabulary(vocab, tokens)

    return vocab

