# ============================================================================
# Helper Functions
# ============================================================================

fn strCharAt
  input: (text: string, index: number)
  output: string
  intent: "문자열의 특정 인덱스 문자 반환"
  do
    return strSubstring(text, index, 1)

fn stringSplit
  input: (text: string, delimiter: string)
  output: array<string>
  intent: "구분자 기반 문자열 분할"
  do
    # FreeLang: 표준 라이브러리 split 함수 사용 필요
    # 임시: 공백 기준 간단한 분할
    let parts = []
    let current = ""

    for i in 0..stringLen(text)
      let char = strCharAt(text, i)
      if char == delimiter
        if stringLen(current) > 0
          parts = arrayPush(parts, current)
        current = ""
      else
        current = current + char

    if stringLen(current) > 0
      parts = arrayPush(parts, current)

    return parts

fn normalizeVector
  input: v: Vector
  output: Result<Vector, string>
  intent: "벡터 정규화 (vector.fl 참조)"
  do
    match vectorNorm(v)
      Ok(norm) => {
        if norm == 0
          return Err("영벡터")
        let normalized = []
        for i in 0..v.dimension
          normalized = arrayPush(normalized, arrayGet(v.values, i) / norm)
        return Ok({
          id: v.id,
          values: normalized,
          dimension: v.dimension,
          metadata: v.metadata
        })
      }
      Err(e) => return Err(e)

fn vectorNorm
  input: v: Vector
  output: Result<number, string>
  intent: "벡터 L2 노름 계산 (vector.fl 참조)"
  do
    let sumSq = 0
    for i in 0..v.dimension
      let val = arrayGet(v.values, i)
      sumSq = sumSq + val * val
    return Ok(sqrt(sumSq))
