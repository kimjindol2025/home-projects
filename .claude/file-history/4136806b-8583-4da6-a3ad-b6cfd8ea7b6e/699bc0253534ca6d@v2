fn testRaftLeaderElection
  input: none
  output: Result<bool, string>
  intent: "3-node 클러스터에서 단 1개 리더 선출"
  do
    # 3개 노드 초기화
    let peers0 = [1, 2]
    let peers1 = [0, 2]
    let peers2 = [0, 1]

    let node0 = createRaftIndexNode(0, peers0, 128, [0, 1, 2])
    let node1 = createRaftIndexNode(1, peers1, 128, [3, 4, 5])
    let node2 = createRaftIndexNode(2, peers2, 128, [6, 7, 8])

    # 선거 트리거 (node0에서)
    let (newNode0, _voteReq) = startElection(node0)

    # 리더 여부 확인
    if newNode0.state == LEADER
      return Ok(true)
    else
      return Err("No leader elected")

fn testRaftLogReplication
  input: none
  output: Result<bool, string>
  intent: "INSERT 명령 3노드 로그 복제"
  do
    # 클러스터 초기화
    let cluster = initRaftCluster(3, [[1, 2], [0, 2], [0, 1]], 128, [[0, 1, 2], [3, 4, 5], [6, 7, 8]])

    # 리더 설정 (node 0)
    match mapGet(cluster.nodes, 0)
      Some(node) => {
        let leader = node
        leader.state = LEADER

        # INSERT 명령 추가
        let cmd = {
          commandType: "INSERT",
          vectorId: "vec_001",
          partitionId: 0,
          payload: "{\"id\":\"vec_001\",\"values\":[...]}",
          timestamp: 0
        }

        match appendVectorCommand(leader, cmd)
          Ok(updatedLeader) => {
            # 로그 길이 확인
            if arrayLen(updatedLeader.log) >= 1
              return Ok(true)
            else
              return Err("Log not replicated")
          }
          Err(e) => return Err(e)
      }
      None => return Err("Node not found")

fn testRaftSnapshotCompaction
  input: none
  output: Result<bool, string>
  intent: "500개 명령 후 스냅샷 생성 및 복구"
  do
    # 노드 생성
    let node = createRaftIndexNode(0, [1, 2], 128, [0, 1, 2])

    # 500개 로그 엔트리 추가 (시뮬레이션)
    let i = 0
    let newNode = node
    for i in 0..500
      let entry = {
        term: 0,
        index: i,
        command: {
          commandType: "INSERT",
          vectorId: "vec_" + stringFromNumber(i),
          partitionId: i % 16,
          payload: "",
          timestamp: 0
        }
      }
      newNode.log = arrayPush(newNode.log, entry)

    # 스냅샷 생성 여부 확인
    if shouldTakeSnapshot(newNode)
      let snapshot = takeIndexSnapshot(newNode)

      # 새 노드에 복구
      let node2 = createRaftIndexNode(1, [0, 2], 128, [3, 4, 5])
      match restoreFromIndexSnapshot(node2, snapshot)
        Ok(recoveredNode) => {
          if recoveredNode.lastApplied >= snapshot.lastIncludedIndex
            return Ok(true)
          else
            return Err("Snapshot not applied correctly")
        }
        Err(e) => return Err(e)
    else
      return Err("Snapshot not triggered")

