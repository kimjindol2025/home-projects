fn testConsistentHashDistribution
  input: none
  output: Result<bool, string>
  intent: "1000개 벡터 ID → 16 파티션 균등 분배"
  do
    let ring = newConsistentHashRing([0, 1, 2], 150, 16)
    let distribution = {}

    # 1000개 벡터 라우팅
    let i = 0
    for i in 0..1000
      let vectorId = "vec_" + stringFromNumber(i)
      let partitionId = getPartitionId(vectorId, 16)

      let count = mapGet(distribution, partitionId)
      match count
        Some(c) => distribution = mapSet(distribution, partitionId, c + 1)
        None => distribution = mapSet(distribution, partitionId, 1)

    # 균형 점수 계산
    let score = computeBalanceScore(distribution)

    if score > 0.75
      return Ok(true)
    else
      return Err("Balance score too low: " + stringFromNumber(score))

fn testVirtualNodeRouting
  input: none
  output: Result<bool, string>
  intent: "동일 vectorId는 항상 동일 파티션"
  do
    let ring = newConsistentHashRing([0, 1, 2], 150, 16)
    let vectorId = "test_vector_123"

    # 10번 라우팅
    let partitionIds = []
    let i = 0
    for i in 0..10
      let partId = getPartitionId(vectorId, 16)
      partitionIds = arrayPush(partitionIds, partId)

    # 모두 같은 파티션인지 확인
    let firstPartId = arrayGet(partitionIds, 0)
    let allSame = true
    for i in 1..arrayLen(partitionIds)
      if arrayGet(partitionIds, i) != firstPartId
        allSame = false

    if allSame
      return Ok(true)
    else
      return Err("Inconsistent routing")

fn testNodeAdditionMinimalRerouting
  input: none
  output: Result<bool, string>
  intent: "노드 추가 시 최소 재배정"
  do
    let ring1 = newConsistentHashRing([0, 1, 2], 150, 16)
    let ring2 = addNodeToRing(ring1, 3)

    # 재평형 계획 수립
    let router1 = { ring: ring1, partitions: {}, replicationFactor: 3, stats: {} }
    let router2 = { ring: ring2, partitions: {}, replicationFactor: 3, stats: {} }

    match computeRebalancePlan(router2, Some(3), None)
      migrations => {
        # 이동 파티션 수 < totalPartitions / 4 (25%)
        if arrayLen(migrations) <= 4
          return Ok(true)
        else
          return Err("Too many migrations: " + stringFromNumber(arrayLen(migrations)))
      }

fn testPartitionReplicaCount
  input: none
  output: Result<bool, string>
  intent: "각 파티션 복제 노드 수 == 3"
  do
    let ring = newConsistentHashRing([0, 1, 2, 3, 4], 150, 16)

    # 모든 파티션의 복제 노드 확인
    let allCorrect = true
    let i = 0
    for i in 0..16
      let replicas = getReplicaNodes(ring, i, 3)
      if arrayLen(replicas) != 3
        allCorrect = false

    if allCorrect
      return Ok(true)
    else
      return Err("Replica count mismatch")

