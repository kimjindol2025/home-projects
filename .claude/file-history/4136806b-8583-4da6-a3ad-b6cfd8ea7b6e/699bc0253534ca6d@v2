fn testRaftSingleLeaderPerTerm
  input: none
  output: Result<bool, string>
  intent: "동일 term에 리더 1개만 존재 (Safety)"
  do
    # 간단한 검증: node 0과 node 1이 같은 term에 모두 리더가 될 수 없음
    let node0 = createRaftIndexNode(0, [1, 2], 128, [0, 1, 2])
    let node1 = createRaftIndexNode(1, [0, 2], 128, [3, 4, 5])

    let (leader0, _) = startElection(node0)
    let (leader1, _) = startElection(node1)

    # 같은 term이면 하나만 리더여야 함
    if leader0.currentTerm == leader1.currentTerm
      let leaderCount = if leader0.state == LEADER then 1 else 0
      let leaderCount2 = if leader1.state == LEADER then leaderCount + 1 else leaderCount

      if leaderCount2 <= 1
        return Ok(true)
      else
        return Err("Multiple leaders in same term")
    else
      return Ok(true)  # 다른 term이면 OK

