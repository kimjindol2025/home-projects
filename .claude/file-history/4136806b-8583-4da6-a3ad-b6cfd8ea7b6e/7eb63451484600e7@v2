## 🔧 사용 예제

### Python 예제

```python
import requests
import json

# 1. API 기본 설정
API_BASE = "http://localhost:8080/api/v1"
headers = {"Content-Type": "application/json"}

# 2. 문서 삽입
def insert_documents(texts):
    url = f"{API_BASE}/insert/batch"
    data = {"texts": texts}
    resp = requests.post(url, json=data, headers=headers)
    return resp.json()

# 3. 검색
def search(query, k=10):
    url = f"{API_BASE}/search"
    data = {"query": query, "k": k}
    resp = requests.post(url, json=data, headers=headers)
    return resp.json()

# 4. 통계
def get_stats():
    url = f"{API_BASE}/stats"
    resp = requests.get(url)
    return resp.json()

# 사용
docs = [
    "FreeLang은 정적 타입의 프로그래밍 언어입니다",
    "Rust는 메모리 안전성을 보장합니다",
    "Go는 병렬 처리에 최적화되어 있습니다"
]

# 삽입
result = insert_documents(docs)
print(f"삽입: {result['count']}개")

# 검색
results = search("정적 타입 언어")
for item in results['results']:
    print(f"{item['rank']}: {item['score']:.4f} - doc_{item['id']}")

# 통계
stats = get_stats()
print(f"총 문서: {stats['total_docs']}")
print(f"평균 검색: {stats['avg_search_ms']:.3f}ms")
```

### Node.js 예제

```javascript
const fetch = require('node-fetch');

const API_BASE = "http://localhost:8080/api/v1";

async function insert(texts) {
  const res = await fetch(`${API_BASE}/insert/batch`, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ texts })
  });
  return res.json();
}

async function search(query, k = 10) {
  const res = await fetch(`${API_BASE}/search`, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ query, k })
  });
  return res.json();
}

// 사용
(async () => {
  const result = await insert(["문서 1", "문서 2"]);
  console.log(`삽입: ${result.count}개`);

  const searchResult = await search("문서");
  console.log(`검색: ${searchResult.count}건`);
})();
```

