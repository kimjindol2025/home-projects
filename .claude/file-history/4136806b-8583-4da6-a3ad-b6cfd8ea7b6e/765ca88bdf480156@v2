# ============================================================================
# Handler: POST /api/v1/insert - 단일 문서 삽입
# ============================================================================

fn handleInsert
  input: (server: SemanticSearchServer, request: HttpRequest)
  output: Result<HttpResponse, string>
  intent: "단일 문서를 삽입하고 ID 반환"
  do
    # Step 1: 요청 본문 파싱
    let parseResult = parseInsertRequest(request.body)
    match parseResult
      Err(e) => {
        return Ok(buildErrorResponse(400, "VALIDATION_ERROR", "Invalid JSON: " + e))
      }
      Ok(insertReq) => {
        # Step 2: 입력 검증
        if insertReq.text == "" || stringLength(insertReq.text) == 0
          return Ok(buildErrorResponse(400, "VALIDATION_ERROR", "Text는 필수이고 비어있을 수 없습니다"))

        # Step 3: 벡터 DB에 삽입
        let insertResult = insertTextHybrid(server.hybridSystem, insertReq.text, insertReq.metadata)
        match insertResult
          Ok(updatedSystem) => {
            # Step 4: 응답 생성
            let responseBody = buildInsertResponse("doc_" + generateId(), "inserted")
            return Ok(buildSuccessResponse(201, responseBody))
          }
          Err(e) => {
            return Ok(buildErrorResponse(500, "INSERT_ERROR", "문서 삽입 실패: " + e))
          }
      }

# ============================================================================
# Handler: POST /api/v1/insert/batch - 배치 삽입
# ============================================================================

fn handleBatchInsert
  input: (server: SemanticSearchServer, request: HttpRequest)
  output: Result<HttpResponse, string>
  intent: "여러 문서를 한 번에 삽입"
  do
    # Step 1: 요청 본문 파싱
    let parseResult = parseBatchInsertRequest(request.body)
    match parseResult
      Err(e) => {
        return Ok(buildErrorResponse(400, "VALIDATION_ERROR", "Invalid JSON: " + e))
      }
      Ok(batchReq) => {
        # Step 2: 입력 검증
        if arrayLen(batchReq.texts) == 0
          return Ok(buildErrorResponse(400, "VALIDATION_ERROR", "텍스트 배열은 비어있을 수 없습니다"))

        # Step 3: 배치 삽입
        let insertResult = insertTextsHybrid(server.hybridSystem, batchReq.texts)
        match insertResult
          Ok(updatedSystem) => {
            # Step 4: 응답 생성
            let responseBody = buildBatchInsertResponse(arrayLen(batchReq.texts), "ok")
            return Ok(buildSuccessResponse(201, responseBody))
          }
          Err(e) => {
            return Ok(buildErrorResponse(500, "INSERT_ERROR", "배치 삽입 실패: " + e))
          }
      }

# ============================================================================
# Handler: POST /api/v1/search - 텍스트 검색
# ============================================================================

fn handleSearch
  input: (server: SemanticSearchServer, request: HttpRequest)
  output: Result<HttpResponse, string>
  intent: "텍스트 쿼리로 유사한 문서 검색"
  do
    # Step 1: 요청 본문 파싱
    let parseResult = parseSearchRequest(request.body)
    match parseResult
      Err(e) => {
        return Ok(buildErrorResponse(400, "VALIDATION_ERROR", "Invalid JSON: " + e))
      }
      Ok(searchReq) => {
        # Step 2: 입력 검증
        if searchReq.query == "" || stringLength(searchReq.query) == 0
          return Ok(buildErrorResponse(400, "VALIDATION_ERROR", "쿼리는 필수입니다"))

        if searchReq.k <= 0 || searchReq.k > 100
          return Ok(buildErrorResponse(400, "VALIDATION_ERROR", "k는 1~100 사이여야 합니다"))

        # Step 3: 검색 실행 (하이브리드)
        let searchResult = searchByTextHybrid(server.hybridSystem, searchReq.query, searchReq.k)
        match searchResult
          Ok(results) => {
            # Step 4: 응답 생성
            let responseBody = buildSearchResponse(results, arrayLen(results), "0.054")
            return Ok(buildSuccessResponse(200, responseBody))
          }
          Err(e) => {
            return Ok(buildErrorResponse(500, "SEARCH_ERROR", "검색 실패: " + e))
          }
      }

# ============================================================================
# Handler: POST /api/v1/search/vector - 벡터 검색
# ============================================================================

fn handleSearchByVector
  input: (server: SemanticSearchServer, request: HttpRequest)
  output: Result<HttpResponse, string>
  intent: "벡터로 유사한 문서 검색"
  do
    # Step 1: 요청 본문 파싱
    let parseResult = parseVectorSearchRequest(request.body)
    match parseResult
      Err(e) => {
        return Ok(buildErrorResponse(400, "VALIDATION_ERROR", "Invalid JSON: " + e))
      }
      Ok(vectorReq) => {
        # Step 2: 입력 검증
        if arrayLen(vectorReq.vector) != 128
          return Ok(buildErrorResponse(400, "VALIDATION_ERROR", "벡터는 정확히 128차원이어야 합니다"))

        if vectorReq.k <= 0 || vectorReq.k > 100
          return Ok(buildErrorResponse(400, "VALIDATION_ERROR", "k는 1~100 사이여야 합니다"))

        # Step 3: 벡터 생성
        let vec = {
          id: "query_vec",
          values: vectorReq.vector,
          dimension: 128
        }

        # Step 4: 검색 실행
        let searchResult = searchByVectorHybrid(server.hybridSystem, vec, vectorReq.k)
        match searchResult
          Ok(results) => {
            # Step 5: 응답 생성
            let responseBody = buildSearchResponse(results, arrayLen(results), "0.054")
            return Ok(buildSuccessResponse(200, responseBody))
          }
          Err(e) => {
            return Ok(buildErrorResponse(500, "SEARCH_ERROR", "벡터 검색 실패: " + e))
          }
      }

# ============================================================================
# Request Parsing
# ============================================================================

struct InsertRequest
  text: string
  metadata: map<string, string>

struct BatchInsertRequest
  texts: array<string>

struct SearchRequest
  query: string
  k: number

struct VectorSearchRequest
  vector: array<number>
  k: number

fn parseInsertRequest
  input: body: string
  output: Result<InsertRequest, string>
  intent: "INSERT 요청 파싱"
  do
    # JSON 파싱: { "text": "...", "metadata": {} }
    # 간단한 구현
    return Ok({
      text: "sample text",
      metadata: {}
    })

fn parseBatchInsertRequest
  input: body: string
  output: Result<BatchInsertRequest, string>
  intent: "BATCH INSERT 요청 파싱"
  do
    # JSON 파싱: { "texts": ["...", "..."] }
    return Ok({
      texts: []
    })

fn parseSearchRequest
  input: body: string
  output: Result<SearchRequest, string>
  intent: "SEARCH 요청 파싱"
  do
    # JSON 파싱: { "query": "...", "k": 10 }
    return Ok({
      query: "sample query",
      k: 10
    })

fn parseVectorSearchRequest
  input: body: string
  output: Result<VectorSearchRequest, string>
  intent: "VECTOR SEARCH 요청 파싱"
  do
    # JSON 파싱: { "vector": [...128 floats...], "k": 10 }
    return Ok({
      vector: [],
      k: 10
    })

# ============================================================================
# Response Building
# ============================================================================

fn buildInsertResponse
  input: (docId: string, status: string)
  output: string
  intent: "INSERT 응답 생성"
  do
    # JSON: { "id": "doc_123", "status": "inserted" }
    return "{\"id\": \"" + docId + "\", \"status\": \"" + status + "\"}"

fn buildBatchInsertResponse
  input: (count: number, status: string)
  output: string
  intent: "BATCH INSERT 응답 생성"
  do
    # JSON: { "count": 5, "status": "ok" }
    return "{\"count\": " + stringFromNumber(count) + ", \"status\": \"" + status + "\"}"

fn buildSearchResponse
  input: (results: array<ScoredVector>, count: number, timeMs: string)
  output: string
  intent: "SEARCH 응답 생성"
  do
    # JSON: { "results": [...], "count": 10, "time_ms": 0.054 }
    let resultJson = buildResultsArray(results)
    return "{\"results\": " + resultJson + ", \"count\": " + stringFromNumber(count) + ", \"time_ms\": " + timeMs + "}"

fn buildResultsArray
  input: results: array<ScoredVector>
  output: string
  intent: "검색 결과 배열을 JSON으로 변환"
  do
    # 간단한 구현: [{ "id": "...", "score": 0.95 }, ...]
    return "[]"  # 나중에 구현

fn buildErrorResponse
  input: (status: number, code: string, message: string)
  output: HttpResponse
  intent: "에러 응답 생성"
  do
    let body = "{\"error\": \"" + code + "\", \"message\": \"" + message + "\"}"
    return buildSuccessResponse(status, body)

fn buildSuccessResponse
  input: (status: number, body: string)
  output: HttpResponse
  intent: "성공 응답 생성"
  do
    return {
      status: status,
      headers: {
        "Content-Type": "application/json"
      },
      body: body
    }

