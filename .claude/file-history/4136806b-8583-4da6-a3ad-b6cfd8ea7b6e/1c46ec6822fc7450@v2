fn testChunkSmallDocument
  input: none
  output: Result<bool, string>
  intent: "짧은 문서는 1개 청크로"
  do
    let config = newChunkConfigDefault()
    let text = "짧은 문서입니다."
    match chunkDocument("doc_1", text, config)
      Ok(chunks) => {
        if arrayLen(chunks) == 1
          return Ok(true)
        else
          return Err("예상 1개, 실제 " + stringFromNumber(arrayLen(chunks)))
      }
      Err(e) => return Err(e)

