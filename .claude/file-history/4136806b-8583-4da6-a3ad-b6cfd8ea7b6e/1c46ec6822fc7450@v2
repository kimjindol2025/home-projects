fn runAllRagTests
  input: none
  output: map<string, bool>
  intent: "모든 RAG 테스트 실행"
  do
    let results = {}

    # Group A: Chunking
    results["testChunkSmallDocument"] = testChunkSmallDocument()
    results["testChunkLargeDocument"] = testChunkLargeDocument()
    results["testChunkOverlap"] = testChunkOverlap()
    results["testChunkMinSize"] = testChunkMinSize()
    results["testChunkMetadata"] = testChunkMetadata()

    # Group B: Batch Embedding
    results["testBatchEmbedSingle"] = testBatchEmbedSingle()
    results["testBatchEmbedMultiple"] = testBatchEmbedMultiple()
    results["testBatchRetry"] = testBatchRetry()
    results["testBatchProgress"] = testBatchProgress()

    # Group C: Pipeline
    results["testIngestDocument"] = testIngestDocument()
    results["testIngestBatch"] = testIngestBatch()
    results["testQuery"] = testQuery()
    results["testBuildContext"] = testBuildContext()
    results["testBuildPrompt"] = testBuildPrompt()

    # Group D: LLM Integration
    results["testBuildRagMessages"] = testBuildRagMessages()
    results["testParseRagResponse"] = testParseRagResponse()
    results["testEstimateConfidence"] = testEstimateConfidence()

    return results
