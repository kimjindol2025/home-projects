fn createTestChunks
  input: count: number
  output: array<Chunk>
  intent: "테스트용 청크 배열 생성"
  do
    let chunks = []
    let i = 0
    for i in 0..count
      let chunk = {
        id: "chunk_" + stringFromNumber(i),
        text: "테스트 청크 " + stringFromNumber(i),
        docId: "doc_test",
        chunkIndex: i,
        tokenCount: 100,
        startOffset: i * 100,
        endOffset: (i + 1) * 100,
        metadata: {}
      }
      chunks = arrayPush(chunks, chunk)

    return chunks

fn createTestDocuments
  input: count: number
  output: array<Document>
  intent: "테스트용 문서 배열 생성"
  do
    let docs = []
    let i = 0
    for i in 0..count
      let doc = {
        id: "test_doc_" + stringFromNumber(i),
        title: "테스트 문서 " + stringFromNumber(i),
        text: generateLargeText(500),
        metadata: {}
      }
      docs = arrayPush(docs, doc)

    return docs

fn createTestSearchResults
  input: count: number
  output: array<ScoredVector>
  intent: "테스트용 검색 결과 생성"
  do
    let results = []
    let i = 0
    for i in 0..count
      let result = {
        id: "chunk_test_" + stringFromNumber(i),
        score: 0.9 - (i * 0.1),
        rank: i + 1
      }
      results = arrayPush(results, result)

    return results

fn generateLargeText
  input: charCount: number
  output: string
  intent: "지정된 길이의 테스트 텍스트 생성"
  do
    let text = ""
    let i = 0
    for i in 0..charCount
      text = text + "a"

    return text

