struct ReplicaSet
  partitionId: number
  primaryNodeId: number
  replicaNodeIds: array<number>
  replicationFactor: number
  quorumSize: number             # ceil(replicationFactor / 2) + 1

struct ReplicationRequest
  vectorId: string
  partitionId: number
  commandType: string             # "INSERT" | "DELETE"
  payload: string
  requestId: string               # UUID (멱등성)
  term: number

struct ReplicationResponse
  nodeId: number
  success: bool
  term: number
  errorMessage: Option<string>

struct QuorumResult
  requestId: string
  success: bool
  successCount: number
  quorumAchieved: bool
  responses: array<ReplicationResponse>
  latencyMs: number

struct FailoverState
  failedNodeId: number
  detectedAt: number
  replacement: Option<number>
  status: string                  # "DETECTED" | "PROMOTING" | "COMPLETE"
  affectedPartitions: array<number>

struct ReplicationManager
  replicaSets: map<number, ReplicaSet>
  pendingRequests: map<string, ReplicationRequest>
  failoverStates: map<number, FailoverState>
  stats: ReplicationStats

struct ReplicationStats
  totalWrites: number
  quorumSuccesses: number
  quorumFailures: number
  failovers: number
  avgReplicationLatencyMs: number

struct PartitionHealth
  partitionId: number
  isHealthy: bool
  liveReplicas: number
  issues: array<string>

# ============================================================================
# 초기화
# ============================================================================

fn newReplicationManager
  input: (partitions: array<PartitionInfo>, replicationFactor: number)
  output: ReplicationManager
  intent: "복제 관리자 초기화"
  do
    let replicaSets = {}
    let i = 0

    for i in 0..arrayLen(partitions)
      let partition = arrayGet(partitions, i)
      let replicaSet = buildReplicaSet(partition, replicationFactor)
      replicaSets = mapSet(replicaSets, partition.partitionId, replicaSet)

    return {
      replicaSets: replicaSets,
      pendingRequests: {},
      failoverStates: {},
      stats: {
        totalWrites: 0,
        quorumSuccesses: 0,
        quorumFailures: 0,
        failovers: 0,
        avgReplicationLatencyMs: 0
      }
    }

fn buildReplicaSet
  input: (partition: PartitionInfo, replicationFactor: number)
  output: ReplicaSet
  intent: "파티션의 복제 세트 구성"
  do
    let quorumSize = (replicationFactor / 2) + 1

    return {
      partitionId: partition.partitionId,
      primaryNodeId: partition.primaryNodeId,
      replicaNodeIds: partition.replicaNodeIds,
      replicationFactor: replicationFactor,
      quorumSize: quorumSize
    }

# ============================================================================
# Quorum Write
# ============================================================================

fn quorumWrite
  input: (mgr: ReplicationManager, req: ReplicationRequest, cluster: RaftIndexCluster)
  output: Result<QuorumResult, string>
  intent: "Quorum Write: 다수 복제 노드에 쓰기"
  do
    let startTime = 0  # getCurrentTimeMs()

    # 복제 세트 조회
    match mapGet(mgr.replicaSets, req.partitionId)
      None => return Err("Partition not found")
      Some(replicaSet) => {
        let responses = []
        let i = 0

        # 각 복제 노드에 쓰기 요청
        for i in 0..arrayLen(replicaSet.replicaNodeIds)
          let nodeId = arrayGet(replicaSet.replicaNodeIds, i)
          let response = sendReplicationRequest(nodeId, req, cluster)
          responses = arrayPush(responses, response)

        # Quorum 결과 수집
        let quorumResult = collectQuorumResponses(responses, replicaSet.quorumSize)
        quorumResult.requestId = req.requestId
        quorumResult.latencyMs = 0  # startTime 이후 경과시간

        if quorumResult.quorumAchieved
          return Ok(quorumResult)
        else
          return Err("Quorum not achieved: " + stringFromNumber(quorumResult.successCount) + "/" + stringFromNumber(replicaSet.quorumSize))
      }

fn sendReplicationRequest
  input: (targetNodeId: number, req: ReplicationRequest, cluster: RaftIndexCluster)
  output: ReplicationResponse
  intent: "개별 노드에 복제 요청 전송"
  do
    # 시뮬레이션: Raft AppendEntries를 통한 복제
    match mapGet(cluster.nodes, targetNodeId)
      None => {
        return {
          nodeId: targetNodeId,
          success: false,
          term: 0,
          errorMessage: Some("Node not found")
        }
      }
      Some(node) => {
        # 명령을 RaftIndexNode에 추가
        match appendVectorCommand(node, req.commandType, req.partitionId, req.payload)
          Ok(_updatedNode) => {
            return {
              nodeId: targetNodeId,
              success: true,
              term: node.currentTerm,
              errorMessage: None
            }
          }
          Err(e) => {
            return {
              nodeId: targetNodeId,
              success: false,
              term: node.currentTerm,
              errorMessage: Some(e)
            }
          }

fn collectQuorumResponses
  input: (responses: array<ReplicationResponse>, quorumSize: number)
  output: QuorumResult
  intent: "복제 응답 집계"
  do
    let successCount = 0
    let i = 0

    for i in 0..arrayLen(responses)
      let resp = arrayGet(responses, i)
      if resp.success
        successCount = successCount + 1

    let quorumAchieved = successCount >= quorumSize

    return {
      requestId: "",
      success: quorumAchieved,
      successCount: successCount,
      quorumAchieved: quorumAchieved,
      responses: responses,
      latencyMs: 0
    }

