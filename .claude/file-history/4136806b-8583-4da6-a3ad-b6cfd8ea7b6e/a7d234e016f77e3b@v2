fn checkReplicationHealth
  input: (mgr: ReplicationManager, cluster: RaftIndexCluster)
  output: array<PartitionHealth>
  intent: "복제 건강도 확인"
  do
    let healths = []
    let i = 0

    for i in 0..mapSize(mgr.replicaSets)
      match mapGet(mgr.replicaSets, i)
        Some(replicaSet) => {
          let liveReplicas = 0
          let issues = []
          let j = 0

          # 각 replica 확인
          for j in 0..arrayLen(replicaSet.replicaNodeIds)
            let nodeId = arrayGet(replicaSet.replicaNodeIds, j)
            match mapGet(cluster.nodes, nodeId)
              Some(_node) => liveReplicas = liveReplicas + 1
              None => issues = arrayPush(issues, "Replica " + stringFromNumber(nodeId) + " unavailable")

          let isHealthy = liveReplicas >= replicaSet.quorumSize

          let health = {
            partitionId: replicaSet.partitionId,
            isHealthy: isHealthy,
            liveReplicas: liveReplicas,
            issues: issues
          }

          healths = arrayPush(healths, health)
        }
        None => {}

    return healths

fn reportReplicationStatus
  input: mgr: ReplicationManager
  output: string
  intent: "복제 상태 리포트"
  do
    let report = ""
    report = report + "=== Replication Status ===\n"
    report = report + "Total Writes: " + stringFromNumber(mgr.stats.totalWrites) + "\n"
    report = report + "Quorum Successes: " + stringFromNumber(mgr.stats.quorumSuccesses) + "\n"
    report = report + "Quorum Failures: " + stringFromNumber(mgr.stats.quorumFailures) + "\n"
    report = report + "Failovers: " + stringFromNumber(mgr.stats.failovers) + "\n"

    return report

