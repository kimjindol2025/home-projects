# ============================================================================
# 장애 감지 및 복구
# ============================================================================

fn detectNodeFailure
  input: (mgr: ReplicationManager, nodeId: number, cluster: RaftIndexCluster)
  output: Result<FailoverState, string>
  intent: "노드 장애 감지"
  do
    # 영향 받는 파티션 찾기
    let affectedPartitions = []
    let i = 0

    for i in 0..mapSize(mgr.replicaSets)
      let keyStr = stringFromNumber(i)
      match mapGet(mgr.replicaSets, i)
        Some(replicaSet) => {
          if replicaSet.primaryNodeId == nodeId
            affectedPartitions = arrayPush(affectedPartitions, replicaSet.partitionId)
        }
        None => {}

    if arrayLen(affectedPartitions) == 0
      return Err("Node is not primary of any partition")

    let failoverState = {
      failedNodeId: nodeId,
      detectedAt: 0,  # getCurrentTimeMs()
      replacement: None,
      status: "DETECTED",
      affectedPartitions: affectedPartitions
    }

    return Ok(failoverState)

fn initiateFailover
  input: (mgr: ReplicationManager, failedNodeId: number, cluster: RaftIndexCluster)
  output: Result<ReplicationManager, string>
  intent: "장애 복구 시작: Replica 승격"
  do
    # 각 파티션별로 Replica 승격
    let newMgr = mgr
    let i = 0

    for i in 0..mapSize(mgr.replicaSets)
      match mapGet(mgr.replicaSets, i)
        Some(replicaSet) => {
          if replicaSet.primaryNodeId == failedNodeId
            # 새 Primary 선택
            match selectReplacementNode(failedNodeId, arrayPush(replicaSet.replicaNodeIds, replicaSet.primaryNodeId), cluster)
              Some(newPrimary) => {
                match promoteReplica(newMgr, replicaSet.partitionId, newPrimary)
                  Ok(updatedMgr) => newMgr = updatedMgr
                  Err(_e) => {}
              }
              None => {}
        }
        None => {}

    newMgr.stats.failovers = newMgr.stats.failovers + 1
    return Ok(newMgr)

fn selectReplacementNode
  input: (failedNodeId: number, candidateNodeIds: array<number>, cluster: RaftIndexCluster)
  output: Option<number>
  intent: "가장 부하가 낮은 정상 노드 선택"
  do
    let bestNodeId = None
    let minLoad = 999999
    let i = 0

    for i in 0..arrayLen(candidateNodeIds)
      let nodeId = arrayGet(candidateNodeIds, i)
      if nodeId != failedNodeId
        match mapGet(cluster.nodes, nodeId)
          Some(node) => {
            # 간단한 부하 추정: log 크기
            let load = arrayLen(node.log)
            if load < minLoad
              minLoad = load
              bestNodeId = Some(nodeId)
          }
          None => {}

    return bestNodeId

fn promoteReplica
  input: (mgr: ReplicationManager, partitionId: number, newPrimaryId: number)
  output: Result<ReplicationManager, string>
  intent: "Replica를 새 Primary로 승격"
  do
    match mapGet(mgr.replicaSets, partitionId)
      None => return Err("Partition not found")
      Some(replicaSet) => {
        let newReplicaSet = replicaSet
        newReplicaSet.primaryNodeId = newPrimaryId

        let newMgr = mgr
        newMgr.replicaSets = mapSet(newMgr.replicaSets, partitionId, newReplicaSet)

        return Ok(newMgr)
      }

fn completeFailover
  input: (mgr: ReplicationManager, failedNodeId: number)
  output: ReplicationManager
  intent: "장애 복구 완료"
  do
    match mapGet(mgr.failoverStates, failedNodeId)
      Some(state) => {
        let newState = state
        newState.status = "COMPLETE"
        let newMgr = mgr
        newMgr.failoverStates = mapSet(newMgr.failoverStates, failedNodeId, newState)
        return newMgr
      }
      None => return mgr

