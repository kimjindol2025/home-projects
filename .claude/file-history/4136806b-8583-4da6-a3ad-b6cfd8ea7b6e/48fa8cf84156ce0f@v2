fn testInsertSingleDocument
  input: none
  output: Result<bool, string>
  intent: "단일 문서 삽입 성공"
  do
    let server = createTestServer()
    let request = {
      method: "POST",
      path: "/api/v1/insert",
      body: "{\"text\": \"Hello World\", \"metadata\": {}}"
    }

    match routeRequest(server, request)
      Ok(response) => {
        if response.status == 201
          return Ok(true)
        else
          return Err("예상 201, 실제 " + stringFromNumber(response.status))
      }
      Err(e) => return Err(e)

