# ============================================================================
# Test Runner
# ============================================================================

fn runAllApiTests
  input: none
  output: map<string, bool>
  intent: "모든 API 테스트 실행"
  do
    let results = {}

    # Group A: Insert
    results["testInsertSingleDocument"] = testInsertSingleDocument()
    results["testInsertWithMetadata"] = testInsertWithMetadata()
    results["testInsertBatch"] = testInsertBatch()
    results["testInsertInvalidJson"] = testInsertInvalidJson()
    results["testInsertEmptyText"] = testInsertEmptyText()

    # Group B: Search
    results["testSearchByText"] = testSearchByText()
    results["testSearchTopK"] = testSearchTopK()
    results["testSearchEmptyQuery"] = testSearchEmptyQuery()
    results["testSearchInvalidK"] = testSearchInvalidK()
    results["testSearchByVector"] = testSearchByVector()
    results["testSearchByVectorWrongDimension"] = testSearchByVectorWrongDimension()
    results["testSearchReturnFormat"] = testSearchReturnFormat()

    # Group C: Stats & Health
    results["testStatsAfterInsert"] = testStatsAfterInsert()
    results["testStatsBeforeInsert"] = testStatsBeforeInsert()
    results["testHealthEndpoint"] = testHealthEndpoint()
    results["testHealthFormat"] = testHealthFormat()

    # Group D: Routing
    results["testUnknownRoute404"] = testUnknownRoute404()
    results["testMethodNotAllowed"] = testMethodNotAllowed()
    results["testCORSHeaders"] = testCORSHeaders()

    return results
