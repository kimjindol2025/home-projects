class TestAssertRaises(unittest.TestCase):
    """assertRaises - 예외 발생 검증"""

    def test_raises_value_error(self):
        """ValueError 발생 확인"""
        with self.assertRaises(ValueError):
            calculate_data_reliability(150, 100)

    def test_raises_type_error(self):
        """TypeError 발생 확인"""
        with self.assertRaises(TypeError):
            # 문자열을 계산에 사용
            result = "invalid" / 100

    def test_no_exception(self):
        """예외가 발생하지 않아야 함"""
        try:
            result = calculate_data_reliability(80, 100)
            self.assertEqual(result, 80.0)
        except Exception as e:
            self.fail(f"예상치 않은 예외: {e}")


class TestDataValidator(unittest.TestCase):
    """DataValidator 종합 테스트"""

    def setUp(self):
        """각 테스트 전 validator 생성"""
        self.validator = DataValidator()

    def test_validate_researcher_valid(self):
        """유효한 연구자 데이터"""
        data = {'name': 'Alice', 'email': 'alice@example.com'}
        self.assertTrue(self.validator.validate_researcher(data))

    def test_validate_researcher_missing_name(self):
        """name 필드 누락"""
        data = {'email': 'alice@example.com'}
        self.assertFalse(self.validator.validate_researcher(data))

    def test_validate_researcher_empty_name(self):
        """name이 빈 문자열"""
        data = {'name': '', 'email': 'alice@example.com'}
        self.assertFalse(self.validator.validate_researcher(data))

    def test_validate_experiment_valid(self):
        """유효한 실험 데이터"""
        data = {'id': 1, 'name': 'Exp1', 'result': 95}
        self.assertTrue(self.validator.validate_experiment(data))

    def test_validate_experiment_invalid_result(self):
        """result가 0~100 범위 벗어남"""
        data = {'id': 1, 'name': 'Exp1', 'result': 150}
        self.assertFalse(self.validator.validate_experiment(data))

    def test_validate_email(self):
        """이메일 형식 검증"""
        self.assertTrue(self.validator.validate_email('test@example.com'))
        self.assertFalse(self.validator.validate_email('invalid-email'))

    def test_validate_score_range(self):
        """점수 범위 검증"""
        self.assertTrue(self.validator.validate_score_range(50))
        self.assertFalse(self.validator.validate_score_range(150))
        self.assertFalse(self.validator.validate_score_range(-10))


class TestReportGenerator(unittest.TestCase):
    """ReportGenerator 종합 테스트"""

    def setUp(self):
        self.generator = ReportGenerator()
        self.test_experiments = [
            {'id': 1, 'name': 'Exp1', 'result': 95, 'status': 'completed'},
            {'id': 2, 'name': 'Exp2', 'result': 85, 'status': 'completed'},
            {'id': 3, 'name': 'Exp3', 'result': 75, 'status': 'completed'},
        ]

    def test_generate_summary_with_data(self):
        """데이터 있을 때 요약 생성"""
        summary = self.generator.generate_summary(self.test_experiments)
        self.assertIn("3개 실험", summary)
        self.assertIn("평균", summary)

    def test_generate_summary_empty(self):
        """빈 데이터로 요약 생성"""
        summary = self.generator.generate_summary([])
        self.assertEqual(summary, "실험 데이터가 없습니다.")

    def test_generate_detailed_report(self):
        """상세 리포트 생성"""
        report = self.generator.generate_detailed_report(self.test_experiments)
        self.assertIn("실험 분석 리포트", report)
        self.assertIn("총 실험 수: 3", report)

    def test_export_csv_header(self):
        """CSV 헤더 생성"""
        header = self.generator.export_csv_header()
        self.assertIn("ID", header)
        self.assertIn("Name", header)
        self.assertIn("Grade", header)

    def test_export_csv_row(self):
        """CSV 행 생성"""
        exp = {'id': 1, 'name': 'Test', 'status': 'ok', 'result': 95, 'researcher': 'John'}
        row = self.generator.export_csv_row(exp, 'A')
        self.assertIn("1,Test,ok,95,John,A", row)


