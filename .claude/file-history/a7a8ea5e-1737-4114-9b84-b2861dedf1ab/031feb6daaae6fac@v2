class TestWithSetupTeardown(unittest.TestCase):
    """setUp/tearDown 기본 사용"""

    @classmethod
    def setUpClass(cls):
        """클래스 전체 테스트 전에 한 번만 실행"""
        print("\n✓ setUpClass 실행 (한 번만)")
        cls.shared_data = [
            {'id': 1, 'result': 95, 'status': 'completed'},
            {'id': 2, 'result': 85, 'status': 'completed'},
            {'id': 3, 'result': 75, 'status': 'completed'},
        ]

    def setUp(self):
        """각 테스트 메서드 전에 실행"""
        print("  → setUp 실행 (매 테스트마다)")
        self.analyzer = ExperimentAnalyzer()
        self.validator = DataValidator()
        self.generator = ReportGenerator()

    def tearDown(self):
        """각 테스트 메서드 후에 실행"""
        print("  ← tearDown 실행 (매 테스트마다)")
        # 필요 시 리소스 정리
        pass

    @classmethod
    def tearDownClass(cls):
        """클래스 전체 테스트 후에 한 번만 실행"""
        print("✓ tearDownClass 실행 (한 번만)\n")
        cls.shared_data = None

    def test_average_score_with_fixture(self):
        """Fixture의 shared_data 사용"""
        avg = self.analyzer.get_average_score(self.__class__.shared_data)
        self.assertEqual(avg, 85)

    def test_get_pass_rate_with_fixture(self):
        """통과율 계산"""
        pass_rate = self.analyzer.get_pass_rate(self.__class__.shared_data)
        self.assertAlmostEqual(pass_rate, 100, places=1)

    def test_validator_initialized(self):
        """validator가 초기화되었는지 확인"""
        self.assertIsNotNone(self.validator)

    def test_generator_initialized(self):
        """generator가 초기화되었는지 확인"""
        self.assertIsNotNone(self.generator)


