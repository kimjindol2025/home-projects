class TestWithTempFiles(unittest.TestCase):
    """임시 파일을 fixture로 관리"""

    def setUp(self):
        """임시 디렉토리 생성"""
        self.temp_dir = tempfile.TemporaryDirectory()
        self.temp_path = self.temp_dir.name

    def tearDown(self):
        """임시 디렉토리 정리"""
        self.temp_dir.cleanup()

    def test_report_file_generation(self):
        """리포트 파일 생성"""
        generator = ReportGenerator()
        report_file = os.path.join(self.temp_path, 'report.txt')

        # 파일 생성
        with open(report_file, 'w') as f:
            f.write("Test Report")

        # 파일 확인
        self.assertTrue(os.path.exists(report_file))

    def test_csv_export(self):
        """CSV 파일 생성"""
        generator = ReportGenerator()
        csv_file = os.path.join(self.temp_path, 'experiments.csv')

        with open(csv_file, 'w') as f:
            f.write(generator.export_csv_header())
            exp = {'id': 1, 'name': 'Test', 'status': 'ok', 'result': 95}
            f.write(generator.export_csv_row(exp, 'A'))

        with open(csv_file, 'r') as f:
            content = f.read()

        self.assertIn("ID", content)
        self.assertIn("Test", content)


class TestWithResourcePooling(unittest.TestCase):
