        """미지의 큐 타입"""
        with self.assertRaises(ValueError):
            QueueFactory.create_queue(
                "unknown",
                self.broker
            )


class TestQueueIntegration(unittest.TestCase):
    """큐 통합 테스트"""

    def setUp(self):
        """각 테스트 전 초기화"""
        self.broker = GogsMessageBroker()

    async def _async_multiple_queues(self):
        """여러 큐 동시 사용"""
        queue1 = BrokerBasedQueue(self.broker, name="Queue1")
        queue2 = DelayedQueue(self.broker, name="Queue2")

        # queue1에 즉시 처리 아이템
        await queue1.enqueue({"data": "immediate"})

        # queue2에 지연 아이템
        await queue2.enqueue({"data": "delayed"}, delay_seconds=0.5)

        return queue1, queue2

    def test_multiple_queues(self):
        """여러 큐 동시 사용"""
        queue1, queue2 = asyncio.run(self._async_multiple_queues())
        self.assertEqual(queue1.enqueue_count, 1)
        self.assertEqual(queue2.enqueue_count, 1)


