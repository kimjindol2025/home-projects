    def setUp(self):
        """각 테스트 전 초기화"""
        self.broker = GogsMessageBroker()
        self.priority_broker = PriorityMessageBroker()

    def test_create_basic_queue(self):
        """기본 큐 생성"""
        queue = QueueFactory.create_queue(
            "basic",
            self.broker,
            name="BasicQueue"
        )
        self.assertIsInstance(queue, BrokerBasedQueue)

    def test_create_priority_queue(self):
        """우선순위 큐 생성"""
        queue = QueueFactory.create_queue(
            "priority",
            self.priority_broker,
            name="PriorityQueue"
        )
        self.assertIsInstance(queue, PriorityQueue)

    def test_create_delayed_queue(self):
        """지연 큐 생성"""
        queue = QueueFactory.create_queue(
            "delayed",
            self.broker,
            name="DelayedQueue"
        )
        self.assertIsInstance(queue, DelayedQueue)

    def test_create_batch_queue(self):
        """배치 큐 생성"""
        queue = QueueFactory.create_queue(
            "batch",
            self.broker,
            batch_size=10,
            name="BatchQueue"
        )
        self.assertIsInstance(queue, BatchQueue)

    def test_create_retry_queue(self):
        """재시도 큐 생성"""
        queue = QueueFactory.create_queue(
            "retry",
            self.broker,
            max_retries=3,
            name="RetryQueue"
        )
        self.assertIsInstance(queue, RetryQueue)

