class TestDeploymentManager(unittest.TestCase):
    """배포 관리자 테스트"""

    def setUp(self):
        self.manager = GogsDeployManager()

    def test_environment_check_basic(self):
        """환경 확인 기본 테스트"""
        status = self.manager.check_environment()
        self.assertIsNotNone(status)
        self.assertIn("python_version", status)

    def test_deployment_report_generation(self):
        """배포 보고서 생성"""
        report = self.manager.generate_deployment_report()
        self.assertIsNotNone(report)
        self.assertIn("is_ready", report)


class TestEnvironmentValidator(unittest.TestCase):
    """환경 검증자 테스트"""

    def test_python_version_validation(self):
        """Python 버전 검증"""
        is_valid, msg = EnvironmentValidator.validate_python_version("3.8")
        self.assertTrue(is_valid)

    def test_os_compatibility(self):
        """OS 호환성 검증"""
        is_valid, msg = EnvironmentValidator.validate_os_compatibility(
            ["Linux", "Windows", "Darwin"]
        )
        self.assertTrue(is_valid)

    def test_venv_active_check(self):
        """가상 환경 활성화 확인"""
        is_active = VirtualEnvironmentManager.is_venv_active()
        self.assertIsInstance(is_active, bool)


class TestDependencyManager(unittest.TestCase):
    """의존성 관리자 테스트"""

    def test_installed_packages_retrieval(self):
        """설치된 패키지 조회"""
        packages = DependencyManager.get_installed_packages()
        self.assertIsInstance(packages, dict)
        self.assertGreater(len(packages), 0)

    def test_environment_isolation_report(self):
        """환경 격리 보고서"""
        report = EnvironmentIsolationReport.generate_report("development")
        self.assertIsNotNone(report)
        self.assertIn("reproducibility", report)


