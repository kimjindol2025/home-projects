// ============ TensorSemantics Implementation ============

std::string TensorSemantics::getSemantics() const {
  if (auto matmul = dyn_cast<linalg::MatmulOp>(mlirOp_)) {
    return getMatMulSemantics();
  }
  if (auto conv = dyn_cast<linalg::Conv2DOp>(mlirOp_)) {
    return getConv2DSemantics();
  }
  if (auto add = dyn_cast<linalg::AddOp>(mlirOp_)) {
    return getAddSemantics();
  }
  return "[Unknown tensor operation]";
}

