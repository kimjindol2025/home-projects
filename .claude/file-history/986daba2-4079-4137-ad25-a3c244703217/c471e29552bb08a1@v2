CorrectnessChecker::CorrectnessChecker(mlir::MLIRContext* ctx)
    : context(ctx) {
    // LLVM 초기화
    llvm::InitializeNativeTarget();
    llvm::InitializeNativeTargetAsmPrinter();
}

// ============================================================================
// 메인 검증 함수
// ============================================================================

bool CorrectnessChecker::verify(mlir::Operation* original,
                                mlir::Operation* optimized) {
    // Phase 1: 구체적 테스트로 빠르게 검증
    std::vector<std::vector<float>> testInputs = {
        {1.0f},                    // 단순 입력
        {10.0f},
        {100.0f},
        {0.1f},
        {-1.0f},                   // 음수
        {std::sqrt(2.0f)},         // 무리수
    };

    if (!concreteTest(original, optimized, testInputs)) {
        return false;  // 구체적 테스트 실패
    }

    // Phase 2: 심볼릭 실행 (선택적)
    // if (!symbolicExecution(optimized)) {
    //     return false;
    // }

    return true;  // 모든 검증 통과
}

// ============================================================================
// 구체적 테스트 (Concrete Test)
// ============================================================================

bool CorrectnessChecker::concreteTest(
    mlir::Operation* original,
    mlir::Operation* optimized,
    const std::vector<std::vector<float>>& testInputs) {

    // Golden reference 실행
    extractGoldenReference(original);

    // 각 테스트 입력에 대해 검증
    for (const auto& input : testInputs) {
        auto originalOutput = executeAndCapture(original, input);
        auto optimizedOutput = executeAndCapture(optimized, input);

        if (originalOutput.size() != optimizedOutput.size()) {
            llvm::errs() << "Output size mismatch: "
                        << originalOutput.size() << " vs "
                        << optimizedOutput.size() << "\n";
            return false;
        }

        // 수치 오차 허용 (부동소수점 계산)
        const float EPSILON = 1e-5f;

        for (size_t i = 0; i < originalOutput.size(); i++) {
            float diff = std::abs(originalOutput[i] - optimizedOutput[i]);
            float relError = diff / (std::abs(originalOutput[i]) + 1e-10f);

            // 절대 오차 또는 상대 오차가 너무 크면 실패
            if (diff > EPSILON && relError > 1e-3f) {
                llvm::errs() << "Output mismatch at index " << i << ": "
                            << originalOutput[i] << " vs "
                            << optimizedOutput[i]
                            << " (diff=" << diff << ")\n";
                return false;
            }
        }
    }

    llvm::outs() << "✓ Concrete test passed\n";
    return true;
}

