// ============================================================================
// Golden Reference 추출
// ============================================================================

void CorrectnessChecker::extractGoldenReference(mlir::Operation* op) {
    // 원본 Operation을 실행하고 결과를 저장
    std::vector<float> reference = executeAndCapture(op, {1.0f});
    goldenReferences.push_back(reference);
}

// ============================================================================
// Operation 실행 및 결과 캡처
//
// 실제 MLIR/LLVM 실행 엔진 사용
// ============================================================================

std::vector<float> CorrectnessChecker::executeAndCapture(
    mlir::Operation* op,
    const std::vector<float>& input) {

    std::vector<float> result;

    // MLIR Operation을 LLVM로 컴파일
    auto module = llvm::dyn_cast<mlir::ModuleOp>(op);
    if (!module) {
        // op를 포함하는 Module 찾기 (대부분 함수)
        module = op->getParentOfType<mlir::ModuleOp>();
    }

    if (!module) {
        llvm::errs() << "Could not find module\n";
        return result;  // 빈 벡터 반환
    }

    // ExecutionEngine 생성
    auto maybeEngine = mlir::ExecutionEngine::create(module);
    if (!maybeEngine) {
        llvm::errs() << "Failed to create ExecutionEngine\n";
        return result;
    }

    auto& engine = maybeEngine.get();

    // 함수 이름 추출 (보통 "main" 또는 첫 번째 함수)
    std::string funcName = "main";
    module->walk([&](mlir::func::FuncOp func) {
        if (func.getName().str() != "main") {
            funcName = func.getName().str();
        }
    });

    // 함수 조회
    auto func = engine->lookupPacked(funcName);
    if (!func) {
        // 다른 이름으로 시도
        module->walk([&](mlir::func::FuncOp f) {
            auto name = f.getName().str();
            func = engine->lookupPacked(name);
            if (func) {
                return;
            }
        });
    }

    if (!func) {
        llvm::errs() << "Could not find function " << funcName << "\n";
        return result;
    }

    // 함수 호출 (입력 준비)
    std::vector<float> output(10);  // 최대 10개 출력

    // 입력 포인터 생성
    float* inputPtr = const_cast<float*>(input.data());
    float* outputPtr = output.data();

    // 함수 호출: func(input, output)
    try {
        func(inputPtr, outputPtr);
    } catch (const std::exception& e) {
        llvm::errs() << "Function execution failed: " << e.what() << "\n";
        return result;
    }

    // 출력 결과 수집
    for (int i = 0; i < 10 && output[i] != 0.0f; i++) {
        result.push_back(output[i]);
    }

    return result;
}

