"""
Phase 2.2 통합 테스트: 루프 및 텐서 동등성 증명

모든 Phase 2.2 컴포넌트를 통합적으로 테스트하고,
루프 변환의 정확성을 종합적으로 검증합니다.

테스트 시나리오:
  1. 간단한 루프 분석 (loop_analyzer)
  2. 의존성 분석 및 병렬화 (dependency_analyzer)
  3. 메모리 변환 검증 (memory_layout_verifier)
  4. 수학적 귀납법 증명 (induction_prover)
  5. 루프 interchange 검증 (polyhedral_model)
  6. Tiling 변환 검증 (polyhedral_model)
"""

import sys
sys.path.insert(0, '/data/data/com.termux/files/home/mlir-postdoc-adaptive/scripts')

from loop_analyzer import LoopAnalyzer, Bound
from dependency_analyzer import DependencyAnalyzer, DistanceVector, DependenceType, DependenceLevel
from memory_layout_verifier import MemoryLayoutVerifier, MemoryLayoutType, LayoutTransformationSpec, AccessPattern
from polyhedral_model import PolyhedralModel, IterationSpace, LinearConstraint, ConstraintType
from induction_prover import InductionProver, InductionProperty
import z3
import time
from typing import Tuple


class Phase22IntegrationTest:
    """Phase 2.2 통합 테스트"""

    def __init__(self):
        self.ctx = z3.Context()
        self.tests_passed = 0
        self.tests_failed = 0
        self.test_results = []

    def run_all_tests(self) -> None:
        """모든 테스트 실행"""
        print("="*80)
        print("Phase 2.2 Comprehensive Integration Tests")
        print("="*80)

        self._test_loop_analysis()
        self._test_dependency_analysis()
        self._test_memory_layout_transformation()
        self._test_polyhedral_iteration_space()
        self._test_loop_interchange_feasibility()
        self._test_tiling_verification()
        self._test_induction_proof()
        self._test_end_to_end_matrix_multiply()

        self._print_summary()

    def _test_loop_analysis(self) -> None:
        """Test 1: 루프 분석"""
        print("\n[Test 1] Loop Analysis")
        print("-"*80)

        analyzer = LoopAnalyzer()

        # 간단한 2D 루프 코드
        code = """
        for i in range(100):
            for j in range(100):
                C[i,j] = A[i,j] + B[i,j]
        """

        loop_bounds_str = "0 <= i < 100; 0 <= j < 100"
        body = "C[i,j] = A[i,j] + B[i,j]"

        try:
            # Bound 파싱
            bounds = analyzer.parse_loop_bounds(loop_bounds_str)
            self._record_test("Loop bound parsing", len(bounds) == 2)

            # 메모리 접근 추출
            accesses = analyzer.extract_memory_accesses(body)
            self._record_test("Memory access extraction", len(accesses) >= 3)

            print(f"  ✓ Parsed {len(bounds)} loop bounds")
            print(f"  ✓ Extracted {len(accesses)} memory accesses")
            for acc in accesses[:3]:
                print(f"    - {acc.location} ({acc.access_type.name})")

        except Exception as e:
            self._record_test("Loop analysis", False)
            print(f"  ✗ Error: {e}")

    def _test_dependency_analysis(self) -> None:
        """Test 2: 의존성 분석"""
        print("\n[Test 2] Dependency Analysis")
        print("-"*80)

        analyzer = DependencyAnalyzer()

        try:
            # Distance vector 계산
            dv1 = analyzer.compute_distance_vector("A[i]", "A[i+1]", ["i"])
            self._record_test("Distance vector 1D", dv1 is not None)

            dv2 = analyzer.compute_distance_vector("A[i,j]", "A[i,j+1]", ["i", "j"])
            self._record_test("Distance vector 2D", dv2 is not None)

            # 병렬화 가능성
            if dv1 and dv2:
                result = analyzer.analyze_parallelizability([dv1, dv2], 2)
                self._record_test(
                    "Parallelizability analysis",
                    len(result.parallelizable_loops) >= 0
                )

                print(f"  ✓ Distance vector 1: {dv1}")
                print(f"  ✓ Distance vector 2: {dv2}")
                print(f"  ✓ Parallelizable loops: {result.parallelizable_loops}")

        except Exception as e:
            self._record_test("Dependency analysis", False)
            print(f"  ✗ Error: {e}")

    def _test_memory_layout_transformation(self) -> None:
        """Test 3: 메모리 레이아웃 변환"""
        print("\n[Test 3] Memory Layout Transformation")
        print("-"*80)

        verifier = MemoryLayoutVerifier()

        try:
            # 주소 계산 테스트
            indices = {"i": 2, "j": 3}
            dimensions = {"i": 10, "j": 10}

            row_major_addr = verifier.compute_address_row_major(indices, dimensions)
            col_major_addr = verifier.compute_address_column_major(indices, dimensions)

            self._record_test("Row-major address calculation", row_major_addr == 23)
            self._record_test("Column-major address calculation", col_major_addr == 32)

            print(f"  ✓ Row-major (2,3) in 10x10: {row_major_addr}")
            print(f"  ✓ Column-major (2,3) in 10x10: {col_major_addr}")

            # Tiled 주소 계산
            tile_sizes = {"i": 5, "j": 5}
            tiled_addr = verifier.compute_address_tiled(indices, dimensions, tile_sizes)
            self._record_test("Tiled address calculation", tiled_addr >= 0)
            print(f"  ✓ Tiled address (tile 5x5): {tiled_addr}")

        except Exception as e:
            self._record_test("Memory layout transformation", False)
            print(f"  ✗ Error: {e}")

    def _test_polyhedral_iteration_space(self) -> None:
        """Test 4: 다항식 iteration space"""
        print("\n[Test 4] Polyhedral Iteration Space")
        print("-"*80)

        try:
            # Iteration space 정의
            constraints = [
                LinearConstraint({"i": 1}, 0, ConstraintType.LOWER_BOUND),
                LinearConstraint({"i": 1}, 100, ConstraintType.UPPER_BOUND),
                LinearConstraint({"j": 1}, 0, ConstraintType.LOWER_BOUND),
                LinearConstraint({"j": 1}, 100, ConstraintType.UPPER_BOUND),
            ]

            space = IterationSpace(
                depth=2,
                variable_names=["i", "j"],
                constraints=constraints
            )

            # Bounds 계산
            bounds = space.get_bounds()
            self._record_test("Iteration space bounds", len(bounds) == 2)

            # 포인트 검증
            valid_point = space.is_valid_iteration({"i": 50, "j": 50})
            invalid_point = space.is_valid_iteration({"i": 150, "j": 50})

            self._record_test("Valid point check", valid_point)
            self._record_test("Invalid point check", not invalid_point)

            print(f"  ✓ Iteration space bounds: {bounds}")
            print(f"  ✓ Valid point (50,50): {valid_point}")
            print(f"  ✓ Invalid point (150,50): {not invalid_point}")

        except Exception as e:
            self._record_test("Polyhedral iteration space", False)
            print(f"  ✗ Error: {e}")

    def _test_loop_interchange_feasibility(self) -> None:
        """Test 5: 루프 interchange 가능성"""
        print("\n[Test 5] Loop Interchange Feasibility")
        print("-"*80)

        analyzer = DependencyAnalyzer()

        try:
            # Loop-independent 의존성 (interchange 가능)
            dv_independent = DistanceVector(
                distances=[0, 0],
                loop_variables=["i", "j"],
                dependence_type=DependenceType.FLOW,
                level=DependenceLevel.LOOP_INDEPENDENT
            )

            can_interchange = analyzer.analyze_loop_interchange_feasibility(
                [dv_independent], (0, 1)
            )
            self._record_test("Interchange loop-independent", can_interchange)

            # Loop-carried 의존성 (interchange 불가능)
            dv_carried = DistanceVector(
                distances=[1, 0],
                loop_variables=["i", "j"],
                dependence_type=DependenceType.FLOW,
                level=DependenceLevel.LOOP_CARRIED
            )

            can_interchange_2 = analyzer.analyze_loop_interchange_feasibility(
                [dv_carried], (0, 1)
            )
            self._record_test("Interchange with loop-carried dependency", not can_interchange_2)

            print(f"  ✓ Loop-independent can interchange: {can_interchange}")
            print(f"  ✓ Loop-carried cannot interchange: {not can_interchange_2}")

        except Exception as e:
            self._record_test("Loop interchange feasibility", False)
            print(f"  ✗ Error: {e}")

    def _test_tiling_verification(self) -> None:
        """Test 6: Tiling 변환 검증"""
        print("\n[Test 6] Tiling Transformation Verification")
        print("-"*80)

        model = PolyhedralModel()

        try:
            # 원본 iteration space
            constraints = [
                LinearConstraint({"i": 1}, 0, ConstraintType.LOWER_BOUND),
                LinearConstraint({"i": 1}, 100, ConstraintType.UPPER_BOUND),
                LinearConstraint({"j": 1}, 0, ConstraintType.LOWER_BOUND),
                LinearConstraint({"j": 1}, 100, ConstraintType.UPPER_BOUND),
            ]

            space = IterationSpace(
                depth=2,
                variable_names=["i", "j"],
                constraints=constraints
            )

            model.add_loop_nest("matrix", space)

            # Tiling 검증
            tile_sizes = {"i": 32, "j": 32}
            result = model.verify_tile_correctness("matrix", tile_sizes)

            self._record_test("Tile correctness", result)
            print(f"  ✓ 100x100 matrix with 32x32 tiling: {'correct' if result else 'incorrect'}")

            # 스케줄 생성
            schedule = model.generate_iteration_schedule("matrix", ["i", "j"])
            self._record_test("Schedule generation", len(schedule.iteration_to_time) == 10000)
            print(f"  ✓ Generated schedule for {len(schedule.iteration_to_time)} iterations")

        except Exception as e:
            self._record_test("Tiling verification", False)
            print(f"  ✗ Error: {e}")

    def _test_induction_proof(self) -> None:
        """Test 7: 수학적 귀납법 증명"""
        print("\n[Test 7] Mathematical Induction Proof")
        print("-"*80)

        prover = InductionProver(ctx=self.ctx)

        try:
            # 배열 정확성 성질
            def array_computation(i):
                return z3.And(i >= 0, ctx=self.ctx)

            property_ = InductionProver.create_array_correctness_property(
                array_name="A",
                loop_var="i",
                computation=array_computation,
                ctx=self.ctx
            )

            # 증명 시도
            result = prover.prove_by_induction(property_, loop_bounds=1000)

            self._record_test(
                "Induction proof base case",
                result.base_case_result == "VERIFIED"
            )

            print(f"  ✓ Base case: {result.base_case_result}")
            print(f"  ✓ Inductive step: {result.inductive_step_result}")
            print(f"  ✓ Proof status: {result.status}")
            print(f"  ✓ Verification time: {result.verification_time_ms:.2f}ms")

        except Exception as e:
            self._record_test("Induction proof", False)
            print(f"  ✗ Error: {e}")

    def _test_end_to_end_matrix_multiply(self) -> None:
        """Test 8: 엔드-투-엔드 행렬곱셈 변환"""
        print("\n[Test 8] End-to-End: Matrix Multiply Transformation")
        print("-"*80)

        try:
            # 시나리오: 행렬곱셈 C[i,j] = sum_k A[i,k] * B[k,j]
            # 변환: 원본 → 타일된 버전

            loop_analyzer = LoopAnalyzer()
            dependency_analyzer = DependencyAnalyzer()
            memory_verifier = MemoryLayoutVerifier()
            model = PolyhedralModel()

            # Step 1: 루프 분석
            loop_bounds = "0 <= i < 100; 0 <= j < 100; 0 <= k < 100"
            body = "C[i,j] += A[i,k] * B[k,j]"

            bounds = loop_analyzer.parse_loop_bounds(loop_bounds)
            accesses = loop_analyzer.extract_memory_accesses(body)

            step1 = len(bounds) == 3 and len(accesses) >= 3
            self._record_test("Step 1: Loop analysis", step1)

            # Step 2: 의존성 분석
            dv = dependency_analyzer.compute_distance_vector("A[i,k]", "A[i,k+1]", ["i", "k"])
            step2 = dv is not None

            self._record_test("Step 2: Dependency analysis", step2)

            # Step 3: 메모리 변환 검증
            spec = LayoutTransformationSpec(
                src_layout=MemoryLayoutType.ROW_MAJOR,
                tgt_layout=MemoryLayoutType.TILED,
                src_dimensions={"i": 100, "j": 100},
                tgt_dimensions={"i": 100, "j": 100},
                tile_sizes={"i": 32, "j": 32}
            )

            pattern = AccessPattern(
                iteration_order=["i", "j"],
                bounds={"i": (0, 3), "j": (0, 3)},
                access_stride={"i": 1, "j": 1}
            )

            result = memory_verifier.verify_layout_transformation(spec, pattern)
            step3 = result.is_equivalent

            self._record_test("Step 3: Memory layout verification", step3)

            # Step 4: 폴리헤드럴 모델
            constraints = [
                LinearConstraint({"i": 1}, 0, ConstraintType.LOWER_BOUND),
                LinearConstraint({"i": 1}, 100, ConstraintType.UPPER_BOUND),
                LinearConstraint({"j": 1}, 0, ConstraintType.LOWER_BOUND),
                LinearConstraint({"j": 1}, 100, ConstraintType.UPPER_BOUND),
                LinearConstraint({"k": 1}, 0, ConstraintType.LOWER_BOUND),
                LinearConstraint({"k": 1}, 100, ConstraintType.UPPER_BOUND),
            ]

            space = IterationSpace(
                depth=3,
                variable_names=["i", "j", "k"],
                constraints=constraints
            )

            model.add_loop_nest("matmul", space)
            tile_result = model.verify_tile_correctness("matmul", {"i": 32, "j": 32, "k": 32})

            step4 = tile_result
            self._record_test("Step 4: Polyhedral modeling", step4)

            print(f"  ✓ End-to-end matrix multiply verification complete")
            print(f"    - Loop analysis: {'✓' if step1 else '✗'}")
            print(f"    - Dependency: {'✓' if step2 else '✗'}")
            print(f"    - Memory layout: {'✓' if step3 else '✗'}")
            print(f"    - Polyhedral model: {'✓' if step4 else '✗'}")

        except Exception as e:
            self._record_test("End-to-end matrix multiply", False)
            print(f"  ✗ Error: {e}")

    def _record_test(self, test_name: str, passed: bool) -> None:
        """테스트 결과 기록"""
        if passed:
            self.tests_passed += 1
            self.test_results.append((test_name, "PASS"))
        else:
            self.tests_failed += 1
            self.test_results.append((test_name, "FAIL"))

    def _print_summary(self) -> None:
        """테스트 결과 요약"""
        print("\n" + "="*80)
        print("Test Summary")
        print("="*80)

        for test_name, result in self.test_results:
            symbol = "✓" if result == "PASS" else "✗"
            print(f"  {symbol} {test_name}: {result}")

        total = self.tests_passed + self.tests_failed
        pass_rate = (self.tests_passed / total * 100) if total > 0 else 0

        print(f"\n{'─'*80}")
        print(f"Total: {self.tests_passed}/{total} passed ({pass_rate:.1f}%)")
        print(f"{'─'*80}")

        if self.tests_failed == 0:
            print("\n🎉 All tests passed! Phase 2.2 implementation is complete.")
        else:
            print(f"\n⚠️  {self.tests_failed} test(s) failed. Review and fix.")


if __name__ == "__main__":
    tester = Phase22IntegrationTest()
    tester.run_all_tests()
