/**
 * Level 3: 중학생도 이해하는 반복
 *
 * 학습 목표:
 * - 같은 일을 여러 번 하기
 * - for/while 반복문 사용
 * - 반복에서 합계 구하기
 *
 * 난이도: ⭐⭐ (중학생)
 */

fun main() {
    println("╔══════════════════════════════════════════════╗")
    println("║  Level 3: 중학생도 이해하는 반복             ║")
    println("╚══════════════════════════════════════════════╝\n")

    // 📚 개념 1: 같은 일을 여러 번 하기
    println("📌 개념 1: for 반복문")
    println("-".repeat(40))

    println("1부터 10까지 출력:")
    for (i in 1..10) {
        println("$i 번 째")
    }
    println()

    // 📚 개념 2: 범위 역순으로
    println("📌 개념 2: 역순 출력")
    println("-".repeat(40))

    println("10부터 1까지 내림차순:")
    for (i in 10 downTo 1) {
        println("$i")
    }
    println()

    // 📚 개념 3: 컬렉션에서 반복하기
    println("📌 개념 3: 리스트 반복")
    println("-".repeat(40))

    val fruits = listOf("사과", "딸기", "포도", "바나나")
    println("우리 가게의 과일:")
    for (fruit in fruits) {
        println("  🍎 $fruit")
    }
    println()

    // 📚 개념 4: 인덱스와 함께 반복
    println("📌 개념 4: 인덱스와 함께")
    println("-".repeat(40))

    val students = listOf("김철수", "이영희", "박민준")
    for ((index, name) in students.withIndex()) {
        println("${index + 1}번 학생: $name")
    }
    println()

    // 📚 개념 5: while로 반복하기
    println("📌 개념 5: while 반복문")
    println("-".repeat(40))

    var count = 1
    println("while로 5번 반복:")
    while (count <= 5) {
        println("$count번 안녕!")
        count = count + 1
    }
    println()

    // 📚 개념 6: 문제 해결 - 합계 구하기
    println("📌 개념 6: 합계 구하기")
    println("-".repeat(40))

    var sum = 0
    for (num in 1..10) {
        sum = sum + num
    }
    println("1부터 10까지의 합: $sum")
    println()

    // 📚 개념 7: 문제 해결 - 평균 구하기
    println("📌 개념 7: 평균 구하기")
    println("-".repeat(40))

    val scores = listOf(85, 90, 78, 92, 88)
    var total = 0
    for (score in scores) {
        total = total + score
    }
    val average = total / scores.size
    println("성적들: $scores")
    println("합계: $total")
    println("평균: $average")
    println()

    // 📚 개념 8: 구간값으로 반복 (2칸씩)
    println("📌 개념 8: 단계값으로 반복")
    println("-".repeat(40))

    println("짝수만 출력 (1부터 20까지):")
    for (i in 2..20 step 2) {
        print("$i ")
    }
    println("\n")

    // 📚 개념 9: 중첩 반복 (구구단)
    println("📌 개념 9: 중첩 반복 (구구단)")
    println("-".repeat(40))

    println("2단 구구단:")
    for (i in 1..9) {
        val result = 2 * i
        println("2 × $i = $result")
    }
    println()

    // 📚 개념 10: 최댓값 찾기
    println("📌 개념 10: 최댓값 찾기")
    println("-".repeat(40))

    val numbers = listOf(15, 8, 23, 12, 19)
    var max = numbers[0]
    for (num in numbers) {
        if (num > max) {
            max = num
        }
    }
    println("숫자들: $numbers")
    println("최댓값: $max")
    println()

    // 📚 최종 요약
    println("╔══════════════════════════════════════════════╗")
    println("║  요약: 반복은 프로그래밍의 기본입니다!       ║")
    println("║  같은 코드를 여러 번 쓸 필요가 없어요!      ║")
    println("╚══════════════════════════════════════════════╝")
}

