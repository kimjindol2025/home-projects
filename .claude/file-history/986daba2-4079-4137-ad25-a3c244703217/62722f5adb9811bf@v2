/**
 * Unit Tests for Stochastic Code Optimizer
 *
 * Tests cover:
 * - Mutation generation and validation
 * - Performance evaluation consistency
 * - Correctness checking
 * - Optimization loop convergence
 */

#include <iostream>
#include <vector>
#include <cassert>
#include <cmath>
#include <chrono>
#include <iomanip>

using namespace std;

// ============================================================================
// Simple Test Framework
// ============================================================================

struct TestResult {
    string name;
    bool passed;
    string message;
    double executionTimeMs;
};

class TestSuite {
private:
    vector<TestResult> results;
    int passCount = 0;
    int failCount = 0;

public:
    void addResult(const TestResult& result) {
        results.push_back(result);
        if (result.passed) {
            passCount++;
        } else {
            failCount++;
        }
    }

    void printSummary() const {
        cout << "\n╔════════════════════════════════════════╗\n";
        cout << "║        Test Results Summary            ║\n";
        cout << "╠════════════════════════════════════════╣\n";
        cout << "║ Total Tests:  " << setw(20) << (passCount + failCount) << " ║\n";
        cout << "║ Passed:       " << setw(20) << passCount << " ✅ ║\n";
        cout << "║ Failed:       " << setw(20) << failCount << " ❌ ║\n";
        cout << "╚════════════════════════════════════════╝\n\n";

        for (const auto& result : results) {
            if (result.passed) {
                cout << "✅ [PASS] " << result.name
                     << " (" << fixed << setprecision(2) << result.executionTimeMs << "ms)\n";
            } else {
                cout << "❌ [FAIL] " << result.name << "\n";
                cout << "   Error: " << result.message << "\n";
            }
        }
    }

    bool allPassed() const {
        return failCount == 0;
    }
};

// ============================================================================
// Mock Classes for Testing
// ============================================================================

enum class MutationType {
    LoopTiling, LoopUnrolling, Vectorization,
    LoopInterchange, ConstantPropagation, COUNT
};

struct Mutation {
    MutationType type;
    int parameter;  // tile size, unroll factor, vector width, etc.

    bool isValid() const {
        switch (type) {
            case MutationType::LoopTiling:
                return parameter >= 4 && parameter <= 256;
            case MutationType::LoopUnrolling:
                return parameter >= 2 && parameter <= 16;
            case MutationType::Vectorization:
                return parameter >= 2 && parameter <= 64;
            case MutationType::LoopInterchange:
                return parameter >= 0 && parameter < 10;
            case MutationType::ConstantPropagation:
                return parameter >= 0 && parameter < 100;
            default:
                return false;
        }
    }
};

struct PerformanceMetrics {
    double latency;
    long cacheHits;
    long cacheMisses;

    double getScore() const {
        return 1.0 / (latency + 0.01);
    }

    bool isValid() const {
        return latency > 0 && cacheHits >= 0 && cacheMisses >= 0;
    }
};

class MockMutator {
private:
    int seed = 42;

public:
    Mutation generateMutation() {
        seed = (seed * 1103515245 + 12345) & 0x7fffffff;
        int typeIdx = seed % (int)MutationType::COUNT;

        // Generate parameters within valid ranges for each mutation type
        int param = 0;
        switch ((MutationType)typeIdx) {
            case MutationType::LoopTiling:
                param = 4 + (seed % 252);  // 4-255
                break;
            case MutationType::LoopUnrolling:
                param = 2 + (seed % 15);   // 2-16
                break;
            case MutationType::Vectorization:
                param = 2 + (seed % 63);   // 2-64
                break;
            case MutationType::LoopInterchange:
                param = seed % 10;         // 0-9
                break;
            case MutationType::ConstantPropagation:
                param = seed % 100;        // 0-99
                break;
            default:
                param = 0;
        }

        return Mutation{
            static_cast<MutationType>(typeIdx),
            param
        };
    }

    string getName(MutationType type) const {
        static const vector<string> names = {
            "LoopTiling", "LoopUnrolling", "Vectorization",
            "LoopInterchange", "ConstProp"
        };
        return names[(int)type];
    }
};

class MockEvaluator {
private:
    int seed = 42;

public:
    PerformanceMetrics evaluate(double speedup) {
        PerformanceMetrics metrics;

        double baseLatency = 5.234;
        metrics.latency = baseLatency / speedup;

        // Simulate cache stats
        seed = (seed * 1103515245 + 12345) & 0x7fffffff;
        metrics.cacheHits = 8000 + (seed % 2000) - 1000;
        metrics.cacheMisses = 2000 + (seed % 1000) - 500;

        if (metrics.cacheMisses < 0) metrics.cacheMisses = 500;

        return metrics;
    }
};

// ============================================================================
// Test Cases
// ============================================================================

TestResult testMutationGeneration() {
    auto start = chrono::high_resolution_clock::now();

    MockMutator mutator;
    int validCount = 0;
    const int attempts = 1000;

    for (int i = 0; i < attempts; i++) {
        auto mutation = mutator.generateMutation();
        if (mutation.isValid()) {
            validCount++;
        }
    }

    auto end = chrono::high_resolution_clock::now();
    auto duration = chrono::duration<double, milli>(end - start);

    bool passed = validCount >= attempts;  // All should be valid now

    return TestResult{
        "Mutation Generation (1000 mutations)",
        passed,
        "Valid: " + to_string(validCount) + "/" + to_string(attempts),
        duration.count()
    };
}

TestResult testPerformanceEvaluation() {
    auto start = chrono::high_resolution_clock::now();

    MockEvaluator evaluator;
    double baseline = 5.234;  // ms

    // Test various speedup values
    vector<double> speedups = {1.0, 1.1, 1.2, 1.5, 2.0};
    bool allValid = true;

    for (double speedup : speedups) {
        auto metrics = evaluator.evaluate(speedup);

        // Check metrics are valid
        if (!metrics.isValid()) {
            allValid = false;
            break;
        }

        // Check speedup calculation
        double actualSpeedup = baseline / metrics.latency;
        double error = abs(actualSpeedup - speedup) / speedup;

        if (error > 0.01) {  // Allow 1% error
            allValid = false;
            break;
        }
    }

    auto end = chrono::high_resolution_clock::now();
    auto duration = chrono::duration<double, milli>(end - start);

    return TestResult{
        "Performance Evaluation (5 speedups)",
        allValid,
        allValid ? "All metrics consistent" : "Inconsistency detected",
        duration.count()
    };
}

TestResult testConvergence() {
    auto start = chrono::high_resolution_clock::now();

    MockMutator mutator;
    MockEvaluator evaluator;

    double baseline = 5.234;
    double bestLatency = baseline;
    int improvements = 0;
    const int iterations = 1000;

    for (int i = 0; i < iterations; i++) {
        auto mutation = mutator.generateMutation();

        if (!mutation.isValid()) continue;

        // Estimate speedup from mutation type
        double speedup = 1.0;
        switch (mutation.type) {
            case MutationType::LoopTiling:
                speedup = 1.12;
                break;
            case MutationType::LoopUnrolling:
                speedup = 1.08;
                break;
            case MutationType::Vectorization:
                speedup = 1.18;
                break;
            case MutationType::LoopInterchange:
                speedup = 1.06;
                break;
            case MutationType::ConstantPropagation:
                speedup = 1.02;
                break;
            default:
                speedup = 1.0;
        }

        auto metrics = evaluator.evaluate(speedup);

        if (metrics.latency < bestLatency) {
            bestLatency = metrics.latency;
            improvements++;
        }
    }

    auto end = chrono::high_resolution_clock::now();
    auto duration = chrono::duration<double, milli>(end - start);

    // Check convergence
    double finalSpeedup = baseline / bestLatency;
    bool converged = finalSpeedup >= 1.1 && improvements > 0;

    return TestResult{
        "Convergence Test (1000 iterations)",
        converged,
        "Final speedup: " + to_string(finalSpeedup) + "x, Improvements: " + to_string(improvements),
        duration.count()
    };
}

TestResult testCacheMetrics() {
    auto start = chrono::high_resolution_clock::now();

    MockEvaluator evaluator;
    bool allValid = true;

    const int trials = 100;
    double avgHitRate = 0.0;

    for (int i = 0; i < trials; i++) {
        auto metrics = evaluator.evaluate(1.2);

        if (!metrics.isValid()) {
            allValid = false;
            break;
        }

        double total = metrics.cacheHits + metrics.cacheMisses;
        if (total <= 0) {
            allValid = false;
            break;
        }

        double hitRate = (double)metrics.cacheHits / total;
        if (hitRate < 0.0 || hitRate > 1.0) {
            allValid = false;
            break;
        }

        avgHitRate += hitRate;
    }

    avgHitRate /= trials;

    auto end = chrono::high_resolution_clock::now();
    auto duration = chrono::duration<double, milli>(end - start);

    return TestResult{
        "Cache Metrics Consistency (100 samples)",
        allValid && avgHitRate > 0.7,  // Expect >70% hit rate
        "Avg hit rate: " + to_string(avgHitRate * 100) + "%",
        duration.count()
    };
}

TestResult testScoreCalculation() {
    auto start = chrono::high_resolution_clock::now();

    MockEvaluator evaluator;
    bool scoresValid = true;

    vector<double> speedups = {1.0, 1.1, 1.2, 1.5, 2.0};
    vector<double> scores;

    for (double speedup : speedups) {
        auto metrics = evaluator.evaluate(speedup);
        double score = metrics.getScore();

        // Score should increase with speedup (lower latency → higher score)
        if (score <= 0 || isnan(score) || isinf(score)) {
            scoresValid = false;
            break;
        }

        scores.push_back(score);
    }

    // Verify monotonicity (higher speedup → higher score)
    for (size_t i = 1; i < scores.size(); i++) {
        if (scores[i] <= scores[i-1]) {
            scoresValid = false;
            break;
        }
    }

    auto end = chrono::high_resolution_clock::now();
    auto duration = chrono::duration<double, milli>(end - start);

    return TestResult{
        "Score Calculation Monotonicity (5 speedups)",
        scoresValid,
        scoresValid ? "Scores monotonically increasing" : "Monotonicity violated",
        duration.count()
    };
}

TestResult testMutationDistribution() {
    auto start = chrono::high_resolution_clock::now();

    MockMutator mutator;
    vector<int> typeCount((int)MutationType::COUNT, 0);

    const int samples = 10000;
    for (int i = 0; i < samples; i++) {
        auto mutation = mutator.generateMutation();
        typeCount[(int)mutation.type]++;
    }

    // All mutation types should appear
    bool wellDistributed = true;
    for (int count : typeCount) {
        if (count < samples / 50) {  // Each type should appear at least 2% of the time
            wellDistributed = false;
            break;
        }
    }

    auto end = chrono::high_resolution_clock::now();
    auto duration = chrono::duration<double, milli>(end - start);

    return TestResult{
        "Mutation Type Distribution (10000 samples)",
        wellDistributed,
        "Distribution: " + to_string(typeCount[0]) + "," + to_string(typeCount[1]) +
        "," + to_string(typeCount[2]) + "," + to_string(typeCount[3]) +
        "," + to_string(typeCount[4]),
        duration.count()
    };
}

// ============================================================================
// Main Test Runner
// ============================================================================

int main() {
    cout << "\n╔════════════════════════════════════════╗\n";
    cout << "║   Stochastic Optimizer - Unit Tests   ║\n";
    cout << "╚════════════════════════════════════════╝\n\n";

    TestSuite suite;

    // Run all tests
    suite.addResult(testMutationGeneration());
    suite.addResult(testPerformanceEvaluation());
    suite.addResult(testConvergence());
    suite.addResult(testCacheMetrics());
    suite.addResult(testScoreCalculation());
    suite.addResult(testMutationDistribution());

    // Print summary
    suite.printSummary();

    // Return appropriate exit code
    return suite.allPassed() ? 0 : 1;
}
