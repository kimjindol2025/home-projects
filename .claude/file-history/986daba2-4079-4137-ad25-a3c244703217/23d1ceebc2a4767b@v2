#!/usr/bin/env python3
"""
구간 산술 (Interval Arithmetic)

각 부동소수점 값을 단일 숫자가 아닌 [lower, upper] 범위로 추적합니다.
오차 전파를 직관적으로 모델링하는 가장 기초적인 방법입니다.

장점:
  ✓ 구현이 간단
  ✓ 직관적

단점:
  ✗ Interval bloat: 계산이 진행되면서 범위가 무한정 커짐
  ✗ x - x = 0이 아닌 [음수, 양수]가 됨

이 문제는 affine_arithmetic.py에서 개선됩니다.
"""

from dataclasses import dataclass
from typing import Tuple, Optional
import math


@dataclass
class Interval:
    """폐쇄 구간 [lower, upper]를 나타냅니다."""
    lower: float
    upper: float

    def __post_init__(self):
        """구간 유효성 검사"""
        if self.lower > self.upper:
            raise ValueError(f"Invalid interval: {self.lower} > {self.upper}")

    def midpoint(self) -> float:
        """구간의 중점"""
        return (self.lower + self.upper) / 2.0

    def radius(self) -> float:
        """구간의 반지름 (반폭)"""
        return (self.upper - self.lower) / 2.0

    def width(self) -> float:
        """구간의 폭 (오차 크기)"""
        return self.upper - self.lower

    def contains(self, value: float) -> bool:
        """점이 구간에 포함되는가?"""
        return self.lower <= value <= self.upper

    def __str__(self) -> str:
        return f"[{self.lower:.6g}, {self.upper:.6g}]"

    def __repr__(self) -> str:
        return f"Interval({self.lower}, {self.upper})"

    # ==================== 산술 연산 ====================

    def __add__(self, other) -> 'Interval':
        """덧셈: [a_l, a_u] + [b_l, b_u] = [a_l + b_l, a_u + b_u]"""
        if isinstance(other, (int, float)):
            return Interval(self.lower + other, self.upper + other)
        elif isinstance(other, Interval):
            return Interval(
                lower=self.lower + other.lower,
                upper=self.upper + other.upper
            )
        return NotImplemented

    def __radd__(self, other) -> 'Interval':
        return self.__add__(other)

    def __sub__(self, other) -> 'Interval':
        """뺄셈: [a_l, a_u] - [b_l, b_u] = [a_l - b_u, a_u - b_l]"""
        if isinstance(other, (int, float)):
            return Interval(self.lower - other, self.upper - other)
        elif isinstance(other, Interval):
            return Interval(
                lower=self.lower - other.upper,
                upper=self.upper - other.lower
            )
        return NotImplemented

    def __rsub__(self, other) -> 'Interval':
        if isinstance(other, (int, float)):
            return Interval(other - self.upper, other - self.lower)
        return NotImplemented

    def __mul__(self, other) -> 'Interval':
        """곱셈: 모든 조합의 곱 중 최소/최대"""
        if isinstance(other, (int, float)):
            if other >= 0:
                return Interval(self.lower * other, self.upper * other)
            else:
                return Interval(self.upper * other, self.lower * other)
        elif isinstance(other, Interval):
            # 4가지 경우의 곱을 모두 계산
            products = [
                self.lower * other.lower,
                self.lower * other.upper,
                self.upper * other.lower,
                self.upper * other.upper
            ]
            return Interval(min(products), max(products))
        return NotImplemented

    def __rmul__(self, other) -> 'Interval':
        return self.__mul__(other)

    def __truediv__(self, other) -> 'Interval':
        """나눗셈: 분모가 0을 포함하면 오류"""
        if isinstance(other, (int, float)):
            if other == 0:
                raise ValueError("Division by zero")
            if other > 0:
                return Interval(self.lower / other, self.upper / other)
            else:
                return Interval(self.upper / other, self.lower / other)
        elif isinstance(other, Interval):
            if other.lower <= 0 <= other.upper:
                raise ValueError("Division by interval containing zero")

            # 분모가 0을 포함하지 않으면 안전함
            quotients = [
                self.lower / other.lower,
                self.lower / other.upper,
                self.upper / other.lower,
                self.upper / other.upper
            ]
            return Interval(min(quotients), max(quotients))
        return NotImplemented

    def __rtruediv__(self, other) -> 'Interval':
        if isinstance(other, (int, float)):
            if self.lower <= 0 <= self.upper:
                raise ValueError("Division by interval containing zero")
            return Interval(other / self.upper, other / self.lower)
        return NotImplemented

    def __neg__(self) -> 'Interval':
        """음수: -[a_l, a_u] = [-a_u, -a_l]"""
        return Interval(-self.upper, -self.lower)

    # ==================== 특수 함수 ====================

    def exp(self) -> 'Interval':
        """지수 함수: e^x"""
        return Interval(
            lower=math.exp(self.lower),
            upper=math.exp(self.upper)
        )

    def log(self) -> 'Interval':
        """자연로그: ln(x)"""
        if self.lower <= 0:
            raise ValueError("log requires positive interval")
        return Interval(
            lower=math.log(self.lower),
            upper=math.log(self.upper)
        )

    def sqrt(self) -> 'Interval':
        """제곱근: √x"""
        if self.lower < 0:
            raise ValueError("sqrt requires non-negative interval")
        return Interval(
            lower=math.sqrt(self.lower),
            upper=math.sqrt(self.upper)
        )

    def sin(self) -> 'Interval':
        """사인 함수 (복잡한 경우 처리)"""
        # 간단한 구현: 양끝점 + 임계점 검사
        endpoints = [math.sin(self.lower), math.sin(self.upper)]

        # π/2, -π/2에서의 값 (최대/최소)
        for critical in [math.pi/2, -math.pi/2]:
            # critical이 구간 내에 있는지 확인
            normalized = critical % (2 * math.pi)
            if self.lower <= normalized <= self.upper or \
               self.lower <= normalized - 2*math.pi <= self.upper:
                if critical == math.pi/2:
                    endpoints.append(1.0)
                else:
                    endpoints.append(-1.0)

        return Interval(min(endpoints), max(endpoints))

    def cos(self) -> 'Interval':
        """코사인 함수 (복잡한 경우 처리)"""
        endpoints = [math.cos(self.lower), math.cos(self.upper)]

        for critical in [0, math.pi]:
            normalized = critical % (2 * math.pi)
            if self.lower <= normalized <= self.upper:
                if critical == 0:
                    endpoints.append(1.0)
                else:
                    endpoints.append(-1.0)

        return Interval(min(endpoints), max(endpoints))

    def power(self, n: int) -> 'Interval':
        """거듭제곱: x^n"""
        if n == 0:
            return Interval(1.0, 1.0)
        elif n > 0:
            if n % 2 == 0:  # 짝수
                # 구간이 0을 포함하면 최소값이 0
                if self.lower <= 0 <= self.upper:
                    lower = 0.0
                    upper = max(self.lower ** n, self.upper ** n)
                    return Interval(lower, upper)
                else:
                    return Interval(
                        self.lower ** n if self.lower >= 0 else self.upper ** n,
                        max(self.lower ** n, self.upper ** n)
                    )
            else:  # 홀수
                return Interval(
                    self.lower ** n,
                    self.upper ** n
                )
        else:
            # 음수 지수: 0을 포함하면 오류
            if self.lower <= 0 <= self.upper:
                raise ValueError("Cannot compute negative power with interval containing zero")
            return Interval(
                min(self.lower ** n, self.upper ** n),
                max(self.lower ** n, self.upper ** n)
            )

    def abs(self) -> 'Interval':
        """절댓값: |x|"""
        if self.lower >= 0:
            return Interval(self.lower, self.upper)
        elif self.upper <= 0:
            return Interval(-self.upper, -self.lower)
        else:
            # 구간이 0을 포함
            return Interval(0.0, max(-self.lower, self.upper))

    # ==================== 구간 연산 ====================

    def union(self, other: 'Interval') -> 'Interval':
        """합집합: 두 구간을 포함하는 가장 작은 구간"""
        return Interval(
            lower=min(self.lower, other.lower),
            upper=max(self.upper, other.upper)
        )

    def intersection(self, other: 'Interval') -> Optional['Interval']:
        """교집합: 겹치는 부분 (없으면 None)"""
        if self.upper < other.lower or other.upper < self.lower:
            return None  # 교집합 없음
        return Interval(
            lower=max(self.lower, other.lower),
            upper=min(self.upper, other.upper)
        )

    def relative_error_bound(self, exact: float) -> float:
        """정확한 값에 대한 상대 오차 경계"""
        if exact == 0:
            return self.width()  # 절대 오차 사용

        # 정확한 값이 구간에 포함되는가?
        if not self.contains(exact):
            raise ValueError(f"Exact value {exact} not in interval {self}")

        # 상대 오차 = |오차| / |정확한 값|
        abs_error = max(abs(exact - self.lower), abs(exact - self.upper))
        return abs_error / abs(exact)


# 사용 예제
if __name__ == "__main__":
    print("="*70)
    print("Interval Arithmetic Demo")
    print("="*70)

    # 예제 1: 기본 연산
    print("\n[Example 1] Basic Arithmetic")
    print("-"*70)

    a = Interval(1.0, 2.0)
    b = Interval(3.0, 4.0)

    print(f"a = {a}")
    print(f"b = {b}")
    print(f"a + b = {a + b}")
    print(f"a * b = {a * b}")
    print(f"a - b = {a - b}")
    print(f"b / a = {b / a}")

    # 예제 2: 특수 함수
    print("\n[Example 2] Special Functions")
    print("-"*70)

    x = Interval(0.0, 1.0)
    print(f"x = {x}")
    print(f"exp(x) = {x.exp()}")
    print(f"sqrt(x) = {x.sqrt()}")
    print(f"sin(x) = {x.sin()}")

    # 예제 3: 구간 bloat 문제
    print("\n[Example 3] Interval Bloat Problem")
    print("-"*70)

    x = Interval(0.9, 1.1)
    print(f"x = {x}")
    print(f"x - x = {x - x}  ← 0이어야 하는데!")
    print(f"폭: {(x - x).width()}")
    print(f"→ Affine Arithmetic 필요!")

    # 예제 4: 오차 경계
    print("\n[Example 4] Relative Error Bound")
    print("-"*70)

    computed = Interval(0.998, 1.002)
    exact = 1.0
    rel_error = computed.relative_error_bound(exact)
    print(f"Computed: {computed}")
    print(f"Exact: {exact}")
    print(f"Relative error: {rel_error:.4%}")

    print("\n" + "="*70)
    print("Interval Arithmetic Complete")
    print("="*70)
