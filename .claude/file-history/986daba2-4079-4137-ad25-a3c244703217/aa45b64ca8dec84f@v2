    println()

    // 📚 사용 3: 책 관리
    println("📌 예제 3: 도서관 시스템")
    println("-".repeat(40))
    val books = listOf(
        Book("Kotlin in Action", "Dmitry Jemerov", 2017),
        Book("Clean Code", "Robert Martin", 2008),
