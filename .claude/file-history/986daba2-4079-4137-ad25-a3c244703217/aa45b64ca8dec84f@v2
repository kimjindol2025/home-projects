// 📚 클래스 1: 학생 정보
data class Student(
    val name: String,
    val age: Int,
    val grade: Int
)

// 📚 클래스 2: 학교 관리
class School(val name: String) {
    val students = mutableListOf<Student>()

    fun addStudent(student: Student) {
        students.add(student)
        println("${student.name} 학생이 ${this.name}에 입학했습니다")
    }

    fun removeStudent(name: String) {
        students.removeIf { it.name == name }
        println("$name 학생이 퇴학했습니다")
    }

    fun printAllStudents() {
        println("\n=== ${this.name} 학생 명단 ===")
        for ((index, student) in students.withIndex()) {
            println("${index + 1}. ${student.name} (${student.age}세, ${student.grade}학년)")
        }
    }

    fun getStudentCount(): Int = students.size
}

// 📚 클래스 3: 계좌
class BankAccount(val accountHolder: String, initialBalance: Double = 0.0) {
    private var balance = initialBalance

    fun deposit(amount: Double) {
        if (amount > 0) {
            balance += amount
            println("$amount 원 입금. 잔액: $balance")
        }
    }

    fun withdraw(amount: Double): Boolean {
        return if (amount <= balance) {
            balance -= amount
            println("$amount 원 출금. 잔액: $balance")
            true
        } else {
            println("잔액이 부족합니다")
            false
        }
    }

    fun getBalance(): Double = balance
}

// 📚 클래스 4: 책
data class Book(
    val title: String,
    val author: String,
    val year: Int,
    var isBorrowed: Boolean = false
) {
    fun borrow() {
        if (!isBorrowed) {
            isBorrowed = true
            println("\"$title\"을(를) 대출했습니다")
        } else {
            println("\"$title\"은(는) 이미 대출 중입니다")
        }
    }

    fun returnBook() {
        if (isBorrowed) {
            isBorrowed = false
            println("\"$title\"을(를) 반납했습니다")
        } else {
            println("\"$title\"은(는) 이미 반납 상태입니다")
        }
    }
}

