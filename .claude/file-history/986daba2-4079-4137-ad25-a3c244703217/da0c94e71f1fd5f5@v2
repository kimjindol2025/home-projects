/**
 * 최적화 결과 통계
 */
struct OptimizationResult {
    double originalLatency;           // 원본 지연시간 (ms)
    double optimizedLatency;          // 최적화 후 지연시간 (ms)
    double speedup;                   // 성능 향상 (배)
    double improvement;               // 개선율 (%)

    int mutationsAttempted;           // 시도한 변형 수
    int mutationsSuccessful;          // 성공한 변형 수

    std::string bestMutation;         // 최고 성능 변형 이름
    std::vector<std::string> appliedTransforms;  // 적용된 변형 목록

    std::chrono::duration<double> optimizationTime;  // 총 최적화 시간

    void print() const;
};

/**
 * MLIR 변형 타입
 */
enum class MutationType {
    LoopTiling,              // 루프 타일링
    LoopFusion,              // 루프 퓨전
    LoopUnrolling,           // 루프 언롤링
    MemoryLayout,            // 메모리 레이아웃 변경 (row/col/mixed)
    Vectorization,           // SIMD 벡터화
    OperationReordering,     // 연산 재배열
    InliningDepth,           // 인라인 깊이 조정
    UnusedCodeRemoval,       // 불필요 코드 제거
    ConstantPropagation,     // 상수 전파
    LoopInterchange,         // 루프 순서 변경

    COUNT                    // 변형 타입 총 개수
};

/**
 * 변형 후보
 */
struct MutationCandidate {
    MutationType type;
    std::string description;
    std::map<std::string, int> parameters;  // 변형 파라미터

    mlir::Operation* mutatedOp;

    MutationCandidate(MutationType t, const std::string& desc)
        : type(t), description(desc), mutatedOp(nullptr) {}
};

/**
 * 성능 평가 결과
 */
struct PerformanceMetrics {
    double latency;              // 지연시간 (ms)
    double throughput;           // 처리량 (ops/ms)
    long memoryAccesses;         // 메모리 접근 수
    long cacheHits;              // 캐시 히트
    long cacheMisses;            // 캐시 미스
    double energyEstimate;       // 에너지 (추정치, J)
    double codeSize;             // 코드 크기 (bytes)

    double getScore() const {
        // 복합 스코어: 성능 중시, 에너지/크기 부차
        return (1.0 / (latency + 0.01)) *
               (1.0 - energyEstimate / 1000.0) *
               (1.0 - codeSize / 100000.0);
    }

    void print() const;
};

// ============================================================================
// IR 변형 엔진
// ============================================================================

class IRMutator {
public:
    explicit IRMutator(mlir::MLIRContext* ctx);

    /**
     * 주어진 Operation을 랜덤하게 변형
     */
    MutationCandidate mutateLoc(mlir::Operation* op);

    /**
     * 특정 변형 타입 적용
     */
    mlir::Operation* applyMutation(mlir::Operation* op,
                                   const MutationCandidate& candidate);

    /**
     * 모든 가능한 변형 나열
     */
    std::vector<MutationCandidate> enumerateMutations(mlir::Operation* op);

private:
    mlir::MLIRContext* context;

    // 변형별 구현 함수
    mlir::Operation* applyLoopTiling(mlir::Operation* op, int tileSize);
    mlir::Operation* applyLoopFusion(mlir::Operation* op1, mlir::Operation* op2);
    mlir::Operation* applyLoopUnrolling(mlir::Operation* op, int factor);
    mlir::Operation* applyVectorization(mlir::Operation* op, int vectorWidth);
    mlir::Operation* applyOperationReordering(mlir::Operation* op);
    mlir::Operation* applyMemoryLayout(mlir::Operation* op, const std::string& layout);
    mlir::Operation* applyLoopInterchange(mlir::Operation* op);
    mlir::Operation* applyConstantPropagation(mlir::Operation* op);
};

// ============================================================================
// 정확성 검증
// ============================================================================

class CorrectnessChecker {
public:
    explicit CorrectnessChecker(mlir::MLIRContext* ctx);

    /**
     * 원본과 최적화 버전이 동일한 결과를 내는지 검증
     *
     * @return true if identical output, false otherwise
     */
    bool verify(mlir::Operation* original, mlir::Operation* optimized);

    /**
     * 심볼릭 실행으로 정확성 확인
     */
    bool symbolicExecution(mlir::Operation* op);

    /**
     * 구체적 테스트 케이스로 검증
     */
    bool concreteTest(mlir::Operation* original,
                     mlir::Operation* optimized,
                     const std::vector<std::vector<float>>& testInputs);

private:
    mlir::MLIRContext* context;
    std::vector<std::vector<float>> goldenReferences;

    // 헬퍼 함수들
    void extractGoldenReference(mlir::Operation* op);
    std::vector<float> executeAndCapture(mlir::Operation* op,
                                        const std::vector<float>& input);
};

// ============================================================================
// 성능 평가
// ============================================================================

class PerformanceEvaluator {
public:
    explicit PerformanceEvaluator(mlir::MLIRContext* ctx);

    /**
     * MLIR Operation의 성능 추정
     *
     * 방법:
     * 1. MLIR IR을 LLVM IR로 컴파일
     * 2. -O3로 최적화하여 아웃풋 생성
     * 3. perf/time으로 실제 실행 시간 측정
     * 4. 메트릭 수집
     */
    PerformanceMetrics evaluate(mlir::Operation* op);

    /**
     * 성능 모델 기반 빠른 추정 (Phase 2에서 사용)
     */
    PerformanceMetrics estimatePerformance(mlir::Operation* op);

    /**
     * 캐시 미스 예측
     */
    long predictCacheMisses(mlir::Operation* op);

private:
    mlir::MLIRContext* context;

    // 캐시 파라미터 (예: Intel Xeon)
    static constexpr int L1_SIZE = 32 * 1024;        // 32KB
    static constexpr int L2_SIZE = 256 * 1024;       // 256KB
    static constexpr int L3_SIZE = 20 * 1024 * 1024; // 20MB
    static constexpr int LINE_SIZE = 64;             // 64bytes

    PerformanceMetrics compileAndBenchmark(mlir::Operation* op);
    PerformanceMetrics analyzeFromIR(mlir::Operation* op);
};

// ============================================================================
// 메인 스토캐스틱 옵티마이저
// ============================================================================

class StochasticOptimizer {
public:
    struct Config {
        int maxIterations = 10000;        // 최대 반복 횟수
        int maxTime = 3600;               // 최대 실행 시간 (초)
        bool enableSeed = true;           // 재현성을 위한 시드
        unsigned int seed = 42;
        bool verbose = true;              // 상세 로그 출력
        std::string outputDir = "./results";
    };

    explicit StochasticOptimizer(mlir::MLIRContext* ctx,
                                 const Config& cfg = Config());

    /**
     * 주어진 MLIR Operation을 최적화
     *
     * 알고리즘:
     * 1. 기본 성능 측정
     * 2. 반복: 뮤테이션 → 검증 → 평가 → 기록
     * 3. 최고 성능 반환
     */
    OptimizationResult optimize(mlir::Operation* target);

    /**
     * 중간 결과 저장
     */
    void saveCheckpoint(const OptimizationResult& result,
                       const std::string& filename);

    /**
     * 최적화 진행 상황 조회
     */
    OptimizationResult getProgress() const;

private:
    mlir::MLIRContext* context;
    Config config;

    std::unique_ptr<IRMutator> mutator;
    std::unique_ptr<CorrectnessChecker> checker;
    std::unique_ptr<PerformanceEvaluator> evaluator;

    OptimizationResult currentBest;
    std::vector<OptimizationResult> history;

    // 스토캐스틱 검색 상태
    int iterationCount = 0;
    auto startTime = std::chrono::high_resolution_clock::now();

    // 헬퍼 함수
    bool shouldContinue() const;
    void logProgress(int iteration, const MutationCandidate& mutation,
                    const PerformanceMetrics& metrics);
};

