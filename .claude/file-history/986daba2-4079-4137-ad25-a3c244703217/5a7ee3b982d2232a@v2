#!/usr/bin/env node

/**
 * KimSearch Mini - 테스트 스위트
 *
 * 실행: npm test
 * 또는: node tests/mini.test.js
 */

const { KimSearchMini, Cache, QualityManager } = require('../kimsearch-mini');
const path = require('path');

// 색상 정의
const colors = {
  reset: '\x1b[0m',
  green: '\x1b[32m',
  red: '\x1b[31m',
  yellow: '\x1b[33m',
  blue: '\x1b[34m',
  gray: '\x1b[90m'
};

function log(msg, color = 'reset') {
  console.log(`${colors[color]}${msg}${colors.reset}`);
}

// 테스트 러너
class TestRunner {
  constructor() {
    this.tests = [];
    this.passed = 0;
    this.failed = 0;
  }

  test(name, fn) {
    this.tests.push({ name, fn });
  }

  async run() {
    log('\n🧪 KimSearch Mini - 테스트 스위트\n', 'blue');

    for (const { name, fn } of this.tests) {
      try {
        await fn();
        this.passed++;
        log(`✅ ${name}`, 'green');
      } catch (err) {
        this.failed++;
        log(`❌ ${name}`, 'red');
        log(`   ${err.message}`, 'red');
      }
    }

    log('\n' + '━'.repeat(50), 'gray');
    log(`📊 결과: ${this.passed}/${this.tests.length} 통과`,
        this.failed === 0 ? 'green' : 'yellow');
    log('━'.repeat(50) + '\n', 'gray');

    process.exit(this.failed > 0 ? 1 : 0);
  }
}

function assert(condition, message) {
  if (!condition) {
    throw new Error(message || 'Assertion failed');
  }
}

function assertEqual(actual, expected, message) {
  if (actual !== expected) {
    throw new Error(`${message || 'Assertion failed'}\nExpected: ${expected}\nActual: ${actual}`);
  }
}

function assertDefined(value, message) {
  if (value === undefined || value === null) {
    throw new Error(message || 'Value is undefined or null');
  }
}

function assertTrue(value, message) {
  if (value !== true) {
    throw new Error(message || `Expected true, got ${value}`);
  }
}

// ============================================
// 테스트 정의
// ============================================

const runner = new TestRunner();

// 1. KimSearchMini 초기화
runner.test('✓ KimSearchMini 초기화 (기본 경로)', async () => {
  const engine = new KimSearchMini();
  assertDefined(engine);
  assert(engine.dataPaths.length > 0, '최소 1개의 검색 경로 필요');
});

runner.test('✓ KimSearchMini 초기화 (커스텀 경로 배열)', async () => {
  const engine = new KimSearchMini(['/tmp/kimsearch-mini', '/tmp']);
  assertEqual(engine.dataPaths.length, 2, '정확히 2개의 경로 필요');
});

runner.test('✓ KimSearchMini 초기화 (커스텀 경로 문자열)', async () => {
  const engine = new KimSearchMini('/tmp/kimsearch-mini');
  assertEqual(engine.dataPaths.length, 1, '정확히 1개의 경로 필요');
});

// 2. 검색 기본 기능
runner.test('✓ 기본 검색 실행', async () => {
  const engine = new KimSearchMini(['/tmp/kimsearch-mini']);
  const results = engine.search('require');

  assertDefined(results);
  assertDefined(results.query);
  assertDefined(results.results);
  assertDefined(results.count);
  assertEqual(results.cached, false, '첫 검색은 캐시 miss');
});

runner.test('✓ 빠른 검색 (quickSearch)', async () => {
  const engine = new KimSearchMini(['/tmp/kimsearch-mini']);
  const results = engine.quickSearch('const', 5);

  assertDefined(results);
  assertEqual(results.mode, 'quick', '모드가 "quick"이어야 함');
  assert(results.count <= 5, '결과가 limit을 초과할 수 없음');
});

runner.test('✓ 검색 결과 구조 검증', async () => {
  const engine = new KimSearchMini(['/tmp/kimsearch-mini']);
  const results = engine.search('class', { limit: 1 });

  if (results.count > 0) {
    const first = results.results[0];
    assertDefined(first.file, '파일 경로 필요');
    assertDefined(first.repo, '저장소명 필요');
    assertDefined(first.line, '라인 번호 필요');
    assertDefined(first.content, '내용 필요');
    assertDefined(first.fullPath, '전체 경로 필요');
  }
});

// 3. 캐시 동작
runner.test('✓ 캐시 저장', async () => {
  const cache = new Cache(30000);
  cache.set('test-key', { data: 'test' });
  assertTrue(cache.has('test-key'), '캐시 키 존재 확인');
});

runner.test('✓ 캐시 조회', async () => {
  const cache = new Cache(30000);
  const value = { result: 'data' };
  cache.set('key1', value);
  const retrieved = cache.get('key1');

  assertEqual(JSON.stringify(retrieved), JSON.stringify(value), '저장된 값 일치');
});

runner.test('✓ 캐시 초기화', async () => {
  const cache = new Cache(30000);
  cache.set('key1', { a: 1 });
  cache.set('key2', { b: 2 });
  cache.clear();

  assertEqual(cache.cache.size, 0, '캐시가 완전히 비워져야 함');
});

runner.test('✓ 검색 결과 캐싱', async () => {
  const engine = new KimSearchMini(['/tmp/kimsearch-mini']);

  // 첫 검색
  const first = engine.search('function', { limit: 5 });
  assertEqual(first.cached, false, '첫 검색은 캐시 miss');

  // 두 번째 동일한 검색
  const second = engine.search('function', { limit: 5 });
  assertEqual(second.cached, true, '동일한 검색은 캐시 hit');

  // 내용이 동일해야 함
  assertEqual(first.count, second.count, '캐시된 결과 개수 동일');
});

// 4. 필터링 및 정렬
runner.test('✓ 언어별 필터링', async () => {
  const engine = new KimSearchMini(['/tmp/kimsearch-mini']);
  const results = engine.search('const', { lang: 'js', limit: 10 });

  assertDefined(results);
  // JS 파일만 포함되어야 함
  assert(results.results.every(r => r.file.includes('.js')), '모든 결과가 .js 파일이어야 함');
});

runner.test('✓ 정렬 - relevance (기본)', async () => {
  const engine = new KimSearchMini(['/tmp/kimsearch-mini']);
  const results = engine.search('const', { sort: 'relevance', limit: 5 });
  assert(results.count >= 0, '정렬 완료');
});

runner.test('✓ 정렬 - file명', async () => {
  const engine = new KimSearchMini(['/tmp/kimsearch-mini']);
  const results = engine.search('const', { sort: 'file', limit: 10 });

  if (results.count > 1) {
    // 파일명 순서 확인
    const files = results.results.map(r => r.file);
    for (let i = 1; i < files.length; i++) {
      assert(files[i-1] <= files[i], `파일이 정렬되어야 함: ${files[i-1]} <= ${files[i]}`);
    }
  }
});

runner.test('✓ 정렬 - line번호', async () => {
  const engine = new KimSearchMini(['/tmp/kimsearch-mini']);
  const results = engine.search('const', { sort: 'line', limit: 10 });

  if (results.count > 1) {
    // 라인 번호 순서 확인
    const lines = results.results.map(r => r.line);
    for (let i = 1; i < lines.length; i++) {
      assert(lines[i-1] <= lines[i], `라인이 정렬되어야 함: ${lines[i-1]} <= ${lines[i]}`);
    }
  }
});

// 5. 유틸리티 함수
runner.test('✓ grep 검색어 이스케이프', async () => {
  const engine = new KimSearchMini(['/tmp/kimsearch-mini']);
  const escaped = engine.escapeGrep('test"query$dollar');

  assert(escaped.includes('\\"'), '"가 이스케이프되어야 함');
  assert(escaped.includes('\\$'), '$가 이스케이프되어야 함');
});

runner.test('✓ 캐시 키 생성', async () => {
  const engine = new KimSearchMini(['/tmp/kimsearch-mini']);
  const key1 = engine.getCacheKey('query1', { lang: 'js' });
  const key2 = engine.getCacheKey('query2', { lang: 'js' });

  assert(key1 !== key2, '다른 쿼리는 다른 키');
  assertDefined(key1, '캐시 키 생성됨');
});

runner.test('✓ 언어 확장자 매핑', async () => {
  const engine = new KimSearchMini(['/tmp/kimsearch-mini']);

  assertEqual(engine.getLangExt('js'), 'js', 'JavaScript 확장자');
  assertEqual(engine.getLangExt('python'), 'py', 'Python 확장자');
  assertEqual(engine.getLangExt('go'), 'go', 'Go 확장자');
  assertEqual(engine.getLangExt('typescript'), 'ts', 'TypeScript 확장자');
});

runner.test('✓ 캐시 통계', async () => {
  const engine = new KimSearchMini(['/tmp/kimsearch-mini']);
  engine.search('test1');
  engine.search('test2');

  const stats = engine.getCacheStats();
  assertDefined(stats.size, '캐시 크기 표시');
  assertDefined(stats.keys, '캐시 키 목록 표시');
  assert(stats.size >= 2, '최소 2개의 캐시 항목');
});

// ============================================
// 테스트 실행
// ============================================

runner.run();
