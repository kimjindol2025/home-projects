## 🔧 기본 API 사용

### C++에서 프로그래매틱하게 사용
```cpp
#include "stochastic_optimizer.h"

using namespace sco;

int main() {
    // 1. MLIRContext 생성
    mlir::MLIRContext ctx;
    ctx.getOrLoadDialect<mlir::affine::AffineDialect>();
    ctx.getOrLoadDialect<mlir::scf::SCFDialect>();

    // 2. MLIR 코드 로드 또는 생성
    // ... MLIR 코드 준비 ...
    mlir::Operation* targetOp = createTargetOperation(&ctx);

    // 3. 최적화 설정
    StochasticOptimizer::Config config;
    config.maxIterations = 10000;
    config.maxTime = 3600;  // 1시간
    config.verbose = true;
    config.seed = 42;  // 재현성

    // 4. 옵티마이저 생성
    StochasticOptimizer optimizer(&ctx, config);

    // 5. 최적화 실행
    OptimizationResult result = optimizer.optimize(targetOp);

    // 6. 결과 확인
    result.print();

    // 7. 결과 저장
    optimizer.saveCheckpoint(result, "checkpoint.txt");

    return 0;
}
```

