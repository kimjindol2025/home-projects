/**
 * KimSearch Mobile - Search Engine
 *
 * 기능:
 * - 텍스트 검색 (정규식 지원)
 * - 필터링 (확장자, 별점, 카테고리)
 * - 정렬 (관련도, 품질, 수정일)
 * - 하이라이팅 (검색어 강조)
 *
 * Author: Claude (Haiku 4.5)
 * Date: 2026-02-26
 */

import DatabaseManager from './database';

class SearchEngine {
  constructor() {
    this.cache = new Map();
    this.searchStats = {
      totalSearches: 0,
      lastSearch: null,
      cachedResults: 0
    };
  }

  /**
   * 메인 검색 함수
   */
  async search(query, options = {}) {
    const startTime = Date.now();

    // 캐시 확인
    const cacheKey = this.getCacheKey(query, options);
    const cached = this.cache.get(cacheKey);
    if (cached) {
      this.searchStats.cachedResults++;
      return {
        ...cached,
        cached: true,
        responseTime: Date.now() - startTime
      };
    }

    // 데이터베이스에서 검색
    const results = await DatabaseManager.searchCode(query, {
      extension: options.lang ? this.getExtension(options.lang) : null,
      minStars: options.minQuality,
      category: options.category,
      sort: options.sort || 'relevance',
      limit: options.limit || 20
    });

    // 관련도순 정렬 (기본)
    if (options.sort === 'relevance' || !options.sort) {
      results.sort((a, b) => {
        const aRelevance = this.calculateRelevance(a, query);
        const bRelevance = this.calculateRelevance(b, query);
        return bRelevance - aRelevance;
      });
    }

    // 검색어 하이라이팅
    const highlighted = results.map(r => ({
      ...r,
      highlightedContent: this.highlightText(r.content, query)
    }));

    const response = {
      query,
      results: highlighted,
      count: highlighted.length,
      cached: false,
      responseTime: Date.now() - startTime,
      timestamp: new Date().toISOString()
    };

    // 캐시 저장 (30초)
    this.cache.set(cacheKey, response);
    setTimeout(() => this.cache.delete(cacheKey), 30000);

    this.searchStats.totalSearches++;
    this.searchStats.lastSearch = query;

    return response;
  }

  /**
   * 빠른 검색 (최소 정보만)
   */
  async quickSearch(query, limit = 5) {
    const startTime = Date.now();
    const results = await DatabaseManager.searchCode(query, {
      limit: limit
    });

    return {
      query,
      results: results.map(r => ({
        path: r.path,
        file_name: r.file_name,
        line: r.lines_count,
        extension: r.extension
      })),
      count: results.length,
      responseTime: Date.now() - startTime,
      mode: 'quick'
    };
  }

  /**
   * 관련도 계산
   */
  calculateRelevance(result, query) {
    let score = 0;

    // 파일명 매치 (높은 가중치)
    if (result.file_name.toLowerCase().includes(query.toLowerCase())) {
      score += 100;
    }

    // 함수명 매치
    if (result.functions.some(f => f.toLowerCase().includes(query.toLowerCase()))) {
      score += 50;
    }

    // 클래스명 매치
    if (result.classes.some(c => c.toLowerCase().includes(query.toLowerCase()))) {
      score += 50;
    }

    // 내용 매치 (낮은 가중치)
    const contentMatches = (result.content.match(new RegExp(query, 'gi')) || []).length;
    score += contentMatches * 10;

    // 품질 스코어 (보너스)
    score += result.quality.stars * 5;

    return score;
  }

  /**
   * 검색어 하이라이팅
   */
  highlightText(text, query) {
    if (!query) return text;

    const regex = new RegExp(`(${query})`, 'gi');
    return text.replace(regex, '【$1】');
  }

  /**
   * 언어 → 확장자 변환
   */
  getExtension(language) {
    const map = {
      'js': '.js',
      'javascript': '.js',
      'py': '.py',
      'python': '.py',
      'go': '.go',
      'golang': '.go',
      'ts': '.ts',
      'typescript': '.ts',
      'tsx': '.tsx',
      'jsx': '.jsx',
      'java': '.java',
      'rb': '.rb',
      'ruby': '.rb',
      'php': '.php',
      'swift': '.swift',
      'kt': '.kt',
      'kotlin': '.kt',
      'rs': '.rs',
      'rust': '.rs',
      'c': '.c',
      'cpp': '.cpp',
      'h': '.h'
    };
    return map[language.toLowerCase()];
  }

  /**
   * 캐시 키 생성
   */
  getCacheKey(query, options) {
    return `${query}|${options.lang || 'all'}|${options.sort || 'relevance'}|${options.limit || 20}`;
  }

  /**
   * 캐시 통계
   */
  getCacheStats() {
    return {
      cacheSize: this.cache.size,
      totalSearches: this.searchStats.totalSearches,
      cachedResults: this.searchStats.cachedResults,
      lastSearch: this.searchStats.lastSearch,
      hitRate: this.searchStats.totalSearches > 0
        ? (this.searchStats.cachedResults / this.searchStats.totalSearches * 100).toFixed(1)
        : '0'
    };
  }

  /**
   * 캐시 초기화
   */
  clearCache() {
    this.cache.clear();
  }

  /**
   * 고급 검색 (정규식)
   */
  async advancedSearch(regex, options = {}) {
    try {
      const regexObj = new RegExp(regex, 'gi');
      const allResults = await DatabaseManager.searchCode('', {
        limit: 1000
      });

      const matched = allResults.filter(r =>
        regexObj.test(r.content) ||
        regexObj.test(r.file_name) ||
        regexObj.test(r.path)
      );

      return {
        query: regex,
        results: matched,
        count: matched.length,
        mode: 'advanced',
        timestamp: new Date().toISOString()
      };
    } catch (error) {
      console.error('❌ 고급 검색 실패:', error);
      return {
        query: regex,
        results: [],
        count: 0,
        error: error.message
      };
    }
  }

  /**
   * 유사 코드 찾기 (레벤슈타인 거리)
   */
  async findSimilar(codeSnippet, threshold = 0.7) {
    const allResults = await DatabaseManager.searchCode('', { limit: 1000 });

    const similar = allResults
      .map(r => ({
        ...r,
        similarity: this.calculateSimilarity(codeSnippet, r.content)
      }))
      .filter(r => r.similarity >= threshold)
      .sort((a, b) => b.similarity - a.similarity);

    return {
      query: codeSnippet,
      results: similar,
      count: similar.length,
      mode: 'similarity',
      threshold
    };
  }

  /**
   * 코사인 유사도 계산
   */
  calculateSimilarity(str1, str2) {
    const getTokens = (str) => str.toLowerCase().split(/\W+/);
    const tokens1 = new Set(getTokens(str1));
    const tokens2 = new Set(getTokens(str2));

    let intersection = 0;
    tokens1.forEach(t => {
      if (tokens2.has(t)) intersection++;
    });

    const union = tokens1.size + tokens2.size - intersection;
    return union > 0 ? intersection / union : 0;
  }
}

export default new SearchEngine();
