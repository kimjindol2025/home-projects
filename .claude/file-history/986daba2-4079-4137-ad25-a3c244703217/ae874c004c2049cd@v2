/**
 * Code Feature Extractor
 *
 * 코드의 특성을 추출하여 신경망 입력으로 변환
 * Features: 10-15차원 벡터로 정규화됨 (0-1 범위)
 */

#ifndef CODE_FEATURE_EXTRACTOR_H
#define CODE_FEATURE_EXTRACTOR_H

#include <vector>
#include <string>
#include <cmath>
#include <algorithm>
#include <unordered_map>
#include <iostream>
#include <iomanip>

using namespace std;

/**
 * 추출 가능한 코드 특성 (Features)
 *
 * 1. code_length: 코드 라인 수 (정규화)
 * 2. loop_depth: 루프 중첩 깊이
 * 3. loop_count: 루프 총 개수
 * 4. mem_access_count: 메모리 접근 횟수
 * 5. read_write_ratio: 읽기/(읽기+쓰기) 비율
 * 6. vector_width_hint: 벡터화 가능성 (0-1)
 * 7. has_reduction: Reduction 연산 여부 (0-1)
 * 8. arithmetic_intensity: 연산/메모리 비율
 * 9. data_reuse: 데이터 재사용도
 * 10. parallelizable: 병렬화 가능성 (0-1)
 */

struct CodeFeatures {
    // 기본 특성
    double code_length = 0.0;        // 0-1 (정규화)
    double loop_depth = 0.0;         // 0-1 (depth 10으로 정규화)
    double loop_count = 0.0;         // 0-1 (count 100으로 정규화)
    double mem_access_count = 0.0;   // 0-1 (1000으로 정규화)
    double read_write_ratio = 0.0;   // 0-1

    // 최적화 가능성
    double vector_width_hint = 0.0;  // 0-1 (vectorization 가능도)
    double has_reduction = 0.0;      // 0 or 1
    double arithmetic_intensity = 0.0;  // 0-1
    double data_reuse = 0.0;         // 0-1
    double parallelizable = 0.0;     // 0-1

    // 추가 특성 (선택사항)
    double branch_density = 0.0;     // 분기 밀도
    double memory_stride = 0.0;      // 메모리 접근 stride 규칙성

    /**
     * 모든 특성을 벡터로 변환
     * @return 10-12차원 벡터
     */
    vector<double> toVector() const {
        return {
            code_length,
            loop_depth,
            loop_count,
            mem_access_count,
            read_write_ratio,
            vector_width_hint,
            has_reduction,
            arithmetic_intensity,
            data_reuse,
            parallelizable,
            branch_density,
            memory_stride
        };
    }

    /**
     * 특성 값 검증
     * @return 모든 특성이 [0,1] 범위인지 확인
     */
    bool isValid() const {
        auto vec = toVector();
        for (double val : vec) {
            if (val < 0.0 || val > 1.0) {
                return false;
            }
        }
        return true;
    }

    /**
     * 디버그 출력
     */
    void print() const {
        cout << "CodeFeatures:\n"
             << "  code_length: " << code_length << "\n"
             << "  loop_depth: " << loop_depth << "\n"
             << "  loop_count: " << loop_count << "\n"
             << "  mem_access_count: " << mem_access_count << "\n"
             << "  read_write_ratio: " << read_write_ratio << "\n"
             << "  vector_width_hint: " << vector_width_hint << "\n"
             << "  has_reduction: " << has_reduction << "\n"
             << "  arithmetic_intensity: " << arithmetic_intensity << "\n"
             << "  data_reuse: " << data_reuse << "\n"
             << "  parallelizable: " << parallelizable << "\n";
    }
};

/**
 * Code Feature Extractor
 *
 * 주어진 코드 시뮬레이션에서 특성을 추출
 * Phase 1에서는 Mock 코드로 특성을 정의
 * Phase 2+에서는 실제 MLIR Operation에서 추출
 */
class CodeFeatureExtractor {
private:
    // 정규화 상수들
    static constexpr double MAX_CODE_LENGTH = 10000.0;
    static constexpr double MAX_LOOP_DEPTH = 10.0;
    static constexpr double MAX_LOOP_COUNT = 100.0;
    static constexpr double MAX_MEM_ACCESSES = 1000.0;

public:
    /**
     * Mock 코드에서 특성 추출
     * 테스트 목적으로 임의의 특성 생성
     *
     * @param codeId 코드 식별자 (시드로 사용)
     * @return 추출된 특성
     */
    CodeFeatures extractFromMock(int codeId) {
        CodeFeatures features;

        // 의사 난수 생성 (deterministic)
        int seed = codeId * 12345;

        // 1. Code Length (1-10000 라인)
        int codeLength = (seed % 9000) + 1000;
        features.code_length = min(1.0, (double)codeLength / MAX_CODE_LENGTH);
        seed = (seed * 1103515245 + 12345) & 0x7fffffff;

        // 2. Loop Depth (0-10)
        int loopDepth = seed % 11;
        features.loop_depth = (double)loopDepth / MAX_LOOP_DEPTH;
        seed = (seed * 1103515245 + 12345) & 0x7fffffff;

        // 3. Loop Count (0-100)
        int loopCount = seed % 101;
        features.loop_count = (double)loopCount / MAX_LOOP_COUNT;
        seed = (seed * 1103515245 + 12345) & 0x7fffffff;

        // 4. Memory Access Count (10-1000)
        int memAccesses = (seed % 990) + 10;
        features.mem_access_count = min(1.0, (double)memAccesses / MAX_MEM_ACCESSES);
        seed = (seed * 1103515245 + 12345) & 0x7fffffff;

        // 5. Read/Write Ratio (0-1)
        features.read_write_ratio = (double)(seed % 100) / 100.0;
        seed = (seed * 1103515245 + 12345) & 0x7fffffff;

        // 6. Vectorization Hint (루프가 있고 메모리 접근 규칙적이면 높음)
        double vectorPotential = 0.0;
        if (loopDepth >= 1 && memAccesses > 50) {
            vectorPotential = min(1.0, 0.3 + (features.read_write_ratio * 0.7));
        }
        features.vector_width_hint = vectorPotential;

        // 7. Has Reduction (루프가 있고 연산이 있으면 가능)
        features.has_reduction = (loopDepth > 0 && memAccesses > 20) ? 1.0 : 0.0;
        seed = (seed * 1103515245 + 12345) & 0x7fffffff;

        // 8. Arithmetic Intensity (연산/메모리 비율)
        // 가정: 루프 깊이가 깊을수록 산술 강도 높음
        features.arithmetic_intensity = min(1.0, (double)loopDepth / 10.0);
        seed = (seed * 1103515245 + 12345) & 0x7fffffff;

        // 9. Data Reuse (루프 깊이가 깊고 루프 수가 많으면 높음)
        double reuse = min(1.0, ((double)loopDepth / 10.0 + (double)loopCount / 100.0) / 2.0);
        features.data_reuse = reuse;

        // 10. Parallelizable (루프가 중첩되고 reduction이 없으면 가능)
        double parallel = 0.0;
        if (loopDepth > 0 && features.has_reduction == 0.0) {
            parallel = min(1.0, (double)loopDepth / 5.0);
        }
        features.parallelizable = parallel;

        // 11. Branch Density
        features.branch_density = (double)(seed % 30) / 100.0;
        seed = (seed * 1103515245 + 12345) & 0x7fffffff;

        // 12. Memory Stride (규칙적 접근 = 높은 값)
        features.memory_stride = (features.read_write_ratio > 0.5) ? 0.8 : 0.3;

        return features;
    }

    /**
     * 여러 코드 샘플에서 특성 추출
     * 학습 데이터 생성용
     *
     * @param numSamples 샘플 개수
     * @return 특성 벡터 리스트
     */
    vector<CodeFeatures> extractMultiple(int numSamples) {
        vector<CodeFeatures> featuresList;
        featuresList.reserve(numSamples);

        for (int i = 0; i < numSamples; i++) {
            featuresList.push_back(extractFromMock(i));
        }

        return featuresList;
    }

    /**
     * 특성 벡터를 학습용 행렬로 변환
     * @param featuresList 특성 리스트
     * @return flattened 행렬 (numSamples x 12)
     */
    vector<vector<double>> toMatrix(const vector<CodeFeatures>& featuresList) {
        vector<vector<double>> matrix;
        matrix.reserve(featuresList.size());

        for (const auto& features : featuresList) {
            matrix.push_back(features.toVector());
        }

        return matrix;
    }

    /**
     * 특성 통계 계산
     * 정규화 범위 결정 용
     */
    struct FeatureStatistics {
        double mean = 0.0;
        double stddev = 0.0;
        double min = 1.0;
        double max = 0.0;
    };

    FeatureStatistics computeStatistics(
            const vector<vector<double>>& matrix,
            int featureIndex) {
        FeatureStatistics stats;

        if (matrix.empty()) return stats;

        // Min/Max
        stats.min = 1.0;
        stats.max = 0.0;
        double sum = 0.0;

        for (const auto& row : matrix) {
            if (featureIndex < (int)row.size()) {
                double val = row[featureIndex];
                stats.min = min(stats.min, val);
                stats.max = max(stats.max, val);
                sum += val;
            }
        }

        // Mean
        stats.mean = sum / matrix.size();

        // Stddev
        double variance = 0.0;
        for (const auto& row : matrix) {
            if (featureIndex < (int)row.size()) {
                double val = row[featureIndex];
                variance += (val - stats.mean) * (val - stats.mean);
            }
        }
        stats.stddev = sqrt(variance / matrix.size());

        return stats;
    }
};

#endif  // CODE_FEATURE_EXTRACTOR_H
