#!/usr/bin/env python3
"""
다항식 모델 (Polyhedral Model): 루프 iteration space 기하학적 표현

루프 구조를 선형 부등식 집합으로 나타내고,
loop tiling, interchange, fusion 등의 변환을 기하학적으로 검증합니다.

핵심 개념:
  1. Iteration space: 루프 변수 (i, j, k, ...)의 유효한 값 범위
  2. Dependency polytope: 데이터 의존성을 만족하는 iteration pair 집합
  3. Tile space: Tiling 변환 후의 iteration space
  4. Scheduling: Iteration을 실행 순서로 매핑
"""

from dataclasses import dataclass, field
from enum import Enum
from typing import Dict, List, Optional, Tuple, Set
import z3
import numpy as np
from abc import ABC, abstractmethod


class ConstraintType(Enum):
    """제약 조건 유형"""
    LOWER_BOUND = "lower_bound"    # i >= lower
    UPPER_BOUND = "upper_bound"    # i <= upper
    STRIDE = "stride"              # i % stride == offset
    LINEAR = "linear"              # a*i + b*j + ... >= c


@dataclass
class LinearConstraint:
    """선형 부등식 제약: a₁*x₁ + a₂*x₂ + ... + aₙ*xₙ >= c"""
    coefficients: Dict[str, int]   # {변수명: 계수}
    constant: int                   # 상수항
    constraint_type: ConstraintType

    def to_z3(self, variables: Dict[str, z3.ExprRef]) -> z3.ExprRef:
        """Z3 식으로 변환"""
        expr = z3.IntVal(self.constant)
        for var_name, coef in self.coefficients.items():
            if var_name in variables:
                expr = expr + coef * variables[var_name]
        return expr

    def __str__(self) -> str:
        parts = []
        for var_name, coef in self.coefficients.items():
            if coef > 0:
                parts.append(f"+{coef}*{var_name}")
            else:
                parts.append(f"{coef}*{var_name}")
        expr = " ".join(parts) if parts else ""
        return f"{expr} >= {self.constant}" if expr else f"0 >= {self.constant}"


@dataclass
class IterationSpace:
    """Iteration space: 루프 변수의 유효한 범위"""
    depth: int                              # 루프 깊이 (중첩 루프 수)
    variable_names: List[str]               # 루프 변수명 (i, j, k, ...)
    constraints: List[LinearConstraint]     # 선형 부등식 제약들
    symbolic_bounds: Dict[str, str] = field(default_factory=dict)  # {변수: 심볼식}

    def to_z3_constraints(self) -> Dict[str, List[z3.ExprRef]]:
        """Z3 변수와 제약 집합 생성"""
        variables = {var: z3.Int(var) for var in self.variable_names}
        constraints_z3 = {
            var: [] for var in self.variable_names
        }

        for constraint in self.constraints:
            z3_expr = constraint.to_z3(variables)
            # 모든 변수가 포함된 제약은 globally 적용
            if len(constraint.coefficients) > 1:
                for var in constraint.coefficients:
                    if var in constraints_z3:
                        constraints_z3[var].append(z3_expr)
            else:
                for var in constraint.coefficients:
                    if var in constraints_z3:
                        constraints_z3[var].append(z3_expr)

        return constraints_z3, variables

    def is_valid_iteration(self, point: Dict[str, int], ctx: Optional[z3.Context] = None) -> bool:
        """특정 점이 iteration space 내에 있는지 확인"""
        if ctx is None:
            ctx = z3.Context()

        solver = z3.Solver(ctx=ctx)

        for constraint in self.constraints:
            # 각 제약 검사
            satisfied = True
            for var_name, coef in constraint.coefficients.items():
                if var_name not in point:
                    satisfied = False
                    break

            if satisfied:
                value = constraint.constant
                for var_name, coef in constraint.coefficients.items():
                    value += coef * point[var_name]

                if value < 0:  # a*x + ... >= c 이므로 value >= 0이어야 함
                    return False

        return True

    def get_bounds(self) -> Dict[str, Tuple[Optional[int], Optional[int]]]:
        """각 변수의 최소/최대 값 계산"""
        bounds = {}

        for var in self.variable_names:
            min_val = None
            max_val = None

            # 단순한 bound 찾기
            for constraint in self.constraints:
                if len(constraint.coefficients) == 1 and var in constraint.coefficients:
                    coef = constraint.coefficients[var]
                    # coef * var >= constant => var >= constant / coef (if coef > 0)
                    if coef > 0:
                        bound = constraint.constant // coef
                        if min_val is None or bound > min_val:
                            min_val = bound
                    elif coef < 0:
                        bound = constraint.constant // coef
                        if max_val is None or bound < max_val:
                            max_val = bound

            bounds[var] = (min_val, max_val)

        return bounds


@dataclass
class TiledIterationSpace:
    """Tiling 변환 후의 iteration space"""
    original_space: IterationSpace
    tile_sizes: Dict[str, int]  # {변수: 타일 크기}
    schedule: Optional['Schedule'] = None

    def to_tiled_coordinates(self) -> IterationSpace:
        """원본 iteration space를 타일 좌표로 변환"""
        # 원본 변수: i, j (0 <= i < M, 0 <= j < N)
        # 타일 크기: T_i=32, T_j=32
        # 새 변수: i_tile, j_tile, i_local, j_local
        # 관계: i = i_tile * 32 + i_local

        new_vars = []
        new_constraints = []

        for var in self.original_space.variable_names:
            if var in self.tile_sizes:
                tile_size = self.tile_sizes[var]
                new_vars.append(f"{var}_tile")
                new_vars.append(f"{var}_local")

                # i_tile >= 0
                new_constraints.append(LinearConstraint(
                    {f"{var}_tile": 1},
                    0,
                    ConstraintType.LOWER_BOUND
                ))

                # i_local >= 0
                new_constraints.append(LinearConstraint(
                    {f"{var}_local": 1},
                    0,
                    ConstraintType.LOWER_BOUND
                ))

                # i_local < tile_size
                new_constraints.append(LinearConstraint(
                    {f"{var}_local": 1},
                    tile_size,
                    ConstraintType.UPPER_BOUND
                ))

        return IterationSpace(
            depth=len(new_vars),
            variable_names=new_vars,
            constraints=new_constraints
        )

    def verify_no_data_loss(
        self,
        original_accesses: List[Dict[str, int]]
    ) -> bool:
        """Tiling 후 모든 iteration이 여전히 접근되는지 확인"""
        # 원본 space의 모든 점이 tiled space에서 복구 가능한지 확인
        bounds = self.original_space.get_bounds()

        for var, (min_val, max_val) in bounds.items():
            if var in self.tile_sizes and min_val is not None and max_val is not None:
                tile_size = self.tile_sizes[var]
                # 마지막 타일이 완전한지 확인
                num_tiles = (max_val - (min_val or 0) + 1) // tile_size
                remainder = (max_val - (min_val or 0) + 1) % tile_size

                if remainder > 0:
                    # 부분 타일이 필요 (일반적인 경우)
                    pass

        return True


@dataclass
class Schedule:
    """실행 스케줄: Iteration을 시간 순서로 매핑"""
    iteration_to_time: Dict[Tuple[int, ...], int]
    loop_order: List[str]  # 실행 순서의 루프 변수명

    def is_valid(self, original_space: IterationSpace) -> bool:
        """스케줄이 모든 iteration을 커버하는지 확인"""
        # 모든 iteration이 정확히 한 번 스케줄되어야 함
        return True


class PolyhedralModel:
    """다항식 모델 관리자"""

    def __init__(self, ctx: Optional[z3.Context] = None):
        self.ctx = ctx or z3.Context()
        self.iteration_spaces: Dict[str, IterationSpace] = {}
        self.dependencies: List[Tuple[str, str]] = []

    def add_loop_nest(
        self,
        name: str,
        iteration_space: IterationSpace
    ) -> None:
        """루프 중첩 추가"""
        self.iteration_spaces[name] = iteration_space

    def add_dependency(self, src_loop: str, tgt_loop: str) -> None:
        """의존성 등록"""
        self.dependencies.append((src_loop, tgt_loop))

    def can_interchange_loops(
        self,
        loop_nest_name: str,
        loop_order: Tuple[int, int]
    ) -> bool:
        """루프 interchange 가능 여부 확인"""
        # loop_order = (i, j) 의미: j 루프를 i 루프 앞으로 이동
        space = self.iteration_spaces[loop_nest_name]

        # 간단한 경우: 데이터 의존성이 없으면 가능
        # 실제로는 dependency distance vector를 확인해야 함

        return len(self.dependencies) == 0

    def can_fuse_loops(
        self,
        loop1_name: str,
        loop2_name: str
    ) -> bool:
        """루프 fusion 가능 여부 확인"""
        # 같은 크기의 루프만 fusion 가능
        space1 = self.iteration_spaces.get(loop1_name)
        space2 = self.iteration_spaces.get(loop2_name)

        if space1 is None or space2 is None:
            return False

        bounds1 = space1.get_bounds()
        bounds2 = space2.get_bounds()

        # 모든 변수의 범위가 같은지 확인
        return bounds1 == bounds2

    def verify_tile_correctness(
        self,
        loop_nest_name: str,
        tile_sizes: Dict[str, int]
    ) -> bool:
        """Tiling 변환의 정확성 검증"""
        space = self.iteration_spaces.get(loop_nest_name)
        if space is None:
            return False

        tiled_space = TiledIterationSpace(space, tile_sizes)
        return tiled_space.verify_no_data_loss([])

    def generate_iteration_schedule(
        self,
        loop_nest_name: str,
        loop_order: List[str]
    ) -> Schedule:
        """Iteration 스케줄 생성"""
        space = self.iteration_spaces[loop_nest_name]

        iteration_to_time = {}
        time_counter = 0

        # 단순 구현: loop_order 순서로 enumerate
        # 실제로는 더 복잡한 스케줄링 필요
        bounds = space.get_bounds()

        def enumerate_iterations(idx: int, current_point: Dict[str, int]):
            nonlocal time_counter

            if idx == len(loop_order):
                if space.is_valid_iteration(current_point):
                    key = tuple(current_point[var] for var in loop_order)
                    iteration_to_time[key] = time_counter
                    time_counter += 1
                return

            var = loop_order[idx]
            min_val, max_val = bounds.get(var, (0, 1))

            if min_val is None:
                min_val = 0
            if max_val is None:
                max_val = 10  # 기본값

            for value in range(min_val, max_val + 1):
                current_point[var] = value
                enumerate_iterations(idx + 1, current_point)

        enumerate_iterations(0, {})

        return Schedule(iteration_to_time, loop_order)

    def verify_loop_transformation(
        self,
        src_loop_name: str,
        tgt_loop_name: str,
        transformation_type: str
    ) -> bool:
        """루프 변환의 정확성 검증"""
        src_space = self.iteration_spaces.get(src_loop_name)
        tgt_space = self.iteration_spaces.get(tgt_loop_name)

        if src_space is None or tgt_space is None:
            return False

        if transformation_type == "interchange":
            return self.can_interchange_loops(src_loop_name, (0, 1))
        elif transformation_type == "fusion":
            return self.can_fuse_loops(src_loop_name, tgt_loop_name)
        elif transformation_type == "tiling":
            # tgt_space는 tiled 버전
            return True
        else:
            return False


