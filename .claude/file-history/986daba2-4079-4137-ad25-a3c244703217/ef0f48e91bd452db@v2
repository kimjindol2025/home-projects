 * Date: 2026-02-26
 */

import React from 'react';
import { render, screen, fireEvent, waitFor } from '@testing-library/react-native';
import SearchScreen from '../src/SearchScreen';
import SearchEngine from '../src/searchEngine';
import DatabaseManager from '../src/database';

// Mock SearchEngine과 DatabaseManager
jest.mock('../src/searchEngine');
jest.mock('../src/database');

describe('SearchScreen', () => {
  beforeEach(() => {
    jest.clearAllMocks();
  });

  describe('렌더링', () => {
    test('✅ 컴포넌트 렌더링', () => {
      SearchEngine.search = jest.fn().mockResolvedValue({
        results: [],
        count: 0
      });
      SearchEngine.getCacheStats = jest.fn().mockReturnValue({
        cacheSize: 0,
        hitRate: '0'
      });

      const { getByText } = render(<SearchScreen />);

      expect(getByText('🔍 KimSearch Mobile')).toBeTruthy();
      expect(getByText('코드 탐색기')).toBeTruthy();
    });

    test('✅ 헤더 렌더링', () => {
      const { getByText } = render(<SearchScreen />);

      expect(getByText('🔍 KimSearch Mobile')).toBeTruthy();
      expect(getByText('코드 탐색기')).toBeTruthy();
    });

    test('✅ 검색창 렌더링', () => {
      const { getByPlaceholderText } = render(<SearchScreen />);

      expect(getByPlaceholderText('검색어 입력...')).toBeTruthy();
    });

    test('✅ 필터 버튼 렌더링', () => {
      const { getByText } = render(<SearchScreen />);

      expect(getByText('ALL')).toBeTruthy();
      expect(getByText('JS')).toBeTruthy();
      expect(getByText('PY')).toBeTruthy();
      expect(getByText('GO')).toBeTruthy();
    });

    test('✅ 정렬 옵션 렌더링', () => {
      const { getByText } = render(<SearchScreen />);

      expect(getByText('relevance')).toBeTruthy();
      expect(getByText('quality')).toBeTruthy();
      expect(getByText('recent')).toBeTruthy();
    });
  });

  describe('검색 기능', () => {
    test('✅ 검색어 입력', () => {
      const { getByPlaceholderText } = render(<SearchScreen />);

      const input = getByPlaceholderText('검색어 입력...');
      fireEvent.changeText(input, 'function');

      // React hook state는 직접 테스트하기 어려우므로,
      // 버튼을 통해 효과를 확인
      expect(input.props.value).toBe('function');
    });

    test('✅ 검색 버튼 클릭', async () => {
      SearchEngine.search = jest.fn().mockResolvedValue({
        results: [
          {
            id: 1,
            path: 'src/utils.js',
            file_name: 'utils.js',
            extension: '.js',
            functions: ['add'],
            classes: [],
            content: 'code',
            highlightedContent: 'code',
            quality: { stars: 5, category: 'excellent' },
            last_modified: '2026-02-26'
          }
        ],
        count: 1,
        cached: false
      });
      SearchEngine.getCacheStats = jest.fn().mockReturnValue({
        cacheSize: 1,
        totalSearches: 1,
        hitRate: '0'
      });

      const { getByPlaceholderText, getByText } = render(<SearchScreen />);

      const input = getByPlaceholderText('검색어 입력...');
      fireEvent.changeText(input, 'function');

      const searchButton = getByText('검색');
      fireEvent.press(searchButton);

      await waitFor(() => {
        expect(SearchEngine.search).toHaveBeenCalledWith(
          'function',
          expect.objectContaining({
            limit: 20
          })
        );
      });
    });

    test('✅ 빈 검색어 무시', async () => {
      const { getByText } = render(<SearchScreen />);

      const searchButton = getByText('검색');
      fireEvent.press(searchButton);

      await waitFor(() => {
        expect(SearchEngine.search).not.toHaveBeenCalled();
      });
    });

    test('✅ 로딩 상태 표시', async () => {
      SearchEngine.search = jest.fn(() =>
        new Promise(resolve =>
          setTimeout(() => resolve({
            results: [],
            count: 0,
            cached: false
          }), 100)
        )
      );
      SearchEngine.getCacheStats = jest.fn().mockReturnValue({
        cacheSize: 0,
        hitRate: '0'
      });

      const { getByPlaceholderText, getByTestId } = render(<SearchScreen />);

      const input = getByPlaceholderText('검색어 입력...');
      fireEvent.changeText(input, 'test');

      const searchButton = getByText('검색');
      fireEvent.press(searchButton);

      // 로딩 상태 확인 (ActivityIndicator)
      await waitFor(() => {
        expect(getByTestId('activity-indicator')).toBeTruthy();
      }, { timeout: 50 });
    });
  });

  describe('필터링', () => {
    test('✅ 언어 필터 선택', async () => {
      SearchEngine.search = jest.fn().mockResolvedValue({
        results: [],
        count: 0
      });
      SearchEngine.getCacheStats = jest.fn().mockReturnValue({
        cacheSize: 0,
        hitRate: '0'
      });

      const { getByText, getByPlaceholderText } = render(<SearchScreen />);

      const pyButton = getByText('PY');
      fireEvent.press(pyButton);

      const input = getByPlaceholderText('검색어 입력...');
      fireEvent.changeText(input, 'def');

      const searchButton = getByText('검색');
      fireEvent.press(searchButton);

      await waitFor(() => {
        expect(SearchEngine.search).toHaveBeenCalledWith(
          'def',
          expect.objectContaining({
            lang: 'py'
          })
        );
      });
    });

    test('✅ ALL 언어 필터 (null로 전달)', async () => {
      SearchEngine.search = jest.fn().mockResolvedValue({
        results: [],
        count: 0
      });
      SearchEngine.getCacheStats = jest.fn().mockReturnValue({
        cacheSize: 0,
        hitRate: '0'
      });

      const { getByText, getByPlaceholderText } = render(<SearchScreen />);

      const allButton = getByText('ALL');
      fireEvent.press(allButton);

      const input = getByPlaceholderText('검색어 입력...');
      fireEvent.changeText(input, 'code');

      const searchButton = getByText('검색');
      fireEvent.press(searchButton);

      await waitFor(() => {
        expect(SearchEngine.search).toHaveBeenCalledWith(
          'code',
          expect.objectContaining({
            lang: null
          })
        );
      });
    });

    test('✅ 정렬 옵션 선택', async () => {
      SearchEngine.search = jest.fn().mockResolvedValue({
        results: [],
        count: 0
      });
      SearchEngine.getCacheStats = jest.fn().mockReturnValue({
        cacheSize: 0,
        hitRate: '0'
      });

      const { getByText, getByPlaceholderText } = render(<SearchScreen />);

      const qualityButton = getByText('quality');
      fireEvent.press(qualityButton);

      const input = getByPlaceholderText('검색어 입력...');
      fireEvent.changeText(input, 'test');

      const searchButton = getByText('검색');
      fireEvent.press(searchButton);

      await waitFor(() => {
        expect(SearchEngine.search).toHaveBeenCalledWith(
          'test',
          expect.objectContaining({
            sort: 'quality'
          })
        );
      });
    });
  });

  describe('검색 결과 표시', () => {
    test('✅ 검색 결과 렌더링', async () => {
      SearchEngine.search = jest.fn().mockResolvedValue({
        results: [
          {
            id: 1,
            path: 'src/utils.js',
            file_name: 'utils.js',
            extension: '.js',
            functions: ['add', 'multiply'],
            classes: [],
            content: 'const add = (a, b) => a + b;',
            highlightedContent: 'const add = (a, b) => a + b;',
            quality: { stars: 5, category: 'excellent' },
            last_modified: '2026-02-26'
          }
        ],
        count: 1,
        cached: false
      });
      SearchEngine.getCacheStats = jest.fn().mockReturnValue({
        cacheSize: 1,
        totalSearches: 1,
        hitRate: '0'
      });

      const { getByText, getByPlaceholderText } = render(<SearchScreen />);

      const input = getByPlaceholderText('검색어 입력...');
      fireEvent.changeText(input, 'add');

      const searchButton = getByText('검색');
      fireEvent.press(searchButton);

      await waitFor(() => {
        expect(getByText('utils.js')).toBeTruthy();
        expect(getByText('src/utils.js')).toBeTruthy();
        expect(getByText('Functions: add, multiply')).toBeTruthy();
      });
    });

    test('✅ 결과 없음 메시지', async () => {
      SearchEngine.search = jest.fn().mockResolvedValue({
        results: [],
        count: 0,
        cached: false
      });
      SearchEngine.getCacheStats = jest.fn().mockReturnValue({
        cacheSize: 0,
        hitRate: '0'
      });

      const { getByText, getByPlaceholderText } = render(<SearchScreen />);

      const input = getByPlaceholderText('검색어 입력...');
      fireEvent.changeText(input, 'nonexistent');

      const searchButton = getByText('검색');
      fireEvent.press(searchButton);

      await waitFor(() => {
        expect(getByText('"nonexistent"에 대한 결과가 없습니다.')).toBeTruthy();
      });
    });

    test('✅ 품질 표시 (이모지)', async () => {
      SearchEngine.search = jest.fn().mockResolvedValue({
        results: [
          {
            id: 1,
            path: 'src/test.js',
            file_name: 'test.js',
            extension: '.js',
            functions: [],
            classes: [],
            content: 'code',
            highlightedContent: 'code',
            quality: { stars: 5, category: 'excellent' },
            last_modified: '2026-02-26'
          }
        ],
        count: 1,
        cached: false
      });
      SearchEngine.getCacheStats = jest.fn().mockReturnValue({
        cacheSize: 1,
        totalSearches: 1,
        hitRate: '0'
      });

      const { getByText, getByPlaceholderText } = render(<SearchScreen />);

      const input = getByPlaceholderText('검색어 입력...');
      fireEvent.changeText(input, 'test');

      const searchButton = getByText('검색');
      fireEvent.press(searchButton);

      await waitFor(() => {
        expect(getByText('🟢 ⭐5')).toBeTruthy();
      });
    });
  });

  describe('상세보기', () => {
    test('✅ 결과 항목 클릭 → 상세보기 열기', async () => {
      SearchEngine.search = jest.fn().mockResolvedValue({
        results: [
          {
            id: 1,
            path: 'src/math.js',
            file_name: 'math.js',
            extension: '.js',
            functions: ['add'],
            classes: [],
            content: 'const add = (a, b) => a + b;\nconst multiply = (a, b) => a * b;',
            highlightedContent: 'const add = (a, b) => a + b;',
            quality: { stars: 5, category: 'excellent' },
            last_modified: '2026-02-26'
          }
        ],
        count: 1,
        cached: false
      });
      SearchEngine.getCacheStats = jest.fn().mockReturnValue({
        cacheSize: 1,
        totalSearches: 1,
        hitRate: '0'
      });

      const { getByText, getByPlaceholderText, getByTestId } = render(<SearchScreen />);

      const input = getByPlaceholderText('검색어 입력...');
      fireEvent.changeText(input, 'add');

      const searchButton = getByText('검색');
      fireEvent.press(searchButton);

      await waitFor(() => {
        const resultItem = getByTestId('result-item-1');
        fireEvent.press(resultItem);

        expect(getByText('math.js')).toBeTruthy();
        expect(getByText('src/math.js')).toBeTruthy();
        expect(getByText('Quality: 5⭐')).toBeTruthy();
      });
    });

    test('✅ 상세보기에서 함수 목록 표시', async () => {
      SearchEngine.search = jest.fn().mockResolvedValue({
        results: [
          {
            id: 1,
            path: 'src/utils.js',
            file_name: 'utils.js',
            extension: '.js',
            functions: ['add', 'subtract'],
            classes: [],
            content: 'code here',
            highlightedContent: 'code here',
            quality: { stars: 4, category: 'good' },
            last_modified: '2026-02-26'
          }
        ],
        count: 1,
        cached: false
      });
      SearchEngine.getCacheStats = jest.fn().mockReturnValue({
        cacheSize: 1,
        totalSearches: 1,
        hitRate: '0'
      });

      const { getByText, getByPlaceholderText, getByTestId } = render(<SearchScreen />);

      const input = getByPlaceholderText('검색어 입력...');
      fireEvent.changeText(input, 'add');

      const searchButton = getByText('검색');
      fireEvent.press(searchButton);

      await waitFor(() => {
        const resultItem = getByTestId('result-item-1');
        fireEvent.press(resultItem);

        expect(getByText('Functions')).toBeTruthy();
        expect(getByText('• add')).toBeTruthy();
        expect(getByText('• subtract')).toBeTruthy();
      });
    });

    test('✅ 상세보기 닫기', async () => {
      SearchEngine.search = jest.fn().mockResolvedValue({
        results: [
          {
            id: 1,
            path: 'src/test.js',
            file_name: 'test.js',
            extension: '.js',
            functions: [],
            classes: [],
            content: 'code',
            highlightedContent: 'code',
            quality: { stars: 3, category: 'ok' },
            last_modified: '2026-02-26'
          }
        ],
        count: 1,
        cached: false
      });
      SearchEngine.getCacheStats = jest.fn().mockReturnValue({
        cacheSize: 1,
        totalSearches: 1,
        hitRate: '0'
      });

      const { getByText, getByPlaceholderText, getByTestId } = render(<SearchScreen />);

      const input = getByPlaceholderText('검색어 입력...');
      fireEvent.changeText(input, 'test');

      const searchButton = getByText('검색');
      fireEvent.press(searchButton);

      await waitFor(() => {
        const resultItem = getByTestId('result-item-1');
        fireEvent.press(resultItem);

        const closeButton = getByTestId('close-button');
        fireEvent.press(closeButton);

        // 상세보기가 닫혀야 함
        expect(getByPlaceholderText('검색어 입력...')).toBeTruthy();
      });
    });
  });

  describe('통계', () => {
    test('✅ 통계 표시', async () => {
      SearchEngine.search = jest.fn().mockResolvedValue({
        results: [],
        count: 0,
        cached: false
      });
      SearchEngine.getCacheStats = jest.fn().mockReturnValue({
        cacheSize: 5,
        totalSearches: 10,
        cachedResults: 3,
        lastSearch: 'test',
        hitRate: '30.0'
      });

      const { getByText } = render(<SearchScreen />);

      expect(getByText(/10 검색/)).toBeTruthy();
      expect(getByText(/5 캐시/)).toBeTruthy();
      expect(getByText(/30\.0%/)).toBeTruthy();
    });
  });

  describe('에러 처리', () => {
    test('✅ 검색 실패 처리', async () => {
      SearchEngine.search = jest.fn().mockRejectedValue(
        new Error('Search failed')
      );
      SearchEngine.getCacheStats = jest.fn().mockReturnValue({
        cacheSize: 0,
        hitRate: '0'
      });

      const { getByText, getByPlaceholderText } = render(<SearchScreen />);

      const input = getByPlaceholderText('검색어 입력...');
      fireEvent.changeText(input, 'test');

      const searchButton = getByText('검색');
      fireEvent.press(searchButton);

      await waitFor(() => {
        // 결과가 비어있어야 함
        const results = screen.queryAllByTestId(/result-item/);
        expect(results).toHaveLength(0);
      });
    });
  });

  describe('성능 & 사용성', () => {
    test('✅ 검색 취소 (다른 검색 시작)', async () => {
      let searchCount = 0;
      SearchEngine.search = jest.fn().mockImplementation(() => {
        searchCount++;
        return Promise.resolve({
          results: [],
          count: 0,
          cached: false
        });
      });
      SearchEngine.getCacheStats = jest.fn().mockReturnValue({
        cacheSize: 0,
        hitRate: '0'
      });

      const { getByText, getByPlaceholderText } = render(<SearchScreen />);

      const input = getByPlaceholderText('검색어 입력...');

      // 첫 번째 검색
      fireEvent.changeText(input, 'query1');
      fireEvent.press(getByText('검색'));

      // 두 번째 검색 (즉시)
      fireEvent.changeText(input, 'query2');
      fireEvent.press(getByText('검색'));

      await waitFor(() => {
        expect(searchCount).toBe(2);
      });
    });
  });
});
