/**
 * Neural Network Model Loader
 *
 * Python에서 학습한 모델을 C++에서 로드하고 추론하기
 * 현재: NumPy 형식 (.npy 파일) 지원
 * 향후: ONNX 형식 지원
 */

#ifndef MODEL_LOADER_H
#define MODEL_LOADER_H

#include <vector>
#include <string>
#include <fstream>
#include <cstring>
#include <cmath>
#include <algorithm>
#include <iostream>

using namespace std;

/**
 * 간단한 Matrix 클래스
 */
struct Matrix {
    vector<vector<double>> data;
    int rows = 0;
    int cols = 0;

    Matrix() = default;

    Matrix(int r, int c, double val = 0.0) : rows(r), cols(c) {
        data.assign(r, vector<double>(c, val));
    }

    double& operator()(int i, int j) {
        return data[i][j];
    }

    const double& operator()(int i, int j) const {
        return data[i][j];
    }

    // 행렬 곱셈: (m×n) × (n×p) = (m×p)
    static Matrix multiply(const Matrix& A, const Matrix& B) {
        if (A.cols != B.rows) {
            throw runtime_error("Matrix dimensions mismatch");
        }

        Matrix result(A.rows, B.cols, 0.0);

        for (int i = 0; i < A.rows; i++) {
            for (int j = 0; j < B.cols; j++) {
                double sum = 0.0;
                for (int k = 0; k < A.cols; k++) {
                    sum += A(i, k) * B(k, j);
                }
                result(i, j) = sum;
            }
        }

        return result;
    }

    // ReLU 활성화
    static Matrix relu(const Matrix& A) {
        Matrix result = A;
        for (int i = 0; i < result.rows; i++) {
            for (int j = 0; j < result.cols; j++) {
                result(i, j) = max(0.0, result(i, j));
            }
        }
        return result;
    }

    void print() const {
        cout << "Matrix(" << rows << "x" << cols << "):\n";
        for (int i = 0; i < min(rows, 3); i++) {
            for (int j = 0; j < min(cols, 5); j++) {
                cout << data[i][j] << " ";
            }
            if (cols > 5) cout << "...";
            cout << "\n";
        }
    }
};

/**
 * Neural Network Layer
 */
struct NetworkLayer {
    Matrix W;  // 가중치 (input_size × output_size)
    vector<double> b;  // 바이어스 (output_size)
    string activation;  // "relu" or "linear"

    NetworkLayer() = default;

    NetworkLayer(int input_size, int output_size, const string& act = "relu")
        : W(input_size, output_size, 0.0), b(output_size, 0.0), activation(act) {}

    /**
     * 순전파
     * @param X 입력 (1 × input_size)
     * @return 출력 (1 × output_size)
     */
    vector<double> forward(const vector<double>& X) {
        int output_size = W.cols;
        vector<double> Z(output_size, 0.0);

        // Z = X * W + b
        for (int j = 0; j < output_size; j++) {
            Z[j] = b[j];
            for (int i = 0; i < W.rows; i++) {
                Z[j] += X[i] * W(i, j);
            }
        }

        // 활성화 함수
        vector<double> A = Z;
        if (activation == "relu") {
            for (int i = 0; i < A.size(); i++) {
                A[i] = max(0.0, A[i]);
            }
        }
        // activation == "linear" -> no change

        return A;
    }

    void print() const {
        cout << "Layer: " << W.rows << " -> " << W.cols << " (" << activation << ")\n";
        cout << "  W shape: " << W.rows << "x" << W.cols << "\n";
        cout << "  b size: " << b.size() << "\n";
    }
};

/**
 * Mock Model Loader
 *
 * 실제 환경에서는 NumPy 파일을 로드하지만,
 * 여기서는 테스트 목적으로 Mock 가중치를 사용
 */
class ModelLoader {
private:
    vector<NetworkLayer> layers;
    bool loaded = false;

    // 정규화 파라미터
    vector<double> X_mean;
    vector<double> X_scale;
    vector<double> y_mean;
    vector<double> y_scale;

public:
    /**
     * Mock 모델 생성 (테스트용)
     * 실제로는 NumPy 파일에서 로드
     */
    bool loadMockModel() {
        cout << "📂 Loading mock model (test version)...\n";

        // 레이어 생성: 12 → 128 → 64 → 32 → 5
        layers.clear();
        layers.push_back(NetworkLayer(12, 128, "relu"));
        layers.push_back(NetworkLayer(128, 64, "relu"));
        layers.push_back(NetworkLayer(64, 32, "relu"));
        layers.push_back(NetworkLayer(32, 5, "linear"));

        // 가중치 초기화 (테스트용 난수)
        srand(42);
        for (auto& layer : layers) {
            for (int i = 0; i < layer.W.rows; i++) {
                for (int j = 0; j < layer.W.cols; j++) {
                    layer.W(i, j) = ((double)rand() / RAND_MAX - 0.5) * 0.1;
                }
            }
            for (auto& bias : layer.b) {
                bias = ((double)rand() / RAND_MAX - 0.5) * 0.01;
            }
        }

        // 정규화 파라미터 (기본값)
        X_mean.assign(12, 0.0);
        X_scale.assign(12, 1.0);
        y_mean.assign(5, 1.1);  // 평균 성능
        y_scale.assign(5, 0.1);  // 표준편차

        loaded = true;
        cout << "✅ Mock model loaded\n";
        printInfo();

        return true;
    }

    /**
     * 모델 정보 출력
     */
    void printInfo() {
        cout << "\n🧠 Model Architecture:\n";
        for (size_t i = 0; i < layers.size(); i++) {
            cout << "  Layer " << (i+1) << ": ";
            layers[i].print();
        }
    }

    /**
     * 추론 (예측)
     *
     * @param input 입력 특성 (12차원)
     * @return 예상 성능 (5차원: 5가지 변형의 성능)
     */
    vector<double> predict(const vector<double>& input) {
        if (!loaded) {
            throw runtime_error("Model not loaded");
        }

        if (input.size() != 12) {
            throw runtime_error("Input size must be 12");
        }

        // 1. 입력 정규화
        vector<double> X_normalized = input;
        for (size_t i = 0; i < X_normalized.size(); i++) {
            X_normalized[i] = (X_normalized[i] - X_mean[i]) / (X_scale[i] + 1e-8);
        }

        // 2. 순전파
        vector<double> A = X_normalized;
        for (size_t i = 0; i < layers.size(); i++) {
            A = layers[i].forward(A);
        }

        // 3. 출력 역정규화
        vector<double> y_pred = A;
        for (size_t i = 0; i < y_pred.size(); i++) {
            y_pred[i] = y_pred[i] * y_scale[i] + y_mean[i];
        }

        // 4. 성능은 1.0 이상 (속도 향상)
        for (double& val : y_pred) {
            val = max(1.0, min(2.0, val));  // 1.0 ~ 2.0 범위
        }

        return y_pred;
    }

    /**
     * 배치 추론
     *
     * @param inputs 입력 배치 (n × 12)
     * @return 예측 배치 (n × 5)
     */
    vector<vector<double>> predictBatch(const vector<vector<double>>& inputs) {
        vector<vector<double>> predictions;
        predictions.reserve(inputs.size());

        for (const auto& input : inputs) {
            predictions.push_back(predict(input));
        }

        return predictions;
    }

    /**
     * 가장 유망한 변형 추천
     *
     * @param input 입력 특성
     * @return 가장 높은 성능을 갖는 변형 인덱스 (0-4)
     */
    int recommendMutation(const vector<double>& input) {
        auto predictions = predict(input);

        int best_idx = 0;
        double best_speedup = predictions[0];

        for (int i = 1; i < (int)predictions.size(); i++) {
            if (predictions[i] > best_speedup) {
                best_speedup = predictions[i];
                best_idx = i;
            }
        }

        return best_idx;
    }

    /**
     * 모델이 로드되었는지 확인
     */
    bool isLoaded() const {
        return loaded;
    }

    /**
     * 레이어 개수
     */
    size_t getNumLayers() const {
        return layers.size();
    }

    /**
     * 특정 레이어 정보
     */
    const NetworkLayer& getLayer(size_t idx) const {
        if (idx >= layers.size()) {
            throw out_of_range("Layer index out of range");
        }
        return layers[idx];
    }
};

#endif  // MODEL_LOADER_H
