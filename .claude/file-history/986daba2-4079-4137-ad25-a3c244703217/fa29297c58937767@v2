/**
 * Performance Dataset Generator
 *
 * Phase 2를 위한 학습 데이터 생성
 * Output: CSV 파일 (코드 특성 + 변형별 성능)
 *
 * Format:
 * code_id, feature_1, ..., feature_12, speedup_tiling, speedup_unroll, speedup_vec, speedup_inter, speedup_const
 */

#include "code_feature_extractor.h"
#include <iostream>
#include <fstream>
#include <iomanip>
#include <vector>
#include <random>
#include <cmath>

using namespace std;

// ============================================================================
// Mock Performance Simulator
// ============================================================================

/**
 * 주어진 특성과 변형에 대해 예상 성능 향상도 계산
 */
class PerformanceSimulator {
private:
    mt19937 gen{42};

public:
    /**
     * 루프 타일링의 예상 속도 향상
     * 루프 깊이가 깊고 메모리 접근이 많을수록 효과적
     */
    double simulateLoopTiling(const CodeFeatures& features) {
        double baseSpeedup = 1.0;

        // 루프 깊이 기여 (max 1.12x)
        baseSpeedup += features.loop_depth * 0.12;

        // 메모리 접근 기여
        baseSpeedup += features.mem_access_count * 0.05;

        // 데이터 재사용도 기여
        baseSpeedup += features.data_reuse * 0.03;

        // 작은 노이즈 추가 (실제 성능 변동 시뮬레이션)
        normal_distribution<> noise(0, 0.02);
        baseSpeedup += noise(gen);

        return max(1.0, min(2.0, baseSpeedup));  // 1.0 ~ 2.0 범위
    }

    /**
     * 루프 언롤링의 예상 속도 향상
     * 산술 강도가 높을수록 효과적
     */
    double simulateLoopUnrolling(const CodeFeatures& features) {
        double baseSpeedup = 1.0;

        // 산술 강도 기여 (max 1.10x)
        baseSpeedup += features.arithmetic_intensity * 0.10;

        // 루프 깊이 기여
        baseSpeedup += features.loop_depth * 0.05;

        // 노이즈
        normal_distribution<> noise(0, 0.015);
        baseSpeedup += noise(gen);

        return max(1.0, min(2.0, baseSpeedup));
    }

    /**
     * 벡터화의 예상 속도 향상
     * 벡터화 가능도가 높을수록 효과적 (max 1.25x)
     */
    double simulateVectorization(const CodeFeatures& features) {
        double baseSpeedup = 1.0;

        // 벡터화 가능도 기여 (max 1.25x)
        baseSpeedup += features.vector_width_hint * 0.25;

        // 메모리 접근 규칙성 기여
        baseSpeedup += features.memory_stride * 0.05;

        // 노이즈
        normal_distribution<> noise(0, 0.025);
        baseSpeedup += noise(gen);

        return max(1.0, min(2.5, baseSpeedup));
    }

    /**
     * 루프 인터체인지의 예상 속도 향상
     * 데이터 재사용도가 높을수록 효과적 (max 1.10x)
     */
    double simulateLoopInterchange(const CodeFeatures& features) {
        double baseSpeedup = 1.0;

        // 데이터 재사용도 기여
        baseSpeedup += features.data_reuse * 0.10;

        // 루프 깊이 기여
        baseSpeedup += features.loop_depth * 0.03;

        // 노이즈
        normal_distribution<> noise(0, 0.012);
        baseSpeedup += noise(gen);

        return max(1.0, min(1.8, baseSpeedup));
    }

    /**
     * 상수 전파의 예상 속도 향상
     * 코드 길이가 짧을수록 효과적 (max 1.05x)
     */
    double simulateConstantPropagation(const CodeFeatures& features) {
        double baseSpeedup = 1.0;

        // 코드 길이 기여 (짧을수록 효과)
        baseSpeedup += (1.0 - features.code_length) * 0.05;

        // 노이즈
        normal_distribution<> noise(0, 0.01);
        baseSpeedup += noise(gen);

        return max(1.0, min(1.5, baseSpeedup));
    }

    /**
     * 모든 변형의 예상 성능 계산
     */
    vector<double> getAllSpeedups(const CodeFeatures& features) {
        return {
            simulateLoopTiling(features),
            simulateLoopUnrolling(features),
            simulateVectorization(features),
            simulateLoopInterchange(features),
            simulateConstantPropagation(features)
        };
    }
};

// ============================================================================
// Dataset Generation
// ============================================================================

int main() {
    cout << "\n╔════════════════════════════════════════╗\n";
    cout << "║  Phase 2 Dataset Generator             ║\n";
    cout << "║  AI-Guided Mutation Selection          ║\n";
    cout << "╚════════════════════════════════════════╝\n\n";

    // 설정
    const int NUM_SAMPLES = 1000;  // 1000개 코드 샘플
    const string OUTPUT_FILE = "phase2_training_data.csv";

    // 1. 특성 추출
    cout << "📊 Extracting features from " << NUM_SAMPLES << " code samples...\n";
    CodeFeatureExtractor extractor;
    auto featuresList = extractor.extractMultiple(NUM_SAMPLES);
    cout << "✅ Extracted " << featuresList.size() << " code features\n\n";

    // 2. 성능 데이터 생성
    cout << "⚡ Simulating performance for all mutations...\n";
    PerformanceSimulator simulator;

    // CSV 파일 열기
    ofstream csvFile(OUTPUT_FILE);
    if (!csvFile.is_open()) {
        cerr << "❌ Failed to open output file: " << OUTPUT_FILE << "\n";
        return 1;
    }

    // CSV 헤더 작성
    csvFile << "code_id";
    csvFile << ",code_length,loop_depth,loop_count,mem_access_count,read_write_ratio";
    csvFile << ",vector_hint,has_reduction,arithmetic_intensity,data_reuse,parallelizable";
    csvFile << ",branch_density,memory_stride";
    csvFile << ",speedup_tiling,speedup_unroll,speedup_vectorization,speedup_interchange,speedup_const\n";

    // 데이터 작성
    vector<vector<double>> allSpeedups;
    for (int i = 0; i < NUM_SAMPLES; i++) {
        const auto& features = featuresList[i];

        // 특성 작성
        csvFile << i;
        auto featureVec = features.toVector();
        for (double val : featureVec) {
            csvFile << "," << fixed << setprecision(6) << val;
        }

        // 성능 데이터 작성
        auto speedups = simulator.getAllSpeedups(features);
        for (double speedup : speedups) {
            csvFile << "," << fixed << setprecision(4) << speedup;
        }
        csvFile << "\n";

        allSpeedups.push_back(speedups);

        // 진행 상황 표시
        if ((i + 1) % 100 == 0) {
            cout << "  ✓ Processed " << (i + 1) << "/" << NUM_SAMPLES << "\n";
        }
    }

    csvFile.close();
    cout << "✅ Generated " << NUM_SAMPLES << " training examples\n\n";

    // 3. 통계 출력
    cout << "╔════════════════════════════════════════╗\n";
    cout << "║        Dataset Statistics              ║\n";
    cout << "╠════════════════════════════════════════╣\n";

    auto featureMatrix = extractor.toMatrix(featuresList);

    // 각 특성의 통계
    vector<string> featureNames = {
        "code_length", "loop_depth", "loop_count", "mem_access_count",
        "read_write_ratio", "vector_hint", "has_reduction", "arithmetic_intensity",
        "data_reuse", "parallelizable", "branch_density", "memory_stride"
    };

    cout << "\nFeature Statistics:\n";
    for (size_t i = 0; i < featureNames.size() && i < 5; i++) {
        auto stats = extractor.computeStatistics(featureMatrix, i);
        cout << setw(20) << featureNames[i]
             << ": mean=" << fixed << setprecision(3) << stats.mean
             << ", σ=" << stats.stddev
             << ", min=" << stats.min
             << ", max=" << stats.max << "\n";
    }

    // 변형별 성능 통계
    cout << "\nMutation Performance Statistics:\n";
    vector<string> mutationNames = {
        "LoopTiling", "LoopUnrolling", "Vectorization", "LoopInterchange", "ConstProp"
    };

    for (size_t mutIdx = 0; mutIdx < mutationNames.size(); mutIdx++) {
        double minSpeedup = 2.0, maxSpeedup = 1.0, sumSpeedup = 0.0;

        for (const auto& speedups : allSpeedups) {
            if (mutIdx < speedups.size()) {
                double speedup = speedups[mutIdx];
                minSpeedup = min(minSpeedup, speedup);
                maxSpeedup = max(maxSpeedup, speedup);
                sumSpeedup += speedup;
            }
        }

        double avgSpeedup = sumSpeedup / allSpeedups.size();
        cout << setw(20) << mutationNames[mutIdx]
             << ": avg=" << fixed << setprecision(3) << avgSpeedup
             << "x, min=" << minSpeedup
             << "x, max=" << maxSpeedup << "x\n";
    }

    cout << "\n╚════════════════════════════════════════╝\n";
    cout << "\n✅ Dataset generated: " << OUTPUT_FILE << "\n";
    cout << "   Size: ~" << (NUM_SAMPLES * 50) / 1024 << " KB\n";
    cout << "   Use for training Phase 2 ML model\n\n";

    return 0;
}
