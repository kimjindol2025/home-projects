#!/usr/bin/env python3
"""
Phase 2: PyTorch를 사용한 고급 신경망 학습

목표: R² > 0.85, MSE < 0.1 달성
"""

import csv
import math
import torch
import torch.nn as nn
import torch.optim as optim
from torch.utils.data import TensorDataset, DataLoader
import numpy as np

print("=" * 70)
print("Phase 2: Advanced Neural Network (PyTorch)")
print("=" * 70)

# ============================================================================
# 1. 데이터 로딩
# ============================================================================

print("\n📊 Step 1: Loading training data...")

data = []
try:
    with open('phase2_training_data.csv', 'r') as f:
        reader = csv.DictReader(f)
        for i, row in enumerate(reader):
            if i >= 1000:
                break
            data.append(row)
except FileNotFoundError:
    print("❌ phase2_training_data.csv not found")
    exit(1)

print(f"✅ Loaded {len(data)} samples")

# ============================================================================
# 2. 데이터 전처리
# ============================================================================

print("\n📐 Step 2: Preprocessing data...")

feature_keys = ['code_length', 'loop_depth', 'loop_count', 'mem_access_count',
                'read_write_ratio', 'vector_hint', 'has_reduction', 'arithmetic_intensity',
                'data_reuse', 'parallelizable', 'branch_density', 'memory_stride']
target_keys = ['speedup_tiling', 'speedup_unroll', 'speedup_vectorization',
               'speedup_interchange', 'speedup_const']

X = np.array([[float(row[key]) for key in feature_keys] for row in data])
y = np.array([[float(row[key]) for key in target_keys] for row in data])

# 정규화
X_mean = X.mean(axis=0)
X_std = X.std(axis=0)
X = (X - X_mean) / (X_std + 1e-8)

y_mean = y.mean(axis=0)
y_std = y.std(axis=0)
y = (y - y_mean) / (y_std + 1e-8)

# Train/Test split
split_idx = int(len(X) * 0.8)
X_train, X_test = X[:split_idx], X[split_idx:]
y_train, y_test = y[:split_idx], y[split_idx:]

# PyTorch 텐서로 변환
X_train_t = torch.FloatTensor(X_train)
y_train_t = torch.FloatTensor(y_train)
X_test_t = torch.FloatTensor(X_test)
y_test_t = torch.FloatTensor(y_test)

print(f"Train: {len(X_train)}, Test: {len(X_test)}")

# ============================================================================
# 3. 고급 신경망 (PyTorch)
# ============================================================================

print("\n🧠 Step 3: Building advanced neural network...")

class AdvancedNetwork(nn.Module):
    def __init__(self):
        super(AdvancedNetwork, self).__init__()

        # 아키텍처: 12 → 256 → 128 → 64 → 5
        self.fc1 = nn.Linear(12, 256)
        self.bn1 = nn.BatchNorm1d(256)
        self.dropout1 = nn.Dropout(0.2)

        self.fc2 = nn.Linear(256, 128)
        self.bn2 = nn.BatchNorm1d(128)
        self.dropout2 = nn.Dropout(0.2)

        self.fc3 = nn.Linear(128, 64)
        self.bn3 = nn.BatchNorm1d(64)
        self.dropout3 = nn.Dropout(0.2)

        self.fc4 = nn.Linear(64, 5)

        self.relu = nn.ReLU()

    def forward(self, x):
        x = self.fc1(x)
        x = self.bn1(x)
        x = self.relu(x)
        x = self.dropout1(x)

        x = self.fc2(x)
        x = self.bn2(x)
        x = self.relu(x)
        x = self.dropout2(x)

        x = self.fc3(x)
        x = self.bn3(x)
        x = self.relu(x)
        x = self.dropout3(x)

        x = self.fc4(x)
        return x

# ============================================================================
# 4. 학습 (PyTorch)
# ============================================================================

print("\n🚀 Step 4: Training with PyTorch...")

device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"Using device: {device}")

model = AdvancedNetwork().to(device)
criterion = nn.MSELoss()
optimizer = optim.Adam(model.parameters(), lr=0.001, weight_decay=0.0001)
scheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode='min',
                                                   factor=0.5, patience=10,
                                                   verbose=False)

# DataLoader
batch_size = 32
train_dataset = TensorDataset(X_train_t, y_train_t)
train_loader = DataLoader(train_dataset, batch_size=batch_size, shuffle=True)

# 학습
epochs = 200
train_losses = []
test_losses = []

print(f"\nTraining for {epochs} epochs...")
for epoch in range(epochs):
    # Train
    train_loss = 0
    for X_batch, y_batch in train_loader:
        X_batch = X_batch.to(device)
        y_batch = y_batch.to(device)

        optimizer.zero_grad()
        y_pred = model(X_batch)
        loss = criterion(y_pred, y_batch)
        loss.backward()
        optimizer.step()

        train_loss += loss.item() * len(X_batch)

    train_loss /= len(X_train)
    train_losses.append(train_loss)

    # Test
    model.eval()
    with torch.no_grad():
        y_test_pred = model(X_test_t.to(device))
        test_loss = criterion(y_test_pred, y_test_t.to(device)).item()
    model.train()

    test_losses.append(test_loss)
    scheduler.step(test_loss)

    if (epoch + 1) % 20 == 0:
        print(f"  Epoch {epoch+1:3d}/200: Train Loss={train_loss:.6f}, Test Loss={test_loss:.6f}")

# ============================================================================
# 5. 평가
# ============================================================================

print("\n📈 Step 5: Evaluation...")

model.eval()
with torch.no_grad():
    y_train_pred = model(X_train_t.to(device)).cpu().numpy()
    y_test_pred = model(X_test_t.to(device)).cpu().numpy()

# 역정규화
y_train_actual = y_train * y_std + y_mean
y_test_actual = y_test * y_std + y_mean
y_train_pred_actual = y_train_pred * y_std + y_mean
y_test_pred_actual = y_test_pred * y_std + y_mean

# 메트릭
def mse(y_true, y_pred):
    return np.mean((y_true - y_pred) ** 2)

def mae(y_true, y_pred):
    return np.mean(np.abs(y_true - y_pred))

def r2(y_true, y_pred):
    ss_res = np.sum((y_true - y_pred) ** 2)
    ss_tot = np.sum((y_true - y_true.mean()) ** 2)
    return 1 - (ss_res / ss_tot) if ss_tot > 0 else 0

train_mse = mse(y_train_actual, y_train_pred_actual)
test_mse = mse(y_test_actual, y_test_pred_actual)
train_mae = mae(y_train_actual, y_train_pred_actual)
test_mae = mae(y_test_actual, y_test_pred_actual)
train_r2 = r2(y_train_actual, y_train_pred_actual)
test_r2 = r2(y_test_actual, y_test_pred_actual)

print(f"\n✅ Train MSE: {train_mse:.6f}")
print(f"✅ Test MSE:  {test_mse:.6f}")
print(f"✅ Train MAE: {train_mae:.6f}")
print(f"✅ Test MAE:  {test_mae:.6f}")
print(f"✅ Train R²:  {train_r2:.6f}")
print(f"✅ Test R²:   {test_r2:.6f}")

# ============================================================================
# 6. 변형별 성능
# ============================================================================

print("\n📊 Per-mutation performance:")

mutation_names = ['Tiling', 'Unroll', 'Vector', 'Interchange', 'ConstProp']

for i in range(5):
    y_true_m = y_test_actual[:, i]
    y_pred_m = y_test_pred_actual[:, i]

    mse_m = np.mean((y_true_m - y_pred_m) ** 2)
    r2_m = r2(y_true_m.reshape(-1, 1), y_pred_m.reshape(-1, 1))

    status = "✅" if r2_m > 0.85 else "⚠️ " if r2_m > 0.75 else "❌"
    print(f"  {status} {mutation_names[i]:15s}: R² = {r2_m:.4f}, MSE = {mse_m:.6f}")

# ============================================================================
# 7. 최종 요약
# ============================================================================

print("\n" + "=" * 70)
print("PyTorch Training Complete!")
print("=" * 70)

print(f"\n✅ Model trained successfully!")
print(f"   • Architecture: 12 → 256 → 128 → 64 → 5")
print(f"   • Features:")
print(f"     ✓ Batch Normalization")
print(f"     ✓ Dropout (p=0.2)")
print(f"     ✓ Adam Optimizer")
print(f"     ✓ Learning Rate Scheduling")
print(f"   • Epochs: 200")
print(f"   • Device: {device}")

print(f"\n📈 Results:")
print(f"   • Test MSE: {test_mse:.6f}")
print(f"   • Test MAE: {test_mae:.6f}")
print(f"   • Test R²:  {test_r2:.6f}")

print(f"\n🎯 Status:")
if test_r2 > 0.85:
    print(f"   ✅ R² > 0.85 ACHIEVED! 🏆")
elif test_r2 > 0.75:
    print(f"   ⚠️  R² = {test_r2:.4f} (nearly there!)")
else:
    print(f"   ❌ R² = {test_r2:.4f} (needs improvement)")

print("\n" + "=" * 70)
