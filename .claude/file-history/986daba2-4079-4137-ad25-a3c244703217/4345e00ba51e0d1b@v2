/**
 * Level 5: 고등학생도 이해하는 컬렉션
 *
 * 학습 목표:
 * - 리스트, Set, Map 다루기
 * - 함수형 연산 (filter, map, reduce)
 * - 컬렉션 기본 연산
 *
 * 난이도: ⭐⭐⭐ (고등학생)
 */

fun main() {
    println("╔══════════════════════════════════════════════╗")
    println("║  Level 5: 고등학생도 이해하는 컬렉션       ║")
    println("╚══════════════════════════════════════════════╝\n")

    // 📚 개념 1: 리스트 기본
    println("📌 개념 1: 리스트 생성과 접근")
    println("-".repeat(40))
    val grades = listOf(85, 90, 78, 92, 88)
    println("성적: $grades")
    println("첫 번째: ${grades[0]}")
    println("마지막: ${grades.last()}")
    println("크기: ${grades.size}")
    println()

    // 📚 개념 2: 변경 가능한 리스트
    println("📌 개념 2: 변경 가능한 리스트")
    println("-".repeat(40))
    val shoppingList = mutableListOf("우유", "계란", "빵")
    println("원본: $shoppingList")
    shoppingList.add("버터")
    println("버터 추가: $shoppingList")
    shoppingList.remove("우유")
    println("우유 제거: $shoppingList")
    println()

    // 📚 개념 3: filter - 필터링
    println("📌 개념 3: filter (조건에 맞는 것만)")
    println("-".repeat(40))
    val numbers = (1..20).toList()
    val evenNumbers = numbers.filter { it % 2 == 0 }
    println("1-20 중 짝수: $evenNumbers")

    val highScores = grades.filter { it >= 85 }
    println("85 이상: $highScores")
    println()

    // 📚 개념 4: map - 변환
    println("📌 개념 4: map (변환하기)")
    println("-".repeat(40))
    val prices = listOf(1000, 2000, 3000)
    val discounted = prices.map { it * 0.9 }  // 10% 할인
    println("원가: $prices")
    println("할인가: $discounted")

    val squared = listOf(1, 2, 3, 4, 5).map { it * it }
    println("1-5의 제곱: $squared")
    println()

    // 📚 개념 5: reduce - 하나로 합치기
    println("📌 개념 5: reduce (합치기)")
    println("-".repeat(40))
    val sum = listOf(1, 2, 3, 4, 5).reduce { acc, value -> acc + value }
    println("1+2+3+4+5 = $sum")

    val product = listOf(1, 2, 3, 4, 5).reduce { acc, value -> acc * value }
    println("1*2*3*4*5 = $product")
    println()

    // 📚 개념 6: Set - 중복 없는 컬렉션
    println("📌 개념 6: Set (중복 없음)")
    println("-".repeat(40))
    val fruits = setOf("사과", "딸기", "포도", "사과", "딸기")
    println("중복 포함: [사과, 딸기, 포도, 사과, 딸기]")
    println("Set 결과: $fruits")
    println("크기: ${fruits.size}")
    println()

    // 📚 개념 7: Map - 키-값 쌍
    println("📌 개념 7: Map (사전)")
    println("-".repeat(40))
    val phoneBook = mapOf(
        "철수" to "010-1234-5678",
        "영희" to "010-8765-4321",
        "민준" to "010-5555-5555"
    )
    println("전화번호부:")
    for ((name, phone) in phoneBook) {
        println("  $name: $phone")
    }
    println("철수의 번호: ${phoneBook["철수"]}")
    println()

    // 📚 개념 8: 함수 조합
    println("📌 개념 8: 함수 조합 (체이닝)")
    println("-".repeat(40))
    val result = listOf(1, 2, 3, 4, 5)
        .filter { it % 2 == 1 }      // 홀수만: [1, 3, 5]
        .map { it * 2 }               // 2배: [2, 6, 10]
        .reduce { a, b -> a + b }    // 합: 18
    println("1-5 중 홀수 → 2배 → 합 = $result")
    println()

    // 📚 개념 9: any, all 확인
    println("📌 개념 9: any, all (확인하기)")
    println("-".repeat(40))
    val nums = listOf(2, 4, 6, 8, 10)
    println("$nums 중:")
    println("  5보다 큰 게 있나? ${nums.any { it > 5 }}")
    println("  모두 짝수? ${nums.all { it % 2 == 0 }}")
    println()

    // 📚 개념 10: groupBy - 분류
    println("📌 개념 10: groupBy (분류하기)")
    println("-".repeat(40))
    val words = listOf("apple", "banana", "apricot", "blueberry")
    val grouped = words.groupBy { it[0] }  // 첫 글자로 분류
    println("첫 글자로 분류:")
    for ((key, values) in grouped) {
        println("  $key: $values")
    }
}

