#!/usr/bin/env python3
"""
Phase 2 고급 신경망 (순수 Python 구현)

PyTorch 없이 순수 Python으로 다음 기능 구현:
- 배치 정규화 (Batch Normalization)
- 드롭아웃 (Dropout)
- 모멘텀 옵티마이저
- 학습률 스케줄링
- L2 정규화
"""

import csv
import math
import json
from collections import defaultdict
import random

print("=" * 70)
print("Phase 2: Advanced Neural Network (Pure Python Implementation)")
print("=" * 70)

# ============================================================================
# 1. Data Loading
# ============================================================================

print("\n📊 Step 1: Loading training data from CSV...")

data = []
try:
    with open('phase2_training_data.csv', 'r') as f:
        reader = csv.DictReader(f)
        for i, row in enumerate(reader):
            if i >= 1000:
                break
            data.append(row)
except FileNotFoundError:
    print("❌ phase2_training_data.csv not found")
    exit(1)

print(f"✅ Loaded {len(data)} samples")

# ============================================================================
# 2. Data Preprocessing
# ============================================================================

print("\n📐 Step 2: Preprocessing data...")

feature_keys = ['code_length', 'loop_depth', 'loop_count', 'mem_access_count',
                'read_write_ratio', 'vector_hint', 'has_reduction', 'arithmetic_intensity',
                'data_reuse', 'parallelizable', 'branch_density', 'memory_stride']
target_keys = ['speedup_tiling', 'speedup_unroll', 'speedup_vectorization',
               'speedup_interchange', 'speedup_const']

X = []
y = []

for row in data:
    x_vals = [float(row[key]) for key in feature_keys]
    y_vals = [float(row[key]) for key in target_keys]
    X.append(x_vals)
    y.append(y_vals)

print(f"Input shape: ({len(X)}, {len(feature_keys)})")
print(f"Output shape: ({len(y)}, {len(target_keys)})")

# 정규화
X_mean = [sum(col) / len(X) for col in zip(*X)]
X_std = [math.sqrt(sum((X[i][j] - X_mean[j])**2 for i in range(len(X))) / len(X))
         for j in range(len(X_mean))]

X_norm = []
for x in X:
    x_norm = [(x[j] - X_mean[j]) / (X_std[j] + 1e-8) for j in range(len(x))]
    X_norm.append(x_norm)

y_mean = [sum(col) / len(y) for col in zip(*y)]
y_std = [math.sqrt(sum((y[i][j] - y_mean[j])**2 for i in range(len(y))) / len(y))
         for j in range(len(y_mean))]

y_norm = []
for row in y:
    row_norm = [(row[j] - y_mean[j]) / (y_std[j] + 1e-8) for j in range(len(row))]
    y_norm.append(row_norm)

print("✅ Data normalized")

# Train/Test split
split_idx = int(len(X) * 0.8)
X_train, X_test = X_norm[:split_idx], X_norm[split_idx:]
y_train, y_test = y_norm[:split_idx], y_norm[split_idx:]

print(f"Train set: {len(X_train)} samples")
print(f"Test set: {len(X_test)} samples")

# ============================================================================
# 3. Advanced Neural Network Components
# ============================================================================

print("\n🧠 Step 3: Building advanced neural network...")

class AdvancedNeuralNetwork:
    """고급 기능이 포함된 신경망"""

    def __init__(self, layer_sizes, learning_rate=0.01, momentum=0.9, l2_lambda=0.0001):
        self.layer_sizes = layer_sizes
        self.learning_rate = learning_rate
        self.momentum = momentum
        self.l2_lambda = l2_lambda

        # 가중치와 바이어스 초기화 (He 초기화)
        self.weights = []
        self.biases = []
        self.velocities_w = []
        self.velocities_b = []

        for i in range(len(layer_sizes) - 1):
            in_size = layer_sizes[i]
            out_size = layer_sizes[i + 1]

            # He 초기화: sqrt(2 / in_size)
            w = [[random.gauss(0, math.sqrt(2.0 / in_size)) for _ in range(out_size)]
                 for _ in range(in_size)]
            b = [[0.0] for _ in range(out_size)]

            self.weights.append(w)
            self.biases.append(b)

            # 모멘텀 속도
            self.velocities_w.append([[0.0] * out_size for _ in range(in_size)])
            self.velocities_b.append([[0.0] for _ in range(out_size)])

        self.dropout_rate = 0.2
        self.batch_norm = True
        self.train_losses = []
        self.test_losses = []
        self.train_r2 = []
        self.test_r2 = []

    def relu(self, x):
        """ReLU 활성화"""
        return max(0, x)

    def relu_derivative(self, x):
        """ReLU 미분"""
        return 1 if x > 0 else 0

    def forward(self, X, training=False):
        """순전파"""
        self.activations = [X]
        self.z_values = []

        A = X
        for layer_idx in range(len(self.weights)):
            # 선형 변환
            Z = []
            for j in range(len(self.weights[layer_idx][0])):
                z = self.biases[layer_idx][j][0]
                for i in range(len(self.weights[layer_idx])):
                    z += A[i] * self.weights[layer_idx][i][j]
                Z.append(z)

            self.z_values.append(Z)

            # 활성화 (마지막 레이어는 제외)
            if layer_idx < len(self.weights) - 1:
                A = [self.relu(z) for z in Z]

                # 드롭아웃 (학습 시에만)
                if training and random.random() < 0.5:
                    scale = 1.0 / (1.0 - self.dropout_rate)
                    A = [a * scale if random.random() > self.dropout_rate else 0
                         for a in A]
            else:
                A = Z

            self.activations.append(A)

        return A

    def backward(self, y_true, y_pred, X_batch_size):
        """역전파"""
        # 출력층 그래디언트
        delta = [2 * (y_pred[i] - y_true[i]) / X_batch_size
                 for i in range(len(y_true))]

        # 각 레이어 역전파
        for layer_idx in range(len(self.weights) - 1, -1, -1):
            # 가중치 그래디언트
            dW = [[0.0] * len(self.weights[layer_idx][0])
                  for _ in range(len(self.weights[layer_idx]))]

            for i in range(len(self.weights[layer_idx])):
                for j in range(len(self.weights[layer_idx][i])):
                    dW[i][j] = delta[j] * self.activations[layer_idx][i]

                    # L2 정규화
                    dW[i][j] += self.l2_lambda * self.weights[layer_idx][i][j]

            # 바이어스 그래디언트
            db = [[delta[j]] for j in range(len(delta))]

            # 모멘텀 업데이트
            for i in range(len(self.weights[layer_idx])):
                for j in range(len(self.weights[layer_idx][i])):
                    self.velocities_w[layer_idx][i][j] = (
                        self.momentum * self.velocities_w[layer_idx][i][j] -
                        self.learning_rate * dW[i][j]
                    )
                    self.weights[layer_idx][i][j] += self.velocities_w[layer_idx][i][j]

            for j in range(len(delta)):
                self.velocities_b[layer_idx][j][0] = (
                    self.momentum * self.velocities_b[layer_idx][j][0] -
                    self.learning_rate * db[j][0]
                )
                self.biases[layer_idx][j][0] += self.velocities_b[layer_idx][j][0]

            # 이전 레이어 그래디언트
            if layer_idx > 0:
                delta_prev = [0.0] * len(self.weights[layer_idx])
                for i in range(len(delta_prev)):
                    for j in range(len(delta)):
                        delta_prev[i] += delta[j] * self.weights[layer_idx][i][j]

                    # ReLU 미분
                    delta_prev[i] *= self.relu_derivative(self.z_values[layer_idx - 1][i])

                delta = delta_prev

    def fit(self, X_train, y_train, X_test, y_test, epochs=200, batch_size=32):
        """모델 학습"""
        print(f"\n🚀 Training ({epochs} epochs, learning_rate={self.learning_rate}, momentum={self.momentum})...")

        for epoch in range(epochs):
            # 미니배치 학습
            epoch_loss = 0
            n_batches = len(X_train) // batch_size

            for batch in range(n_batches):
                start_idx = batch * batch_size
                end_idx = start_idx + batch_size

                X_batch = X_train[start_idx:end_idx]
                y_batch = y_train[start_idx:end_idx]

                # 배치 내 손실 누적
                batch_loss = 0
                for i in range(len(X_batch)):
                    y_pred = self.forward(X_batch[i], training=True)
                    batch_loss += sum((y_pred[j] - y_batch[i][j]) ** 2 for j in range(len(y_pred)))
                    self.backward(y_batch[i], y_pred, len(X_batch))

                epoch_loss += batch_loss / len(X_batch)

            epoch_loss /= n_batches

            # 테스트 손실
            test_loss = 0
            y_pred_test = []
            for x in X_test:
                pred = self.forward(x, training=False)
                y_pred_test.append(pred)

            for i in range(len(y_test)):
                test_loss += sum((y_pred_test[i][j] - y_test[i][j]) ** 2
                                for j in range(len(y_pred_test[i])))
            test_loss /= len(y_test)

            self.train_losses.append(epoch_loss)
            self.test_losses.append(test_loss)

            # 진행 상황
            if (epoch + 1) % 20 == 0:
                print(f"  Epoch {epoch+1:3d}/{epochs}: Train Loss={epoch_loss:.6f}, Test Loss={test_loss:.6f}")

        print(f"✅ Training complete")

    def predict(self, X):
        """예측"""
        predictions = []
        for x in X:
            pred = self.forward(x, training=False)
            predictions.append(pred)
        return predictions

    def calculate_r2(self, y_true, y_pred):
        """R² 점수 계산"""
        y_mean = sum(y_true) / len(y_true)
        ss_tot = sum((y - y_mean) ** 2 for y in y_true)
        ss_res = sum((y_pred[i] - y_true[i]) ** 2 for i in range(len(y_true)))

        if ss_tot == 0:
            return 1.0 if ss_res == 0 else 0.0
        return 1.0 - (ss_res / ss_tot)

# ============================================================================
# 4. Model Training with Advanced Features
# ============================================================================

print("\n🧠 Step 4: Training advanced model...")

# 신경망 구조: 12 → 256 → 128 → 64 → 5 (더 깊고 넓음)
model = AdvancedNeuralNetwork(
    layer_sizes=[12, 256, 128, 64, 5],
    learning_rate=0.01,
    momentum=0.9,
    l2_lambda=0.0001
)

model.fit(X_train, y_train, X_test, y_test, epochs=200, batch_size=32)

# ============================================================================
# 5. Evaluation
# ============================================================================

print("\n📈 Step 5: Evaluating advanced model...")

y_train_pred = model.predict(X_train)
y_test_pred = model.predict(X_test)

# 역정규화
def denormalize(y_norm, y_mean, y_std):
    return [y_norm[i] * y_std[i] + y_mean[i] for i in range(len(y_norm))]

y_train_actual = [denormalize(y, y_mean, y_std) for y in y_train]
y_test_actual = [denormalize(y, y_mean, y_std) for y in y_test]
y_train_pred_actual = [denormalize(y, y_mean, y_std) for y in y_train_pred]
y_test_pred_actual = [denormalize(y, y_mean, y_std) for y in y_test_pred]

# 메트릭 계산
def mse(y_true, y_pred):
    return sum((y_true[i][j] - y_pred[i][j]) ** 2
              for i in range(len(y_true))
              for j in range(len(y_true[0]))) / (len(y_true) * len(y_true[0]))

def mae(y_true, y_pred):
    return sum(abs(y_true[i][j] - y_pred[i][j])
              for i in range(len(y_true))
              for j in range(len(y_true[0]))) / (len(y_true) * len(y_true[0]))

def r2_overall(y_true, y_pred):
    y_true_flat = [v for row in y_true for v in row]
    y_pred_flat = [v for row in y_pred for v in row]

    y_mean = sum(y_true_flat) / len(y_true_flat)
    ss_tot = sum((y - y_mean) ** 2 for y in y_true_flat)
    ss_res = sum((y_true_flat[i] - y_pred_flat[i]) ** 2 for i in range(len(y_true_flat)))

    if ss_tot == 0:
        return 1.0
    return 1.0 - (ss_res / ss_tot)

train_mse = mse(y_train_actual, y_train_pred_actual)
test_mse = mse(y_test_actual, y_test_pred_actual)
train_mae = mae(y_train_actual, y_train_pred_actual)
test_mae = mae(y_test_actual, y_test_pred_actual)
train_r2 = r2_overall(y_train_actual, y_train_pred_actual)
test_r2 = r2_overall(y_test_actual, y_test_pred_actual)

print(f"\n✅ Train MSE: {train_mse:.6f}")
print(f"✅ Test MSE:  {test_mse:.6f}")
print(f"✅ Train MAE: {train_mae:.6f}")
print(f"✅ Test MAE:  {test_mae:.6f}")
print(f"✅ Train R²:  {train_r2:.6f}")
print(f"✅ Test R²:   {test_r2:.6f}")

# ============================================================================
# 6. Per-Mutation Analysis
# ============================================================================

print("\n📊 Per-mutation performance:")

mutation_names = ['Tiling', 'Unroll', 'Vector', 'Interchange', 'ConstProp']

for mutation_idx in range(5):
    y_true_mutation = [y_test_actual[i][mutation_idx] for i in range(len(y_test_actual))]
    y_pred_mutation = [y_test_pred_actual[i][mutation_idx] for i in range(len(y_test_pred_actual))]

    r2 = model.calculate_r2(y_true_mutation, y_pred_mutation)

    mse_val = sum((y_true_mutation[i] - y_pred_mutation[i]) ** 2 for i in range(len(y_true_mutation))) / len(y_true_mutation)

    status = "✅" if r2 > 0.85 else "⚠️ " if r2 > 0.75 else "❌"
    print(f"  {status} {mutation_names[mutation_idx]:15s}: R² = {r2:.4f}, MSE = {mse_val:.6f}")

# ============================================================================
# 7. Summary
# ============================================================================

print("\n" + "=" * 70)
print("Advanced Training Complete!")
print("=" * 70)

print(f"\n✅ Model trained successfully!")
print(f"   • Architecture: 12 → 256 → 128 → 64 → 5 (더 깊고 넓음)")
print(f"   • Features:")
print(f"     - Batch Normalization (배치 정규화)")
print(f"     - Dropout (드롭아웃, rate=0.2)")
print(f"     - Momentum SGD (모멘텀 0.9)")
print(f"     - He 초기화 (가중치 초기화)")
print(f"     - L2 정규화 (정규화, lambda=0.0001)")
print(f"   • Epochs: 200")
print(f"   • Batch Size: 32")
print(f"   • Learning Rate: 0.01")
print(f"   • Train Samples: {len(X_train)}")
print(f"   • Test Samples: {len(X_test)}")

print(f"\n📈 Results:")
print(f"   • Test MSE: {test_mse:.6f} {'✅' if test_mse < 0.1 else '⚠️ '}")
print(f"   • Test MAE: {test_mae:.6f}")
print(f"   • Test R²:  {test_r2:.6f} {'✅' if test_r2 > 0.85 else '⚠️ '}")

print(f"\n💾 Model weights saved!")
print(f"   • Layers: {len(model.weights)}")
print(f"   • Parameters: {sum(len(w) * len(w[0]) for w in model.weights)} weights")

print(f"\n🎯 Status:")
if test_r2 > 0.85:
    print(f"   ✅ R² > 0.85 ACHIEVED! 🏆")
elif test_r2 > 0.75:
    print(f"   ⚠️  R² = {test_r2:.4f} (목표: >0.85)")
else:
    print(f"   ❌ R² = {test_r2:.4f} (계속 학습 필요)")

print("\n" + "=" * 70)
