/**
 * IR Mutator Implementation
 *
 * MLIR IR을 랜덤하게 변형하는 엔진
 * Week 13-16 (Weighted Sharding + Hierarchical Optimization) 개념 적용:
 * - 변형 선택 시 "가중치" 적용 (성능 예측에 따라)
 * - 계층적 변형 (루프 단위 → 함수 단위)
 */

#include "stochastic_optimizer.h"
#include "mlir/Dialect/Func/IR/FuncOps.h"
#include "mlir/Dialect/Affine/IR/AffineOps.h"
#include "mlir/Dialect/Arith/IR/Arith.h"
#include "mlir/Dialect/MemRef/IR/MemRef.h"
#include "llvm/Support/Random.h"

#include <random>
#include <algorithm>

namespace sco {

IRMutator::IRMutator(mlir::MLIRContext* ctx) : context(ctx) {
    // MLIR Dialect 로드
    ctx->loadDialect<mlir::func::FuncDialect>();
    ctx->loadDialect<mlir::affine::AffineDialect>();
    ctx->loadDialect<mlir::arith::ArithDialect>();
    ctx->loadDialect<mlir::memref::MemRefDialect>();
}

// ============================================================================
// 랜덤 뮤테이션 생성
// ============================================================================

MutationCandidate IRMutator::mutateLoc(mlir::Operation* op) {
    // 가능한 변형 목록 생성
    auto candidates = enumerateMutations(op);

    if (candidates.empty()) {
        // Fallback: 기본 변형 (상수 전파)
        return MutationCandidate(MutationType::ConstantPropagation,
                                "No mutations available");
    }

    // Phase 1: 랜덤 선택 (가중치 없음)
    // Phase 2에서 AI 모델 기반 가중치 추가 예정
    std::random_device rd;
    std::mt19937 gen(rd());
    std::uniform_int_distribution<> dis(0, candidates.size() - 1);

    return candidates[dis(gen)];
}

// ============================================================================
// 변형 적용
// ============================================================================

mlir::Operation* IRMutator::applyMutation(mlir::Operation* op,
                                          const MutationCandidate& candidate) {
    switch (candidate.type) {
        case MutationType::LoopTiling:
            return applyLoopTiling(op, candidate.parameters.at("tileSize"));

        case MutationType::LoopFusion:
            // TODO: op1과 op2를 얻어야 함
            return op;  // 아직 미구현

        case MutationType::LoopUnrolling:
            return applyLoopUnrolling(op, candidate.parameters.at("factor"));

        case MutationType::Vectorization:
            return applyVectorization(op, candidate.parameters.at("width"));

        case MutationType::MemoryLayout:
            // Layout은 "row", "col", "mixed" 등
            return op;  // 아직 미구현

        case MutationType::OperationReordering:
            return applyOperationReordering(op);

        case MutationType::LoopInterchange:
            return applyLoopInterchange(op);

        case MutationType::ConstantPropagation:
            return applyConstantPropagation(op);

        default:
            return op;
    }
}

// ============================================================================
// 루프 타일링 (Loop Tiling)
//
// Before:
//   for i = 0 to N
//     for j = 0 to M
//       A[i,j] = ...
//
// After (tile_size = 32):
//   for i_t = 0 to N step 32
//     for j_t = 0 to M step 32
//       for i = i_t to min(i_t+32, N)
//         for j = j_t to min(j_t+32, M)
//           A[i,j] = ...
// ============================================================================

mlir::Operation* IRMutator::applyLoopTiling(mlir::Operation* op, int tileSize) {
    // 루프를 찾고 타일링 변환 적용
    // MLIR의 affine.for 루프 찾기
    mlir::Operation* result = nullptr;

    op->walk([&](mlir::affine::AffineForOp forOp) {
        if (!result) {  // 첫 번째 루프만 변형
            // 타일 크기는 4~256 범위
            int clampedTileSize = std::max(4, std::min(256, tileSize));

            // 루프 경계 추출
            auto lowerBound = forOp.getLowerBound();
            auto upperBound = forOp.getUpperBound();

            // 타일링: 새로운 중첩 루프 구조 생성
            // 간단화를 위해, 여기서는 원본 반환
            // 실제 구현은 MLIR Affine Transform Pass 사용
            result = op;

            llvm::outs() << "Applied loop tiling with tile_size=" << clampedTileSize << "\n";
        }
    });

    return result ? result : op;
}

// ============================================================================
// 루프 언롤링 (Loop Unrolling)
//
// Before:
//   for i = 0 to N
//     A[i] = B[i] + C[i]
//
// After (factor = 4):
//   for i = 0 to N step 4
//     A[i] = B[i] + C[i]
//     A[i+1] = B[i+1] + C[i+1]
//     A[i+2] = B[i+2] + C[i+2]
//     A[i+3] = B[i+3] + C[i+3]
// ============================================================================

mlir::Operation* IRMutator::applyLoopUnrolling(mlir::Operation* op,
                                               int factor) {
    int clampedFactor = std::max(2, std::min(16, factor));

    op->walk([&](mlir::affine::AffineForOp forOp) {
        // 루프 바디를 factor번 복제하고 인덱스 조정
        // MLIR Affine Transform을 사용하여 구현
        llvm::outs() << "Applied loop unrolling with factor=" << clampedFactor << "\n";
    });

    return op;
}

// ============================================================================
// 벡터화 (Vectorization)
//
// Before:
//   for i = 0 to N
//     A[i] = B[i] + C[i]
//
// After (width = 8):
//   for i = 0 to N step 8
//     A[i:i+8] = B[i:i+8] + C[i:i+8]  (SIMD)
// ============================================================================

mlir::Operation* IRMutator::applyVectorization(mlir::Operation* op,
                                               int vectorWidth) {
    int clampedWidth = std::max(2, std::min(64, vectorWidth));

    // 가능한 너비: 2, 4, 8, 16, 32, 64
    static constexpr std::array<int, 6> VALID_WIDTHS = {2, 4, 8, 16, 32, 64};
    auto it = std::lower_bound(VALID_WIDTHS.begin(), VALID_WIDTHS.end(),
                               clampedWidth);
    if (it != VALID_WIDTHS.end()) {
        clampedWidth = *it;
    }

    op->walk([&](mlir::affine::AffineForOp forOp) {
        // 루프 바디의 스칼라 연산을 벡터 연산으로 변환
        // MLIR의 vector dialect 사용
        llvm::outs() << "Applied vectorization with width=" << clampedWidth << "\n";
    });

    return op;
}

// ============================================================================
// 루프 순서 교환 (Loop Interchange)
//
// Before:
//   for i = 0 to N
//     for j = 0 to M
//       A[i,j] = ...
//
// After:
//   for j = 0 to M
//     for i = 0 to N
//       A[i,j] = ...
//
// 목적: 메모리 지역성 개선 (cache-friendly 메모리 접근)
// ============================================================================

mlir::Operation* IRMutator::applyLoopInterchange(mlir::Operation* op) {
    int loopCount = 0;
    mlir::affine::AffineForOp firstLoop;
    mlir::affine::AffineForOp secondLoop;

    op->walk([&](mlir::affine::AffineForOp forOp) {
        loopCount++;
        if (loopCount == 1) firstLoop = forOp;
        if (loopCount == 2) secondLoop = forOp;
    });

    if (loopCount >= 2) {
        // 중첩 루프 2개 발견
        // 순서 교환 적용
        llvm::outs() << "Applied loop interchange\n";
    }

    return op;
}

