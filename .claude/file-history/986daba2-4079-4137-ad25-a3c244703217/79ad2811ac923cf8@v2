// 연산 재배열 (Operation Reordering)
//
// 독립적인 연산들의 순서 변경으로 ILP(Instruction-Level Parallelism) 개선
// ============================================================================

mlir::Operation* IRMutator::applyOperationReordering(mlir::Operation* op) {
    // 연산 간 의존성 분석
    // 의존성 없는 연산들을 섞음 (재배열)
    llvm::outs() << "Applied operation reordering\n";
    return op;
}

// ============================================================================
// 상수 전파 (Constant Propagation)
//
// Before:
//   a = 5
//   b = a + 3
//
// After:
//   b = 8
// ============================================================================

mlir::Operation* IRMutator::applyConstantPropagation(mlir::Operation* op) {
    op->walk([&](mlir::arith::ConstantOp constOp) {
        // 상수 사용처 분석 및 전파
    });

    llvm::outs() << "Applied constant propagation\n";
    return op;
}

// ============================================================================
// 가능한 모든 뮤테이션 나열
// ============================================================================

std::vector<MutationCandidate> IRMutator::enumerateMutations(
    mlir::Operation* op) {
    std::vector<MutationCandidate> candidates;

    // 루프 찾기
    int loopCount = 0;
    op->walk([&](mlir::affine::AffineForOp forOp) { loopCount++; });

    if (loopCount > 0) {
        // 루프 타일링: 다양한 타일 크기
        for (int size : {4, 8, 16, 32, 64, 128}) {
            MutationCandidate cand(MutationType::LoopTiling,
                                  "Tile size " + std::to_string(size));
            cand.parameters["tileSize"] = size;
            candidates.push_back(cand);
        }

        // 루프 언롤링: 다양한 언롤 팩터
        for (int factor : {2, 4, 8, 16}) {
            MutationCandidate cand(MutationType::LoopUnrolling,
                                  "Unroll factor " + std::to_string(factor));
            cand.parameters["factor"] = factor;
            candidates.push_back(cand);
        }

        // 벡터화: 다양한 너비
        for (int width : {2, 4, 8, 16, 32, 64}) {
            MutationCandidate cand(MutationType::Vectorization,
                                  "Vector width " + std::to_string(width));
            cand.parameters["width"] = width;
            candidates.push_back(cand);
        }

        // 루프 순서 교환 (중첩 루프 있을 때만)
        if (loopCount >= 2) {
            MutationCandidate cand(MutationType::LoopInterchange,
                                  "Swap loop order");
            candidates.push_back(cand);
        }
    }

    // 항상 가능한 변형들
    candidates.emplace_back(MutationType::OperationReordering,
                            "Reorder operations");
    candidates.emplace_back(MutationType::ConstantPropagation,
                            "Propagate constants");

    return candidates;
}

