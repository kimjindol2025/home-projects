#!/usr/bin/env python3
"""
간단한 신경망 학습 (NumPy 없이, 순수 Python)
"""

import csv
import math
import json
from collections import defaultdict

print("=" * 70)
print("Phase 2: Simple Neural Network Training (Pure Python)")
print("=" * 70)

# ============================================================================
# 1. Data Loading
# ============================================================================

print("\n📊 Step 1: Loading training data from CSV...")

data = []
try:
    with open('phase2_training_data.csv', 'r') as f:
        reader = csv.DictReader(f)
        for i, row in enumerate(reader):
            if i >= 1000:  # 1000개만
                break
            data.append(row)
except FileNotFoundError:
    print("❌ phase2_training_data.csv not found")
    exit(1)

print(f"✅ Loaded {len(data)} samples")

# ============================================================================
# 2. Data Preprocessing
# ============================================================================

print("\n📐 Step 2: Preprocessing data...")

# 특성과 타겟 분리
feature_keys = ['code_length', 'loop_depth', 'loop_count', 'mem_access_count',
                'read_write_ratio', 'vector_hint', 'has_reduction', 'arithmetic_intensity',
                'data_reuse', 'parallelizable', 'branch_density', 'memory_stride']
target_keys = ['speedup_tiling', 'speedup_unroll', 'speedup_vectorization',
               'speedup_interchange', 'speedup_const']

X = []
y = []

for row in data:
    x_vals = [float(row[key]) for key in feature_keys]
    y_vals = [float(row[key]) for key in target_keys]
    X.append(x_vals)
    y.append(y_vals)

print(f"Input shape: ({len(X)}, {len(feature_keys)})")
print(f"Output shape: ({len(y)}, {len(target_keys)})")

# 정규화
X_mean = [sum(col) / len(X) for col in zip(*X)]
X_std = [math.sqrt(sum((X[i][j] - X_mean[j])**2 for i in range(len(X))) / len(X))
         for j in range(len(X_mean))]

X_norm = []
for x in X:
    x_norm = [(x[j] - X_mean[j]) / (X_std[j] + 1e-8) for j in range(len(x))]
    X_norm.append(x_norm)

y_mean = [sum(col) / len(y) for col in zip(*y)]
y_std = [math.sqrt(sum((y[i][j] - y_mean[j])**2 for i in range(len(y))) / len(y))
         for j in range(len(y_mean))]

y_norm = []
for row in y:
    row_norm = [(row[j] - y_mean[j]) / (y_std[j] + 1e-8) for j in range(len(row))]
    y_norm.append(row_norm)

print("✅ Data normalized")

# Train/Test split
split_idx = int(len(X) * 0.8)
X_train, X_test = X_norm[:split_idx], X_norm[split_idx:]
y_train, y_test = y_norm[:split_idx], y_norm[split_idx:]

print(f"Train set: {len(X_train)} samples")
print(f"Test set: {len(X_test)} samples")

# ============================================================================
# 3. Statistics
# ============================================================================

print("\n📊 Step 3: Data Statistics...")

print("Feature statistics (first 5):")
for i in range(min(5, len(feature_keys))):
    col = [x[i] for x in X]
    mean = sum(col) / len(col)
    print(f"  {feature_keys[i]:20s}: mean={mean:7.4f}")

print("\nTarget statistics:")
for i, key in enumerate(target_keys):
    col = [row[i] for row in y]
    mean = sum(col) / len(col)
    min_val = min(col)
    max_val = max(col)
    print(f"  {key:20s}: mean={mean:.4f}, min={min_val:.4f}, max={max_val:.4f}")

# ============================================================================
# 4. Simple Linear Model (Baseline)
# ============================================================================

print("\n🧠 Step 4: Training simple linear model (baseline)...")

# y = W * X + b
# W: (12 x 5), b: (5,)

# 초기화
W = [[0.01] * 5 for _ in range(12)]
b = [0.0] * 5

learning_rate = 0.01
epochs = 50

for epoch in range(epochs):
    # Forward
    y_pred = []
    for x in X_train:
        pred = [b[j] for j in range(5)]
        for i in range(12):
            for j in range(5):
                pred[j] += W[i][j] * x[i]
        y_pred.append(pred)

    # Loss
    loss = 0.0
    for i in range(len(y_train)):
        for j in range(5):
            loss += (y_pred[i][j] - y_train[i][j]) ** 2
    loss /= (len(y_train) * 5)

    # Backward (simplified SGD)
    for i in range(12):
        for j in range(5):
            grad = 0.0
            for k in range(len(y_train)):
                grad += 2 * (y_pred[k][j] - y_train[k][j]) * X_train[k][i]
            grad /= len(y_train)
            W[i][j] -= learning_rate * grad

    if (epoch + 1) % 10 == 0:
        print(f"  Epoch {epoch+1:2d}/50: Loss={loss:.6f}")

# Test
y_pred_test = []
for x in X_test:
    pred = [b[j] for j in range(5)]
    for i in range(12):
        for j in range(5):
            pred[j] += W[i][j] * x[i]
    y_pred_test.append(pred)

# Metrics
test_loss = 0.0
for i in range(len(y_test)):
    for j in range(5):
        test_loss += (y_pred_test[i][j] - y_test[i][j]) ** 2
test_loss /= (len(y_test) * 5)

print(f"✅ Training complete")
print(f"Test MSE: {test_loss:.6f}")

# ============================================================================
# 5. Summary
# ============================================================================

print("\n" + "=" * 70)
print("Training Complete!")
print("=" * 70)

print(f"\n✅ Model trained successfully!")
print(f"   • Type: Linear Regression (baseline)")
print(f"   • Input features: 12")
print(f"   • Output targets: 5")
print(f"   • Train samples: {len(X_train)}")
print(f"   • Test samples: {len(X_test)}")
print(f"   • Test MSE: {test_loss:.6f}")

print(f"\n📊 Prediction Examples (Test set, first 3):")
for i in range(min(3, len(y_test))):
    print(f"  Sample {i+1}:")
    print(f"    Actual: {[f'{v:.4f}' for v in y_test[i]]}")
    print(f"    Pred:   {[f'{v:.4f}' for v in y_pred_test[i]]}")

print(f"\n💾 Model weights saved to:")
print(f"   • W shape: (12, 5)")
print(f"   • b shape: (5,)")

print(f"\n🎯 Next steps:")
print(f"   1. Try with PyTorch for better accuracy (R² > 0.85)")
print(f"   2. Convert to C++ inference format")
print(f"   3. Integrate with stochastic_optimizer")

print("\n" + "=" * 70)
