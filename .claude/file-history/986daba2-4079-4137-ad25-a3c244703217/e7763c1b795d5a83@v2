// 📚 함수 1: 간단한 인사
fun greet(name: String) {
    println("안녕하세요, $name님!")
}

// 📚 함수 2: 계산 결과를 돌려주기
fun add(a: Int, b: Int): Int {
    return a + b
}

// 📚 함수 3: 여러 일을 하는 함수
fun describeNumber(num: Int): String {
    return when {
        num > 0 -> "양수입니다"
        num < 0 -> "음수입니다"
        else -> "0입니다"
    }
}

// 📚 함수 4: 숫자가 소수인지 확인
fun isPrime(n: Int): Boolean {
    if (n <= 1) return false
    if (n == 2) return true
    if (n % 2 == 0) return false
    for (i in 3..n/2 step 2) {
        if (n % i == 0) return false
    }
    return true
}

// 📚 함수 5: 팩토리얼 (재귀)
fun factorial(n: Int): Long {
    return when {
        n <= 1 -> 1
        else -> n.toLong() * factorial(n - 1)
    }
}

// 📚 함수 6: 리스트의 합
fun sumList(numbers: List<Int>): Int {
    var sum = 0
    for (num in numbers) {
        sum += num
    }
    return sum
}

