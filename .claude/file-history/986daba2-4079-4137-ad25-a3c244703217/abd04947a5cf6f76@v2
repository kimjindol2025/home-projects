# Makefile for Stochastic Code Optimizer
# Simple build system when CMake is not available

CXX = g++
CXXFLAGS = -std=c++17 -O3 -Wall -Wextra
LDFLAGS =

SRC_DIR = src
TEST_DIR = tests
BUILD_DIR = build
BIN_DIR = $(BUILD_DIR)/bin

# Source files
DEMO_SRC = $(SRC_DIR)/main_demo.cpp
TEST_SRC = $(TEST_DIR)/unit_tests.cpp

# Targets
DEMO_BIN = $(BIN_DIR)/stochastic_optimizer_demo
TEST_BIN = $(BIN_DIR)/unit_tests

# Default target
.PHONY: all
all: $(DEMO_BIN) $(TEST_BIN)

# Create build directory
$(BUILD_DIR):
	@mkdir -p $(BUILD_DIR) $(BIN_DIR)

# Demo executable
$(DEMO_BIN): $(DEMO_SRC) | $(BUILD_DIR)
	@echo "🔨 Compiling demo: $@"
	$(CXX) $(CXXFLAGS) -o $@ $< $(LDFLAGS)
	@echo "✅ Demo built successfully"

# Unit tests executable
$(TEST_BIN): $(TEST_SRC) | $(BUILD_DIR)
	@echo "🔨 Compiling tests: $@"
	$(CXX) $(CXXFLAGS) -o $@ $< $(LDFLAGS)
	@echo "✅ Tests built successfully"

# Run demo
.PHONY: run-demo
run-demo: $(DEMO_BIN)
	@echo "\n🚀 Running demo..."
	@$(DEMO_BIN)

# Run tests
.PHONY: test
test: $(TEST_BIN)
	@echo "\n🧪 Running unit tests..."
	@$(TEST_BIN)

# Clean build artifacts
.PHONY: clean
clean:
	@echo "🧹 Cleaning build artifacts..."
	@rm -rf $(BUILD_DIR)
	@echo "✅ Clean complete"

# Full rebuild
.PHONY: rebuild
rebuild: clean all

# Show help
.PHONY: help
help:
	@echo "╔════════════════════════════════════╗"
	@echo "║  Stochastic Optimizer - Makefile   ║"
	@echo "╠════════════════════════════════════╣"
	@echo "║  make all        - Build all       ║"
	@echo "║  make run-demo   - Run demo        ║"
	@echo "║  make test       - Run tests       ║"
	@echo "║  make rebuild    - Clean & build   ║"
	@echo "║  make clean      - Remove builds   ║"
	@echo "║  make help       - Show this       ║"
	@echo "╚════════════════════════════════════╝"

# Verbose build
.PHONY: verbose
verbose: CXXFLAGS += -v
verbose: all

.PHONY: info
info:
	@echo "Project Information:"
	@echo "  CXX:       $(CXX)"
	@echo "  CXXFLAGS:  $(CXXFLAGS)"
	@echo "  SRC_DIR:   $(SRC_DIR)"
	@echo "  BUILD_DIR: $(BUILD_DIR)"
