#!/usr/bin/env node

/**
 * KimSearch Mini - CLI Interface
 *
 * 사용:
 * $ ks "pattern"
 * $ ks "pattern" --lang py --limit 5
 * $ ks quick "pattern"
 *
 * Author: Claude (Haiku 4.5)
 * Date: 2026-02-26
 */

const { KimSearchMini } = require('./kimsearch-mini');

// 설정
const HOME = process.env.HOME || '/root';
const QUALITY_PATH = '/tmp/kimsearch-v2/quality-assessment.json';

// 검색 경로 (우선순위 순)
const searchPaths = [
  '/tmp/kimsearch-v2/repos-extract/kim/',
  `${HOME}/freelang-v6/`,
  `${HOME}/grie-engine/`,
  `${HOME}/projects/`,
  `${HOME}/golang_study/`,
  `${HOME}/zig-study/`
];

const engine = new KimSearchMini(searchPaths, QUALITY_PATH);

// 색상 정의
const colors = {
  reset: '\x1b[0m',
  bold: '\x1b[1m',
  dim: '\x1b[2m',

  // 배경색
  bgGreen: '\x1b[42m',
  bgRed: '\x1b[41m',
  bgYellow: '\x1b[43m',
  bgGray: '\x1b[100m',

  // 텍스트색
  green: '\x1b[32m',
  red: '\x1b[31m',
  yellow: '\x1b[33m',
  blue: '\x1b[34m',
  cyan: '\x1b[36m',
  gray: '\x1b[90m',
  white: '\x1b[37m'
};

/**
 * 컬러 텍스트
 */
function c(text, color) {
  return `${colors[color]}${text}${colors.reset}`;
}

/**
 * 결과 포맷팅
 */
function formatResults(data, options = {}) {
  const { minimal = false } = options;

  if (!data.results || data.results.length === 0) {
    console.log(`\n${c('🔍 검색 결과 없음', 'gray')}\n`);
    return;
  }

  console.log(`\n${c('🔍 검색:', 'blue')} ${c(data.query, 'bold')} ${c(`(${data.results.length}개)`, 'cyan')}`);
  console.log(c('━'.repeat(80), 'gray'));

  data.results.forEach((result, index) => {
    const num = c(`${index + 1}️⃣`, 'yellow');

    if (minimal) {
      // 미니 포맷
      const repo = c(result.repo, 'blue');
      const line = c(`:${result.line}`, 'gray');
      console.log(`${num} ${repo}${line}`);
    } else {
      // 상세 포맷
      const status = result.quality?.status || '⚪';
      const repo = c(result.repo, 'blue');
      const line = c(`:${result.line}`, 'gray');
      const file = c(result.file, 'cyan');

      console.log(`${num} ${status} ${file}${line}`);
      console.log(`   ${c(result.content, 'dim')}`);

      if (result.quality && !minimal) {
        const stars = c(`⭐×${result.quality.stars}`, 'yellow');
        const status_text = c(result.quality.status || 'UNKNOWN', 'dim');
        const completion = c(`${result.quality.completion}%`, 'dim');
        const issues = result.quality.issues > 0 ? c(` | ${result.quality.issues} issues`, 'red') : '';
        console.log(`   ${stars} ${status_text} | ${completion}${issues}`);
      }
    }
  });

  console.log(c('━'.repeat(80), 'gray'));

  // 통계
  const starred = data.results.filter(r => r.quality).reduce((s, r) => s + (r.quality.stars || 0), 0);
  const totalStars = data.results.filter(r => r.quality).length;
  const avgStars = totalStars > 0 ? (starred / totalStars).toFixed(1) : 'N/A';

  console.log(`${c('⏱️  시간:', 'gray')} ${c(Date.now() - startTime + 'ms', 'cyan')} | ${c('📦 캐시:', 'gray')} ${c(data.cached ? 'hit' : 'miss', data.cached ? 'green' : 'yellow')} | ${c('🏷️  평균별:', 'gray')} ${c(avgStars, 'yellow')}`);
  console.log();
}

/**
 * 빠른 결과 포맷팅
 */
function formatQuickResults(data) {
  if (!data.results || data.results.length === 0) {
    console.log(`\n${c('검색 결과 없음', 'gray')}\n`);
    return;
  }

  console.log(`\n${c('🔍 quick:', 'blue')} ${c(data.query, 'bold')} ${c(`(${data.results.length}개)`, 'cyan')}\n`);

  data.results.forEach((result, index) => {
    const repo = c(result.repo, 'blue');
    const line = c(`:${result.line}`, 'gray');
    console.log(`${c((index + 1) + '.', 'yellow')} ${repo}${line}`);
  });

  console.log(`\n${c('⏱️  ' + (Date.now() - startTime) + 'ms', 'gray')} | ${c('📦 quick mode', 'cyan')}\n`);
}

/**
 * 통계 출력
 */
function printStats() {
  const cacheStats = engine.getCacheStats();
  console.log(`\n${c('📊 캐시 통계', 'blue')}`);
  console.log(c('━'.repeat(40), 'gray'));
  console.log(`${c('크기:', 'gray')} ${c(cacheStats.size, 'cyan')}`);
  if (cacheStats.keys.length > 0) {
    console.log(`${c('최근:', 'gray')} ${cacheStats.keys.map(k => c(Buffer.from(k, 'base64').toString().split('|')[0], 'dim')).join(', ')}`);
  }
  console.log();
}

/**
 * 헬프 출력
 */
function printHelp() {
  console.log(`
${c('🔍 KimSearch Mini - Termux 최적화 검색엔진', 'blue')}

${c('사용:', 'bold')}
  ks <query> [옵션]           # 검색
  ks quick <query> [옵션]     # 빠른 검색
  ks stats                    # 캐시 통계
  ks clear-cache              # 캐시 초기화
  ks --help                   # 도움말

${c('옵션:', 'bold')}
  -l, --limit <n>             결과 개수 (기본: 10)
  -L, --lang <언어>           언어 필터 (js, py, go, zig, ...)
  --sort <방식>               정렬 (relevance, quality, file)
  --quality-only              품질 평가된 것만
  --no-color                  색상 제거

${c('예시:', 'bold')}
  ks "function" -l 5
  ks "async" -L js --sort quality
  ks quick "database"
  ks "error" --quality-only

${c('범위:', 'blue')} ${c(HOME, 'cyan')} (홈 폴더 전체)
`);
}

/**
 * 메인
 */
const startTime = Date.now();
const args = process.argv.slice(2);

if (args.length === 0 || args[0] === '--help' || args[0] === '-h') {
  printHelp();
  process.exit(0);
}

const command = args[0];

if (command === 'stats') {
  printStats();
} else if (command === 'clear-cache') {
  engine.clearCache();
  console.log(`${c('✅ 캐시 삭제됨', 'green')}\n`);
} else if (command === 'quick') {
  // 빠른 검색
  const query = args[1];
  if (!query) {
    console.log(c('❌ 검색어를 입력하세요', 'red'));
    process.exit(1);
  }

  const limit = parseInt(args[args.indexOf('-l') + 1] || args[args.indexOf('--limit') + 1] || 5);
  const results = engine.quickSearch(query, limit);
  formatQuickResults(results);
} else {
  // 일반 검색
  const query = command;

  // 옵션 파싱
  const options = {};

  if (args.includes('-l') || args.includes('--limit')) {
    const idx = args.includes('-l') ? args.indexOf('-l') : args.indexOf('--limit');
    options.limit = parseInt(args[idx + 1] || 10);
  } else {
    options.limit = 10;
  }

  if (args.includes('-L') || args.includes('--lang')) {
    const idx = args.includes('-L') ? args.indexOf('-L') : args.indexOf('--lang');
    options.lang = args[idx + 1];
  }

  if (args.includes('--sort')) {
    const idx = args.indexOf('--sort');
    options.sort = args[idx + 1];
  }

  if (args.includes('--quality-only')) {
    options.minQuality = 3;
  }

  // 검색 실행
  const results = engine.search(query, options);
  const hasColor = !args.includes('--no-color');
  formatResults(results, { minimal: false });
}
