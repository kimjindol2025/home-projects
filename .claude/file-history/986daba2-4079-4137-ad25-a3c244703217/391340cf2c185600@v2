## **Level 12: 마이크로서비스와 동시성 제어**

### 예제 코드: `12-master-microservices.kt`

```kotlin
import kotlinx.coroutines.*
import java.util.concurrent.atomic.AtomicInteger

// 📚 패턴 1: 분산 락 (Distributed Lock)

class DistributedLock {
    private val locked = AtomicInteger(0)

    suspend inline fun <T> withLock(block: suspend () -> T): T {
        while (!locked.compareAndSet(0, 1)) {
            delay(10)
        }
        return try {
            block()
        } finally {
            locked.set(0)
        }
    }
}

// 📚 패턴 2: 서킷 브레이커 (Circuit Breaker)

enum class CircuitState {
    CLOSED, OPEN, HALF_OPEN
}

class CircuitBreaker(
    val threshold: Int = 5,
    val timeout: Long = 5000
) {
    private var failureCount = 0
    private var state = CircuitState.CLOSED
    private var lastFailureTime = 0L

    suspend fun <T> execute(block: suspend () -> T): T? {
        return when (state) {
            CircuitState.CLOSED -> {
                try {
                    val result = block()
                    failureCount = 0
                    result
                } catch (e: Exception) {
                    failureCount++
                    if (failureCount >= threshold) {
                        state = CircuitState.OPEN
                        lastFailureTime = System.currentTimeMillis()
                    }
                    throw e
                }
            }

            CircuitState.OPEN -> {
                if (System.currentTimeMillis() - lastFailureTime > timeout) {
                    state = CircuitState.HALF_OPEN
                    execute(block)
                } else {
                    null
                }
            }

            CircuitState.HALF_OPEN -> {
                try {
                    val result = block()
                    state = CircuitState.CLOSED
                    failureCount = 0
                    result
                } catch (e: Exception) {
                    state = CircuitState.OPEN
                    lastFailureTime = System.currentTimeMillis()
                    null
                }
            }
        }
    }
}

fun main() {
    runBlocking {
        val lock = DistributedLock()
        var counter = 0

        val jobs = (1..10).map {
            launch {
                lock.withLock {
                    counter++
                    println("Counter: $counter (Task $it)")
                }
            }
        }

        jobs.joinAll()
        println("최종 counter: $counter")
    }
}
```

