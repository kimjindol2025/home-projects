```kotlin
// 📚 정렬 알고리즘: 버블 정렬

fun bubbleSort(arr: MutableList<Int>): List<Int> {
    val n = arr.size
    for (i in 0 until n) {
        for (j in 0 until n - i - 1) {
            if (arr[j] > arr[j + 1]) {
                // 스왑
                val temp = arr[j]
                arr[j] = arr[j + 1]
                arr[j + 1] = temp
            }
        }
    }
    return arr
}

// 📚 이진 탐색
fun binarySearch(arr: List<Int>, target: Int): Int {
    var left = 0
    var right = arr.size - 1

    while (left <= right) {
        val mid = (left + right) / 2
        when {
            arr[mid] == target -> return mid
            arr[mid] < target -> left = mid + 1
            else -> right = mid - 1
        }
    }
    return -1
}

// 📚 피보나치 수열 (재귀)
fun fibonacci(n: Int): Long {
    return when {
        n <= 1 -> n.toLong()
        else -> fibonacci(n - 1) + fibonacci(n - 2)
    }
}

fun main() {
    val numbers = mutableListOf(64, 34, 25, 12, 22, 11, 90)
    println("원본 배열: $numbers")
    println("정렬된 배열: ${bubbleSort(numbers)}")

    val sorted = listOf(10, 20, 30, 40, 50, 60)
    println("35의 위치: ${binarySearch(sorted, 35)}")
    println("50의 위치: ${binarySearch(sorted, 50)}")

    println("10번째 피보나치: ${fibonacci(10)}")
}
```

