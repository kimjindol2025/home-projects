### 예제 코드: `13-phd-formal-verification.kt`

```kotlin
// 📚 불변성 증명: 수학적 성질을 코드로 검증

/**
 * 성질: sum(1 to n) = n * (n + 1) / 2
 * 증명: 귀납법으로 증명
 */

fun sumFormula(n: Int): Long {
    return n.toLong() * (n + 1) / 2
}

fun sumIterative(n: Int): Long {
    var sum = 0L
    for (i in 1..n) {
        sum += i
    }
    return sum
}

// 증명: 두 구현이 수학적으로 동등함
fun verifyFormula() {
    for (n in 1..1000) {
        val formula = sumFormula(n)
        val iterative = sumIterative(n)
        assert(formula == iterative) {
            "Formula failed for n=$n: formula=$formula, iterative=$iterative"
        }
    }
    println("✅ 합 공식 증명 완료")
}

