## **Level 15: 형식 시스템과 SMT 검증**

### 예제 코드: `15-phd-smt-verification.kt`

```kotlin
// 📚 제약 조건 검증

data class Constraint(
    val variable: String,
    val operation: String,  // >, <, ==, <=, >=
    val value: Int
)

class ConstraintSolver {
    private val constraints = mutableListOf<Constraint>()

    fun addConstraint(variable: String, operation: String, value: Int) {
        constraints.add(Constraint(variable, operation, value))
    }

    fun findSatisfyingAssignment(variables: List<String>): Map<String, Int>? {
        // 간단한 Z3 모의 구현
        for (value in -1000..1000) {
            val assignment = variables.associateWith { value }

            if (constraints.all { c ->
                val v = assignment[c.variable] ?: return@all false
                when (c.operation) {
                    ">" -> v > c.value
                    "<" -> v < c.value
                    "==" -> v == c.value
                    ">=" -> v >= c.value
                    "<=" -> v <= c.value
                    else -> false
                }
            }) {
                return assignment
            }
        }
        return null
    }
}

// 📚 논리식 검증

sealed class Formula {
    data class Var(val name: String) : Formula()
    data class And(val left: Formula, val right: Formula) : Formula()
    data class Or(val left: Formula, val right: Formula) : Formula()
    data class Not(val formula: Formula) : Formula()

    fun isSatisfiable(): Boolean {
        // SAT Solver (간단한 구현)
        return checkAllAssignments()
    }

    private fun checkAllAssignments(): Boolean {
        // 모든 변수 추출
        val variables = extractVariables()
        // 모든 할당 시도
        return tryAssignments(variables, mapOf())
    }

    private fun extractVariables(): Set<String> {
        return when (this) {
            is Var -> setOf(name)
            is And -> left.extractVariables() + right.extractVariables()
            is Or -> left.extractVariables() + right.extractVariables()
            is Not -> formula.extractVariables()
        }
    }

    private fun tryAssignments(
        variables: Set<String>,
        assignment: Map<String, Boolean>
    ): Boolean {
        if (variables.isEmpty()) {
            return evaluate(assignment)
        }

        val variable = variables.first()
        val rest = variables - variable

        return tryAssignments(rest, assignment + (variable to true)) ||
               tryAssignments(rest, assignment + (variable to false))
    }

    private fun evaluate(assignment: Map<String, Boolean>): Boolean {
        return when (this) {
            is Var -> assignment[name] ?: false
            is And -> left.evaluate(assignment) && right.evaluate(assignment)
            is Or -> left.evaluate(assignment) || right.evaluate(assignment)
            is Not -> !formula.evaluate(assignment)
        }
    }
}

fun main() {
    // 제약 조건 풀기
    val solver = ConstraintSolver()
    solver.addConstraint("x", ">", 5)
    solver.addConstraint("x", "<", 10)

    val solution = solver.findSatisfyingAssignment(listOf("x"))
    println("해: $solution")

    // 논리식 만족성 검증
    val formula = Formula.And(
        Formula.Var("p"),
        Formula.Or(
            Formula.Var("q"),
            Formula.Not(Formula.Var("p"))
        )
    )

    println("만족 가능: ${formula.isSatisfiable()}")
}
