class Stack<T> {
    private val items = mutableListOf<T>()

    fun push(item: T) {
        items.add(item)
    }

    fun pop(): T? = if (items.isEmpty()) null else items.removeAt(items.size - 1)

    fun peek(): T? = items.lastOrNull()

    fun isEmpty() = items.isEmpty()
}

