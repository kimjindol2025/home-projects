// 📚 Phantom 타입으로 컴파일 타임에 에러 검증

// 상태 표현
interface State
class Raw : State
class Processed : State
class Finalized : State

// 제너릭 래퍼: 타입 안전성
data class Data<S : State>(val value: String) {

    fun process(): Data<Processed> {
        return Data(value.uppercase())
    }

    fun finalize(): Data<Finalized> {
        return Data(value + " [FINALIZED]")
    }
}

// 📚 "불가능한" 상태 제거

// 이것은 컴파일 불가능:
// val raw = Data<Raw>("hello")
// val bad = raw.finalize()  // ❌ Error: can't finalize Raw state

// 이것만 가능:
// val processed = Data<Processed>("hello")
// val finalized = processed.finalize()  // ✅ OK

// 📚 우아한 타입 안전성

sealed class Either<L, R> {
    class Left<L, R>(val value: L) : Either<L, R>()
    class Right<L, R>(val value: R) : Either<L, R>()

    fun <T> map(f: (R) -> T): Either<L, T> = when (this) {
        is Left -> Left(value)
        is Right -> Right(f(value))
    }

    fun <T> flatMap(f: (R) -> Either<L, T>): Either<L, T> = when (this) {
        is Left -> Left(value)
        is Right -> f(value)
    }
}

fun parseInt(s: String): Either<String, Int> {
    return try {
        Either.Right(s.toInt())
    } catch (e: Exception) {
        Either.Left("Invalid number: $s")
    }
}

fun main() {
    val result = parseInt("42")
        .map { it * 2 }
        .flatMap { value ->
            if (value > 50) Either.Right(value) else Either.Left("Too small")
        }

    when (result) {
        is Either.Left -> println("Error: ${result.value}")
        is Either.Right -> println("Success: ${result.value}")
    }
}
