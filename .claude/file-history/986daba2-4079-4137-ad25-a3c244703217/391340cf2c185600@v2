// 📚 주제 1: 추상 해석 (Abstract Interpretation)

interface Domain<T> {
    val bottom: T
    val top: T
    infix fun meet(other: T): T
    infix fun join(other: T): T
    infix fun leq(other: T): Boolean
}

class IntInterval(val min: Int, val max: Int) {
    override fun toString() = "[$min, $max]"

    companion object {
        val BOTTOM = IntInterval(Int.MAX_VALUE, Int.MIN_VALUE)
        val TOP = IntInterval(Int.MIN_VALUE, Int.MAX_VALUE)
    }

    infix fun meet(other: IntInterval): IntInterval {
        return IntInterval(
            maxOf(this.min, other.min),
            minOf(this.max, other.max)
        )
    }

    infix fun join(other: IntInterval): IntInterval {
        return IntInterval(
            minOf(this.min, other.min),
            maxOf(this.max, other.max)
        )
    }
}

// 📚 주제 2: 도달성 분석 (Reachability Analysis)

class ControlFlowGraph {
    private val nodes = mutableMapOf<String, MutableSet<String>>()

    fun addEdge(from: String, to: String) {
        nodes.getOrPut(from) { mutableSetOf() }.add(to)
    }

    fun reachable(start: String): Set<String> {
        val visited = mutableSetOf<String>()
        val queue = mutableListOf(start)

        while (queue.isNotEmpty()) {
            val current = queue.removeAt(0)
            if (current in visited) continue

            visited.add(current)
            nodes[current]?.forEach { neighbor ->
                if (neighbor !in visited) {
                    queue.add(neighbor)
                }
            }
        }

        return visited
    }

    fun findDeadCode(): Set<String> {
        val reachableFromEntry = reachable("entry")
        return nodes.keys - reachableFromEntry
    }
}

// 📚 주제 3: 성능 모델링과 보증

data class PerformanceModel(
    val algorithm: String,
    val timeComplexity: String,  // O(n), O(n log n), etc
    val spaceComplexity: String
) {

    fun estimate(inputSize: Int): Long {
        return when (timeComplexity) {
            "O(1)" -> 1
            "O(log n)" -> (kotlin.math.log2(inputSize.toDouble())).toLong()
            "O(n)" -> inputSize.toLong()
            "O(n log n)" -> (inputSize * kotlin.math.log2(inputSize.toDouble())).toLong()
            "O(n^2)" -> (inputSize.toLong() * inputSize)
            "O(2^n)" -> (1L shl inputSize)
            else -> -1
        }
    }
}

fun main() {
    println("=== 박사 수준 연구 주제 ===\n")

    // 추상 해석
    val interval1 = IntInterval(1, 10)
    val interval2 = IntInterval(5, 15)
    println("Interval 1: $interval1")
    println("Interval 2: $interval2")
    println("Meet: ${interval1 meet interval2}")
    println("Join: ${interval1 join interval2}\n")

    // 도달성 분석
    val cfg = ControlFlowGraph()
    cfg.addEdge("entry", "block1")
    cfg.addEdge("block1", "block2")
    cfg.addEdge("block2", "exit")
    cfg.addEdge("block_dead", "block_more_dead")

    println("도달 가능한 블록: ${cfg.reachable("entry")}")
    println("죽은 코드: ${cfg.findDeadCode()}\n")

    // 성능 모델
    val models = listOf(
        PerformanceModel("선형 검색", "O(n)", "O(1)"),
        PerformanceModel("병합 정렬", "O(n log n)", "O(n)"),
        PerformanceModel("동적 프로그래밍", "O(2^n)", "O(n)")
    )

    println("성능 추정 (n=1000):")
    models.forEach { model ->
        println("  ${model.algorithm}: ${model.estimate(1000)} 연산")
    }
}
