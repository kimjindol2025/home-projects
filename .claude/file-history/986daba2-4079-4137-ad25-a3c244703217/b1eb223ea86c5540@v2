## **4. MLIR 인터페이스 설계**

### **4.1 HardwareAwareInterface**

```cpp
/// HardwareAwareInterface - 모든 연산이 구현할 인터페이스
///
/// 목적: 컴파일러가 특정 최적화의 비용을 정량적으로 계산하도록 함
///
/// 예:
///   auto matmul = createMatMulOp(...);
///   auto costAnalyzer = createCostAnalyzer(h100_spec);
///   int64_t memory = matmul.getMemoryFootprint(tileSizes);
///   double time = matmul.estimateComputeTime(h100_spec);

class HardwareAwareInterface : public OpInterface<"HardwareAwareInterface"> {
public:
  /// 주어진 타일 크기에서 필요한 메모리량 계산
  ///
  /// @param tileSizes: 각 차원의 타일 크기
  /// @return: 필요한 메모리량 (bytes)
  int64_t getMemoryFootprint(ArrayRef<int64_t> tileSizes);

  /// 주어진 하드웨어에서 예상 연산 시간
  ///
  /// @param spec: 하드웨어 스펙
  /// @return: 예상 실행 시간 (milliseconds)
  double estimateComputeTime(const HardwareSpec& spec);

  /// 메모리 대역폭 제약 확인
  ///
  /// @param spec: 하드웨어 스펙
  /// @return: 메모리 접근이 병목인가?
  bool isMemoryBound(const HardwareSpec& spec);

  /// 캐시 효율성 예측
  ///
  /// @param tileSizes: 타일 크기
  /// @return: 캐시 히트율 (0.0 ~ 1.0)
  double estimateCacheHitRate(ArrayRef<int64_t> tileSizes);

  /// Roofline 모델을 통한 성능 분석
  ///
  /// @param spec: 하드웨어 스펙
  /// @return: 달성 가능 FLOPS
  double getRooflinePerformance(const HardwareSpec& spec);
};
```

### **4.2 HardwareSpec 데이터 구조**

```cpp
struct HardwareSpec {
  // 계산 성능 (FLOPS)
  double peakFLOPS;

  // 메모리 대역폭 (GB/sec)
  double memoryBandwidth;

  // On-chip 메모리 크기 (bytes)
  int64_t sramSize;

  // 메모리 지연시간 (cycles)
  double memoryLatency;

  // 기타 파라미터
  int64_t cacheLineSize;      // Typical: 64 bytes
  int64_t l1CacheSize;        // L1$ 크기
  int64_t l2CacheSize;        // L2$ 크기
  double clockFrequencyGHz;    // CPU/GPU 클록속도

  // 생성자
  HardwareSpec(
    double peak = 0,
    double bw = 0,
    int64_t sram = 0,
    double lat = 0
  ) : peakFLOPS(peak),
      memoryBandwidth(bw),
      sramSize(sram),
      memoryLatency(lat) {}

  // 유틸리티: 알려진 하드웨어 프로필 로드
  static HardwareSpec getNvidiaH100();
  static HardwareSpec getIntelXeon();
  static HardwareSpec getAppleNeuralEngine();
};
```

