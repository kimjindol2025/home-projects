cmake_minimum_required(VERSION 3.20)
project(stochastic-code-optimizer
        VERSION 1.0.0
        DESCRIPTION "AI-Driven Automatic Code Optimization via Stochastic Search on MLIR"
        LANGUAGES CXX)

# C++ Standard
set(CMAKE_CXX_STANDARD 17)
set(CMAKE_CXX_STANDARD_REQUIRED ON)
set(CMAKE_CXX_FLAGS_RELEASE "-O3 -DNDEBUG")
set(CMAKE_CXX_FLAGS_DEBUG "-g -O0")

# ============================================================================
# Project Structure
# ============================================================================
set(PROJECT_ROOT ${CMAKE_CURRENT_SOURCE_DIR})
set(SRC_DIR ${PROJECT_ROOT}/src)
set(INCLUDE_DIR ${PROJECT_ROOT}/include)
set(BENCHMARK_DIR ${PROJECT_ROOT}/benchmarks)
set(TEST_DIR ${PROJECT_ROOT}/tests)
set(EVAL_DIR ${PROJECT_ROOT}/evaluation)

# ============================================================================
# Build Options
# ============================================================================
option(USE_LLVM "Build with LLVM/MLIR support (requires LLVM 17+)" OFF)
option(BUILD_TESTS "Build unit tests" ON)
option(BUILD_BENCHMARKS "Build benchmark suite" ON)
option(ENABLE_VERBOSE "Enable verbose logging" OFF)

# ============================================================================
# Compiler Flags
# ============================================================================
if(ENABLE_VERBOSE)
    add_compile_definitions(VERBOSE_LOG=1)
endif()

# ============================================================================
# LLVM/MLIR Configuration (Optional)
# ============================================================================
if(USE_LLVM)
    message(STATUS "🔍 Searching for LLVM/MLIR...")

    find_package(LLVM REQUIRED CONFIG)
    message(STATUS "Found LLVM ${LLVM_PACKAGE_VERSION}")
    message(STATUS "Using LLVMConfig.cmake in ${LLVM_DIR}")

    set(LLVM_RUNTIME_OUTPUT_INTDIR ${CMAKE_BINARY_DIR}/bin)
    set(LLVM_LIBRARY_OUTPUT_INTDIR ${CMAKE_BINARY_DIR}/lib)

    include_directories(${LLVM_INCLUDE_DIRS})
    add_definitions(${LLVM_DEFINITIONS})

    llvm_map_components_to_libnames(llvm_libs
        support core irreader passes)

    set(MLIR_LIBS
        MLIRDump
        MLIRPassManagerInterfaceImpl
        MLIRTransforms
        MLIRAnalysis
        MLIRLLVM
        MLIRLLVMCommonConversion
        MLIRCommonFolders
        MLIRInferTypeOpInterface
        MLIRAffine
        MLIRSCFToControlFlow
        MLIRMemRefTransforms
        MLIRMemRefToLLVM)

    message(STATUS "✅ LLVM/MLIR enabled (Full version with real MLIR support)")
    set(FULL_VERSION TRUE)
else()
    message(STATUS "⚠️  LLVM/MLIR disabled (Demo version with mock classes)")
    message(STATUS "    💡 Tip: cmake -DUSE_LLVM=ON for full version")
    set(FULL_VERSION FALSE)
endif()

# ============================================================================
# Source Files
# ============================================================================
if(FULL_VERSION)
    # Full version with LLVM/MLIR
    set(STOCHASTIC_OPT_SOURCES
        ${SRC_DIR}/stochastic_optimizer.cpp
        ${SRC_DIR}/ir_mutator.cpp
        ${SRC_DIR}/correctness_checker.cpp
        ${SRC_DIR}/performance_evaluator.cpp
        ${SRC_DIR}/main.cpp)
else()
    # Demo version without LLVM/MLIR
    set(STOCHASTIC_OPT_SOURCES
        ${SRC_DIR}/main_demo.cpp)
endif()

# ============================================================================
# Main Executable
# ============================================================================
add_executable(stochastic_optimizer ${STOCHASTIC_OPT_SOURCES})

target_include_directories(stochastic_optimizer
    PRIVATE ${INCLUDE_DIR})

if(FULL_VERSION)
    target_link_libraries(stochastic_optimizer
        ${llvm_libs}
        ${MLIR_LIBS})
endif()

# ============================================================================
# Testing
# ============================================================================
if(BUILD_TESTS)
    enable_testing()
    message(STATUS "✅ Testing enabled")

    # Unit tests
    add_executable(unit_tests
        ${TEST_DIR}/unit_tests.cpp)

    target_include_directories(unit_tests
        PRIVATE ${INCLUDE_DIR})

    if(FULL_VERSION)
        target_link_libraries(unit_tests
            ${llvm_libs}
            ${MLIR_LIBS})
    endif()

    add_test(NAME BasicTests
             COMMAND unit_tests)

    # Integration tests
    if(FULL_VERSION)
        add_executable(integration_tests
            ${TEST_DIR}/integration_tests.cpp)

        target_include_directories(integration_tests
            PRIVATE ${INCLUDE_DIR})

        target_link_libraries(integration_tests
            ${llvm_libs}
            ${MLIR_LIBS})

        add_test(NAME IntegrationTests
                 COMMAND integration_tests)
    endif()
else()
    message(STATUS "⏭️  Testing disabled")
endif()

# ============================================================================
# Benchmarks
# ============================================================================
if(BUILD_BENCHMARKS AND FULL_VERSION)
    message(STATUS "✅ Benchmark suite enabled")

    # Microbenchmarks
    file(GLOB BENCHMARK_FILES
        "${BENCHMARK_DIR}/microbenchmarks/*.cpp")

    foreach(bench_file ${BENCHMARK_FILES})
        get_filename_component(bench_name ${bench_file} NAME_WE)
        add_executable(benchmark_${bench_name} ${bench_file})

        target_include_directories(benchmark_${bench_name}
            PRIVATE ${INCLUDE_DIR})

        target_link_libraries(benchmark_${bench_name}
            ${llvm_libs}
            ${MLIR_LIBS})
    endforeach()
else()
    message(STATUS "⏭️  Benchmarks disabled (requires LLVM)")
endif()

# ============================================================================
# Installation
# ============================================================================
install(TARGETS stochastic_optimizer
        RUNTIME DESTINATION bin)

install(DIRECTORY ${INCLUDE_DIR}/
        DESTINATION include)

