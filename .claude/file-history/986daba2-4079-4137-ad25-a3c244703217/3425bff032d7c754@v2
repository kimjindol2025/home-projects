#ifndef MLIR_FORMAL_SEMANTICS_H
#define MLIR_FORMAL_SEMANTICS_H

#include "mlir/IR/Operation.h"
#include "mlir/IR/Value.h"
#include <string>
#include <vector>
#include <memory>

namespace mlir::formal {

using ::mlir::Operation;
using ::mlir::Value;

/// Base class for all formally defined entities
class FormalEntity {
protected:
  std::string name_;
  Operation* mlirOp_;

public:
  explicit FormalEntity(const std::string& name, Operation* op)
      : name_(name), mlirOp_(op) {}

  virtual ~FormalEntity() = default;

  /// Get human-readable semantic formula
  /// Example: "∀i,j,k: C[i,j] := A[i,k] × B[k,j] + C[i,j]"
  virtual std::string getSemantics() const = 0;

  /// Get SMT-LIB2 encoding
  virtual std::string getSMTFormula() const = 0;

  const std::string& getName() const { return name_; }
  Operation* getOperation() const { return mlirOp_; }
};

/// Semantics of tensor operations (linalg dialect)
class TensorSemantics : public FormalEntity {
public:
  explicit TensorSemantics(const std::string& name, Operation* op)
      : FormalEntity(name, op) {}

  std::string getSemantics() const override;
  std::string getSMTFormula() const override;

  // Specific methods for each operation
  std::string getMatMulSemantics() const;
  std::string getConv2DSemantics() const;
  std::string getAddSemantics() const;
};

/// Semantics of affine loops
class AffineSemantics : public FormalEntity {
private:
  std::vector<int64_t> lowerBounds_;
  std::vector<int64_t> upperBounds_;
  std::vector<int64_t> steps_;

public:
  explicit AffineSemantics(const std::string& name, Operation* op)
      : FormalEntity(name, op) {}

  std::string getSemantics() const override;
  std::string getSMTFormula() const override;

  std::string getIterationDomain() const;
  std::string getBodySemantics() const;
};

/// Memory reference semantics
class MemRefSemantics : public FormalEntity {
private:
  std::vector<int64_t> shape_;
  std::string elementType_;
  int64_t baseAddress_;

public:
  explicit MemRefSemantics(const std::string& name, Operation* op)
      : FormalEntity(name, op) {}

  std::string getSemantics() const override;
  std::string getSMTFormula() const override;

  bool canAliasWith(const MemRefSemantics& other) const;
};

} // namespace mlir::formal

#endif // MLIR_FORMAL_SEMANTICS_H
