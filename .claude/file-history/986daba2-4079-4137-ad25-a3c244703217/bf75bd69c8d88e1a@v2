/**
 * Performance Evaluator Implementation
 *
 * MLIR Operation의 성능을 측정하는 엔진
 *
 * 측정 방법:
 * 1. MLIR → LLVM IR 컴파일
 * 2. -O3 최적화 적용
 * 3. 실제 실행 시간 측정 (perf/std::chrono)
 * 4. 캐시 미스, 메모리 접근 등 분석
 */

#include "stochastic_optimizer.h"
#include "mlir/ExecutionEngine/ExecutionEngine.h"
#include "mlir/Target/LLVMIR.h"
#include "llvm/IR/LLVMContext.h"
#include "llvm/IR/Module.h"
#include "llvm/Support/TargetSelect.h"
#include "llvm/ExecutionEngine/ExecutionEngine.h"
#include "llvm/ExecutionEngine/GenericValue.h"

#include <chrono>
#include <cmath>
#include <algorithm>

namespace sco {

PerformanceEvaluator::PerformanceEvaluator(mlir::MLIRContext* ctx)
    : context(ctx) {
    llvm::InitializeNativeTarget();
    llvm::InitializeNativeTargetAsmPrinter();
}

// ============================================================================
// 메인 평가 함수
// ============================================================================

PerformanceMetrics PerformanceEvaluator::evaluate(mlir::Operation* op) {
    // 실제 벤치마크 실행
    return compileAndBenchmark(op);
}

// ============================================================================
// 성능 모델 기반 빠른 추정 (Phase 2에서 AI 모델 사용)
// ============================================================================

PerformanceMetrics PerformanceEvaluator::estimatePerformance(
    mlir::Operation* op) {
    // IR 분석을 통한 빠른 추정
    return analyzeFromIR(op);
}

// ============================================================================
// 캐시 미스 예측
//
// Roofline 모델을 간단히 구현:
// - 메모리 접근 패턴 분석
// - 재사용성 (reuse distance) 계산
// - L1/L2/L3 캐시 라인 추적
// ============================================================================

long PerformanceEvaluator::predictCacheMisses(mlir::Operation* op) {
    long misses = 0;

    // Operation 트리 순회하여 메모리 접근 분석
    op->walk([&](mlir::Operation* innerOp) {
        // MemRef load/store 연산 분석
        std::string opName = innerOp->getName().getStringRef().str();

        if (opName.find("memref.load") != std::string::npos ||
            opName.find("memref.store") != std::string::npos) {
            // 각 메모리 접근이 캐시 미스 가능성
            // 단순화: 10% 미스율 가정
            misses += 10;
        }
    });

    return misses;
}

// ============================================================================
// 컴파일 및 벤치마크
// ============================================================================

PerformanceMetrics PerformanceEvaluator::compileAndBenchmark(
    mlir::Operation* op) {

    PerformanceMetrics metrics;

    // Module 찾기
    auto module = llvm::dyn_cast<mlir::ModuleOp>(op);
    if (!module) {
        module = op->getParentOfType<mlir::ModuleOp>();
    }

    if (!module) {
        // 에러: Module 없음
        metrics.latency = 999999.0;
        return metrics;
    }

    // ExecutionEngine 생성
    auto maybeEngine = mlir::ExecutionEngine::create(module);
    if (!maybeEngine) {
        metrics.latency = 999999.0;
        return metrics;
    }

    auto& engine = maybeEngine.get();

    // 메인 함수 조회
    auto func = engine->lookupPacked("main");
    if (!func) {
        metrics.latency = 999999.0;
        return metrics;
    }

    // ===== 벤치마크 실행 =====
    // 10번 반복 실행하여 평균 계산 (워밍업 2회 포함)

    const int WARMUP_RUNS = 2;
    const int BENCHMARK_RUNS = 10;
    const int TOTAL_RUNS = WARMUP_RUNS + BENCHMARK_RUNS;

    std::vector<double> timings;
    timings.reserve(BENCHMARK_RUNS);

    std::vector<float> inputData(100);  // 100 floats
    for (int i = 0; i < 100; i++) {
        inputData[i] = static_cast<float>(i) / 100.0f;
    }

    float* inputPtr = inputData.data();
    float outputBuffer[100] = {0};
    float* outputPtr = outputBuffer;

    for (int run = 0; run < TOTAL_RUNS; run++) {
        auto start = std::chrono::high_resolution_clock::now();

        try {
            func(inputPtr, outputPtr);
        } catch (...) {
            // 실행 실패
            metrics.latency = 999999.0;
            return metrics;
        }

        auto end = std::chrono::high_resolution_clock::now();
        auto duration = std::chrono::duration<double, std::milli>(end - start);

        if (run >= WARMUP_RUNS) {
            timings.push_back(duration.count());
        }
    }

    // 평균 계산
    double avgLatency = 0.0;
    for (double t : timings) {
        avgLatency += t;
    }
    avgLatency /= timings.size();

    // 중앙값도 계산 (이상치 무시)
    std::sort(timings.begin(), timings.end());
    double medianLatency = timings[timings.size() / 2];

    // ===== 메트릭 계산 =====
    metrics.latency = avgLatency;
    metrics.throughput = 1000.0 / avgLatency;  // ops per second

    // 메모리 접근 추정
    metrics.memoryAccesses = 1000;  // 단순화

    // 캐시 미스 예측
    metrics.cacheMisses = predictCacheMisses(op);
    metrics.cacheHits = metrics.memoryAccesses - metrics.cacheMisses;

    // 에너지 추정 (간단한 모델)
    // Energy = (CPI * frequency) * power_per_cycle
    double estimatedCPI = 2.0;  // 사이클/명령어
    double frequency = 3.0e9;  // 3 GHz
    double powerPerCycle = 50;  // 50W (추정)
    double energy = estimatedCPI * (frequency / 1e9) * powerPerCycle;
    metrics.energyEstimate = energy * avgLatency / 1000.0;  // Joules

    // 코드 크기 추정 (명령어 수)
    int instructionCount = 0;
    op->walk([&](mlir::Operation* innerOp) {
        instructionCount++;  // 각 op를 1개 명령어로 간주 (단순화)
    });
    metrics.codeSize = instructionCount * 4;  // 평균 4 bytes/instruction

    return metrics;
}

// ============================================================================
// IR 분석 기반 빠른 추정
// ============================================================================

PerformanceMetrics PerformanceEvaluator::analyzeFromIR(
    mlir::Operation* op) {
    PerformanceMetrics metrics;

    // Operation 개수 세기
    int opCount = 0;
    int loopDepth = 0;
    int memoryOps = 0;

    op->walk([&](mlir::Operation* innerOp) {
        opCount++;

        // 루프 깊이 추정
        std::string opName = innerOp->getName().getStringRef().str();
        if (opName.find("affine.for") != std::string::npos ||
            opName.find("scf.for") != std::string::npos) {
            loopDepth++;
        }

        // 메모리 연산 수
        if (opName.find("memref") != std::string::npos) {
            memoryOps++;
        }
    });

    // 지연시간 추정 (단순 모델)
    // latency ≈ (opCount / IPC) / frequency
    // IPC = Instructions Per Cycle (2~4 가정)
    double estimatedIPC = 2.0;
    double latency = opCount / estimatedIPC;  // ms 단위 (단순화)
    metrics.latency = std::max(0.1, latency);

    metrics.throughput = 1000.0 / metrics.latency;
    metrics.memoryAccesses = memoryOps * 10;
    metrics.cacheHits = metrics.memoryAccesses / 2;  // 50% 히트율 가정
    metrics.cacheMisses = metrics.memoryAccesses - metrics.cacheHits;
    metrics.codeSize = opCount * 4;
    metrics.energyEstimate = metrics.latency * 50 / 1000.0;

    return metrics;
}

}  // namespace sco

// ============================================================================
// PerformanceMetrics 출력
// ============================================================================

void PerformanceMetrics::print() const {
    llvm::outs() << "╔════════════════════════════════════════╗\n";
    llvm::outs() << "║     Performance Metrics               ║\n";
    llvm::outs() << "╠════════════════════════════════════════╣\n";
    llvm::outs() << "║ Latency:        " << std::fixed << std::setprecision(3)
                 << latency << " ms\n";
    llvm::outs() << "║ Throughput:     " << throughput << " ops/ms\n";
    llvm::outs() << "║ Memory Accesses:" << memoryAccesses << "\n";
    llvm::outs() << "║ Cache Hits:     " << cacheHits << "\n";
    llvm::outs() << "║ Cache Misses:   " << cacheMisses << "\n";
    llvm::outs() << "║ Energy:         " << energyEstimate << " J\n";
    llvm::outs() << "║ Code Size:      " << codeSize << " bytes\n";
    llvm::outs() << "║ Score:          " << getScore() << "\n";
    llvm::outs() << "╚════════════════════════════════════════╝\n";
}
