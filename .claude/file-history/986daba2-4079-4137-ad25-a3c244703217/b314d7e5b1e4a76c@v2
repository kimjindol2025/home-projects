#ifndef MLIR_ADAPTIVE_PROFILING_SYSTEM_H
#define MLIR_ADAPTIVE_PROFILING_SYSTEM_H

#include "mlir/Adaptive/HardwareAwareInterface.h"
#include <vector>
#include <string>
#include <map>
#include <cstdint>

namespace mlir {
namespace adaptive {

/// Optimization state representing a single compiler configuration
struct OptimizationState {
  // Tiling parameters: [t_1, t_2, ..., t_n]
  std::vector<int64_t> tileSizes;

  // Loop permutation: [π(0), π(1), ..., π(n-1)]
  std::vector<int> loopOrder;

  // SIMD vectorization width: {4, 8, 16, 32, 64}
  int vectorWidth;

  // Memory layout
  enum MemoryLayout {
    ROW_MAJOR = 0,
    COLUMN_MAJOR = 1,
    BLOCKED = 2
  } memoryLayout;

  // Data type
  enum DataType {
    FP32 = 0,
    FP16 = 1,
    INT8 = 2
  } dataType;

  // String representation for debugging
  std::string toString() const;

  // Hash for caching
  uint64_t hash() const;
};

/// Profiling result for a single state
struct ProfilingResult {
  OptimizationState state;

  // Ground truth measurements
  double executionTimeMs;  // Actual execution time
  double energyMJ;         // Energy consumption
  double memoryBandwidth;  // Memory bandwidth utilization (%)
  double cacheHitRate;     // Cache hit rate (0.0-1.0)

  // Reward signal
  double reward;           // Combined reward (multi-objective)

  // Metadata
  std::string hardware;
  std::string operation;
  int64_t timestamp;

  ProfilingResult() : executionTimeMs(0), energyMJ(0),
                      memoryBandwidth(0), cacheHitRate(0),
                      reward(0), timestamp(0) {}
};

/// Search space generator and filter
class SearchSpaceGenerator {
public:
  /// Generate all valid optimization states
  /// Apply hard constraints (SRAM, dimension bounds)
  std::vector<OptimizationState> generateSearchSpace(
      const std::vector<int64_t>& tensorShape,
      const HardwareSpec& hwSpec,
      bool applyDomainKnowledge = true);

  /// Apply soft constraints (preferences)
  void applySoftConstraints(
      std::vector<OptimizationState>& states,
      const HardwareSpec& hwSpec);

  /// Filter states by data type (TypeConverter)
  void filterByDataType(
      std::vector<OptimizationState>& states,
      OptimizationState::DataType preferredType);

private:
  /// Check if tiling respects SRAM constraint
  bool checkSRAMConstraint(
      const std::vector<int64_t>& tileSizes,
      int64_t sramSize,
      int numInputs = 3,  // Typical: A, B, C
      int elemSize = 4);  // FP32

  /// Generate all permutations respecting data dependencies
  std::vector<std::vector<int>> generateValidPermutations(
      int numDimensions);
};

/// Automated profiling pipeline
class AutomatedProfilingPipeline {
public:
  /// Profile a single optimization state
  /// Requires: MLIR code compiled, simulator/hardware ready
  ProfilingResult profileState(
      const OptimizationState& state,
      const HardwareSpec& hwSpec,
      const std::string& operationName);

  /// Batch profile multiple states
  std::vector<ProfilingResult> profileBatch(
      const std::vector<OptimizationState>& states,
      const HardwareSpec& hwSpec,
      const std::string& operationName,
      bool parallel = true);

  /// Save results to CSV
  void saveToCSV(
      const std::string& filename,
      const std::vector<ProfilingResult>& results);

  /// Load results from CSV
  std::vector<ProfilingResult> loadFromCSV(
      const std::string& filename);

private:
  /// Execute MLIR code and measure time
  double measureExecutionTime(
      const OptimizationState& state,
      const std::string& operationName);

  /// Estimate energy consumption
  double estimateEnergy(
      double executionTimeMs,
      const HardwareSpec& hwSpec);
};

/// Reward signal calculator (multi-objective)
class RewardCalculator {
public:
  /// Calculate reward for a profiling result
  /// Multi-objective: throughput + energy + fairness
  double calculateReward(
      const ProfilingResult& result,
      double weightThroughput = 0.5,
      double weightEnergy = 0.3,
      double weightFairness = 0.2);

  /// Apply penalties for constraint violations
  double applyPenalties(
      double baseReward,
      const ProfilingResult& result,
      const HardwareSpec& hwSpec);

private:
  double calculateThroughputReward(double executionTimeMs);
  double calculateEnergyReward(double energyMJ);
  double calculateFairnessReward(double cacheHitRate);
};

} // namespace adaptive
} // namespace mlir

#endif // MLIR_ADAPTIVE_PROFILING_SYSTEM_H
