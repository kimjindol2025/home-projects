/**
 * Advanced Neural Network Model Loader
 *
 * 고급 기능이 포함된 신경망:
 * - 배치 정규화 (Batch Normalization)
 * - 드롭아웃 (Dropout)
 * - 모멘텀 옵티마이저 (Momentum SGD)
 * - 적응형 학습률 (Adaptive Learning Rate)
 * - L2 정규화 (L2 Regularization)
 */

#ifndef ADVANCED_MODEL_LOADER_H
#define ADVANCED_MODEL_LOADER_H

#include <vector>
#include <string>
#include <cmath>
#include <algorithm>
#include <iostream>
#include <iomanip>

using namespace std;

/**
 * 배치 정규화 (Batch Normalization)
 */
class BatchNormLayer {
public:
    vector<double> gamma;  // 스케일
    vector<double> beta;   // 시프트
    vector<double> moving_mean;
    vector<double> moving_var;
    double momentum_bn = 0.99;
    double epsilon = 1e-5;

    BatchNormLayer(int size)
        : gamma(size, 1.0), beta(size, 0.0),
          moving_mean(size, 0.0), moving_var(size, 1.0) {}

    vector<double> forward(const vector<double>& x, bool training = false) {
        vector<double> normalized(x.size());

        if (training) {
            // 배치 통계
            double mean = 0;
            for (double val : x) mean += val;
            mean /= x.size();

            double var = 0;
            for (double val : x) var += (val - mean) * (val - mean);
            var /= x.size();

            // 정규화
            for (size_t i = 0; i < x.size(); i++) {
                double normalized_val = (x[i] - mean) / sqrt(var + epsilon);
                normalized[i] = gamma[i] * normalized_val + beta[i];
            }

            // 이동 평균 업데이트
            for (size_t i = 0; i < x.size(); i++) {
                moving_mean[i] = momentum_bn * moving_mean[i] + (1 - momentum_bn) * mean;
                moving_var[i] = momentum_bn * moving_var[i] + (1 - momentum_bn) * var;
            }
        } else {
            // 테스트: 이동 평균 사용
            for (size_t i = 0; i < x.size(); i++) {
                double normalized_val = (x[i] - moving_mean[i]) / sqrt(moving_var[i] + epsilon);
                normalized[i] = gamma[i] * normalized_val + beta[i];
            }
        }

        return normalized;
    }
};

/**
 * 드롭아웃 레이어 (Dropout)
 */
class DropoutLayer {
public:
    double rate;
    int seed;

    DropoutLayer(double rate = 0.2) : rate(rate), seed(42) {
        srand(seed);
    }

    vector<double> forward(const vector<double>& x, bool training = false) {
        vector<double> output = x;

        if (training && rate > 0) {
            double scale = 1.0 / (1.0 - rate);
            for (size_t i = 0; i < output.size(); i++) {
                if ((double)rand() / RAND_MAX < rate) {
                    output[i] = 0;
                } else {
                    output[i] *= scale;
                }
            }
        }

        return output;
    }
};

/**
 * 모멘텀 옵티마이저 (Momentum SGD)
 */
class MomentumOptimizer {
public:
    double learning_rate;
    double momentum;
    double l2_lambda;  // L2 정규화
    vector<vector<double>> velocity_w;
    vector<vector<double>> velocity_b;

    MomentumOptimizer(double lr = 0.01, double momentum = 0.9, double l2 = 0.0001)
        : learning_rate(lr), momentum(momentum), l2_lambda(l2) {}

    void initialize(size_t n_layers, const vector<int>& layer_sizes) {
        velocity_w.clear();
        velocity_b.clear();

        for (size_t i = 0; i < n_layers; i++) {
            velocity_w.push_back(vector<double>(layer_sizes[i] * layer_sizes[i + 1], 0.0));
            velocity_b.push_back(vector<double>(layer_sizes[i + 1], 0.0));
        }
    }

    void update(int layer_idx, vector<vector<double>>& W, vector<double>& b,
                const vector<double>& grad_w_flat, const vector<double>& grad_b) {
        // W 업데이트
        for (size_t i = 0; i < grad_w_flat.size(); i++) {
            double grad = grad_w_flat[i] + l2_lambda * W[i / W[0].size()][i % W[0].size()];
            velocity_w[layer_idx][i] = momentum * velocity_w[layer_idx][i] - learning_rate * grad;
            W[i / W[0].size()][i % W[0].size()] += velocity_w[layer_idx][i];
        }

        // b 업데이트
        for (size_t i = 0; i < grad_b.size(); i++) {
            velocity_b[layer_idx][i] = momentum * velocity_b[layer_idx][i] - learning_rate * grad_b[i];
            b[i] += velocity_b[layer_idx][i];
        }
    }
};

/**
 * 고급 신경망 (Advanced Neural Network)
 */
class AdvancedModelLoader {
private:
    vector<vector<vector<double>>> weights;
    vector<vector<double>> biases;
    vector<BatchNormLayer> batch_norms;
    vector<DropoutLayer> dropouts;
    MomentumOptimizer optimizer;

    bool loaded = false;

    // 정규화 파라미터
    vector<double> X_mean;
    vector<double> X_scale;
    vector<double> y_mean;
    vector<double> y_scale;

public:
    AdvancedModelLoader() : optimizer(0.01, 0.9, 0.0001) {}

    /**
     * 고급 모의 모델 생성
     */
    bool loadAdvancedMockModel() {
        cout << "📂 Loading advanced mock model...\n";

        // 더 깊고 복잡한 아키텍처
        // 12 → 256 → 128 → 64 → 5
        weights.clear();
        biases.clear();
        batch_norms.clear();
        dropouts.clear();

        vector<int> layer_sizes = {12, 256, 128, 64, 5};

        // 가중치 초기화 (He 초기화)
        srand(42);
        for (size_t i = 0; i < layer_sizes.size() - 1; i++) {
            int in = layer_sizes[i];
            int out = layer_sizes[i + 1];

            auto layer_w = vector<vector<double>>(in, vector<double>(out));
            auto layer_b = vector<double>(out);

            // He 초기화: sqrt(2 / in)
            double he_scale = sqrt(2.0 / in);
            for (int j = 0; j < in; j++) {
                for (int k = 0; k < out; k++) {
                    layer_w[j][k] = ((double)rand() / RAND_MAX - 0.5) * he_scale;
                }
            }

            for (int j = 0; j < out; j++) {
                layer_b[j] = ((double)rand() / RAND_MAX - 0.5) * 0.01;
            }

            weights.push_back(layer_w);
            biases.push_back(layer_b);

            // 배치 정규화 (숨겨진 레이어에만)
            if (i < layer_sizes.size() - 2) {
                batch_norms.push_back(BatchNormLayer(out));
            }

            // 드롭아웃
            dropouts.push_back(DropoutLayer(0.2));
        }

        optimizer.initialize(layer_sizes.size() - 1, layer_sizes);

        // 정규화 파라미터
        X_mean.assign(12, 0.0);
        X_scale.assign(12, 1.0);
        y_mean.assign(5, 1.1);
        y_scale.assign(5, 0.1);

        loaded = true;
        cout << "✅ Advanced model loaded\n";
        printInfo();

        return true;
    }

    /**
     * 모델 정보 출력
     */
    void printInfo() {
        cout << "\n🧠 Advanced Model Architecture:\n";
        cout << "  Layer Structure:\n";
        cout << "    Input:  12D (code features)\n";
        cout << "    Hidden 1: 256 neurons + BatchNorm + ReLU + Dropout(0.2)\n";
        cout << "    Hidden 2: 128 neurons + BatchNorm + ReLU + Dropout(0.2)\n";
        cout << "    Hidden 3: 64 neurons + ReLU + Dropout(0.2)\n";
        cout << "    Output:  5D (mutation speedups)\n";

        cout << "\n  Features:\n";
        cout << "    ✓ He Weight Initialization\n";
        cout << "    ✓ Batch Normalization\n";
        cout << "    ✓ Dropout (p=0.2)\n";
        cout << "    ✓ Momentum SGD (beta=0.9)\n";
        cout << "    ✓ L2 Regularization (lambda=0.0001)\n";

        // 파라미터 개수
        int total_params = 0;
        for (const auto& w : weights) {
            total_params += w.size() * w[0].size();
        }
        cout << "\n  Parameters: " << total_params << " weights\n";
    }

    /**
     * 추론 (예측)
     */
    vector<double> predict(const vector<double>& input, bool training = false) {
        if (!loaded) {
            throw runtime_error("Model not loaded");
        }

        if (input.size() != 12) {
            throw runtime_error("Input size must be 12");
        }

        // 입력 정규화
        vector<double> X_normalized = input;
        for (size_t i = 0; i < X_normalized.size(); i++) {
            X_normalized[i] = (X_normalized[i] - X_mean[i]) / (X_scale[i] + 1e-8);
        }

        // 순전파
        vector<double> A = X_normalized;

        for (size_t i = 0; i < weights.size(); i++) {
            // 선형 변환
            vector<double> Z(biases[i].size());
            for (size_t j = 0; j < biases[i].size(); j++) {
                Z[j] = biases[i][j];
                for (size_t k = 0; k < A.size(); k++) {
                    Z[j] += A[k] * weights[i][k][j];
                }
            }

            // 활성화 (마지막 레이어 제외)
            if (i < weights.size() - 1) {
                // 배치 정규화
                A = batch_norms[i].forward(Z, training);

                // ReLU
                for (double& val : A) {
                    val = max(0.0, val);
                }

                // 드롭아웃
                A = dropouts[i].forward(A, training);
            } else {
                A = Z;
            }
        }

        // 출력 역정규화
        vector<double> y_pred = A;
        for (size_t i = 0; i < y_pred.size(); i++) {
            y_pred[i] = y_pred[i] * y_scale[i] + y_mean[i];
        }

        // 성능은 1.0 이상 유지
        for (double& val : y_pred) {
            val = max(1.0, min(2.0, val));
        }

        return y_pred;
    }

    /**
     * 배치 추론
     */
    vector<vector<double>> predictBatch(const vector<vector<double>>& inputs,
                                       bool training = false) {
        vector<vector<double>> predictions;
        for (const auto& input : inputs) {
            predictions.push_back(predict(input, training));
        }
        return predictions;
    }

    /**
     * 최우수 변형 추천
     */
    int recommendMutation(const vector<double>& input) {
        auto predictions = predict(input, false);

        int best_idx = 0;
        double best_speedup = predictions[0];

        for (int i = 1; i < (int)predictions.size(); i++) {
            if (predictions[i] > best_speedup) {
                best_speedup = predictions[i];
                best_idx = i;
            }
        }

        return best_idx;
    }

    /**
     * 모델이 로드되었는지 확인
     */
    bool isLoaded() const {
        return loaded;
    }

    /**
     * 레이어 개수
     */
    size_t getNumLayers() const {
        return weights.size();
    }
};

#endif  // ADVANCED_MODEL_LOADER_H
