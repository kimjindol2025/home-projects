class InferenceEngine:
    def __init__(self, checkpoint_path, device='cpu'):
        self.policy_net = PolicyNetwork()
        self.value_net = ValueNetwork()

        checkpoint = torch.load(checkpoint_path, map_location=device)
        self.policy_net.load_state_dict(checkpoint['policy_state'])
        self.value_net.load_state_dict(checkpoint['value_state'])
        self.hyperparams = checkpoint['hyperparameters']

        self.policy_net.eval()  # 평가 모드
        self.value_net.eval()
        self.device = device

    def infer(self, state):
        """
        상태를 받아 최적 행동 선택 (그래디언트 X)
        """
        with torch.no_grad():
            state_tensor = torch.FloatTensor(state).to(self.device)
            logits, probs = self.policy_net(state_tensor)
            action = torch.argmax(probs).item()
            return action
```

