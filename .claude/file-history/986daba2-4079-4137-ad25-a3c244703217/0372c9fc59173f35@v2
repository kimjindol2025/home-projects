/**
 * Level 1: 초등학생도 이해하는 변수
 *
 * 학습 목표:
 * - 변수의 개념 이해 (값을 저장하는 상자)
 * - 숫자와 텍스트 다루기
 * - 간단한 계산하기
 *
 * 난이도: ⭐ (가장 쉬움)
 */

fun main() {
    println("╔══════════════════════════════════════════════╗")
    println("║  Level 1: 초등학생도 이해하는 변수             ║")
    println("╚══════════════════════════════════════════════╝\n")

    // 📚 개념 1: 변수 = 상자에 값을 저장하는 것
    println("📌 개념 1: 변수와 저장")
    println("-".repeat(40))

    val myAge = 10              // 내 나이를 저장 (상자에 10을 넣음)
    val myName = "김철수"        // 내 이름을 저장
    val appleCount = 5          // 사과 개수

    println("안녕하세요, 저는 $myName 입니다")
    println("저는 $myAge 살 입니다")
    println("사과가 $appleCount 개 있습니다\n")

    // 📚 개념 2: 계산하기
    println("📌 개념 2: 계산하기")
    println("-".repeat(40))

    val totalApples = appleCount + 3    // 사과 3개를 더 받음
    println("원래 사과: $appleCount 개")
    println("새로 받은 사과: 3개")
    println("이제 사과는 $totalApples 개입니다\n")

    // 📚 개념 3: 변수 이름은 중요하다!
    println("📌 개념 3: 명확한 변수 이름")
    println("-".repeat(40))

    val candyInBag = 10        // 가방 안의 사탕
    val candyIAte = 3          // 내가 먹은 사탕
    val candyLeft = candyInBag - candyIAte  // 남은 사탕

    println("가방에 있던 사탕: $candyInBag 개")
    println("내가 먹은 사탕: $candyIAte 개")
    println("남은 사탕: $candyLeft 개\n")

    // 📚 개념 4: 다양한 타입의 값
    println("📌 개념 4: 다양한 종류의 값")
    println("-".repeat(40))

    val studentName = "이영희"      // 텍스트 (이름)
    val gradeLevel = 5             // 숫자 (학년)
    val height = 145.5             // 소수 (키)
    val isPassing = true           // 참/거짓

    println("이름: $studentName")
    println("학년: $gradeLevel 학년")
    println("키: $height cm")
    println("합격 여부: $isPassing\n")

    // 📚 개념 5: 계산해서 새로운 값 만들기
    println("📌 개념 5: 계산으로 새 값 만들기")
    println("-".repeat(40))

    val pencilCount = 7
    val penCount = 5
    val totalWritingTools = pencilCount + penCount

    println("연필: $pencilCount 개")
    println("펜: $penCount 개")
    println("필기구 총합: $totalWritingTools 개\n")

    val bookPrice = 12000
    val moneyIHave = 50000
    val moneyLeft = moneyIHave - bookPrice

    println("가진 돈: $moneyIHave 원")
    println("책 가격: $bookPrice 원")
    println("남은 돈: $moneyLeft 원\n")

    // 📚 개념 6: 나눗셈 (몫과 나머지)
    println("📌 개념 6: 나누기")
    println("-".repeat(40))

    val totalCandies = 20
    val childrenCount = 3
    val candiesPerChild = totalCandies / childrenCount  // 몫 (나눗셈)
    val candiesRemain = totalCandies % childrenCount    // 나머지

    println("사탕: $totalCandies 개")
    println("아이: $childrenCount 명")
    println("한 명당 $candiesPerChild 개씩")
    println("남은 사탕: $candiesRemain 개\n")

    // 📚 개념 7: 변수 이름 짓기 연습
    println("📌 개념 7: 좋은 변수 이름")
    println("-".repeat(40))

    // ❌ 나쁜 이름: a, b, x
    val a = 100      // 이게 뭐지?

    // ✅ 좋은 이름: 명확하고 설명적
    val studentScore = 100  // 아, 학생의 성적이군!

    println("좋은 변수 이름: studentScore = $studentScore")
    println("나쁜 변수 이름: a = $a")
    println("(같은 값이지만 이름이 의미를 전달합니다!)\n")

    // 📚 최종 요약
    println("╔══════════════════════════════════════════════╗")
    println("║  요약: 변수는 이름 있는 상자입니다!             ║")
    println("║  변수에 값을 저장하고,                        ║")
    println("║  계산하고, 필요할 때 꺼내서 사용합니다.        ║")
    println("╚══════════════════════════════════════════════╝")
}

