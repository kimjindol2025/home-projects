## 📝 사용 예제

### **예제 1: 기본 검색**
```javascript
const { KimSearchMini } = require('./kimsearch-mini');

const engine = new KimSearchMini();
const results = engine.search('function');

console.log(`찾음: ${results.count}개`);
results.results.forEach(r => {
  console.log(`${r.file}:${r.line} - ${r.content}`);
});
```

### **예제 2: Python 함수 검색**
```javascript
const results = engine.search('def ', {
  lang: 'py',
  limit: 5,
  sort: 'file'
});

results.results.forEach(r => {
  console.log(`${r.repo}/${r.file}:${r.line}`);
  console.log(`  ${r.content}`);
});
```

### **예제 3: 품질 필터**
```javascript
const results = engine.search('secure', {
  minQuality: 4,
  limit: 10
});

results.results.forEach(r => {
  console.log(`${r.file} - ${r.quality.status} ${r.quality.stars}⭐`);
});
```

### **예제 4: 캐시 활용**
```javascript
// 첫 검색 (캐시 miss)
const r1 = engine.search('test', {limit: 5});
console.log(`첫 검색: ${r1.cached}`);  // false
console.log(`시간: ${Date.now() - start}ms`);

// 동일한 검색 (캐시 hit)
const r2 = engine.search('test', {limit: 5});
console.log(`두 번째: ${r2.cached}`);  // true
console.log(`시간: ${Date.now() - start}ms`);  // <10ms
```

### **예제 5: 빠른 검색**
```javascript
const results = engine.quickSearch('api', 3);
// 품질 정보 없음, 더 빠름 (~50ms)

console.log(results.results.map(r => r.file).join('\n'));
```

### **예제 6: 통계 확인**
```javascript
// 여러 검색 수행
engine.search('function', {lang: 'js'});
engine.search('class', {lang: 'py'});
engine.search('struct', {lang: 'go'});

// 통계 확인
const stats = engine.getCacheStats();
console.log(`캐시 크기: ${stats.size}`);
console.log(`최근 검색: ${stats.keys.length}개`);
```

### **예제 7: 커스텀 경로**
```javascript
const engine = new KimSearchMini([
  '/home/user/projects/frontend',
  '/home/user/projects/backend'
]);

const results = engine.search('api');
// 이 2개 경로에서만 검색
```

### **예제 8: 프로그래밍 워크플로우**
```javascript
const { KimSearchMini } = require('./kimsearch-mini');

async function analyzeCode() {
  const engine = new KimSearchMini();

  // 1. 에러 처리 코드 찾기
  const errorHandling = engine.search('try|catch', {
    limit: 10
  });

  // 2. 보안 검토 코드만
  const secure = engine.search('validation', {
    minQuality: 4,
    limit: 5
  });

  // 3. JavaScript 클래스
  const classes = engine.search('class', {
    lang: 'js',
    limit: 20
  });

  // 4. 분석
  console.log(`에러 처리: ${errorHandling.count}개`);
  console.log(`보안 검증: ${secure.count}개`);
  console.log(`클래스: ${classes.count}개`);
}

analyzeCode();
```

