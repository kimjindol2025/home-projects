/**
 * Level 2: 초등학생도 이해하는 조건
 *
 * 학습 목표:
 * - if/else로 선택하기
 * - 참/거짓 판단
 * - 조건에 따라 다른 결과
 *
 * 난이도: ⭐ (가장 쉬움)
 */

fun main() {
    println("╔══════════════════════════════════════════════╗")
    println("║  Level 2: 초등학생도 이해하는 조건             ║")
    println("╚══════════════════════════════════════════════╝\n")

    // 📚 개념 1: 나이에 따라 다른 인사
    println("📌 개념 1: 조건에 따라 다르게 하기")
    println("-".repeat(40))

    val myAge = 10

    if (myAge < 13) {
        println("안녕! 나는 초등학생이야")
    } else {
        println("안녕! 나는 중학생이야")
    }
    println()

    // 📚 개념 2: 여러 조건 (점수 등급)
    println("📌 개념 2: 여러 가지 경우")
    println("-".repeat(40))

    val score = 85

    if (score >= 90) {
        println("A등급 - 훌륭해요! 🏆")
    } else if (score >= 80) {
        println("B등급 - 좋아요! 👍")
    } else if (score >= 70) {
        println("C등급 - 노력하세요 💪")
    } else {
        println("D등급 - 더 열심히! 📚")
    }
    println()

    // 📚 개념 3: 여러 점수 확인
    println("📌 개념 3: 같은 구조 반복 사용")
    println("-".repeat(40))

    val scores = listOf(95, 78, 82, 60, 88)

    for (s in scores) {
        val grade = when {
            s >= 90 -> "A"
            s >= 80 -> "B"
            s >= 70 -> "C"
            s >= 60 -> "D"
            else -> "F"
        }
        println("점수: $s → 등급: $grade")
    }
    println()

    // 📚 개념 4: 복합 조건 (그리고, 또는)
    println("📌 개념 4: 두 개 이상의 조건")
    println("-".repeat(40))

    val temperature = 28

    // &&: 그리고 (둘 다 참이어야 참)
    if (temperature > 25 && temperature < 30) {
        println("날씨가 쾌적합니다! ☀️")
    }

    // ||: 또는 (하나라도 참이면 참)
    if (temperature < 0 || temperature > 35) {
        println("외출을 조심하세요! ⚠️")
    }
    println()

    // 📚 개념 5: 실생활 예제 - 우산 필요 여부
    println("📌 개념 5: 실생활 예제")
    println("-".repeat(40))

    val humidity = 75    // 습도 (%)
    val temp = 12        // 온도 (°C)
    val isRaining = true // 비가 오고 있나?

    if (isRaining || (humidity > 70 && temp < 15)) {
        println("우산을 가져가세요! ☔")
    } else {
        println("우산은 필요 없어요! 🚶")
    }
    println()

    // 📚 개념 6: 참/거짓 반대로
    println("📌 개념 6: 반대 조건 (!)")
    println("-".repeat(40))

    val isHoliday = false

    if (!isHoliday) {  // !는 "아니"라는 뜻
        println("학교에 가야 합니다 📖")
    } else {
        println("놀 수 있어요! 🎮")
    }
    println()

    // 📚 개념 7: 숫자 비교 정리
    println("📌 개념 7: 비교 연산자 정리")
    println("-".repeat(40))

    val a = 10
    val b = 20

    println("$a == $b : ${a == b}  (같은가?)")
    println("$a != $b : ${a != b}  (다른가?)")
    println("$a < $b  : ${a < b}   (작은가?)")
    println("$a > $b  : ${a > b}   (큰가?)")
    println("$a <= $b : ${a <= b}  (작거나 같은가?)")
    println("$a >= $b : ${a >= b}  (크거나 같은가?)")
    println()

    // 📚 개념 8: 복합 조건 연습
    println("📌 개념 8: 복합 조건 예제")
    println("-".repeat(40))

    val age = 16
    val hasLicense = false

    if (age >= 18 && hasLicense) {
        println("자동차를 운전할 수 있어요 🚗")
    } else if (age >= 18) {
        println("나이는 충분하지만 면허가 필요해요")
    } else if (hasLicense) {
        println("면허는 있지만 나이가 부족해요")
    } else {
        println("자동차를 운전할 수 없어요")
    }
    println()

    // 📚 최종 요약
    println("╔══════════════════════════════════════════════╗")
    println("║  요약: 조건은 프로그램의 선택입니다!          ║")
    println("║  if/else로 상황에 맞게 다르게 행동합니다.    ║")
    println("╚══════════════════════════════════════════════╝")
}

