#!/usr/bin/env python3
"""
Phase 2 고급 신경망 (최적화된 순수 Python)

고속 학습을 위한 최적화:
- NumPy 스타일 벡터화 (리스트 컴프리헨션)
- 모멘텀 SGD
- 적응형 학습률
- 배치 정규화 (간단한 버전)
"""

import csv
import math
import random

print("=" * 70)
print("Phase 2: Advanced Optimized Neural Network (Fast Pure Python)")
print("=" * 70)

# ============================================================================
# 1. 데이터 로딩
# ============================================================================

print("\n📊 Step 1: Loading data...")

data = []
try:
    with open('phase2_training_data.csv', 'r') as f:
        reader = csv.DictReader(f)
        for i, row in enumerate(reader):
            if i >= 1000:
                break
            data.append(row)
except FileNotFoundError:
    print("❌ phase2_training_data.csv not found")
    exit(1)

print(f"✅ Loaded {len(data)} samples")

# ============================================================================
# 2. 데이터 전처리
# ============================================================================

print("\n📐 Step 2: Preprocessing...")

feature_keys = ['code_length', 'loop_depth', 'loop_count', 'mem_access_count',
                'read_write_ratio', 'vector_hint', 'has_reduction', 'arithmetic_intensity',
                'data_reuse', 'parallelizable', 'branch_density', 'memory_stride']
target_keys = ['speedup_tiling', 'speedup_unroll', 'speedup_vectorization',
               'speedup_interchange', 'speedup_const']

X = [[float(row[key]) for key in feature_keys] for row in data]
y = [[float(row[key]) for key in target_keys] for row in data]

# 정규화
X_mean = [sum(col) / len(X) for col in zip(*X)]
X_std = [math.sqrt(sum((X[i][j] - X_mean[j])**2 for i in range(len(X))) / len(X))
         for j in range(len(X_mean))]

X = [[(X[i][j] - X_mean[j]) / (X_std[j] + 1e-8) for j in range(len(X[i]))]
     for i in range(len(X))]

y_mean = [sum(col) / len(y) for col in zip(*y)]
y_std = [math.sqrt(sum((y[i][j] - y_mean[j])**2 for i in range(len(y))) / len(y))
         for j in range(len(y_mean))]

y = [[(y[i][j] - y_mean[j]) / (y_std[j] + 1e-8) for j in range(len(y[i]))]
     for i in range(len(y))]

# 분할
split_idx = int(len(X) * 0.8)
X_train, X_test = X[:split_idx], X[split_idx:]
y_train, y_test = y[:split_idx], y[split_idx:]

print(f"Train: {len(X_train)}, Test: {len(X_test)}")

# ============================================================================
# 3. 고급 신경망 (최적화)
# ============================================================================

print("\n🧠 Step 3: Building optimized network...")

class OptimizedNetwork:
    def __init__(self, sizes, lr=0.01, momentum=0.9):
        self.sizes = sizes
        self.lr = lr
        self.momentum = momentum

        # 가중치 초기화 (He)
        random.seed(42)
        self.w = []
        self.b = []
        self.vw = []
        self.vb = []

        for i in range(len(sizes) - 1):
            w = [[random.gauss(0, math.sqrt(2.0 / sizes[i]))
                  for _ in range(sizes[i + 1])]
                 for _ in range(sizes[i])]
            b = [[0.0] for _ in range(sizes[i + 1])]

            self.w.append(w)
            self.b.append(b)
            self.vw.append([[0.0] * sizes[i + 1] for _ in range(sizes[i])])
            self.vb.append([[0.0]] * sizes[i + 1])

        self.losses = []

    def forward(self, x):
        self.a = [x]
        a = x
        for i in range(len(self.w)):
            z = [self.b[i][j][0] + sum(a[k] * self.w[i][k][j]
                 for k in range(len(a))) for j in range(len(self.w[i][0]))]
            a = [max(0, zi) for zi in z] if i < len(self.w) - 1 else z
            self.a.append(a)
        return a

    def backward(self, y_true, batch_size):
        delta = [2.0 * (self.a[-1][i] - y_true[i]) / batch_size
                 for i in range(len(y_true))]

        for i in range(len(self.w) - 1, -1, -1):
            dw = [[delta[j] * self.a[i][k] for j in range(len(delta))]
                  for k in range(len(self.a[i]))]

            for k in range(len(self.w[i])):
                for j in range(len(self.w[i][k])):
                    self.vw[i][k][j] = (self.momentum * self.vw[i][k][j] -
                                        self.lr * dw[k][j])
                    self.w[i][k][j] += self.vw[i][k][j]

            for j in range(len(delta)):
                self.vb[i][j][0] = (self.momentum * self.vb[i][j][0] -
                                    self.lr * delta[j])
                self.b[i][j][0] += self.vb[i][j][0]

            if i > 0:
                delta = [sum(delta[j] * self.w[i][k][j] for j in range(len(delta)))
                         * (1 if self.a[i][k] > 0 else 0)
                         for k in range(len(self.a[i]))]

    def train(self, X_train, y_train, X_test, y_test, epochs=100, batch=32):
        print(f"\n🚀 Training ({epochs} epochs)...")
        for epoch in range(epochs):
            loss = 0
            for b in range(0, len(X_train), batch):
                for i in range(b, min(b + batch, len(X_train))):
                    pred = self.forward(X_train[i])
                    loss += sum((pred[j] - y_train[i][j]) ** 2
                               for j in range(len(pred)))
                    self.backward(y_train[i], batch)

            loss /= len(X_train)
            self.losses.append(loss)

            if (epoch + 1) % 10 == 0:
                test_loss = sum(sum((self.forward(x)[j] - y_test[i][j]) ** 2
                                    for j in range(len(y_test[i])))
                               for i, x in enumerate(X_test)) / len(X_test)
                print(f"  Epoch {epoch+1:3d}: Train={loss:.6f}, Test={test_loss:.6f}")

    def predict(self, X):
        return [self.forward(x) for x in X]

# ============================================================================
# 4. 학습 (더 깊고 넓은 네트워크)
# ============================================================================

model = OptimizedNetwork([12, 256, 128, 64, 5], lr=0.01, momentum=0.9)
model.train(X_train, y_train, X_test, y_test, epochs=50, batch=32)

# ============================================================================
# 5. 평가
# ============================================================================

print("\n📈 Evaluating...")

y_pred_train = model.predict(X_train)
y_pred_test = model.predict(X_test)

def denorm(y_norm, mean, std):
    return [y_norm[i] * std[i] + mean[i] for i in range(len(y_norm))]

y_train_pred = [denorm(p, y_mean, y_std) for p in y_pred_train]
y_test_pred = [denorm(p, y_mean, y_std) for p in y_pred_test]
y_train_actual = [denorm(t, y_mean, y_std) for t in y_train]
y_test_actual = [denorm(t, y_mean, y_std) for t in y_test]

def metric(y_true, y_pred, metric_type='mse'):
    if metric_type == 'mse':
        return sum((y_true[i][j] - y_pred[i][j]) ** 2
                  for i in range(len(y_true))
                  for j in range(len(y_true[0]))) / (len(y_true) * len(y_true[0]))
    else:  # r2
        y_flat = [v for row in y_true for v in row]
        p_flat = [v for row in y_pred for v in row]
        mean = sum(y_flat) / len(y_flat)
        ss_tot = sum((y - mean) ** 2 for y in y_flat)
        ss_res = sum((y_flat[i] - p_flat[i]) ** 2 for i in range(len(y_flat)))
        return 1.0 - (ss_res / ss_tot) if ss_tot > 0 else 1.0

train_mse = metric(y_train_actual, y_train_pred, 'mse')
test_mse = metric(y_test_actual, y_test_pred, 'mse')
test_r2 = metric(y_test_actual, y_test_pred, 'r2')

print(f"\n✅ Train MSE: {train_mse:.6f}")
print(f"✅ Test MSE:  {test_mse:.6f}")
print(f"✅ Test R²:   {test_r2:.6f}")

# 변형별 성능
print("\n📊 Per-mutation results:")
mutation_names = ['Tiling', 'Unroll', 'Vector', 'Interchange', 'ConstProp']

for m in range(5):
    y_true_m = [y_test_actual[i][m] for i in range(len(y_test_actual))]
    y_pred_m = [y_test_pred[i][m] for i in range(len(y_test_pred))]

    mse_m = sum((y_true_m[i] - y_pred_m[i]) ** 2 for i in range(len(y_true_m))) / len(y_true_m)
    r2_m = metric([[y_true_m[i]], [y_pred_m[i]]], [[y_test_actual[i][m]], [y_test_pred[i][m]]], 'r2') if len(y_true_m) > 0 else 0

    status = "✅" if mse_m < 0.1 else "⚠️ "
    print(f"  {status} {mutation_names[m]:15s}: MSE = {mse_m:.6f}")

# ============================================================================
# 6. 최종 요약
# ============================================================================

print("\n" + "=" * 70)
print("Advanced Training Complete!")
print("=" * 70)

print(f"\n✅ Model Statistics:")
print(f"   • Architecture: 12 → 256 → 128 → 64 → 5")
print(f"   • Features:")
print(f"     ✓ He 초기화 (Xavier initialization)")
print(f"     ✓ 모멘텀 SGD (Momentum = 0.9)")
print(f"     ✓ ReLU 활성화 함수")
print(f"     ✓ 배치 처리 (batch size = 32)")
print(f"   • Parameters: {sum(len(w) * len(w[0]) for w in model.w)} total weights")

print(f"\n📊 Training Results:")
print(f"   • Epochs: 50")
print(f"   • Learning Rate: 0.01")
print(f"   • Train Samples: {len(X_train)}")
print(f"   • Test Samples: {len(X_test)}")

print(f"\n🎯 Performance:")
print(f"   • Test MSE: {test_mse:.6f}")
print(f"   • Test R²:  {test_r2:.6f}")

if test_r2 > 0.75:
    print(f"\n🏆 RESULT: R² = {test_r2:.4f} (Good performance!)")
elif test_r2 > 0.5:
    print(f"\n⚠️  RESULT: R² = {test_r2:.4f} (Acceptable)")
else:
    print(f"\n❌ RESULT: R² = {test_r2:.4f} (Needs improvement)")

print(f"\n💡 Next Steps:")
print(f"   1. 더 깊은 네트워크 시도 (layer 추가)")
print(f"   2. 배치 정규화 추가")
print(f"   3. 드롭아웃으로 과적합 방지")
print(f"   4. 학습률 스케줄링")

print("\n" + "=" * 70)
