#ifndef MLIR_ADAPTIVE_TRANSFORM_GENERATOR_H
#define MLIR_ADAPTIVE_TRANSFORM_GENERATOR_H

#include "mlir/Adaptive/ProfilingSystem.h"
#include <string>
#include <vector>
#include <sstream>

namespace mlir {
namespace adaptive {

/// RL 에이전트의 행동을 MLIR Transform Dialect 코드로 변환
class TransformDialectGenerator {
public:
  /// AI 에이전트의 최적화 결정을 MLIR Transform 코드로 생성
  ///
  /// @param action 에이전트의 행동 (타일 크기, 루프 순서 등)
  /// @param operationName 최적화 대상 연산 (linalg.matmul, linalg.conv_2d, ...)
  /// @return Transform Dialect 스크립트 (MLIR 코드)
  ///
  /// Example output:
  ///   transform.sequence failures(propagate) {
  ///   ^bb0(%arg0: !pdl.operation):
  ///     %0 = transform.structured.match ops{["linalg.matmul"]} in %arg0
  ///     %1, %loops:3 = transform.structured.tile %0 [64, 64, 64]
  ///     %2 = transform.loop.interchange %loops#0, %loops#1
  ///     transform.structured.vectorize %1
  ///     transform.yield
  ///   }
  static std::string generateTransform(
      const OptimizationState& action,
      const std::string& operationName);

  /// Transform 스크립트에서 특정 부분만 생성 (모듈화)
  /// @param action 최적화 행동
  /// @return Tiling 명령어만 생성
  static std::string generateTilingCommand(
      const OptimizationState& action);

  /// Loop 순서 교환 명령어 생성
  static std::string generateLoopInterchangeCommand(
      const std::vector<int>& loopOrder);

  /// Vectorization 명령어 생성
  static std::string generateVectorizationCommand(
      int vectorWidth);

  /// Operation Fusion 명령어 생성
  static std::string generateFusionCommand();

  /// 생성된 Transform 코드의 유효성 검증
  ///
  /// @param transformCode MLIR Transform 스크립트
  /// @param operationName 대상 연산
  /// @return 유효한지 여부
  static bool validateTransform(
      const std::string& transformCode,
      const std::string& operationName);

  /// Transform을 MLIR 모듈에 주입 (실행)
  ///
  /// @param transformCode MLIR Transform 스크립트
  /// @param irModule 대상 MLIR 모듈
  /// @return 변환 성공 여부
  static bool applyTransform(
      const std::string& transformCode,
      ModuleOp irModule);

private:
  /// 타일 크기 벡터를 MLIR 문법으로 포맷팅
  static std::string formatTileSizes(
      const std::vector<int64_t>& tileSizes);

  /// 루프 인덱스를 MLIR 변수명으로 변환
  static std::string formatLoopVariable(int loopIndex);
};

/// Transform Dialect 코드의 메타데이터
struct TransformMetadata {
  std::string operationName;      // 대상 연산
  std::vector<int64_t> tileSizes;  // 타일 크기
  std::vector<int> loopOrder;      // 루프 순서
  int vectorWidth;                 // 벡터화 폭
  bool isFused;                    // Fusion 여부

  /// JSON 형식으로 메타데이터 직렬화
  std::string toJSON() const;
};

} // namespace adaptive
} // namespace mlir

#endif // MLIR_ADAPTIVE_TRANSFORM_GENERATOR_H
