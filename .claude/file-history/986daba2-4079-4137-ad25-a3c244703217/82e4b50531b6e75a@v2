/**
 * KimSearch Mini - Termux 최적화 검색엔진
 *
 * 특징:
 * - 450줄 경량 코드
 * - <100ms 검색 응답
 * - <20MB 메모리
 * - grep 네이티브 + 30초 캐시
 *
 * Author: Claude (Haiku 4.5)
 * Date: 2026-02-26
 */

const { execSync } = require('child_process');
const fs = require('fs');
const path = require('path');

class KimSearchMini {
  constructor(dataPath, qualityPath) {
    this.dataPath = dataPath;
    this.qualityPath = qualityPath;
    this.quality = new QualityManager(qualityPath);
    this.cache = new Cache(30000);  // 30초 TTL
  }

  /**
   * 메인 검색
   */
  search(query, options = {}) {
    // 1. 캐시 확인
    const cacheKey = this.getCacheKey(query, options);
    if (this.cache.has(cacheKey)) {
      const cached = this.cache.get(cacheKey);
      return { ...cached, cached: true };
    }

    // 2. grep 검색
    const results = this.grepSearch(query, {
      limit: options.limit || 10,
      lang: options.lang,
      type: options.type
    });

    // 3. 품질 정보 추가
    const enriched = results.map(r => ({
      ...r,
      quality: this.quality.getQuick(r.repo)
    }));

    // 4. 필터링
    const filtered = this.filter(enriched, options);

    // 5. 정렬
    const sorted = this.sort(filtered, options.sort);

    // 6. 캐싱
    this.cache.set(cacheKey, {
      query,
      results: sorted,
      count: sorted.length,
      cached: false,
      timestamp: new Date().toISOString()
    });

    return {
      query,
      results: sorted,
      count: sorted.length,
      cached: false,
      timestamp: new Date().toISOString()
    };
  }

  /**
   * 빠른 검색 (품질 정보 제외)
   */
  quickSearch(query, limit = 5) {
    const results = this.grepSearch(query, { limit });
    return {
      query,
      results,
      count: results.length,
      mode: 'quick'
    };
  }

  /**
   * grep 실행 (네이티브)
   */
  grepSearch(query, options = {}) {
    try {
      // 언어 확장자 필터
      let includes = '--include="*.{js,py,go,zig,ts,tsx,jsx,java,rb,php,swift,kt}"';
      if (options.lang) {
        const ext = this.getLangExt(options.lang);
        includes = `--include="*.${ext}"`;
      }

      const limit = options.limit || 10;
      const cmd = `grep -r "${this.escapeGrep(query)}" "${this.dataPath}" \
        ${includes} \
        -n --color=never 2>/dev/null | head -${limit}`;

      const output = execSync(cmd, {
        encoding: 'utf-8',
        stdio: ['pipe', 'pipe', 'ignore']
      });

      return this.parseGrepOutput(output);
    } catch (e) {
      return [];
    }
  }

  /**
   * grep 출력 파싱
   */
  parseGrepOutput(output) {
    return output
      .trim()
      .split('\n')
      .filter(line => line.length > 0)
      .map(line => {
        const match = line.match(/^(.+?):(\d+):(.*)$/);
        if (!match) return null;

        const [, filePath, lineNum, content] = match;
        const repoPath = filePath.replace(this.dataPath + '/', '');
        const repo = repoPath.split('/')[0];

        return {
          file: repoPath,
          repo: `kim/${repo}`,
          line: parseInt(lineNum),
          content: content.trim().substring(0, 100),  // 100자 이상 자르기
          fullPath: filePath
        };
      })
      .filter(Boolean);
  }

  /**
   * 필터링
   */
  filter(results, options = {}) {
    return results.filter(r => {
      // 별 필터
      if (options.stars && !options.stars.includes(r.quality?.stars)) {
        return false;
      }

      // 카테고리 필터
      if (options.category && r.quality?.category !== options.category) {
        return false;
      }

      // 최소 품질 필터
      if (options.minQuality && (r.quality?.stars || 0) < options.minQuality) {
        return false;
      }

      // 보안 검토 필터
      if (options.securityOnly && r.quality?.stars !== 2) {
        return false;
      }

      return true;
    });
  }

  /**
   * 정렬
   */
  sort(results, sortBy = 'relevance') {
    switch (sortBy) {
      case 'quality':
        return results.sort((a, b) => (b.quality?.stars || 0) - (a.quality?.stars || 0));
      case 'quality-asc':
        return results.sort((a, b) => (a.quality?.stars || 0) - (b.quality?.stars || 0));
      case 'file':
        return results.sort((a, b) => a.file.localeCompare(b.file));
      case 'line':
        return results.sort((a, b) => a.line - b.line);
      default:  // 'relevance'
        return results;
    }
  }

  /**
   * grep 검색어 이스케이프
   */
  escapeGrep(query) {
    return query.replace(/"/g, '\\"').replace(/\$/g, '\\$');
  }

  /**
   * 캐시 키 생성
   */
  getCacheKey(query, options) {
    const key = [
      query,
      options.lang || 'all',
      options.sort || 'relevance',
      options.limit || 10
    ].join('|');
    return Buffer.from(key).toString('base64');
  }

  /**
   * 언어별 확장자
   */
  getLangExt(lang) {
    const map = {
      'js': 'js',
      'javascript': 'js',
      'py': 'py',
      'python': 'py',
      'go': 'go',
      'golang': 'go',
      'zig': 'zig',
      'ts': 'ts',
      'typescript': 'ts',
      'tsx': 'tsx',
      'jsx': 'jsx',
      'java': 'java',
      'rb': 'rb',
      'ruby': 'rb',
      'php': 'php',
      'swift': 'swift',
      'kt': 'kt',
      'kotlin': 'kt'
    };
    return map[lang.toLowerCase()] || lang;
  }

  /**
   * 캐시 통계
   */
  getCacheStats() {
    return this.cache.stats();
  }

  /**
   * 캐시 초기화
   */
  clearCache() {
    this.cache.clear();
  }
}

/**
 * 로컬 캐시 (30초 TTL)
 */
class Cache {
  constructor(ttl = 30000) {
    this.ttl = ttl;
    this.cache = new Map();
    this.timers = new Map();
  }

  set(key, value) {
    // 기존 타이머 취소
    if (this.timers.has(key)) {
      clearTimeout(this.timers.get(key));
    }

    // 새로 설정
    this.cache.set(key, value);

    // TTL 타이머
    const timer = setTimeout(() => {
      this.cache.delete(key);
      this.timers.delete(key);
    }, this.ttl);

    this.timers.set(key, timer);
  }

  get(key) {
    return this.cache.get(key);
  }

  has(key) {
    return this.cache.has(key);
  }

  clear() {
    for (const timer of this.timers.values()) {
      clearTimeout(timer);
    }
    this.cache.clear();
    this.timers.clear();
  }

  stats() {
    return {
      size: this.cache.size,
      keys: Array.from(this.cache.keys()).slice(0, 5)
    };
  }
}

/**
 * 품질 매니저
 */
class QualityManager {
  constructor(qualityPath) {
    this.data = new Map();
    this.loadQuality(qualityPath);
  }

  loadQuality(qualityPath) {
    try {
      if (fs.existsSync(qualityPath)) {
        const content = fs.readFileSync(qualityPath, 'utf-8');
        const json = JSON.parse(content);

        if (Array.isArray(json)) {
          json.forEach(item => {
            this.data.set(item.repo, item);
          });
        }
      }
    } catch (e) {
      // 조용히 실패 - 평가 없이 계속 진행
    }
  }

  /**
   * 빠른 조회 (필수 정보만)
   */
  getQuick(repo) {
    const item = this.data.get(repo);
    if (!item) return null;

    return {
      stars: item.stars,
      status: this.getStatus(item.stars),
      category: item.category,
      issues: Array.isArray(item.issues) ? item.issues.length : 0,
      completion: item.completion || (item.stars * 20)
    };
  }

  /**
   * 상태 이모지
   */
  getStatus(stars) {
    const statuses = {
      5: '🟢',
      4: '🟡',
      3: '🟠',
      2: '🔴',
      1: '⛔'
    };
    return statuses[stars] || '⚪';
  }

  /**
   * 상태 텍스트
   */
  getStatusText(stars) {
    const texts = {
      5: 'PRODUCTION_READY',
      4: 'GOOD',
      3: 'AVERAGE',
      2: 'SECURITY_REVIEW',
      1: 'INCOMPLETE'
    };
    return texts[stars] || 'UNKNOWN';
  }
}

module.exports = { KimSearchMini, Cache, QualityManager };
