const QualityService = require('../quality-service');
const assert = require('assert');

let service;
let testCount = 0;
let passCount = 0;
let failCount = 0;

// 테스트 헬퍼
function test(name, fn) {
  testCount++;
  try {
    fn();
    console.log(`✅ Test ${testCount}: ${name}`);
    passCount++;
  } catch (e) {
    console.log(`❌ Test ${testCount}: ${name}`);
    console.log(`   Error: ${e.message}`);
    failCount++;
  }
}

// 초기화
console.log('🧪 Starting Quality Service Tests...\n');

// ===== 테스트 1: 평가 저장 =====
console.log('📝 Test Suite 1: Rate\n');

service = new QualityService(':memory:');

test('should rate a repository', () => {
  const result = service.rate(
    'kim/test-repo-1',
    5,
    'test',
    ['no issues'],
    [],
    '2026-03-07'
  );
  assert.strictEqual(result.stars, 5);
  assert.strictEqual(result.status, '🟢 PRODUCTION_READY');
  assert.strictEqual(result.completion, 100);
});

test('should reject invalid stars', () => {
  try {
    service.rate('kim/test-repo-2', 10, 'test');
    throw new Error('Should have thrown');
  } catch (e) {
    assert(e.message.includes('Invalid'));
  }
});

test('should handle missing repo', () => {
  try {
    service.rate(null, 3, 'test');
    throw new Error('Should have thrown');
  } catch (e) {
    assert(e.message.includes('Invalid'));
  }
});

// ===== 테스트 2: 목록 조회 =====
console.log('\n📋 Test Suite 2: List\n');

service.rate('kim/repo-5star', 5, 'lang');
service.rate('kim/repo-4star', 4, 'api');
service.rate('kim/repo-3star', 3, 'api');
service.rate('kim/repo-2star', 2, 'security');
service.rate('kim/repo-1star', 1, 'test');

test('should list all assessments', () => {
  const results = service.list();
  assert(results.length >= 5);
});

test('should filter by stars', () => {
  const results = service.list({ stars: [2] });
  assert(results.every(r => r.stars === 2));
  assert(results.length >= 1);
});

test('should filter by multiple stars', () => {
  const results = service.list({ stars: [4, 5] });
  assert(results.every(r => r.stars === 4 || r.stars === 5));
});

test('should filter by category', () => {
  const results = service.list({ category: 'api' });
  assert(results.every(r => r.category === 'api'));
});

test('should sort by stars descending', () => {
  const results = service.list({ sort: 'stars-desc' });
  for (let i = 1; i < results.length; i++) {
    assert(results[i - 1].stars >= results[i].stars);
  }
});

test('should search repositories', () => {
  const results = service.list({ search: '5star' });
  assert(results.length >= 1);
  assert(results[0].repo.includes('5star'));
});

// ===== 테스트 3: 단일 조회 =====
console.log('\n🔍 Test Suite 3: Get\n');

test('should get single assessment', () => {
  const result = service.get('kim/repo-5star');
  assert(result !== null);
  assert.strictEqual(result.stars, 5);
});

test('should return null for missing repo', () => {
  const result = service.get('kim/nonexistent');
  assert.strictEqual(result, null);
});

// ===== 테스트 4: 보안 검토 =====
console.log('\n🔴 Test Suite 4: Security Review\n');

test('should get security review', () => {
  const review = service.securityReview();
  assert('critical_count' in review);
  assert('urgent' in review);
  assert('on_hold' in review);
});

test('should identify urgent items (2 stars)', () => {
  const review = service.securityReview();
  assert(review.urgent.length >= 1);
  assert(review.urgent.every(r => r.stars === 2));
});

test('should identify on-hold items (1 star)', () => {
  const review = service.securityReview();
  assert(review.on_hold.length >= 1);
});

// ===== 테스트 5: 통계 =====
console.log('\n📊 Test Suite 5: Statistics\n');

test('should calculate total', () => {
  const stats = service.statistics();
  assert(stats.total >= 5);
});

test('should have by_stars breakdown', () => {
  const stats = service.statistics();
  assert('5' in stats.by_stars);
  assert('2' in stats.by_stars);
  assert(stats.by_stars['5'].count >= 1);
  assert(stats.by_stars['2'].count >= 1);
});

test('should have summary', () => {
  const stats = service.statistics();
  assert('production_ready' in stats.summary);
  assert('security_review' in stats.summary);
  assert('incomplete' in stats.summary);
  // 주의: 모든 카테고리의 합 확인
  const sum = Object.values(stats.by_stars).reduce((s, cat) => s + cat.count, 0);
  assert.strictEqual(stats.total, sum);
});

test('should group by category', () => {
  const stats = service.statistics();
  assert(Object.keys(stats.by_category).length >= 1);
  assert('api' in stats.by_category);
  assert(stats.by_category['api'].count >= 2);
});

// ===== 테스트 6: 삭제 =====
console.log('\n🗑️ Test Suite 6: Delete\n');

test('should delete assessment', () => {
  const result = service.delete('kim/repo-1star');
  assert.strictEqual(result, true);
  const check = service.get('kim/repo-1star');
  assert.strictEqual(check, null);
});

test('should return false for non-existent', () => {
  const result = service.delete('kim/nonexistent');
  assert.strictEqual(result, false);
});

// ===== 테스트 7: 상태 정의 =====
console.log('\n🟡 Test Suite 7: Status\n');

test('should return correct status for 5 stars', () => {
  assert.strictEqual(service.getStatus(5), '🟢 PRODUCTION_READY');
});

test('should return correct status for 2 stars', () => {
  assert.strictEqual(service.getStatus(2), '🔴 SECURITY_REVIEW');
});

test('should return correct status for 1 star', () => {
  assert.strictEqual(service.getStatus(1), '⛔ INCOMPLETE');
});

// ===== 최종 결과 =====
console.log(`
${'═'.repeat(60)}
📊 테스트 결과
${'═'.repeat(60)}
✅ 통과: ${passCount}
❌ 실패: ${failCount}
📝 총 테스트: ${testCount}
${'═'.repeat(60)}

${failCount === 0 ? '🎉 모든 테스트 통과!' : '⚠️ 일부 테스트 실패'}
`);

process.exit(failCount > 0 ? 1 : 0);
