#!/usr/bin/env python3
"""
오차 한계 계산기 (Error Bound Calculator)

테일러 급수와 수치 미분을 이용한 오차 상한 계산.
복잡한 함수의 오차를 정교하게 분석합니다.
"""

from dataclasses import dataclass
from typing import Callable, List, Tuple, Optional
import math
from abc import ABC, abstractmethod


@dataclass
class ErrorBound:
    """오차 한계"""
    absolute_error: float       # 절대 오차
    relative_error: float       # 상대 오차
    confidence_level: float     # 신뢰도 (0.0 ~ 1.0)
    description: str


class Function(ABC):
    """함수의 추상 기본 클래스"""

    @abstractmethod
    def evaluate(self, x: float) -> float:
        """함수값 f(x)"""
        pass

    @abstractmethod
    def derivative(self, x: float, order: int = 1) -> float:
        """도함수 f'(x), f''(x), ... """
        pass

    @abstractmethod
    def domain(self) -> Tuple[float, float]:
        """정의역 [min, max]"""
        pass


class ExponentialFunction(Function):
    """지수 함수 e^x"""

    def evaluate(self, x: float) -> float:
        return math.exp(x)

    def derivative(self, x: float, order: int = 1) -> float:
        # e^x의 모든 도함수는 e^x
        return math.exp(x)

    def domain(self) -> Tuple[float, float]:
        return (-float('inf'), float('inf'))


class LogarithmFunction(Function):
    """로그 함수 ln(x)"""

    def evaluate(self, x: float) -> float:
        return math.log(x)

    def derivative(self, x: float, order: int = 1) -> float:
        if order == 1:
            return 1.0 / x
        elif order == 2:
            return -1.0 / (x ** 2)
        else:
            # (-1)^(n+1) * (n-1)! / x^n
            return ((-1.0) ** (order + 1)) * math.factorial(order - 1) / (x ** order)

    def domain(self) -> Tuple[float, float]:
        return (0.0, float('inf'))


class SineFunction(Function):
    """사인 함수 sin(x)"""

    def evaluate(self, x: float) -> float:
        return math.sin(x)

    def derivative(self, x: float, order: int = 1) -> float:
        # sin의 도함수: sin, cos, -sin, -cos, sin, ...
        order = order % 4
        if order == 0:
            return math.sin(x)
        elif order == 1:
            return math.cos(x)
        elif order == 2:
            return -math.sin(x)
        else:  # order == 3
            return -math.cos(x)

    def domain(self) -> Tuple[float, float]:
        return (-float('inf'), float('inf'))


class ErrorBoundCalculator:
    """오차 한계 계산 엔진"""

    @staticmethod
    def taylor_approximation_error(func: Function,
                                   x: float,
                                   h: float,
                                   order: int = 1) -> Tuple[float, float]:
        """
        테일러 급수 근사의 오차 계산

        f(x+h) ≈ f(x) + h*f'(x) + h²/2!*f''(x) + ...

        order차 근사의 오차: |R_n(h)| ≤ |h^(n+1)/(n+1)!| * max(|f^(n+1)(ξ)|)
        (ξ는 x와 x+h 사이)

        Args:
            func: 함수
            x: 중심값
            h: 변위량
            order: 테일러 급수의 차수

        Returns:
            (근사값, 오차 한계)
        """
        approx = 0.0
        for k in range(order + 1):
            term = (h ** k / math.factorial(k)) * func.derivative(x, k)
            approx += term

        # 오차 한계: (n+1)차 도함수의 최댓값
        # 간단한 구현: x 근처에서 수치 미분으로 추정
        h_small = h * 1e-4
        d_upper = func.derivative(x + h_small, order + 1)
        d_lower = func.derivative(x - h_small, order + 1)
        max_derivative = max(abs(d_upper), abs(d_lower))

        error_bound = (abs(h) ** (order + 1) / math.factorial(order + 1)) * max_derivative

        return approx, error_bound

    @staticmethod
    def accumulated_rounding_error(operation_count: int,
                                   machine_epsilon: float,
                                   error_growth: str = "worst_case") -> float:
        """
        누적 반올림 오차

        Args:
            operation_count: 연산 횟수
            machine_epsilon: 기계 epsilon
            error_growth: "worst_case" (선형) or "statistical" (제곱근)

        Returns:
            상대 오차 한계
        """
        if error_growth == "worst_case":
            # δ ≤ n * ε / (1 - n*ε)
            if operation_count * machine_epsilon >= 1:
                return float('inf')
            return operation_count * machine_epsilon / (1 - operation_count * machine_epsilon)
        elif error_growth == "statistical":
            # δ ≤ √n * ε
            return math.sqrt(operation_count) * machine_epsilon
        else:
            raise ValueError(f"Unknown error_growth: {error_growth}")

    @staticmethod
    def cancellation_error(a: float, b: float,
                          precision_digits: int) -> float:
        """
        뺄셈 재앙 (Cancellation Catastrophe)

        a ≈ b인 경우, a - b 계산에서 유효 자리 손실

        Args:
            a, b: 피연산자
            precision_digits: 유효 자리 수

        Returns:
            손실된 유효 자리 수 추정
        """
        if a == b or (a + b) == 0:
            return precision_digits  # 모든 자리 손실

        relative_diff = abs((a - b) / (a + b))
        if relative_diff == 0:
            return precision_digits

        # log10(relative_diff) < 0이므로, 손실된 자리 ≈ -log10(relative_diff)
        digits_lost = max(0, -math.log10(relative_diff))

        return digits_lost

    @staticmethod
    def condition_number(func: Function, x: float,
                        h: float = 1e-6) -> float:
        """
        함수의 조건수 (Condition Number)

        κ = |x * f'(x) / f(x)| (상대 오차 증폭 계수)

        입력 오차가 δ일 때, 출력 오차는 약 κ*δ배

        Args:
            func: 함수
            x: 평가 지점
            h: 수치 미분 간격

        Returns:
            조건수 (작을수록 좋음)
        """
        f_x = func.evaluate(x)
        if f_x == 0:
            return float('inf')

        # 수치 미분으로 f'(x) 계산
        f_prime = (func.evaluate(x + h) - func.evaluate(x - h)) / (2 * h)

        if f_prime == 0:
            return 0.0

        kappa = abs(x * f_prime / f_x)
        return kappa

    @staticmethod
    def forward_error_analysis(func: Function,
                              x: float,
                              input_error: float) -> ErrorBound:
        """
        전향 오차 분석 (Forward Error Analysis)

        입력 오차 δx가 주어졌을 때, 출력 오차 δy 계산

        δy ≈ |f'(x)| * δx

        Args:
            func: 함수
            x: 입력값
            input_error: 입력 오차

        Returns:
            오차 한계
        """
        # 1차 근사: δy ≈ |f'(x)| * δx
        f_x = func.evaluate(x)
        h = input_error if input_error > 0 else 1e-6

        f_prime_approx = (func.evaluate(x + h) - func.evaluate(x - h)) / (2 * h)

        abs_error = abs(f_prime_approx) * input_error
        rel_error = abs_error / abs(f_x) if f_x != 0 else float('inf')

        return ErrorBound(
            absolute_error=abs_error,
            relative_error=rel_error,
            confidence_level=0.95,  # 1차 근사
            description=f"f'({x:.6g}) ≈ {f_prime_approx:.6g}, δx = {input_error:.6g}"
        )

    @staticmethod
    def backward_error_analysis(func: Function,
                               x: float,
                               computed_result: float,
                               true_result: float) -> ErrorBound:
        """
        역향 오차 분석 (Backward Error Analysis)

        계산된 결과 y_computed가 f(x + δx)와 같을 때, δx를 구함

        f(x + δx) = y_computed

        Args:
            func: 함수
            x: 입력값
            computed_result: 계산된 결과
            true_result: 정확한 결과

        Returns:
            입력 오차 (역향 오차)
        """
        output_error = abs(computed_result - true_result)

        # 역향 오차 ≈ δy / |f'(x)|
        h = 1e-6
        f_prime = (func.evaluate(x + h) - func.evaluate(x - h)) / (2 * h)

        if abs(f_prime) < 1e-15:
            backward_error = float('inf')
        else:
            backward_error = output_error / abs(f_prime)

        return ErrorBound(
            absolute_error=backward_error,
            relative_error=backward_error / abs(x) if x != 0 else float('inf'),
            confidence_level=0.90,
            description=f"Backward error: δx ≈ {backward_error:.6g}"
        )


# 사용 예제
if __name__ == "__main__":
    print("="*70)
    print("Error Bound Calculator Demo")
    print("="*70)

    calculator = ErrorBoundCalculator()

    # 예제 1: 테일러 근사 오차
    print("\n[Example 1] Taylor Approximation Error")
    print("-"*70)

    func = ExponentialFunction()
    x = 0.5
    h = 0.1

    for order in range(1, 4):
        approx, error_bound = calculator.taylor_approximation_error(func, x, h, order)
        true_val = func.evaluate(x + h)
        actual_error = abs(approx - true_val)

        print(f"Order {order}:")
        print(f"  Approximation: {approx:.8f}")
        print(f"  True value: {true_val:.8f}")
        print(f"  Actual error: {actual_error:.3e}")
        print(f"  Bound: {error_bound:.3e}")
        print(f"  Bound > Actual: {error_bound >= actual_error}")

    # 예제 2: 누적 오차
    print("\n[Example 2] Accumulated Rounding Error")
    print("-"*70)

    fp32_epsilon = 1.19e-7

    for n_ops in [100, 1000, 10000]:
        worst = calculator.accumulated_rounding_error(n_ops, fp32_epsilon, "worst_case")
        statistical = calculator.accumulated_rounding_error(n_ops, fp32_epsilon, "statistical")

        print(f"{n_ops} operations:")
        print(f"  Worst case: {worst:.3e}")
        print(f"  Statistical: {statistical:.3e}")

    # 예제 3: 조건수
    print("\n[Example 3] Condition Number")
    print("-"*70)

    functions = [
        ("exp(x)", ExponentialFunction()),
        ("log(x)", LogarithmFunction()),
        ("sin(x)", SineFunction()),
    ]

    for name, func in functions:
        x = 1.0
        kappa = calculator.condition_number(func, x)
        print(f"{name} at x={x}: κ = {kappa:.4f}")

    # 예제 4: 전향 오차
    print("\n[Example 4] Forward Error Analysis")
    print("-"*70)

    func = ExponentialFunction()
    x = 1.0
    input_error = 1e-6

    error_bound = calculator.forward_error_analysis(func, x, input_error)
    print(error_bound.description)
    print(f"Absolute error bound: {error_bound.absolute_error:.3e}")
    print(f"Relative error bound: {error_bound.relative_error:.3%}")

    print("\n" + "="*70)
    print("Error Bound Calculation Complete")
    print("="*70)
