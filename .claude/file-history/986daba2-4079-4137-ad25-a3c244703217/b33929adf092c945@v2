## 🔧 핵심 컴포넌트 설계

### **1️⃣ kimsearch-mini.js (200줄) - 검색 엔진**

```javascript
class KimSearchMini {
  constructor(dataPath, qualityPath) {
    this.dataPath = dataPath;
    this.qualityPath = qualityPath;
    this.quality = new QualityManager(qualityPath);
    this.cache = new Cache(30000);  // 30초 TTL
  }

  // 검색 (메인)
  search(query, options = {}) {
    // 1. 캐시 확인
    const cacheKey = this.getCacheKey(query, options);
    if (this.cache.has(cacheKey)) {
      return { ...this.cache.get(cacheKey), cached: true };
    }

    // 2. grep 검색
    const results = this.grepSearch(query, {
      limit: options.limit || 10,
      lang: options.lang,
      type: options.type
    });

    // 3. 품질 정보 추가
    const enriched = results.map(r => ({
      ...r,
      quality: this.quality.getQuick(r.repo)
    }));

    // 4. 필터링
    const filtered = this.filter(enriched, options);

    // 5. 정렬
    const sorted = this.sort(filtered, options.sort);

    // 6. 캐싱
    this.cache.set(cacheKey, { ...sorted, cached: false });

    return sorted;
  }

  // grep 실행 (네이티브)
  grepSearch(query, options) {
    const cmd = `grep -r "${query}" ${this.dataPath} \
      ${options.lang ? `--include="*.${this.getLangExt(options.lang)}"` : ''} \
      --include="*.{js,py,go,zig,ts,tsx,jsx}" \
      -n --color=never 2>/dev/null | head -${options.limit}`;

    // exec으로 실행 후 파싱
  }

  // 필터링
  filter(results, options) {
    return results.filter(r => {
      if (options.stars && !options.stars.includes(r.quality?.stars)) return false;
      if (options.category && r.quality?.category !== options.category) return false;
      if (options.minQuality && r.quality?.stars < options.minQuality) return false;
      return true;
    });
  }

  // 정렬
  sort(results, sortBy = 'relevance') {
    switch(sortBy) {
      case 'quality':
        return results.sort((a, b) => (b.quality?.stars || 0) - (a.quality?.stars || 0));
      case 'file':
        return results.sort((a, b) => a.file.localeCompare(b.file));
      default:  // 'relevance'
        return results;
    }
  }

  // 빠른 조회 (평가 없음)
  quickSearch(query, limit = 5) {
    return this.search(query, { limit, excludeQuality: true });
  }
}
```

