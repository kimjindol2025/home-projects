### **2️⃣ cli.js (150줄) - 명령어 인터페이스**

```javascript
const yargs = require('yargs');
const KimSearchMini = require('./kimsearch-mini');
const { formatResults, printStats } = require('./formatter');

const searchEngine = new KimSearchMini(
  process.env.KIMSEARCH_PATH || '/tmp/kimsearch-v2/repos-extract/kim',
  process.env.QUALITY_PATH || '/tmp/kimsearch-v2/quality-assessment.json'
);

yargs
  .command('search <query>', '코드 검색', (yargs) => {
    return yargs
      .positional('query', { describe: '검색어' })
      .option('limit', {
        alias: 'l',
        describe: '결과 개수',
        default: 10,
        type: 'number'
      })
      .option('lang', {
        alias: 'L',
        describe: '언어 필터 (js, py, go, zig)',
        type: 'string'
      })
      .option('stars', {
        alias: 's',
        describe: '별 필터 (5,4,3,2,1)',
        type: 'string'
      })
      .option('sort', {
        describe: '정렬 (relevance, quality, file)',
        default: 'relevance',
        type: 'string'
      })
      .option('color', {
        describe: '컬러 출력',
        default: true,
        type: 'boolean'
      })
  }, (argv) => {
    const results = searchEngine.search(argv.query, {
      limit: argv.limit,
      lang: argv.lang,
      stars: argv.stars ? argv.stars.split(',').map(Number) : undefined,
      sort: argv.sort
    });

    formatResults(results, { color: argv.color });
  })
  .command('quick <query>', '빠른 검색 (품질 정보 제외)', (yargs) => {
    // 옵션 없음, 최대한 빠름
  }, (argv) => {
    const results = searchEngine.quickSearch(argv.query, 5);
    formatResults(results, { minimal: true });
  })
  .command('stats', '통계', (yargs) => yargs, (argv) => {
    printStats();
  })
  .command('clear-cache', '캐시 삭제', (yargs) => yargs, (argv) => {
    searchEngine.cache.clear();
    console.log('✅ 캐시 삭제됨');
  })
  .demandCommand()
  .argv;
