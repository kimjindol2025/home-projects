### **4️⃣ quality.js (80줄) - 품질 매니저**

```javascript
class QualityManager {
  constructor(qualityPath) {
    this.data = new Map();
    this.loadQuality(qualityPath);
  }

  loadQuality(path) {
    try {
      const json = require(path);
      if (Array.isArray(json)) {
        json.forEach(item => {
          this.data.set(item.repo, item);
        });
      }
    } catch (e) {
      console.warn('⚠️ Quality data not loaded');
    }
  }

  getQuick(repo) {
    const item = this.data.get(repo);
    if (!item) return null;

    // 필수 정보만 반환 (빠름)
    return {
      stars: item.stars,
      status: this.getStatus(item.stars),
      category: item.category,
      issues: item.issues?.length || 0
    };
  }

  getStatus(stars) {
    const statuses = {
      5: '🟢',
      4: '🟡',
      3: '🟠',
      2: '🔴',
      1: '⛔'
    };
    return statuses[stars] || '⚪';
  }
}
```

