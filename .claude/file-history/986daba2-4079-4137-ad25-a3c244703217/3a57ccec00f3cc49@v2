#!/usr/bin/env python3
"""
Phase 3.2 통합 테스트: 자동 샤딩 및 데이터 파티셔닝

샤딩 차원, 통신 비용, 자동 최적화, Resharding, 계층적 통신 테스트
"""

from sharding_dimension_analyzer import (
    ShardingDimensionAnalyzer, ShardingDimension, TensorSpec
)
from communication_cost_model import CostModelAnalyzer
from auto_sharding_optimizer import AutoShardingOptimizer
from resharding_planner import ReshardingPlanner
from hierarchical_communication import (
    HierarchyDetector, HierarchicalAllReduceGenerator, HierarchicalCommunicationDAG
)


class Phase32IntegrationTest:
    """Phase 3.2 통합 테스트"""

    def __init__(self):
        self.tests_passed = 0
        self.tests_failed = 0

    def run_all_tests(self):
        """모든 테스트 실행"""
        print("=" * 80)
        print("Phase 3.2 자동 샤딩 및 데이터 파티셔닝 통합 테스트")
        print("=" * 80)

        self._test_sharding_dimension_analysis()
        self._test_communication_cost_model()
        self._test_auto_sharding_optimization()
        self._test_resharding_planning()
        self._test_hierarchical_communication()
        self._test_end_to_end_llama_7b()

        self._print_summary()

    def _test_sharding_dimension_analysis(self):
        """Test 1: 샤딩 차원 분석"""
        print("\n[Test 1] 샤딩 차원 분석 (Sharding Dimension Analysis)")
        print("-" * 80)

        try:
            analyzer = ShardingDimensionAnalyzer()

            # 샘플 텐서: Weight [4096, 12288]
            weight_tensor = TensorSpec(
                name="attention_weight",
                shape=(4096, 12288),
                dtype="float32"
            )

            num_devices = 8

            # 각 샤딩 차원 분석
            for dim in ShardingDimension:
                info = analyzer.analyze_tensor_sharding(
                    weight_tensor, num_devices, dim
                )

                comm_time = analyzer.estimate_communication_time_ms(
                    info, bandwidth_gbps=900.0, latency_us=1.0
                )

                print(f"\n{dim.value.upper()}:")
                print(f"  Local Memory: {info.local_memory_bytes / (1024**2):.2f} MB")
                print(f"  Communication: {info.communication_pattern.value}")
                print(f"  Est. Comm Time: {comm_time:.2f} ms")

            self._record_test("Sharding dimension analysis", True)
            print(f"\n✓ All sharding dimensions analyzed")

        except Exception as e:
            self._record_test("Sharding dimension analysis", False)
            print(f"✗ Error: {e}")

    def _test_communication_cost_model(self):
        """Test 2: 통신 비용 모델"""
        print("\n[Test 2] 통신 비용 모델 (Communication Cost Model)")
        print("-" * 80)

        try:
            cost_model = CostModelAnalyzer()

            # 8개 H100 설정
            for i in range(8):
                cost_model.set_device_capability(i, 1800.0)  # 1800 TFLOPS

            cost_model.set_network_capability(900.0, 1.0)  # NVLink

            # Transformer 레이어: [batch=32, seq=2048, hidden=12288]
            weight_shape = (12288, 12288)
            activation_shape = (32 * 2048, 12288)

            # 각 샤딩 전략의 비용 비교
            analysis = cost_model.cost_layer_with_all_strategies(
                "attention_layer",
                weight_shape,
                activation_shape,
                8
            )

            print(f"\nAttention Layer Cost Analysis:")
            for strategy, cost in analysis["strategies"].items():
                print(f"  {strategy.upper()}:")
                print(f"    Compute: {cost['compute_time_ms']:.2f} ms")
                print(f"    Communication: {cost['communication_time_ms']:.2f} ms")
                print(f"    Total: {cost['total_time_ms']:.2f} ms")

            self._record_test("Communication cost model", True)
            print(f"\n✓ Cost model analysis complete")

        except Exception as e:
            self._record_test("Communication cost model", False)
            print(f"✗ Error: {e}")

    def _test_auto_sharding_optimization(self):
        """Test 3: 자동 샤딩 최적화"""
        print("\n[Test 3] 자동 샤딩 최적화 (Auto Sharding)")
        print("-" * 80)

        try:
            cost_model = CostModelAnalyzer()
            for i in range(8):
                cost_model.set_device_capability(i, 1800.0)
            cost_model.set_network_capability(900.0, 1.0)

            optimizer = AutoShardingOptimizer(cost_model)

            # LLaMA 7B의 처음 4개 레이어
            layers = [
                ("layer_0", (12288, 12288), (32 * 2048, 12288)),
                ("layer_1", (12288, 12288), (32 * 2048, 12288)),
                ("layer_2", (12288, 12288), (32 * 2048, 12288)),
                ("layer_3", (12288, 12288), (32 * 2048, 12288)),
            ]

            # Greedy 최적화
            greedy_result = optimizer.optimize_fast(layers, 8, 80.0)

            print(f"\nGreedy Optimization Result:")
            for strategy in greedy_result:
                print(f"  {strategy.layer_name}: {strategy.sharding_type}")

            # DP 최적화
            dp_result = optimizer.optimize_medium(layers, 8, 80.0)

            print(f"\nDynamic Programming Result:")
            for strategy in dp_result:
                print(f"  {strategy.layer_name}: {strategy.sharding_type}")

            self._record_test("Auto sharding optimization", True)
            print(f"\n✓ Auto sharding optimization complete")

        except Exception as e:
            self._record_test("Auto sharding optimization", False)
            print(f"✗ Error: {e}")

    def _test_resharding_planning(self):
        """Test 4: Resharding 계획"""
        print("\n[Test 4] Resharding 계획 (Resharding Planning)")
        print("-" * 80)

        try:
            cost_model = CostModelAnalyzer()
            for i in range(8):
                cost_model.set_device_capability(i, 1800.0)
            cost_model.set_network_capability(900.0, 1.0)

            planner = ReshardingPlanner(cost_model)

            layers = ["layer_0", "layer_1", "layer_2", "layer_3"]
            sharding_sequence = ["replicate", "row_sharding", "column_sharding", "row_sharding"]

            # Resharding 지점 감지
            resharding_ops = planner.detect_resharding_points(
                layers, sharding_sequence
            )

            print(f"\nResharding Points Detected: {len(resharding_ops)}")
            for op in resharding_ops:
                print(f"  {op.from_layer} → {op.to_layer}")
                print(f"    {op.from_sharding} → {op.to_sharding}")
                print(f"    Comm Time: {op.communication_cost_ms:.2f} ms")

            # Resharding 최소화 전략
            optimized_sharding = planner.minimize_resharding_cost(
                layers, sharding_sequence
            )

            print(f"\nOptimized Sharding:")
            for layer, sharding in zip(layers, optimized_sharding):
                print(f"  {layer}: {sharding}")

            self._record_test("Resharding planning", True)
            print(f"\n✓ Resharding planning complete")

        except Exception as e:
            self._record_test("Resharding planning", False)
            print(f"✗ Error: {e}")

    def _test_hierarchical_communication(self):
        """Test 5: 계층적 통신"""
        print("\n[Test 5] 계층적 통신 (Hierarchical Communication)")
        print("-" * 80)

        try:
            # 계층 감지
            detector = HierarchyDetector()
            hierarchy = detector.detect_hierarchy_from_topology(
                8,  # 8 GPUs
                {
                    "intra_server_gbps": 2700.0,  # NVLink
                    "intra_latency_us": 0.5,
                    "inter_server_gbps": 100.0,  # Ethernet
                    "inter_latency_us": 100.0
                }
            )

            print(detector.report_hierarchy(hierarchy))

            # 계층적 AllReduce 생성
            generator = HierarchicalAllReduceGenerator()
            data_size = 1e9  # 1GB

            schedule = generator.generate_hierarchical_all_reduce(
                data_size, hierarchy
            )

            print(generator.report_hierarchical_schedule(schedule))

            # Flat vs Hierarchical 비교
            comparison = generator.compare_flat_vs_hierarchical(
                data_size, 8, 100.0
            )

            print(f"\nFlat Ring vs Hierarchical:")
            print(f"  Flat Ring Time: {comparison['flat_ring']['time_ms']:.2f} ms")
            print(f"  Hierarchical Time: {comparison['hierarchical']['time_ms']:.2f} ms")
            print(f"  Speedup: {comparison['speedup']:.2f}x")

            self._record_test("Hierarchical communication", True)
            print(f"\n✓ Hierarchical communication analysis complete")

        except Exception as e:
            self._record_test("Hierarchical communication", False)
            print(f"✗ Error: {e}")

    def _test_end_to_end_llama_7b(self):
        """Test 6: End-to-End LLaMA 7B 자동 샤딩"""
        print("\n[Test 6] End-to-End LLaMA 7B 자동 샤딩")
        print("-" * 80)

        try:
            print("\nScenario: LLaMA 7B on 8x H100 with Auto-Sharding\n")

            cost_model = CostModelAnalyzer()
            for i in range(8):
                cost_model.set_device_capability(i, 1800.0)
            cost_model.set_network_capability(900.0, 1.0)

            optimizer = AutoShardingOptimizer(cost_model)

            # LLaMA 7B의 모든 32개 Transformer 레이어
            layers = []
            for i in range(32):
                layers.append((
                    f"transformer_layer_{i}",
                    (4096, 12288),  # Attention weight shape
                    (32 * 2048, 4096)  # Activation shape
                ))

            print(f"Optimizing sharding for {len(layers)} layers...")

            # 자동 최적화 (DP)
            optimal_sharding = optimizer.optimize_medium(layers, 8, 80.0)

            # 통계 계산
            replicate_count = sum(1 for s in optimal_sharding if s.sharding_type == "replicate")
            row_count = sum(1 for s in optimal_sharding if s.sharding_type == "row_sharding")
            column_count = sum(1 for s in optimal_sharding if s.sharding_type == "column_sharding")

            print(f"\nOptimal Sharding Strategy:")
            print(f"  Replicate: {replicate_count} layers")
            print(f"  Row Sharding: {row_count} layers")
            print(f"  Column Sharding: {column_count} layers")

            # Resharding 계획
            sharding_sequence = [s.sharding_type for s in optimal_sharding]
            layer_names = [s.layer_name for s in optimal_sharding]

            planner = ReshardingPlanner(cost_model)
            resharding_ops = planner.detect_resharding_points(
                layer_names, sharding_sequence
            )

            print(f"\nResharding Points: {len(resharding_ops)}")

            # 계층적 통신 (AllReduce)
            detector = HierarchyDetector()
            hierarchy = detector.detect_hierarchy_from_topology(
                8, {"intra_server_gbps": 2700.0, "inter_server_gbps": 100.0}
            )

            generator = HierarchicalAllReduceGenerator()
            schedule = generator.generate_hierarchical_all_reduce(1e9, hierarchy)

            print(f"\nCommunication Optimization:")
            print(f"  AllReduce Time: {schedule.total_time_ms:.2f} ms (hierarchical)")

            # 성능 추정
            compute_time = 100.0  # ms per iteration (추정)
            resharding_time = sum(op.communication_cost_ms for op in resharding_ops)
            allreduce_time = schedule.total_time_ms

            total_time = compute_time + resharding_time + allreduce_time

            print(f"\nEstimated Performance:")
            print(f"  Compute Time: {compute_time:.2f} ms")
            print(f"  Resharding Time: {resharding_time:.2f} ms")
            print(f"  AllReduce Time: {allreduce_time:.2f} ms")
            print(f"  Total Iteration Time: {total_time:.2f} ms")

            self._record_test("End-to-end LLaMA 7B", True)
            print(f"\n✓ End-to-End LLaMA 7B auto-sharding test passed")

        except Exception as e:
            self._record_test("End-to-end LLaMA 7B", False)
            print(f"✗ Error: {e}")

    def _record_test(self, name: str, passed: bool):
        """테스트 결과 기록"""
        if passed:
            self.tests_passed += 1
        else:
            self.tests_failed += 1

    def _print_summary(self):
        """요약"""
        total = self.tests_passed + self.tests_failed
        print(f"\n{'=' * 80}")
        print(f"테스트 결과: {self.tests_passed}/{total} 통과")
        print(f"{'=' * 80}\n")


if __name__ == "__main__":
    tester = Phase32IntegrationTest()
    tester.run_all_tests()

