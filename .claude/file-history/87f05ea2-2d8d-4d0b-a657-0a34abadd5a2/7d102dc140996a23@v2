## 🎯 권고사항

### 1순위 (필수)

```c
// 1. kcommander_new 수정
kcommander_t* kcommander_new(void) {
    kcommander_t *cmd = (kcommander_t *)malloc(sizeof(kcommander_t));
    if (!cmd) return NULL;

    memset(cmd, 0, sizeof(kcommander_t));
    cmd->command_capacity = 10;
    cmd->commands = (kcommander_command_t *)malloc(cmd->command_capacity * sizeof(kcommander_command_t));

    if (!cmd->commands) {  // ✅ 추가
        free(cmd);
        return NULL;
    }

    return cmd;
}

// 2. kcommander_add_command realloc 수정
bool kcommander_add_command(kcommander_t *cmd, const char *name, const char *desc) {
    if (!cmd || !name) return false;

    if (cmd->command_count >= cmd->command_capacity) {
        cmd->command_capacity *= 2;
        kcommander_command_t *new_commands = (kcommander_command_t *)realloc(cmd->commands,
                                             cmd->command_capacity * sizeof(kcommander_command_t));

        if (!new_commands) {  // ✅ 추가
            cmd->command_capacity /= 2;  // 복구
            return false;
        }
        cmd->commands = new_commands;
    }

    // ... 나머지 코드 ...
}

// 3. kcommander_add_option realloc 수정
bool kcommander_add_option(...) {
    // ...
    if (target_cmd->option_count >= target_cmd->option_capacity) {
        target_cmd->option_capacity *= 2;
        kcommander_option_t *new_options = (kcommander_option_t *)realloc(target_cmd->options,
                                           target_cmd->option_capacity * sizeof(kcommander_option_t));

        if (!new_options) {  // ✅ 추가
            target_cmd->option_capacity /= 2;
            return false;
        }
        target_cmd->options = new_options;
    }
    // ...
}
```

