/*
 * Final-C Comprehensive Test Suite
 *
 * Test Coverage:
 * - Error handler registration
 * - Error handling and dispatch
 * - Error message lookup
 * - Error code extraction
 * - Multiple error codes
 * - Error message formatting
 * - Handler lifecycle
 * - NULL pointer handling
 */

#include "../kfinal.h"
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <assert.h>
#include <stdbool.h>

static int tests_passed = 0;
static int tests_failed = 0;
static int handler_called = 0;
static int last_error_code = 0;
static char last_error_msg[256] = "";

#define ASSERT(condition, message) \
    do { \
        if (!(condition)) { \
            printf("  ❌ FAILED: %s\n", message); \
            tests_failed++; \
        } else { \
            printf("  ✅ %s\n", message); \
            tests_passed++; \
        } \
    } while (0)

/* ==================== Error Handlers ==================== */

static void test_handler(int code, const char *msg) {
    handler_called++;
    last_error_code = code;
    if (msg) {
        strncpy(last_error_msg, msg, sizeof(last_error_msg) - 1);
        last_error_msg[sizeof(last_error_msg) - 1] = '\0';
    }
}

static void counting_handler(int code, const char *msg) {
    handler_called++;
}

/* ==================== Handler Registration ==================== */

void test_set_error_handler(void) {
    printf("\nTest: Set Error Handler\n");

    handler_called = 0;
    kfinal_set_handler(test_handler);

    ASSERT(true, "Handler registration completed");
}

void test_set_different_handlers(void) {
    printf("\nTest: Set Different Handlers\n");

    handler_called = 0;
    kfinal_set_handler(test_handler);
    ASSERT(handler_called == 0, "Callback not invoked on registration");

    handler_called = 0;
    kfinal_set_handler(counting_handler);
    ASSERT(handler_called == 0, "New handler registered");
}

void test_reset_handler(void) {
    printf("\nTest: Reset Handler\n");

    kfinal_set_handler(test_handler);
    kfinal_set_handler(NULL);

    ASSERT(true, "Handler reset to NULL");
}

/* ==================== Error Handling ==================== */

void test_handle_error_basic(void) {
    printf("\nTest: Handle Error - Basic\n");

    handler_called = 0;
    kfinal_set_handler(test_handler);

    kfinal_handle_error(1, "Test error");

    ASSERT(handler_called == 1, "Handler should be called");
    ASSERT(last_error_code == 1, "Error code should match");
    ASSERT(strlen(last_error_msg) > 0, "Error message should be set");
}

void test_handle_multiple_errors(void) {
    printf("\nTest: Handle Multiple Errors\n");

    handler_called = 0;
    kfinal_set_handler(counting_handler);

    kfinal_handle_error(1, "Error 1");
    kfinal_handle_error(2, "Error 2");
    kfinal_handle_error(3, "Error 3");

    ASSERT(handler_called == 3, "Handler called 3 times");
}

void test_handle_error_with_null_message(void) {
    printf("\nTest: Handle Error - NULL Message\n");

    handler_called = 0;
    kfinal_set_handler(test_handler);

    kfinal_handle_error(5, NULL);

    ASSERT(handler_called == 1, "Handler called with NULL message");
}

void test_handle_zero_code(void) {
    printf("\nTest: Handle Error - Code 0\n");

    handler_called = 0;
    kfinal_set_handler(counting_handler);

    kfinal_handle_error(0, "Success");

    ASSERT(handler_called == 1, "Handler called for code 0");
}

void test_handle_negative_code(void) {
    printf("\nTest: Handle Error - Negative Code\n");

    handler_called = 0;
    kfinal_set_handler(counting_handler);

    kfinal_handle_error(-1, "Negative error");

    ASSERT(handler_called == 1, "Handler called for negative code");
}

void test_handle_large_code(void) {
    printf("\nTest: Handle Error - Large Code\n");

    handler_called = 0;
    kfinal_set_handler(counting_handler);

    kfinal_handle_error(99999, "Large error code");

    ASSERT(handler_called == 1, "Handler called for large code");
}

