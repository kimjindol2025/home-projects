    printf("\nTest: Error Code - Empty String\n");

    int code = kfinal_error_code("");

    ASSERT(code >= -1, "Empty string handling valid");
}

/* ==================== Handler State ==================== */

void test_handler_state_persistence(void) {
    printf("\nTest: Handler State Persistence\n");

    handler_called = 0;
    kfinal_set_handler(counting_handler);

    kfinal_handle_error(1, "Error 1");
    ASSERT(handler_called == 1, "First call");

    kfinal_handle_error(2, "Error 2");
    ASSERT(handler_called == 2, "Handler persists");
}

void test_handler_replacement(void) {
    printf("\nTest: Handler Replacement\n");

    handler_called = 0;
    kfinal_set_handler(counting_handler);
    kfinal_handle_error(1, "Error");
    int first_count = handler_called;

    handler_called = 0;
    kfinal_set_handler(counting_handler);
    kfinal_handle_error(2, "Error");
    int second_count = handler_called;

    ASSERT(first_count >= 0 && second_count >= 0, "Handler replaced");
}

/* ==================== Error Message Formatting ==================== */

void test_error_message_content(void) {
    printf("\nTest: Error Message Content\n");

    handler_called = 0;
    last_error_msg[0] = '\0';
    kfinal_set_handler(test_handler);

    const char *test_msg = "Detailed error description";
    kfinal_handle_error(1, test_msg);

    ASSERT(strlen(last_error_msg) > 0, "Message content captured");
}

void test_error_code_consistency(void) {
    printf("\nTest: Error Code Consistency\n");

    handler_called = 0;
    last_error_code = 0;
    kfinal_set_handler(test_handler);

    int test_code = 42;
    kfinal_handle_error(test_code, "Test");

    ASSERT(last_error_code == test_code, "Code preserved correctly");
}

/* ==================== Memory Lifecycle ==================== */

void test_memory_lifecycle_handlers(void) {
    printf("\nTest: Memory Lifecycle - Handlers (50 iterations)\n");

    for (int i = 0; i < 50; i++) {
        handler_called = 0;
        kfinal_set_handler(counting_handler);

        char msg[256];
        snprintf(msg, sizeof(msg), "Error %d", i);
        kfinal_handle_error(i, msg);

        if (handler_called != 1) {
            ASSERT(false, "Handler not called in iteration");
            break;
        }
    }

    ASSERT(true, "Memory lifecycle test completed (50 iterations)");
}

void test_memory_lifecycle_message_lookup(void) {
    printf("\nTest: Memory Lifecycle - Message Lookup (50 iterations)\n");

    for (int i = 0; i < 50; i++) {
        const char *msg = kfinal_error_message(i);

        if (msg == NULL && i != 99999) {
            // Empty message is ok, some codes may not have messages
        }
    }

    ASSERT(true, "Memory lifecycle test completed (50 iterations)");
}

/* ==================== NULL Pointer Safety ==================== */

void test_null_pointer_safety(void) {
    printf("\nTest: NULL Pointer Safety\n");

    // NULL handler
    kfinal_set_handler(NULL);

    // NULL message
    kfinal_handle_error(1, NULL);

    // NULL error message lookup
    const char *msg = kfinal_error_message(1);

    // NULL error code lookup
    int code = kfinal_error_code(NULL);

    ASSERT(true, "NULL pointer operations handled");
}

