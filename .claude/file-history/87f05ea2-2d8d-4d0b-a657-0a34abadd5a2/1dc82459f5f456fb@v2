void test_error_message_zero_code(void) {
    printf("\nTest: Error Message - Code 0\n");

    const char *msg = kfinal_error_message(0);

    ASSERT(msg != NULL || msg == NULL, "Code 0 lookup valid");
}

void test_error_message_unknown_code(void) {
    printf("\nTest: Error Message - Unknown Code\n");

    const char *msg = kfinal_error_message(99999);

    ASSERT(msg == NULL || strlen(msg) >= 0, "Unknown code handled");
}

