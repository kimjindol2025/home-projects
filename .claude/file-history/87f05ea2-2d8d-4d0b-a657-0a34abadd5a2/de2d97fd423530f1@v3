  let url2 = "example.com"
  if validate_url_simple(url2) {
    println("OK: URL " + url2)
  } else {
    println("FAIL: URL " + url2)
  }

  println("")
  println("=== Regex Tests ===")
  println("")

  // Regex pattern tests
  let pattern1 = regex_test("[0-9]", "abc123")
