// FreeLang v6: Todo List Manager
// 파일 I/O + 배열 + 고차 함수

let todos_file = "todos.json"

fn load_todos() {
  if file_exists(todos_file) {
    return read_file(todos_file)
  }
  return "[]"
}

fn save_todos(todos) {
  write_file(todos_file, todos)
}

fn parse_todos(json_str) {
  let result = []
  // 간단한 파싱 (실제로는 JSON 파서 필요)
  return result
}

fn add_todo(text) {
  let todos = parse_todos(load_todos())
  push(todos, {
    id: timestamp(),
    text: text,
    done: false,
    created_at: now()
  })
  save_todos(toString(todos))
  return "✅ Todo added: " + text
}

fn list_todos() {
  let todos = parse_todos(load_todos())
  if length(todos) == 0 {
    return "📭 No todos yet!"
  }

  let output = "📝 Your Todos:\n"
  for todo in todos {
    let status = todo.done ? "✓" : "○"
    output = output + status + " " + todo.text + "\n"
  }
  return output
}

fn complete_todo(id) {
  let todos = parse_todos(load_todos())
  let updated = map(todos, fn(todo) {
    if todo.id == id {
      todo.done = true
    }
    return todo
  })
  save_todos(toString(updated))
  return "✅ Todo completed!"
}

// 메인 루프
fn main() {
  println("🚀 FreeLang Todo Manager")
  println("======================")
  println("")

  // 테스트 데이터
  add_todo("Learn FreeLang")
  add_todo("Build a project")
  add_todo("Deploy to production")

  println(list_todos())
  println("")
  println("💡 Todos automatically saved to todos.json")
}

main()
