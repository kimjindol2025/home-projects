int main(void) {
    printf("\n");
    printf("════════════════════════════════════════════════════════════════\n");
    printf("          Body-C (kbody) Comprehensive Test Suite\n");
    printf("════════════════════════════════════════════════════════════════\n");

    // Basic structure tests
    test_body_structure();
