void test_get_bool_default(void) {
    printf("\nTest: Get Bool - Default\n");

    kbody_t body;
    memset(&body, 0, sizeof(body));

    bool value = kbody_get_bool(&body, "missing", true);
    ASSERT(value == true, "Default bool returned");
