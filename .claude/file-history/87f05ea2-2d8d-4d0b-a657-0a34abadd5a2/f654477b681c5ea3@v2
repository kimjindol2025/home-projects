/* ==================== Memory Lifecycle ==================== */

void test_memory_lifecycle_struct_creation(void) {
    printf("\nTest: Memory Lifecycle - Struct Creation (50 iterations)\n");

    for (int i = 0; i < 50; i++) {
        kbody_t body;
        memset(&body, 0, sizeof(body));
        body.field_count = 0;
    }

    ASSERT(true, "Memory lifecycle test completed (50 iterations)");
}

void test_memory_lifecycle_field_setting(void) {
    printf("\nTest: Memory Lifecycle - Field Setting (50 iterations)\n");

    for (int i = 0; i < 50; i++) {
        kbody_t body;
        memset(&body, 0, sizeof(body));

        char key[256], value[256];
        snprintf(key, sizeof(key), "field_%d", i);
        snprintf(value, sizeof(value), "value_%d", i);

        strcpy(body.fields[0].key, key);
        strcpy(body.fields[0].value, value);
        body.field_count = 1;
    }

    ASSERT(true, "Memory lifecycle test completed (50 iterations)");
}

/* ==================== NULL Pointer Safety ==================== */

void test_null_pointer_safety(void) {
    printf("\nTest: NULL Pointer Safety\n");

    kbody_t body;
    memset(&body, 0, sizeof(body));

    // Test with NULL inputs
    const char *result = kbody_get(&body, NULL);
    ASSERT(result == NULL, "NULL key handled");

    bool has = kbody_has(&body, NULL);
    ASSERT(has == false, "NULL key has check handled");

    kbody_clear(&body);
    ASSERT(true, "NULL safe operations completed");
}

/* ==================== Content-Type Detection ==================== */

void test_content_type_json(void) {
    printf("\nTest: Content-Type - JSON\n");

    const char *ct = "application/json";
    ASSERT(strstr(ct, "json") != NULL, "JSON content type detectable");
}

void test_content_type_form(void) {
    printf("\nTest: Content-Type - Form\n");

    const char *ct = "application/x-www-form-urlencoded";
    ASSERT(strstr(ct, "form") != NULL, "Form content type detectable");
}

