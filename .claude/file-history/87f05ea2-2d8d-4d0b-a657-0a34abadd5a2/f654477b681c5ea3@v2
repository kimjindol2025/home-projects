    // Simple field operation tests
    test_manually_set_fields();
    test_multiple_manual_fields();

    // Validation tests
    test_json_validation_empty();
    test_json_validation_simple();
    test_form_validation_empty();
    test_form_validation_simple();

    // Type conversion tests
    test_get_int_default();
    test_get_bool_default();
    test_get_double_default();

    // Memory tests
    test_memory_lifecycle_struct_creation();
    test_memory_lifecycle_field_setting();

    // Safety tests
    test_null_pointer_safety();

    // Content-Type tests
    test_content_type_json();
    test_content_type_form();

    // Summary
    printf("\n");
    printf("════════════════════════════════════════════════════════════════\n");
    printf("Test Results: %d PASSED, %d FAILED\n", tests_passed, tests_failed);

    if (tests_failed == 0) {
        printf("✅ ALL TESTS PASSED!\n");
    } else {
        printf("❌ SOME TESTS FAILED!\n");
    }
    printf("════════════════════════════════════════════════════════════════\n\n");

