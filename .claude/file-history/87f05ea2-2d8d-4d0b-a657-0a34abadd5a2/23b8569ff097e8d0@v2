```bash
gcc -Wall -Wextra -O2 -std=c11 -pthread \
    -Iinclude \
    src/kuuid.c src/kuuid_hash.c src/kuuid_encoding.c \
    tests/test_kuuid_comprehensive.c \
    -o build/test_comprehensive
```

