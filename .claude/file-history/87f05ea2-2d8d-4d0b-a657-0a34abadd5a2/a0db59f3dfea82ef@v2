## 🎯 권고사항

### 즉시 필요 (높은 우선순위)

```c
// getaddrinfo() 사용으로 마이그레이션
#include <netdb.h>

kconnect_t* kconnect_create_modern(const char *host, const char *port) {
    kconnect_t *c = malloc(sizeof(*c));
    if (!c) return NULL;

    // DNS resolution (thread-safe)
    struct addrinfo hints = {0};
    hints.ai_family = AF_UNSPEC;        // IPv4/IPv6 모두
    hints.ai_socktype = SOCK_STREAM;

    struct addrinfo *result;
    int ret = getaddrinfo(host, port, &hints, &result);
    if (ret != 0) {
        free(c);
        return NULL;
    }

    // Try each address
    for (struct addrinfo *rp = result; rp != NULL; rp = rp->ai_next) {
        c->fd = socket(rp->ai_family, rp->ai_socktype, rp->ai_protocol);
        if (c->fd < 0) continue;

        if (connect(c->fd, rp->ai_addr, rp->ai_addrlen) == 0) {
            freeaddrinfo(result);
            return c;  // 연결 성공
        }

        close(c->fd);
    }

    freeaddrinfo(result);
    free(c);
    return NULL;  // 모든 연결 시도 실패
}
```

### 권장 (중간 우선순위)

```c
// 포트를 정수 대신 문자열로 받기 (더 유연함)
kconnect_t* kconnect_create(const char *host, const char *port);

// 또는 호환성 유지
kconnect_t* kconnect_create_compat(const char *host, int port) {
    char port_str[16];
    snprintf(port_str, sizeof(port_str), "%d", port);
    return kconnect_create(host, port_str);
}
```

