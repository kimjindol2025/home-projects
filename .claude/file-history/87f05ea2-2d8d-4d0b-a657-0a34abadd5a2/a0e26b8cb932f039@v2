## 🎯 권고사항

### 1순위 (권장)

```c
// 1. strtok() → strtok_r() 변경
int krange_parse(const char *range_header, krange_list_t *list) {
    if (!range_header || !list) return -1;

    memset(list, 0, sizeof(krange_list_t));

    char buffer[1024];
    strncpy(buffer, range_header, sizeof(buffer) - 1);
    buffer[sizeof(buffer) - 1] = '\0';

    trim_whitespace(buffer);

    char *equals = strchr(buffer, '=');
    if (!equals) return -1;

    *equals = '\0';
    list->unit = "bytes";

    char *unit = buffer;
    trim_whitespace(unit);

    if (strcmp(unit, "bytes") != 0) {
        return -1;
    }

    char *range_spec = equals + 1;
    char *saveptr;  // ✅ strtok_r 상태
    char *token = strtok_r(range_spec, ",", &saveptr);  // ✅ 변경

    while (token && list->count < KRANGE_MAX_RANGES) {
        // ... 기존 코드 ...
        token = strtok_r(NULL, ",", &saveptr);  // ✅ 변경
    }

    return list->count > 0 ? 0 : -1;
}

// 2. trim_whitespace 수정
static void trim_whitespace(char *str) {
    if (!str || !*str) return;  // ✅ 빈 문자열 체크

    char *start = str;
    while (*start && isspace(*start)) start++;

    size_t len = strlen(start);
    if (len == 0) {
        *str = '\0';  // ✅ 빈 결과
        return;
    }

    char *end = start + len - 1;
    while (end >= start && isspace(*end)) end--;  // >= 사용
    *(end + 1) = '\0';

    if (start != str) {
        memmove(str, start, strlen(start) + 1);
    }
}

// 3. Counter 경쟁 조건 수정
#include <pthread.h>

static pthread_mutex_t boundary_mutex = PTHREAD_MUTEX_INITIALIZER;
static int boundary_counter = 0;

int krange_generate_boundary(char *boundary) {
    if (!boundary) return -1;

    pthread_mutex_lock(&boundary_mutex);  // ✅ 보호
    int counter = boundary_counter++;
    pthread_mutex_unlock(&boundary_mutex);

    snprintf(boundary, 64, "KRANGE_BOUNDARY_%d_%ld",
             counter, (long)time(NULL));

    return 0;
}
```

