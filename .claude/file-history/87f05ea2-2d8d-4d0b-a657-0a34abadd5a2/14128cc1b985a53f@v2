/*
 * Test to verify fs-c API memory documentation
 * Demonstrates proper usage of malloc'd return values
 */

#include "kfs.h"
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

int main(void) {
    printf("\n=== fs-c API Memory Management Test ===\n\n");

    // Test 1: kfs_read_file
    printf("Test 1: kfs_read_file()\n");
    printf("  Creating test file...\n");
    kfs_write_file("/tmp/test_fs.txt", "Hello from fs-c!");

    char *content = kfs_read_file("/tmp/test_fs.txt");
    if (content) {
        printf("  ✓ Read: %s\n", content);
        printf("  ✓ Freeing malloc'd pointer...\n");
        free(content);  // MUST free - API requirement
        printf("  ✅ Memory freed correctly\n\n");
    } else {
        printf("  ❌ Failed to read file\n\n");
    }

    // Test 2: kfs_cwd
    printf("Test 2: kfs_cwd()\n");
    char *cwd = kfs_cwd();
    if (cwd) {
        printf("  ✓ Current directory: %s\n", cwd);
        printf("  ✓ Freeing malloc'd pointer...\n");
        free(cwd);  // MUST free - API requirement
        printf("  ✅ Memory freed correctly\n\n");
    } else {
        printf("  ❌ Failed to get cwd\n\n");
    }

    // Test 3: kfs_basename
    printf("Test 3: kfs_basename()\n");
    char *base = kfs_basename("/path/to/file.txt");
    if (base) {
        printf("  ✓ Basename: %s\n", base);
        printf("  ✓ Freeing malloc'd pointer...\n");
        free(base);  // MUST free - API requirement
        printf("  ✅ Memory freed correctly\n\n");
    }

    // Test 4: kfs_dirname
    printf("Test 4: kfs_dirname()\n");
    char *dir = kfs_dirname("/path/to/file.txt");
    if (dir) {
        printf("  ✓ Dirname: %s\n", dir);
        printf("  ✓ Freeing malloc'd pointer...\n");
        free(dir);  // MUST free - API requirement
        printf("  ✅ Memory freed correctly\n\n");
    }

    // Test 5: kfs_extname
    printf("Test 5: kfs_extname()\n");
    char *ext = kfs_extname("file.txt");
    if (ext) {
        printf("  ✓ Extension: %s\n", ext);
        printf("  ✓ Freeing malloc'd pointer...\n");
        free(ext);  // MUST free - API requirement
        printf("  ✅ Memory freed correctly\n\n");
    }

    // Test 6: kfs_join
    printf("Test 6: kfs_join()\n");
    char *joined = kfs_join("/path/to", "file.txt");
    if (joined) {
        printf("  ✓ Joined: %s\n", joined);
        printf("  ✓ Freeing malloc'd pointer...\n");
        free(joined);  // MUST free - API requirement
        printf("  ✅ Memory freed correctly\n\n");
    }

    // Test 7: kfs_normalize
    printf("Test 7: kfs_normalize()\n");
    char *normalized = kfs_normalize("./a/../b/./c");
    if (normalized) {
        printf("  ✓ Normalized: %s\n", normalized);
        printf("  ✓ Freeing malloc'd pointer...\n");
        free(normalized);  // MUST free - API requirement
        printf("  ✅ Memory freed correctly\n\n");
    }

    // Test 8: kfs_resolve
    printf("Test 8: kfs_resolve()\n");
    char *resolved = kfs_resolve("./test_fs.txt");
    if (resolved) {
        printf("  ✓ Resolved: %s\n", resolved);
        printf("  ✓ Freeing malloc'd pointer...\n");
        free(resolved);  // MUST free - API requirement
        printf("  ✅ Memory freed correctly\n\n");
    }

    // Cleanup
    kfs_remove_file("/tmp/test_fs.txt");

    printf("=== All API Memory Tests Passed ===\n");
    printf("\nKey Finding: All 8 functions that return malloc'd pointers");
    printf("\nrequire caller to call free() - this is now clearly documented in kfs.h\n\n");

    return 0;
}
