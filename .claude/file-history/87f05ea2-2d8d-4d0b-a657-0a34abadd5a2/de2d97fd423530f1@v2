// FreeLang v6: Data Validation Tool
// 정규표현식 + 검증 함수 활용

fn validate_email(email) {
  return is_email(email)
}

fn validate_phone(phone) {
  return is_phone(phone)
}

fn validate_url(url) {
  return is_url(url)
}

fn validate_password(pwd) {
  // 최소 8자, 대문자, 숫자 포함
  if str_len(pwd) < 8 {
    return false
  }

  let has_upper = regex_test("[A-Z]", pwd)
  let has_number = regex_test("[0-9]", pwd)
  let has_special = regex_test("[!@#$%^&*]", pwd)

  return has_upper and has_number
}

fn validate_username(user) {
  // 3-20자, 알파벳/숫자/언더스코어만
  if str_len(user) < 3 or str_len(user) > 20 {
    return false
  }

  return regex_test("^[a-zA-Z0-9_]+$", user)
}

fn validate_credit_card(cc) {
  // 16자 숫자
  let clean = regex_replace(cc, "-", "")
  return regex_test("^[0-9]{16}$", clean)
}

fn validate_record(record) {
  let errors = []

  if not validate_username(record.username) {
    push(errors, "❌ Username: 3-20 chars, alphanumeric and underscore only")
  }

  if not validate_email(record.email) {
    push(errors, "❌ Email: invalid format")
  }

  if not validate_phone(record.phone) {
    push(errors, "❌ Phone: invalid format")
  }

  if not validate_password(record.password) {
    push(errors, "❌ Password: min 8 chars, uppercase, number")
  }

  if has(record, "website") and not validate_url(record.website) {
    push(errors, "❌ Website: invalid URL")
  }

  return {
    valid: length(errors) == 0,
    errors: errors
  }
}

// 테스트
fn main() {
  println("📋 Data Validator Demo")
  println("======================\n")

  let test_data = {
    username: "john_doe",
    email: "john@example.com",
    phone: "+82-10-1234-5678",
    password: "SecurePass123",
    website: "https://example.com"
  }

  let result = validate_record(test_data)

  if result.valid {
    println("✅ All fields are valid!")
  } else {
    println("⚠️  Validation errors:")
    for error in result.errors {
      println(error)
    }
  }

  println("\n📊 Individual Tests:")
  println("  Email: " + (validate_email("test@test.com") ? "✅" : "❌"))
  println("  Phone: " + (validate_phone("+1-123-456-7890") ? "✅" : "❌"))
  println("  URL: " + (validate_url("https://google.com") ? "✅" : "❌"))
  println("  Username: " + (validate_username("user_123") ? "✅" : "❌"))
  println("  Password: " + (validate_password("MyPass123") ? "✅" : "❌"))
  println("  Credit Card: " + (validate_credit_card("1234-5678-9012-3456") ? "✅" : "❌"))
}

main()
