/*
 * Body-C Bug Fix Verification Tests
 *
 * Verifies that the following bugs are fixed:
 * 1. Stack overflow from large buffer allocation
 * 2. Buffer overflow from strcpy
 * 3. Memory leaks from missing free()
 */

#include "../kbody.h"
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <assert.h>
#include <stdbool.h>

static int tests_passed = 0;
static int tests_failed = 0;

#define ASSERT(condition, message) \
    do { \
        if (!(condition)) { \
            printf("  ❌ FAILED: %s\n", message); \
            tests_failed++; \
        } else { \
            printf("  ✅ %s\n", message); \
            tests_passed++; \
        } \
    } while (0)

/* ==================== Stack Overflow Protection ==================== */

void test_large_form_body(void) {
    printf("\nTest: Large Form Body (5MB)\n");

    // Create a large form body
    size_t large_size = 5 * 1024 * 1024;
    char *large_body = (char *)malloc(large_size);

    if (!large_body) {
        ASSERT(false, "Memory allocation for test data");
        return;
    }

    // Fill with form data
    memset(large_body, 'a', large_size);
    large_body[0] = 'k';
    large_body[1] = '=';
    large_body[2] = 'v';

    kbody_t body;
    memset(&body, 0, sizeof(body));

    // This should not cause stack overflow
    int result = kbody_parse("application/x-www-form-urlencoded",
                             large_body, large_size, &body);

    // Even if parsing fails, it shouldn't crash
    ASSERT(result >= -1, "Large body parsing completed without crash");

    free(large_body);
}

void test_max_body_size_boundary(void) {
    printf("\nTest: Max Body Size Boundary\n");

    // Create body at max size
    size_t max_size = 10 * 1024 * 1024;
    char *body_data = (char *)malloc(max_size);

    if (!body_data) {
        ASSERT(false, "Memory allocation for boundary test");
        return;
    }

    memset(body_data, 'x', max_size);
    body_data[0] = '{';
    body_data[max_size - 1] = '}';

    kbody_t body;
    memset(&body, 0, sizeof(body));

    // Should be rejected without crashing
    int result = kbody_parse("application/json", body_data, max_size, &body);

    ASSERT(result >= -1, "Boundary size handled safely");

    free(body_data);
}

/* ==================== Buffer Overflow Protection ==================== */

void test_long_error_messages(void) {
    printf("\nTest: Long Error Messages\n");

    kbody_t body;
    memset(&body, 0, sizeof(body));

    // Parse with unsupported content type (triggers error message)
    int result = kbody_parse("application/unsupported", "{}", 2, &body);

    ASSERT(result == -1, "Unsupported type rejected");
    ASSERT(body.error_msg[0] != '\0', "Error message set");
    ASSERT(strlen(body.error_msg) < sizeof(body.error_msg),
           "Error message within bounds");
}

void test_strcpy_replacement(void) {
    printf("\nTest: Safe String Copy (snprintf)\n");

    kbody_t body;
    memset(&body, 0, sizeof(body));

    // Call with empty body (triggers error)
    int result = kbody_parse("application/json", "", 0, &body);

    // Error message should be safely set
    ASSERT(body.error_msg[sizeof(body.error_msg) - 1] == '\0',
           "Error message null-terminated");
}

/* ==================== Memory Leak Detection ==================== */

void test_form_parsing_memory(void) {
    printf("\nTest: Form Parsing Memory Management\n");

    // Parse multiple form bodies to detect leaks
    const char *test_forms[] = {
        "name=John&age=30",
        "key1=val1&key2=val2&key3=val3",
        "a=1&b=2&c=3&d=4&e=5"
    };

    for (int i = 0; i < 3; i++) {
        kbody_t body;
        memset(&body, 0, sizeof(body));

        kbody_parse("application/x-www-form-urlencoded",
                   test_forms[i],
                   strlen(test_forms[i]),
                   &body);

        kbody_clear(&body);
    }

    ASSERT(true, "Form parsing memory freed without crash");
}

void test_json_parsing_memory(void) {
    printf("\nTest: JSON Parsing Memory Management\n");

    // Parse multiple JSON bodies
    const char *test_jsons[] = {
        "{}",
        "{\"key\":\"value\"}",
        "{\"a\":\"1\",\"b\":\"2\",\"c\":\"3\"}"
    };

    for (int i = 0; i < 3; i++) {
        kbody_t body;
        memset(&body, 0, sizeof(body));

        kbody_parse("application/json",
                   test_jsons[i],
                   strlen(test_jsons[i]),
                   &body);

        kbody_clear(&body);
    }

    ASSERT(true, "JSON parsing memory freed without crash");
}

void test_repeated_parsing_cycles(void) {
    printf("\nTest: Repeated Parsing Cycles (100 iterations)\n");

    for (int i = 0; i < 100; i++) {
        kbody_t body;
        memset(&body, 0, sizeof(body));

        char buffer[256];
        snprintf(buffer, sizeof(buffer), "field_%d=value_%d", i, i);

        kbody_parse("application/x-www-form-urlencoded", buffer, strlen(buffer), &body);
        kbody_clear(&body);
    }

    ASSERT(true, "100 parsing cycles completed");
}

/* ==================== Edge Cases ==================== */

void test_empty_body_safety(void) {
    printf("\nTest: Empty Body Safety\n");

    kbody_t body;
    memset(&body, 0, sizeof(body));

    kbody_parse("application/json", "", 0, &body);
    ASSERT(body.field_count == 0, "Empty JSON parsed");

    memset(&body, 0, sizeof(body));
    kbody_parse("application/x-www-form-urlencoded", "", 0, &body);
    ASSERT(body.field_count == 0, "Empty form parsed");
}

void test_null_content_type(void) {
    printf("\nTest: NULL Content Type\n");

    kbody_t body;
    memset(&body, 0, sizeof(body));

    int result = kbody_parse(NULL, "{}", 2, &body);
    ASSERT(result == -1, "NULL content type rejected");
}

void test_malformed_data(void) {
    printf("\nTest: Malformed Data Handling\n");

    kbody_t body;

    // Very long form field
    memset(&body, 0, sizeof(body));
    char long_form[10000] = {0};
    memset(long_form, 'a', sizeof(long_form) - 1);
    long_form[0] = 'k';
    long_form[1] = '=';

    int result = kbody_parse("application/x-www-form-urlencoded",
                            long_form, sizeof(long_form), &body);
    ASSERT(result >= -1, "Long form handled");
}

/* ==================== Main ==================== */

int main(void) {
    printf("\n");
    printf("════════════════════════════════════════════════════════════════\n");
    printf("       Body-C (kbody) Bug Fix Verification Test Suite\n");
    printf("════════════════════════════════════════════════════════════════\n");

    // Stack overflow tests
    test_large_form_body();
    test_max_body_size_boundary();

    // Buffer overflow tests
    test_long_error_messages();
    test_strcpy_replacement();

    // Memory management tests
    test_form_parsing_memory();
    test_json_parsing_memory();
    test_repeated_parsing_cycles();

    // Edge cases
    test_empty_body_safety();
    test_null_content_type();
    test_malformed_data();

    // Summary
    printf("\n");
    printf("════════════════════════════════════════════════════════════════\n");
    printf("Test Results: %d PASSED, %d FAILED\n", tests_passed, tests_failed);

    if (tests_failed == 0) {
        printf("✅ ALL BUG FIX TESTS PASSED!\n");
    } else {
        printf("❌ SOME TESTS FAILED!\n");
    }
    printf("════════════════════════════════════════════════════════════════\n\n");

    return tests_failed > 0 ? 1 : 0;
}
