CC = gcc
CFLAGS = -Wall -Wextra -std=c11 -pedantic -fPIC
LDFLAGS = -shared

TARGET_LIB = lib$(LIBNAME).so
TARGET_TEST = test_$(LIBNAME)_advanced
SOURCES = $(wildcard k$(LIBNAME)*.c)
HEADERS = $(wildcard k$(LIBNAME)*.h)
TEST_SOURCES = tests/test_*.c
OBJECTS = $(SOURCES:.c=.o)

LIBNAME := $(shell basename $(PWD) | sed 's/-c//')

all: $(TARGET_LIB) $(TARGET_TEST)

$(TARGET_LIB): $(OBJECTS)
	$(CC) $(LDFLAGS) -o $@ $^

$(TARGET_TEST): $(OBJECTS) $(TEST_SOURCES)
	$(CC) $(CFLAGS) -I. -o $@ $(TEST_SOURCES) $(OBJECTS)

%.o: %.c $(HEADERS)
	$(CC) $(CFLAGS) -c $< -o $@

test: $(TARGET_TEST)
	@./$(TARGET_TEST)

clean:
	rm -f $(OBJECTS) $(TARGET_LIB) $(TARGET_TEST)

install: $(TARGET_LIB)
	@mkdir -p /usr/local/lib /usr/local/include
	@cp $(TARGET_LIB) /usr/local/lib/
	@cp $(HEADERS) /usr/local/include/

.PHONY: all test clean install
