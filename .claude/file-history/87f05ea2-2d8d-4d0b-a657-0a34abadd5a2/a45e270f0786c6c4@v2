/*
 * async-c Queue Memory Management Test
 *
 * Demonstrates the memory management pattern in kasync_queue
 */

#include "kasync.h"
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

static int task_count = 0;

void test_task_1(kasync_callback_fn callback) {
    printf("  [Task 1] Executing\n");
    task_count++;
    if (callback) {
        callback(NULL, NULL);
    }
}

void test_task_2(kasync_callback_fn callback) {
    printf("  [Task 2] Executing\n");
    task_count++;
    if (callback) {
        callback(NULL, NULL);
    }
}

void test_task_3(kasync_callback_fn callback) {
    printf("  [Task 3] Executing\n");
    task_count++;
    if (callback) {
        callback(NULL, NULL);
    }
}

void queue_final_callback(void *err) {
    printf("  [Queue] All tasks completed\n");
}

int main(void) {
    printf("\n=====================================\n");
    printf("async-c Queue Memory Management Test\n");
    printf("=====================================\n\n");

    printf("✅ Test: Queue Create → Push → Process → Free\n");
    printf("─────────────────────────────────────────────\n");

    // Step 1: Create queue
    printf("Step 1: Create queue\n");
    kasync_queue_t *queue = kasync_queue_new(10, 1);
    printf("  Queue created (malloc allocated)\n\n");

    // Step 2: Push tasks
    printf("Step 2: Push 3 tasks\n");
    kasync_queue_push(queue, test_task_1);
    printf("  Task 1 pushed (malloc allocated)\n");
    kasync_queue_push(queue, test_task_2);
    printf("  Task 2 pushed (malloc allocated)\n");
    kasync_queue_push(queue, test_task_3);
    printf("  Task 3 pushed (malloc allocated)\n");
    printf("  Queue size: %d\n\n", kasync_queue_size(queue));

    // Step 3: Process queue
    printf("Step 3: Process queue\n");
    kasync_queue_process(queue, queue_final_callback);
    printf("  %d tasks executed\n\n", task_count);

    // Step 4: Check memory status
    printf("Step 4: Memory Status (CRITICAL ISSUE)\n");
    printf("─────────────────────────────────────\n");
    printf("⚠️  WARNING: Tasks are NOT freed by process()!\n");
    printf("   - queue->head: Points to task1 ✅ (still allocated)\n");
    printf("   - queue->tail: Points to task3 ✅ (still allocated)\n");
    printf("   - queue->count: %d (unchanged)\n\n", kasync_queue_size(queue));

    printf("Memory Status:\n");
    printf("  ALLOCATED (not freed):\n");
    printf("    - kasync_queue_t struct\n");
    printf("    - kasync_task_t #1\n");
    printf("    - kasync_task_t #2\n");
    printf("    - kasync_task_t #3\n\n");

    // Step 5: Show the pattern
    printf("Step 5: Queue Internal State\n");
    printf("────────────────────────────\n");
    printf("queue->head → [Task1] → [Task2] → [Task3] → NULL\n");
    printf("queue->tail ─────────────────────↑\n");
    printf("All tasks still linked in queue!\n\n");

    // Step 6: Proper cleanup
    printf("Step 6: Proper Cleanup (kasync_queue_free)\n");
    printf("─────────────────────────────────────────\n");
    kasync_queue_free(queue);
    printf("✅ kasync_queue_free() called\n");
    printf("   - All tasks freed in loop (lines 314-319)\n");
    printf("   - Queue structure freed\n");
    printf("   - Memory properly released\n\n");

    // Analysis
    printf("=====================================\n");
    printf("ANALYSIS\n");
    printf("=====================================\n");
    printf("Issue 1: process() doesn't free tasks\n");
    printf("  Code (line 287-309):\n");
    printf("    while (task) {\n");
    printf("        task->fn(callback);  // Execute\n");
    printf("        task = next;         // Move to next\n");
    printf("    }                        // ← NO free(task)!\n\n");

    printf("Issue 2: Memory remains in queue structure\n");
    printf("  - queue->head still points to task1\n");
    printf("  - queue->tail still points to task3\n");
    printf("  - All tasks are allocated but orphaned\n\n");

    printf("Issue 3: API documentation missing\n");
    printf("  - No comment explaining memory ownership\n");
    printf("  - Users may forget kasync_queue_free()\n");
    printf("  - Result: Memory leak\n\n");

    printf("Proper Usage Pattern:\n");
    printf("  1. queue = kasync_queue_new(...)\n");
    printf("  2. kasync_queue_push(queue, task1)\n");
    printf("  3. kasync_queue_push(queue, task2)\n");
    printf("  4. kasync_queue_process(queue, final)  // ← process doesn't free\n");
    printf("  5. kasync_queue_free(queue)            // ← MUST free here\n\n");

    printf("Wrong Usage (Memory Leak):\n");
    printf("  1. queue = kasync_queue_new(...)\n");
    printf("  2. kasync_queue_push(queue, task1)\n");
    printf("  3. kasync_queue_process(queue, final)\n");
    printf("  4. (No free call)                      // ← LEAK!\n\n");

    printf("=====================================\n");
    printf("CONCLUSION\n");
    printf("=====================================\n");
    printf("Severity: 🟡 MEDIUM\n");
    printf("Risk: 70% (memory leak if free() forgotten)\n");
    printf("Fix: Add API documentation\n");
    printf("Recommendation: Document kasync_queue_free() as mandatory\n\n");

    return 0;
}
