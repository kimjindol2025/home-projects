CC = gcc
CFLAGS = -Wall -Wextra -O2 -std=c11 -pthread
INCLUDES = -Iinclude
LDFLAGS = -pthread

# Directories
SRC_DIR = src
EXAMPLE_DIR = examples
BUILD_DIR = build

# Source files
SRCS = $(SRC_DIR)/kuuid.c $(SRC_DIR)/kuuid_hash.c $(SRC_DIR)/kuuid_encoding.c
OBJS = $(SRCS:$(SRC_DIR)/%.c=$(BUILD_DIR)/%.o)

# Targets
LIB = $(BUILD_DIR)/libkuuid.a
EXAMPLE = $(BUILD_DIR)/simple_uuid

# Test binaries
TEST_CORE = $(BUILD_DIR)/test_core
TEST_STRING = $(BUILD_DIR)/test_string
TEST_COMPARISON = $(BUILD_DIR)/test_comparison
TEST_METADATA = $(BUILD_DIR)/test_metadata
TEST_STRESS = $(BUILD_DIR)/test_stress
TEST_HASH = $(BUILD_DIR)/test_hash
TEST_NAMESPACE = $(BUILD_DIR)/test_namespace
TEST_ENCODING = $(BUILD_DIR)/test_encoding
TEST_COMPREHENSIVE = $(BUILD_DIR)/test_comprehensive

.PHONY: all clean test example run install \
        test_core test_string test_comparison test_metadata test_stress \
        test_hash test_namespace test_encoding test_comprehensive \
        tests

all: $(BUILD_DIR) $(LIB) $(EXAMPLE)

$(BUILD_DIR):
	mkdir -p $(BUILD_DIR)

# Build static library
$(BUILD_DIR)/%.o: $(SRC_DIR)/%.c
	$(CC) $(CFLAGS) $(INCLUDES) -c $< -o $@

$(LIB): $(OBJS)
	ar rcs $@ $^
	@echo "✅ Library built: $(LIB)"

# Build example
$(EXAMPLE): $(EXAMPLE_DIR)/simple_uuid.c $(LIB)
	$(CC) $(CFLAGS) $(INCLUDES) $< $(LIB) $(LDFLAGS) -o $@
	@echo "✅ Example built: $(EXAMPLE)"

# Run example
run: $(EXAMPLE)
	@echo "🚀 Running Kim-UUID example..."
	./$(EXAMPLE)

# Build and run tests (Phase 1 + Phase 2 + Phase 3 + Comprehensive)
tests: $(TEST_CORE) $(TEST_STRING) $(TEST_COMPARISON) $(TEST_METADATA) $(TEST_STRESS) $(TEST_HASH) $(TEST_NAMESPACE) $(TEST_ENCODING) $(TEST_COMPREHENSIVE)

$(TEST_CORE): $(EXAMPLE_DIR)/test_core_v1.1.c $(LIB)
	$(CC) $(CFLAGS) $(INCLUDES) $< $(LIB) $(LDFLAGS) -o $@
	@echo "✅ Core test built: $@"

test_core: $(TEST_CORE)
	@echo "=== Running Core Tests ==="
	@$(TEST_CORE)

$(TEST_STRING): $(EXAMPLE_DIR)/test_string_v1.1.c $(LIB)
	$(CC) $(CFLAGS) $(INCLUDES) $< $(LIB) $(LDFLAGS) -o $@
	@echo "✅ String test built: $@"

test_string: $(TEST_STRING)
	@echo "=== Running String Tests ==="
	@$(TEST_STRING)

$(TEST_COMPARISON): $(EXAMPLE_DIR)/test_comparison_v1.1.c $(LIB)
	$(CC) $(CFLAGS) $(INCLUDES) $< $(LIB) $(LDFLAGS) -o $@
	@echo "✅ Comparison test built: $@"

test_comparison: $(TEST_COMPARISON)
	@echo "=== Running Comparison Tests ==="
	@$(TEST_COMPARISON)

$(TEST_METADATA): $(EXAMPLE_DIR)/test_metadata_v1.1.c $(LIB)
	$(CC) $(CFLAGS) $(INCLUDES) $< $(LIB) $(LDFLAGS) -o $@
	@echo "✅ Metadata test built: $@"

test_metadata: $(TEST_METADATA)
	@echo "=== Running Metadata Tests ==="
	@$(TEST_METADATA)

$(TEST_STRESS): $(EXAMPLE_DIR)/test_stress_v1.1.c $(LIB)
	$(CC) $(CFLAGS) $(INCLUDES) $< $(LIB) $(LDFLAGS) -o $@
	@echo "✅ Stress test built: $@"

test_stress: $(TEST_STRESS)
	@echo "=== Running Stress Tests ==="
	@$(TEST_STRESS)

$(TEST_HASH): $(EXAMPLE_DIR)/test_hash_v1.1.c $(LIB)
	$(CC) $(CFLAGS) $(INCLUDES) $< $(LIB) $(LDFLAGS) -o $@
	@echo "✅ Hash test built: $@"

test_hash: $(TEST_HASH)
	@echo "=== Running Hash-Based UUID Tests ==="
	@$(TEST_HASH)

$(TEST_NAMESPACE): $(EXAMPLE_DIR)/test_namespace_v1.1.c $(LIB)
	$(CC) $(CFLAGS) $(INCLUDES) $< $(LIB) $(LDFLAGS) -o $@
	@echo "✅ Namespace test built: $@"

test_namespace: $(TEST_NAMESPACE)
	@echo "=== Running Namespace Tests ==="
	@$(TEST_NAMESPACE)

$(TEST_ENCODING): $(EXAMPLE_DIR)/test_encoding_v1.1.c $(LIB)
	$(CC) $(CFLAGS) $(INCLUDES) $< $(LIB) $(LDFLAGS) -o $@
	@echo "✅ Encoding test built: $@"

test_encoding: $(TEST_ENCODING)
	@echo "=== Running Extended Format Tests (Base64/Base32) ==="
	@$(TEST_ENCODING)

$(TEST_COMPREHENSIVE): tests/test_kuuid_comprehensive.c $(LIB)
	$(CC) $(CFLAGS) $(INCLUDES) $< $(LIB) $(LDFLAGS) -o $@
	@echo "✅ Comprehensive test built: $@"

test_comprehensive: $(TEST_COMPREHENSIVE)
	@echo "=== Running Comprehensive UUID Tests ==="
	@$(TEST_COMPREHENSIVE)

# Clean
clean:
	rm -rf $(BUILD_DIR)
	@echo "🧹 Cleaned build directory"

# Install (copy to /usr/local)
install: $(LIB)
	cp include/kuuid.h /usr/local/include/
	cp $(LIB) /usr/local/lib/
	@echo "✅ Installed to /usr/local"
