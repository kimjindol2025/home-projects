## 🎯 권고사항

### 즉시 필요 없음 (1순위)

### 권장 사항 (2순위)

```c
// 1. getrandom() 시도 추가 (Linux 3.17+)
#ifdef __linux__
#include <sys/random.h>

static void random_bytes(uint8_t *buffer, size_t count) {
    // 1단계: getrandom() 시도 (가장 강함)
    if (getrandom(buffer, count, 0) == (ssize_t)count) {
        return;
    }

    // 2단계: /dev/urandom 시도
    int fd = open("/dev/urandom", O_RDONLY);
    if (fd >= 0) {
        ssize_t total = 0;
        while (total < (ssize_t)count) {
            ssize_t n = read(fd, buffer + total, count - total);
            if (n <= 0) break;
            total += n;
        }
        close(fd);
        if (total == (ssize_t)count) {
            return;
        }
    }

    // 3단계: /dev/random 시도
    fd = open("/dev/random", O_RDONLY | O_NONBLOCK);
    if (fd >= 0) {
        ssize_t n = read(fd, buffer, count);
        close(fd);
        if (n == (ssize_t)count) {
            return;
        }
    }

    // 최후 수단: arc4random() 또는 crypto API
    // 또는 rand() (최악의 경우)
}
#endif
```

### 선택사항 (3순위)

```c
// 2. 더 강한 seed 생성
#include <fcntl.h>
#include <errno.h>

void kuuid_init(void) {
    if (initialized) return;

    unsigned int seed = 0;
    int fd = open("/dev/urandom", O_RDONLY);
    if (fd >= 0) {
        read(fd, &seed, sizeof(seed));
        close(fd);
    } else {
        // 폴백: 여러 소스 조합
        struct timeval tv;
        gettimeofday(&tv, NULL);
        seed = (unsigned int)(
            (tv.tv_sec ^ tv.tv_usec) +
            getpid() +
            getppid() +
            getuid()
        );
    }

    srand(seed);
    initialized = 1;
}
```

