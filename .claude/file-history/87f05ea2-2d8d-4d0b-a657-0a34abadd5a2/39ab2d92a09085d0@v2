// FreeLang v6: Log File Analyzer
// 파일 I/O + 정규표현식 + 고차 함수 + 통계

fn parse_log_line(line) {
  // 형식: [2026-02-21 10:30:45] ERROR: Connection timeout
  let pattern = "^\\[(.*?)\\] ([A-Z]+): (.*)$"

  if regex_test(pattern, line) {
    let parts = regex_split(line, "] ")
    if length(parts) >= 2 {
      let timestamp = str_trim(parts[0])
      timestamp = str_replace(timestamp, "[", "")

      let rest = str_join(slice(parts, 1, length(parts)), "] ")
      let level_and_msg = regex_split(rest, ": ")

      if length(level_and_msg) >= 2 {
        let level = level_and_msg[0]
        let message = str_join(slice(level_and_msg, 1, length(level_and_msg)), ": ")

        return {
          timestamp: timestamp,
          level: level,
          message: message,
          valid: true
        }
      }
    }
  }

  return {
    line: line,
    valid: false
  }
}

fn count_by_level(logs) {
  let counts = {}
  for log in logs {
    if log.valid {
      let level = log.level
      if has(counts, level) {
        counts[level] = counts[level] + 1
      } else {
        counts[level] = 1
      }
    }
  }
  return counts
}

fn filter_by_level(logs, level) {
  return filter(logs, fn(log) {
    return log.valid and log.level == level
  })
}

fn filter_by_date(logs, date) {
  return filter(logs, fn(log) {
    return log.valid and str_starts_with(log.timestamp, date)
  })
}

fn analyze_logs(filename) {
  if not file_exists(filename) {
    return "❌ File not found: " + filename
  }

  let content = read_file(filename)
  let lines = str_split(content, "\n")

  let logs = map(lines, fn(line) {
    return parse_log_line(line)
  })

  let valid_logs = filter(logs, fn(log) { return log.valid })

  let output = "📊 Log Analysis Report\n"
  output = output + "======================\n\n"

  output = output + "📈 Total Entries: " + length(valid_logs) + "\n"
  output = output + "❌ Parse Errors: " + (length(logs) - length(valid_logs)) + "\n\n"

  let counts = count_by_level(valid_logs)
  output = output + "📌 By Level:\n"

  for level in counts {
    output = output + "  " + level + ": " + counts[level] + "\n"
  }

  output = output + "\n⏰ Time Range:\n"
  if length(valid_logs) > 0 {
    let first = valid_logs[0]
    let last = valid_logs[length(valid_logs) - 1]
    output = output + "  From: " + first.timestamp + "\n"
    output = output + "  To: " + last.timestamp + "\n"
  }

  // 에러 로그 샘플
  let errors = filter_by_level(valid_logs, "ERROR")
  output = output + "\n🔴 Recent Errors (" + length(errors) + " total):\n"

  let sample_size = length(errors) > 5 ? 5 : length(errors)
  for i in range(sample_size) {
    output = output + "  • " + errors[i].message + "\n"
  }

  return output
}

// 테스트: 샘플 로그 파일 생성
fn create_sample_log() {
  let sample = "[2026-02-21 08:00:00] INFO: Application started\n"
  sample = sample + "[2026-02-21 08:15:30] DEBUG: Database connection established\n"
  sample = sample + "[2026-02-21 08:30:45] ERROR: Connection timeout\n"
  sample = sample + "[2026-02-21 09:00:00] WARN: High memory usage detected\n"
  sample = sample + "[2026-02-21 09:15:20] ERROR: Failed to fetch data\n"
  sample = sample + "[2026-02-21 09:30:00] INFO: Cache cleared\n"
  sample = sample + "[2026-02-21 10:00:00] DEBUG: Request processed\n"
  sample = sample + "[2026-02-21 10:15:45] ERROR: Invalid token\n"
  sample = sample + "[2026-02-21 10:30:00] INFO: Backup completed\n"

  write_file("sample.log", sample)
  return "sample.log"
}

// 메인
fn main() {
  println("🔍 FreeLang Log Analyzer\n")

  // 샘플 로그 생성
  let logfile = create_sample_log()
  println("📁 Created: " + logfile + "\n")

  // 분석
  let report = analyze_logs(logfile)
  println(report)

  println("\n✨ Analysis complete!")
}

main()
