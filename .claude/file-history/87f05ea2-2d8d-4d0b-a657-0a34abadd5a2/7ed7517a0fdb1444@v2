/* ==================== Provider Switching ==================== */

void test_switch_providers(void) {
    printf("\nTest: Switch Providers\n");

    // Start with FNV-1a
    kcookie_set_crypto_provider(kcookie_crypto_fnv1a());
    char sig_fnv[512];
    kcookie_sign("value", "key", sig_fnv, sizeof(sig_fnv));

    // Switch to HMAC-SHA256
    kcookie_set_crypto_provider(kcookie_crypto_hmac_sha256());
    char sig_hmac[512];
    kcookie_sign("value", "key", sig_hmac, sizeof(sig_hmac));

    ASSERT(strlen(sig_fnv) != strlen(sig_hmac), "Different algorithms should produce different signature lengths");
}

/* ==================== Memory Lifecycle ==================== */

void test_memory_lifecycle_signing(void) {
    printf("\nTest: Memory Lifecycle - Signing (100 iterations)\n");

    kcookie_set_crypto_provider(kcookie_crypto_fnv1a());

    for (int i = 0; i < 100; i++) {
        char value[256];
        snprintf(value, sizeof(value), "value_%d", i);

        char signed_val[512];
        int result = kcookie_sign(value, "key", signed_val, sizeof(signed_val));

        if (result < -1) {
            ASSERT(false, "Signing failed");
            break;
        }
    }

    ASSERT(true, "Memory lifecycle test completed (100 iterations)");
}

void test_memory_lifecycle_verification(void) {
    printf("\nTest: Memory Lifecycle - Verification (100 iterations)\n");

    kcookie_set_crypto_provider(kcookie_crypto_fnv1a());

    // Sign once
    char signed_value[512];
    kcookie_sign("test", "key", signed_value, sizeof(signed_value));

    // Verify many times
    for (int i = 0; i < 100; i++) {
        char output[512];
        int result = kcookie_unsign(signed_value, "key", output, sizeof(output));

        if (result < -1) {
            ASSERT(false, "Verification failed");
            break;
        }
    }

    ASSERT(true, "Memory lifecycle test completed (100 iterations)");
}

/* ==================== NULL Pointer Safety ==================== */

void test_null_pointer_safety(void) {
    printf("\nTest: NULL Pointer Safety\n");

    kcookie_crypto_provider_t *provider = kcookie_get_crypto_provider();

    if (provider) {
        // NULL value
        char sig[512];
        provider->sign(NULL, "key", sig, sizeof(sig));

        // NULL key
        provider->sign("value", NULL, sig, sizeof(sig));

        // NULL output
        provider->sign("value", "key", NULL, 512);
    }

    // Set NULL provider (reset to default)
    kcookie_set_crypto_provider(NULL);

    ASSERT(true, "NULL pointer operations handled");
}

