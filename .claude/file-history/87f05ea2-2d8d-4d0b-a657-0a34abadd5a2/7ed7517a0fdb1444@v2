static int tests_passed = 0;
static int tests_failed = 0;

#define ASSERT(condition, message) \
    do { \
        if (!(condition)) { \
            printf("  ❌ FAILED: %s\n", message); \
            tests_failed++; \
        } else { \
            printf("  ✅ %s\n", message); \
            tests_passed++; \
        } \
    } while (0)

/* ==================== Provider Access ==================== */

void test_get_default_provider(void) {
    printf("\nTest: Get Default Provider\n");

    kcookie_crypto_provider_t *provider = kcookie_get_crypto_provider();
    ASSERT(provider != NULL, "Default provider should exist");
    ASSERT(provider->algorithm >= 0, "Provider should have valid algorithm");
}

void test_fnv1a_provider(void) {
    printf("\nTest: FNV-1a Provider\n");

    kcookie_crypto_provider_t *fnv = kcookie_crypto_fnv1a();
    ASSERT(fnv != NULL, "FNV-1a provider should exist");
    ASSERT(fnv->algorithm == KCOOKIE_HASH_FNV1A, "Algorithm should be FNV-1a");
    ASSERT(fnv->name != NULL, "Provider should have a name");
}

void test_hmac_sha256_provider(void) {
    printf("\nTest: HMAC-SHA256 Provider\n");

    kcookie_crypto_provider_t *hmac = kcookie_crypto_hmac_sha256();
    ASSERT(hmac != NULL, "HMAC-SHA256 provider should exist");
    ASSERT(hmac->algorithm == KCOOKIE_HASH_HMAC_SHA256, "Algorithm should be HMAC-SHA256");
    ASSERT(hmac->name != NULL, "Provider should have a name");
}

void test_set_provider_fnv1a(void) {
    printf("\nTest: Set Provider - FNV-1a\n");

    kcookie_crypto_provider_t *fnv = kcookie_crypto_fnv1a();
    kcookie_set_crypto_provider(fnv);

    kcookie_crypto_provider_t *current = kcookie_get_crypto_provider();
    ASSERT(current->algorithm == KCOOKIE_HASH_FNV1A, "FNV-1a should be set");
}

void test_set_provider_hmac_sha256(void) {
    printf("\nTest: Set Provider - HMAC-SHA256\n");

    kcookie_crypto_provider_t *hmac = kcookie_crypto_hmac_sha256();
    kcookie_set_crypto_provider(hmac);

    kcookie_crypto_provider_t *current = kcookie_get_crypto_provider();
    ASSERT(current->algorithm == KCOOKIE_HASH_HMAC_SHA256, "HMAC-SHA256 should be set");
}

void test_reset_provider(void) {
    printf("\nTest: Reset Provider to Default\n");

    // Set to a specific provider
    kcookie_set_crypto_provider(kcookie_crypto_hmac_sha256());

    // Reset to default (NULL)
    kcookie_set_crypto_provider(NULL);

    kcookie_crypto_provider_t *current = kcookie_get_crypto_provider();
    ASSERT(current != NULL, "Should have default provider after reset");
}

