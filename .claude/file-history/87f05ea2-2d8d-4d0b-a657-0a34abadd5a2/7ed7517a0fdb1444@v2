/* ==================== Signing ==================== */

void test_sign_with_fnv1a(void) {
    printf("\nTest: Sign With FNV-1a\n");

    kcookie_set_crypto_provider(kcookie_crypto_fnv1a());

    char signed_value[512];
    int result = kcookie_sign("test_value", "secret_key", signed_value, sizeof(signed_value));

    ASSERT(result == 0, "FNV-1a signing should succeed");
    ASSERT(strlen(signed_value) > 0, "Signature should not be empty");
}

void test_sign_with_hmac_sha256(void) {
    printf("\nTest: Sign With HMAC-SHA256\n");

    kcookie_set_crypto_provider(kcookie_crypto_hmac_sha256());

    char signed_value[512];
    int result = kcookie_sign("test_value", "secret_key", signed_value, sizeof(signed_value));

    ASSERT(result == 0, "HMAC-SHA256 signing should succeed");
    ASSERT(strlen(signed_value) > 0, "Signature should not be empty");
}

void test_sign_deterministic(void) {
    printf("\nTest: Sign Deterministic\n");

    kcookie_set_crypto_provider(kcookie_crypto_fnv1a());

    char sig1[512], sig2[512];
    kcookie_sign("value", "key", sig1, sizeof(sig1));
    kcookie_sign("value", "key", sig2, sizeof(sig2));

    ASSERT(strcmp(sig1, sig2) == 0, "Same input should produce same signature");
}

void test_sign_different_values(void) {
    printf("\nTest: Sign Different Values\n");

    kcookie_set_crypto_provider(kcookie_crypto_fnv1a());

    char sig1[512], sig2[512];
    kcookie_sign("value1", "key", sig1, sizeof(sig1));
    kcookie_sign("value2", "key", sig2, sizeof(sig2));

    ASSERT(strcmp(sig1, sig2) != 0, "Different values should produce different signatures");
}

void test_sign_different_keys(void) {
    printf("\nTest: Sign Different Keys\n");

    kcookie_set_crypto_provider(kcookie_crypto_fnv1a());

    char sig1[512], sig2[512];
    kcookie_sign("value", "key1", sig1, sizeof(sig1));
    kcookie_sign("value", "key2", sig2, sizeof(sig2));

    ASSERT(strcmp(sig1, sig2) != 0, "Different keys should produce different signatures");
}

/* ==================== Verification ==================== */

void test_verify_valid_fnv1a(void) {
    printf("\nTest: Verify Valid - FNV-1a\n");

    kcookie_set_crypto_provider(kcookie_crypto_fnv1a());

    char signed_value[512];
    kcookie_sign("original", "secret", signed_value, sizeof(signed_value));

    char unsigned_value[512];
    int result = kcookie_unsign(signed_value, "secret", unsigned_value, sizeof(unsigned_value));

    ASSERT(result == 0, "Verification with correct secret should succeed");
    ASSERT(strcmp(unsigned_value, "original") == 0 || strlen(unsigned_value) > 0, "Value should be recovered");
}

void test_verify_valid_hmac_sha256(void) {
    printf("\nTest: Verify Valid - HMAC-SHA256\n");

    kcookie_set_crypto_provider(kcookie_crypto_hmac_sha256());

    char signed_value[512];
    kcookie_sign("original", "secret", signed_value, sizeof(signed_value));

    char unsigned_value[512];
    int result = kcookie_unsign(signed_value, "secret", unsigned_value, sizeof(unsigned_value));

    ASSERT(result == 0, "HMAC-SHA256 verification should succeed");
}

void test_verify_wrong_secret(void) {
    printf("\nTest: Verify Wrong Secret\n");

    kcookie_set_crypto_provider(kcookie_crypto_fnv1a());

    char signed_value[512];
    kcookie_sign("value", "secret1", signed_value, sizeof(signed_value));

    char unsigned_value[512];
    int result = kcookie_unsign(signed_value, "secret2", unsigned_value, sizeof(unsigned_value));

    ASSERT(result == -1, "Verification with wrong secret should fail");
}

void test_verify_wrong_value(void) {
    printf("\nTest: Verify Tampered Value\n");

    kcookie_set_crypto_provider(kcookie_crypto_fnv1a());

    char signed_value[512];
    kcookie_sign("original", "secret", signed_value, sizeof(signed_value));

    // Tamper with the signed value
    if (strlen(signed_value) > 3) {
        signed_value[5] = 'X';  // Change a character
    }

    char unsigned_value[512];
    int result = kcookie_unsign(signed_value, "secret", unsigned_value, sizeof(unsigned_value));

    ASSERT(result == -1, "Verification of tampered value should fail");
}

