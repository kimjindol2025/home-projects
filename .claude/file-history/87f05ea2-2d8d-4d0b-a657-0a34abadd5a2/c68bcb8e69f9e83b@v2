/*
 * Lodash-C Comprehensive Test Suite
 *
 * Test Coverage:
 * - Array creation and manipulation
 * - Array operations (push, pop, shift, unshift)
 * - Array search and access
 * - Object creation and manipulation
 * - Object key-value operations
 * - Memory lifecycle
 * - NULL pointer safety
 */

#include "../klodash.h"
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <assert.h>

static int tests_passed = 0;
static int tests_failed = 0;

#define ASSERT(condition, message) \
    do { \
        if (!(condition)) { \
            printf("  ❌ FAILED: %s\n", message); \
            tests_failed++; \
        } else { \
            printf("  ✅ %s\n", message); \
            tests_passed++; \
        } \
    } while (0)

/* ==================== Helper Functions ==================== */

static void free_string(void *item) {
    if (item) free(item);
}

static char* new_string(const char *str) {
    char *s = malloc(strlen(str) + 1);
    strcpy(s, str);
    return s;
}

/* ==================== Array Creation ==================== */

void test_array_creation(void) {
    printf("\nTest: Array Creation\n");

    klodash_array_t *arr = klodash_array_new(NULL);
    ASSERT(arr != NULL, "klodash_array_new should return non-NULL");
    ASSERT(klodash_array_length(arr) == 0, "Initial array length should be 0");

    klodash_array_free(arr);
    ASSERT(true, "klodash_array_free should complete");
}

void test_array_with_free_function(void) {
    printf("\nTest: Array with Free Function\n");

    klodash_array_t *arr = klodash_array_new(free_string);
    ASSERT(arr != NULL, "Array with free function created");

    klodash_array_free(arr);
    ASSERT(true, "Array with free function freed");
}

/* ==================== Array Push/Pop ==================== */

void test_array_push(void) {
    printf("\nTest: Array Push\n");

    klodash_array_t *arr = klodash_array_new(NULL);

    // Push items
    int val1 = 10, val2 = 20, val3 = 30;
    klodash_array_push(arr, &val1);
    klodash_array_push(arr, &val2);
    klodash_array_push(arr, &val3);

    ASSERT(klodash_array_length(arr) == 3, "Array length should be 3 after 3 pushes");

    klodash_array_free(arr);
}

void test_array_pop(void) {
    printf("\nTest: Array Pop\n");

    klodash_array_t *arr = klodash_array_new(NULL);

    int val1 = 10, val2 = 20, val3 = 30;
    klodash_array_push(arr, &val1);
    klodash_array_push(arr, &val2);
    klodash_array_push(arr, &val3);

    void *popped = klodash_array_pop(arr);
    ASSERT(popped == &val3, "Popped value should be last item");
    ASSERT(klodash_array_length(arr) == 2, "Array length should be 2 after pop");

    klodash_array_free(arr);
}

void test_array_shift_unshift(void) {
    printf("\nTest: Array Shift/Unshift\n");

    klodash_array_t *arr = klodash_array_new(NULL);

    int val1 = 10, val2 = 20;
    klodash_array_push(arr, &val1);
    klodash_array_push(arr, &val2);

    // Unshift (prepend)
    int val0 = 0;
    klodash_array_unshift(arr, &val0);
    ASSERT(klodash_array_length(arr) == 3, "Array length should be 3 after unshift");

    // Shift (remove first)
    void *shifted = klodash_array_shift(arr);
    ASSERT(shifted == &val0, "Shifted value should be first item");
    ASSERT(klodash_array_length(arr) == 2, "Array length should be 2 after shift");

    klodash_array_free(arr);
}

/* ==================== Array Access ==================== */

void test_array_get_set(void) {
    printf("\nTest: Array Get/Set\n");

    klodash_array_t *arr = klodash_array_new(NULL);

    int val1 = 10, val2 = 20, val3 = 30;
    klodash_array_push(arr, &val1);
    klodash_array_push(arr, &val2);
    klodash_array_push(arr, &val3);

    void *got = klodash_array_get(arr, 1);
    ASSERT(got == &val2, "Get should return correct item");

    int val_new = 25;
    klodash_array_set(arr, 1, &val_new);
    got = klodash_array_get(arr, 1);
    ASSERT(got == &val_new, "Set should update item");

    klodash_array_free(arr);
}

void test_array_includes(void) {
    printf("\nTest: Array Includes\n");

    klodash_array_t *arr = klodash_array_new(NULL);

    int val1 = 10, val2 = 20, val3 = 30;
    klodash_array_push(arr, &val1);
    klodash_array_push(arr, &val2);
    klodash_array_push(arr, &val3);

    ASSERT(klodash_array_includes(arr, &val2), "Array should include val2");

    int val_missing = 99;
    ASSERT(klodash_array_includes(arr, &val_missing) == false, "Array should not include missing value");

    klodash_array_free(arr);
}

/* ==================== Array Utilities ==================== */

void test_array_reverse(void) {
    printf("\nTest: Array Reverse\n");

    klodash_array_t *arr = klodash_array_new(NULL);

    int val1 = 10, val2 = 20, val3 = 30;
    klodash_array_push(arr, &val1);
    klodash_array_push(arr, &val2);
    klodash_array_push(arr, &val3);

    klodash_array_reverse(arr);

    // After reverse, should be: val3, val2, val1
    ASSERT(klodash_array_get(arr, 0) == &val3, "First should be val3 after reverse");
    ASSERT(klodash_array_get(arr, 2) == &val1, "Last should be val1 after reverse");

    klodash_array_free(arr);
}

void test_array_slice(void) {
    printf("\nTest: Array Slice\n");

    klodash_array_t *arr = klodash_array_new(NULL);

    int val1 = 10, val2 = 20, val3 = 30, val4 = 40;
    klodash_array_push(arr, &val1);
    klodash_array_push(arr, &val2);
    klodash_array_push(arr, &val3);
    klodash_array_push(arr, &val4);

    klodash_array_t *sliced = klodash_array_slice(arr, 1, 3);
    ASSERT(sliced != NULL, "Slice should return array");
    ASSERT(klodash_array_length(sliced) == 2, "Sliced array should have 2 items");

    klodash_array_free(arr);
    if (sliced) klodash_array_free(sliced);
}

void test_array_concat(void) {
    printf("\nTest: Array Concat\n");

    klodash_array_t *arr1 = klodash_array_new(NULL);
    klodash_array_t *arr2 = klodash_array_new(NULL);

    int val1 = 10, val2 = 20, val3 = 30, val4 = 40;
    klodash_array_push(arr1, &val1);
    klodash_array_push(arr1, &val2);
    klodash_array_push(arr2, &val3);
    klodash_array_push(arr2, &val4);

    klodash_array_t *combined = klodash_array_concat(arr1, arr2);
    ASSERT(combined != NULL, "Concat should return array");
    ASSERT(klodash_array_length(combined) == 4, "Combined array should have 4 items");

    klodash_array_free(arr1);
    klodash_array_free(arr2);
    if (combined) klodash_array_free(combined);
}

