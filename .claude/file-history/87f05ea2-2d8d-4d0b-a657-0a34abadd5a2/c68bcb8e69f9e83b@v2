/* ==================== Object Key-Value ==================== */

void test_object_set_get(void) {
    printf("\nTest: Object Set/Get\n");

    klodash_object_t *obj = klodash_object_new();

    int val1 = 100, val2 = 200;
    klodash_object_set(obj, "key1", &val1);
    klodash_object_set(obj, "key2", &val2);

    void *got1 = klodash_object_get(obj, "key1");
    ASSERT(got1 == &val1, "Get should return correct value");

    void *got2 = klodash_object_get(obj, "key2");
    ASSERT(got2 == &val2, "Get should return correct value");

    klodash_object_free(obj);
}

void test_object_has(void) {
    printf("\nTest: Object Has\n");

    klodash_object_t *obj = klodash_object_new();

    int val = 100;
    klodash_object_set(obj, "existing", &val);

    ASSERT(klodash_object_has(obj, "existing"), "Object should have existing key");
    ASSERT(klodash_object_has(obj, "missing") == false, "Object should not have missing key");

    klodash_object_free(obj);
}

void test_object_delete(void) {
    printf("\nTest: Object Delete\n");

    klodash_object_t *obj = klodash_object_new();

    int val = 100;
    klodash_object_set(obj, "key", &val);
    ASSERT(klodash_object_has(obj, "key"), "Key should exist");

    klodash_object_delete(obj, "key");
    ASSERT(klodash_object_has(obj, "key") == false, "Key should be deleted");

    klodash_object_free(obj);
}

void test_object_size(void) {
    printf("\nTest: Object Size\n");

    klodash_object_t *obj = klodash_object_new();

    int val = 100;
    klodash_object_set(obj, "key1", &val);
    ASSERT(klodash_object_size(obj) >= 1, "Object size should be at least 1");

    klodash_object_set(obj, "key2", &val);
    ASSERT(klodash_object_size(obj) >= 2, "Object size should be at least 2");

    klodash_object_free(obj);
}

void test_object_keys(void) {
    printf("\nTest: Object Keys\n");

    klodash_object_t *obj = klodash_object_new();

    int val = 100;
    klodash_object_set(obj, "name", &val);
    klodash_object_set(obj, "age", &val);

    klodash_array_t *keys = klodash_object_keys(obj);
    ASSERT(keys != NULL, "Keys should return array");
    ASSERT(klodash_array_length(keys) >= 2, "Keys array should have at least 2 items");

    klodash_object_free(obj);
    if (keys) klodash_array_free(keys);
}

void test_object_values(void) {
    printf("\nTest: Object Values\n");

    klodash_object_t *obj = klodash_object_new();

    int val1 = 100, val2 = 200;
    klodash_object_set(obj, "key1", &val1);
    klodash_object_set(obj, "key2", &val2);

    klodash_array_t *values = klodash_object_values(obj);
    ASSERT(values != NULL, "Values should return array");
    ASSERT(klodash_array_length(values) >= 2, "Values array should have at least 2 items");

    klodash_object_free(obj);
    if (values) klodash_array_free(values);
}

/* ==================== Memory Lifecycle ==================== */

void test_memory_lifecycle_arrays(void) {
    printf("\nTest: Memory Lifecycle - Arrays (50 iterations)\n");

    for (int i = 0; i < 50; i++) {
        klodash_array_t *arr = klodash_array_new(NULL);
        if (arr == NULL) {
            ASSERT(false, "Array creation failed");
            break;
        }

        for (int j = 0; j < 10; j++) {
            int *val = malloc(sizeof(int));
            *val = i * 10 + j;
            klodash_array_push(arr, val);
            free(val);
        }

        klodash_array_free(arr);
    }

    ASSERT(true, "Memory lifecycle test completed (50 iterations)");
}

void test_memory_lifecycle_objects(void) {
    printf("\nTest: Memory Lifecycle - Objects (50 iterations)\n");

    for (int i = 0; i < 50; i++) {
        klodash_object_t *obj = klodash_object_new();
        if (obj == NULL) {
            ASSERT(false, "Object creation failed");
            break;
        }

        for (int j = 0; j < 10; j++) {
            char key[256];
            snprintf(key, sizeof(key), "key_%d", j);
            int val = i * 10 + j;
            klodash_object_set(obj, key, (void *)(intptr_t)val);
        }

        klodash_object_free(obj);
    }

    ASSERT(true, "Memory lifecycle test completed (50 iterations)");
}

