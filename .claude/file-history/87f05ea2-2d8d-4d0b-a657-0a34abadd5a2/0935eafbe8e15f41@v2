## 🎯 권고사항

```c
// 1. realloc 에러 처리
bool kgraphql_type_add_field(...) {
    // ...
    if (type->field_count >= type->field_capacity) {
        type->field_capacity *= 2;
        kgraphql_field_t *new_fields = (kgraphql_field_t *)realloc(type->fields,
                           type->field_capacity * sizeof(kgraphql_field_t));
        if (!new_fields) {  // ✅ 추가
            type->field_capacity /= 2;
            return false;
        }
        type->fields = new_fields;
    }
    // ...
}

// 2. malloc 에러 체크
kgraphql_type_def_t* kgraphql_type_new(const char *name) {
    // ...
    type->fields = (kgraphql_field_t *)malloc(type->field_capacity * sizeof(kgraphql_field_t));
    if (!type->fields) {  // ✅ 추가
        free(type);
        return NULL;
    }
    return type;
}

// 3. JSON 이스케이프 추가
static const char* escape_json_string(const char *input, char *output, size_t size) {
    size_t j = 0;
    for (size_t i = 0; input[i] && j < size - 1; i++) {
        char c = input[i];
        if (c == '"' || c == '\\' || c == '\n') {
            if (j + 2 >= size) break;
            output[j++] = '\\';
        }
        output[j++] = c;
    }
    output[j] = '\0';
    return output;
}

// 사용:
char escaped[2048];
escape_json_string(message, escaped, sizeof(escaped));
snprintf(error, 1024, "{\"errors\":[{\"message\":\"%s\"}]}", escaped);
```

