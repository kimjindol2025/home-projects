/* ==================== Memory Lifecycle ==================== */

void test_memory_lifecycle_lookups(void) {
    printf("\nTest: Memory Lifecycle - Lookups (100 iterations)\n");

    char mime_type[256];
    const char *extensions[] = {"html", "json", "txt", "png", "jpg", "zip"};
    int ext_count = sizeof(extensions) / sizeof(extensions[0]);

    for (int i = 0; i < 100; i++) {
        const char *ext = extensions[i % ext_count];
        int result = kmime_lookup(ext, mime_type, sizeof(mime_type));

        if (result != 0 && result != -1) {
            ASSERT(false, "Unexpected return value");
            break;
        }
    }

    ASSERT(true, "Memory lifecycle test completed (100 iterations)");
}

void test_memory_lifecycle_info(void) {
    printf("\nTest: Memory Lifecycle - Info Retrieval (100 iterations)\n");

    kmime_info_t info;
    const char *extensions[] = {"html", "json", "txt", "png", "jpg"};
    int ext_count = sizeof(extensions) / sizeof(extensions[0]);

    for (int i = 0; i < 100; i++) {
        const char *ext = extensions[i % ext_count];
        kmime_get_info(ext, &info);
    }

    ASSERT(true, "Memory lifecycle test completed (100 iterations)");
}

