/* ==================== MIME Info ==================== */

void test_mime_get_info(void) {
    printf("\nTest: MIME Get Info\n");

    kmime_info_t info;
    int result = kmime_get_info("html", &info);

    ASSERT(result == 0, "kmime_get_info should succeed");
    ASSERT(strlen(info.mime_type) > 0, "MIME type should be set");
    ASSERT(strlen(info.charset) > 0, "Charset should be set");
    ASSERT(strcmp(info.extension, "html") == 0, "Extension should match");
}

void test_mime_get_info_compressible(void) {
    printf("\nTest: MIME Get Info - Compressible\n");

    kmime_info_t info;
    int result = kmime_get_info("html", &info);

    ASSERT(result == 0, "kmime_get_info should succeed");
    // HTML should be compressible
    ASSERT(info.compressible == true || info.compressible == false, "Compressible flag set");
}

