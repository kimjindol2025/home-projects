/* ==================== Extension to MIME Type ==================== */

void test_mime_lookup_html(void) {
    printf("\nTest: MIME Lookup - HTML\n");

    char mime_type[256];
    int result = kmime_lookup("html", mime_type, sizeof(mime_type));

    ASSERT(result == 0, "kmime_lookup should succeed for html");
    ASSERT(strlen(mime_type) > 0, "MIME type should not be empty");
    ASSERT(strstr(mime_type, "text") != NULL, "HTML should be text type");
}

