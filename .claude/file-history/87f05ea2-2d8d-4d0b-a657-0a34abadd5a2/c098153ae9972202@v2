    ASSERT(kmime_lookup("txt", mime_type, sizeof(mime_type)) == 0, "txt should be found");
    ASSERT(kmime_lookup("csv", mime_type, sizeof(mime_type)) == 0, "csv should be found");

    // Images
    ASSERT(kmime_lookup("png", mime_type, sizeof(mime_type)) == 0, "png should be found");
