/*
 * Express-C Comprehensive Test Suite
 *
 * Test Coverage:
 * - App creation and cleanup
 * - Route registration (GET, POST, PUT, DELETE)
 * - Middleware setup
 * - Request/Response handling
 * - HTTP method support
 * - Header management
 * - NULL pointer safety
 * - Memory lifecycle
 */

#include "../express.h"
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <assert.h>

static int tests_passed = 0;
static int tests_failed = 0;

#define ASSERT(condition, message) \
    do { \
        if (!(condition)) { \
            printf("  ❌ FAILED: %s\n", message); \
            tests_failed++; \
        } else { \
            printf("  ✅ %s\n", message); \
            tests_passed++; \
        } \
    } while (0)

/* ==================== App Creation & Cleanup ==================== */

void test_app_creation(void) {
    printf("\nTest: Express App Creation\n");

    express_app_t *app = express_create();
    ASSERT(app != NULL, "express_create should return non-NULL");
    ASSERT(app->route_count == 0, "Initial route count should be 0");
    ASSERT(app->middleware_count == 0, "Initial middleware count should be 0");

    express_free(app);
    ASSERT(true, "express_free should complete without crash");
}

/* ==================== Route Registration ==================== */

// Simple test handler
static void test_handler(request_t *req, response_t *res) {
    res_status(res, 200);
    res_send(res, "OK");
}

static void json_handler(request_t *req, response_t *res) {
    res_status(res, 200);
    res_json(res, "{\"status\":\"ok\"}");
}

void test_get_route_registration(void) {
    printf("\nTest: GET Route Registration\n");

    express_app_t *app = express_create();
    assert(app != NULL);

    // Register GET route
    express_get(app, "/api/test", test_handler);
    ASSERT(app->route_count == 1, "Route count should be 1 after registration");
    ASSERT(app->routes[0].method == HTTP_GET, "Route method should be GET");
    ASSERT(strcmp(app->routes[0].path, "/api/test") == 0, "Route path should match");
    ASSERT(app->routes[0].handler == test_handler, "Handler should be registered");

    express_free(app);
}

void test_multiple_route_registration(void) {
    printf("\nTest: Multiple Route Registration\n");

    express_app_t *app = express_create();
    assert(app != NULL);

    // Register multiple routes
    express_get(app, "/users", test_handler);
    express_post(app, "/users", test_handler);
    express_put(app, "/users/:id", test_handler);
    express_delete(app, "/users/:id", test_handler);

    ASSERT(app->route_count == 4, "Route count should be 4");
    ASSERT(app->routes[0].method == HTTP_GET, "First route should be GET");
    ASSERT(app->routes[1].method == HTTP_POST, "Second route should be POST");
    ASSERT(app->routes[2].method == HTTP_PUT, "Third route should be PUT");
    ASSERT(app->routes[3].method == HTTP_DELETE, "Fourth route should be DELETE");

    express_free(app);
}

void test_route_method_types(void) {
    printf("\nTest: Route Method Types\n");

    express_app_t *app = express_create();
    assert(app != NULL);

    express_get(app, "/get", test_handler);
    express_post(app, "/post", test_handler);
    express_put(app, "/put", test_handler);
    express_delete(app, "/delete", test_handler);

    ASSERT(app->routes[0].method == HTTP_GET, "HTTP_GET method");
    ASSERT(app->routes[1].method == HTTP_POST, "HTTP_POST method");
    ASSERT(app->routes[2].method == HTTP_PUT, "HTTP_PUT method");
    ASSERT(app->routes[3].method == HTTP_DELETE, "HTTP_DELETE method");

    express_free(app);
}

/* ==================== Middleware ==================== */

static int test_middleware(request_t *req, response_t *res) {
    return 1;  // Continue
}

void test_middleware_registration(void) {
    printf("\nTest: Middleware Registration\n");

    express_app_t *app = express_create();
    assert(app != NULL);

    express_use(app, test_middleware);
    ASSERT(app->middleware_count == 1, "Middleware count should be 1");
    ASSERT(app->middleware[0] == test_middleware, "Middleware should be registered");

    express_free(app);
}

void test_multiple_middleware(void) {
    printf("\nTest: Multiple Middleware\n");

    express_app_t *app = express_create();
    assert(app != NULL);

    express_use(app, test_middleware);
    express_use(app, test_middleware);
    express_use(app, test_middleware);

    ASSERT(app->middleware_count == 3, "Middleware count should be 3");

    express_free(app);
}

/* ==================== Request Structure ==================== */

void test_request_creation(void) {
    printf("\nTest: Request Structure\n");

    request_t req;
    memset(&req, 0, sizeof(request_t));

    req.method = HTTP_GET;
    strcpy(req.path, "/api/test");

    ASSERT(req.method == HTTP_GET, "Request method should be set");
    ASSERT(strcmp(req.path, "/api/test") == 0, "Request path should be set");
    ASSERT(req.header_count == 0, "Initial header count should be 0");
}

void test_request_headers(void) {
    printf("\nTest: Request Headers\n");

    request_t req;
    memset(&req, 0, sizeof(request_t));

    // Simulate adding headers
    strcpy(req.headers[0], "Content-Type: application/json");
    req.header_count = 1;

    ASSERT(req.header_count == 1, "Header count should be 1");
    ASSERT(strstr(req.headers[0], "Content-Type") != NULL, "Header content should match");
}

/* ==================== Response Structure ==================== */

void test_response_creation(void) {
    printf("\nTest: Response Structure\n");

    response_t res;
    memset(&res, 0, sizeof(response_t));

    res.status_code = 200;
    strcpy(res.body, "Hello World");

    ASSERT(res.status_code == 200, "Status code should be 200");
    ASSERT(strcmp(res.body, "Hello World") == 0, "Response body should match");
}

void test_response_status(void) {
    printf("\nTest: Response Status\n");

    response_t res;
    memset(&res, 0, sizeof(response_t));

    res_status(&res, 404);
    ASSERT(res.status_code == 404, "Status code should be 404");

    res_status(&res, 500);
    ASSERT(res.status_code == 500, "Status code should be 500");
}

void test_response_send(void) {
    printf("\nTest: Response Send (Buffer)\n");

    response_t res;
    memset(&res, 0, sizeof(response_t));

    res_send(&res, "Test response");
    ASSERT(strcmp(res.body, "Test response") == 0, "Body should contain sent content");
    ASSERT(res.body_length > 0, "Body length should be > 0");
}

void test_response_json(void) {
    printf("\nTest: Response JSON\n");

    response_t res;
    memset(&res, 0, sizeof(response_t));

    res_json(&res, "{\"key\":\"value\"}");
    ASSERT(strstr(res.body, "key") != NULL, "JSON body should contain key");
    ASSERT(strstr(res.body, "value") != NULL, "JSON body should contain value");
}

void test_response_headers(void) {
    printf("\nTest: Response Headers\n");

    response_t res;
    memset(&res, 0, sizeof(response_t));

    res_set_header(&res, "Content-Type", "application/json");
    ASSERT(res.header_count == 1, "Header count should be 1");
    ASSERT(strstr(res.headers[0], "Content-Type") != NULL, "Header should contain key");
    ASSERT(strstr(res.headers[0], "application/json") != NULL, "Header should contain value");

    res_set_header(&res, "X-Custom", "value");
    ASSERT(res.header_count == 2, "Header count should be 2");
}

/* ==================== Path Handling ==================== */

void test_path_storage(void) {
    printf("\nTest: Path Storage\n");

    express_app_t *app = express_create();
    assert(app != NULL);

    express_get(app, "/", test_handler);
    express_get(app, "/api", test_handler);
    express_get(app, "/api/users", test_handler);
    express_get(app, "/api/users/:id", test_handler);

    ASSERT(strcmp(app->routes[0].path, "/") == 0, "Root path should be stored");
    ASSERT(strcmp(app->routes[1].path, "/api") == 0, "API path should be stored");
    ASSERT(strcmp(app->routes[2].path, "/api/users") == 0, "Users path should be stored");
    ASSERT(strstr(app->routes[3].path, ":id") != NULL, "Dynamic path should be stored");

    express_free(app);
}

/* ==================== NULL Pointer Handling ==================== */

void test_null_pointer_safety(void) {
    printf("\nTest: NULL Pointer Safety\n");

    express_app_t *app = express_create();
    assert(app != NULL);

    // These should not crash
    express_get(app, NULL, test_handler);  // May or may not be handled
    express_post(app, "/test", NULL);      // May or may not be handled
    express_use(app, NULL);                 // May or may not be handled

    ASSERT(true, "NULL pointer calls did not crash");

    express_free(app);
}

/* ==================== Route Capacity ==================== */

void test_max_routes(void) {
    printf("\nTest: Maximum Routes\n");

    express_app_t *app = express_create();
    assert(app != NULL);

    // Try to register many routes (up to MAX_ROUTES - 1)
    for (int i = 0; i < 50; i++) {
        char path[256];
        snprintf(path, sizeof(path), "/route%d", i);
        express_get(app, path, test_handler);
    }

    ASSERT(app->route_count == 50, "Should be able to register 50 routes");

    express_free(app);
}

/* ==================== Memory Lifecycle ==================== */

void test_memory_lifecycle(void) {
    printf("\nTest: Memory Lifecycle (100 iterations)\n");

    for (int i = 0; i < 100; i++) {
        express_app_t *app = express_create();
        if (app == NULL) {
            ASSERT(false, "App creation failed");
            break;
        }

        express_get(app, "/test", test_handler);
        express_post(app, "/test", test_handler);
        express_use(app, test_middleware);

        response_t res;
        memset(&res, 0, sizeof(response_t));
        res_status(&res, 200);
        res_send(&res, "Test");

        express_free(app);
    }

    ASSERT(true, "Memory lifecycle test completed (100 iterations)");
}

