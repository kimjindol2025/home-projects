    printf("\nTest: HTTP Method Enum Values\n");

    ASSERT(HTTP_GET == 0, "HTTP_GET should be defined");
    ASSERT(HTTP_POST == 1, "HTTP_POST should be defined");
    ASSERT(HTTP_PUT == 2, "HTTP_PUT should be defined");
    ASSERT(HTTP_DELETE == 3, "HTTP_DELETE should be defined");
    ASSERT(HTTP_PATCH == 4, "HTTP_PATCH should be defined");
    ASSERT(HTTP_OPTIONS == 5, "HTTP_OPTIONS should be defined");
    ASSERT(HTTP_HEAD == 6, "HTTP_HEAD should be defined");

    ASSERT(true, "All HTTP methods defined");
}

/* ==================== Route Lookup ==================== */

void test_route_lookup(void) {
    printf("\nTest: Route Lookup\n");

    express_app_t *app = express_create();
    assert(app != NULL);

    express_get(app, "/users", test_handler);
    express_post(app, "/users", test_handler);
    express_get(app, "/posts", test_handler);

    // Verify routes are stored in order
    ASSERT(app->routes[0].method == HTTP_GET, "First route GET");
    ASSERT(strcmp(app->routes[0].path, "/users") == 0, "First path is /users");

    ASSERT(app->routes[1].method == HTTP_POST, "Second route POST");
    ASSERT(strcmp(app->routes[1].path, "/users") == 0, "Second path is /users");

    ASSERT(app->routes[2].method == HTTP_GET, "Third route GET");
    ASSERT(strcmp(app->routes[2].path, "/posts") == 0, "Third path is /posts");

    express_free(app);
}

