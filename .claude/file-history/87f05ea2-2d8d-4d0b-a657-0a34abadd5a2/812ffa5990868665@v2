#include "../kasync.h"
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <assert.h>

static int tests_passed = 0;
static int tests_failed = 0;

#define ASSERT(condition, message) \
    do { \
        if (!(condition)) { \
            printf("  ❌ FAILED: %s\n", message); \
            tests_failed++; \
        } else { \
            printf("  ✅ %s\n", message); \
            tests_passed++; \
        } \
    } while (0)

/* ==================== Error Handling ==================== */

void test_error_creation(void) {
    printf("\nTest: Error Creation\n");

    kasync_error_t *err = kasync_error_new(1, "Test error");
    ASSERT(err != NULL, "kasync_error_new should return non-NULL");
    ASSERT(err->code == 1, "Error code should be 1");
    ASSERT(strcmp(err->message, "Test error") == 0, "Error message should match");

    kasync_error_free(err);
    ASSERT(true, "kasync_error_free should complete");
}

void test_error_codes(void) {
    printf("\nTest: Error Codes\n");

    kasync_error_t *err1 = kasync_error_new(0, "Success");
    kasync_error_t *err2 = kasync_error_new(404, "Not found");
    kasync_error_t *err3 = kasync_error_new(500, "Server error");

    ASSERT(err1->code == 0, "Code 0 should be success");
    ASSERT(err2->code == 404, "Code 404");
    ASSERT(err3->code == 500, "Code 500");

    kasync_error_free(err1);
    kasync_error_free(err2);
    kasync_error_free(err3);
}

void test_error_message_storage(void) {
    printf("\nTest: Error Message Storage\n");

    const char *long_msg = "This is a very detailed error message";
    kasync_error_t *err = kasync_error_new(1, long_msg);

    ASSERT(err != NULL, "Error creation should succeed");
    ASSERT(strstr(err->message, "detailed") != NULL, "Message should contain content");

    kasync_error_free(err);
}

/* ==================== Queue Creation ==================== */

void test_queue_creation(void) {
    printf("\nTest: Queue Creation\n");

    kasync_queue_t *queue = kasync_queue_new(100, 5);
    ASSERT(queue != NULL, "kasync_queue_new should return non-NULL");
    ASSERT(queue->max_size == 100, "Max size should be 100");
    ASSERT(queue->concurrent == 5, "Concurrent should be 5");
    ASSERT(queue->count == 0, "Initial count should be 0");

    kasync_queue_free(queue);
    ASSERT(true, "kasync_queue_free should complete");
}

void test_queue_different_sizes(void) {
    printf("\nTest: Queue Different Sizes\n");

    kasync_queue_t *small_queue = kasync_queue_new(10, 1);
    ASSERT(small_queue->max_size == 10, "Small queue max size");
    kasync_queue_free(small_queue);

    kasync_queue_t *large_queue = kasync_queue_new(1000, 50);
    ASSERT(large_queue->max_size == 1000, "Large queue max size");
    kasync_queue_free(large_queue);

    ASSERT(true, "Different queue sizes handled");
}

void test_queue_concurrency_levels(void) {
    printf("\nTest: Queue Concurrency Levels\n");

    kasync_queue_t *serial = kasync_queue_new(100, 1);
    ASSERT(serial->concurrent == 1, "Serial queue (concurrent=1)");
    kasync_queue_free(serial);

    kasync_queue_t *parallel = kasync_queue_new(100, 10);
    ASSERT(parallel->concurrent == 10, "Parallel queue (concurrent=10)");
    kasync_queue_free(parallel);

    kasync_queue_t *unlimited = kasync_queue_new(100, 0);
    ASSERT(unlimited->concurrent == 0, "Unlimited concurrency");
    kasync_queue_free(unlimited);
}

/* ==================== Queue Operations ==================== */

void test_queue_size(void) {
    printf("\nTest: Queue Size\n");

    kasync_queue_t *queue = kasync_queue_new(100, 5);
    ASSERT(kasync_queue_size(queue) == 0, "Initial queue size should be 0");

    kasync_queue_free(queue);
}

void test_queue_empty_check(void) {
    printf("\nTest: Queue Empty Check\n");

    kasync_queue_t *queue = kasync_queue_new(100, 5);

    int size = kasync_queue_size(queue);
    ASSERT(size == 0, "Empty queue should have size 0");

    kasync_queue_free(queue);
}

/* ==================== Task Functions ==================== */

static int task_called = 0;

void simple_task(void (*callback)(void *err, void *result)) {
    task_called++;
    callback(NULL, NULL);
}

void test_task_callback_signature(void) {
    printf("\nTest: Task Callback Signature\n");

    // Verify callback function type
    typedef void (*kasync_task_fn)(void (*callback)(void *err, void *result));

    ASSERT(true, "Task callback signature verified");
}

/* ==================== Memory Lifecycle ==================== */

void test_memory_lifecycle_queues(void) {
    printf("\nTest: Memory Lifecycle - Queues (50 iterations)\n");

    for (int i = 0; i < 50; i++) {
        kasync_queue_t *queue = kasync_queue_new(100 + i, 5);
        if (queue == NULL) {
            ASSERT(false, "Queue creation failed");
            break;
        }

        int size = kasync_queue_size(queue);
        if (size < 0) {
            ASSERT(false, "Queue size check failed");
        }

        kasync_queue_free(queue);
    }

    ASSERT(true, "Memory lifecycle test completed (50 iterations)");
}

void test_memory_lifecycle_errors(void) {
    printf("\nTest: Memory Lifecycle - Errors (100 iterations)\n");

    for (int i = 0; i < 100; i++) {
        kasync_error_t *err = kasync_error_new(i, "Error message");
        if (err == NULL) {
            ASSERT(false, "Error creation failed");
            break;
        }

        kasync_error_free(err);
    }

    ASSERT(true, "Memory lifecycle test completed (100 iterations)");
}

/* ==================== NULL Pointer Handling ==================== */

void test_null_pointer_safety(void) {
    printf("\nTest: NULL Pointer Safety\n");

    // These operations should not crash
    kasync_queue_t *queue = kasync_queue_new(100, 5);

    // NULL queue operations
    int size = kasync_queue_size(queue);
    ASSERT(size >= 0, "Queue size operation safe");

    kasync_queue_free(queue);

    ASSERT(true, "NULL pointer operations did not crash");
}

/* ==================== Error Structure ==================== */

void test_error_structure_fields(void) {
    printf("\nTest: Error Structure Fields\n");

    kasync_error_t *err = kasync_error_new(42, "Test");

    ASSERT(err->code == 42, "Error code field works");
    ASSERT(strlen(err->message) > 0, "Error message field works");
    ASSERT(sizeof(err->message) >= 256, "Message buffer is at least 256 bytes");

    kasync_error_free(err);
}

/* ==================== Queue Structure ==================== */

void test_queue_structure_fields(void) {
    printf("\nTest: Queue Structure Fields\n");

    kasync_queue_t *queue = kasync_queue_new(200, 10);

    ASSERT(queue->head != NULL || queue->head == NULL, "Queue head field exists");
    ASSERT(queue->tail != NULL || queue->tail == NULL, "Queue tail field exists");
    ASSERT(queue->count >= 0, "Queue count field");
    ASSERT(queue->max_size == 200, "Queue max_size field");
    ASSERT(queue->concurrent == 10, "Queue concurrent field");
    ASSERT(queue->running >= 0, "Queue running field");

    kasync_queue_free(queue);
}

