void test_function_pointer_types(void) {
    printf("\nTest: Function Pointer Types\n");

    // Verify that function pointers can be assigned
    kasync_callback_fn callback = NULL;
    kasync_task_fn task = simple_task;
    kasync_final_fn final = NULL;

    ASSERT(task != NULL, "Task function pointer assigned");
    ASSERT(true, "All function pointer types defined");
}

/* ==================== Queue Lifecycle ==================== */

void test_queue_create_free_cycle(void) {
    printf("\nTest: Queue Create-Free Cycle (30 iterations)\n");

    for (int i = 1; i <= 30; i++) {
        kasync_queue_t *queue = kasync_queue_new(i * 10, i);

        ASSERT(queue != NULL, "Queue creation should succeed");
        ASSERT(queue->max_size == i * 10, "Max size should match");
        ASSERT(queue->concurrent == i, "Concurrent should match");

        kasync_queue_free(queue);
    }

    ASSERT(true, "Queue lifecycle cycle completed");
}

/* ==================== Error Lifecycle ==================== */

void test_error_create_free_cycle(void) {
    printf("\nTest: Error Create-Free Cycle (100 iterations)\n");

    for (int i = 0; i < 100; i++) {
        char msg[256];
        snprintf(msg, sizeof(msg), "Error %d", i);

        kasync_error_t *err = kasync_error_new(i, msg);

        ASSERT(err != NULL, "Error creation should succeed");
        ASSERT(err->code == i, "Error code should match");

        kasync_error_free(err);
    }

    ASSERT(true, "Error lifecycle cycle completed");
}

