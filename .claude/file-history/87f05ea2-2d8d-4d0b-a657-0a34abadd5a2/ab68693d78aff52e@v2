**예시:**

```c
char* klodash_string_concat(const char *s1, const char *s2) {
    if (!s1 || !s2) return NULL;

    int len1 = strlen(s1);
    int len2 = strlen(s2);
    char *result = (char *)malloc(len1 + len2 + 1);
    // ❌ malloc 실패 시 NULL

    strcpy(result, s1);  // NULL 포인터 역참조!
    strcat(result, s2);

    return result;
}
