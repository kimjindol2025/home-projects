#include "../include/kuuid.h"
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <assert.h>

static int tests_passed = 0;
static int tests_failed = 0;

#define ASSERT(condition, message) \
    do { \
        if (!(condition)) { \
            printf("  ❌ FAILED: %s\n", message); \
            tests_failed++; \
        } else { \
            printf("  ✅ %s\n", message); \
            tests_passed++; \
        } \
    } while (0)

/* ==================== UUID v4 Generation ==================== */

void test_uuid_v4_generation(void) {
    printf("\nTest: UUID v4 Generation (Random)\n");

    kuuid_t uuid1 = kuuid_v4();
    kuuid_t uuid2 = kuuid_v4();

    // v4 should be random, so they should differ
    ASSERT(kuuid_equal(&uuid1, &uuid2) == false, "Two v4 UUIDs should be different");

    // v4 should not be nil
    ASSERT(kuuid_is_nil(&uuid1) == false, "v4 should not be nil");
    ASSERT(kuuid_is_nil(&uuid2) == false, "v4 should not be nil");

    // v4 should have version 4
    int ver1 = kuuid_get_version(&uuid1);
    ASSERT(ver1 == 4, "v4 should have version 4");
}

/* ==================== UUID v1 Generation ==================== */

void test_uuid_v1_generation(void) {
    printf("\nTest: UUID v1 Generation (Time-based)\n");

    kuuid_t uuid1 = kuuid_v1();
    kuuid_t uuid2 = kuuid_v1();

    // v1 should have version 1
    int ver1 = kuuid_get_version(&uuid1);
    ASSERT(ver1 == 1, "v1 should have version 1");

    // v1 should not be nil
    ASSERT(kuuid_is_nil(&uuid1) == false, "v1 should not be nil");

    // Two v1 UUIDs generated closely in time might be the same
    // (depending on clock resolution), but let's at least check format
    char buf1[37], buf2[37];
    kuuid_to_string(&uuid1, buf1);
    kuuid_to_string(&uuid2, buf2);

    ASSERT(strlen(buf1) == 36, "UUID string length should be 36 characters");
    ASSERT(strlen(buf2) == 36, "UUID string length should be 36 characters");
}

/* ==================== UUID String Conversion ==================== */

void test_uuid_to_string(void) {
    printf("\nTest: UUID to String Conversion\n");

    kuuid_t uuid = kuuid_v4();
    char buffer[37];

    char *result = kuuid_to_string(&uuid, buffer);
    ASSERT(result != NULL, "kuuid_to_string should not return NULL");
    ASSERT(strlen(buffer) == 36, "UUID string should be 36 chars (excluding null)");

    // Check format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
    ASSERT(buffer[8] == '-', "UUID format check: dash at position 8");
    ASSERT(buffer[13] == '-', "UUID format check: dash at position 13");
    ASSERT(buffer[18] == '-', "UUID format check: dash at position 18");
    ASSERT(buffer[23] == '-', "UUID format check: dash at position 23");
}

/* ==================== UUID Parsing ==================== */

void test_uuid_from_string(void) {
    printf("\nTest: UUID Parsing from String\n");

    kuuid_t original = kuuid_v4();
    char original_str[37];
    kuuid_to_string(&original, original_str);

    kuuid_t parsed;
    bool result = kuuid_from_string(original_str, &parsed);
    ASSERT(result == true, "kuuid_from_string should succeed");
    ASSERT(kuuid_equal(&original, &parsed), "Parsed UUID should match original");
}

void test_uuid_parse_without_hyphens(void) {
    printf("\nTest: UUID Parsing Without Hyphens\n");

    kuuid_t original = kuuid_v4();
    char original_str[37];
    kuuid_to_string(&original, original_str);

    // Remove hyphens
    char no_hyphens[33];
    int j = 0;
    for (int i = 0; i < 36; i++) {
        if (original_str[i] != '-') {
            no_hyphens[j++] = original_str[i];
        }
    }
    no_hyphens[32] = '\0';

    kuuid_t parsed;
    bool result = kuuid_from_string(no_hyphens, &parsed);
    ASSERT(result == true, "Should parse UUID without hyphens");
    ASSERT(kuuid_equal(&original, &parsed), "Parsed UUID without hyphens should match original");
}

/* ==================== UUID Validation ==================== */

void test_uuid_validation(void) {
    printf("\nTest: UUID Validation\n");

    kuuid_t uuid = kuuid_v4();
    char valid_uuid[37];
    kuuid_to_string(&uuid, valid_uuid);

    bool valid = kuuid_is_valid(valid_uuid);
    ASSERT(valid == true, "Valid UUID should be recognized");

    // Test invalid format
    char invalid1[] = "not-a-uuid-at-all";
    bool invalid = kuuid_is_valid(invalid1);
    ASSERT(invalid == false, "Invalid format should be rejected");

    // Test short string
    char invalid2[] = "00000000";
    ASSERT(kuuid_is_valid(invalid2) == false, "Short string should be invalid");
}

/* ==================== UUID Comparison ==================== */

void test_uuid_comparison(void) {
    printf("\nTest: UUID Comparison\n");

    kuuid_t uuid1 = kuuid_v4();
    kuuid_t uuid2 = kuuid_v4();
    kuuid_t uuid1_copy;
    kuuid_copy(&uuid1_copy, &uuid1);

    // Equality
    ASSERT(kuuid_equal(&uuid1, &uuid1_copy), "Copy should be equal to original");
    ASSERT(kuuid_equal(&uuid1, &uuid2) == false, "Two different UUIDs should not be equal");

    // Compare
    int cmp_equal = kuuid_compare(&uuid1, &uuid1_copy);
    ASSERT(cmp_equal == 0, "Compare should return 0 for equal UUIDs");

    int cmp_diff = kuuid_compare(&uuid1, &uuid2);
    ASSERT(cmp_diff != 0, "Compare should not return 0 for different UUIDs");
}

/* ==================== NIL UUID ==================== */

void test_nil_uuid(void) {
    printf("\nTest: NIL UUID\n");

    kuuid_t nil_uuid = kuuid_nil();
    ASSERT(kuuid_is_nil(&nil_uuid), "kuuid_nil() should create nil UUID");

    kuuid_t v4 = kuuid_v4();
    ASSERT(kuuid_is_nil(&v4) == false, "v4 UUID should not be nil");

    char nil_str[37];
    kuuid_to_string(&nil_uuid, nil_str);
    ASSERT(strcmp(nil_str, "00000000-0000-0000-0000-000000000000") == 0,
           "NIL UUID string should be all zeros");
}

/* ==================== UUID Copy ==================== */

void test_uuid_copy(void) {
    printf("\nTest: UUID Copy\n");

    kuuid_t original = kuuid_v4();
    kuuid_t copy;

    kuuid_copy(&copy, &original);
    ASSERT(kuuid_equal(&original, &copy), "Copied UUID should equal original");

    // Modify original shouldn't affect copy (they're separate)
    kuuid_t another = kuuid_v4();
    kuuid_copy(&original, &another);
    ASSERT(kuuid_equal(&copy, &another) == false, "Modifying original shouldn't affect copy");
}

/* ==================== UUID v3 (MD5-based) ==================== */

void test_uuid_v3(void) {
    printf("\nTest: UUID v3 (MD5-based, Deterministic)\n");

    kuuid_t ns_dns = kuuid_namespace_dns();
    const char *name = "example.com";

    kuuid_t uuid1 = kuuid_v3(&ns_dns, name, strlen(name));
    kuuid_t ns_dns_copy = kuuid_namespace_dns();
    kuuid_t uuid2 = kuuid_v3(&ns_dns_copy, name, strlen(name));

    // v3 should be deterministic: same inputs = same output
    ASSERT(kuuid_equal(&uuid1, &uuid2), "v3 should be deterministic");

    // v3 should have version 3
    int ver = kuuid_get_version(&uuid1);
    ASSERT(ver == 3, "v3 should have version 3");

    // Check if recognized as deterministic
    ASSERT(kuuid_is_deterministic(&uuid1), "v3 should be recognized as deterministic");
}

/* ==================== UUID v5 (SHA-1-based) ==================== */

void test_uuid_v5(void) {
    printf("\nTest: UUID v5 (SHA-1-based, Deterministic)\n");

    kuuid_t ns_dns = kuuid_namespace_dns();
    const char *name = "www.example.com";

    kuuid_t uuid1 = kuuid_v5(&ns_dns, name, strlen(name));
    kuuid_t ns_dns_copy = kuuid_namespace_dns();
    kuuid_t uuid2 = kuuid_v5(&ns_dns_copy, name, strlen(name));

    // v5 should be deterministic: same inputs = same output
    ASSERT(kuuid_equal(&uuid1, &uuid2), "v5 should be deterministic");

    // v5 should have version 5
    int ver = kuuid_get_version(&uuid1);
    ASSERT(ver == 5, "v5 should have version 5");

    // Check if recognized as deterministic
    ASSERT(kuuid_is_deterministic(&uuid1), "v5 should be recognized as deterministic");
}

/* ==================== UUID Namespaces ==================== */

void test_uuid_namespaces(void) {
    printf("\nTest: UUID Standard Namespaces\n");

    kuuid_t ns_dns = kuuid_namespace_dns();
    kuuid_t ns_url = kuuid_namespace_url();
    kuuid_t ns_oid = kuuid_namespace_oid();
    kuuid_t ns_x500 = kuuid_namespace_x500();

    // Each namespace should be different
    ASSERT(kuuid_equal(&ns_dns, &ns_url) == false, "DNS and URL namespaces should differ");
    ASSERT(kuuid_equal(&ns_dns, &ns_oid) == false, "DNS and OID namespaces should differ");
    ASSERT(kuuid_equal(&ns_url, &ns_x500) == false, "URL and X500 namespaces should differ");

    // All should be non-nil
    ASSERT(kuuid_is_nil(&ns_dns) == false, "DNS namespace should not be nil");
    ASSERT(kuuid_is_nil(&ns_url) == false, "URL namespace should not be nil");
}

/* ==================== Base64 Encoding ==================== */

void test_uuid_base64(void) {
    printf("\nTest: Base64 Encoding/Decoding\n");

    kuuid_t original = kuuid_v4();

    char base64_buf[25];
    char *encoded = kuuid_to_base64(&original, base64_buf);
    ASSERT(encoded != NULL, "kuuid_to_base64 should succeed");
    ASSERT(strlen(base64_buf) > 0 && strlen(base64_buf) <= 24,
           "Base64 encoded UUID should be <= 24 chars");

    // Validate base64 string
    bool valid_b64 = kuuid_is_valid_base64(base64_buf);
    ASSERT(valid_b64, "Encoded string should be valid base64");

    // Decode back
    kuuid_t decoded;
    bool decode_result = kuuid_from_base64(base64_buf, &decoded);
    ASSERT(decode_result, "kuuid_from_base64 should succeed");
    ASSERT(kuuid_equal(&original, &decoded), "Decoded UUID should match original");
}

