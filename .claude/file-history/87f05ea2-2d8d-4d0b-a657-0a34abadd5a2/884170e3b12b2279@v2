/* ==================== NULL Pointer Handling ==================== */

void test_null_pointer_handling(void) {
    printf("\nTest: NULL Pointer Handling\n");

    kuuid_t uuid = kuuid_v4();

    // kuuid_to_string with NULL buffer
    char *result = kuuid_to_string(&uuid, NULL);
    ASSERT(result == NULL, "kuuid_to_string with NULL buffer should return NULL");

    // kuuid_from_string with NULL string
    bool parse_result = kuuid_from_string(NULL, &uuid);
    ASSERT(parse_result == false, "kuuid_from_string with NULL string should fail");

    // kuuid_is_valid with NULL
    bool valid_result = kuuid_is_valid(NULL);
    ASSERT(valid_result == false, "kuuid_is_valid with NULL should return false");

    // kuuid_equal with NULL
    kuuid_t uuid2 = kuuid_v4();
    bool equal_result = kuuid_equal(NULL, &uuid2);
    ASSERT(equal_result == false, "kuuid_equal with NULL should return false");
}

/* ==================== Memory Lifecycle ==================== */

void test_memory_lifecycle(void) {
    printf("\nTest: Memory Lifecycle (1000 iterations)\n");

    // This tests for memory leaks and allocation failures
    for (int i = 0; i < 1000; i++) {
        kuuid_t uuid1 = kuuid_v4();
        kuuid_t uuid2 = kuuid_v1();

        char str_buf[37];
        kuuid_to_string(&uuid1, str_buf);

        kuuid_t parsed;
        kuuid_from_string(str_buf, &parsed);

        char *allocated = kuuid_v4_alloc();
        if (allocated) free(allocated);

        // Use the UUIDs
        kuuid_equal(&uuid1, &uuid2);
        kuuid_is_nil(&uuid1);
    }

    ASSERT(true, "Memory lifecycle test completed (1000 iterations)");
}

/* ==================== Version Detection ==================== */

void test_version_detection(void) {
    printf("\nTest: UUID Version Detection\n");

    kuuid_t v1 = kuuid_v1();
    kuuid_t v4 = kuuid_v4();
    kuuid_t ns_dns = kuuid_namespace_dns();
    kuuid_t ns_dns_copy = kuuid_namespace_dns();
    kuuid_t v3 = kuuid_v3(&ns_dns, "test", 4);
    kuuid_t v5 = kuuid_v5(&ns_dns_copy, "test", 4);
    kuuid_t nil = kuuid_nil();

    ASSERT(kuuid_get_version(&v1) == 1, "v1 should be detected as version 1");
    ASSERT(kuuid_get_version(&v4) == 4, "v4 should be detected as version 4");
    ASSERT(kuuid_get_version(&v3) == 3, "v3 should be detected as version 3");
    ASSERT(kuuid_get_version(&v5) == 5, "v5 should be detected as version 5");
}

/* ==================== Hash Algorithm Detection ==================== */

void test_hash_algorithm_detection(void) {
    printf("\nTest: Hash Algorithm Detection\n");

    kuuid_t ns_dns = kuuid_namespace_dns();
    kuuid_t ns_dns_copy = kuuid_namespace_dns();
    kuuid_t v3 = kuuid_v3(&ns_dns, "test", 4);
    kuuid_t v5 = kuuid_v5(&ns_dns_copy, "test", 4);
    kuuid_t v4 = kuuid_v4();

    int algo_v3 = kuuid_get_hash_algorithm(&v3);
    int algo_v5 = kuuid_get_hash_algorithm(&v5);
    int algo_v4 = kuuid_get_hash_algorithm(&v4);

    ASSERT(algo_v3 == 3, "v3 should report MD5 algorithm (3)");
    ASSERT(algo_v5 == 5, "v5 should report SHA-1 algorithm (5)");
    ASSERT(algo_v4 == 0, "v4 should report no hash algorithm (0)");
}

