## 🎯 권고사항

### 1순위 (권장)

```c
// 1. strtok → strtok_r
int kcookie_parse(const char *cookie_header, kcookie_jar_t *jar) {
    // ...
    char *saveptr;
    char *token = strtok_r(buffer, ";", &saveptr);  // ✅
    while (token && jar->count < KCOOKIE_MAX_COOKIES) {
        // ...
        token = strtok_r(NULL, ";", &saveptr);  // ✅
    }
    // ...
}

// 2. strcpy → strncpy
void kcookie_options_init(kcookie_options_t *options) {
    // ...
    strncpy(options->path, "/", sizeof(options->path) - 1);  // ✅
    options->path[sizeof(options->path) - 1] = '\0';
    strncpy(options->same_site, "", sizeof(options->same_site) - 1);  // ✅
    options->same_site[sizeof(options->same_site) - 1] = '\0';
}

// 3. trim_whitespace 개선
static void trim_whitespace(char *str) {
    if (!str || !*str) return;  // ✅ 빈 문자열 체크

    char *start = str;
    while (*start && isspace(*start)) start++;

    size_t len = strlen(start);
    if (len == 0) {
        *str = '\0';
        return;
    }

    char *end = start + len - 1;
    while (end >= start && isspace(*end)) end--;  // >= 사용
    *(end + 1) = '\0';

    if (start != str) {
        memmove(str, start, strlen(start) + 1);
    }
}

// 4. Zero-copy 문서화
/**
 * Parse Cookie header (zero-copy version)
 *
 * WARNING: The returned jar holds pointers to the original header string.
 * The header_ref MUST remain valid and unchanged for the jar's entire lifetime.
 *
 * Example:
 *   const char *header = "name=value";
 *   kcookie_jar_zerocopy_t jar;
 *   kcookie_parse_zerocopy(header, &jar);  // jar.header_ref = header
 *
 *   // header must remain valid here
 *
 *   kcookie_get_zerocopy(&jar, "name");    // OK
 *
 *   // If header is freed, this causes use-after-free!
 *
 * @param cookie_header Cookie header (must remain valid)
 * @param jar Output jar
 * @return 0 on success, -1 on error
 */
int kcookie_parse_zerocopy(const char *cookie_header,
                           kcookie_jar_zerocopy_t *jar);
```

