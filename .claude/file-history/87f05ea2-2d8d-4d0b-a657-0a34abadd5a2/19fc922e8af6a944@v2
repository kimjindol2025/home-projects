    printf("\nTest: Range Types\n");

    ASSERT(KRANGE_NORMAL == 0, "KRANGE_NORMAL defined");
    ASSERT(KRANGE_SUFFIX == 1, "KRANGE_SUFFIX defined");
    ASSERT(KRANGE_OPEN == 2, "KRANGE_OPEN defined");
