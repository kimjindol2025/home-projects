/* ==================== Memory Lifecycle ==================== */

void test_memory_lifecycle_parsing(void) {
    printf("\nTest: Memory Lifecycle - Parsing (50 iterations)\n");

    krange_list_t list;
    const char *ranges[] = {"bytes=0-1023", "bytes=1000-2000", "bytes=-500", "bytes=5000-"};
    int range_count = sizeof(ranges) / sizeof(ranges[0]);

    for (int i = 0; i < 50; i++) {
        const char *range = ranges[i % range_count];
        int result = krange_parse(range, &list);

        if (result < -1 || result > 0) {
            // Unexpected return
            break;
        }
    }

    ASSERT(true, "Memory lifecycle test completed (50 iterations)");
}

void test_memory_lifecycle_satisfaction(void) {
    printf("\nTest: Memory Lifecycle - Satisfaction (50 iterations)\n");

    krange_t range;
    krange_result_t result;

    for (int i = 0; i < 50; i++) {
        range.type = KRANGE_NORMAL;
        range.start = i * 1000;
        range.end = (i + 1) * 1000 - 1;

        krange_satisfy(&range, 100000, &result);
    }

    ASSERT(true, "Memory lifecycle test completed (50 iterations)");
}

