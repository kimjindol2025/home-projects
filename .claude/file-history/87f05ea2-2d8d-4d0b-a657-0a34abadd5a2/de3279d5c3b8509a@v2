CC = gcc
CFLAGS = -Wall -Wextra -std=c11 -pedantic -fPIC
LDFLAGS = -shared

LIBNAME := $(shell basename $(PWD) | sed 's/-c//')
TARGET_LIB = lib$(LIBNAME).so
SOURCES = $(wildcard k$(LIBNAME)*.c)
HEADERS = $(wildcard k$(LIBNAME)*.h)
TEST_FILES = $(wildcard tests/test_*.c)
TEST_EXES = $(TEST_FILES:.c=)
OBJECTS = $(SOURCES:.c=.o)

all: $(TARGET_LIB) $(TEST_EXES)

$(TARGET_LIB): $(OBJECTS)
	$(CC) $(LDFLAGS) -o $@ $^

tests/test_%: tests/test_%.c $(OBJECTS)
	$(CC) $(CFLAGS) -I. -o $@ $< $(OBJECTS)

%.o: %.c $(HEADERS)
	$(CC) $(CFLAGS) -c $< -o $@

test: $(TEST_EXES)
	@for test in $(TEST_EXES); do \
		echo "Running $$test..."; \
		./$$test || exit 1; \
	done

test_cookie: tests/test_cookie_comprehensive
	@./tests/test_cookie_comprehensive

test_crypto: tests/test_cookie_crypto_comprehensive
	@./tests/test_cookie_crypto_comprehensive

clean:
	rm -f $(OBJECTS) $(TARGET_LIB) $(TEST_EXES)

install: $(TARGET_LIB)
	@mkdir -p /usr/local/lib /usr/local/include
	@cp $(TARGET_LIB) /usr/local/lib/
	@cp $(HEADERS) /usr/local/include/

.PHONY: all test test_cookie test_crypto clean install
