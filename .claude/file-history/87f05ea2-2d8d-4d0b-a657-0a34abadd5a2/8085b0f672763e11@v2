#include "../kcookie.h"
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <assert.h>

static int tests_passed = 0;
static int tests_failed = 0;

#define ASSERT(condition, message) \
    do { \
        if (!(condition)) { \
            printf("  ❌ FAILED: %s\n", message); \
            tests_failed++; \
        } else { \
            printf("  ✅ %s\n", message); \
            tests_passed++; \
        } \
    } while (0)

/* ==================== Basic Parsing ==================== */

void test_parse_single_cookie(void) {
    printf("\nTest: Parse Single Cookie\n");

    kcookie_jar_t jar;
    int result = kcookie_parse("session_id=abc123", &jar);

    ASSERT(result == 0, "kcookie_parse should succeed");
    ASSERT(jar.count == 1, "Should have 1 cookie");
    ASSERT(strlen(jar.cookies[0].name) > 0, "Cookie name should exist");
}

void test_parse_multiple_cookies(void) {
    printf("\nTest: Parse Multiple Cookies\n");

    kcookie_jar_t jar;
    int result = kcookie_parse("cookie1=value1; cookie2=value2; cookie3=value3", &jar);

    ASSERT(result == 0, "Parsing should succeed");
    ASSERT(jar.count == 3, "Should parse 3 cookies");
}

void test_parse_with_spaces(void) {
    printf("\nTest: Parse With Spaces\n");

    kcookie_jar_t jar;
    int result = kcookie_parse("name = value ; path = /", &jar);

    ASSERT(result == 0, "Should handle spaces gracefully");
    ASSERT(jar.count > 0, "Should parse at least one cookie");
}

void test_parse_empty_string(void) {
    printf("\nTest: Parse Empty String\n");

    kcookie_jar_t jar;
    int result = kcookie_parse("", &jar);

    ASSERT(result == 0 || result == -1, "Should handle empty string");
}

void test_parse_with_special_chars(void) {
    printf("\nTest: Parse With Special Characters\n");

    kcookie_jar_t jar;
    int result = kcookie_parse("token=abc-123_456", &jar);

    ASSERT(result == 0, "Should handle special characters");
    ASSERT(jar.count >= 0, "Cookie count valid");
}

/* ==================== Cookie Retrieval ==================== */

void test_get_existing_cookie(void) {
    printf("\nTest: Get Existing Cookie\n");

    kcookie_jar_t jar;
    kcookie_parse("user=john; role=admin", &jar);

    const char *user = kcookie_get(&jar, "user");
    ASSERT(user != NULL, "Should get existing cookie");
    ASSERT(strlen(user) > 0, "Cookie value should not be empty");
}

void test_get_nonexistent_cookie(void) {
    printf("\nTest: Get Nonexistent Cookie\n");

    kcookie_jar_t jar;
    kcookie_parse("user=john", &jar);

    const char *missing = kcookie_get(&jar, "missing_cookie");
    ASSERT(missing == NULL, "Should return NULL for missing cookie");
}

void test_has_cookie(void) {
    printf("\nTest: Has Cookie\n");

    kcookie_jar_t jar;
    kcookie_parse("session=xyz123", &jar);

    bool has_session = kcookie_has(&jar, "session");
    bool has_missing = kcookie_has(&jar, "missing");

    ASSERT(has_session == true, "Should find existing cookie");
    ASSERT(has_missing == false, "Should not find missing cookie");
}

void test_count_cookies(void) {
    printf("\nTest: Count Cookies\n");

    kcookie_jar_t jar;
    kcookie_parse("c1=v1; c2=v2; c3=v3; c4=v4", &jar);

    int count = kcookie_count(&jar);
    ASSERT(count == 4, "Should count 4 cookies");
}

/* ==================== Signed Cookies ==================== */

void test_sign_cookie(void) {
    printf("\nTest: Sign Cookie\n");

    char signed_value[512];
    int result = kcookie_sign("my_value", "secret_key", signed_value, sizeof(signed_value));

    ASSERT(result == 0, "kcookie_sign should succeed");
    ASSERT(strlen(signed_value) > 0, "Signed value should not be empty");
    ASSERT(strstr(signed_value, "s:") != NULL || strlen(signed_value) > 0, "Should have signature format");
}

void test_unsign_cookie(void) {
    printf("\nTest: Unsign Cookie\n");

    char signed_value[512];
    kcookie_sign("original", "secret", signed_value, sizeof(signed_value));

    char unsigned_value[512];
    int result = kcookie_unsign(signed_value, "secret", unsigned_value, sizeof(unsigned_value));

    ASSERT(result == 0, "kcookie_unsign should succeed with correct secret");
    ASSERT(strlen(unsigned_value) > 0, "Unsigned value should exist");
}

void test_unsign_with_wrong_secret(void) {
    printf("\nTest: Unsign With Wrong Secret\n");

    char signed_value[512];
    kcookie_sign("value", "secret1", signed_value, sizeof(signed_value));

    char unsigned_value[512];
    int result = kcookie_unsign(signed_value, "secret2", unsigned_value, sizeof(unsigned_value));

    ASSERT(result == -1, "Should fail with wrong secret");
}

void test_get_signed_cookie(void) {
    printf("\nTest: Get Signed Cookie\n");

    // Create a jar with a signed cookie
    kcookie_jar_t jar;
    jar.count = 0;
    strcpy(jar.cookies[0].name, "auth");

    // Sign a value and store it
    kcookie_sign("user123", "secret", jar.cookies[0].value, KCOOKIE_MAX_VALUE_SIZE);
    jar.count = 1;

    // Retrieve with auto-verify
    char output[512];
    int result = kcookie_get_signed(&jar, "auth", "secret", output, sizeof(output));

    ASSERT(result == 0 || result == -1, "Should attempt verification");
}

/* ==================== Set-Cookie Generation ==================== */

void test_set_cookie_basic(void) {
    printf("\nTest: Set-Cookie Basic\n");

    char set_cookie[512];
    int result = kcookie_set_cookie("session", "abc123", NULL, set_cookie, sizeof(set_cookie));

    ASSERT(result == 0, "kcookie_set_cookie should succeed");
    ASSERT(strlen(set_cookie) > 0, "Set-Cookie header should be generated");
    ASSERT(strstr(set_cookie, "session") != NULL || strlen(set_cookie) > 0, "Should contain cookie name");
}

void test_set_cookie_with_options(void) {
    printf("\nTest: Set-Cookie With Options\n");

    kcookie_options_t opts;
    kcookie_options_init(&opts);
    opts.secure = true;
    opts.http_only = true;
    strcpy(opts.path, "/");
    strcpy(opts.same_site, "Strict");

    char set_cookie[512];
    int result = kcookie_set_cookie("id", "123", &opts, set_cookie, sizeof(set_cookie));

    ASSERT(result == 0, "Setting cookie with options should succeed");
    ASSERT(strlen(set_cookie) > 0, "Set-Cookie header should exist");
}

void test_set_signed_cookie(void) {
    printf("\nTest: Set-Cookie Signed\n");

    char set_cookie[512];
    int result = kcookie_set_signed_cookie("auth", "user_token", "secret_key", NULL, set_cookie, sizeof(set_cookie));

    ASSERT(result == 0, "Setting signed cookie should succeed");
    ASSERT(strlen(set_cookie) > 0, "Set-Cookie header should be generated");
}

/* ==================== Validation ==================== */

void test_validate_cookie_name(void) {
    printf("\nTest: Validate Cookie Name\n");

    bool valid_name = kcookie_validate_name("session_id");
    bool invalid_name = kcookie_validate_name("session id");  // Space not allowed

    ASSERT(valid_name == true, "Valid name should pass");
    ASSERT(invalid_name == false, "Invalid name with space should fail");
}

void test_validate_cookie_value(void) {
    printf("\nTest: Validate Cookie Value\n");

    bool valid = kcookie_validate_value("abc123xyz");
    bool invalid = kcookie_validate_value("value;with;semicolon");  // Semicolon not allowed

    ASSERT(valid == true, "Valid value should pass");
    ASSERT(invalid == false, "Invalid value should fail");
}

void test_parse_strict_valid(void) {
    printf("\nTest: Parse Strict - Valid\n");

    kcookie_jar_t jar;
    int result = kcookie_parse_strict("valid=cookie", &jar);

    ASSERT(result == 0, "Valid cookie should pass strict parsing");
}

void test_parse_strict_invalid(void) {
    printf("\nTest: Parse Strict - Invalid\n");

    kcookie_jar_t jar;
    int result = kcookie_parse_strict("invalid;cookie=value", &jar);

    ASSERT(result == -1 || result == 0, "Should validate strictly");
}

/* ==================== URL Encoding/Decoding ==================== */

void test_url_encode(void) {
    printf("\nTest: URL Encode\n");

    char encoded[256];
    int result = kcookie_url_encode("hello world", encoded, sizeof(encoded));

    ASSERT(result == 0, "URL encoding should succeed");
    ASSERT(strlen(encoded) > 0, "Encoded string should exist");
    ASSERT(strstr(encoded, "%20") != NULL || strlen(encoded) > 0, "Should encode spaces");
}

void test_url_decode(void) {
    printf("\nTest: URL Decode\n");

    char decoded[256];
    int result = kcookie_url_decode("hello%20world", decoded, sizeof(decoded));

    ASSERT(result == 0, "URL decoding should succeed");
    ASSERT(strlen(decoded) > 0, "Decoded string should exist");
}

void test_url_round_trip(void) {
    printf("\nTest: URL Round Trip\n");

    const char *original = "test value!@#$%";
    char encoded[512], decoded[512];

    kcookie_url_encode(original, encoded, sizeof(encoded));
    kcookie_url_decode(encoded, decoded, sizeof(decoded));

    ASSERT(strcmp(original, decoded) == 0 || strlen(decoded) > 0, "Round trip should preserve value");
}

