void test_count_zerocopy(void) {
    printf("\nTest: Count Zero-Copy\n");

    const char *header = "c1=v1; c2=v2; c3=v3";
    kcookie_jar_zerocopy_t jar;
    kcookie_parse_zerocopy(header, &jar);

