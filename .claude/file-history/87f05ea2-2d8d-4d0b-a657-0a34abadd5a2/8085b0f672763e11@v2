void test_parse_zerocopy(void) {
    printf("\nTest: Parse Zero-Copy\n");

    const char *header = "cookie1=value1; cookie2=value2";
    kcookie_jar_zerocopy_t jar;
    int result = kcookie_parse_zerocopy(header, &jar);

    ASSERT(result == 0, "Zero-copy parsing should succeed");
    ASSERT(jar.count > 0, "Should parse cookies");
}

void test_get_zerocopy(void) {
    printf("\nTest: Get Zero-Copy\n");

    const char *header = "session=xyz123";
    kcookie_jar_zerocopy_t jar;
    kcookie_parse_zerocopy(header, &jar);

    char value[256];
    int result = kcookie_get_zerocopy(&jar, "session", value, sizeof(value));

    ASSERT(result == 0, "Getting zero-copy cookie should succeed");
    ASSERT(strlen(value) > 0, "Value should be returned");
}

void test_has_zerocopy(void) {
    printf("\nTest: Has Zero-Copy\n");

    const char *header = "token=abc";
    kcookie_jar_zerocopy_t jar;
    kcookie_parse_zerocopy(header, &jar);

