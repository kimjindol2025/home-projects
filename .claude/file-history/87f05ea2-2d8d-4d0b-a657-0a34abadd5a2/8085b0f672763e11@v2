void test_get_raw(void) {
    printf("\nTest: Get Raw (Zero-Copy)\n");

    const char *header = "cookie=value";
    kcookie_jar_zerocopy_t jar;
    kcookie_parse_zerocopy(header, &jar);

    const char *ptr;
    size_t len;
    bool needs_decode;
    int result = kcookie_get_raw(&jar, "cookie", &ptr, &len, &needs_decode);

    ASSERT(result == 0, "Getting raw pointer should succeed");
    ASSERT(len > 0, "Value length should be > 0");
}

/* ==================== Memory Lifecycle ==================== */

void test_memory_lifecycle_parsing(void) {
    printf("\nTest: Memory Lifecycle - Parsing (100 iterations)\n");

    char headers[100][256];
    for (int i = 0; i < 100; i++) {
        snprintf(headers[i], sizeof(headers[i]), "cookie_%d=value_%d", i, i);
    }

    for (int i = 0; i < 100; i++) {
        kcookie_jar_t jar;
        int result = kcookie_parse(headers[i], &jar);

        if (result < -1) {
            ASSERT(false, "Parsing failed");
            break;
        }
    }

    ASSERT(true, "Memory lifecycle test completed (100 iterations)");
}

void test_memory_lifecycle_signing(void) {
    printf("\nTest: Memory Lifecycle - Signing (100 iterations)\n");

    for (int i = 0; i < 100; i++) {
        char value[256];
        snprintf(value, sizeof(value), "value_%d", i);

        char signed_val[512];
        int result = kcookie_sign(value, "key", signed_val, sizeof(signed_val));

        if (result < -1) {
            ASSERT(false, "Signing failed");
            break;
        }
    }

    ASSERT(true, "Memory lifecycle test completed (100 iterations)");
}

/* ==================== NULL Pointer Safety ==================== */

void test_null_pointer_safety(void) {
    printf("\nTest: NULL Pointer Safety\n");

    kcookie_jar_t jar;
    kcookie_parse("test=value", &jar);

    // NULL jar
    const char *result = kcookie_get(NULL, "test");
    // Should handle gracefully

    // NULL name
    kcookie_has(&jar, NULL);

    // NULL header
    kcookie_parse(NULL, &jar);

    ASSERT(true, "NULL pointer operations handled");
}

