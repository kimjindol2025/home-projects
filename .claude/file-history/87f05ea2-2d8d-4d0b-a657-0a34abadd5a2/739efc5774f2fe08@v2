/*
 * Moment-C Comprehensive Test Suite
 *
 * Test Coverage:
 * - Moment creation (now, unix, date)
 * - Moment parsing and formatting
 * - Datetime operations (clone, compare)
 * - Format conversions (ISO 8601, custom)
 * - Timestamp operations
 * - Memory lifecycle
 * - NULL pointer safety
 */

#include "../kmoment.h"
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>
#include <assert.h>

static int tests_passed = 0;
static int tests_failed = 0;

#define ASSERT(condition, message) \
    do { \
        if (!(condition)) { \
            printf("  ❌ FAILED: %s\n", message); \
            tests_failed++; \
        } else { \
            printf("  ✅ %s\n", message); \
            tests_passed++; \
        } \
    } while (0)

/* ==================== Moment Creation ==================== */

void test_moment_now(void) {
    printf("\nTest: Moment Now\n");

    kmoment_t *m = kmoment_now();
    ASSERT(m != NULL, "kmoment_now should return non-NULL");
    ASSERT(m->timestamp > 0, "Timestamp should be > 0");

    kmoment_free(m);
    ASSERT(true, "kmoment_free should complete");
}

void test_moment_unix(void) {
    printf("\nTest: Moment Unix\n");

    time_t now = time(NULL);
    kmoment_t *m = kmoment_unix(now);

    ASSERT(m != NULL, "kmoment_unix should return non-NULL");
    ASSERT(m->timestamp == now, "Timestamp should match input");

    kmoment_free(m);
}

void test_moment_date(void) {
    printf("\nTest: Moment Date\n");

    kmoment_t *m = kmoment_date(2025, 1, 22, 10, 30, 45);
    ASSERT(m != NULL, "kmoment_date should return non-NULL");
    ASSERT(m->timestamp > 0, "Timestamp should be valid");

    kmoment_free(m);
}

void test_moment_date_various(void) {
    printf("\nTest: Moment Date - Various\n");

    // Test different dates
    kmoment_t *m1 = kmoment_date(2000, 1, 1, 0, 0, 0);
    ASSERT(m1 != NULL, "Year 2000 date");
    kmoment_free(m1);

    kmoment_t *m2 = kmoment_date(2025, 12, 31, 23, 59, 59);
    ASSERT(m2 != NULL, "Year 2025 end date");
    kmoment_free(m2);

    ASSERT(true, "Various dates handled");
}

/* ==================== Moment Clone ==================== */

void test_moment_clone(void) {
    printf("\nTest: Moment Clone\n");

    kmoment_t *original = kmoment_now();
    kmoment_t *cloned = kmoment_clone(original);

    ASSERT(cloned != NULL, "kmoment_clone should return non-NULL");
    ASSERT(original->timestamp == cloned->timestamp, "Timestamps should match");

    kmoment_free(original);
    kmoment_free(cloned);
    ASSERT(true, "Both moments freed");
}

/* ==================== Moment Parsing ==================== */

void test_moment_parse_date(void) {
    printf("\nTest: Moment Parse - Date\n");

    kmoment_t *m = kmoment_parse("2025-01-22");
    ASSERT(m != NULL, "kmoment_parse should parse date string");
    ASSERT(m->timestamp > 0, "Timestamp should be valid");

    kmoment_free(m);
}

void test_moment_parse_datetime(void) {
    printf("\nTest: Moment Parse - DateTime\n");

    kmoment_t *m = kmoment_parse("2025-01-22 10:30:45");
    ASSERT(m != NULL, "kmoment_parse should parse datetime string");
    ASSERT(m->timestamp > 0, "Timestamp should be valid");

    kmoment_free(m);
}

void test_moment_parse_unix(void) {
    printf("\nTest: Moment Parse - Unix\n");

    time_t now = time(NULL);
    char unix_str[64];
    snprintf(unix_str, sizeof(unix_str), "%ld", (long)now);

    kmoment_t *m = kmoment_parse_unix(unix_str);
    ASSERT(m != NULL, "kmoment_parse_unix should parse unix timestamp");

    kmoment_free(m);
}

/* ==================== Moment Formatting ==================== */

void test_moment_format_iso(void) {
    printf("\nTest: Moment Format - ISO 8601\n");

    kmoment_t *m = kmoment_now();
    char *iso = kmoment_to_iso_string(m);

    ASSERT(iso != NULL, "kmoment_to_iso_string should return non-NULL");
    ASSERT(strlen(iso) > 0, "ISO string should not be empty");
    ASSERT(strchr(iso, 'T') != NULL || strchr(iso, '-') != NULL, "ISO format check");

    free(iso);
    kmoment_free(m);
}

void test_moment_to_string(void) {
    printf("\nTest: Moment To String\n");

    kmoment_t *m = kmoment_now();
    char *str = kmoment_to_string(m);

    ASSERT(str != NULL, "kmoment_to_string should return non-NULL");
    ASSERT(strlen(str) > 0, "String should not be empty");

    free(str);
    kmoment_free(m);
}

void test_moment_format_custom(void) {
    printf("\nTest: Moment Format - Custom\n");

    kmoment_t *m = kmoment_date(2025, 1, 22, 10, 30, 45);
    char *formatted = kmoment_format(m, "YYYY-MM-DD");

    ASSERT(formatted != NULL, "kmoment_format should return non-NULL");
    ASSERT(strlen(formatted) > 0, "Formatted string should not be empty");

    free(formatted);
    kmoment_free(m);
}

void test_moment_format_various(void) {
    printf("\nTest: Moment Format - Various Formats\n");

    kmoment_t *m = kmoment_now();

    // Test different format strings
    char *fmt1 = kmoment_format(m, "YYYY-MM-DD");
    ASSERT(fmt1 != NULL && strlen(fmt1) > 0, "YYYY-MM-DD format");
    free(fmt1);

    char *fmt2 = kmoment_format(m, "HH:mm:ss");
    ASSERT(fmt2 != NULL && strlen(fmt2) > 0, "HH:mm:ss format");
    free(fmt2);

    char *fmt3 = kmoment_format(m, "YYYY-MM-DD HH:mm:ss");
    ASSERT(fmt3 != NULL && strlen(fmt3) > 0, "Full datetime format");
    free(fmt3);

    kmoment_free(m);
}

/* ==================== Moment Comparison ==================== */

void test_moment_timestamp_comparison(void) {
    printf("\nTest: Moment Timestamp Comparison\n");

    kmoment_t *m1 = kmoment_date(2025, 1, 1, 0, 0, 0);
    kmoment_t *m2 = kmoment_date(2025, 1, 2, 0, 0, 0);

    ASSERT(m1->timestamp < m2->timestamp, "Earlier date should have smaller timestamp");

    kmoment_free(m1);
    kmoment_free(m2);
}

/* ==================== Moment Arithmetic ==================== */

void test_moment_year_month_day(void) {
    printf("\nTest: Moment Year/Month/Day Components\n");

    kmoment_t *m = kmoment_date(2025, 3, 15, 10, 30, 45);

    ASSERT(m->tm.tm_year + 1900 == 2025, "Year component");
    ASSERT(m->tm.tm_mon + 1 == 3, "Month component");
    ASSERT(m->tm.tm_mday == 15, "Day component");

    kmoment_free(m);
}

void test_moment_hour_minute_second(void) {
    printf("\nTest: Moment Hour/Minute/Second Components\n");

    kmoment_t *m = kmoment_date(2025, 3, 15, 14, 30, 45);

    ASSERT(m->tm.tm_hour == 14, "Hour component");
    ASSERT(m->tm.tm_min == 30, "Minute component");
    ASSERT(m->tm.tm_sec == 45, "Second component");

    kmoment_free(m);
}

/* ==================== Memory Lifecycle ==================== */

void test_memory_lifecycle_creation(void) {
    printf("\nTest: Memory Lifecycle - Creation (100 iterations)\n");

    for (int i = 0; i < 100; i++) {
        kmoment_t *m = kmoment_date(2020 + (i % 10), (i % 12) + 1, (i % 28) + 1,
                                     (i % 24), (i % 60), (i % 60));
        if (m == NULL) {
            ASSERT(false, "Moment creation failed");
            break;
        }

        kmoment_free(m);
    }

    ASSERT(true, "Memory lifecycle test completed (100 iterations)");
}

void test_memory_lifecycle_formatting(void) {
    printf("\nTest: Memory Lifecycle - Formatting (100 iterations)\n");

    kmoment_t *m = kmoment_now();

    for (int i = 0; i < 100; i++) {
        char *formatted = kmoment_format(m, "YYYY-MM-DD HH:mm:ss");
        if (formatted) {
            free(formatted);
        }
    }

    kmoment_free(m);
    ASSERT(true, "Memory lifecycle test completed (100 iterations)");
}

/* ==================== NULL Pointer Safety ==================== */

void test_null_pointer_safety(void) {
    printf("\nTest: NULL Pointer Safety\n");

    // NULL parsing
    kmoment_t *m = kmoment_parse(NULL);
    // Should handle gracefully (may return NULL)

    // Free NULL
    kmoment_free(NULL);

    ASSERT(true, "NULL pointer operations handled");
}

/* ==================== Timestamp Validation ==================== */

void test_timestamp_positive(void) {
    printf("\nTest: Timestamp Positive\n");

    kmoment_t *m = kmoment_now();
    ASSERT(m->timestamp > 0, "Current timestamp should be positive");
    kmoment_free(m);
}

void test_timestamp_range(void) {
    printf("\nTest: Timestamp Range\n");

    kmoment_t *m = kmoment_date(2000, 1, 1, 0, 0, 0);
    time_t y2k = m->timestamp;
    kmoment_free(m);

    m = kmoment_date(2050, 12, 31, 23, 59, 59);
    time_t future = m->timestamp;
    kmoment_free(m);

    ASSERT(future > y2k, "Future timestamp should be > Y2K timestamp");
}

