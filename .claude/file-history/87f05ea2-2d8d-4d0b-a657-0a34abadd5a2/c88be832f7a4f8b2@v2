## 🎯 권고사항

```c
// 1. strtok() → strtok_r() 변경
int kcookie_parse(const char *cookie_header, kcookie_jar_t *jar) {
    if (!cookie_header || !jar) return -1;

    memset(jar, 0, sizeof(kcookie_jar_t));

    char buffer[8192];
    strncpy(buffer, cookie_header, sizeof(buffer) - 1);
    buffer[sizeof(buffer) - 1] = '\0';

    char *saveptr;  // ✅ strtok_r 상태
    char *token = strtok_r(buffer, ";", &saveptr);  // ✅ 변경
    while (token && jar->count < KCOOKIE_MAX_COOKIES) {
        // ...
        token = strtok_r(NULL, ";", &saveptr);  // ✅ 변경
    }

    return 0;
}

// 2. strcpy() → strncpy() 변경
void kcookie_options_init(kcookie_options_t *options) {
    if (!options) return;

    memset(options, 0, sizeof(kcookie_options_t));
    options->max_age = -1;
    strncpy(options->path, "/", sizeof(options->path) - 1);  // ✅
    options->path[sizeof(options->path) - 1] = '\0';        // ✅
    options->secure = false;
    options->http_only = false;
    strncpy(options->same_site, "", sizeof(options->same_site) - 1);  // ✅
    options->same_site[sizeof(options->same_site) - 1] = '\0';       // ✅
}

// 3. trim_whitespace() 수정
static void trim_whitespace(char *str) {
    if (!str || !*str) return;  // ✅ empty 체크

    char *start = str;
    while (*start && isspace(*start)) start++;

    size_t start_len = strlen(start);
    if (start_len == 0) {
        *str = '\0';  // ✅ empty string 처리
        return;
    }

    char *end = start + start_len - 1;
    while (end > start && isspace(*end)) end--;
    *(end + 1) = '\0';

    if (start != str) {
        memmove(str, start, strlen(start) + 1);
    }
}
```

