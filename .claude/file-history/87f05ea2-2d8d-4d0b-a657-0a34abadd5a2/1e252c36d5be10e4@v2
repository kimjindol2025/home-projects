/* ==================== Memory Lifecycle ==================== */

void test_memory_lifecycle_connections(void) {
    printf("\nTest: Memory Lifecycle - Connections (30 iterations)\n");

    for (int i = 0; i < 30; i++) {
        kconnect_t *conn = kconnect_create("127.0.0.1", 8000 + i);

        if (conn) {
            kconnect_close(conn);
        }
    }

    ASSERT(true, "Memory lifecycle test completed (30 iterations)");
}

void test_memory_lifecycle_send_recv(void) {
    printf("\nTest: Memory Lifecycle - Send/Recv (50 iterations)\n");

    kconnect_t *conn = kconnect_create("127.0.0.1", 8080);

    if (conn && conn->fd >= 0) {
        for (int i = 0; i < 50; i++) {
            char data[64];
            snprintf(data, sizeof(data), "Message %d", i);

            kconnect_send(conn, data, strlen(data));

            char buffer[256];
            kconnect_recv(conn, buffer, sizeof(buffer));
        }

        kconnect_close(conn);
    }

    ASSERT(true, "Memory lifecycle test completed (50 iterations)");
}

/* ==================== NULL Pointer Safety ==================== */

void test_null_pointer_safety(void) {
    printf("\nTest: NULL Pointer Safety\n");

    // NULL host
    kconnect_t *conn = kconnect_create(NULL, 8080);

    if (conn) {
        // NULL data
        kconnect_send(conn, NULL, 10);

        // NULL buffer
        kconnect_recv(conn, NULL, 256);

        kconnect_close(conn);
    }

    // NULL connection
    if (conn) {
        kconnect_close(conn);
    }

    ASSERT(true, "NULL pointer operations handled");
}

