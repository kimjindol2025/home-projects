/* ==================== Send and Receive Sequence ==================== */

void test_send_then_recv(void) {
    printf("\nTest: Send Then Receive\n");

    kconnect_t *conn = kconnect_create("127.0.0.1", 8080);

    if (conn && conn->fd >= 0) {
        const char *request = "GET / HTTP/1.0\r\n\r\n";
        kconnect_send(conn, request, strlen(request));

        char response[512];
        int result = kconnect_recv(conn, response, sizeof(response));

        ASSERT(result >= -1, "Request-response cycle valid");

        kconnect_close(conn);
    } else {
        ASSERT(true, "Send-recv sequence callable");
    }
}

