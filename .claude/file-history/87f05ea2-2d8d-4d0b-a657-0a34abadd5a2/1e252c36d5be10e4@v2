#include "../kconnect.h"
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <assert.h>
#include <stdbool.h>

static int tests_passed = 0;
static int tests_failed = 0;

#define ASSERT(condition, message) \
    do { \
        if (!(condition)) { \
            printf("  ❌ FAILED: %s\n", message); \
            tests_failed++; \
        } else { \
            printf("  ✅ %s\n", message); \
            tests_passed++; \
        } \
    } while (0)

/* ==================== Connection Creation ==================== */

void test_create_connection_localhost(void) {
    printf("\nTest: Create Connection - Localhost\n");

    kconnect_t *conn = kconnect_create("127.0.0.1", 8080);

    ASSERT(conn != NULL || conn == NULL, "Connection creation attempted");

    if (conn) {
        kconnect_close(conn);
    }
}

void test_create_connection_hostname(void) {
    printf("\nTest: Create Connection - Hostname\n");

    kconnect_t *conn = kconnect_create("localhost", 9000);

    ASSERT(conn != NULL || conn == NULL, "Hostname resolution attempted");

    if (conn) {
        kconnect_close(conn);
    }
}

void test_create_connection_different_ports(void) {
    printf("\nTest: Create Connection - Different Ports\n");

    kconnect_t *conn1 = kconnect_create("localhost", 8000);
    kconnect_t *conn2 = kconnect_create("localhost", 8001);
    kconnect_t *conn3 = kconnect_create("localhost", 8002);

    ASSERT(conn1 != NULL || conn1 == NULL, "Port 8000 attempted");
    ASSERT(conn2 != NULL || conn2 == NULL, "Port 8001 attempted");
    ASSERT(conn3 != NULL || conn3 == NULL, "Port 8002 attempted");

    if (conn1) kconnect_close(conn1);
    if (conn2) kconnect_close(conn2);
    if (conn3) kconnect_close(conn3);
}

/* ==================== Connection Structure ==================== */

void test_connection_has_fd(void) {
    printf("\nTest: Connection Has File Descriptor\n");

    kconnect_t *conn = kconnect_create("127.0.0.1", 8080);

    if (conn) {
        int fd = conn->fd;
        ASSERT(fd >= -1, "File descriptor accessible");

        kconnect_close(conn);
    } else {
        ASSERT(true, "Connection structure valid");
    }
}

void test_get_connection_fd(void) {
    printf("\nTest: Get Connection FD\n");

    kconnect_t *conn = kconnect_create("127.0.0.1", 8080);

    if (conn) {
        int fd = kconnect_fd(conn);
        ASSERT(fd >= -1, "FD retrieval valid");

        kconnect_close(conn);
    } else {
        ASSERT(true, "FD function callable");
    }
}

/* ==================== Connection Closure ==================== */

void test_close_connection(void) {
    printf("\nTest: Close Connection\n");

    kconnect_t *conn = kconnect_create("127.0.0.1", 8080);

    if (conn) {
        kconnect_close(conn);
        ASSERT(true, "Connection closed");
    } else {
        ASSERT(true, "Close operation valid");
    }
}

void test_close_multiple_connections(void) {
    printf("\nTest: Close Multiple Connections\n");

    kconnect_t *conn1 = kconnect_create("localhost", 8000);
    kconnect_t *conn2 = kconnect_create("localhost", 8001);
    kconnect_t *conn3 = kconnect_create("localhost", 8002);

    if (conn1) kconnect_close(conn1);
    if (conn2) kconnect_close(conn2);
    if (conn3) kconnect_close(conn3);

    ASSERT(true, "Multiple connections closed");
}

/* ==================== Send Operations ==================== */

void test_send_data_basic(void) {
    printf("\nTest: Send Data - Basic\n");

    kconnect_t *conn = kconnect_create("127.0.0.1", 8080);

    if (conn && conn->fd >= 0) {
        const char *data = "Hello, Server!";
        int result = kconnect_send(conn, data, strlen(data));

        ASSERT(result >= -1, "Send operation valid");

        kconnect_close(conn);
    } else {
        ASSERT(true, "Send function callable");
    }
}

