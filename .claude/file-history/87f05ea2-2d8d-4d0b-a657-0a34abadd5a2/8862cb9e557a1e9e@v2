/* ==================== Memory Lifecycle ==================== */

void test_memory_lifecycle_creation(void) {
    printf("\nTest: Memory Lifecycle - Creation (50 iterations)\n");

    for (int i = 0; i < 50; i++) {
        kknex_query_t *q = kknex_new();
        if (q == NULL) {
            ASSERT(false, "Query creation failed");
            break;
        }

        char table[256];
        snprintf(table, sizeof(table), "table_%d", i);
        kknex_table(q, table);

        kknex_free(q);
    }

    ASSERT(true, "Memory lifecycle test completed (50 iterations)");
}

void test_memory_lifecycle_query_building(void) {
    printf("\nTest: Memory Lifecycle - Query Building (50 iterations)\n");

    for (int i = 0; i < 50; i++) {
        kknex_query_t *q = kknex_new();

        kknex_table(q, "users");
        kknex_select(q, "*");
        kknex_where(q, "id > 0");
        kknex_order_by(q, "id", "ASC");
        kknex_limit(q, 10);

        char *sql = kknex_to_select(q);
        if (sql == NULL) {
            ASSERT(false, "Query generation failed");
            kknex_free(q);
            break;
        }

        kknex_free(q);
    }

    ASSERT(true, "Memory lifecycle test completed (50 iterations)");
}

/* ==================== NULL Pointer Safety ==================== */

void test_null_pointer_safety(void) {
    printf("\nTest: NULL Pointer Safety\n");

    kknex_query_t *q = kknex_new();

    // NULL table
    kknex_table(q, NULL);

    // NULL columns
    kknex_select(q, NULL);

    // NULL where clause
    kknex_where(q, NULL);

    // NULL join table
    kknex_join(q, NULL, "condition");

    kknex_free(q);
    ASSERT(true, "NULL pointer operations handled");
}

