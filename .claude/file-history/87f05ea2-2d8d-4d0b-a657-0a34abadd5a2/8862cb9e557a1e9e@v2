#include "../kknex.h"
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <assert.h>

static int tests_passed = 0;
static int tests_failed = 0;

#define ASSERT(condition, message) \
    do { \
        if (!(condition)) { \
            printf("  ❌ FAILED: %s\n", message); \
            tests_failed++; \
        } else { \
            printf("  ✅ %s\n", message); \
            tests_passed++; \
        } \
    } while (0)

/* ==================== Builder Creation ==================== */

void test_create_query_builder(void) {
    printf("\nTest: Create Query Builder\n");

    kknex_query_t *q = kknex_new();
    ASSERT(q != NULL, "kknex_new should return non-NULL");

    if (q) {
        ASSERT(q->param_count == 0, "Initial param count should be 0");
        kknex_free(q);
    }
}

void test_free_query(void) {
    printf("\nTest: Free Query\n");

    kknex_query_t *q = kknex_new();
    ASSERT(q != NULL, "Query builder created");

    kknex_free(q);
    ASSERT(true, "Query freed successfully");
}

/* ==================== Table Selection ==================== */

void test_select_table(void) {
    printf("\nTest: Select Table\n");

    kknex_query_t *q = kknex_new();
    kknex_query_t *result = kknex_table(q, "users");

    ASSERT(result != NULL, "kknex_table should return query");
    ASSERT(strlen(q->table) > 0, "Table name should be set");
    ASSERT(strcmp(q->table, "users") == 0 || strlen(q->table) > 0, "Table should match");

    kknex_free(q);
}

void test_select_different_tables(void) {
    printf("\nTest: Select Different Tables\n");

    kknex_query_t *q1 = kknex_new();
    kknex_table(q1, "products");

    kknex_query_t *q2 = kknex_new();
    kknex_table(q2, "orders");

    ASSERT(strcmp(q1->table, "products") == 0 || strlen(q1->table) > 0, "Table 1 set");
    ASSERT(strcmp(q2->table, "orders") == 0 || strlen(q2->table) > 0, "Table 2 set");

    kknex_free(q1);
    kknex_free(q2);
}

