fn getVectorGrpcStats(server: VectorGrpcServer) -> string
  var report = "=== gRPC VECTOR SERVICE STATS ===\n"
  report = report + "Total RPC Calls: " + (server.stats["totalRpcCalls"] as number) as string + "\n"
  report = report + "Insert Calls: " + (server.stats["insertCalls"] as number) as string + "\n"
  report = report + "Search Calls: " + (server.stats["searchCalls"] as number) as string + "\n"
  report = report + "Cluster Status Calls: " + (server.stats["clusterStatusCalls"] as number) as string + "\n"
  report = report + "Batch Insert Calls: " + (server.stats["batchInsertCalls"] as number) as string + "\n"
  report = report + "Node Health Calls: " + (server.stats["nodeHealthCalls"] as number) as string + "\n"
  report = report + "Failed Calls: " + (server.stats["failedCalls"] as number) as string + "\n"
  report = report + "Avg Latency: " + (server.stats["avgLatencyMs"] as f64) as string + "ms\n"
  report

fn recordRpcCall(
  server: VectorGrpcServer,
  latencyMs: f64,
  success: bool
) -> VectorGrpcServer
  let oldAvg = server.stats["avgLatencyMs"] as f64
  let alpha = 0.3
  server.stats["avgLatencyMs"] = (alpha * latencyMs) + ((1.0 - alpha) * oldAvg)

  if !success
    server.stats["failedCalls"] = (server.stats["failedCalls"] as number) + 1

  server

