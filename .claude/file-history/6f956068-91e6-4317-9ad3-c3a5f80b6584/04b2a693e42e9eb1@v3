// v5.8: 데이터 모델링 실전 프로젝트 — 통합 보안 관제 시스템
// 철학: "데이터 구조가 시스템을 정의한다"
// 설계 목표: 데이터 소유권 지도, 불변성, 에러 핸들링 내재화

// ============================================================
// [1단계] 상태 정의 — 노드가 가질 수 있는 모든 상태 (v5.2 Enum)
// ============================================================

enum NodeStatus {
    Active,                          // 정상 운영
    Warning(String),                 // 경고 상태 (이유 포함)
    Critical,                        // 치명적 위기
}

// ============================================================
// [2단계] 개별 노드 정의 — 보안 관제의 최소 단위 (v5.0 Struct)
// ============================================================

struct SecurityNode {
    id: u32,                         // 노드 식별자
    location: String,                // 물리적 위치
    status: NodeStatus,              // 현재 상태
    last_check: String,              // 마지막 점검 시간
}

// ============================================================
// [3단계] 관제 기록 — 상태 변화의 역사 (v5.0 Struct)
// ============================================================

struct StatusChange {
    node_id: u32,
    old_status: String,
    new_status: String,
    timestamp: String,
    reason: Option<String>,         // 변경 이유 (v5.3 Option)
}

// ============================================================
// [4단계] 관제 센터 — 모든 데이터의 소유자 (v5.0 Struct + v5.5 Vec + v5.7 HashMap)
// ============================================================

struct ControlCenter {
    center_name: String,
    nodes: String,                  // HashMap<u32, SecurityNode> — 노드 저장소 (v5.7)
    logs: String,                   // Vec<String> — 작업 로그 (v5.5)
    status_history: String,         // Vec<StatusChange> — 상태 변화 이력 (v5.5)
    total_checks: u32,              // 누적 점검 횟수
}

// ============================================================
// [5단계] 관제 센터 메서드 구현 (v5.1 impl)
// ============================================================

// impl ControlCenter 블록
// new() — 새로운 관제 센터 초기화
fn new_control_center(name: String) -> String {
    \"center:initialized\"
}

// register_node() — 노드 등록 (메서드를 통한 캡슐화)
fn register_node(center: String, id: u32, location: String) -> String {
    \"node:registered\"
}

// update_node_status() — 노드 상태 업데이트 (Option 활용)
fn update_node_status(center: String, node_id: u32, new_status: String) -> String {
    \"status:updated\"
}

// update_node_status_with_reason() — 이유를 포함한 상태 업데이트
fn update_node_status_with_reason(
    center: String,
    node_id: u32,
    new_status: String,
    reason: Option<String>
) -> String {
    \"status:updated:with_reason\"
}

// ============================================================
// [패턴 1] 감사 및 점검 — pattern matching 활용 (v5.4 Pattern Matching)
// ============================================================

// audit() — 전체 노드의 상태를 점검하고 리포트 (Pattern Matching)
fn audit_control_center(center: String) -> String {
    // match NodeStatus 패턴으로 각 상태에 대응
    // Active => \"정상\"
    // Warning(msg) => format!(\"주의: {}\", msg)
    // Critical => \"치명적 위기\"
    \"audit:complete\"
}

// get_active_nodes() — 정상 상태 노드만 조회
fn get_active_nodes(center: String) -> String {
    \"active:nodes:found\"
}

// get_warning_nodes() — 경고 상태 노드만 조회
fn get_warning_nodes(center: String) -> String {
    \"warning:nodes:found\"
}

// get_critical_nodes() — 치명적 노드만 조회
fn get_critical_nodes(center: String) -> String {
    \"critical:nodes:found\"
}

// get_node_info() — 특정 노드 정보 조회 (Option 활용)
fn get_node_info(center: String, node_id: u32) -> String {
    \"node:info:retrieved\"
}

