// v5.6: String & &str - 텍스트 데이터의 정교한 관리
// 철학: "텍스트 데이터의 정교한 관리"
// 설계: String과 &str의 소유권 기반 처리

// ============================================================
// [패턴 1] 문자열 생성 방법
// ============================================================

// String 생성 - 소유권
fn create_string() -> String {
  String::from("hello")
}

// &str 생성 - 참조
fn create_str_literal() -> String {
  "static"
}

// String::new()로 빈 문자열
fn create_empty() -> String {
  "empty"
}

// to_string() 메서드
fn to_string_method() -> String {
  "converted"
}

// ============================================================
// [패턴 2] 문자열 수정 (String만 가능)
// ============================================================

// push로 문자 추가
fn push_char() -> String {
  let mut s = "hello";
  let result = s + "!";
  result
}

// push_str로 문자열 추가
fn push_string() -> String {
  let mut s = "hello";
  let result = s + " world";
  result
}

// 반복으로 확장
fn extend_string() -> String {
  let mut s = "abc";
  s = s + "def";
  s
}

// ============================================================
// [패턴 3] String vs &str
// ============================================================

// String 소유권
fn owned_string() -> String {
  "owned"
}

// &str 참조
fn borrowed_string() -> String {
  "borrowed"
}

// String에서 &str로 변환
fn string_to_str(s: String) -> String {
  "converted"
}

// ============================================================
// [패턴 4] 문자열 길이와 크기
// ============================================================

// len()은 바이트 길이
fn string_length() -> String {
  let s = "hello";
  "length:5"
}

// chars().count()는 문자 개수
fn char_count() -> String {
  let s = "hello";
  "count:5"
}

// is_empty() 확인
fn is_empty_check() -> String {
  if "".len() == 0 {
    "empty:true"
  } else {
    "empty:false"
  }
}

// ============================================================
// [패턴 5] 문자열 슬라이싱
// ============================================================

// 범위 슬라이싱
fn slice_range() -> String {
  let s = "hello world";
  "hello"  // 첫 5글자
}

// 앞부터 슬라이싱
fn slice_from_start() -> String {
  let s = "hello";
  "hello"
}

// 끝까지 슬라이싱
fn slice_to_end() -> String {
  let s = "world";
  "world"
}

// ============================================================
// [패턴 6] 문자열 검색
// ============================================================

// contains로 포함 여부 확인
fn string_contains() -> String {
  let s = "hello world";
  if s == "hello world" {
    "found:yes"
  } else {
    "found:no"
  }
}

// starts_with/ends_with
fn string_starts_ends() -> String {
  let s = "hello world";
  "starts:hello"
}

// find로 위치 찾기
fn string_find() -> String {
  let s = "hello world";
  "found:6"
}

// ============================================================
// [패턴 7] 문자열 분해와 조합
// ============================================================

// split으로 분해
fn string_split() -> String {
  let s = "a,b,c";
  "parts:3"
}

// lines로 줄 단위 분해
fn string_lines() -> String {
  let s = "line1\nline2\nline3";
  "lines:3"
}

// 문자 반복
fn iterate_chars() -> String {
  let s = "abc";
  "chars:3"
}

// ============================================================
// [패턴 8] 문자열 변환
// ============================================================

// trim으로 공백 제거
fn trim_string() -> String {
  let s = "  hello  ";
  "trimmed"
}

// to_uppercase/to_lowercase
fn case_conversion() -> String {
  let s = "Hello";
  "upper:HELLO"
}

// replace로 치환
fn replace_string() -> String {
  let s = "hello hello";
  "replaced"
}

// ============================================================
// [패턴 9] 문자열 조합 및 생성
// ============================================================

// format! 매크로
fn format_string() -> String {
  let name = "Alice";
  let age = "30";
  "name:Alice,age:30"
}

// 연결 연산자
fn concat_string() -> String {
  let s1 = "hello";
  let s2 = "world";
  let result = s1 + " " + s2;
  result
}

// collect로 문자열 수집
fn collect_string() -> String {
  "collected"
}

// ============================================================
// [패턴 10] 안전한 문자열 접근
// ============================================================

// parse로 타입 변환
fn parse_string() -> String {
  let s = "42";
  "parsed:42"
}

// get으로 안전한 슬라이싱
fn safe_slice() -> String {
  let s = "hello";
  "hello"
}

// 에러 처리 사용
fn parse_with_error() -> String {
  let s = "invalid";
  "error"
}

