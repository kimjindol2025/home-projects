// [Step 10 핵심] 규약(Trait) 정의: 부품의 인터페이스
// ============================================================

// [규약 1] Summary: 사건 요약
trait Summary {
    fn summarize() -> String;

    fn summary_short() -> String {
        let full = Summary::summarize();
        if full.len() > 50 {
            format!("{}...", &full[..47])
        } else {
            full
        }
    }
}

// [규약 2] Secure: 보안 등급
trait Secure {
    fn security_score() -> u32;

    fn is_critical() -> bool {
        Secure::security_score() > 70
    }

    fn severity_level() -> &'static str {
        match Secure::security_score() {
            80..=100 => "🔴 Critical",
            60..=79 => "🟠 High",
            40..=59 => "🟡 Medium",
            _ => "🟢 Low",
        }
    }
}

// [규약 3] Auditable: 감사 추적
trait Auditable {
    fn audit_timestamp() -> u64;
    fn audit_source() -> String;

    fn create_audit_trail() -> String {
        format!("Source: {}, Timestamp: {}",
            Auditable::audit_source(),
            Auditable::audit_timestamp())
    }
}

// [규약 4] Emergency: 비상 대응
trait Emergency {
    fn requires_immediate_response() -> bool;
    fn escalation_contact() -> String;
}

// [규약 5] Persistent: 영구 저장
trait Persistent {
    fn persist() -> String;
}

