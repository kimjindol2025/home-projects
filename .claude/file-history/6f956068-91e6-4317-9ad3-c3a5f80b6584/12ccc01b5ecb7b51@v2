// ============================================================
// [통합 함수 1] audit_report: 기본 감사 (Step 6-7)
// ============================================================

fn audit_report<T>()
where
    T: Summary + Secure,
{
    println!("\n╔═══════════════════════════════════╗");
    println!("║         감사 보고서 (Audit)        ║");
    println!("╚═══════════════════════════════════╝");
    println!("내용: {}", T::summarize());
    println!("보안점수: {}/100", T::security_score());
    println!("심각도: {}", T::severity_level());

    if T::is_critical() {
        println!("⚠️ 즉시 조치 필요!");
    } else {
        println!("✅ 정상 모니터링");
    }
}

// ============================================================
// [통합 함수 2] classify_threat: 위협 분류
// ============================================================

fn classify_threat<T>() -> String
where
    T: Secure,
{
    format!("[위협 분류] {}: {}/100",
        T::severity_level(),
        T::security_score())
}

// ============================================================
// [통합 함수 3] escalate_alert: 비상 상황 상향
// ============================================================

fn escalate_alert<T>()
where
    T: Summary + Emergency,
{
    println!("\n╔═══════════════════════════════════╗");
    println!("║         🚨 비상 알림 🚨           ║");
    println!("╚═══════════════════════════════════╝");
    println!("내용: {}", T::summarize());
    println!("즉시 대응: {}", if T::requires_immediate_response() { "YES" } else { "NO" });
    println!("연락처: {}", T::escalation_contact());
}

// ============================================================
// [통합 함수 4] create_audit_trail: 감사 추적
// ============================================================

fn create_audit_trail<T>()
where
    T: Summary + Auditable,
{
    println!("\n📋 감사 추적:");
    println!("  사건: {}", T::summarize());
    println!("  추적: {}", T::create_audit_trail());
}

// ============================================================
// [통합 함수 5] archive_incident: 사건 보관
// ============================================================

fn archive_incident<T>()
where
    T: Summary + Persistent,
{
    println!("\n💾 사건 보관:");
    println!("  내용: {}", T::summarize());
    println!("  저장: {}", T::persist());
}

// ============================================================
// [통합 함수 6] comprehensive_analysis: 종합 분석
// ============================================================

fn comprehensive_analysis<T>()
where
    T: Summary + Secure + Auditable,
{
    println!("\n╔═══════════════════════════════════╗");
    println!("║         종합 보안 분석 📊          ║");
    println!("╚═══════════════════════════════════╝");
    println!("1️⃣ 요약: {}", T::summarize());
    println!("2️⃣ 등급: {} ({}점)", T::severity_level(), T::security_score());
    println!("3️⃣ 추적: {}", T::create_audit_trail());
}

