// Pattern 10.1: 핫팟 감지 (Hot Path Detection)
fn jit_hot_path(iterations: usize) {
    // 컴파일러가 호출 횟수를 추적
    // iterations > threshold이면 JIT 컴파일

    for _ in 0..iterations {
        let x = 2 + 3;  // 자주 실행되는 부분
        let _ = x;
    }
}

fn jit_trigger() {
    jit_hot_path(1000000);  // 1M번 실행 → JIT 컴파일 트리거
}

// Pattern 10.2: 호출 카운트 (Call Count Tracking)
fn jit_call_count() {
    fn tracked_function(x: i32) -> i32 {
        // 호출 횟수 자동 추적
        x * 2
    }

    // 처음: 인터프리터로 실행
    for _ in 0..100 {
        tracked_function(5);  // 100번 호출
    }
    // 이후: JIT 컴파일되어 기계어로 실행
}

// Pattern 10.3: 프로파일 기반 최적화 (PGO)
fn pgo_optimization() {
    // 프로파일 수집:
    // 1. instrumented 바이너리로 전형적인 워크로드 실행
    // 2. 호출 빈도, 분기 확률 기록
    //
    // 프로파일 적용:
    // 3. 기록된 프로파일을 바탕으로 최적화

    fn likely_branch(condition: bool) -> i32 {
        if condition {
            42  // 99% 실행
        } else {
            0   // 1% 실행
        }
    }

    // PGO: likely_branch를 앞에, else를 뒤에 배치
    // -> 분기 예측 실패 최소화
    let result = likely_branch(true);
    println!("PGO result: {}", result);
}

// Pattern 10.4: 인라인 캐시 (Inline Caching)
struct InlineCache {
    cached_value: Option<i32>,
}

impl InlineCache {
    fn get_or_compute(&mut self, key: i32) -> i32 {
        if let Some(cached) = self.cached_value {
            cached  // 캐시 히트
        } else {
            let value = expensive_computation(key);
            self.cached_value = Some(value);
            value
        }
    }
}

fn expensive_computation(x: i32) -> i32 {
    x * x * x
}

fn jit_inline_cache() {
    let mut cache = InlineCache { cached_value: None };
    let result = cache.get_or_compute(5);
    println!("Cached: {}", result);
}

// Pattern 10.5: 동적 역최적화 (Deoptimization)
fn jit_deoptimization() {
    // JIT이 가정에 기반해 최적화:
    // "이 변수는 항상 i32이다"
    //
    // 하지만 런타임에 가정 위반 발생:
    // -> 역최적화 (deoptimize)
    // -> 인터프리터로 복귀
    // -> 다시 최적화 전략 재검토

    fn flexible_function(x: &dyn std::any::Any) -> i32 {
        if let Some(val) = x.downcast_ref::<i32>() {
            *val * 2  // 최적화 가능
        } else {
            0
        }
    }

    let value: Box<dyn std::any::Any> = Box::new(42i32);
    let result = flexible_function(&value);
    println!("Deopt result: {}", result);
}

