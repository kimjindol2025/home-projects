// ================================================================================
// Pattern Group 1: 상수 폴딩 (Constant Folding) - 컴파일 타임 계산
// ================================================================================

// Pattern 1.1: 기본 산술 상수 폴딩
fn const_folding_arithmetic() {
    // Before Optimization:
    //   let x = 2 + 3;
    //   let y = 10 - 5;
    //   let z = 4 * 7;
    //
    // After Optimization (Constant Folding):
    //   let x = 5;
    //   let y = 5;
    //   let z = 28;
    //
    // Benefit: 런타임에 계산하지 않음 → 3회 연산 제거

    let x = 2 + 3;           // 컴파일 시 계산: 5
    let y = 10 - 5;          // 컴파일 시 계산: 5
    let z = 4 * 7;           // 컴파일 시 계산: 28
    println!("Results: {}, {}, {}", x, y, z);
}

// Pattern 1.2: 논리 상수 폴딩
fn const_folding_logic() {
    // Before:
    //   if (true && condition) { ... }
    //   if (false || condition) { ... }
    //
    // After:
    //   if (condition) { ... }
    //   if (condition) { ... }

    if true && false {           // 항상 false로 폴딩
        println!("Never executed");
    }
    if true || false {           // 항상 true로 폴딩
        println!("Always executed");
    }
}

// Pattern 1.3: 비트 연산 폴딩
fn const_folding_bitwise() {
    let x = 0xFF & 0x0F;         // 컴파일 시: 0x0F
    let y = 1 << 3;              // 컴파일 시: 8
    let z = 16 >> 2;             // 컴파일 시: 4
    println!("Bit operations: 0x{:X}, {}, {}", x, y, z);
}

// Pattern 1.4: 함수 호출 상수 폴딩
fn const_folding_function() {
    // const fn이 있으면 컴파일 타임에 계산 가능
    const fn square(x: i32) -> i32 {
        x * x
    }

    let x = square(5);           // 컴파일 시 계산: 25
    let y = square(10);          // 컴파일 시 계산: 100
    println!("Squares: {}, {}", x, y);
}

// Pattern 1.5: 배열 상수 폴딩
fn const_folding_array() {
    let arr = [1 + 1, 2 * 2, 3 - 1];  // [2, 4, 2]로 폴딩
    println!("Array: {:?}", arr);
}

// ================================================================================
// Pattern Group 2: 죽은 코드 제거 (Dead Code Elimination)
// ================================================================================

// Pattern 2.1: 도달 불가능한 코드 제거
fn dead_code_unreachable() {
    // Before:
    //   return 42;
    //   println!("Never reached");
    //   let x = 100;
    //
    // After:
    //   return 42;
    //   [제거됨]

    fn inner() -> i32 {
        return 42;
        println!("This is dead code");   // 컴파일러가 제거
        100                             // 도달 불가능
    }
}

// Pattern 2.2: 조건이 거짓인 코드 제거
fn dead_code_false_condition() {
    if false {
        println!("This is never executed");  // 제거됨
    }

    if true {
        println!("This is always executed");  // 유지됨
    }
}

// Pattern 2.3: 사용되지 않는 변수 제거
fn dead_code_unused_vars() {
    let x = 100;         // 사용되지 않음 → 제거 권장
    let y = 200;         // 사용됨 → 유지
    println!("y = {}", y);
}

// Pattern 2.4: 사용되지 않는 함수 제거
fn dead_code_unused_function() {
    fn never_called() {
        println!("This function is never called");  // 제거됨
    }

    fn used_function() {
        println!("This function is called");
    }

    used_function();
}

// Pattern 2.5: 빈 블록 제거
fn dead_code_empty_blocks() {
    // Before:
    //   if condition {
    //   }
    //
    // After:
    //   [제거됨]

    if false {}    // 제거됨
    if true {}     // 제거됨
}

// ================================================================================
// Pattern Group 3: 함수 인라이닝 (Function Inlining)
// ================================================================================

// Pattern 3.1: 작은 함수 인라이닝
#[inline]  // 컴파일러 힌트
fn add(a: i32, b: i32) -> i32 {
    a + b
}

fn inlining_small_function() {
    // Before:
    //   call add(2, 3)
    //
    // After:
    //   2 + 3  [함수 호출 오버헤드 제거]

    let result = add(2, 3);  // 인라인됨: 2 + 3
    println!("Result: {}", result);
}

// Pattern 3.2: Getter 메서드 인라이닝
struct Point {
    x: i32,
    y: i32,
}

impl Point {
    #[inline]
    fn get_x(&self) -> i32 {
        self.x  // 함수 호출 대신 직접 접근
    }
}

fn inlining_getter() {
    let p = Point { x: 10, y: 20 };
    let x = p.get_x();  // 인라인됨
    println!("x = {}", x);
}

// Pattern 3.3: 인라인 불가능 조건 (재귀)
fn inlining_recursive(n: i32) -> i32 {
    if n <= 1 { 1 } else { n * inlining_recursive(n - 1) }
    // 재귀 함수는 인라인될 수 없음 (무한 확대)
}

// Pattern 3.4: 조건부 인라인
#[inline(always)]  // 항상 인라인
fn must_inline(x: i32) -> i32 {
    x * 2
}

#[inline(never)]   // 절대 인라인하지 않음
fn must_not_inline(x: i32) -> i32 {
    x * 2
}

fn inlining_conditional() {
    let a = must_inline(5);        // 항상 인라인
    let b = must_not_inline(10);   // 항상 함수 호출
    println!("{} {}", a, b);
}

// Pattern 3.5: 체인 함수 인라인
#[inline]
fn double(x: i32) -> i32 { x * 2 }

#[inline]
fn add_one(x: i32) -> i32 { x + 1 }

fn inlining_chain() {
    // Before:
    //   call double(5) -> call add_one(10) -> call double(11) -> 22
    //
    // After (인라인):
    //   ((5 * 2) + 1) * 2 = 22

    let result = double(add_one(double(5)));
    println!("Chain result: {}", result);
}

// ================================================================================
// Pattern Group 4: 루프 언롤링 (Loop Unrolling)
// ================================================================================

// Pattern 4.1: 고정 크기 루프 언롤링
fn loop_unrolling_fixed() {
    // Before:
    //   for i in 0..4 { sum += arr[i]; }
    //
    // After (언롤링):
    //   sum += arr[0]; sum += arr[1]; sum += arr[2]; sum += arr[3];

    let arr = [1, 2, 3, 4];
    let mut sum = 0;
    for i in 0..4 {
        sum += arr[i];
    }
    println!("Sum: {}", sum);
}

// Pattern 4.2: 부분 언롤링 (Unroll Factor = 2)
fn loop_unrolling_partial() {
    // Before:
    //   for i in 0..8 { process(arr[i]); }
    //
    // After (Unroll Factor = 2):
    //   for i in (0..8).step_by(2) {
    //       process(arr[i]);
    //       process(arr[i+1]);
    //   }

    let arr = [1, 2, 3, 4, 5, 6, 7, 8];
    for i in (0..arr.len()).step_by(2) {
        let _ = arr[i];
        let _ = arr[i + 1];
    }
}

// Pattern 4.3: SIMD와 루프 언롤링
fn loop_unrolling_simd() {
    // Before:
    //   for i in 0..n { c[i] = a[i] + b[i]; }
    //
    // After (SIMD 언롤링):
    //   for i in (0..n).step_by(4) {
    //       c[i..i+4] = a[i..i+4] + b[i..i+4];  // 4개 요소 한 번에

    let a = vec![1, 2, 3, 4, 5, 6, 7, 8];
    let b = vec![10, 20, 30, 40, 50, 60, 70, 80];
    let mut c = vec![0; 8];

    for i in 0..a.len() {
        c[i] = a[i] + b[i];
    }
}

// Pattern 4.4: 분기 최소화
fn loop_unrolling_minimize_branches() {
    // Before:
    //   for i in 0..1000000 { if condition { ... } }
    //   [1000000번 분기]
    //
    // After (언롤링 + 루프 불변 제거):
    //   if condition { for i in 0..1000000 { ... } }
    //   [1번 분기]

    let iterations = 1000000;
    for _ in 0..iterations {
        // 루프 내 분기 최소화
    }
}

// Pattern 4.5: 캐시 친화적 언롤링
fn loop_unrolling_cache_friendly() {
    // L1 캐시(32KB)에 들어올 수 있도록 언롤링
    // 데이터 재사용성 극대화

    let matrix = vec![vec![0; 1024]; 1024];
    for i in 0..matrix.len() {
        for j in 0..matrix[i].len() {
            // 인접한 메모리 접근 → 캐시 히트율 높음
            let _ = matrix[i][j];
        }
    }
}

