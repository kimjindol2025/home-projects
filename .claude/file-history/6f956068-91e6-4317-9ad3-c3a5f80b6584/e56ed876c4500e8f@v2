// Pattern Group 9: 메모리 최적화 (Memory Optimization)
// ================================================================================

// Pattern 9.1: 데이터 구조 정렬 (Data Structure Alignment)
#[repr(C)]
struct Unoptimized {
    a: u8,           // 1 byte
    _pad1: [u8; 3],  // 패딩
    b: u32,          // 4 bytes
    c: u8,           // 1 byte
    _pad2: [u8; 7],  // 패딩
    // 총 16 bytes
}

#[repr(C)]
struct Optimized {
    b: u32,          // 4 bytes
    a: u8,           // 1 byte
    c: u8,           // 1 byte
    _pad: [u8; 2],   // 2 bytes 패딩만
    // 총 8 bytes
}

fn memory_alignment() {
    println!("Unoptimized size: {}", std::mem::size_of::<Unoptimized>());
    println!("Optimized size: {}", std::mem::size_of::<Optimized>());
}

// Pattern 9.2: 메모리 풀 (Object Pool)
struct ObjectPool<T> {
    available: Vec<T>,
    in_use: Vec<T>,
}

impl<T> ObjectPool<T> {
    fn allocate(&mut self) -> Option<T> {
        // 새로 할당하지 않고 풀에서 가져옴
        self.available.pop()
    }

    fn deallocate(&mut self, obj: T) {
        // 해제하지 않고 풀에 반환
        self.available.push(obj);
    }
}

fn memory_pool() {
    let mut pool = ObjectPool {
        available: vec![1, 2, 3],
        in_use: vec![],
    };

    let obj = pool.allocate();  // 할당
    pool.deallocate(obj.unwrap());  // 반환
}

// Pattern 9.3: 캐시라인 정렬 (Cache Line Alignment)
#[repr(align(64))]  // 64바이트 정렬
struct CacheAligned {
    data: u64,
}

fn memory_cache_alignment() {
    let a = CacheAligned { data: 1 };
    let b = CacheAligned { data: 2 };

    // a와 b가 다른 캐시라인에 위치
    // -> False sharing 방지
    println!("a = {}, b = {}", a.data, b.data);
}

// Pattern 9.4: 스택 vs 힙
fn memory_stack_vs_heap() {
    // 스택 (빠름, 크기 작음):
    let stack_var = 42i32;  // 4 bytes, 즉시 할당

    // 힙 (느림, 크기 제한 없음):
    let heap_var = Box::new(vec![0; 1000]);  // 느림, 동적

    println!("Stack: {}", stack_var);
    println!("Heap size: {}", heap_var.len());
}

// Pattern 9.5: NUMA 최적화 (멀티소켓)
fn memory_numa() {
    // 스레드가 실행 중인 NUMA 노드에서 메모리 할당
    // -> 원격 노드 접근보다 2~3배 빠름

    let local_alloc = vec![0; 1000];  // 로컬 노드에서 할당
    println!("NUMA local: {} bytes", local_alloc.len());
}

