// Pattern Group 5: 복사 전파 (Copy Propagation)
// ================================================================================

// Pattern 5.1: 기본 복사 전파
fn copy_propagation_basic() {
    // Before:
    //   let x = y;
    //   let z = x;
    //   return z;
    //
    // After (전파):
    //   return y;

    let y = 42;
    let x = y;
    let z = x;
    println!("z = {}", z);
}

// Pattern 5.2: 레지스터 압박 감소
fn copy_propagation_register_pressure() {
    // Before:
    //   r1 = load(y)
    //   r2 = r1
    //   r3 = r2
    //   [더 많은 레지스터 필요]
    //
    // After (전파):
    //   r1 = load(y)
    //   [r1을 직접 사용]

    let a = 100;
    let b = a;
    let c = b;
    println!("{}", c);
}

// Pattern 5.3: 함수 반환값 전파
fn copy_propagation_return() {
    // Before:
    //   let x = foo();
    //   let y = x;
    //   return y;
    //
    // After:
    //   return foo();

    fn foo() -> i32 { 42 }
    let x = foo();
    let y = x;
    println!("y = {}", y);
}

// Pattern 5.4: 메모리 대역폭 절약
fn copy_propagation_memory_bandwidth() {
    // 불필요한 메모리 연산 제거
    // -> 메모리 대역폭 절약

    let data = vec![1, 2, 3, 4, 5];
    let ptr1 = &data;
    let ptr2 = ptr1;
    println!("Data: {:?}", ptr2);
}

// Pattern 5.5: 복사 제거의 한계
fn copy_propagation_limits() {
    // 복사 전파가 항상 가능한 것은 아님
    // - 뮤터블 참조: let mut x = y; x = 100;
    // - 소유권 이동: let x = y; // y가 move됨

    let original = 42;
    let _copy = original;  // Copy trait이 있으면 괜찮음
    let _still_valid = original;  // original은 여전히 유효
}

// ================================================================================
// Pattern Group 6: 공통 부분식 제거 (Common Subexpression Elimination)
// ================================================================================

// Pattern 6.1: 기본 CSE
fn cse_basic() {
    // Before:
    //   x = a + b;
    //   y = a + b;
    //
    // After (CSE):
    //   temp = a + b;
    //   x = temp;
    //   y = temp;

    let a = 10;
    let b = 20;
    let x = a + b;  // 계산
    let y = a + b;  // 계산 (중복) → temp에서 가져옴
    println!("x = {}, y = {}", x, y);
}

// Pattern 6.2: 배열 접근 CSE
fn cse_array_access() {
    // Before:
    //   arr[i] = x;
    //   arr[i] = arr[i] + 1;  // arr[i] 두 번 계산
    //
    // After (CSE):
    //   temp = arr[i];
    //   arr[i] = x;
    //   arr[i] = temp + 1;

    let mut arr = vec![1, 2, 3];
    let i = 0;
    arr[i] = arr[i] + 1;  // arr[i] 계산 최소화
    println!("arr: {:?}", arr);
}

// Pattern 6.3: 함수 호출 CSE
fn cse_function_call() {
    // Before:
    //   if is_valid(data) { ... }
    //   if is_valid(data) { ... }  // 두 번 호출
    //
    // After (CSE):
    //   temp = is_valid(data);
    //   if temp { ... }
    //   if temp { ... }

    fn is_valid(data: i32) -> bool { data > 0 }

    let data = 42;
    if is_valid(data) {
        println!("Valid");
    }
    if is_valid(data) {  // CSE로 최적화되면 한 번만 호출
        println!("Still valid");
    }
}

// Pattern 6.4: 메모리 로드 CSE
fn cse_memory_load() {
    // Before:
    //   x = *ptr;
    //   y = *ptr + 1;  // 다시 로드 (불필요)
    //
    // After (CSE):
    //   x = *ptr;
    //   y = x + 1;

    let data = 100;
    let ptr = &data;
    let x = *ptr;
    let y = *ptr + 1;  // CSE: x + 1
    println!("x = {}, y = {}", x, y);
}

// Pattern 6.5: CSE와 데이터 흐름
fn cse_dataflow() {
    // CSE는 데이터 흐름이 같아야만 적용
    // 부작용(Side Effect) 있으면 불가능

    fn pure_function(x: i32) -> i32 { x * 2 }  // Pure
    fn side_effect_function(x: &mut i32) -> i32 { *x += 1; *x }  // Side Effect

    let a = 5;
    let x = pure_function(a);      // CSE 가능
    let y = pure_function(a);      // 중복 제거 가능

    let mut b = 5;
    let p = side_effect_function(&mut b);  // Side Effect 있음
    let q = side_effect_function(&mut b);  // 중복 제거 불가능
    println!("{} {} {} {}", x, y, p, q);
}

// ================================================================================
// Pattern Group 7: 꼬리 호출 최적화 (Tail Call Optimization)
// ================================================================================

// Pattern 7.1: 기본 꼬리 호출
fn tail_call_basic(n: i32) -> i32 {
    if n <= 1 { 1 } else { tail_call_basic(n - 1) }
    // 마지막 연산이 재귀 호출 → TCO 가능
}

fn tail_call_basic_optimized() {
    tail_call_basic(1000000);  // 스택 오버플로우 방지
}

// Pattern 7.2: 누적값을 이용한 꼬리 호출
fn factorial_tail(n: i32, acc: i32) -> i32 {
    if n <= 1 { acc } else { factorial_tail(n - 1, n * acc) }
    // TCO로 O(n) 스택 → O(1) 스택
}

fn tail_call_accumulator() {
    let result = factorial_tail(10, 1);
    println!("10! = {}", result);
}

// Pattern 7.3: 꼬리 호출이 아닌 경우
fn not_tail_call(n: i32) -> i32 {
    if n <= 1 { 1 } else { n * not_tail_call(n - 1) }
    // 재귀 호출 후 곱셈이 있음 → TCO 불가능 → 스택 누적
}

// Pattern 7.4: 호출 쌍 최적화 (Tail Call Pair)
fn mutual_recursion_a(n: i32) -> bool {
    if n == 0 { true } else { mutual_recursion_b(n - 1) }
}

fn mutual_recursion_b(n: i32) -> bool {
    if n == 0 { false } else { mutual_recursion_a(n - 1) }
}

fn tail_call_mutual() {
    mutual_recursion_a(1000000);  // TCO로 안전
}

// Pattern 7.5: 스택 프레임 재사용
fn fibonacci_naive(n: i32) -> i32 {
    // 재귀 깊이: O(2^n) - 스택 오버플로우
    if n <= 1 { n } else { fibonacci_naive(n - 1) + fibonacci_naive(n - 2) }
}

fn fibonacci_tail(n: i32, a: i32, b: i32) -> i32 {
    // 재귀 깊이: O(n) - TCO로 O(1) 스택
    if n == 0 { a } else { fibonacci_tail(n - 1, b, a + b) }
}

fn tail_call_fibonacci() {
    let result = fibonacci_tail(50, 0, 1);
    println!("Fib(50) = {}", result);
}

// ================================================================================
// Pattern Group 8: 병렬화 및 벡터화 (Parallelization & Vectorization)
// ================================================================================

// Pattern 8.1: SIMD 벡터화
fn vectorization_simd() {
    // Before:
    //   for i in 0..n { c[i] = a[i] + b[i]; }
    //
    // After (SIMD):
    //   for i in (0..n).step_by(4) {
    //       c[i:i+4] = a[i:i+4] + b[i:i+4];  // 한 번에 4개 처리

    let a = vec![1.0, 2.0, 3.0, 4.0];
    let b = vec![10.0, 20.0, 30.0, 40.0];
    let mut c = vec![0.0; 4];

    for i in 0..a.len() {
        c[i] = a[i] + b[i];  // 컴파일러가 SIMD로 벡터화
    }
    println!("SIMD result: {:?}", c);
}

// Pattern 8.2: 병렬 루프 (Rayon 스타일)
fn parallelization_loop() {
    // Before:
    //   for i in 0..n { result[i] = expensive_fn(arr[i]); }
    //
    // After (병렬):
    //   result.par_iter_mut().enumerate().for_each(|(i, r)| {
    //       *r = expensive_fn(arr[i]);  // 여러 스레드에서 동시 실행
    //   })

    let arr = vec![1, 2, 3, 4, 5, 6, 7, 8];
    let result: Vec<_> = arr.iter().map(|x| x * x).collect();
    println!("Parallel: {:?}", result);
}

// Pattern 8.3: 데이터 지역성 (Data Locality)
fn parallelization_locality() {
    // 캐시 친화적 액세스 패턴
    // Row-major (fast): for row { for col { matrix[row][col] } }
    // Column-major (slow): for col { for row { matrix[row][col] } }

    let matrix = vec![vec![0; 1024]; 1024];

    // Fast: Row-major
    for row in 0..matrix.len() {
        for col in 0..matrix[row].len() {
            let _ = matrix[row][col];
        }
    }
}

// Pattern 8.4: 병렬 접두사 합 (Parallel Prefix Sum)
fn parallelization_prefix_sum() {
    let arr = vec![1, 2, 3, 4, 5, 6, 7, 8];
    let mut result = vec![0; arr.len()];

    // 순차: O(n)
    result[0] = arr[0];
    for i in 1..arr.len() {
        result[i] = result[i - 1] + arr[i];
    }
    println!("Prefix sum: {:?}", result);
}

// Pattern 8.5: 동적 조정 (Dynamic Scheduling)
fn parallelization_dynamic() {
    // 정적: 균등 분할 (불균형하면 비효율)
    // 동적: 작업량에 따라 동적 할당 (더 나음)

    let tasks = vec![100, 200, 150, 300, 250];
    for task in tasks {
        // 동적으로 스레드에 할당
        let _ = task;
    }
}

