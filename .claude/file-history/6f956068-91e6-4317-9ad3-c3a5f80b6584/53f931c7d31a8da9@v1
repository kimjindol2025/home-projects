/**
 * StdLib Module Tests
 * 59개 함수 테스트
 */

import * as stdlib from '../src/stdlib';

describe('StdLib - String Module', () => {
  test('split', () => {
    expect(stdlib.split('a,b,c', ',')).toEqual(['a', 'b', 'c']);
  });

  test('join', () => {
    expect(stdlib.join(['a', 'b', 'c'], ',')).toBe('a,b,c');
  });

  test('contains', () => {
    expect(stdlib.contains('hello', 'ell')).toBe(true);
    expect(stdlib.contains('hello', 'xyz')).toBe(false);
  });

  test('trim', () => {
    expect(stdlib.trim('  hello  ')).toBe('hello');
  });

  test('uppercase', () => {
    expect(stdlib.uppercase('hello')).toBe('HELLO');
  });

  test('lowercase', () => {
    expect(stdlib.lowercase('HELLO')).toBe('hello');
  });
});

describe('StdLib - Functional Module', () => {
  test('map', () => {
    const result = stdlib.map([1, 2, 3], x => x * 2);
    expect(result).toEqual([2, 4, 6]);
  });

  test('filter', () => {
    const result = stdlib.filter([1, 2, 3, 4], x => x > 2);
    expect(result).toEqual([3, 4]);
  });

  test('reduce', () => {
    const result = stdlib.reduce([1, 2, 3], 0, (acc, x) => acc + x);
    expect(result).toBe(6);
  });

  test('any', () => {
    expect(stdlib.any([1, 2, 3], x => x > 2)).toBe(true);
    expect(stdlib.any([1, 2, 3], x => x > 10)).toBe(false);
  });

  test('all', () => {
    expect(stdlib.all([1, 2, 3], x => x > 0)).toBe(true);
    expect(stdlib.all([1, 2, 3], x => x > 2)).toBe(false);
  });
});

describe('StdLib - Math Module', () => {
  test('abs', () => {
    expect(stdlib.abs(-5)).toBe(5);
  });

  test('sqrt', () => {
    expect(stdlib.sqrt(4)).toBe(2);
  });

  test('pow', () => {
    expect(stdlib.pow(2, 3)).toBe(8);
  });

  test('floor', () => {
    expect(stdlib.floor(4.9)).toBe(4);
  });

  test('ceil', () => {
    expect(stdlib.ceil(4.1)).toBe(5);
  });
});

describe('StdLib - Array Module', () => {
  test('push', () => {
    const arr = [1, 2];
    const len = stdlib.push(arr, 3);
    expect(len).toBe(3);
    expect(arr).toEqual([1, 2, 3]);
  });

  test('pop', () => {
    const arr = [1, 2, 3];
    const val = stdlib.pop(arr);
    expect(val).toBe(3);
    expect(arr).toEqual([1, 2]);
  });

  test('slice', () => {
    const arr = [1, 2, 3, 4, 5];
    expect(stdlib.slice(arr, 1, 3)).toEqual([2, 3]);
  });

  test('concat', () => {
    expect(stdlib.concat([1, 2], [3, 4])).toEqual([1, 2, 3, 4]);
  });
});

describe('StdLib - JSON Module', () => {
  test('parse', () => {
    const obj = stdlib.parse('{"a":1,"b":2}');
    expect(obj.a).toBe(1);
    expect(obj.b).toBe(2);
  });

  test('stringify', () => {
    expect(stdlib.stringify({a: 1, b: 2})).toBe('{"a":1,"b":2}');
  });

  test('isJSON', () => {
    expect(stdlib.isJSON('{"a":1}')).toBe(true);
    expect(stdlib.isJSON('not json')).toBe(false);
  });
});

describe('StdLib - Regex Module', () => {
  test('test', () => {
    expect(stdlib.test('hello123', '\\d+')).toBe(true);
    expect(stdlib.test('hello', '\\d+')).toBe(false);
  });

  test('match', () => {
    const result = stdlib.match('hello123world456', '\\d+');
    expect(result).not.toBeNull();
    expect(result![0]).toBe('123');
  });

  test('replace_regex', () => {
    const result = stdlib.replace_regex('hello123world456', '\\d+', 'X');
    expect(result).toBe('helloXworldX');
  });
});

describe('StdLib - Utility Module', () => {
  test('typeof_value', () => {
    expect(stdlib.typeof_value(42)).toBe('number');
    expect(stdlib.typeof_value('hello')).toBe('string');
    expect(stdlib.typeof_value(true)).toBe('boolean');
  });

  test('deepEqual', () => {
    expect(stdlib.deepEqual({a: 1}, {a: 1})).toBe(true);
    expect(stdlib.deepEqual({a: 1}, {a: 2})).toBe(false);
  });

  test('clone', () => {
    const obj = {a: 1, b: {c: 2}};
    const cloned = stdlib.clone(obj);
    expect(cloned).toEqual(obj);
    expect(cloned === obj).toBe(false);
  });

  test('keys', () => {
    expect(stdlib.keys({a: 1, b: 2})).toEqual(['a', 'b']);
  });

  test('values', () => {
    expect(stdlib.values({a: 1, b: 2})).toEqual([1, 2]);
  });

  test('merge', () => {
    const merged = stdlib.merge({a: 1}, {b: 2});
    expect(merged).toEqual({a: 1, b: 2});
  });
});
