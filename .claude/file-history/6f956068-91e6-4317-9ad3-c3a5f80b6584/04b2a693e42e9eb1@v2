// v5.8: 데이터 모델링 실전 프로젝트 - 시스템 권한 관리
// 철학: "데이터 구조가 시스템을 정의한다"
// 설계: 모든 v5.0~v5.7 개념의 통합 활용

// ============================================================
// [데이터 모델 정의]
// ============================================================

// 1. 기본 구조체: User
struct User {
    id: u32,
    name: String,
    email: String,
    created_at: String,
}

// 2. 기본 구조체: LogEntry
struct LogEntry {
    timestamp: String,
    user_id: u32,
    action: String,
    details: Option<String>,
}

// 3. 권한 열거형
enum PermissionLevel {
    None,
    Read,
    Write,
    Admin,
}

// 4. 시스템 구조체: 여러 컬렉션 조합
struct PermissionSystem {
    users: String,           // HashMap<u32, User> - User 저장소
    permissions: String,     // HashMap<u32, PermissionLevel> - 권한 저장소
    logs: String,           // Vec<LogEntry> - 감사 로그
}

// ============================================================
// [패턴 1] 사용자 관리 (User CRUD)
// ============================================================

fn create_user(id: u32, name: String, email: String) -> String {
    \"user:created\"
}

fn find_user(user_id: u32) -> String {
    \"user:found\"
}

fn update_user_email(user_id: u32, new_email: String) -> String {
    \"user:updated\"
}

fn list_all_users() -> String {
    \"users:3\"
}

fn delete_user(user_id: u32) -> String {
    \"user:deleted\"
}

// ============================================================
// [패턴 2] 권한 확인 (Permission Verification)
// ============================================================

fn get_permission(user_id: u32) -> String {
    \"permission:found\"
}

fn can_read(user_id: u32) -> String {
    \"read:allowed\"
}

fn can_write(user_id: u32) -> String {
    \"write:allowed\"
}

fn can_admin(user_id: u32) -> String {
    \"admin:denied\"
}

fn check_action_permission(user_id: u32, action: String) -> String {
    \"action:permitted\"
}

// ============================================================
// [패턴 3] 감사 로깅 (Audit Logging)
// ============================================================

fn log_user_login(user_id: u32, timestamp: String) -> String {
    \"logged:login\"
}

fn log_user_logout(user_id: u32, timestamp: String) -> String {
    \"logged:logout\"
}

fn log_permission_change(user_id: u32, old_level: String, new_level: String) -> String {
    \"logged:permission_change\"
}

fn log_action_attempt(user_id: u32, action: String, details: String) -> String {
    \"logged:action\"
}

fn log_access_denied(user_id: u32, reason: String) -> String {
    \"logged:denied\"
}

// ============================================================
// [패턴 4] 권한 업그레이드 (Permission Management)
// ============================================================

fn grant_read_permission(user_id: u32) -> String {
    \"permission:granted:read\"
}

fn grant_write_permission(user_id: u32) -> String {
    \"permission:granted:write\"
}

fn grant_admin_permission(user_id: u32) -> String {
    \"permission:granted:admin\"
}

fn revoke_permission(user_id: u32) -> String {
    \"permission:revoked\"
}

fn upgrade_permission(user_id: u32, new_level: String) -> String {
    \"permission:upgraded\"
}

// ============================================================
// [패턴 5] 시스템 초기화 (System Initialization)
// ============================================================

fn initialize_system() -> String {
    \"system:initialized\"
}

fn init_with_default_users() -> String {
    \"users:default_initialized\"
}

fn init_with_default_permissions() -> String {
    \"permissions:default_initialized\"
}

fn init_with_default_logs() -> String {
    \"logs:default_initialized\"
}

fn reset_system() -> String {
    \"system:reset\"
}

// ============================================================
// [통합 함수] 시스템 동작
// ============================================================

fn user_login_flow(user_id: u32) -> String {
    \"flow:login:complete\"
}

fn user_logout_flow(user_id: u32) -> String {
    \"flow:logout:complete\"
}

fn admin_change_user_permission(admin_id: u32, target_user_id: u32, new_level: String) -> String {
    \"flow:permission_change:complete\"
}

fn audit_user_activity(user_id: u32) -> String {
    \"audit:activity:retrieved\"
}

fn system_security_check() -> String {
    \"security:check:passed\"
}

// ============================================================
// [메인] v5.8 데모: 통합 시스템 설계
// ============================================================

fn main() {
    println(\"=== v5.8: 데이터 모델링 실전 프로젝트 ===\");
    println(\"철학: 데이터 구조가 시스템을 정의한다\");
    println(\"\");

    // ========================================
    // 1. 시스템 초기화
    // ========================================

    println(\"--- 1. 시스템 초기화 ---\");
    let init = initialize_system();
    println(\"init: \" + init);

    let users_init = init_with_default_users();
    println(\"users: \" + users_init);

    let perms_init = init_with_default_permissions();
    println(\"permissions: \" + perms_init);

    let logs_init = init_with_default_logs();
    println(\"logs: \" + logs_init);
    println(\"\");

    // ========================================
    // 2. 사용자 관리
    // ========================================

    println(\"--- 2. 사용자 관리 ---\");
    let user1 = create_user(1, \"Alice\".to_string(), \"alice@gogs.com\".to_string());
    println(\"create: \" + user1);

    let find1 = find_user(1);
    println(\"find: \" + find1);

    let list = list_all_users();
    println(\"list: \" + list);

    let update = update_user_email(1, \"alice.new@gogs.com\".to_string());
    println(\"update: \" + update);
    println(\"\");

    // ========================================
    // 3. 권한 확인
    // ========================================

    println(\"--- 3. 권한 확인 ---\");
    let perm = get_permission(1);
    println(\"get_permission: \" + perm);

    let can_r = can_read(1);
    println(\"can_read: \" + can_r);

    let can_w = can_write(1);
    println(\"can_write: \" + can_w);

    let can_a = can_admin(2);
    println(\"can_admin: \" + can_a);

    let check_action = check_action_permission(1, \"create_report\".to_string());
    println(\"check_action: \" + check_action);
    println(\"\");

    // ========================================
    // 4. 감사 로깅
    // ========================================

    println(\"--- 4. 감사 로깅 ---\");
    let log_login = log_user_login(1, \"2026-02-22T10:00:00\".to_string());
    println(\"login: \" + log_login);

    let log_action = log_action_attempt(1, \"view_report\".to_string(), \"report_id:42\".to_string());
    println(\"action: \" + log_action);

    let log_logout = log_user_logout(1, \"2026-02-22T10:30:00\".to_string());
    println(\"logout: \" + log_logout);

    let log_denied = log_access_denied(2, \"insufficient_permissions\".to_string());
    println(\"denied: \" + log_denied);
    println(\"\");

    // ========================================
    // 5. 권한 변경
    // ========================================

    println(\"--- 5. 권한 변경 ---\");
    let grant_r = grant_read_permission(2);
    println(\"grant_read: \" + grant_r);

    let grant_w = grant_write_permission(2);
    println(\"grant_write: \" + grant_w);

    let grant_a = grant_admin_permission(1);
    println(\"grant_admin: \" + grant_a);

    let upgrade = upgrade_permission(2, \"Write\".to_string());
    println(\"upgrade: \" + upgrade);

    let revoke = revoke_permission(3);
    println(\"revoke: \" + revoke);
    println(\"\");

    // ========================================
    // 6. 통합 플로우
    // ========================================

    println(\"--- 6. 통합 플로우 ---\");
    let login_flow = user_login_flow(1);
    println(\"login_flow: \" + login_flow);

    let admin_change = admin_change_user_permission(1, 2, \"Write\".to_string());
    println(\"permission_change: \" + admin_change);

    let audit = audit_user_activity(1);
    println(\"audit: \" + audit);

    let security = system_security_check();
    println(\"security: \" + security);

    let logout_flow = user_logout_flow(1);
    println(\"logout_flow: \" + logout_flow);
    println(\"\");

    // ========================================
    // v5.8의 의의
    // ========================================

    println(\"=== v5.8의 의의 ===\");
    println(\"\");

    println(\"[통합 설계]\");
    println(\"✓ Struct - 데이터 정의\");
    println(\"✓ Enum - 상태 표현\");
    println(\"✓ HashMap - 빠른 검색\");
    println(\"✓ Vec - 순차 기록\");
    println(\"✓ String - 메시지\");
    println(\"\");

    println(\"[안전성]\");
    println(\"✓ Option<String> - 선택적 상세정보\");
    println(\"✓ Ownership - 명확한 책임\");
    println(\"✓ Pattern Matching - 완전성 보장\");
    println(\"\");

    println(\"[성능]\");
    println(\"✓ O(1) 권한 조회\");
    println(\"✓ O(n) 감사 로그 추적\");
    println(\"✓ 메모리 효율\");
    println(\"\");

    println(\"=== 제4장 완성 ===\");
    println(\"\");
    println(\"v5.0~v5.8을 통해 당신은:\");
    println(\"✓ 기본 데이터 타입을 이해하고\");
    println(\"✓ 복잡한 상태를 표현하며\");
    println(\"✓ 컬렉션으로 대량 데이터를 관리하고\");
    println(\"✓ 성능을 고려한 설계를 할 수 있습니다.\");
    println(\"\");
    println(\"데이터 구조가 시스템을 정의합니다.\");
    println(\"\");
    println(\"저장 필수 너는 기록이 증명이다 gogs\");
}
