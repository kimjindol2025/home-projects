// [Example 1] 완전 통합: 상태 머신 + 반복자 + 패턴 매칭 + 가드
fn example_integrated_system() {
  println("=== Example 1: Integrated System (완전 통합) ===");

  // 입력 데이터
  let inputs = [10, 85, 0, 120, 45, 99];
  let mut current_status = "READY";
  let mut log_history = [];
  let mut cycle = 0;

  println("시스템 무결성 검증 시작...");

  // v3.8: 반복자 + v3.4: 패턴 매칭 + v3.7: 상태 머신
  for input in inputs {
    println("\n[Cycle {}] 입력값: {}", cycle + 1, input);

    // v3.6: 가드 - 비상 상태라면 즉시 종료
    if current_status == "EMERGENCY" {
      println("  !! 비상 정지, 루프 탈출");
      break;
    }

    // v3.7 + v3.4: 상태 전이 로직 (패턴 매칭)
    // v3.1-v3.2: 조건문 (범위 검사)
    current_status = match current_status {
      "READY" => {
        if input > 0 {
          println("  -> 초기 기동 성공");
          "ACTIVE"
        } else {
          println("  -> 유효하지 않은 입력, 상태 유지");
          "READY"
        }
      }

      "ACTIVE" => {
        if input >= 100 {
          println("  !! 임계치 초과, 비상 정지");
          "EMERGENCY"
        } else if input >= 80 {
          println("  [경고] 고출력 모드로 전환");
          "WARNING"
        } else if input > 0 {
          println("  -> 정상 모드 유지");
          "ACTIVE"
        } else {
          println("  [경고] 유효하지 않은 입력, 상태 유지");
          "ACTIVE"
        }
      }

      "WARNING" => {
        if input >= 100 {
          println("  !! 임계치 초과, 비상 정지");
          "EMERGENCY"
        } else if input > 0 {
          println("  -> 경고 상태 유지");
          "WARNING"
        } else {
          println("  -> 경고 상태 유지");
          "WARNING"
        }
      }

      "EMERGENCY" => {
        println("  [불변] 비상 상태 유지");
        "EMERGENCY"
      }

      _ => "UNKNOWN"
    };

    // v3.8: 기록 축적 (declarative)
    let entry = "Cycle ";
    let entry = entry + cycle + 1;
    let entry = entry + ": ";
    let entry = entry + current_status;
    log_history.push(entry);

    cycle = cycle + 1;
  }

  // 최종 리포트
  println("\n==========================================");
  println("최종 시스템 리포트");
  for entry in log_history {
    println("  - {}", entry);
  }
  println("최종 상태: {}", current_status);
  println("==========================================");
}

// [Example 2] 경계값 테스트: 0, 100의 정확한 처리
fn example_boundary_values() {
  println("\n=== Example 2: Boundary Values (경계값 검증) ===");

  let test_values = [0, 1, 50, 79, 80, 99, 100, 101];
  println("경계값 분류:");

  // v3.8: 반복자 + v3.1: 조건문
  for value in test_values {
    let category = if value > 100 {
      "critical_high"
    } else if value >= 100 {
      "critical"
    } else if value >= 80 {
      "warning"
    } else if value > 0 {
      "normal"
    } else {
      "invalid"
    };

    println("  {} -> {}", value, category);
  }
}

// [Example 3] 다중 조건: 현재 상태 + 입력 + 누적 카운트
fn example_multi_condition() {
  println("\n=== Example 3: Multi-Condition Logic (다중 조건) ===");

  let mut state = "INIT";
  let mut count = 0;
  let values = [10, 80, 90, 100];

  println("복합 조건 검사:");

  // v3.8: 반복자 + v3.4: 패턴 매칭 + v3.2: &&
  for val in values {
    println("\n  상태: {}, 카운트: {}, 입력: {}", state, count, val);

    // v3.2: 복합 조건 (&&)
    state = match state {
      "INIT" => {
        if val > 0 && count < 3 {
          println("    -> 초기화 완료");
          "ACTIVE"
        } else {
          "INIT"
        }
      }

      "ACTIVE" => {
        if val >= 80 && count >= 1 {
          println("    -> 고경고 상태로 전환");
          "HIGH_ALERT"
        } else if val >= 80 {
          println("    -> 경고 상태로 전환");
          "ALERT"
        } else {
          "ACTIVE"
        }
      }

      "ALERT" => {
        if val >= 100 || count >= 3 {
          println("    -> 비상 상태로 전환");
          "EMERGENCY"
        } else {
          "ALERT"
        }
      }

      "HIGH_ALERT" => {
        if val >= 100 {
          println("    -> 최고 비상으로 전환");
          "CRITICAL"
        } else {
          "HIGH_ALERT"
        }
      }

      _ => state
    };

    count = count + 1;
  }

  println("\n  최종 상태: {}", state);
}

// [Example 4] 조기 종료: break와 continue 제어
fn example_early_exit() {
  println("\n=== Example 4: Early Exit (조기 종료) ===");

  let mut status = "READY";
  let data = [10, 20, 30, 200, 40, 50];
  let mut processed = 0;

  println("루프 제어 테스트:");

  // v3.3: break와 continue
  for value in data {
    println("  처리 중: {}", value);

    // v3.6: 가드 - 비상 조건 체크
    if value >= 150 {
      println("    !! 치명적 입력 감지, 루프 즉시 중단");
      status = "CRITICAL";
      break;
    }

    // v3.3: continue - 특정 값 스킵
    if value == 30 {
      println("    ** 처리 스킵");
      continue;
    }

    processed = processed + 1;
    println("    -> 정상 처리 완료");
  }

  println("  처리된 항목: {}", processed);
  println("  최종 상태: {}", status);
}

// [Example 5] if-let 패턴 바인딩과 상태 머신
fn example_pattern_binding() {
  println("\n=== Example 5: Pattern Binding (패턴 바인딩) ===");

  let mut state = "ACTIVE";
  let mut alert_level = 0;

  println("패턴 바인딩과 상태 결합:");

  // v3.5: if-let + v3.7: 상태 머신
  if state == "ACTIVE" {
    if alert_level > 0 {
      println("  [경고] 활성 상태에서 알람 감지: {}", alert_level);
      state = "ALERT";
    } else {
      println("  [정상] 활성 상태, 알람 없음");
    }
  }

  // 상태 전이
  if state == "ALERT" {
    alert_level = alert_level + 5;
    if alert_level >= 10 {
      println("  [비상] 알람 레벨 {} 도달", alert_level);
      state = "EMERGENCY";
    } else {
      println("  [경고] 알람 레벨: {}", alert_level);
    }
  }

  println("  최종 상태: {}", state);
  println("  최종 알람: {}", alert_level);
}

// [Example 6] 중첩 루프 + 상태 추적
fn example_nested_loops() {
  println("\n=== Example 6: Nested Loops (중첩 루프) ===");

  let matrix = [[1, 2, 3], [10, 20, 30], [100, 200, 300]];
  let mut total = 0;
  let mut high_count = 0;

  println("중첩 루프 처리:");

  // v3.8: 반복자 + v3.1: 조건문
  for row in matrix {
    println("  행 처리:");
    for cell in row {
      // v3.1: 조건문
      if cell >= 100 {
        println("    - {} [높음]", cell);
        high_count = high_count + 1;
      } else if cell >= 10 {
        println("    - {} [중간]", cell);
      } else {
        println("    - {} [낮음]", cell);
      }
      total = total + cell;
    }
  }

  println("  합계: {}", total);
  println("  높은 값 개수: {}", high_count);
}

// [Example 7] 상태 기록: 모든 전이를 로깅
fn example_state_logging() {
  println("\n=== Example 7: State Logging (상태 기록) ===");

  let mut state = "INIT";
  let mut log = [];
  let inputs = [10, 85, 0, 150, 50];

  println("상태 전이 로깅:");

  // v3.8: 반복자 + v3.4: 패턴 매칭 + 기록
  for input in inputs {
    let next_state = match state {
      "INIT" => {
        if input > 0 {
          "READY"
        } else {
          "INIT"
        }
      }
      "READY" => {
        if input >= 100 {
          "EMERGENCY"
        } else if input >= 80 {
          "WARNING"
        } else {
          "ACTIVE"
        }
      }
      "ACTIVE" => {
        if input >= 100 {
          "EMERGENCY"
        } else if input >= 80 {
          "WARNING"
        } else {
          "ACTIVE"
        }
      }
      "WARNING" => {
        if input >= 100 {
          "EMERGENCY"
        } else {
          "WARNING"
        }
      }
      "EMERGENCY" => "EMERGENCY"
      _ => state
    };

    // v3.8: 선언적 기록
    let entry = state + " -> " + next_state + " (input: " + input + ")";
    log.push(entry);

    state = next_state;
  }

  println("  기록:");
  for entry in log {
    println("    {}", entry);
  }
  println("  최종: {}", state);
}

// [Example 8] 결정론적 수렴: 어떤 경로도 안전 상태에 도달
fn example_deterministic_convergence() {
  println("\n=== Example 8: Deterministic Convergence (결정론적 수렴) ===");

  let test_sequences = [
    [10, 20, 30],
    [50, 60, 70],
    [80, 90, 100],
    [0, 0, 0],
    [100, 200, 300],
  ];

  println("모든 경로가 안전 상태로 수렴함을 검증:");

  // v3.8: 반복자 + v3.4: 패턴 매칭
  for seq in test_sequences {
    let mut state = "READY";

    for val in seq {
      state = match state {
        "READY" => {
          if val > 0 {
            "ACTIVE"
          } else {
            "READY"
          }
        }
        "ACTIVE" => {
          if val >= 100 {
            "SAFE"
          } else {
            "ACTIVE"
          }
        }
        "SAFE" => "SAFE"
        _ => "SAFE"
      };
    }

    println("  수열 처리 완료 -> 최종 상태: {}", state);
  }

  println("결론: 모든 경로가 정의된 안전 상태에 도달");
}

// [Example 9] 완전 통합: 모든 v3.1-v3.8 기법을 한 시스템에서 사용
fn example_complete_integration() {
  println("\n=== Example 9: Complete Integration (완전 통합) ===");
  println("모든 v3.1~v3.8 기법의 동시 사용:");

  let mut system_state = "BOOT";
  let mut critical_alerts = 0;
  let sensor_data = [5, 45, 85, 95, 105];
  let mut decisions = [];

  println("\n통합 시스템 실행:");

  // v3.8: 반복자
  for reading in sensor_data {
    println!("  [감지값: {}]", reading);

    // v3.6: 가드 - 조기 종료 조건
    if critical_alerts >= 2 {
      println!("    -> 임계 알람 도달, 시스템 중단");
      break;
    }

    // v3.4 + v3.7: 패턴 매칭 + 상태 머신
    let decision = match system_state {
      "BOOT" => {
        if reading > 0 {
          system_state = "MONITOR";
          "시스템 시작"
        } else {
          "대기"
        }
      }

      "MONITOR" => {
        // v3.1 + v3.2: 조건문 + 범위 검사
        if reading >= 100 {
          critical_alerts = critical_alerts + 1;
          system_state = "ALERT";
          "위험 신호 감지"
        } else if reading >= 80 {
          system_state = "CAUTION";
          "주의 신호 감지"
        } else {
          "정상 운영"
        }
      }

      "CAUTION" => {
        if reading >= 100 {
          critical_alerts = critical_alerts + 1;
          system_state = "ALERT";
          "위험으로 상향"
        } else if reading < 50 {
          system_state = "MONITOR";
          "정상으로 복구"
        } else {
          "주의 유지"
        }
      }

      "ALERT" => {
        critical_alerts = critical_alerts + 1;
        "경고 지속"
      }

      _ => "불명"
    };

    // v3.8: 기록
    decisions.push(decision);

    println("    상태: {} | 결정: {}", system_state, decision);
  }

  println!("\n시스템 요약:");
  println!("  최종 상태: {}", system_state);
  println!("  심각 알람: {}", critical_alerts);
  println!("  의사결정 경로:");
  for d in decisions {
    println!("    - {}", d);
  }

  println!("결론: 제2장의 모든 설계가 완벽하게 통합되었습니다.");
}

