// String Module (14개 함수)
export function split(str: string, sep: string): string[] {
  return str.split(sep);
}

export function join(arr: string[], sep: string): string {
  return arr.join(sep);
}

export function contains(str: string, substr: string): boolean {
  return str.includes(substr);
}

export function trim(str: string): string {
  return str.trim();
}

export function uppercase(str: string): string {
  return str.toUpperCase();
}

export function lowercase(str: string): string {
  return str.toLowerCase();
}

export function replace(str: string, from: string, to: string): string {
  return str.replace(from, to);
}

export function substring(str: string, start: number, end?: number): string {
  return end !== undefined ? str.substring(start, end) : str.substring(start);
}

export function startsWith(str: string, prefix: string): boolean {
  return str.startsWith(prefix);
}

export function endsWith(str: string, suffix: string): boolean {
  return str.endsWith(suffix);
}

export function charAt(str: string, index: number): string {
  return str.charAt(index);
}

export function indexOf(str: string, substr: string): number {
  return str.indexOf(substr);
}

export function length(str: string): number {
  return str.length;
}

export function reverse(str: string): string {
  return str.split('').reverse().join('');
}

// Functional Module (9개 함수)
export function map<T, U>(arr: T[], fn: (x: T) => U): U[] {
  return arr.map(fn);
}

export function filter<T>(arr: T[], fn: (x: T) => boolean): T[] {
  return arr.filter(fn);
}

export function reduce<T, U>(arr: T[], init: U, fn: (acc: U, x: T) => U): U {
  return arr.reduce(fn, init);
}

export function fold<T, U>(arr: T[], init: U, fn: (x: T, acc: U) => U): U {
  return arr.reduce((acc, x) => fn(x, acc), init);
}

export function any<T>(arr: T[], fn: (x: T) => boolean): boolean {
  return arr.some(fn);
}

export function all<T>(arr: T[], fn: (x: T) => boolean): boolean {
  return arr.every(fn);
}

export function find<T>(arr: T[], fn: (x: T) => boolean): T | undefined {
  return arr.find(fn);
}

export function findIndex<T>(arr: T[], fn: (x: T) => boolean): number {
  return arr.findIndex(fn);
}

export function compose<T, U, V>(f: (x: U) => V, g: (x: T) => U): (x: T) => V {
  return (x: T) => f(g(x));
}

// Math Module (10개 함수)
export function abs(n: number): number {
  return Math.abs(n);
}

export function sqrt(n: number): number {
  return Math.sqrt(n);
}

export function pow(base: number, exp: number): number {
  return Math.pow(base, exp);
}

export function floor(n: number): number {
  return Math.floor(n);
}

export function ceil(n: number): number {
  return Math.ceil(n);
}

export function round(n: number): number {
  return Math.round(n);
}

export function sin(x: number): number {
  return Math.sin(x);
}

export function cos(x: number): number {
  return Math.cos(x);
}

export function tan(x: number): number {
  return Math.tan(x);
}

export function random(): number {
  return Math.random();
}

// Array Module (8개 함수)
export function push<T>(arr: T[], x: T): number {
  return arr.push(x);
}

export function pop<T>(arr: T[]): T | undefined {
  return arr.pop();
}

export function shift<T>(arr: T[]): T | undefined {
  return arr.shift();
}

export function unshift<T>(arr: T[], x: T): number {
  return arr.unshift(x);
}

export function slice<T>(arr: T[], start: number, end?: number): T[] {
  return end !== undefined ? arr.slice(start, end) : arr.slice(start);
}

export function concat<T>(arr1: T[], arr2: T[]): T[] {
  return arr1.concat(arr2);
}

export function reverse_array<T>(arr: T[]): T[] {
  return arr.reverse();
}

export function sort<T>(arr: T[], fn?: (a: T, b: T) => number): T[] {
  return fn ? arr.sort(fn) : arr.sort();
}

// JSON Module (6개 함수)
export function parse(json: string): any {
  return JSON.parse(json);
}

export function stringify(obj: any): string {
  return JSON.stringify(obj);
}

export function pretty(obj: any, indent: number = 2): string {
  return JSON.stringify(obj, null, indent);
}

export function encode(obj: any): string {
  return btoa(JSON.stringify(obj));
}

export function decode(encoded: string): any {
  return JSON.parse(atob(encoded));
}

export function isJSON(str: string): boolean {
  try {
    JSON.parse(str);
    return true;
  } catch {
    return false;
  }
}

// Regex Module (7개 함수)
export function match(str: string, pattern: string): RegExpMatchArray | null {
  return str.match(new RegExp(pattern));
}

export function test(str: string, pattern: string): boolean {
  return new RegExp(pattern).test(str);
}

export function replace_regex(str: string, pattern: string, replacement: string): string {
  return str.replace(new RegExp(pattern, 'g'), replacement);
}

export function exec(str: string, pattern: string): RegExpExecArray | null {
  return new RegExp(pattern).exec(str);
}

export function split_regex(str: string, pattern: string): string[] {
  return str.split(new RegExp(pattern));
}

export function matchAll(str: string, pattern: string): IterableIterator<RegExpMatchArray> {
  return str.matchAll(new RegExp(pattern, 'g'));
}

export function escape_regex(str: string): string {
  return str.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}

