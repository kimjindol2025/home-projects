// Time Module (5개 함수)
export function now(): number {
  return Date.now();
}

export function sleep(ms: number): Promise<void> {
  return new Promise(resolve => setTimeout(resolve, ms));
}

export function timer(fn: () => void, interval: number): number {
  return setInterval(fn, interval) as unknown as number;
}

export function clear_timer(id: number): void {
  clearInterval(id as any);
}

export function timeout(fn: () => void, delay: number): number {
  return setTimeout(fn, delay) as unknown as number;
}

