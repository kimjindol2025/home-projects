/**
 * [Test 9] Real-world Scenarios
 */
fn test_real_world_scenarios() {
    println("▶ Real-world Scenarios Test");

    // Scenario 1: Signal handling
    let signal = Some("EMERGENCY_STOP");
    if let Some(msg) = signal {
        println("  ✓ Emergency signal: " + msg);
    }

    // Scenario 2: Optional configuration
    let config = Some(100);
    if let Some(timeout) = config {
        println("  ✓ Timeout configured: " + timeout);
    } else {
        println("  Using default timeout");
    }

    // Scenario 3: Result-like pattern
    let status = Some("SUCCESS");
    let message = "no operation";

    if let Some(s) = status {
        if s == "SUCCESS" {
            message = "operation completed";
            println("  ✓ Status: " + message);
        }
    }

    // Scenario 4: Data extraction
    let user = Some("admin");
    if let Some(u) = user {
        println("  ✓ User authenticated: " + u);
    } else {
        println("  Authentication failed");
    }

    // Scenario 5: Multiple if let
    let data1 = Some(10);
    let data2 = Some(20);
    let sum = 0;

    if let Some(a) = data1 {
        if let Some(b) = data2 {
            sum = a + b;
            println("  ✓ Sum: " + sum);
        }
    }

    println("");
}

/**
 * Helper function
 */
fn get_decreasing(n) {
    if n > 0 {
        return Some(n);
    } else {
        return None;
    }
}

/**
 * Simple assert function
 */
fn assert(condition) {
    if !condition {
        println("❌ ASSERTION FAILED");
    }
}
