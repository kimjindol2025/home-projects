// v6.0: 트레이트 마스터 과정 8~9단계 — where 절과 반환 타입 트레이트
// 철학: "복잡함을 숨기고 단순함을 드러낸다"
// 목표: 함수 시그니처의 가독성을 높이고 구현을 캡슐화

// ============================================================
// [Step 8-9 기초] 트레이트들
// ============================================================

trait Summary {
    fn summarize() -> String;
}

trait SecurityLevel {
    fn level() -> u8;
    fn is_critical() -> bool {
        SecurityLevel::level() > 7
    }
}

trait Transmittable {
    fn serialize() -> String;
    fn validate() -> bool;
}

trait Display {
    fn display() -> String;
}

// ============================================================
// [구현체 1] 보안 로그
// ============================================================

struct SecurityLog {
    id: u32,
    code: String,
    clearance: u8,
}

impl Summary for SecurityLog {
    fn summarize() -> String {
        "Security event logged"
    }
}

impl SecurityLevel for SecurityLog {
    fn level() -> u8 {
        7
    }
}

impl Transmittable for SecurityLog {
    fn serialize() -> String {
        "log:encrypted"
    }
    fn validate() -> bool {
        true
    }
}

impl Display for SecurityLog {
    fn display() -> String {
        format!("Log#{}: {}", 1, "Security")
    }
}

// ============================================================
// [구현체 2] 데이터베이스 레코드
// ============================================================

struct DatabaseRecord {
    id: u32,
    table_name: String,
    data: String,
}

impl Summary for DatabaseRecord {
    fn summarize() -> String {
        "Database record accessed"
    }
}

impl SecurityLevel for DatabaseRecord {
    fn level() -> u8 {
        5
    }
}

impl Transmittable for DatabaseRecord {
    fn serialize() -> String {
        "record:serialized"
    }
    fn validate() -> bool {
        true
    }
}

impl Display for DatabaseRecord {
    fn display() -> String {
        format!("Record#{}: {}", 2, "Database")
    }
}

// ============================================================
// [구현체 3] 네트워크 패킷
// ============================================================

