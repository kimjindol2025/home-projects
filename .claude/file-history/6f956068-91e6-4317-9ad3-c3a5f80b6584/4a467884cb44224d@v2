// ============================================================
// [Step 8 패턴 1] 단순한 가독성 개선
// ============================================================

fn display_summary_step8_v1<T>(item: T)
where
    T: Summary,
{
    println!("[Step 8.1] Summary: {}", T::summarize());
}

// ============================================================
// [Step 8 패턴 2] 다중 타입 정리
// ============================================================

fn merge_logs<T, U>(a: T, b: U)
where
    T: Summary + Display,
    U: Summary + Display,
{
    println!("[Step 8.2] Merged: {} + {}", T::display(), U::display());
}

// ============================================================
// [Step 8 패턴 3] 필터링과 처리
// ============================================================

fn filter_and_process<T>(count: u32)
where
    T: Summary + SecurityLevel + Transmittable,
{
    println!("[Step 8.3] Processing {} items:", count);
    println!("  Summary: {}", T::summarize());
    println!("  Level: {}", T::level());
    println!("  Serialized: {}", T::serialize());
}

// ============================================================
// [Step 8 패턴 4] 복잡한 경계의 명확화
// ============================================================

fn complex_operation<T, U, V>(a: T, b: U, c: V)
where
    T: Summary + Display + Transmittable,
    U: SecurityLevel + Transmittable,
    V: Summary + SecurityLevel,
{
    println!("[Step 8.4] Complex operation:");
    println!("  T - Summary: {}, Display: {}", T::summarize(), T::display());
    println!("  U - Level: {}", U::level());
    println!("  V - Summary: {}, Level: {}", V::summarize(), V::level());
}

// ============================================================
// [Step 8 패턴 5] 제네릭 처리 로직
// ============================================================

fn process_with_transform<T, U>(item: T)
where
    T: Summary,
    U: SecurityLevel,
{
    println!("[Step 8.5] Transform: {} -> Level {}", T::summarize(), U::level());
}

// ============================================================
// [Step 9 기본] 단순한 반환 캡슐화
// ============================================================

fn create_log_step9_v1() -> impl Summary {
    SecurityLog {
        id: 1,
        code: "SEC001".to_string(),
        clearance: 7,
    }
}

// ============================================================
// [Step 9 패턴 1] 조건부 반환 (같은 트레이트)
// ============================================================

fn create_appropriate_log(is_security: bool) -> impl Summary {
    if is_security {
        SecurityLog {
            id: 1,
            code: "CRITICAL".to_string(),
            clearance: 8,
        }
    } else {
        DatabaseRecord {
            id: 1,
            table_name: "general".to_string(),
            data: "routine".to_string(),
        }
    }
}

// ============================================================
// [Step 9 패턴 2] 다중 트레이트 반환
// ============================================================

fn create_secure_log() -> impl Summary + SecurityLevel {
    SecurityLog {
        id: 1,
        code: "SECURE".to_string(),
        clearance: 7,
    }
}

// ============================================================
// [Step 9 패턴 3] 다중 트레이트 반환 (전송 가능)
// ============================================================

fn create_transmittable_log() -> impl Summary + Transmittable {
    SecurityLog {
        id: 1,
        code: "SEND".to_string(),
        clearance: 6,
    }
}

// ============================================================
// [Step 9 패턴 4] 높은 수준의 캡슐화
// ============================================================

fn create_comprehensive_log() -> impl Summary + SecurityLevel + Transmittable {
    SecurityLog {
        id: 1,
        code: "COMPLETE".to_string(),
        clearance: 7,
    }
}

// ============================================================
// [Step 9 패턴 5] 추상 팩토리 패턴
// ============================================================

fn create_report_for_level(level: u8) -> impl Summary + SecurityLevel {
    if level > 5 {
        SecurityLog {
            id: 1,
            code: "HIGH".to_string(),
            clearance: level,
        }
    } else {
        DatabaseRecord {
            id: 1,
            table_name: "logs".to_string(),
            data: "routine".to_string(),
        }
    }
}

// ============================================================
// [Step 8-9 통합] where 절 + impl Trait
// ============================================================

fn process_and_create<T>(item: T) -> impl Summary
where
    T: Summary + SecurityLevel,
{
    println!("[Step 8-9] Processing with level: {}", T::level());
    SecurityLog {
        id: 1,
        code: "PROCESSED".to_string(),
        clearance: T::level(),
    }
}

// ============================================================
// [Step 8-9 고급] 체인 처리
// ============================================================

fn create_and_validate() -> impl Summary + Transmittable
where
{
    let log = SecurityLog {
        id: 1,
        code: "VALIDATED".to_string(),
        clearance: 7,
    };
    log
}

// ============================================================
// [Step 8의 철학] 가독성의 력
// ============================================================

fn demonstrate_where_clause_power() {
    println!("\n=== Step 8: where 절의 힘 ===");

    println!("\n[패턴 1] 단순 가독성");
    display_summary_step8_v1::<SecurityLog>();

    println!("\n[패턴 2] 다중 타입 정리");
    merge_logs::<SecurityLog, DatabaseRecord>(SecurityLog {
        id: 1,
        code: "A".to_string(),
        clearance: 7,
    }, DatabaseRecord {
        id: 2,
        table_name: "B".to_string(),
        data: "data".to_string(),
    });

    println!("\n[패턴 3] 필터와 처리");
    filter_and_process::<SecurityLog>(100);

    println!("\n[패턴 4] 복잡한 경계");
    complex_operation::<SecurityLog, DatabaseRecord, SecurityLog>(
        SecurityLog { id: 1, code: "A".to_string(), clearance: 7 },
        DatabaseRecord { id: 2, table_name: "B".to_string(), data: "C".to_string() },
        SecurityLog { id: 3, code: "D".to_string(), clearance: 5 }
    );

    println!("\n[패턴 5] 제네릭 변환");
    process_with_transform::<SecurityLog, DatabaseRecord>(SecurityLog {
        id: 1,
        code: "TRANSFORM".to_string(),
        clearance: 7,
    });
}

// ============================================================
// [Step 9의 철학] 캡슐화의 력
// ============================================================

fn demonstrate_impl_trait_power() {
    println!("\n=== Step 9: impl Trait의 힘 ===");

    println!("\n[패턴 1] 기본 반환");
    let log1 = create_log_step9_v1();
    println!("[Step 9.1] Created: {}", log1.summarize());

    println!("\n[패턴 2] 조건부 반환");
    let log2 = create_appropriate_log(true);
    println!("[Step 9.2] Appropriate: {}", log2.summarize());

    println!("\n[패턴 3] 다중 트레이트 1");
    let log3 = create_secure_log();
    println!("[Step 9.3] Secure - Summary: {}, Level: {}",
        log3.summarize(), log3.level());

    println!("\n[패턴 4] 다중 트레이트 2");
    let log4 = create_transmittable_log();
    println!("[Step 9.4] Transmittable - Summary: {}, Serialized: {}",
        log4.summarize(), log4.serialize());

    println!("\n[패턴 5] 포괄적 반환");
    let log5 = create_comprehensive_log();
    println!("[Step 9.5] Comprehensive - Summary: {}, Level: {}, Serialized: {}",
        log5.summarize(), log5.level(), log5.serialize());
}

// ============================================================
// [Step 8-9 원칙 1] where 절 vs 기본 형태
// ============================================================

fn explain_where_clause_benefit() {
    println!("\n=== where 절의 이점 ===");

    println!("\n❌ 나쁜 예 (한 줄에 다 때려 박음):");
    println!("  fn process<T: Summary + Display + Transmittable, U: SecurityLevel + Clone>(a: T, b: U) { }");
    println!("  → 뭐가 뭔지 한눈에 파악 어려움");

    println!("\n✅ 좋은 예 (where 절로 정리):");
    println!("  fn process<T, U>(a: T, b: U)");
    println!("  where");
    println!("      T: Summary + Display + Transmittable,");
    println!("      U: SecurityLevel + Clone,");
    println!("  {{ }}");
    println!("  → 각 타입의 역할이 명확");
}

// ============================================================
// [Step 8-9 원칙 2] impl Trait vs 구체적 타입
// ============================================================

fn explain_impl_trait_benefit() {
    println!("\n=== impl Trait의 이점 ===");

    println!("\n❌ 나쁜 예 (구체적 타입 반환):");
    println!("  pub fn create() -> SecurityLog {{ }}");
    println!("  → SecurityLog 구현 변경 = API 변경");
    println!("  → 클라이언트가 구체적 구현에 의존");

    println!("\n✅ 좋은 예 (impl Trait 반환):");
    println!("  pub fn create() -> impl Summary {{ }}");
    println!("  → 구현을 DatabaseRecord로 변경해도 API 유지");
    println!("  → 클라이언트는 Summary 트레이트만 사용");
}

// ============================================================
// [Step 8-9 원칙 3] 의존성 역전
// ============================================================

fn explain_dependency_inversion() {
    println!("\n=== 의존성 역전 원칙 ===");

    println!("\nBefore (의존성이 아래로):");
    println!("  Client");
    println!("    ↓");
    println!("  SecurityLog (구체적 타입)");
    println!("    ↓");
    println!("  Database (구현 세부)");
    println!("  → Client가 구현 변경의 영향을 받음");

    println!("\nAfter (의존성을 역전):");
    println!("  Client");
    println!("    ↓");
    println!("  impl Summary (인터페이스)");
    println!("    ↓");
    println!("  구현 (SecurityLog, DatabaseRecord, ...)");
    println!("  → Client는 인터페이스만 사용");
}

// ============================================================
// [Step 8-9 원칙 4] 정적 vs 동적 다형성
// ============================================================

fn explain_polymorphism_types() {
    println!("\n=== 정적 vs 동적 다형성 ===");

    println!("\n정적 다형성 (impl Trait):");
    println!("  ✓ 컴파일 타임에 구체적 타입 결정");
    println!("  ✓ 런타임 오버헤드 없음");
    println!("  ✓ 모든 오류 컴파일 타임에 감지");
    println!("  ✓ 인라인 최적화 가능");

    println!("\n동적 다형성 (&dyn Trait):");
    println!("  ✓ 런타임에 타입 결정");
    println!("  ✓ 유연성 높음");
    println!("  ✗ 런타임 오버헤드 있음");
    println!("  ✗ 일부 오류가 런타임에 발생");
}

