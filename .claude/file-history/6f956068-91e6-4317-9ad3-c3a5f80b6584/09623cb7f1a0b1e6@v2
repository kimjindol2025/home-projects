// Pattern 3.1: 버전 관리
struct Version {
    major: u32,
    minor: u32,
    patch: u32,
}

impl Version {
    fn new(major: u32, minor: u32, patch: u32) -> Self {
        Self { major, minor, patch }
    }

    fn is_compatible(&self, other: &Version) -> bool {
        self.major == other.major  // 같은 메이저 버전
    }
}

fn deployment_version() {
    let v19_0_0 = Version::new(19, 0, 0);
    let v19_0_1 = Version::new(19, 0, 1);
    let v20_0_0 = Version::new(20, 0, 0);

    assert!(v19_0_0.is_compatible(&v19_0_1));
    assert!(!v19_0_0.is_compatible(&v20_0_0));
}

