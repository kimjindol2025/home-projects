// Pattern 3.3: 다중 플랫폼 지원
enum Platform {
    Linux,
    Windows,
    MacOS,
}

impl Platform {
    fn install_path(&self) -> String {
        match self {
            Platform::Linux => "/usr/local/freelang".to_string(),
            Platform::Windows => "C:\\Program Files\\Freelang".to_string(),
            Platform::MacOS => "/usr/local/freelang".to_string(),
        }
    }
}

fn deployment_platform() {
    let linux = Platform::Linux;
    let windows = Platform::Windows;
    println!("Linux: {}", linux.install_path());
    println!("Windows: {}", windows.install_path());
}

