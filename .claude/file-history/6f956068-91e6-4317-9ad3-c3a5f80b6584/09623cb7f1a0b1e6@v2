// ================================================================================
// Pattern Group 1: FFI 기초 (Foreign Function Interface)
// ================================================================================

// Pattern 1.1: C 라이브러리 링크 및 함수 호출
#[link("libc")]
extern "C" {
    fn printf(format: *const u8, ...) -> i32;
    fn strlen(s: *const u8) -> usize;
}

fn ffi_basic() {
    unsafe {
        printf(c"Hello from C library!\n");
    }
}

// Pattern 1.2: 포인터 조작
fn ffi_pointers() {
    let c_string = c"Hello, Gogs!";
    unsafe {
        let len = strlen(c_string as *const u8);
        printf(c"String length: %zu\n", len);
    }
}

// Pattern 1.3: 구조체 전달
#[repr(C)]
struct Point {
    x: f64,
    y: f64,
}

extern "C" {
    fn distance(p1: *const Point, p2: *const Point) -> f64;
}

fn ffi_structs() {
    let p1 = Point { x: 0.0, y: 0.0 };
    let p2 = Point { x: 3.0, y: 4.0 };
    unsafe {
        let d = distance(&p1, &p2);
        println!("Distance: {}", d);
    }
}

// Pattern 1.4: 메모리 할당/해제
extern "C" {
    fn malloc(size: usize) -> *mut u8;
    fn free(ptr: *mut u8);
}

fn ffi_memory() {
    unsafe {
        let ptr = malloc(1024);
        if !ptr.is_null() {
            *ptr = 42;
            free(ptr);
        }
    }
}

// Pattern 1.5: 콜백 함수
type Callback = extern "C" fn(i32) -> i32;

extern "C" {
    fn register_callback(cb: Callback);
}

extern "C" fn my_callback(value: i32) -> i32 {
    println!("Callback called with: {}", value);
    value * 2
}

fn ffi_callbacks() {
    unsafe {
        register_callback(my_callback);
    }
}

