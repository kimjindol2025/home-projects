// Pattern 2.1: 기본 에러 타입
struct Diagnostic {
    code: String,
    message: String,
    line: usize,
    column: usize,
    suggestion: Option<String>,
}

fn diagnostic_basic() {
    let error = Diagnostic {
        code: "E0308".to_string(),
        message: "type mismatch".to_string(),
        line: 5,
        column: 12,
        suggestion: Some("try using 'i32' instead".to_string()),
    };
    println!("Error: {}", error.message);
}

// Pattern 2.2: 상세 에러 보고
fn diagnostic_detailed() {
    println!("\nerror[E0308]: type mismatch");
    println!("  --> src/main.gogs:5:12");
    println!("   |");
    println!(" 5 | let x = \"hello\" + 1;");
    println!("   |          ^^^^^^^ expected `i32`, found `&str`");
    println!(" help: try converting the `&str` to `i32`:");
    println!("   |");
    println!(" 5 | let x = \"hello\".parse::<i32>()? + 1;");
}

// Pattern 2.3: 경고와 노트
fn diagnostic_warnings() {
    println!("warning: unused variable");
    println!("  --> src/main.gogs:10:9");
    println!("   |");
    println!("10 | let unused = 42;");
    println!("   |     ^^^^^^ help: if this is intentional, prefix with '_'");
}

// Pattern 2.4: 다중 에러 보고
fn diagnostic_multiple() {
    let errors = vec![
        ("E0308", "type mismatch", 5, 12),
        ("E0425", "cannot find `x` in this scope", 10, 5),
        ("E0382", "borrow of moved value", 15, 8),
    ];

    for (code, msg, line, col) in errors {
        println!("error[{}]: {} at {}:{}", code, msg, line, col);
    }
}

// Pattern 2.5: 컨텍스트와 함께 표시
fn diagnostic_context() {
    let code_lines = vec![
        ("fn main() {", 1),
        ("    let x = \"10\";", 2),
        ("    let y = x + 1;", 3),  // 에러
        ("}", 4),
    ];

    println!("error: type mismatch at line 3");
    for (line, num) in code_lines {
        if num == 3 {
            println!(" 3 | {} ← 에러", line);
        } else {
            println!(" {} | {}", num, line);
        }
    }
}

