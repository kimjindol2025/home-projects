/* ============================================================
   PATCH 1: knex-c SQL Injection Fix

   기존 (취약함):
     sprintf(query, "SELECT * FROM users WHERE id=%s", user_id);

   수정 (안전함):
     사용자 입력을 파라미터로 분리
   ============================================================ */

#define MAX_QUERY_LEN 4096
#define MAX_PARAM_LEN 256

typedef struct {
    char query_template[MAX_QUERY_LEN];
    char *params[10];  // PreparedStatement 파라미터
    int param_count;
} PreparedStatement;

// 안전한 쿼리 빌더
void knex_safe_query_build(PreparedStatement *stmt, const char *template, ...) {
    assert(stmt != NULL);
    assert(template != NULL);

    // Query template만 저장 (파라미터는 분리)
    strncpy(stmt->query_template, template, MAX_QUERY_LEN - 1);
    stmt->query_template[MAX_QUERY_LEN - 1] = '\0';

    // 파라미터는 나중에 바인딩 (SQL Injection 방지)
    stmt->param_count = 0;
}

// PreparedStatement 파라미터 바인딩 (안전함)
int knex_bind_param(PreparedStatement *stmt, const char *value) {
    if (stmt->param_count >= 10) return -1;
    if (strlen(value) > MAX_PARAM_LEN - 1) return -2;  // 크기 검증

    char *param = malloc(MAX_PARAM_LEN);
    strncpy(param, value, MAX_PARAM_LEN - 1);
    param[MAX_PARAM_LEN - 1] = '\0';

    stmt->params[stmt->param_count++] = param;
    return 0;
}

// 테스트: knex-c 수정 후
void test_knex_remediation() {
    printf("\n=== REMEDIATION: knex-c SQL Injection ===\n");

    PreparedStatement stmt = {0};
    const char *template = "SELECT * FROM users WHERE username=? AND role=?";

    knex_safe_query_build(&stmt, template);

    // 악의적 입력: admin' OR '1'='1
    int result = knex_bind_param(&stmt, "admin' OR '1'='1");

    if (result == 0) {
        printf("✅ Parameter bound safely (SQL Injection 방지)\n");
        printf("   Query template: %s\n", stmt.query_template);
        printf("   Param 1: %s\n", stmt.params[0]);
    }

    // 메모리 정리
    for (int i = 0; i < stmt.param_count; i++) {
        free(stmt.params[i]);
    }
}

/* ============================================================
   PATCH 2: fs-c Buffer Overflow Fix

   기존 (취약함):
     char buffer[256];
     strcpy(buffer, user_path);  // ← Buffer Overflow!

   수정 (안전함):
     strncpy() with size check
   ============================================================ */

#define FS_MAX_PATH 4096

// 안전한 파일 경로 복사
int fs_safe_copy_path(char *dest, size_t dest_size, const char *src) {
    if (src == NULL || dest == NULL) {
        return -1;  // NULL 포인터 검사
    }

    if (strlen(src) >= dest_size) {
        fprintf(stderr, "❌ Path too long: %zu > %zu\n", strlen(src), dest_size);
        return -2;  // 크기 초과
    }

    strncpy(dest, src, dest_size - 1);
    dest[dest_size - 1] = '\0';

    return 0;  // 성공
}

// 테스트: fs-c 수정 후
void test_fs_c_remediation() {
    printf("\n=== REMEDIATION: fs-c Buffer Overflow ===\n");

    char safe_buffer[FS_MAX_PATH];
    char *long_path = "very/long/path/that/exceeds/original/buffer/size/...";

    int result = fs_safe_copy_path(safe_buffer, sizeof(safe_buffer), long_path);

    if (result == 0) {
        printf("✅ Path copied safely: %s\n", safe_buffer);
    } else if (result == -2) {
        printf("✅ Buffer Overflow prevented\n");
    }
}

/* ============================================================
   PATCH 3: body-c Input Validation Fix

   기존 (취약함):
     char *body = malloc(request->content_length);  // 무제한!

   수정 (안전함):
     크기 제한 검사 추가
   ============================================================ */

#define MAX_BODY_SIZE (10 * 1024 * 1024)  // 10MB 제한

struct BodyParser {
    size_t max_size;
    size_t current_size;
    char *data;
};

// 안전한 Body 파싱
int body_parse_safe(struct BodyParser *parser, const char *chunk, size_t chunk_size) {
    if (chunk == NULL || chunk_size == 0) {
        return 0;  // 빈 청크
    }

    // 크기 제한 검사 (DoS 방지)
    if (parser->current_size + chunk_size > parser->max_size) {
        fprintf(stderr, "❌ Body size exceeds limit: %zu + %zu > %zu\n",
                parser->current_size, chunk_size, parser->max_size);
        return -1;  // 크기 초과 - 공격 차단
    }

    // 안전하게 추가
    parser->current_size += chunk_size;
    return 0;  // 성공
}

// 테스트: body-c 수정 후
void test_body_c_remediation() {
    printf("\n=== REMEDIATION: body-c DoS Attack ===\n");

    struct BodyParser parser = {
        .max_size = MAX_BODY_SIZE,
        .current_size = 0
    };

    // 공격 시뮬레이션: 500MB body
    size_t attack_size = 500 * 1024 * 1024;
    int result = body_parse_safe(&parser, "X", attack_size);

    if (result == -1) {
        printf("✅ DoS attack blocked - size limit exceeded\n");
    } else {
        printf("❌ Attack still possible\n");
    }
}

/* ============================================================
   PATCH 4: chalk-c Format String Fix

   기존 (취약함):
     char *user_format = get_user_input();
     printf(user_format);  // ← Format String!

   수정 (안전함):
     printf("%s", user_format);  // 포맷 스트링 분리
   ============================================================ */

// 안전한 출력 함수
void chalk_safe_print(const char *message) {
    if (message == NULL) return;

    // 사용자 입력을 포맷 스트링으로 사용하지 않음
    printf("%s", message);  // Safe!
}

// 테스트: chalk-c 수정 후
void test_chalk_c_remediation() {
    printf("\n=== REMEDIATION: chalk-c Format String ===\n");

    char user_input[] = "%x %x %x %x %s";  // 악의적 포맷 스트링

    printf("Unsafe (vulnerable):  ");
    // printf(user_input);  // ❌ 취약함
    printf("[skipped - vulnerable]\n");

    printf("Safe (remediated):    ");
    chalk_safe_print(user_input);  // ✅ 안전함
    printf("\n");
}

