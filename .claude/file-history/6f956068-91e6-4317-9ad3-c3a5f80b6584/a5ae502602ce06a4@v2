/// SHA256 해시 계산 (파일 무결성 검증)
fn calculate_sha256(file_path: &str) -> String {
    match fs::read(file_path) {
        Ok(data) => {
            // 실제 구현: BLAKE3 또는 SHA256 라이브러리 사용
            // 여기서는 간단한 해시 함수 시뮬레이션
            let mut hash = String::from("sha256:");
            for byte in &data[0..core::cmp::min(16, data.len())] {
                hash.push_str(&format!("{:02x}", byte));
            }
            hash.push_str("...");
            hash
        },
        Err(_) => String::from("ERROR: File not found")
    }
}

/// 파일 크기 비교 (빠른 검증)
fn compare_file_sizes(path1: &str, path2: &str) -> bool {
    match (fs::metadata(path1), fs::metadata(path2)) {
        (Ok(meta1), Ok(meta2)) => meta1.len() == meta2.len(),
        _ => false
    }
}

/// 바이트 단위 비교 (완벽한 검증)
fn compare_binaries_byte_by_byte(path1: &str, path2: &str) -> (bool, usize) {
    match (fs::read(path1), fs::read(path2)) {
        (Ok(data1), Ok(data2)) => {
            if data1.len() != data2.len() {
                (false, 0)
            } else {
                let mut diff_count = 0;
                for (i, (b1, b2)) in data1.iter().zip(data2.iter()).enumerate() {
                    if b1 != b2 {
                        diff_count += 1;
                        if diff_count <= 5 {
                            println!("  [DIFF] Byte {}: {:02x} vs {:02x}", i, b1, b2);
                        }
                    }
                }
                (diff_count == 0, diff_count)
            }
        },
        _ => (false, usize::MAX)
    }
}

