//! v31.0 Neural-Runtime: 신경망 + 양자 + 고전 하이브리드 실행
//! 박사 과정 제2단계: 신경망과 런타임의 완전 결합
//!
//! 철학: "신경망의 유연성" + "양자의 가능성" + "고전의 확실성"
//! 이 세 가지를 타입 시스템으로 통합하여, 결정론적이면서도
//! 적응형인 완벽한 런타임을 달성합니다.
//!
//! **목표**: 세 계층을 매끄럽게 결합하여 자기 개선, 자기 학습 언어 실현

use std::collections::HashMap;
use std::sync::{Arc, Mutex};
use std::marker::PhantomData;

// ============================================================================
// 파트 1: 신경망 기초 (Neural Network Foundation)
// ============================================================================

/// 활성화 함수 (Activation Function)
pub trait Activation: Send + Sync {
    fn forward(&self, x: f64) -> f64;
    fn backward(&self, x: f64) -> f64;  // 도함수 (derivative)
}

pub struct ReLU;
impl Activation for ReLU {
    fn forward(&self, x: f64) -> f64 {
        if x > 0.0 { x } else { 0.0 }
    }
    fn backward(&self, x: f64) -> f64 {
        if x > 0.0 { 1.0 } else { 0.0 }
    }
}

pub struct Sigmoid;
impl Activation for Sigmoid {
    fn forward(&self, x: f64) -> f64 {
        1.0 / (1.0 + (-x).exp())
    }
    fn backward(&self, x: f64) -> f64 {
        let s = self.forward(x);
        s * (1.0 - s)
    }
}

pub struct Tanh;
impl Activation for Tanh {
    fn forward(&self, x: f64) -> f64 {
        x.tanh()
    }
    fn backward(&self, x: f64) -> f64 {
        let t = x.tanh();
        1.0 - (t * t)
    }
}

/// 신경망 레이어 (Neural Layer)
///
/// ```
/// 입력: [x₁, x₂, ..., xₙ]
///       ↓ (가중치 행렬)
/// 은닉: [z₁, z₂, ..., zₘ]
///       ↓ (활성화 함수)
/// 출력: [y₁, y₂, ..., yₘ]
/// ```
pub struct NeuralLayer {
    input_size: usize,
    output_size: usize,
    weights: Vec<Vec<f64>>,  // [output_size][input_size]
    biases: Vec<f64>,        // [output_size]
    activation: String,      // "relu", "sigmoid", "tanh"
    learning_rate: f64,
}

impl NeuralLayer {
    pub fn new(
        input_size: usize,
        output_size: usize,
        activation: &str,
        learning_rate: f64,
    ) -> Self {
        // Xavier 초기화: 가중치를 [-√6/(n+m), √6/(n+m)] 범위로 초기화
        let limit = (6.0 / (input_size + output_size) as f64).sqrt();

        let mut weights = vec![vec![0.0; input_size]; output_size];
        let mut biases = vec![0.0; output_size];

        // 의사 난수 생성 (시드 기반 결정론적)
        let mut seed: u64 = 0x1234567890abcdef;
        for i in 0..output_size {
            for j in 0..input_size {
                seed = seed.wrapping_mul(6364136223846793005).wrapping_add(1);
                let r = ((seed as f64) / (u64::MAX as f64)) * 2.0 - 1.0;
                weights[i][j] = r * limit;
            }
            seed = seed.wrapping_mul(6364136223846793005).wrapping_add(1);
            let r = ((seed as f64) / (u64::MAX as f64)) * 2.0 - 1.0;
            biases[i] = r * limit;
        }

        NeuralLayer {
            input_size,
            output_size,
            weights,
            biases,
            activation: activation.to_string(),
            learning_rate,
        }
    }

    /// Forward pass: 입력 → 출력 계산
    pub fn forward(&self, input: &[f64]) -> Vec<f64> {
        assert_eq!(input.len(), self.input_size, "입력 크기 불일치");

        let mut output = vec![0.0; self.output_size];

        // 선형 변환: y = Wx + b
        for i in 0..self.output_size {
            let mut z = self.biases[i];
            for j in 0..self.input_size {
                z += self.weights[i][j] * input[j];
            }

            // 활성화 함수 적용
            output[i] = match self.activation.as_str() {
                "relu" => ReLU.forward(z),
                "sigmoid" => Sigmoid.forward(z),
                "tanh" => Tanh.forward(z),
                _ => z,
            };
        }

        output
    }

    /// Backward pass: 그래디언트 계산 (역전파)
    pub fn backward(&self, input: &[f64], output_grad: &[f64]) -> Vec<f64> {
        let mut input_grad = vec![0.0; self.input_size];

        // 활성화 함수의 도함수를 고려한 그래디언트 계산
        for i in 0..self.output_size {
            let mut z = self.biases[i];
            for j in 0..self.input_size {
                z += self.weights[i][j] * input[j];
            }

            let activation_grad = match self.activation.as_str() {
                "relu" => ReLU.backward(z),
                "sigmoid" => Sigmoid.backward(z),
                "tanh" => Tanh.backward(z),
                _ => 1.0,
            };

            let delta = output_grad[i] * activation_grad;

            // 입력 그래디언트 누적
            for j in 0..self.input_size {
                input_grad[j] += delta * self.weights[i][j];
            }
        }

        input_grad
    }

    /// 가중치 업데이트 (경사 하강법)
    pub fn update(&mut self, input: &[f64], output_grad: &[f64]) {
        for i in 0..self.output_size {
            // 바이어스 업데이트
            self.biases[i] -= self.learning_rate * output_grad[i];

            // 가중치 업데이트
            for j in 0..self.input_size {
                self.weights[i][j] -= self.learning_rate * output_grad[i] * input[j];
            }
        }
    }
}

// ============================================================================
// 파트 2: 신경망 모델 (Neural Network Model)
// ============================================================================

pub struct NeuralNetwork {
    layers: Vec<NeuralLayer>,
    input_size: usize,
    output_size: usize,
}

impl NeuralNetwork {
    /// 신경망 생성: input_size → [hidden_sizes] → output_size
    pub fn new(
        input_size: usize,
        hidden_sizes: Vec<usize>,
        output_size: usize,
        learning_rate: f64,
    ) -> Self {
        let mut layers = Vec::new();
        let mut prev_size = input_size;

        // 은닉층들
        for (i, &size) in hidden_sizes.iter().enumerate() {
            let activation = if i < hidden_sizes.len() - 1 {
                "relu"  // 중간 레이어: ReLU
            } else {
                "sigmoid"  // 마지막 레이어: Sigmoid
            };

            layers.push(NeuralLayer::new(prev_size, size, activation, learning_rate));
            prev_size = size;
        }

        // 출력층
        layers.push(NeuralLayer::new(prev_size, output_size, "sigmoid", learning_rate));

        NeuralNetwork {
            layers,
            input_size,
            output_size,
        }
    }

    /// 추론 (Inference): input → output 계산
    pub fn predict(&self, input: &[f64]) -> Vec<f64> {
        let mut data = input.to_vec();

        for layer in &self.layers {
            data = layer.forward(&data);
        }

        data
    }

    /// 훈련 스텝 (Training Step): 손실 역전파 및 가중치 업데이트
    pub fn train_step(
        &mut self,
        input: &[f64],
        target: &[f64],
    ) -> f64 {  // 반환: MSE 손실값
        // Forward pass: 각 레이어의 활성화 저장
        let mut activations = vec![input.to_vec()];
        let mut data = input.to_vec();

        for layer in &self.layers {
            data = layer.forward(&data);
            activations.push(data.clone());
        }

        // 손실 계산: Mean Squared Error (MSE)
        let mut loss = 0.0;
        let mut output_grad = vec![0.0; self.output_size];
        for i in 0..self.output_size {
            let error = data[i] - target[i];
            loss += error * error;
            output_grad[i] = 2.0 * error / self.output_size as f64;  // 그래디언트
        }
        loss /= 2.0;

        // Backward pass: 역전파
        let mut current_grad = output_grad;
        for i in (0..self.layers.len()).rev() {
            let layer = &mut self.layers[i];
            let input_data = &activations[i];
            let output_data = &activations[i + 1];

            // 가중치 업데이트
            layer.update(input_data, &current_grad);

            // 이전 레이어로 그래디언트 역전파
            if i > 0 {
                current_grad = layer.backward(input_data, &current_grad);
            }
        }

        loss
    }
}

