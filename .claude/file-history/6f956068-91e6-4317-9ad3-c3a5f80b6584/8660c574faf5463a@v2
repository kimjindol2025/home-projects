/// 3계층 하이브리드 실행 엔진
///
/// 고전층 (Classical)
///    ↓ (벡터화)
/// 신경망층 (Neural)
///    ↓ (기저 상태)
/// 양자층 (Quantum)
///    ↓ (측정)
/// 신경망층 (post-processing)
///    ↓ (디코딩)
/// 고전층 (결과)
pub struct HybridBridge {
    classical_layer: NeuralNetwork,
    neural_quantum_layer: QuantumNeuralLayer,
    post_processing: NeuralNetwork,
    hybrid_cache: Arc<Mutex<HashMap<String, Vec<f64>>>>,
}

impl HybridBridge {
    pub fn new(
        input_size: usize,
        hidden_sizes: Vec<usize>,
        quantum_qubits: usize,
        output_size: usize,
        learning_rate: f64,
    ) -> Self {
        let classical_layer = NeuralNetwork::new(
            input_size,
            hidden_sizes.clone(),
            quantum_qubits,
            learning_rate,
        );

        let neural_quantum_layer = QuantumNeuralLayer::new(quantum_qubits);

        let post_processing = NeuralNetwork::new(
            quantum_qubits,
            vec![quantum_qubits / 2],
            output_size,
            learning_rate,
        );

        HybridBridge {
            classical_layer,
            neural_quantum_layer,
            post_processing,
            hybrid_cache: Arc::new(Mutex::new(HashMap::new())),
        }
    }

    /// 3계층 하이브리드 추론
    pub fn hybrid_predict(&self, input: &[f64]) -> Vec<f64> {
        // 1단계: 고전 신경망 → 양자 기저 상태 인코딩
        let encoded = self.classical_layer.predict(input);

        // 2단계: 양자 신경 레이어 → 얽힘 회로 실행
        let quantum_input = QuantumState::Classic(encoded);
        let quantum_output = self.neural_quantum_layer.forward(quantum_input);

        // 3단계: 측정 → 고전 벡터로 변환
        let measured = self.neural_quantum_layer.measure(quantum_output);

        // 4단계: 후처리 신경망 → 최종 출력
        let output = self.post_processing.predict(&measured);

        output
    }

    /// 3계층 하이브리드 훈련 (변분 양자 고유 솔버 방식)
    pub fn hybrid_train(
        &mut self,
        input: &[f64],
        target: &[f64],
    ) -> f64 {
        // 1단계: 고전층 훈련
        let classical_loss = self.classical_layer.train_step(input, &target);

        // 2단계: 양자층을 통과한 출력
        let encoded = self.classical_layer.predict(input);
        let quantum_input = QuantumState::Classic(encoded);
        let quantum_output = self.neural_quantum_layer.forward(quantum_input);
        let measured = self.neural_quantum_layer.measure(quantum_output);

        // 3단계: 후처리층 훈련
        let post_loss = self.post_processing.train_step(&measured, target);

        // 하이브리드 손실: 가중 평균
        (classical_loss + post_loss) / 2.0
    }

    /// 캐시된 결과 조회
    pub fn get_cached(&self, key: &str) -> Option<Vec<f64>> {
        self.hybrid_cache
            .lock()
            .ok()
            .and_then(|cache| cache.get(key).cloned())
    }

    /// 결과 캐시 저장
    pub fn cache_result(&self, key: String, value: Vec<f64>) {
        if let Ok(mut cache) = self.hybrid_cache.lock() {
            cache.insert(key, value);
        }
    }
}

