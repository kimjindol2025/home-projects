fn main() {
    println!("═══════════════════════════════════════════════════════════");
    println!("v31.0 Neural-Runtime: 신경망 + 양자 + 고전 하이브리드");
    println!("═══════════════════════════════════════════════════════════\n");

    // 간단한 분류 데이터셋 (XOR 문제)
    let training_data = vec![
        (vec![0.0, 0.0], vec![0.0, 1.0]),  // 클래스 0
        (vec![0.0, 1.0], vec![1.0, 0.0]),  // 클래스 1
        (vec![1.0, 0.0], vec![1.0, 0.0]),  // 클래스 1
        (vec![1.0, 1.0], vec![0.0, 1.0]),  // 클래스 0
    ];

    // 테스트 데이터
    let test_data = training_data.clone();

    // 1. 신경망만 테스트
    println!("1️⃣  순수 신경망 (Neural Layer Only)");
    let mut nn = NeuralNetwork::new(2, vec![4], 2, 0.5);
    for epoch in 0..50 {
        let mut epoch_loss = 0.0;
        for (input, target) in &training_data {
            epoch_loss += nn.train_step(input, target);
        }
        if epoch % 10 == 0 {
            println!("   에폭 {}: 손실 = {:.4}", epoch, epoch_loss / training_data.len() as f64);
        }
    }
    println!();

    // 2. 하이브리드 브릿지 테스트
    println!("2️⃣  하이브리드 브릿지 (Classical + Neural + Quantum)");
    let mut bridge = HybridBridge::new(2, vec![4], 4, 2, 0.5);

    for epoch in 0..50 {
        let mut epoch_loss = 0.0;
        for (input, target) in &training_data {
            epoch_loss += bridge.hybrid_train(input, target);
        }
        if epoch % 10 == 0 {
            println!("   에폭 {}: 손실 = {:.4}", epoch, epoch_loss / training_data.len() as f64);
        }
    }
    println!();

    // 3. 자기 개선 엔진 테스트
    println!("3️⃣  자기 개선 엔진 (Self-Improvement Engine)");
    let engine = SelfImprovementEngine::new(2, vec![4], 4, 2, 0.5);

    match engine.self_train(&training_data) {
        Ok(iterations) => println!("   ✅ 훈련 완료: {} 반복", iterations),
        Err(e) => println!("   ❌ 훈련 실패: {}", e),
    }

    match engine.self_evaluate(&test_data) {
        Ok(accuracy) => println!("   정확도: {:.2}%", accuracy * 100.0),
        Err(e) => println!("   ❌ 평가 실패: {}", e),
    }

    match engine.self_optimize() {
        Ok(msg) => println!("{}", msg),
        Err(e) => println!("   ❌ 최적화 실패: {}", e),
    }
    println!();

    println!("═══════════════════════════════════════════════════════════");
    println!("v31.0 완성!");
    println!("철학: \"신경망의 유연성 + 양자의 가능성 + 고전의 확실성\"");
    println!("기록이 증명이다 gogs. 👑");
    println!("═══════════════════════════════════════════════════════════");
}
