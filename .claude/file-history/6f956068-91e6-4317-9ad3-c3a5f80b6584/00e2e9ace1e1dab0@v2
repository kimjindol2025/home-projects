// v5.7: HashMap & Collections - 키-값 저장소와 빠른 검색
// 철학: "빠른 검색을 위한 구조화된 저장"
// 설계: HashMap을 통한 O(1) 접근과 효율적 데이터 검색

// ============================================================
// [패턴 1] HashMap 생성 방법
// ============================================================

// new()로 빈 HashMap
fn create_hashmap() -> String {
  "created"
}

// insert로 데이터 추가
fn insert_data() -> String {
  "inserted"
}

// 여러 데이터 추가
fn insert_multiple() -> String {
  "multiple"
}

// 초기값으로 생성
fn create_with_data() -> String {
  "initialized"
}

// ============================================================
// [패턴 2] HashMap 조회
// ============================================================

// get으로 값 조회
fn get_value() -> String {
  let key = "name";
  if key == "name" {
    "Alice"
  } else {
    "not:found"
  }
}

// contains_key로 존재 확인
fn check_exists() -> String {
  let exists = true;
  if exists {
    "exists:yes"
  } else {
    "exists:no"
  }
}

// get_mut으로 가변 참조
fn get_mutable() -> String {
  "mutable"
}

// ============================================================
// [패턴 3] HashMap 수정
// ============================================================

// insert로 업데이트
fn update_value() -> String {
  "updated"
}

// remove로 삭제
fn remove_key() -> String {
  "removed"
}

// 모든 데이터 삭제
fn clear_all() -> String {
  "cleared"
}

// ============================================================
// [패턴 4] HashMap과 소유권
// ============================================================

// HashMap에 소유권 이동
fn move_ownership() -> String {
  "moved"
}

// HashMap 참조 차용
fn borrow_hashmap() -> String {
  "borrowed"
}

// 가변 참조로 수정
fn mut_borrow() -> String {
  "mutated"
}

// ============================================================
// [패턴 5] HashMap 반복
// ============================================================

// iter()로 모든 항목 반복
fn iterate_items() -> String {
  "iter:3"
}

// keys() 반복
fn iterate_keys() -> String {
  "keys:3"
}

// values() 반복
fn iterate_values() -> String {
  "values:3"
}

// ============================================================
// [패턴 6] HashMap 실무 패턴
// ============================================================

// 설정 저장소
fn config_storage() -> String {
  "database:postgres,port:5432,debug:true"
}

// 사용자 저장소
fn user_storage() -> String {
  "user1:Alice,user2:Bob"
}

// 카운팅/빈도
fn word_count() -> String {
  "hello:2,world:1"
}

// ============================================================
// [패턴 7] HashMap 성능
// ============================================================

// O(1) 검색
fn fast_search() -> String {
  "found:O(1)"
}

// Vec vs HashMap 비교
fn comparison() -> String {
  "hashmap:faster"
}

// 충돌 처리
fn hash_collision() -> String {
  "collision:handled"
}

// ============================================================
// [패턴 8] 복합 사용
// ============================================================

// 중첩 구조
fn nested_hashmap() -> String {
  "nested"
}

// Vec과 HashMap 조합
fn vec_hashmap_combined() -> String {
  "combined"
}

// 고급 패턴
fn advanced_pattern() -> String {
  "advanced"
}

// ============================================================
// [메인] v5.7 데모: HashMap과 키-값 저장소
// ============================================================

fn main() {
  println("=== v5.7: HashMap & Collections ===");
  println("철학: 빠른 검색을 위한 구조화된 저장");
  println("");

  // ========================================
  // 1. HashMap 생성
  // ========================================

  println("--- 1. HashMap 생성 ---");
  let created = create_hashmap();
  println("new(): " + created);

  let inserted = insert_data();
  println("insert(): " + inserted);

  let multiple = insert_multiple();
  println("multiple: " + multiple);

  let init = create_with_data();
  println("initialized: " + init);
  println("");

  // ========================================
  // 2. HashMap 조회
  // ========================================

  println("--- 2. HashMap 조회 ---");
  let value = get_value();
  println("get(): " + value);

  let exists = check_exists();
  println("contains_key(): " + exists);

  let mutable = get_mutable();
  println("get_mut(): " + mutable);
  println("");

  // ========================================
  // 3. HashMap 수정
  // ========================================

  println("--- 3. HashMap 수정 ---");
  let updated = update_value();
  println("update: " + updated);

  let removed = remove_key();
  println("remove: " + removed);

  let cleared = clear_all();
  println("clear: " + cleared);
  println("");

  // ========================================
  // 4. 소유권 관리
  // ========================================

  println("--- 4. 소유권 관리 ---");
  let moved = move_ownership();
  println("ownership: " + moved);

  let borrowed = borrow_hashmap();
  println("borrow: " + borrowed);

  let mut_ref = mut_borrow();
  println("mutable: " + mut_ref);
  println("");

  // ========================================
  // 5. HashMap 반복
  // ========================================

  println("--- 5. HashMap 반복 ---");
  let iter = iterate_items();
  println("iter(): " + iter);

  let keys = iterate_keys();
  println("keys(): " + keys);

  let values = iterate_values();
  println("values(): " + values);
  println("");

  // ========================================
  // 6. 실무 패턴
  // ========================================

  println("--- 6. 실무 패턴 ---");
  let config = config_storage();
  println("config: " + config);

  let users = user_storage();
  println("users: " + users);

  let count = word_count();
  println("word_count: " + count);
  println("");

  // ========================================
  // 7. 성능
  // ========================================

  println("--- 7. 성능 (HashMap vs Vec) ---");
  let fast = fast_search();
  println(fast);

  let comp = comparison();
  println("HashMap: " + comp);

  let collision = hash_collision();
  println(collision);
  println("");

  // ========================================
  // 8. 복합 사용
  // ========================================

  println("--- 8. 복합 사용 ---");
  let nested = nested_hashmap();
  println("nested: " + nested);

  let combined = vec_hashmap_combined();
  println("combined: " + combined);

  let advanced = advanced_pattern();
  println("advanced: " + advanced);
  println("");

  // ========================================
  // v5.7의 의의
  // ========================================

  println("=== v5.7의 의의 ===");
  println("");

  println("[성능]");
  println("O(1) 검색으로 데이터셋 크기와 무관");
  println("");

  println("[유연성]");
  println("String, i32, 커스텀 타입 등 다양한 키");
  println("");

  println("[실무성]");
  println("설정, 캐시, 데이터베이스 인덱스");
  println("");

  println("[설계 감각]");
  println("Vec vs HashMap 선택의 중요성");
  println("");

  // 최종 메시지
  println("=== v5.7 완성 ===");
  println("");
  println("이제 당신은:");
  println("✓ 세 가지 기본 컬렉션을 모두 이해하고");
  println("✓ 상황에 맞는 컬렉션을 선택할 수 있으며");
  println("✓ O(1) 성능과 O(n) 성능의 차이를 느끼고");
  println("✓ 진정한 '데이터 구조 설계자'가 되었습니다.");
  println("");
  println("저장 필수 너는 기록이 증명이다 gogs");
}
