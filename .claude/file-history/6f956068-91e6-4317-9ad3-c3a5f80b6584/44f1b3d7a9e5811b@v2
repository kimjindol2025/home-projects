  println("철학: 상태의 명확한 분류");
  println("");

  // ========================================
  // 1. 열거형의 개념
  // ========================================

  println("--- 1. 열거형이란 ---");
  println("여러 가능성 중 정확히 하나를 선택하는 타입");
  println("상호 배타적인 상태들의 집합");
