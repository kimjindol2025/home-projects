// v5.2: Enums & Patterns - 열거형과 패턴
// 철학: "상태의 명확한 분류"
// 설계: 여러 가능성 중 하나를 선택하는 법

// ============================================================
// [패턴 1] 기본 열거형 구조
// ============================================================

// 데이터가 없는 단순 열거형
fn status_idle() -> String {
  "Idle"
}

fn status_active() -> String {
  "Active"
}

fn status_stopped() -> String {
  "Stopped"
}

// ============================================================
// [패턴 2] SystemSignal 핵심 예제 (다형성 신호)
// ============================================================

// 다양한 형태의 신호를 표현하는 함수 기반 열거형 시뮬레이션
fn signal_reset() -> String {
  "Reset"
}

fn signal_update_version(version: f32) -> String {
  "UpdateVersion:" + version
}

fn signal_error_message(message: String) -> String {
  "ErrorMessage:" + message
}

fn signal_change_color(r: i32, g: i32, b: i32) -> String {
  "ChangeColor:" + r + "," + g + "," + b
}

// 신호를 처리하는 함수 (match 시뮬레이션)
fn handle_signal(signal_type: String, data: String) -> String {
  if signal_type == "Reset" {
    "[ACTION] 시스템 초기화 명령 수신."
  } else if signal_type == "UpdateVersion" {
    "[UPDATE] v" + data + "로 버전 갱신 중..."
  } else if signal_type == "ErrorMessage" {
    "[ERROR] 시스템 경고: " + data
  } else if signal_type == "ChangeColor" {
    "[COLOR] 조명 변경: " + data
  } else {
    "[UNKNOWN] 알 수 없는 신호"
  }
}

// ============================================================
// [패턴 3] 상태 기계 (State Machine)
// ============================================================

fn state_process_idle() -> String {
  "Waiting"
}

fn state_process_running() -> String {
  "Running"
}

fn state_process_paused() -> String {
  "Paused"
}

fn state_process_complete() -> String {
  "Complete"
}

// 상태 전이 함수
fn next_state(current: String) -> String {
  if current == "Waiting" {
    "Running"
  } else if current == "Running" {
    "Paused"
  } else if current == "Paused" {
    "Running"
  } else if current == "Complete" {
    "Waiting"
  } else {
    "Unknown"
  }
}

// ============================================================
// [패턴 4] Result 패턴 (성공/실패)
// ============================================================

fn result_ok(message: String) -> String {
  "Ok:" + message
}

fn result_error(code: i32) -> String {
  "Error:" + code
}

fn divide_safe(a: i32, b: i32) -> String {
  if b == 0 {
    result_error(1)
  } else {
    result_ok("success")
  }
}

// ============================================================
// [패턴 5] Option 패턴 (Some/None)
// ============================================================

fn option_some(value: String) -> String {
  "Some:" + value
}

fn option_none() -> String {
  "None"
}

fn find_user(id: i32) -> String {
  if id > 0 {
    option_some("user_" + id)
  } else {
    option_none()
  }
}

// ============================================================
// [패턴 6] 신호 분류 (다양한 신호 타입)
// ============================================================

fn classify_signal(signal_name: String) -> String {
  if signal_name == "Reset" {
    "single"
  } else if signal_name == "UpdateVersion" {
    "with_version"
  } else if signal_name == "ErrorMessage" {
    "with_message"
  } else if signal_name == "ChangeColor" {
    "with_color"
  } else {
    "unknown"
  }
}

// ============================================================
// [패턴 7] 복합 상태 처리
// ============================================================

fn handle_complex_signal(signal: String, param1: String, param2: String) -> String {
  if signal == "Move" {
    "Moving to: " + param1 + ", " + param2
  } else if signal == "Resize" {
    "Resizing to: " + param1 + "x" + param2
  } else if signal == "Paint" {
    "Painting with: " + param1 + " color " + param2
  } else {
    "Unknown operation"
  }
}

