  println("--- 2. 단순 열거형: 상태만 표현 ---");
  let status1 = status_idle();
  let status2 = status_active();
  let status3 = status_stopped();
  println("상태 1: ");
  println(status1);
  println("상태 2: ");
  println(status2);
  println("상태 3: ");
  println(status3);
  println("");

  // ========================================
  // 3. 데이터를 포함하는 열거형 (Variant with Data)
  // ========================================

  println("--- 3. 데이터를 포함하는 신호 ---");
  let sig1 = signal_reset();
  let sig2 = signal_update_version(5.2);
  let sig3 = signal_error_message("연료 부족");
  let sig4 = signal_change_color(255, 128, 0);
  println("신호 1: ");
  println(sig1);
  println("신호 2: ");
  println(sig2);
  println("신호 3: ");
  println(sig3);
  println("신호 4: ");
  println(sig4);
  println("");

  // ========================================
  // 4. 신호 처리 (match 시뮬레이션)
  // ========================================

  println("--- 4. 신호 처리: match를 통한 패턴 매칭 ---");
  let action1 = handle_signal("Reset", "");
  let action2 = handle_signal("UpdateVersion", "5.2");
  let action3 = handle_signal("ErrorMessage", "연료 부족");
  let action4 = handle_signal("ChangeColor", "255,128,0");
  println(action1);
  println(action2);
  println(action3);
  println(action4);
  println("");

  // ========================================
  // 5. 상태 기계 (State Machine)
  // ========================================

  println("--- 5. 상태 기계: 상태 전이 ---");
  println("시스템이 취할 수 있는 상태들:");
  let st1 = state_process_idle();
  let st2 = state_process_running();
  let st3 = state_process_paused();
  let st4 = state_process_complete();
  println("상태: ");
  println(st1);
  println("→ ");
  println(st2);
  println("→ ");
  println(st3);
  println("");

  // 상태 전이
  println("상태 전이 예시:");
  let current = "Waiting";
  let next = next_state(current);
  println("현재: " + current + " → 다음: " + next);
  println("");

  // ========================================
  // 6. Result 패턴: 성공/실패
  // ========================================

  println("--- 6. Result 패턴: 성공 또는 실패 ---");
  let ok = result_ok("작업 완료");
  let error = result_error(404);
  println("성공: ");
  println(ok);
  println("실패: ");
  println(error);
  println("");

  // 안전한 나눗셈
  println("안전한 계산:");
  let div1 = divide_safe(10, 2);
  let div2 = divide_safe(10, 0);
  println("10 / 2 = ");
  println(div1);
  println("10 / 0 = ");
  println(div2);
  println("");

  // ========================================
  // 7. Option 패턴: Some/None
  // ========================================

  println("--- 7. Option 패턴: 값이 있을 수도 없을 수도 있음 ---");
  let some_user = option_some("Alice");
  let no_user = option_none();
  println("사용자 찾음: ");
  println(some_user);
  println("사용자 없음: ");
  println(no_user);
  println("");

  // 사용자 검색
  println("데이터베이스 검색:");
  let user1 = find_user(1);
  let user2 = find_user(-1);
  println("ID 1: ");
  println(user1);
  println("ID -1: ");
  println(user2);
  println("");

  // ========================================
  // 8. 신호 분류
  // ========================================

  println("--- 8. 신호 분류: 각 신호의 종류 ---");
  let type1 = classify_signal("Reset");
  let type2 = classify_signal("UpdateVersion");
  let type3 = classify_signal("ErrorMessage");
  let type4 = classify_signal("ChangeColor");
  println("Reset 신호 종류: ");
  println(type1);
  println("UpdateVersion 신호 종류: ");
  println(type2);
  println("ErrorMessage 신호 종류: ");
  println(type3);
  println("ChangeColor 신호 종류: ");
  println(type4);
  println("");

  // ========================================
  // 9. 복합 신호 처리
  // ========================================

  println("--- 9. 복합 신호: 여러 파라미터 ---");
  let complex1 = handle_complex_signal("Move", "100", "200");
  let complex2 = handle_complex_signal("Resize", "800", "600");
  let complex3 = handle_complex_signal("Paint", "Red", "Solid");
  println(complex1);
  println(complex2);
  println(complex3);
  println("");

  // ========================================
  // 10. 열거형의 의의
  // ========================================

  println("--- v5.2의 의의 ---");
  println("");
  println("[안전성]");
  println("정의되지 않은 상태가 발생하는 것을 컴파일 타임에 차단");
  println("");

  println("[명확성]");
