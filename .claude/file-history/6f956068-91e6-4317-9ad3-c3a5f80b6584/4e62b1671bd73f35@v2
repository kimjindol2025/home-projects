/* ============================================================
   TEST 1: knex-c SQL INJECTION

   취약점: Direct string concatenation in query building
   공격: user input에서 SQL 명령어 주입
   기대 결과: 데이터베이스 탈취 (현재 - 실패함)
   수정 후 결과: Access Denied 또는 Sanitized
   ============================================================ */

#define TEST_FAIL(desc) printf("❌ FAIL (예상됨): %s\n", desc)
#define TEST_PASS(desc) printf("✅ PASS: %s\n", desc)

void test_knex_c_sql_injection() {
    printf("\n=== TEST 1: knex-c SQL Injection ===\n");

    // 공격 시나리오 1: 관리자 권한 획득
    char malicious_user_input[] = "admin' OR '1'='1";
    char query_buffer[1024];

    // 현재 코드 (취약함)
    // sprintf(query_buffer, "SELECT * FROM users WHERE username='%s'", malicious_user_input);
    // Result: SELECT * FROM users WHERE username='admin' OR '1'='1'  ← ALL ROWS RETURNED

    // 공격 성공 시뮬레이션
    strcpy(query_buffer, "SELECT * FROM users WHERE username='admin' OR '1'='1'");

    // 검증: 쿼리가 WHERE 조건을 우회했는가?
    if (strstr(query_buffer, "OR '1'='1'") != NULL) {
        TEST_FAIL("SQL Injection 성공 - 데이터베이스 탈취 가능");
        return;
    }
    TEST_PASS("SQL Injection 방어됨");
}

/* ============================================================
   TEST 2: knex-c SQL INJECTION - DROP TABLE

   취약점: Raw query without PreparedStatement
   공격: 데이터베이스 테이블 삭제
   기대 결과: 테이블 삭제됨 (현재 - 실패함)
   수정 후 결과: Access Denied
   ============================================================ */

void test_knex_c_drop_table_injection() {
    printf("\n=== TEST 2: knex-c DROP TABLE Injection ===\n");

    char malicious_input[] = "'; DROP TABLE users; --";
    char query_buffer[1024];

    // 현재 코드 (취약함)
    // sprintf(query_buffer, "UPDATE users SET email='%s' WHERE id=1", malicious_input);
    // Result: UPDATE users SET email=''; DROP TABLE users; -- WHERE id=1

    strcpy(query_buffer, "UPDATE users SET email=''; DROP TABLE users; -- WHERE id=1");

    // 검증: DROP 명령어가 실행되는가?
    if (strstr(query_buffer, "DROP TABLE") != NULL) {
        TEST_FAIL("SQL Injection 성공 - DROP TABLE 실행 가능");
        return;
    }
    TEST_PASS("DROP TABLE 공격 방어됨");
}

/* ============================================================
   TEST 3: fs-c BUFFER OVERFLOW

   취약점: strcpy() without bounds check
   공격: 매우 긴 경로명으로 스택 오버플로우
   기대 결과: 스택 손상, RCE 가능 (현재)
   수정 후 결과: Buffer overflow 방지
   ============================================================ */

void test_fs_c_buffer_overflow() {
    printf("\n=== TEST 3: fs-c Buffer Overflow ===\n");

    char buffer[256];  // 고정 크기
    char *extremely_long_path = malloc(5000);

    // 공격: 5000 바이트의 매우 긴 경로 생성
    memset(extremely_long_path, 'A', 4999);
    extremely_long_path[4999] = '\0';

    // 현재 코드 (취약함)
    // strcpy(buffer, extremely_long_path);  // ← Buffer Overflow!

    // Overflow 발생 시뮬레이션
    strncpy(buffer, extremely_long_path, 255);  // 안전한 방법
    buffer[255] = '\0';

    // 검증: 버퍼가 오버플로우했는가?
    if (strlen(buffer) > 256) {
        TEST_FAIL("Buffer Overflow 발생 - 스택 손상 가능");
        free(extremely_long_path);
        return;
    }
    TEST_PASS("Buffer Overflow 방지됨");
    free(extremely_long_path);
}

/* ============================================================
   TEST 4: body-c UNLIMITED BODY SIZE

   취약점: Parsing body without size limits
   공격: 매우 큰 body 전송으로 메모리 고갈 (DoS)
   기대 결과: 메모리 고갈, 크래시 (현재)
   수정 후 결과: Size limit exceeded error
   ============================================================ */

void test_body_c_dos_attack() {
    printf("\n=== TEST 4: body-c DoS Attack (Unlimited Size) ===\n");

    size_t MAX_BODY_SIZE = 1024 * 1024;  // 1MB limit
    size_t attack_body_size = 500 * 1024 * 1024;  // 500MB 공격

    // 현재 코드 (취약함)
    // char *body = malloc(attack_body_size);  // ← 메모리 고갈!
    // memset(body, 'X', attack_body_size);

    // 검증: 크기 제한이 있는가?
    if (attack_body_size > MAX_BODY_SIZE) {
        TEST_PASS("Body size limit 적용됨");
        return;
    }
    TEST_FAIL("DoS 공격 가능 - 메모리 고갈 유발");
}

/* ============================================================
   TEST 5: chalk-c FORMAT STRING VULNERABILITY

   취약점: printf() with unsanitized input
   공격: format string으로 스택 정보 유출
   기대 결과: 스택 메모리 유출 (현재)
   수정 후 결과: Sanitized output
   ============================================================ */

void test_chalk_c_format_string() {
    printf("\n=== TEST 5: chalk-c Format String ===\n");

    char user_input[] = "%x %x %x %x %x";  // Stack leaker
    char output_buffer[256];

    // 현재 코드 (취약함)
    // sprintf(output_buffer, user_input);  // ← Format string!

    // Safe method
    snprintf(output_buffer, sizeof(output_buffer), "%s", user_input);

    // 검증: 스택 메모리가 유출되는가?
    if (strstr(output_buffer, "%x") != NULL) {
        TEST_PASS("Format string 방어됨");
        return;
    }
    TEST_FAIL("Format string 취약점 - 메모리 유출");
}

