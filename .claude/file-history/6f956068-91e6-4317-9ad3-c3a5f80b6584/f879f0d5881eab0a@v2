  println("매크로: " + v1);

  let v2 = create_empty();
  println("빈 벡터 크기: " + v2);

  let v3 = create_with_capacity();
  println("사전 할당 용량: " + v3);

  let v4 = create_from_range();
  println("범위로 생성: " + v4);
  println("");

  // ========================================
  // 2. 벡터 추가와 제거
  // ========================================

  println("--- 2. 벡터 추가와 제거 ---");
  let push_result = vector_push();
  println("push 결과: " + push_result);

  let pop_result = vector_pop();
  println("pop 결과: " + pop_result);

  let insert_result = vector_insert();
  println("insert 결과: " + insert_result);

  let remove_result = vector_remove();
  println("remove 결과: " + remove_result);
  println("");

  // ========================================
  // 3. 벡터 접근
  // ========================================

  println("--- 3. 벡터 접근 ---");
  let idx0 = vector_index(0);
  println("인덱스 0: " + idx0);

  let idx1 = vector_index(1);
  println("인덱스 1: " + idx1);

  let safe = vector_get(2);
