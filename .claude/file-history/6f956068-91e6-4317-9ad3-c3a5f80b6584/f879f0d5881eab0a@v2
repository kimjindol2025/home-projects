  println("");

  // ========================================
  // 9. 벡터와 열거형
  // ========================================

  println("--- 9. 벡터와 열거형 ---");
  let collected = collect_tasks();
  println("작업 수집: " + collected);

  let processed = process_tasks(3);
  println("처리: " + processed);

  let t1 = task_initialize();
  println("작업 1: " + t1);

  let t2 = task_print("보안");
  println("작업 2: " + t2);
  println("");

  // ========================================
  // 10. 안전한 접근
  // ========================================

  println("--- 10. 안전한 벡터 접근 ---");
  let safe_ok = safe_access(2);
  println("안전 접근 (2): " + safe_ok);

  let safe_err = safe_access(10);
  println("안전 접근 (10): " + safe_err);

  let result_ok = access_with_error(1);
  println("Result (1): " + result_ok);

  let result_err = access_with_error(10);
