  println("소유권 루프: " + move_loop);
  println("");

  // ========================================
  // 6. 벡터와 함수
  // ========================================

  println("--- 6. 벡터와 함수 ---");
  let consumed = consume_vector(3);
  println("소비: " + consumed);

  let read = read_vector(5);
  println("읽기: " + read);

  let returned = return_vector();
  println("반환: " + returned);
  println("");

  // ========================================
  // 7. 변환과 필터
  // ========================================

  println("--- 7. 변환과 필터 ---");
  let doubled = double_elements();
  println("2배 변환: " + doubled);

  let filtered = filter_elements();
  println("필터: " + filtered);

  let mapped = map_structure();
  println("매핑: " + mapped);
  println("");

  // ========================================
  // 8. 중첩 벡터
  // ========================================

  println("--- 8. 중첩 벡터 (2D 배열) ---");
