// [Step 2 패턴 3] 모듈 간 상호작용
// ============================================================

pub struct AuthService {
    vault: GogsVault,
    attempts: u32,
}

impl AuthService {
    pub fn new(secret: &str) -> Self {
        AuthService {
            vault: GogsVault::new(secret),
            attempts: 0,
        }
    }

    pub fn authenticate(&mut self, password: &str) -> bool {
        self.attempts += 1;
        let is_valid = self.vault.access(password);

        if is_valid {
            println!("인증 성공 (시도: {}회)", self.attempts);
        } else {
            println!("인증 실패 (시도: {}회)", self.attempts);
        }

        is_valid
    }

    pub fn get_attempts(&self) -> u32 {
        self.attempts
    }
}

fn demo_pattern_3() {
    println!("\n=== Pattern 3: 모듈 간 상호작용 ===");

    let mut auth = AuthService::new("password123");

    println!("첫 번째 시도 (잘못된 비밀번호):");
    auth.authenticate("wrong");

    println!("두 번째 시도 (잘못된 비밀번호):");
    auth.authenticate("incorrect");

    println!("세 번째 시도 (올바른 비밀번호):");
    auth.authenticate("password123");

    println!("총 시도 횟수: {}", auth.get_attempts());
    println!("추론: 여러 모듈이 함께 작동하는 통합");
    println!("      상태 변경과 상호작용이 일관됨");
}

// ============================================================
// [Step 2 패턴 4] 공개 API vs 비공개 구현
// ============================================================

pub struct SecureVault {
    secret: String,
}

impl SecureVault {
    // 공개 인터페이스
    pub fn new(key: &str) -> Self {
        SecureVault {
            secret: Self::hash_key(key),
        }
    }

    pub fn verify(&self, input: &str) -> bool {
        Self::hash_key(input) == self.secret
    }

    // 비공개 구현 (외부에서 접근 불가)
    fn hash_key(key: &str) -> String {
        // 간단한 해싱 시뮬레이션
        format!("hashed_{}", key.len())
    }
}

fn demo_pattern_4() {
    println!("\n=== Pattern 4: 공개 API vs 비공개 구현 ===");

    let vault = SecureVault::new("SECRET_PASSWORD");

    println!("공개 메서드만 사용 가능:");
    println!("vault.new() ✓");
    println!("vault.verify() ✓");

    println!("비공개 메서드는 외부에서 사용 불가:");
    println!("vault.hash_key() ✗ (컴파일 에러)");

    println!("사용자 입장:");
    println!("- 해시 함수가 어떻게 작동하는지 몰라도 됨");
    println!("- 검증이 안전하다는 것만 믿으면 됨");

    let is_valid = vault.verify("SECRET_PASSWORD");
    println!("검증 결과: {}", is_valid);

    println!("추론: 캡슐화로 구현의 세부를 숨김");
    println!("      공개 인터페이스만 문서화");
}

// ============================================================
// [Step 2 패턴 5] 시나리오 중심 워크플로우
// ============================================================

pub struct SecuritySystem {
    vaults: Vec<GogsVault>,
}

impl SecuritySystem {
    pub fn new() -> Self {
        SecuritySystem { vaults: vec![] }
    }

    pub fn register_vault(&mut self, key: &str) {
        self.vaults.push(GogsVault::new(key));
    }

    pub fn verify_all(&self, input: &str) -> bool {
        !self.vaults.is_empty() &&
        self.vaults.iter().all(|v| v.access(input))
    }
}

fn demo_pattern_5() {
    println!("\n=== Pattern 5: 시나리오 중심 워크플로우 ===");

    println!("시나리오: 다층 보안 시스템");
    println!("1. 시스템 초기화");
    let mut security = SecuritySystem::new();

    println!("2. 보안 레이어 등록");
    security.register_vault("MASTER_KEY");
    security.register_vault("MASTER_KEY");
    security.register_vault("MASTER_KEY");

    println!("3. 올바른 키로 검증");
    let passed = security.verify_all("MASTER_KEY");
    println!("   결과: {}", if passed { "✓ 접근 허용" } else { "✗ 접근 거부" });

    println!("4. 잘못된 키로 검증");
    let passed = security.verify_all("WRONG_KEY");
    println!("   결과: {}", if passed { "✓ 접근 허용" } else { "✗ 접근 거부" });

    println!("추론: 실제 사용자가 경험하는 워크플로우");
    println!("      단위 테스트로는 찾을 수 없는 상호작용 발견");
}

