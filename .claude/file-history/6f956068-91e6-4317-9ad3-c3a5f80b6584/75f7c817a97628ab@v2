// 공개 인터페이스: 금고(Vault) 시스템
pub trait Vault {
    fn new(key: &str) -> Self;
    fn access(&self, input: &str) -> bool;
}

// 구체적 구현
pub struct GogsVault {
    secret_key: String,
}

impl GogsVault {
    pub fn new(key: &str) -> Self {
        GogsVault { secret_key: key.to_string() }
    }

    pub fn access(&self, input: &str) -> bool {
        self.secret_key == input
    }
}

fn demo_pattern_1() {
    println!("\n=== Pattern 1: 기본 라이브러리 구조 ===");

    // 외부 사용자처럼 라이브러리 사용
    let vault = GogsVault::new("MASTER_SECRET");

    println!("Vault 생성: {}", "✓");
    println!("올바른 키 접근: {}", vault.access("MASTER_SECRET"));
    println!("잘못된 키 접근: {}", vault.access("WRONG_KEY"));
    println!("빈 입력 접근: {}", vault.access(""));

    println!("추론: 공개 인터페이스만 사용");
    println!("      private 필드는 외부에서 접근 불가");
}

// ============================================================
// [Step 2 패턴 2] 에러 처리와 Result 타입
// ============================================================

pub struct EnhancedVault {
    secret_key: String,
}

impl EnhancedVault {
    pub fn new(key: &str) -> Result<Self, String> {
        if key.is_empty() {
            Err("Key cannot be empty".to_string())
        } else if key.len() < 4 {
            Err("Key must be at least 4 characters".to_string())
        } else {
            Ok(EnhancedVault { secret_key: key.to_string() })
        }
    }

    pub fn access(&self, input: &str) -> bool {
        self.secret_key == input
    }
}

fn demo_pattern_2() {
    println!("\n=== Pattern 2: 에러 처리와 Result 타입 ===");

    // 성공 케이스
    match EnhancedVault::new("STRONG_SECRET") {
        Ok(vault) => {
            println!("✓ 금고 생성 성공");
            println!("  접근 가능: {}", vault.access("STRONG_SECRET"));
        }
        Err(e) => println!("✗ 에러: {}", e),
    }

    // 실패 케이스 1: 빈 키
    println!("빈 키로 생성 시도:");
    match EnhancedVault::new("") {
        Ok(_) => println!("✓ 생성됨"),
        Err(e) => println!("✗ 에러: {}", e),
    }

    // 실패 케이스 2: 짧은 키
    println!("짧은 키로 생성 시도:");
    match EnhancedVault::new("ABC") {
        Ok(_) => println!("✓ 생성됨"),
        Err(e) => println!("✗ 에러: {}", e),
    }

    println!("추론: Result<T, E>로 실패 상황 명확히 전달");
    println!("      사용자가 에러를 처리할 수 있음");
}

