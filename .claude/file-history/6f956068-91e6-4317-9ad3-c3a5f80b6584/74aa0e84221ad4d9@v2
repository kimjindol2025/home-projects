// Stack 자료구조 - LIFO (Last In First Out)

export class Stack<T> {
  private items: T[] = [];

  /**
   * Stack에 아이템 추가
   */
  push(item: T): void {
    this.items.push(item);
  }

  /**
   * Stack에서 아이템 제거 및 반환
   */
  pop(): T | undefined {
    return this.items.pop();
  }

  /**
   * Stack의 맨 위 아이템 조회 (제거 X)
   */
  peek(): T | undefined {
    if (this.items.length === 0) {
      return undefined;
    }
    return this.items[this.items.length - 1];
  }

  /**
   * Stack이 비어있는지 확인
   */
  isEmpty(): boolean {
    return this.items.length === 0;
  }

  /**
   * Stack의 크기
   */
  size(): number {
    return this.items.length;
  }

  /**
   * Stack 초기화
   */
  clear(): void {
    this.items = [];
  }

  /**
   * Stack 내용 출력
   */
  dump(): void {
    console.log('=== Stack State ===');
    for (let i = this.items.length - 1; i >= 0; i--) {
      console.log(`  [${this.items.length - 1 - i}] ${this.items[i]}`);
    }
  }
}
