/**
 * [사례 1] 보안 접근 제어
 *
 * 설계 원칙:
 *   - 표현식으로서의 IF: 결과를 변수에 할당
 *   - 복합 조건식: && 와 || 조합
 *   - 우선순위: 가장 엄격한 조건부터 검사
 */
fn security_test() {
    let is_admin = true;
    let access_level = 5;
    let system_online = true;

    // [설계] 표현식으로서의 if - 결과를 변수에 담아 불변성 유지
    let security_clearance = if is_admin && system_online {
        // 최고 우선순위: 관리자 AND 시스템 온라인
        "🔓 Full Access Granted"
    } else if access_level > 3 || system_online {
        // 두 번째 조건: (높은 권한) OR (시스템 온라인)
        "🔒 Limited Access Granted"
    } else {
        // 기본값: 모든 조건 미충족
        "🚫 Access Denied"
    };

    println!("입력 상태:");
    println!("  - 관리자 여부: {}", is_admin);
    println!("  - 권한 레벨: {}", access_level);
    println!("  - 시스템 온라인: {}", system_online);
    println!("결과: {}", security_clearance);

    // [무결성 검증]
    println!("무결성 확인:");
    println!("  ✓ 모든 분기가 문자열(str) 반환");
    println!("  ✓ 조건의 우선순위가 명확");
    println!("  ✓ 모든 경로가 else로 포괄됨");
}

/**
 * [사례 2] 온도 제어 시스템
 *
 * 설계 원칙:
 *   - 중첩 조건문으로 세부 제어
 *   - 각 분기는 상호 배타적(mutually exclusive)
 *   - 우선순위: 위에서 아래로 심각도 증가
 */
fn thermal_test() {
    let temperature = 75.5;
    let system_online = true;
    let threshold_critical = 85.0;
    let threshold_warning = 70.0;
    let threshold_caution = 50.0;

    // [설계] 표현식으로서의 if
    let status = if system_online {
        if temperature > threshold_critical {
            "🔴 CRITICAL - Immediate Shutdown"
        } else if temperature > threshold_warning {
            "🟠 WARNING - Cooling Activated"
        } else if temperature > threshold_caution {
            "🟡 CAUTION - Monitor Closely"
        } else {
            "🟢 OPTIMAL - Normal Operation"
        }
    } else {
        "⚪ UNKNOWN - System Offline"
    };

    println!("입력 상태:");
    println!("  - 현재 온도: {}°C", temperature);
    println!("  - 시스템 상태: {}", if system_online { "온라인" } else { "오프라인" });
    println!("결과: {}", status);

    println!("설계 특징:");
    println!("  ✓ 수직적 우선순위: 위에서 아래로 심각도 증가");
    println!("  ✓ 각 분기는 상호 배타적");
    println!("  ✓ 모든 경로가 동일한 타입(str) 반환");
}

/**
 * [사례 3] 복합 의사결정: 대출 승인
 *
 * 설계 원칙:
 *   - 복합 조건식: && 와 || 의 조합
 *   - 각 분기의 의미: 다양한 대출 규모와 조건
 *   - 단락 회로 평가: 첫 조건이 거짓이면 나머지 건너뜀
 */
fn loan_test() {
    let credit_score = 720;
    let income = 75000.0;
    let employment_years = 3;

    // [설계] 각 대출 레벨의 조건을 명확히 정의
    let loan_amount = if credit_score >= 750 && income > 50000.0 && employment_years >= 2 {
        // 모든 조건 우수
        "💰 Approved: $500,000 (Premium)"
    } else if credit_score >= 650 && income > 30000.0 && employment_years >= 1 {
        // 중간 수준
        "💵 Approved: $200,000 (Standard)"
    } else if credit_score >= 550 || income > 40000.0 {
        // OR로 유연하게 처리: 신용점수가 낮아도 소득이 높으면 가능
        "💴 Approved: $50,000 (Conditional)"
    } else {
        // 기본 거부
        "❌ Denied"
    };

    println!("입력 상태:");
    println!("  - 신용점수: {}", credit_score);
    println!("  - 연 소득: ${}", income);
    println!("  - 고용 기간: {}년", employment_years);
    println!("결과: {}", loan_amount);

    println!("설계 분석:");
    println!("  ✓ 조건1 (750+): 최고 조건 (AND로 모두 필요)");
    println!("  ✓ 조건2 (650+): 중간 조건 (AND로 모두 필요)");
    println!("  ✓ 조건3: OR로 유연성 제공");
    println!("  ✓ else: 기본 거부");
}

/**
 * [사례 4] Short-Circuit Evaluation
 *
 * 설계 원칙:
 *   - 첫 번째 거짓이 나타나면 나머지 계산 생략
 *   - 값비싼 연산을 뒤쪽에 배치
 *   - 성능 최적화의 핵심
 */
fn short_circuit_test() {
    println!("Short-Circuit 성능 검증:");
    println!("");

    // [예시 1] AND에서의 단락 회로
    println!("예시 1: 빠른 거짓 판명");
    let is_premium = false;
    let result1 = is_premium && check_expensive_condition();
    // is_premium이 false이므로 check_expensive_condition()은 호출되지 않음
    println!("  - is_premium && check_expensive_condition(): {}", result1);
    println!("  - check_expensive_condition()은 실행되지 않았음! ✓");
    println!("");

    // [예시 2] OR에서의 단락 회로
    println!("예시 2: 빠른 참 판명");
    let is_admin = true;
    let result2 = is_admin || check_expensive_condition();
    // is_admin이 true이므로 check_expensive_condition()은 호출되지 않음
    println!("  - is_admin || check_expensive_condition(): {}", result2);
    println!("  - check_expensive_condition()은 실행되지 않았음! ✓");
    println!("");

    println!("성능 이점:");
    println!("  ✓ 불필요한 계산 제거");
    println!("  ✓ API 호출 감소");
    println!("  ✓ 데이터베이스 쿼리 감소");
    println!("  ✓ 전체 응답 시간 단축");
}

/**
 * Helper function for short-circuit test
 * (실제로 값비싼 연산을 시뮬레이션)
 */
fn check_expensive_condition() -> bool {
    // 이 함수가 호출되면 로그 출력
    println!("    [비싼 연산 실행됨]");
    true
}

/**
 * [사례 5] 무결성 검증 (Completeness Check)
 *
 * 설계 원칙:
 *   - 모든 가능한 입력값에 대한 처리
 *   - 예상 불가능한 값에 대한 기본값
 *   - 논리적 일관성 검증
 */
fn completeness_test() {
    println!("무결성 검증 체크리스트:");
    println!("");

    // [검증 1] 타입 일치
    println!("1️⃣  타입 일치 검증:");
    let result = if true {
        "string"  // 문자열
    } else {
        "value"   // 문자열 (동일한 타입)
    };
    println!("   입력값: bool(true)");
    println!("   출력값: str(\"{}\")", result);
    println!("   ✓ if와 else의 타입이 동일");
    println!("");

    // [검증 2] 우선순위
    println!("2️⃣  연산자 우선순위 검증:");
    let a = true;
    let b = false;
    let c = true;
    let priority_check = a || b && c;
    // b && c가 먼저 계산됨 (false && true = false)
    // a || false = true
    println!("   a={}, b={}, c={}", a, b, c);
    println!("   a || b && c = {} (&&가 먼저 계산됨)", priority_check);
    println!("   ✓ 연산자 우선순위 고려");
    println!("");

    // [검증 3] 가독성
    println!("3️⃣  가독성 검증:");
    let status_code = 200;
    let is_active = true;
    let is_cached = false;

    // 복합 조건을 의미 있는 변수로 분해
    let is_valid_response = status_code >= 200 && status_code < 300;
    let should_cache = is_active && !is_cached;
    let can_serve = is_valid_response && should_cache;

    println!("   조건 분해:");
    println!("   - is_valid_response: {}", is_valid_response);
    println!("   - should_cache: {}", should_cache);
    println!("   - can_serve: {}", can_serve);
    println!("   ✓ 조건이 명확한 이름으로 분해됨");
    println!("");

    // [검증 4] 논리적 완전성
    println!("4️⃣  논리적 완전성 검증:");
    let user_role = "user";  // admin, user, guest
    let access_level = if user_role == "admin" {
        "full"
    } else if user_role == "user" {
        "limited"
    } else {
        "none"  // 모든 경우를 포괄하는 else
    };
    println!("   사용자 역할: \"{}\"", user_role);
    println!("   접근 레벨: \"{}\"", access_level);
    println!("   ✓ 모든 가능한 입력값에 대한 처리");
    println!("");

    // [검증 5] 순환 논리 방지
    println!("5️⃣  순환 논리 방지 검증:");
    let is_admin_user = true;
    let can_delete = is_admin_user && true;  // 추가 조건이 있으면 순환 아님
    println!("   is_admin_user: {}", is_admin_user);
    println!("   can_delete: {}", can_delete);
    println!("   ✓ 조건과 결과가 순환적으로 연결되지 않음");
    println!("");

    println!("✅ 무결성 검증 완료: 모든 항목 통과");
}

