/// 보안 시스템의 핵심 모듈입니다.
///
/// 이 모듈은 다음 기능들을 제공합니다:
///
/// - `GogsVault`: 비밀 키 저장소
/// - `authenticate()`: 사용자 인증
/// - `encrypt()`: 데이터 암호화
///
/// # Examples
///
/// 전형적인 사용 패턴:
/// ```
/// // 1. 금고 생성
/// let vault = module_security_create("SECRET");
/// // 2. 접근 검증
/// if module_security_verify(&vault, "SECRET") {
///     println!("Access granted");
/// }
/// ```
mod module_security {
    pub struct GogsVault {
        key: String,
    }

    pub fn module_security_create(key: &str) -> GogsVault {
        GogsVault { key: key.to_string() }
    }

    pub fn module_security_verify(vault: &GogsVault, input: &str) -> bool {
        vault.key == input
    }
}

fn demo_pattern_5() {
    println!("\n=== Pattern 5: 모듈 레벨 문서화 ===");

    println!("모듈 문서화:");
    println!("  - 모듈 전체의 역할 설명");
    println!("  - 제공하는 기능 나열");
    println!("  - 사용 패턴 제시");

    use module_security::{module_security_create, module_security_verify};

    let vault = module_security_create("SECRET");
    println!("금고 생성 후 검증: {}", module_security_verify(&vault, "SECRET"));

    println!("모듈 전체가 일관되게 문서화됨");
}

