/// 인증 서비스를 제공합니다.
///
/// # Examples
///
/// 성공적인 인증:
/// ```
/// let result = authenticate("username", "correct_password");
/// assert!(result);
/// ```
///
/// 실패하는 인증:
/// ```
/// let result = authenticate("username", "wrong_password");
/// assert!(!result);
/// ```
///
/// 빈 입력:
/// ```
/// let result = authenticate("", "");
/// assert!(!result);
/// ```
fn authenticate(username: &str, password: &str) -> bool {
    if username.is_empty() || password.is_empty() {
        return false;
    }
    username == "user" && password == "pass"
}

