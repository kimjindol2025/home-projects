/// 데이터를 안전하지 않은 방식으로 처리합니다.
///
/// # Panics
///
/// 입력이 빈 문자열이면 panic을 일으킵니다:
/// ```should_panic
/// process_unsafe("");
/// ```
fn process_unsafe(data: &str) {
    if data.is_empty() {
        panic!("Data cannot be empty!");
    }
    println!("Processing: {}", data);
}

