    println!("  /// ```");

    let vault = create_vault("secret");
    println!("금고 생성: {}", verify_access(&vault, "secret"));

    println!("의미:");
    println!("  - 함수/구조체의 역할 설명");
    println!("  - # Examples 섹션에 사용 예제");
    println!("  - cargo test --doc로 검증됨");
}

