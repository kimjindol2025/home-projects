/// 보안 금고(Vault)를 관리합니다.
///
/// 이 구조체는 비밀 키를 저장하고, 주어진 입력과
/// 비교하여 접근 권한을 판단합니다.
///
/// # Examples
///
/// 금고 생성 및 접근:
/// ```
/// let vault = create_vault("SECRET123");
/// assert!(verify_access(&vault, "SECRET123"));
/// assert!(!verify_access(&vault, "WRONG"));
/// ```
struct SecureVault {
    secret_key: String,
}

fn create_vault(key: &str) -> SecureVault {
    SecureVault {
        secret_key: key.to_string(),
    }
}

fn verify_access(vault: &SecureVault, input: &str) -> bool {
    vault.secret_key == input
}

