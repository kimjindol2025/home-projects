/// 안전하게 금고를 생성합니다.
///
/// # Errors
///
/// 다음과 같은 경우 에러를 반환합니다:
///
/// - 키가 비어있음
/// - 키가 너무 짧음 (4글자 미만)
///
/// # Examples
///
/// 성공적인 생성:
/// ```
/// let result = create_vault_safe("SECRET_KEY");
/// assert!(result.is_ok());
/// ```
///
/// 실패 케이스 1:
/// ```
/// let result = create_vault_safe("");
/// assert!(result.is_err());
/// ```
///
/// 실패 케이스 2:
/// ```
/// let result = create_vault_safe("ABC");
/// assert!(result.is_err());
/// ```
fn create_vault_safe(key: &str) -> Result<String, String> {
    if key.is_empty() {
        Err("Key cannot be empty".to_string())
    } else if key.len() < 4 {
        Err("Key must be at least 4 characters".to_string())
    } else {
        Ok(format!("Vault with key: {}", key))
    }
}

fn demo_pattern_4() {
    println!("\n=== Pattern 4: Errors 섹션 ===");

    println!("Errors 섹션:");
    println!("  - Result<T, E> 반환");
    println!("  - 각 에러 상황 설명");
    println!("  - 성공/실패 예제");

    println!("성공: {:?}", create_vault_safe("SECRET123"));
    println!("실패1: {:?}", create_vault_safe(""));
    println!("실패2: {:?}", create_vault_safe("ABC"));

    println!("모든 케이스가 문서에서 검증됨");
}

