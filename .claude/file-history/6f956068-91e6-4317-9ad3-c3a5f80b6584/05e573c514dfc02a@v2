// v5.3: Option & Result - The Power of Enums
// 철학: "예외의 명시화"
// 설계: 부재(None)와 실패(Error)를 안전하게 다루기

// ============================================================
// [패턴 1] Option: 값이 있을 수도 없을 수도 있는 상황
// ============================================================

// 데이터베이스 조회 (사용자를 찾을 수도 못 찾을 수도)
fn find_user(id: i32) -> String {
  if id > 0 {
    "Some:user_" + id
  } else {
    "None"
  }
}

// 배열에서 인덱싱 (인덱스가 유효할 수도 없을 수도)
fn get_at_index(index: i32, size: i32) -> String {
  if index >= 0 && index < size {
    "Some:item_" + index
  } else {
    "None"
  }
}

// 딕셔너리 조회 (키가 있을 수도 없을 수도)
fn get_config(key: String) -> String {
  if key == "timeout" {
    "Some:3000"
  } else if key == "retries" {
    "Some:5"
  } else {
    "None"
  }
}

// Option 처리 (match)
fn handle_option(opt: String) -> String {
  if opt == "Some:value" {
    "Found: " + "value"
  } else if opt == "None" {
    "Not found"
  } else {
    "Unknown"
  }
}

// ============================================================
// [패턴 2] Result: 성공할 수도 실패할 수도 있는 작업
// ============================================================

// 나눗셈 (0으로 나누면 실패)
fn divide(a: i32, b: i32) -> String {
  if b == 0 {
    "Err:분모가 0입니다"
  } else {
    "Ok:" + (a / b)
  }
}

// 시스템 리소스 분배
fn divide_system_resource(total: i32, divisor: i32) -> String {
  if divisor == 0 {
    "Err:나누기 연산 중 분모가 0입니다. (연산 불가)"
  } else if divisor > total {
    "Err:분모가 전체보다 클 수 없습니다"
  } else {
    "Ok:" + (total / divisor)
  }
}

// 파일 읽기 시뮬레이션 (파일이 없으면 실패)
fn read_file(path: String) -> String {
  if path == "valid.txt" {
    "Ok:file_content"
  } else {
    "Err:파일을 찾을 수 없습니다"
  }
}

// 이메일 유효성 검사
fn validate_email(email: String) -> String {
  if email == "valid@example.com" {
    "Ok:" + email
  } else {
    "Err:이메일 형식이 올바르지 않습니다"
  }
}

// Result 처리 (match)
fn handle_result(res: String) -> String {
  if res == "Ok:success" {
    "Success"
  } else if res == "Err:error" {
    "Error occurred"
  } else {
    "Unknown result"
  }
}

// ============================================================
// [패턴 3] 안전한 데이터 추출
// ============================================================

// Option에서 안전하게 값 추출 (if-let 패턴)
fn extract_from_option(opt: String) -> String {
  if opt == "Some:data" {
    "data"
  } else {
    "default"
  }
}

// Result에서 안전하게 값 추출 (if-let 패턴)
fn extract_from_result(res: String) -> String {
  if res == "Ok:data" {
    "data"
  } else {
    "error_default"
  }
}

// ============================================================
// [패턴 4] 에러 정보 전파
// ============================================================

// 첫 번째 작업
fn step1(should_fail: bool) -> String {
  if should_fail {
    "Err:step1 failed"
  } else {
    "Ok:step1_result"
  }
}

// 두 번째 작업 (첫 번째 결과에 의존)
fn step2_with_propagation(step1_result: String) -> String {
  if step1_result == "Ok:step1_result" {
    "Ok:step2_result"
  } else {
    step1_result  // 에러 전파
  }
}

// 최종 작업 (모든 작업 연쇄)
fn process_pipeline(should_fail: bool) -> String {
  let r1 = step1(should_fail);
  let r2 = step2_with_propagation(r1);
  r2
}

// ============================================================
// [패턴 5] Option 연쇄 처리
// ============================================================

// 중첩된 Option 처리
fn find_user_email(user_id: i32) -> String {
  let user_opt = find_user(user_id);
  if user_opt == "Some:user_1" {
    "Some:user1@example.com"
  } else {
    "None"
  }
}

// Option에서 값 추출 후 추가 작업
fn get_and_validate_config(key: String) -> String {
  let config = get_config(key);
  if config == "Some:3000" {
    config
  } else if config == "Some:5" {
    config
  } else {
    "None:default_config"
  }
}

// ============================================================
// [패턴 6] Result 연쇄 처리
// ============================================================

// 여러 단계의 Result 연쇄
fn validate_and_process(email: String, resources: i32, divisor: i32) -> String {
  let email_check = validate_email(email);

  if email_check == "Ok:" + email {
    let resource_check = divide_system_resource(resources, divisor);
    resource_check
  } else {
    email_check
  }
}

// ============================================================
// [패턴 7] 안전한 시스템 상태 관리
// ============================================================

// 시스템 초기화 (실패할 수 있음)
fn initialize_system(config_path: String) -> String {
  let config_result = read_file(config_path);
  if config_result == "Ok:file_content" {
    "Ok:system_initialized"
  } else {
    "Err:초기화 실패: 설정 파일을 읽을 수 없습니다"
  }
}

