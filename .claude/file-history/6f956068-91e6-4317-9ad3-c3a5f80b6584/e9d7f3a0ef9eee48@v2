fn demonstrate_stack_vs_heap() {
    println!("\n=== 개념 1: 스택 vs 힙 ===");

    println!("스택 (Stack):");
    println!("  - 컴파일 타임에 크기 결정");
    println!("  - 매우 빠름");
    println!("  - LIFO (Last In First Out)");
    println!("  - 크기 제한 있음");
    println!("  - 함수 반환 시 자동 정리");
    println!("");

    println!("힙 (Heap):");
    println!("  - 런타임에 크기 결정");
    println!("  - 약간 느림 (포인터 따라가야 함)");
    println!("  - 크기 제한 없음 (메모리 허용하는 한)");
    println!("  - 수동 관리 (또는 스마트 포인터)");
    println!("  - 동적 메모리 할당 가능");
    println!("");

    println!("Box<T>:");
    println!("  - 데이터는 힙에, 포인터는 스택에");
    println!("  - 유연성과 안전성의 조합");
    println!("  - 자동 메모리 해제 보장");
}

// ============================================================
// [Step 1 개념 2] Box의 역참조
// ============================================================

fn explain_dereferencing() {
    println!("\n=== 개념 2: Box의 역참조 ===");

    println!("포인터와 값:");
    println!("  let x = 42;      // 값: 42");
    println!("  let boxed = Box::new(42);");
    println!("  boxed             // 포인터 (주소: 0x1000)");
    println!("  *boxed            // 값: 42 (역참조)");
    println!("");

    println!("역참조 연산자 (*):");
    let boxed = Box::new(10);
    println!("  let boxed = Box::new(10);");
    println!("  boxed = 포인터");
    println!("  *boxed = {}", *boxed);
    println!("");

    println!("메모리 접근:");
    println!("  boxed.method()   // 자동 역참조 (메서드 호출)");
    println!("  *boxed           // 명시적 역참조 (값 접근)");
}

