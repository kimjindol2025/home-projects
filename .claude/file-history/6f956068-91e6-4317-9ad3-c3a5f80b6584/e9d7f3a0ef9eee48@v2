// ============================================================
// [Step 1 패턴 4] 트레이트 객체 (미리보기)
// ============================================================

trait Displayable {
    fn display(&self) -> String;
}

struct MessageNode {
    text: String,
}

impl Displayable for MessageNode {
    fn display(&self) -> String {
        format!("[Message] {}", self.text)
    }
}

struct ErrorNode {
    code: i32,
}

impl Displayable for ErrorNode {
    fn display(&self) -> String {
        format!("[Error {}]", self.code)
    }
}

fn demo_pattern_4() {
    println!("\n=== Pattern 4: 트레이트 객체 (미리보기) ===");

    println!("다른 타입, 하나의 인터페이스:");

    let msg = MessageNode { text: "Hello".to_string() };
    let err = ErrorNode { code: 404 };

    println!("  메시지: {}", msg.display());
    println!("  에러: {}", err.display());
    println!("");

    println!("Box<dyn Trait>를 사용하면:");
    println!("  여러 타입을 하나의 컨테이너에 저장 가능");
    println!("  런타임 다형성 구현");
    println!("");

    println!("추론: Box는 타입 이형성도 지원 (v9.1에서 자세히)");
}

