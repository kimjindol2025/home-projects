fn explain_size_problem() {
    println!("\n=== 개념 3: 크기 문제와 해결책 ===");

    println!("문제: 컴파일 타임 크기 미정");
    println!("  enum Node {{");
    println!("      Data(i32, Node),  // 몇 바이트?");
    println!("      Nil,");
    println!("  }}");
    println!("");

    println!("  Node의 크기 = 4 (i32) + ??? (Node) = ???");
    println!("  재귀적으로 무한 크기!");
    println!("  → 컴파일 에러");
    println!("");

    println!("해결: Box로 포인터 저장");
    println!("  enum Node {{");
    println!("      Data(i32, Box<Node>),  // 몇 바이트?");
    println!("      Nil,");
    println!("  }}");
    println!("");

    println!("  Node의 크기 = 4 (i32) + 8 (포인터) = 12 바이트");
    println!("  포인터는 항상 고정 크기!");
    println!("  → 컴파일 성공");
}

