// ============================================================
// [Step 1 패턴 1] 기본 Box<T> 사용
// ============================================================

fn demo_pattern_1() {
    println!("\n=== Pattern 1: 기본 Box<T> 사용 ===");

    println!("스택에 저장:");
    let stack_value = 42;
    println!("  let x = 42");
    println!("  메모리: 스택에 4바이트");
    println!("  값: {}", stack_value);
    println!("");

    println!("힙에 저장:");
    let boxed_value: i32 = 42;
    println!("  let boxed = Box::new(42)");
    println!("  메모리: 힙에 4바이트, 스택에 포인터(8바이트)");
    println!("  값: {}", boxed_value);
    println!("");

    println!("역참조:");
    println!("  *boxed = {} (역참조로 값 접근)", boxed_value);
    println!("");

    println!("추론: Box는 힙 메모리를 스택 포인터로 관리");
}

// ============================================================
// [Step 1 패턴 2] 재귀적 데이터 구조
// ============================================================

enum GogsNode {
    Data(i32, Box<GogsNode>),
    Nil,
}

fn build_list(values: Vec<i32>) -> GogsNode {
    if values.is_empty() {
        GogsNode::Nil
    } else {
        GogsNode::Data(
            values[0],
            Box::new(build_list(values[1..].to_vec()))
        )
    }
}

fn demo_pattern_2() {
    println!("\n=== Pattern 2: 재귀적 데이터 구조 ===");

    println!("문제: Box가 없으면 컴파일 에러");
    println!("  enum Node {{");
    println!("      Data(i32, Node),  // ← 무한 크기!");
    println!("      Nil,");
    println!("  }}");
    println!("");

    println!("해결: Box로 포인터 저장");
    println!("  enum Node {{");
    println!("      Data(i32, Box<Node>),  // ← 고정 크기!");
    println!("      Nil,");
    println!("  }}");
    println!("");

    println!("사용:");
    let list = build_list(vec![1, 2, 3]);
    println!("  연결 리스트 생성: 1 → 2 → 3 → Nil");
    println!("  메모리: 각 노드가 힙에 저장됨");

    println!("추론: 재귀적 구조는 Box 없이 불가능");
}

