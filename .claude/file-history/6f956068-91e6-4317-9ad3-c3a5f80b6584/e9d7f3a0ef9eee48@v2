fn demo_pattern_5() {
    println!("\n=== Pattern 5: 메모리 생명주기 ===");

    println!("자동 메모리 해제 (RAII):");
    println!("");

    {
        println!("  스코프 시작");
        let data = Box::new(vec![1, 2, 3, 4, 5]);
        println!("    Box 생성: 힙에 메모리 할당");
        println!("    데이터: {:?}", vec![1, 2, 3, 4, 5]);
        println!("    사용 중...");
    }  // 스코프 끝
    println!("  스코프 종료");
    println!("    Box 자동으로 메모리 해제");
    println!("    메모리 누수 없음!");
    println!("");

    println!("명시적 해제:");
    let data = Box::new(42);
    println!("  Box 생성: {}", *data);
    drop(data);
    println!("  drop(data) 호출: 명시적 해제");
    println!("  이후 data 사용 불가");
    println!("");

    println!("추론: 컴파일러가 메모리 해제를 보장");
}

