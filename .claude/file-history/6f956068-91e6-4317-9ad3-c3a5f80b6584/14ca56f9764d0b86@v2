// v7.0: 수명(Lifetimes) Step 1 — 함수의 수명 매개변수
// 철학: "안전한 시간의 경계: 참조자의 유효 기간을 명시한다"
// 목표: 함수가 여러 참조자를 다룰 때 허상 참조를 컴파일 타임에 방지

// ============================================================
// [Step 1 기초 1] 수명 없이 컴파일 불가능한 경우
// ============================================================

// 이 함수는 수명을 명시하지 않으면 컴파일 에러!
// fn compare(x: &str, y: &str) -> &str {
//     if x.len() > y.len() { x } else { y }
// }
// 에러: "cannot infer an appropriate lifetime for lifetime parameter"

// ============================================================
// [Step 1 패턴 1] 단일 입력 + 반환 (수명 생략 가능)
// ============================================================

fn first(x: &str) -> &str {
    x
}

// 명시적으로 쓰면:
fn first_explicit<'a>(x: &'a str) -> &'a str {
    x
}

// ============================================================
// [Step 1 패턴 2] 다중 입력 + 더 긴 것 반환 (수명 필수)
// ============================================================

fn longest<'a>(x: &'a str, y: &'a str) -> &'a str {
    if x.len() > y.len() {
        x
    } else {
        y
    }
}

// ============================================================
// [Step 1 패턴 3] 다중 입력 + 첫 번째만 반환
// ============================================================

fn first_only<'a, 'b>(x: &'a str, y: &'b str) -> &'a str {
    x  // 'a만 반환하므로 y의 수명은 'b로 독립적
}

// ============================================================
// [Step 1 패턴 4] 입력 + 소유 데이터 반환 (수명 불필요)
// ============================================================

fn concat<'a>(x: &'a str, y: &'a str) -> String {
    // String은 소유 데이터이므로 반환값에 수명 지정 불필요
    format!("{} {}", x, y)
}

// ============================================================
// [Step 1 패턴 5] 조건부 반환 (수명 필수)
// ============================================================

fn pick<'a>(condition: bool, x: &'a str, y: &'a str) -> &'a str {
    if condition {
        x
    } else {
        y
    }
}

// ============================================================
// [Step 1 원리 1] 컴파일러의 수명 검증
// ============================================================

fn demonstrate_lifetime_validation() {
    println!("\n=== Step 1 원리 1: 수명 검증 ===");

    println!("\n[사례 1] 같은 블록에서 호출");
    let s1 = "Alpha-Protocol";
    let s2 = "Beta";
    let result = longest(s1, s2);
    println!("더 긴 것: {}", result);
    // s1과 s2가 모두 유효하므로 result도 안전

    println!("\n[사례 2] 중첩 블록에서 호출");
    let s1 = "Longer String";
    let result;
    {
        let s2 = "Short";
        result = longest(s1, s2);
        // 이 블록 안에서만 result 사용 가능
        println!("블록 내부: {}", result);
    }
    // 여기서 s2가 소멸했으므로
    // result를 사용할 수 없음 (컴파일 에러)
}

// ============================================================
// [Step 1 원리 2] 허상 참조 방지
// ============================================================

fn demonstrate_dangling_prevention() {
    println!("\n=== Step 1 원리 2: 허상 참조 방지 ===");

    println!("\n✅ 안전한 패턴:");
    let s = "Safe String";
    let r = first(s);
    println!("반환된 참조: {}", r);
    // s의 수명 > r의 유효 범위 → 안전

    println!("\n❌ 위험한 패턴 (컴파일 에러):");
    println!("fn bad_return() -> &str {{");
    println!("    let s = String::from(\\\"hello\\\");");
    println!("    &s  // 에러! s의 수명이 반환값보다 짧음");
    println!("}}");
    println!("컴파일러: 'cannot return reference to local variable'");
}

// ============================================================
// [Step 1 패턴 비교] 수명 선언의 필요성
// ============================================================

fn compare_with_without_lifetime() {
    println!("\n=== Step 1 패턴: 수명 선언의 필요성 ===");

    println!("\n[패턴 1] 단일 입력 (수명 생략 가능)");
    println!("fn first(x: &str) -> &str {{ x }}");
    let r1 = first("single");
    println!("결과: {}", r1);

    println!("\n[패턴 2] 다중 입력 (수명 필수)");
    println!("fn longest<'a>(x: &'a str, y: &'a str) -> &'a str {{");
    println!("    if x.len() > y.len() {{ x }} else {{ y }}");
    println!("}}");
    let r2 = longest("longer", "short");
    println!("결과: {}", r2);

    println!("\n[패턴 3] 선택적 반환 (수명 필수)");
    println!("fn pick<'a>(cond: bool, x: &'a str, y: &'a str) -> &'a str {{");
    println!("    if cond {{ x }} else {{ y }}");
    println!("}}");
    let r3 = pick(true, "Alpha", "Beta");
    println!("결과: {}", r3);

    println!("\n[패턴 4] 소유 데이터 반환 (수명 불필요)");
    println!("fn concat<'a>(x: &'a str, y: &'a str) -> String {{");
    println!("    format!(\\\"{} {{}}\\\", x, y)");
    println!("}}");
    let r4 = concat("Hello", "World");
    println!("결과: {}", r4);
}

// ============================================================
// [Step 1 설명] 컴파일러의 관점
// ============================================================

fn explain_compiler_perspective() {
    println!("\n=== 컴파일러의 관점: 수명 검증 ===");

    println!("\n함수 정의:");
    println!("fn longest<'a>(x: &'a str, y: &'a str) -> &'a str");
    println!("");

    println!("컴파일러는 이렇게 해석합니다:");
    println!("1. 입력 x는 'a 수명을 가진 참조");
    println!("2. 입력 y도 'a 수명을 가진 참조");
    println!("3. 반환값도 'a 수명을 가진 참조");
    println!("4. 따라서 'a = min(x의 수명, y의 수명)");
    println!("");

    println!("호출 시:");
    println!("let s1 = \\\"Alpha\\\";     // 전체 함수에서 유효");
    println!("let s2 = \\\"Beta\\\";      // 이 블록까지만 유효");
    println!("let r = longest(s1, s2);   // 'a = 블록 끝까지");
    println!("");

    println!("결과:");
    println!("r은 블록 끝까지만 유효하므로");
    println!("블록 밖에서 r을 사용하면 컴파일 에러!");
}

// ============================================================
// [Step 1 원칙] 세 가지 핵심 이해
// ============================================================

fn explain_three_principles() {
    println!("\n=== Step 1의 3가지 원칙 ===");

    println!("\n[원칙 1] 수명은 시간이 아니라 범위");
    println!("  'a = \\\"이 함수 호출 범위\\\"");
    println!("  나이가 아니라 '스코프'를 의미합니다.");
    println!("");

    println!("[원칙 2] 수명은 수명을 늘리지 않는다");
    println!("  'a를 붙인다고 해서 변수가 더 오래 살지 않습니다.");
    println!("  단지 관계를 설명할 뿐입니다.");
    println!("");

    println!("[원칙 3] 생략 규칙 (Lifetime Elision)");
    println!("  fn first(x: &str) -> &str {{ x }}  // 생략 가능");
    println!("  fn first<'a>(x: &'a str) -> &'a str {{ x }}  // 명시 형태");
    println!("");

    println!("모호함이 없으면 생략, 모호함 있으면 명시!");
}

// ============================================================
// [Step 1 사례 1] 가장 긴 단어 찾기
// ============================================================

fn find_longest_message(messages: Vec<&str>) -> &str {
    let mut longest_msg = messages[0];
    for msg in messages {
        if msg.len() > longest_msg.len() {
            longest_msg = msg;
        }
    }
    longest_msg
}

// ============================================================
// [Step 1 사례 2] 메시지 비교
// ============================================================

fn compare_messages<'a>(msg1: &'a str, msg2: &'a str) -> bool {
    msg1.len() == msg2.len()
}

// ============================================================
// [Step 1 사례 3] 메시지 검증
// ============================================================

fn is_valid_message<'a>(msg: &'a str) -> bool {
    msg.len() > 0 && msg.len() <= 1024
}

// ============================================================
// [Step 1의 의미] 안전한 참조
// ============================================================

