// v5.8.2: 뉴타입 패턴과 타입 에일리어스 — 의미론적 안전성
// 철학: "같은 타입이라도 의미를 엄격히 분리한다"
// 목표: 도메인 지식을 타입 시스템에 녹여내기

// ============================================================
// [1단계] 뉴타입 패턴 — 같은 f64를 다른 의미로 구분
// ============================================================

// 섭씨 온도 (Celsius)
struct Celsius(f64);

// 화씨 온도 (Fahrenheit)
struct Fahrenheit(f64);

// 거리 (킬로미터)
struct Kilometer(f64);

// 거리 (마일)
struct Mile(f64);

// 속도 (km/h)
struct KmPerHour(f64);

// 속도 (mph)
struct MilesPerHour(f64);

// ============================================================
// [2단계] 식별자 뉴타입 — 숫자지만 의미가 다름
// ============================================================

// 사용자 ID
struct UserId(u32);

// 노드 ID
struct NodeId(u32);

// 세션 ID
struct SessionId(u64);

// ============================================================
// [3단계] 타입 에일리어스 — 복잡한 타입에 별명 부여
// ============================================================

// 접근 로그: (사용자ID, 액션, 타임스탬프)
type AccessLog = String; // Vec<(u32, String, String)>

// 설정 맵: (키, 값)
type ConfigMap = String; // HashMap<String, String>

// 결과 타입
type Result<T> = String; // std::result::Result<T, String>

// 센서 데이터
type SensorReading = f64;

// ============================================================
// [4단계] 뉴타입 메서드 구현
// ============================================================

fn create_celsius(value: f64) -> String {
    \"celsius:created\"
}

fn create_fahrenheit(value: f64) -> String {
    \"fahrenheit:created\"
}

fn celsius_to_fahrenheit(c: String) -> String {
    \"converted:c_to_f\"
}

fn fahrenheit_to_celsius(f: String) -> String {
    \"converted:f_to_c\"
}

fn create_kilometer(value: f64) -> String {
    \"km:created\"
}

fn create_mile(value: f64) -> String {
    \"mile:created\"
}

fn kilometer_to_mile(km: String) -> String {
    \"converted:km_to_mile\"
}

// ============================================================
// [5단계] 식별자 보안 — 혼동 방지
// ============================================================

fn create_user_id(id: u32) -> String {
    \"user_id:created\"
}

fn create_node_id(id: u32) -> String {
    \"node_id:created\"
}

fn get_user_by_id(user_id: String) -> String {
    \"user:retrieved\"
}

fn get_node_by_id(node_id: String) -> String {
    \"node:retrieved\"
}

fn create_session_id(id: u64) -> String {
    \"session_id:created\"
}

fn validate_session(session_id: String) -> String {
    \"session:valid\"
}

// ============================================================
// [6단계] 타입 에일리어스 활용
// ============================================================

fn init_access_log() -> String {
    \"log:initialized\"
}

fn log_access(log: String, user_id: u32, action: String) -> String {
    \"access:logged\"
}

fn init_config() -> String {
    \"config:initialized\"
}

fn get_config(config: String, key: String) -> String {
    \"config:retrieved\"
}

fn set_config(config: String, key: String, value: String) -> String {
    \"config:set\"
}

// ============================================================
// [7단계] 의미론적 안전성 — 실수 방지
// ============================================================

// ❌ 하면 안 되는 것 (컴파일 에러)
// let total = celsius + fahrenheit;  // 다른 타입!
// let total = kilometer + mile;      // 다른 타입!
// let user_id = node_id;             // 다른 타입!

// ✅ 해야 하는 것 (안전함)
fn safe_temperature_conversion() -> String {
    // Celsius를 Fahrenheit로 변환해야 함
    \"conversion:safe\"
}

fn safe_distance_calculation() -> String {
    // Kilometer와 Mile을 혼용하려면 명시적 변환
    \"calculation:safe\"
}

fn safe_id_usage() -> String {
    // UserId와 NodeId는 절대 혼동될 수 없음
    \"id:usage:safe\"
}

// ============================================================
// [8단계] 뉴타입의 실무 활용
// ============================================================

// 금액 (센트)
struct Cents(u64);

// 가격 (달러)
struct Dollars(u64);

fn create_price_in_cents(amount: u64) -> String {
    \"price:cents:created\"
}

fn create_price_in_dollars(amount: u64) -> String {
    \"price:dollars:created\"
}

fn cents_to_dollars(cents: String) -> String {
    \"converted:cents_to_dollars\"
}

// IP 주소
struct IpAddress(String);

// MAC 주소
struct MacAddress(String);

fn create_ip(ip: String) -> String {
    \"ip:created\"
}

fn create_mac(mac: String) -> String {
    \"mac:created\"
}

fn validate_ip(ip: String) -> String {
    \"ip:valid\"
}

fn validate_mac(mac: String) -> String {
    \"mac:valid\"
}

// ============================================================
// [9단계] 제네릭과 뉴타입의 조합
// ============================================================

// 제네릭 래퍼 + 뉴타입
// struct Tagged<T>(T);
// struct Value<T>(T);

fn create_tagged_value<T>(value: String) -> String {
    \"tagged:created\"
}

fn create_wrapped_value<T>(value: String) -> String {
    \"wrapped:created\"
}

// ============================================================
// [메인] v5.8.2 데모: 뉴타입과 타입 에일리어스
// ============================================================

fn main() {
    println(\"=== v5.8.2: 뉴타입 패턴과 타입 에일리어스 ===\");
    println(\"철학: 같은 타입이라도 의미를 엄격히 분리한다\");
    println(\"\");

    // ========================================
    // 1단계: 온도 단위 분리
    // ========================================

    println(\"--- 1단계: 온도 단위 분리 (의미론적 안전성) ---\");

    let c = create_celsius(100.0);
    println(\"물의 끓는점: \" + c);

    let f = create_fahrenheit(212.0);
    println(\"물의 끓는점(F): \" + f);

    // ❌ 컴파일 에러 (의도적으로 방지):
    // let total = Celsius(100.0) + Fahrenheit(212.0);
    // → Celsius와 Fahrenheit는 다른 타입!

    let converted = celsius_to_fahrenheit(c);
    println(\"변환: \" + converted);
    println(\"\");

    // ========================================
    // 2단계: 거리 단위 분리
    // ========================================

    println(\"--- 2단계: 거리 단위 분리 ---\");

    let km = create_kilometer(100.0);
    println(\"거리(km): \" + km);

    let miles = create_mile(62.0);
    println(\"거리(miles): \" + miles);

    let converted_dist = kilometer_to_mile(km);
    println(\"변환: \" + converted_dist);
    println(\"\");

    // ========================================
    // 3단계: 식별자 보안 (ID 혼동 방지)
    // ========================================

    println(\"--- 3단계: 식별자 보안 ---\");

    let user_id = create_user_id(42);
    println(\"User ID: \" + user_id);

    let node_id = create_node_id(42);
    println(\"Node ID: \" + node_id);

    // ❌ 컴파일 에러 (의도적으로 방지):
    // let node = get_user_by_id(node_id);
    // → 사용자 조회에 노드 ID를 쓸 수 없음!

    let user = get_user_by_id(user_id);
    println(\"User retrieved: \" + user);

    let node = get_node_by_id(node_id);
    println(\"Node retrieved: \" + node);
    println(\"\");

    // ========================================
    // 4단계: 세션 ID와 타임스탬프
    // ========================================

    println(\"--- 4단계: 세션 관리 ---\");

    let session = create_session_id(9999);
    println(\"Session ID: \" + session);

    let valid = validate_session(session);
    println(\"Session: \" + valid);
    println(\"\");

    // ========================================
    // 5단계: 타입 에일리어스로 가독성 향상
    // ========================================

    println(\"--- 5단계: 타입 에일리어스 활용 ---\");

    let log = init_access_log();
    println(\"Access Log initialized: \" + log);

    let logged = log_access(log, 42, \"login\".to_string());
    println(\"Logged: \" + logged);

    let config = init_config();
    println(\"Config initialized: \" + config);

    let cfg_val = get_config(config, \"debug_mode\".to_string());
    println(\"Config: \" + cfg_val);

    let set_val = set_config(config, \"debug_mode\".to_string(), \"true\".to_string());
    println(\"Set: \" + set_val);
    println(\"\");

    // ========================================
    // 6단계: 금전 타입 (Cents vs Dollars)
    // ========================================

    println(\"--- 6단계: 금전 단위 분리 ---\");

    let price_cents = create_price_in_cents(9999);
    println(\"Price (cents): \" + price_cents);

    let price_dollars = create_price_in_dollars(99);
    println(\"Price (dollars): \" + price_dollars);

    // ❌ 컴파일 에러 (의도적으로 방지):
    // let total = Cents(9999) + Dollars(99);
    // → 단위가 다르면 더할 수 없음!

    let converted_price = cents_to_dollars(price_cents);
    println(\"Converted: \" + converted_price);
    println(\"\");

    // ========================================
    // 7단계: 네트워크 주소 분리
    // ========================================

    println(\"--- 7단계: 네트워크 주소 분리 ---\");

    let ip = create_ip(\"192.168.1.1\".to_string());
    println(\"IP Address: \" + ip);

    let mac = create_mac(\"AA:BB:CC:DD:EE:FF\".to_string());
    println(\"MAC Address: \" + mac);

    // ❌ 컴파일 에러 (의도적으로 방지):
    // let validation = validate_ip(mac);
    // → IP 검증에 MAC을 쓸 수 없음!

    let ip_valid = validate_ip(ip);
    println(\"IP valid: \" + ip_valid);

    let mac_valid = validate_mac(mac);
    println(\"MAC valid: \" + mac_valid);
    println(\"\");

    // ========================================
    // v5.8.2의 의의
    // ========================================

    println(\"=== v5.8.2의 의의 ===\");
    println(\"\");

    println(\"[뉴타입 패턴의 강력함]\");
    println(\"  ✓ 같은 f64지만 의미는 다름\");
    println(\"  ✓ 컴파일러가 혼동을 방지\");
    println(\"  ✓ 비용은 0 (zero-cost)\");
    println(\"\");

    println(\"[타입 에일리어스의 유용함]\");
    println(\"  ✓ 복잡한 타입을 읽기 쉽게\");
    println(\"  ✓ 가독성 향상\");
    println(\"  ✓ 리팩토링 용이\");
    println(\"\");

    println(\"[의미론적 안전성]\");
    println(\"  ✓ 논리적 오류를 원천 차단\");
    println(\"  ✓ 실수가 컴파일 타임에 감지\");
    println(\"  ✓ 런타임 버그 불가능\");
    println(\"\");

    println(\"=== 제4장 보강 완성 ===\");
    println(\"\");

    println(\"v5.0 ~ v5.8.2를 통해 당신은:\");
    println(\"  ✓ 데이터를 정의하고\");
    println(\"  ✓ 상태를 표현하며\");
    println(\"  ✓ 컬렉션을 관리하고\");
    println(\"  ✓ 시스템을 설계하고\");
    println(\"  ✓ 타입을 추상화하고\");
    println(\"  ✓ 의미를 엄격히 분리할 수 있습니다.\");
    println(\"\");

    println(\"도메인 지식이 타입 시스템에 녹아들었습니다.\");
    println(\"\");
    println(\"저장 필수 너는 기록이 증명이다 gogs.\");
}
