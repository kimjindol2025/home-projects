// Phase 2: Heap 기반 메모리 관리
// Step 2: Load 연산 통합

import { HeapManager, HeapValue } from './heap';
import { Stack } from './stack';

interface ConstOp {
  type: 'const';
  value: number;
}

interface LoadOp {
  type: 'load';
  name: string;
}

interface StoreOp {
  type: 'store';
  name: string;
}

type Opcode = ConstOp | LoadOp | StoreOp;

export class VM {
  private stack: Stack<number>;
  private heap: HeapManager;
  private globals: Map<string, number>;

  constructor() {
    this.stack = new Stack();
    this.heap = new HeapManager();
    this.globals = new Map();
  }

  /**
   * Step 1 완료: Const 연산
   * Value를 Heap에 할당하고, Ptr을 Stack에 push
   */
  executeConst(op: ConstOp): void {
    const ptr = this.heap.allocate({ val: op.value });
    this.stack.push(ptr);
  }

  /**
   * Step 2: Load 연산 (진행 중)
   * 글로벌 변수의 Ptr을 가져와서 Stack에 push
   */
  executeLoad(op: LoadOp): void {
    const ptr = this.globals.get(op.name);
    if (ptr === undefined) {
      throw new Error(`Variable ${op.name} not defined`);
    }
    this.stack.push(ptr);
  }

  /**
   * Step 2 계획: Store 연산
   * Stack의 top을 글로벌 변수에 저장
   */
  executeStore(op: StoreOp): void {
    const ptr = this.stack.pop();
    if (ptr === undefined) {
      throw new Error('Stack underflow');
    }
    this.globals.set(op.name, ptr);
  }

  execute(opcodes: Opcode[]): void {
    for (const opcode of opcodes) {
      switch (opcode.type) {
        case 'const':
          this.executeConst(opcode);
          break;
        case 'load':
          this.executeLoad(opcode);
          break;
        case 'store':
          this.executeStore(opcode);
          break;
      }
    }
  }

  getStackTop(): number | undefined {
    return this.stack.peek();
  }

  getHeapValue(ptr: number): HeapValue | undefined {
    return this.heap.get(ptr);
  }

  getGlobal(name: string): number | undefined {
    return this.globals.get(name);
  }

  getHeapRefCount(ptr: number): number {
    return this.heap.getRefCount(ptr);
  }
}
