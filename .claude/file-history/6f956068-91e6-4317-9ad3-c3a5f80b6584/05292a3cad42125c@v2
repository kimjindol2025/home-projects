// ============================================================
// [Step 3 개념 3] 안전성의 보장
// ============================================================

fn explain_safety_guarantee() {
    println!("\n=== 개념 3: 'static의 안전성 ===");

    println!("다른 수명의 문제:");
    println!("  let ptr = {");
    println!("      let x = String::from(\"hello\");");
    println!("      &x  // ← x가 블록 끝에서 소멸!");
    println!("  };");
    println!("  println!(\"{}\", ptr);  // ❌ 위험!");
    println!("");

    println!("'static의 해결:");
    println!("  fn get_msg() -> &'static str {{");
    println!("      \"hello\"  // ← 바이너리에 이미 존재");
    println!("  }}");
    println!("  let msg = get_msg();");
    println!("  println!(\"{}\", msg);  // ✅ 100% 안전");
    println!("");

    println!("결론: 'static은 허상 참조를 물리적으로 불가능하게 만듦");
}

