struct AppConfig {
    version: &'static str,
    name: &'static str,
    author: &'static str,
}

// 정적 싱글톤: 프로그램당 한 번만 생성됨
static APP_CONFIG: AppConfig = AppConfig {
    version: "1.0.0",
    name: "GOGS System",
    author: "gogs",
};

fn get_app_config() -> &'static AppConfig {
    &APP_CONFIG
}

fn demo_pattern_4() {
    println!("\n=== Pattern 4: 정적 싱글톤 구조체 ===");

    let config = get_app_config();

    println!("버전: {}", config.version);
    println!("이름: {}", config.name);
    println!("작성자: {}", config.author);
    println!("추론: 정적 변수는 프로그램 데이터 세그먼트에 저장됨");
