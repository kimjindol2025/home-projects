// ============================================================
// [Step 3 패턴 2] 조건부 반환 (모두 'static 리터럴)
// ============================================================

fn get_status_message(code: u32) -> &'static str {
    match code {
        200 => "OK",
        201 => "Created",
        400 => "Bad Request",
        404 => "Not Found",
        500 => "Internal Server Error",
        _ => "Unknown Status",
    }
}

fn get_error_description(error_code: u16) -> &'static str {
    match error_code {
        1001 => "Connection Lost",
        1002 => "Protocol Error",
        1003 => "Unsupported Data Type",
        1004 => "Policy Violation",
        _ => "Unknown Error",
    }
}

fn demo_pattern_2() {
    println!("\n=== Pattern 2: 조건부 'static 반환 ===");

    let status_200 = get_status_message(200);
    let status_404 = get_status_message(404);
    let status_500 = get_status_message(500);

    println!("상태 200: {}", status_200);
    println!("상태 404: {}", status_404);
    println!("상태 500: {}", status_500);

    let error_1001 = get_error_description(1001);
    let error_1003 = get_error_description(1003);

    println!("에러 1001: {}", error_1001);
    println!("에러 1003: {}", error_1003);
    println!("추론: 모든 match 경로가 리터럴을 반환하므로 'static");
}

// ============================================================
// [Step 3 패턴 3] 정적 배열 참조
// ============================================================

// 정적 배열: 프로그램 데이터 세그먼트에 저장됨
static SUPPORTED_PROTOCOLS: &'static [&'static str] = &[
    "HTTP/1.0",
    "HTTP/1.1",
    "HTTP/2.0",
];

static ERROR_CODES: &'static [u32] = &[
    1001, 1002, 1003, 1004, 1005,
];

fn is_protocol_supported(protocol: &str) -> bool {
    SUPPORTED_PROTOCOLS.contains(&protocol)
}

fn is_valid_error_code(code: u32) -> bool {
    ERROR_CODES.contains(&code)
}

fn demo_pattern_3() {
    println!("\n=== Pattern 3: 정적 배열 ===");

    let test_protocols = ["HTTP/1.1", "HTTP/3.0", "FTP"];

    for proto in test_protocols {
        let supported = is_protocol_supported(proto);
        println!("프로토콜 '{}': {}", proto, if supported { "지원" } else { "미지원" });
    }

    let test_codes = [1001, 1002, 9999];

    for code in test_codes {
        let valid = is_valid_error_code(code);
        println!("에러 코드 {}: {}", code, if valid { "유효" } else { "무효" });
    }

    println!("추론: 배열은 'static, 참조도 'static");
}

