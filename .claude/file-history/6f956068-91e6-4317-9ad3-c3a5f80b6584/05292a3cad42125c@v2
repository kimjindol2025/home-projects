// [Step 3 개념 1] 'static vs 다른 수명
// ============================================================

fn demonstrate_static_uniqueness() {
    println!("\n=== 개념 1: 'static의 독특성 ===");

    println!("'static 데이터:");
    println!("  - 프로그램 시작: 존재");
    println!("  - 프로그램 중: 항상 존재");
    println!("  - 프로그램 종료: 함께 종료");
    println!("  - 스코프: 없음 (전역)");
    println!("");

    println!("다른 수명('a, 'b, etc):");
    println!("  - 생성: 스코프 진입");
    println!("  - 유효: 스코프 범위 내");
    println!("  - 종료: 스코프 탈출");
    println!("  - 스코프: 있음 (블록 범위)");
    println!("");

    println!("결론: 'static은 범위가 없는 유일한 수명");
}

