// ============================================================
// [Step 3 패턴 5] 메타데이터 레지스트리
// ============================================================

struct ServiceInfo {
    name: &'static str,
    port: u16,
    protocol: &'static str,
}

static SERVICES: &'static [ServiceInfo] = &[
    ServiceInfo {
        name: "HTTP Server",
        port: 80,
        protocol: "HTTP/1.1",
    },
    ServiceInfo {
        name: "HTTPS Server",
        port: 443,
        protocol: "HTTP/1.1",
    },
    ServiceInfo {
        name: "SSH Server",
        port: 22,
        protocol: "SSH",
    },
];

fn find_service(name: &str) -> Option<&'static ServiceInfo> {
    SERVICES.iter().find(|s| s.name == name).map(|&s| s)
}

fn demo_pattern_5() {
    println!("\n=== Pattern 5: 정적 메타데이터 레지스트리 ===");

    let service_names = ["HTTP Server", "SSH Server", "DNS Server"];

    for name in service_names {
        if let Some(service) = find_service(name) {
            println!("{}: 포트 {} ({})", service.name, service.port, service.protocol);
        } else {
            println!("{}: 등록되지 않음", name);
        }
    }

    println!("추론: 배열의 참조도 'static이므로 안전");
}

