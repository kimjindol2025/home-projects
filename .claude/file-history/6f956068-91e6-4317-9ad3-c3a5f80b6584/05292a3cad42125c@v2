// 문자열 리터럴은 프로그램 바이너리에 컴파일 타임에 포함됨
fn get_welcome_message() -> &'static str {
    "Welcome to GOGS System"
}

fn get_protocol() -> &'static str {
    "GOGS-Protocol-v1"
}

fn get_system_name() -> &'static str {
    "gogs"
}

fn demo_pattern_1() {
    println!("\n=== Pattern 1: 문자열 리터럴 (절대 소멸 안 함) ===");

