    println!("\n=== 정적 다형성 vs 동적 다형성 ===");

    println!("정적 다형성 (Rust의 트레이트 경계):");
    println!("  ✓ 컴파일 타임에 타입 결정");
    println!("  ✓ 런타임 오버헤드 없음");
    println!("  ✓ 모든 오류 컴파일 타임에 감지");
    println!("  ✓ 인라인 최적화 가능");

    println!("\n동적 다형성 (트레이트 객체 &dyn Trait):");
    println!("  ✓ 런타임에 타입 결정");
    println!("  ✓ 유연성 높음");
    println!("  ✗ 런타임 오버헤드 있음");
    println!("  ✗ 일부 오류가 런타임에 발생");
}

