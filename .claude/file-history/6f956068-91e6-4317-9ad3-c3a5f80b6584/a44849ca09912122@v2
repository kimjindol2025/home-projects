// [Step 1 패턴 비교]
// ============================================================

fn compare_patterns() {
    println!("\n=== Step 1 패턴: 5가지 유형 비교 ===");

    println!("\n[패턴 1] 단일 참조");
    let excerpt_data = "Important part";
    let excerpt = ImportantExcerpt { part: excerpt_data };
    excerpt.display();

    println!("\n[패턴 2] 다중 참조 (같은 수명)");
    let full_data = "context|command";
    let parser = GogsParser {
        context: &full_data[..7],
        command: &full_data[8..],
    };
    parser.announce();

    println!("\n[패턴 3] 참조 + 소유");
    let log = SecurityLog {
        message: "System Active",
        timestamp: 1708608000,
        level: 3,
    };
    println!("{}", log.summary());

    println!("\n[패턴 4] 다중 필드");
    let tracker = MessageTracker {
        original: "raw data",
        processed: "cleaned",
        status: "OK",
    };
    tracker.track();

    println!("\n[패턴 5] 다중 수명");
    let source = "source_system";
    let dest = "target_system";
    let bridge = DataBridge {
        source,
        destination: dest,
    };
    println!("{}", bridge.connect());
}

