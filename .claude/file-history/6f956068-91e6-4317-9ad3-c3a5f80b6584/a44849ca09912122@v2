// v7.0 확장: 수명(Lifetimes) Step 1 — 구조체의 수명 명시
// 철학: "빌려온 데이터로 만든 도구"
// 목표: 구조체가 참조자를 필드로 가질 때 안전하게 관리

// ============================================================
// [Step 1 패턴 1] 단일 참조 필드 (기본)
// ============================================================

struct ImportantExcerpt<'a> {
    part: &'a str,
}

impl<'a> ImportantExcerpt<'a> {
    fn display(&self) {
        println!("중요 부분: {}", self.part);
    }

    fn length(&self) -> usize {
        self.part.len()
    }
}

// ============================================================
// [Step 1 패턴 2] GogsParser - 스마트 로그 파서
// ============================================================

struct GogsParser<'a> {
    context: &'a str,
    command: &'a str,
}

impl<'a> GogsParser<'a> {
    fn new(context: &'a str, command: &'a str) -> Self {
        GogsParser {
            context,
            command,
        }
    }

    fn announce(&self) {
        println!("문맥: {}, 명령: {}", self.context, self.command);
    }

    fn analyze(&self) -> String {
        format!("분석 완료: {} | {}",
                self.context.len(),
                self.command.len())
    }
}

// ============================================================
// [Step 1 패턴 3] 보안 로그 (참조 + 소유 데이터)
// ============================================================

struct SecurityLog<'a> {
    message: &'a str,    // 참조 (빌린 데이터)
    timestamp: u64,      // 소유 (자신의 데이터)
    level: u8,           // 소유
}

impl<'a> SecurityLog<'a> {
    fn new(message: &'a str, timestamp: u64, level: u8) -> Self {
        SecurityLog {
            message,
            timestamp,
            level,
        }
    }

    fn summary(&self) -> String {
        format!("[{}] Level {}: {}", self.timestamp, self.level, self.message)
    }

    fn is_critical(&self) -> bool {
        self.level > 7
    }
}

// ============================================================
// [Step 1 패턴 4] 메시지 추적기 (다중 필드)
// ============================================================

struct MessageTracker<'a> {
    original: &'a str,
    processed: &'a str,
    status: &'a str,
}

impl<'a> MessageTracker<'a> {
    fn track(&self) {
        println!("원본: {} → 처리됨: {} (상태: {})",
                 self.original,
                 self.processed,
                 self.status);
    }

    fn validity_check(&self) -> bool {
        !self.original.is_empty() &&
        !self.processed.is_empty() &&
        !self.status.is_empty()
    }
}

// ============================================================
// [Step 1 패턴 5] 다중 수명 (독립적인 참조)
// ============================================================

struct DataBridge<'a, 'b> {
    source: &'a str,     // 'a 수명
    destination: &'b str, // 'b 수명 (독립적)
}

impl<'a, 'b> DataBridge<'a, 'b> {
    fn connect(&self) -> String {
        format!("{}에서 {}로 연결", self.source, self.destination)
    }

    fn validate(&self) -> bool {
        !self.source.is_empty() && !self.destination.is_empty()
    }
}

// ============================================================
// [Step 1 개념 1] 구조체는 데이터보다 짧다
// ============================================================

fn demonstrate_lifetime_ownership() {
    println!("\n=== Step 1 개념: 구조체의 운명 공동체 ===");

    println!("\n[사례 1] 같은 블록에서 안전");
    {
        let data = "LEVEL:INFO | MSG:System_Active";
        let parser = GogsParser {
            context: &data[..10],  // data에서 부분 빌림
            command: &data[13..],
        };
        parser.announce();
        // data가 블록 끝까지 살아있으므로 parser도 안전
    }

    println!("\n[사례 2] 다른 블록이면 컴파일 에러");
    println!("let parser;");
    println!("{{");
    println!("    let data = String::from(\\\"hello\\\");");
    println!("    parser = GogsParser {{ context: &data, command: \\\"x\\\" }};");
    println!("}};  // ← data 소멸!");
    println!("parser.announce();  // ❌ 컴파일 에러!");
    println!("(data가 이미 사라졌는데 parser가 이를 참조하려 함)");
}

// ============================================================
// [Step 1 개념 2] 수명이 전파된다
// ============================================================

fn demonstrate_lifetime_propagation() {
    println!("\n=== Step 1 개념: 수명의 전파 ===");

    println!("\n함수 정의:");
    println!("fn process<'a>(parser: &GogsParser<'a>) -> String {{");
    println!("    // parser와 그 필드들은 모두 'a 범위 내");
    println!("    parser.analyze()");
    println!("}}");

    let data = "GOGS-Alpha-Protocol";
    let parser = GogsParser {
        context: data,
        command: "parse",
    };

    let result = process_parser(&parser);
    println!("처리 결과: {}", result);
}

fn process_parser<'a>(parser: &GogsParser<'a>) -> String {
    parser.analyze()
}

// ============================================================
// [Step 1 개념 3] 메모리 효율성
// ============================================================

fn demonstrate_memory_efficiency() {
    println!("\n=== Step 1 개념: 메모리 절약 ===");

    println!("\n❌ 비효율 (String 복사):");
    println!("struct FullDocument {{");
    println!("    title: String,      // 복사본");
    println!("    content: String,    // 복사본");
    println!("    metadata: String,   // 복사본");
    println!("}}");
    println!("→ 각 필드마다 메모리 할당");

    println!("\n✅ 효율 (참조만):");
    println!("struct SlimDocument<'a> {{");
    println!("    title: &'a str,     // 참조만 (8바이트)");
    println!("    content: &'a str,   // 참조만 (8바이트)");
    println!("    metadata: &'a str,  // 참조만 (8바이트)");
    println!("}}");
    println!("→ 원본 데이터 한 번만 메모리에 로드");

    // 실제 예제
    let large_data = "This is a very large document with lots of content that we want to process efficiently without copying";

    let log = SecurityLog {
        message: large_data,
        timestamp: 1708608000,
        level: 5,
    };

    println!("\n실제 예: SecurityLog<'a>가 대용량 메시지를 참조");
    println!("메시지 크기: {} 바이트", large_data.len());
    println!("로그 크기: ~24 바이트 (timestamp + level + 참조)", );
    println!("효율: {:.1}% 절약",
             (1.0 - 24.0 / large_data.len() as f64) * 100.0);
}

