// v6.0: 트레이트 마스터 과정 4~5단계 — 다형성과 기본 구현
// 철학: "표준을 정의하면 확장이 우아하다"
// 목표: 다형성으로 유연함을, 기본 구현으로 효율성을 얻기

// ============================================================
// [Step 4-5 기초] 트레이트: Alert (다형성 + 기본 구현)
// ============================================================

// 기본 구현이 포함된 트레이트
trait Alert {
    // 기본 구현: 모든 장치가 사용할 표준 경고 메시지
    fn alert_message() -> String {
        "시스템 일반 경고 발생"
    }

    // 필수 구현: 각 장치가 반드시 구현해야 함
    fn log_alert();

    // 또 다른 기본 구현: 경고 레벨 정의
    fn alert_level() -> String {
        "MEDIUM"
    }
}

// ============================================================
// [Step 4: 다형성] 서로 다른 구조체들이 같은 트레이트를 구현
// ============================================================

// 핵심 엔진
struct CoreEngine {
    name: String,
}

impl Alert for CoreEngine {
    // 기본 구현 사용 (alert_message는 오버라이드 안 함)
    // → "시스템 일반 경고 발생" 사용

    fn log_alert() {
        println!("  [LOG] 엔진 로그 기록 중...");
    }

    // alert_level도 기본값 사용
}

// 보안 모듈
struct SecurityModule {
    level: u8,
}

impl Alert for SecurityModule {
    // 기본 구현을 오버라이드 (기본값 무시)
    fn alert_message() -> String {
        "⚠️ 보안 침입 감지! 프로토콜 가동!"
    }

    fn log_alert() {
        println!("  [LOG] 보안 경고 데이터베이스 전송...");
    }

    // alert_level도 오버라이드
    fn alert_level() -> String {
        "CRITICAL"
    }
}

// 네트워크 인터페이스
struct NetworkInterface {
    status: String,
}

impl Alert for NetworkInterface {
    fn alert_message() -> String {
        "🔗 네트워크 연결 불안정"
    }

    fn log_alert() {
        println!("  [LOG] 네트워크 로그를 원격 서버로 전송...");
    }

    fn alert_level() -> String {
        "HIGH"
    }
}

// 데이터베이스 시스템
struct DatabaseSystem;

impl Alert for DatabaseSystem {
    // alert_message 기본값 사용 (모든 DB는 일반 경고 사용)
    // alert_level도 기본값 사용 (MEDIUM)

    fn log_alert() {
        println!("  [LOG] DB 접속 로그 기록...");
    }
}

// ============================================================
// [Step 5: 기본 구현의 활용] 함수들
// ============================================================

// 단일 장치의 경고 처리
fn handle_alert_for_engine() {
    println!("--- CoreEngine ---");
    println!("Message: {}", CoreEngine::alert_message());
    println!("Level: {}", CoreEngine::alert_level());
    CoreEngine::log_alert();
}

fn handle_alert_for_security() {
    println!("\n--- SecurityModule ---");
    println!("Message: {}", SecurityModule::alert_message());
    println!("Level: {}", SecurityModule::alert_level());
    SecurityModule::log_alert();
}

fn handle_alert_for_network() {
    println!("\n--- NetworkInterface ---");
    println!("Message: {}", NetworkInterface::alert_message());
    println!("Level: {}", NetworkInterface::alert_level());
    NetworkInterface::log_alert();
}

fn handle_alert_for_database() {
    println!("\n--- DatabaseSystem ---");
    println!("Message: {}", DatabaseSystem::alert_message());
    println!("Level: {}", DatabaseSystem::alert_level());
    DatabaseSystem::log_alert();
}

// ============================================================
// [Step 4 실천] 다형성: 여러 타입을 하나의 함수로 처리
// ============================================================

// 트레이트 객체를 사용한 다형성 처리
// (주의: FreeLang의 제한으로 직접 구현은 제한될 수 있음)

fn process_all_alerts() {
    println!("\n=== 모든 장치의 경고 처리 ===");
    println!("\n[다형성의 장점]");
    println!("개별 타입을 신경 쓰지 않고");
    println!("Alert 트레이트만으로 모든 장치를 처리!");
}

// ============================================================
// [기본 구현의 효율성 분석]
// ============================================================

fn analyze_efficiency() {
    println!("\n=== 기본 구현의 코드 절감 분석 ===");

    let messages = vec![
        ("CoreEngine", CoreEngine::alert_message()),
        ("SecurityModule", SecurityModule::alert_message()),
        ("NetworkInterface", NetworkInterface::alert_message()),
        ("DatabaseSystem", DatabaseSystem::alert_message()),
    ];

    let mut default_count = 0;
    let mut override_count = 0;

    for (device, msg) in messages.iter() {
        if msg == "시스템 일반 경고 발생" {
            default_count = default_count + 1;
            println!("  {} → 기본값 사용 (오버라이드 안 함)", device);
        } else {
            override_count = override_count + 1;
            println!("  {} → 커스텀 구현", device);
        }
    }

    println!("\n효율성:");
    println!("  기본값 사용: {}개 (코드 작성 0줄)", default_count);
    println!("  커스텀 구현: {}개 (필요한 부분만 작성)", override_count);
    println!("  절감: ~{}%", (default_count * 100) / 4);
}

