// Pattern 21: Timestamp embedding problem
fn timestamp_embedding_problem() -> String {
  "Timestamp Embedding Issue:

   Problem: Build timestamp embedded in binary
   Impact: Every compilation produces different binary

   Source locations:
   - ELF header: build date/time
   - Debug symbols: timestamp metadata
   - String table: __BUILD_TIMESTAMP__ constant

   Solution:
   --build-timestamp 0      # Use fixed epoch timestamp
   --reproducible-mode true # Remove all timestamps

   Effect: Eliminates time-based variance"
}

// Pattern 22: File path normalization
fn file_path_normalization() -> String {
  "File Path Normalization Issue:

   Problem: Absolute file paths in debug info vary
   Impact: Different machines → different binaries

   Sources:
   - Debug symbol paths: /home/alice/... vs /home/bob/...
   - Working directory: /root/project vs ./
   - Include paths: varying absolute locations

   Solution:
   --strip-paths true                # Remove all paths
   --base-path-suffix src/           # Normalize base path
   --relative-paths true             # Use relative paths

   Effect: Machine-independent binaries"
}

// Pattern 23: Randomness removal
fn randomness_removal() -> String {
  "Randomness Removal Issue:

   Problem: Non-deterministic algorithms cause variance
   Impact: HashMap iteration, RNG seeds vary

   Sources:
   - Hash table ordering (HashMap<K,V> iteration)
   - Random number generation (RNG-based algorithms)
   - Non-deterministic scheduling (thread ordering)

   Solution:
   --seed 42                 # Fixed RNG seed
   --hash-order sorted       # Sort hash tables
   --disable-threading true  # Single-threaded mode

   Effect: Guaranteed reproducibility"
}

// Pattern 24: Memory alignment determinism
fn memory_alignment_determinism() -> String {
  "Memory Alignment Determinism Issue:

   Problem: Compiler may align structures differently
   Impact: Binary layout varies between compilations

   Sources:
   - struct padding: varies by alignment algorithm
   - Object file sections: section alignment differs
   - BSS section: varies based on linker

   Solution:
   --struct-alignment fixed  # Fixed alignment algorithm
   --linker gnu              # Use consistent linker
   --object-format elf64     # Fixed binary format

   Effect: Guaranteed layout reproducibility"
}

// Pattern 25: Floating-point determinism
fn floating_point_determinism() -> String {
  "Floating-Point Determinism Issue:

   Problem: FP operations have precision variance
   Impact: Different CPU/FPU → different results

   Sources:
   - FPU rounding modes: may differ
   - SIMD operations: vary by CPU features
   - Constant folding: precision varies

   Solution:
   --float-precision strict  # No FPU optimizations
   --fp-model consistent     # Consistent FP behavior
   --simd-disable true       # No SIMD operations

   Effect: Identical floating-point results"
}

