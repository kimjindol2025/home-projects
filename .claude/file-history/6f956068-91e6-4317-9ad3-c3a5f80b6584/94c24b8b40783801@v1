/**
 * Runtime Module Tests
 * HTTP, JIT, Actor 테스트
 */

import * as runtime from '../src/runtime';

describe('Runtime - HTTP Module', () => {
  test('response', () => {
    const resp = runtime.http.response(200, { message: 'OK' });
    expect(resp.status).toBe(200);
    expect(resp.body.message).toBe('OK');
  });

  test('parseJson', () => {
    const json = '{"a":1,"b":2}';
    const obj = runtime.http.parseJson(json);
    expect(obj.a).toBe(1);
    expect(obj.b).toBe(2);
  });

  test('parseForm', () => {
    const form = 'name=John&age=30';
    const obj = runtime.http.parseForm(form);
    expect(obj.name).toBe('John');
    expect(obj.age).toBe('30');
  });

  test('parseForm with encoded values', () => {
    const form = 'email=test%40example.com&msg=Hello%20World';
    const obj = runtime.http.parseForm(form);
    expect(obj.email).toBe('test@example.com');
    expect(obj.msg).toBe('Hello World');
  });
});

describe('Runtime - JIT Module', () => {
  beforeEach(() => {
    runtime.jit.initJIT({
      hotspotThreshold: 10,
      enablePGO: true,
      enableDeopt: true,
    });
  });

  test('detectHotspot', () => {
    // 첫 호출에서는 false
    expect(runtime.jit.detectHotspot('test')).toBe(false);
    
    // 반복 호출로 threshold 도달
    for (let i = 0; i < 10; i++) {
      runtime.jit.detectHotspot('test');
    }
    expect(runtime.jit.detectHotspot('test')).toBe(true);
  });

  test('getJITStats', () => {
    runtime.jit.detectHotspot('func1');
    for (let i = 0; i < 5; i++) {
      runtime.jit.detectHotspot('func1');
    }
    
    const stats = runtime.jit.getJITStats();
    expect(stats.hotspots).toBeGreaterThan(0);
    expect(stats.totalExecutions).toBeGreaterThan(0);
  });
});

describe('Runtime - Actor Module', () => {
  test('EchoActor creation', () => {
    const actor = new runtime.EchoActor({ name: 'echo' });
    expect(actor.info().name).toBe('echo');
  });

  test('CounterActor increment', () => {
    const counter = new runtime.CounterActor({ name: 'counter' });
    
    counter.receive({
      type: 'INCREMENT',
      payload: 5,
    });
    
    expect(counter.info().name).toBe('counter');
  });

  test('ActorSystem creation', () => {
    const system = new runtime.ActorSystem();
    const echo = system.createActor(runtime.EchoActor, 'echo-1');
    
    expect(system.getActor('echo-1')).toBe(echo);
    system.shutdown();
  });

  test('Actor mailbox', () => {
    const actor = new runtime.EchoActor({ name: 'test', mailboxSize: 10 });
    
    for (let i = 0; i < 5; i++) {
      actor.receive({ type: 'TEST', payload: i });
    }
    
    expect(actor.info().mailboxSize).toBe(5);
  });

  test('Actor hierarchy', () => {
    const parent = new runtime.EchoActor({ name: 'parent' });
    const child = new runtime.EchoActor({ name: 'child' });
    
    parent.spawnChild(child);
    expect(parent.info().children).toBe(1);
    
    parent.stop();
  });
});
