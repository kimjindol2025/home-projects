fn explain_distributed_control() {
    println!("\n=== 개념 2: 중앙 통제 vs 분산 제어 ===");

    println!(\"중앙 통제 방식:\");
    println!(\"  struct System {{\");
    println!(\"      data: Vec<Entity>,\");
    println!(\"  }}\");
    println!(\"\");
    println!(\"  impl System {{\");
    println!(\"      fn update(&mut self, id: u32, value: i32) {{\");
    println!(\"          // 중앙에서만 수정 가능\");
    println!(\"      }}\");
    println!(\"  }}\");
    println!(\"\");

    println!(\"분산 제어 방식:\");
    println!(\"  let entity = Rc::new(RefCell::new(Entity {{ ... }}));\");
    println!(\"  let copy_a = Rc::clone(&entity);\");
    println!(\"  let copy_b = Rc::clone(&entity);\");
    println!(\"  // A도, B도 수정 가능\");
    println!(\"\");

    println!(\"차이:\");
    println!(\"  중앙 통제:\");
    println!(\"    - 명확한 책임\");
    println!(\"    - 병목 가능\");
    println!(\"    - 디버깅 쉬움\");
    println!(\"\");
    println!(\"  분산 제어:\");
    println!(\"    - 자율성 부여\");
    println!(\"    - 병렬 처리 용이\");
    println!(\"    - 디버깅 어려움\");
}

