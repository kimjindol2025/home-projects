// [Step 4 패턴 2] 동적 노드 네트워크 (AdminPanel)
// ============================================================

fn demo_pattern_2() {
    println!("\n=== Pattern 2: 동적 노드 네트워크 (AdminPanel) ===");

    println!(\"구조:\");
    println!(\"\");
    println!(\"struct SecurityConfig {{\");
    println!(\"    active_protocol: String,\");
    println!(\"    revision: i32,\");
    println!(\"  }}\");
    println!(\"\");
    println!(\"struct AdminPanel {{\");
    println!(\"    name: String,\");
    println!(\"    config: Rc<RefCell<SecurityConfig>>,\");
    println!(\"  }}\");
    println!(\"\");

    println!(\"특징:\");
    println!(\"  - 여러 AdminPanel이 하나의 config 공유\");
    println!(\"  - 각 panel에서 독립적으로 수정 가능\");
    println!(\"  - 모두가 변경을 즉시 봄\");
    println!(\"  - 중앙 관리자 불필요\");
    println!(\"\");

    println!(\"사용:\");
    println!(\"  let config = Rc::new(RefCell::new(SecurityConfig {{ ... }}));\");
    println!(\"  let panel_a = AdminPanel {{ config: Rc::clone(&config) }};\");
    println!(\"  let panel_b = AdminPanel {{ config: Rc::clone(&config) }};\");
    println!(\"\");
    println!(\"  panel_a.update_protocol(\\\"ALPHA\\\");\");
    println!(\"  // panel_b도 즉시 변경을 봄\");
    println!(\"\");

    println!(\"추론: 중앙 통제 없는 협업 시스템\");
}

// ============================================================
// [Step 4 패턴 3] 양방향 그래프 (순환 참조 주의!)
// ============================================================

fn demo_pattern_3() {
    println!("\n=== Pattern 3: 양방향 그래프 (순환 참조 주의!) ===");

    println!(\"구조:\");
    println!(\"  struct Node {{\");
    println!(\"      value: i32,\");
    println!(\"      neighbors: Vec<Rc<RefCell<Node>>>,\");
    println!(\"  }}\");
    println!(\"\");

    println!(\"문제: 순환 참조!\");
    println!(\"  let a = Rc::new(RefCell::new(Node {{ ... }}));\");
    println!(\"  let b = Rc::new(RefCell::new(Node {{ ... }}));\");
    println!(\"\");
    println!(\"  a.borrow_mut().neighbors.push(Rc::clone(&b));\");
    println!(\"  b.borrow_mut().neighbors.push(Rc::clone(&a));\");
    println!(\"\");
    println!(\"  ⚠️ A → B → A 순환!\");
    println!(\"  ⚠️ a.strong_count() >= 2\");
    println!(\"  ⚠️ b.strong_count() >= 2\");
    println!(\"  ⚠️ 카운트 0 불가능!\");
    println!(\"  ⚠️ 메모리 누수!\");
    println!(\"\");

    println!(\"해결책: Weak<T> 사용\");
    println!(\"  → 약참조 (weak reference)\");
    println!(\"  → 참조 카운트에 포함 안 됨\");
    println!(\"  → v9.4에서 배울 예정\");
    println!(\"\");

    println!(\"추론: 강력함은 위험함을 동반\");
}

