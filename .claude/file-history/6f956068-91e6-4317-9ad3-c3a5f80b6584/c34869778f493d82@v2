// ============================================================
// [Step 4 패턴 1] 기본 Rc<RefCell<T>> 조합
// ============================================================

fn demo_pattern_1() {
    println!("\n=== Pattern 1: 기본 Rc<RefCell<T>> 조합 ===");

    println!("세 가지의 결합:\");
    println!(\"\");

    println!(\"v9.1 Rc<T>:\");
    println!(\"  let rc = Rc::new(5);\");
    println!(\"  let a = Rc::clone(&rc);\");
    println!(\"  // *a = 10;  불가능!\");
    println!(\"\");

    println!(\"v9.2 RefCell<T>:\");
    println!(\"  let cell = RefCell::new(5);\");
    println!(\"  cell.borrow_mut();  // 가능하지만 단일 소유자\");
    println!(\"\");

    println!(\"v9.3 Rc<RefCell<T>>:\");
    println!(\"  let shared = Rc::new(RefCell::new(5));\");
    println!(\"  let a = Rc::clone(&shared);\");
    println!(\"  let b = Rc::clone(&shared);\");
    println!(\"  a.borrow_mut();  // 가능! 모두 소유하면서도 수정 가능\");
    println!(\"\");

    println!(\"의미:\");
    println!(\"  - Rc: 참조 카운팅 (다중 소유)\");
    println!(\"  - RefCell: 런타임 검사 (내부 가변성)\");
    println!(\"  - 조합: 완전한 자유도 + 완전한 책임\");
    println!(\"\");

    println!(\"추론: Rc<RefCell<T>>는 메모리 제어의 극한\");
}

