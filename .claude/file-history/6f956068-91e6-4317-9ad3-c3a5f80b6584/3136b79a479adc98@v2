fn main() {
  println("=== FreeLang v3.7: Finite State Machine Design ===\n");

  example_traffic_light();
  println("");

  example_player_state();
  println("");

  example_connection_state();
  println("");

  example_login_state();
  println("");

  example_order_state();

  println("\n=== v3.7 Core Principles ===");
  println("1. Explicit state definition");
  println("2. State-specific command handling");
  println("3. Invalid transitions physically blocked");
  println("4. Current state = complete system status");
}
