// [Step 2 패턴 1] 기본 Rc<T> 사용
// ============================================================

fn demo_pattern_1() {
    println!("\n=== Pattern 1: 기본 Rc<T> 사용 ===");

    println!("Box<T> vs Rc<T>:");
    println!(\"\");

    println!(\"Box<T> (단일 소유권):\");
    println!(\"  let boxed = Box::new(42);\");
    println!(\"  let a = boxed;        // 소유권 이동\");
    println!(\"  // boxed는 이제 사용 불가\");
    println!(\"\");

    println!(\"Rc<T> (다중 소유권):\");
    println!(\"  let rc = Rc::new(42);\");
    println!(\"  let a = Rc::clone(&rc);  // 참조 카운트 증가\");
    println!(\"  let b = Rc::clone(&rc);  // 참조 카운트 증가\");
    println!(\"  // rc, a, b 모두 같은 데이터 공유\");
    println!(\"\");

    println!(\"참조 카운팅:\");
    let rc = 42;
    println!(\"  초기: rc만 존재\");
    println!(\"  Rc::clone(&rc) 호출 시: 카운트 증가\");
    println!(\"  drop() 될 때마다: 카운트 감소\");
    println!(\"  카운트가 0: 자동 메모리 해제\");
    println!(\"\");

    println!(\"추론: Rc는 여러 소유자가 데이터를 공유 가능하게 함\");
}

