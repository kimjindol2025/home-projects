fn demo_pattern_5() {
    println!("\n=== Pattern 5: 참조 카운트 추적 ===");

    println!(\"참조 카운트란?\");
    println!(\"\");
    println!(\"  Rc::strong_count(&rc)로 현재 카운트 확인 가능\");
    println!(\"\");

    println!(\"시나리오:\");
    println!(\"  let rc = Rc::new(42);  // 카운트: 1\");
    println!(\"\");

    println!(\"  let a = Rc::clone(&rc);  // 카운트: 2\");
    println!(\"  let b = Rc::clone(&rc);  // 카운트: 3\");
    println!(\"\");

    println!(\"  drop(a);  // 카운트: 2\");
    println!(\"  drop(b);  // 카운트: 1\");
    println!(\"  drop(rc); // 카운트: 0 → 메모리 해제\");
    println!(\"\");

    println!(\"디버깅:\");
    println!(\"  fn debug_rc<T>(rc: &Rc<T>) {{\");
    println!(\"      let count = Rc::strong_count(rc);\");
    println!(\"      println!(\\\"Rc references: {{}}\\\", count);\");
    println!(\"  }}\");
    println!(\"\");

    println!(\"추론: strong_count()로 참조 흐름을 이해하고 디버깅\");
}

