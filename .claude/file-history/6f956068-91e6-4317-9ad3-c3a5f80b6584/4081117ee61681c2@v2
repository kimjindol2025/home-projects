// ============================================================
// [Step 2 개념 2] 참조 카운팅의 원리
// ============================================================

fn explain_reference_counting() {
    println!("\n=== 개념 2: 참조 카운팅의 원리 ===");

    println!(\"RcBox 구조:\");
    println!(\"  ┌─────────────────┐\");
    println!(\"  │ RcBox {{         │\");
    println!(\"  │   strong: 2,    │  ← Rc 참조 카운트\");
    println!(\"  │   weak: 0,      │  ← Weak 참조 카운트\");
    println!(\"  │   value: 42     │  ← 실제 데이터\");
    println!(\"  │ }}              │\");
    println!(\"  └─────────────────┘\");
    println!(\"\");

    println!(\"생명주기:\");
    println!(\"  1. Rc::new(value) → RcBox 생성, strong = 1\");
    println!(\"  2. Rc::clone(&rc) → strong += 1\");
    println!(\"  3. drop(rc) → strong -= 1\");
    println!(\"  4. strong == 0 → 메모리 해제\");
    println!(\"\");

    println!(\"멀티 클론:\");
    println!(\"  let rc = Rc::new(42);        // strong = 1\");
    println!(\"  let a = Rc::clone(&rc);     // strong = 2\");
    println!(\"  let b = Rc::clone(&rc);     // strong = 3\");
    println!(\"  let c = Rc::clone(&a);      // strong = 4\");
    println!(\"\");
    println!(\"  어느 것으로든 clone 가능\");
    println!(\"  모두 같은 값을 가리킴\");
}

