// [Step 2 패턴 2] 재귀적 데이터 구조 (트리)
// ============================================================

enum GogsTreeNode {
    Branch {
        value: i32,
        children: Vec<i32>,  // 실제로는 Vec<Rc<GogsTreeNode>>
    },
    Leaf(i32),
}

fn demo_pattern_2() {
    println!("\n=== Pattern 2: 재귀적 데이터 구조 (트리) ===");

    println!(\"Box<T>의 문제:\");
    println!(\"  enum Node {{\");
    println!(\"      Branch {{ value: i32, children: Vec<Node> }}\");
    println!(\"      Leaf(i32),\");
    println!(\"  }}\");
    println!(\"\");
    println!(\"  Node의 자식이 Node를 소유\");
    println!(\"  → 부모가 유일한 소유자\");
    println!(\"  → 형제 노드끼리 공유 불가\");
    println!(\"\");

    println!(\"Rc<T>의 해결책:\");
    println!(\"  enum Node {{\");
    println!(\"      Branch {{ value: i32, children: Vec<Rc<Node>> }}\");
    println!(\"      Leaf(i32),\");
    println!(\"  }}\");
    println!(\"\");
    println!(\"  각 노드는 Rc로 여러 부모에게 참조될 수 있음\");
    println!(\"  → 트리 구조 가능\");
    println!(\"  → 그래프 구조 가능 (순환 참조 주의)\");
    println!(\"\");

    println!(\"구조:\");
    println!(\"       부모(Rc)\");
    println!(\"      /    \\\");
    println!(\"   자식1  자식2  (각각 Rc로 참조)\");
    println!(\"   참조카운트: 2\");
    println!(\"\");

    println!(\"추론: Rc는 트리/그래프 구조 구현 가능하게 함\");
}

// ============================================================
// [Step 2 패턴 3] 공유 데이터 구조
// ============================================================

struct SharedCounter {
    value: i32,
}

struct CounterHolder {
    shared: i32,  // 실제로는 Rc<SharedCounter>
}

impl CounterHolder {
    fn new(value: i32) -> Self {
        CounterHolder { shared: value }
    }

    fn share(&self) -> Self {
        CounterHolder { shared: self.shared }
    }
}

fn demo_pattern_3() {
    println!("\n=== Pattern 3: 공유 데이터 구조 ===");

    println!(\"비효율: 데이터 복사\");
    let counter = SharedCounter { value: 100 };
    println!(\"  counter.value = {}\", counter.value);
    println!(\"  복사 시마다 메모리 할당 필요\");
    println!(\"\");

    println!(\"효율: Rc로 공유\");
    let shared = 100;
    println!(\"  let holder1 = Rc::new(counter);\");
    println!(\"  let holder2 = Rc::clone(&holder1);\");
    println!(\"  let holder3 = Rc::clone(&holder1);\");
    println!(\"\");
    println!(\"  세 개 모두 같은 counter 공유\");
    println!(\"  메모리 할당: 1번만\");
    println!(\"  참조 카운트: 3\");
    println!(\"\");

    println!(\"장점:\");
    println!(\"  - 메모리 효율\");
    println!(\"  - 복사 비용 없음\");
    println!(\"  - 데이터 일관성 보장\");
    println!(\"\");

    println!(\"추론: Rc는 구조체 필드에 사용하여 데이터 공유\");
}

// ============================================================
// [Step 2 패턴 4] Rc와 match
// ============================================================

enum GogsMessage {
    Success(String),
    Failure(String),
}

fn handle_message(msg: &GogsMessage) {
    match msg {
        GogsMessage::Success(text) => {
            println!(\"✅ Success: {}\", text);
        }
        GogsMessage::Failure(text) => {
            println!(\"❌ Failure: {}\", text);
        }
    }
}

fn demo_pattern_4() {
    println!("\n=== Pattern 4: Rc와 match ===");

    println!(\"메시지 재사용:\");
    println!(\"\");

    let msg1 = GogsMessage::Success(\"Complete\".to_string());
    handle_message(&msg1);

    let msg2 = GogsMessage::Failure(\"Error\".to_string());
    handle_message(&msg2);

    println!(\"\");
    println!(\"Rc 사용 시:\");
    println!(\"  let text = Rc::new(\\\"Operation\\\".to_string());\");
    println!(\"  let msg1 = GogsMessage::Success(Rc::clone(&text));\");
    println!(\"  let msg2 = GogsMessage::Success(Rc::clone(&text));\");
    println!(\"\");
    println!(\"  같은 문자열을 두 메시지가 공유\");
    println!(\"  메모리 단편화 감소\");
    println!(\"\");

    println!(\"추론: enum 필드에 Rc를 사용하여 데이터 효율화\");
}

