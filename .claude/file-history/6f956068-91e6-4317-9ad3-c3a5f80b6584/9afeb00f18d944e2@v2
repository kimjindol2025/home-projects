// Phase 2 Step 2: Load 연산 통합 테스트

import { VM } from './vm';
import { Stack } from './stack';
import { HeapManager } from './heap';

console.log('='.repeat(60));
console.log('Phase 2 Step 2: Load 연산 통합 테스트');
console.log('='.repeat(60));

// Test 1: Const 연산 - Heap 할당 확인
console.log('\n[Test 1] Const 연산 - Heap 할당 및 Stack push');
const vm1 = new VM();
vm1.execute([{ type: 'const', value: 42 }]);

const stackTop = vm1.getStackTop();
console.log(`  Stack top: ${stackTop}`);
const heapValue = vm1.getHeapValue(stackTop!);
console.log(`  Heap[${stackTop}] = { val: ${heapValue?.val}, refCount: ${heapValue?.refCount} }`);
console.assert(heapValue?.val === 42, 'Const 값이 Heap에 저장되어야 함');
console.assert(heapValue?.refCount === 1, 'Initial refCount는 1이어야 함');
console.log('  ✓ PASS');

// Test 2: Store 연산 - 글로벌 변수에 Ptr 저장
console.log('\n[Test 2] Store 연산 - 글로벌 변수에 Ptr 저장');
const vm2 = new VM();
vm2.execute([
  { type: 'const', value: 100 },
  { type: 'store', name: 'x' }
]);

const globalPtr = vm2.getGlobal('x');
console.log(`  globals['x'] = ${globalPtr}`);
const heapValue2 = vm2.getHeapValue(globalPtr!);
console.log(`  Heap[${globalPtr}] = { val: ${heapValue2?.val}, refCount: ${heapValue2?.refCount} }`);
console.assert(heapValue2?.val === 100, 'Store 값이 정확해야 함');
console.log('  ✓ PASS');

// Test 3: Load 연산 - 글로벌 변수에서 Ptr 로드
console.log('\n[Test 3] Load 연산 - 글로벌 변수에서 Ptr 로드');
const vm3 = new VM();
vm3.execute([
  { type: 'const', value: 200 },
  { type: 'store', name: 'y' }
]);

// Load 전 상태
console.log('  [Before Load]');
const globalPtr3 = vm3.getGlobal('y');
console.log(`    globals['y'] = ${globalPtr3}`);
const refCountBefore = vm3.getHeapRefCount(globalPtr3!);
console.log(`    refCount = ${refCountBefore}`);

// Load 실행
vm3.execute([{ type: 'load', name: 'y' }]);

// Load 후 상태
console.log('  [After Load]');
const stackTop3 = vm3.getStackTop();
console.log(`    Stack top = ${stackTop3}`);
const refCountAfter = vm3.getHeapRefCount(globalPtr3!);
console.log(`    refCount = ${refCountAfter}`);

console.assert(stackTop3 === globalPtr3, 'Load된 Ptr이 Stack에 push되어야 함');
console.assert(refCountAfter === refCountBefore, 'Load 연산은 refCount를 변경하면 안 됨');
console.log('  ✓ PASS');

// Test 4: Load 정의되지 않은 변수 - 에러 처리
console.log('\n[Test 4] Load 정의되지 않은 변수 - 에러 처리');
const vm4 = new VM();
try {
  vm4.execute([{ type: 'load', name: 'undefined_var' }]);
  console.log('  ✗ FAIL: 에러가 발생해야 함');
} catch (error: any) {
  console.log(`  Error caught: "${error.message}"`);
  console.assert(
    error.message.includes('not defined'),
    '에러 메시지에 "not defined"가 있어야 함'
  );
  console.log('  ✓ PASS');
}

// Test 5: Store 후 Load - 연쇄 동작
console.log('\n[Test 5] Store 후 Load - 연쇄 동작');
const vm5 = new VM();
vm5.execute([
  { type: 'const', value: 300 },
  { type: 'store', name: 'z' },
  { type: 'load', name: 'z' }
]);

const stackTop5 = vm5.getStackTop();
const globalZ = vm5.getGlobal('z');
console.log(`  globals['z'] = ${globalZ}`);
console.log(`  Stack top = ${stackTop5}`);

console.assert(stackTop5 === globalZ, 'Load된 값이 Store된 Ptr과 같아야 함');

const heapValue5 = vm5.getHeapValue(stackTop5!);
console.log(`  Heap[${stackTop5}] = { val: ${heapValue5?.val} }`);
console.assert(heapValue5?.val === 300, 'Heap의 값이 정확해야 함');
console.log('  ✓ PASS');

// Test 6: 다중 Store/Load - 여러 글로벌 변수
console.log('\n[Test 6] 다중 Store/Load - 여러 글로벌 변수');
const vm6 = new VM();
vm6.execute([
  { type: 'const', value: 10 },
  { type: 'store', name: 'a' },
  { type: 'const', value: 20 },
  { type: 'store', name: 'b' },
  { type: 'const', value: 30 },
  { type: 'store', name: 'c' },
  { type: 'load', name: 'a' },
  { type: 'load', name: 'b' },
  { type: 'load', name: 'c' }
]);

const ptrA = vm6.getGlobal('a');
const ptrB = vm6.getGlobal('b');
const ptrC = vm6.getGlobal('c');

console.log(`  globals['a'] = ${ptrA} (val: ${vm6.getHeapValue(ptrA!)?.val})`);
console.log(`  globals['b'] = ${ptrB} (val: ${vm6.getHeapValue(ptrB!)?.val})`);
console.log(`  globals['c'] = ${ptrC} (val: ${vm6.getHeapValue(ptrC!)?.val})`);

console.assert(vm6.getHeapValue(ptrA!)?.val === 10, 'a 값이 정확해야 함');
console.assert(vm6.getHeapValue(ptrB!)?.val === 20, 'b 값이 정확해야 함');
console.assert(vm6.getHeapValue(ptrC!)?.val === 30, 'c 값이 정확해야 함');
console.log('  ✓ PASS');

// Test 7: RefCount 추적 - 여러 Load
console.log('\n[Test 7] RefCount 추적 - 여러 Load 시에도 변화 없음');
const vm7 = new VM();
vm7.execute([
  { type: 'const', value: 999 },
  { type: 'store', name: 'data' }
]);

const ptrData = vm7.getGlobal('data')!;
const initialRefCount = vm7.getHeapRefCount(ptrData);
console.log(`  Initial refCount: ${initialRefCount}`);

// 여러 번 Load
vm7.execute([
  { type: 'load', name: 'data' },
  { type: 'load', name: 'data' },
  { type: 'load', name: 'data' }
]);

const finalRefCount = vm7.getHeapRefCount(ptrData);
console.log(`  Final refCount: ${finalRefCount}`);
console.assert(
  finalRefCount === initialRefCount,
  'Load는 RefCount를 변경하면 안 됨'
);
console.log('  ✓ PASS');

