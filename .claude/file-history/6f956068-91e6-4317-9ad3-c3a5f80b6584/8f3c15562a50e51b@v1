/**
 * 제3장(v4.0~v4.5) 통합 중간고사: 보안 통신 모듈
 * "모듈화의 초석" - 설계적 판단의 검증
 *
 * 시험 항목:
 * 1. [v4.4] 모듈 정의 및 캡슐화
 * 2. [v4.1] 소유권 유지
 * 3. [v4.2] 불변 참조 사용
 * 4. [v4.3] 슬라이스를 통한 부분 참조
 * 5. [v4.5] 외부 크레이트 시뮬레이션
 */

import { run } from "../src/index";

describe("제3장 통합 중간고사: 보안 통신 모듈", () => {
  const output = (code: string) => run(code).join("");

  describe("설계 원칙 검증", () => {
    test("모듈 정의 및 pub 키워드 사용", () => {
      expect(
        output(`
        mod security_unit {
          pub fn validate_admin(msg: &str) -> bool {
            if msg.len() >= 5 {
              let first_five = slice(msg, 0, 5);
              first_five == "ADMIN"
            } else {
              false
            }
          }
        }
        let message = "ADMIN_MESSAGE";
        let result = security_unit::validate_admin(message);
        if result {
          println("validated");
        }
      `)
      ).toContain("validated");
    });

    test("&str 매개변수로 다양한 문자열 수용", () => {
      expect(
        output(`
        mod security_unit {
          pub fn validate_length(msg: &str) -> bool {
            msg.len() > 0
          }
        }
        let message = "test";
        let result = security_unit::validate_length(message);
        println(result);
      `)
      ).toContain("true");
    });

    test("소유권 유지: 함수 호출 후 재사용 가능", () => {
      expect(
        output(`
        mod security_unit {
          pub fn validate(msg: &str) -> bool {
            msg.len() > 0
          }
        }
        let message = "ADMIN_MESSAGE";
        let _ = security_unit::validate(message);
        println(message);
      `)
      ).toContain("ADMIN_MESSAGE");
    });

    test("슬라이스를 사용한 ADMIN 확인", () => {
      expect(
        output(`
        mod security_unit {
          pub fn validate_admin(msg: &str) -> bool {
            if msg.len() >= 5 {
              let first_five = slice(msg, 0, 5);
              first_five == "ADMIN"
            } else {
              false
            }
          }
        }
        let msg1 = "ADMIN_MESSAGE";
        let result1 = security_unit::validate_admin(msg1);
        println(result1);
      `)
      ).toContain("true");
    });

    test("ADMIN이 아닌 메시지는 false 반환", () => {
      expect(
        output(`
        mod security_unit {
          pub fn validate_admin(msg: &str) -> bool {
            if msg.len() >= 5 {
              let first_five = slice(msg, 0, 5);
              first_five == "ADMIN"
            } else {
              false
            }
          }
        }
        let msg2 = "USER_MESSAGE";
        let result2 = security_unit::validate_admin(msg2);
        println(result2);
      `)
      ).toContain("false");
    });
  });

  describe("외부 크레이트 시뮬레이션 (v4.5)", () => {
    test("보안 토큰 생성 (난수 시뮬레이션)", () => {
      expect(
        output(`
        mod security_unit {
          pub fn generate_token(seed: i32) -> i32 {
            (seed * 7 + 13) % 101
          }
        }
        let token = security_unit::generate_token(42);
        println(token);
      `)
      ).toContain("7");
    });

    test("토큰 기반 보안 수준 계산", () => {
      expect(
        output(`
        mod security_unit {
          pub fn generate_token(seed: i32) -> i32 {
            (seed * 7 + 13) % 101
          }
          fn calculate_security_level(token: i32) -> i32 {
            token / 10
          }
          pub fn check_level(seed: i32) -> bool {
            let token = generate_token(seed);
            let level = calculate_security_level(token);
            level > 5
          }
        }
        let is_secure = security_unit::check_level(80);
        println(is_secure);
      `)
      ).toContain("true");
    });
  });

  describe("종합 검증 (모든 원칙 통합)", () => {
    test("ADMIN 확인 + 토큰 검증", () => {
      expect(
        output(`
        mod security_unit {
          pub fn validate_admin(msg: &str) -> bool {
            if msg.len() >= 5 {
              let first_five = slice(msg, 0, 5);
              first_five == "ADMIN"
            } else {
              false
            }
          }
          pub fn generate_token(seed: i32) -> i32 {
            (seed * 7 + 13) % 101
          }
          fn calculate_security_level(token: i32) -> i32 {
            token / 10
          }
          pub fn full_validation(msg: &str, seed: i32) -> bool {
            let is_admin = validate_admin(msg);
            let token = generate_token(seed);
            let level = calculate_security_level(token);
            is_admin && level > 5
          }
        }
        let message = "ADMIN_MESSAGE";
        let result = security_unit::full_validation(message, 80);
        if result {
          println("access_granted");
        } else {
          println("access_denied");
        }
      `)
      ).toContain("access_granted");
    });

    test("최종 검증: 기록 출력", () => {
      expect(
        output(`
        mod security_unit {
          pub fn validate_admin(msg: &str) -> bool {
            if msg.len() >= 5 {
              let first_five = slice(msg, 0, 5);
              first_five == "ADMIN"
            } else {
              false
            }
          }
        }
        let message = "ADMIN_MESSAGE";
        let _ = security_unit::validate_admin(message);
        println("저장 필수 너는 기록이 증명이다 gogs");
      `)
      ).toContain("저장 필수 너는 기록이 증명이다 gogs");
    });
  });

  describe("메모리 안전성 검증 (v4.2)", () => {
    test("불변 참조는 다중 사용 가능", () => {
      expect(
        output(`
        mod security_unit {
          pub fn check1(msg: &str) -> bool {
            msg.len() > 0
          }
          pub fn check2(msg: &str) -> bool {
            msg.len() < 100
          }
        }
        let msg = "test";
        let r1 = security_unit::check1(msg);
        let r2 = security_unit::check2(msg);
        if r1 && r2 {
          println("both_valid");
        }
      `)
      ).toContain("both_valid");
    });

    test("참조는 소유권을 변경하지 않음", () => {
      expect(
        output(`
        mod security_unit {
          pub fn validate(msg: &str) -> bool {
            msg.len() > 0
          }
        }
        let original = "ADMIN_TEST";
        let check = security_unit::validate(original);
        println(original);
      `)
      ).toContain("ADMIN_TEST");
    });
  });

  describe("설계 판단 검증", () => {
    test("private 함수는 모듈 외부에서 접근 불가", () => {
      expect(
        output(`
        mod security_unit {
          fn private_function() {
            println("private");
          }
          pub fn public_function() {
            private_function();
            println("public");
          }
        }
        security_unit::public_function();
      `)
      ).toContain("public");
    });

    test("슬라이스는 길이 검사 후 사용", () => {
      expect(
        output(`
        mod security_unit {
          pub fn safe_slice(msg: &str) -> String {
            if msg.len() >= 5 {
              slice(msg, 0, 5)
            } else {
              "SHORT"
            }
          }
        }
        let result = security_unit::safe_slice("HI");
        println(result);
      `)
      ).toContain("SHORT");
    });

    test("모듈은 데이터와 행동을 함께 캡슐화", () => {
      expect(
        output(`
        mod audit {
          fn log_entry() {
            println("logged");
          }
          pub fn record(msg: &str) -> bool {
            log_entry();
            msg.len() > 0
          }
        }
        let result = audit::record("test");
        println(result);
      `)
      ).toContain("logged");
    });
  });
});
