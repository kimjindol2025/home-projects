// v7.0 확장: 수명 생략 규칙(Lifetime Elision) Step 2
// 철학: "보이지 않는 규칙: 컴파일러가 자동 추론하는 수명"
// 목표: 명시적 수명 표기 제거, 자동 추론 패턴 이해

// ============================================================
// [Step 2 패턴 1] 단일 입력 참조 - 완전 생략
// ============================================================

// 명시 형태 (생략 가능):
// fn first_explicit<'a>(x: &'a str) -> &'a str { x }

// 생략 형태 (권장):
fn first(x: &str) -> &str {
    x
}

// 사용 예:
fn demo_pattern_1() {
    println!("\n=== Pattern 1: 단일 입력 생략 ===");

    let text = "Hello, World!";
    let result = first(text);
    println!("입력: {}", text);
    println!("결과: {}", result);
    println!("추론: 입력 하나 → 수명 자동 추론");
}

// ============================================================
// [Step 2 패턴 2] 다중 입력 + 소유 반환 (생략)
// ============================================================

// 입력: 두 개의 &str
// 출력: 새로운 String (소유)
// → 반환이 소유 데이터이므로 수명 필수 없음

fn concatenate(x: &str, y: &str) -> String {
    format!("{} {}", x, y)
}

fn demo_pattern_2() {
    println!("\n=== Pattern 2: 소유 반환은 수명 불필요 ===");

    let greeting = "Hello";
    let name = "Gogs";
    let result = concatenate(greeting, name);
    println!("입력: '{}', '{}'", greeting, name);
    println!("반환: {} (String 소유)", result);
    println!("추론: 반환이 String이므로 수명 명시 불필요");
}

// ============================================================
// [Step 2 패턴 3] 다중 입력 + 참조 반환 (명시 필수)
// ============================================================

// 입력: 두 개의 &str, 조건
// 출력: 어느 것을 반환할지 명시 필수!

fn pick_longer<'a>(x: &'a str, y: &'a str) -> &'a str {
    if x.len() > y.len() { x } else { y }
}

fn demo_pattern_3() {
    println!("\n=== Pattern 3: 다중 입력 선택 (명시 필수) ===");

    let short = "Hi";
    let long = "Welcome";
    let result = pick_longer(short, long);
    println!("입력: '{}' ({}바이트), '{}' ({}바이트)",
             short, short.len(), long, long.len());
    println!("반환: {} (더 긴 것)", result);
    println!("명시 필요: <'a> - 어느 것을 반환할지 분명히");
}

// ============================================================
// [Step 2 패턴 4] 메서드 - &self로 자동 추론
// ============================================================

struct TextExtractor<'a> {
    content: &'a str,
}

impl<'a> TextExtractor<'a> {
    // 명시 불필요 (규칙 3):
    // &self의 수명 → 반환값의 수명
    fn get_content(&self) -> &str {
        self.content
    }

    fn get_trimmed(&self) -> &str {
        self.content.trim()
    }

    fn get_uppercase_ref(&self) -> &str {
        self.content
    }

    fn count_words(&self) -> usize {
        self.content.split_whitespace().count()
    }
}

fn demo_pattern_4() {
    println!("\n=== Pattern 4: 메서드 &self 추론 ===");

    let text = "  Hello World  ";
    let extractor = TextExtractor { content: text };

    println!("원본: '{}' ({}바이트)", text, text.len());
    println!("콘텐츠: '{}'", extractor.get_content());
    println!("정돈됨: '{}'", extractor.get_trimmed());
    println!("단어 수: {}", extractor.count_words());
    println!("추론: &self → 자동으로 메서드 반환값 수명");
}

// ============================================================
// [Step 2 패턴 5] 메서드 + 추가 입력 (명시 필수)
// ============================================================

struct SearchEngine<'a> {
    index: &'a str,
}

impl<'a> SearchEngine<'a> {
    // &self와 other 둘 다 입력
    // 어느 것을 기준으로 반환할지 명시 필수!

    fn search_in_index(&self, _query: &str) -> &'a str {
        // index의 수명('a)으로 반환
        self.index
    }

    fn find_first<'b>(&self, text: &'b str) -> &'b str {
        // text의 수명('b)으로 반환
        text
    }
}

fn demo_pattern_5() {
    println!("\n=== Pattern 5: 메서드 + 추가 입력 (명시) ===");

    let index = "database:memory:optimization";
    let query = "memory";
    let engine = SearchEngine { index };

    let result1 = engine.search_in_index(query);
    println!("검색: '{}'", result1);
    println!("수명: index의 'a로 반환");

    let text = "external:data:source";
    let result2 = engine.find_first(text);
    println!("검색: '{}'", result2);
    println!("수명: text의 'b로 반환");
}

// ============================================================
// [Step 2 개념 1] 규칙 1: 각 입력은 자신의 수명
// ============================================================

fn rule_1_example(x: &str, y: &str) -> String {
    println!("\n[규칙 1] 각 입력 참조는 자신의 수명을 받는다");
    println!("  x: {} (고유한 수명)", x);
    println!("  y: {} (고유한 수명)", y);
    println!("  반환: String (소유, 수명 없음)");
    format!("{} + {}", x, y)
}

fn demonstrate_rule_1() {
    println!("\n=== 규칙 1: 각 입력은 자신의 수명 ===");

    let s1 = "first";
    let s2 = "second";
    let result = rule_1_example(s1, s2);
    println!("결과: {}", result);
}

// ============================================================
// [Step 2 개념 2] 규칙 2: 단일 입력 반환 == 그 입력 수명
// ============================================================

fn get_first_word(text: &str) -> &str {
    text.split_whitespace().next().unwrap_or("")
}

fn demonstrate_rule_2() {
    println!("\n=== 규칙 2: 단일 입력 반환 → 그 수명 ===");

    let sentence = "Rust is beautiful";
    let first_word = get_first_word(sentence);
    println!("문장: '{}'", sentence);
    println!("첫 단어: '{}'", first_word);
    println!("추론: 반환값은 자동으로 input의 수명");
}

// ============================================================
// [Step 2 개념 3] 규칙 3: 메서드 &self == 반환 수명
// ============================================================

struct Document {
    title: String,
}

impl Document {
    // &self의 수명 → 반환값의 수명
    // (실제로는 &str 때문에 조금 다르지만, 원칙은 동일)
    fn get_title(&self) -> &str {
        &self.title
    }
}

fn demonstrate_rule_3() {
    println!("\n=== 규칙 3: 메서드 &self → 반환 수명 ===");

    let doc = Document {
        title: "Lifetimes in Rust".to_string(),
    };

    let title = doc.get_title();
    println!("문서 제목: '{}'", title);
    println!("추론: &self의 수명 → 반환값의 수명");
}

