// ============================================================
// [메인] v5.0 데모: 구조체의 정의와 사용
// ============================================================

fn main() {
  println("=== v5.0: Defining Structs (구조체의 정의) ===");
  println("");

  // [Stage 1] 정의: 구조체 틀 정의
  println("--- Stage 1: 구조체 정의 ---");
  println("struct GogsRecord {");
  println("  id: i32,");
  println("  subject: String,");
  println("  content: String,");
  println("  is_verified: bool,");
  println("  version: f32,");
  println("}");
  println("");

  // [Stage 2] 인스턴스화: 실제 데이터 생성
  println("--- Stage 2: 인스턴스 생성 ---");
  let record = gogs_record_new(20260222, "중간고사", "완료", true, 5.0);
  println("let record = GogsRecord { ... };");
  println("생성됨: ");
  println(record);
  println("");

  // [Stage 3] 접근: 점(.) 표기법으로 필드 접근
  println("--- Stage 3: 필드 접근 ---");
  let id = gogs_record_get_id(record);
  println("record.id = ");
  println(id);

  let subject = gogs_record_get_subject(record);
  println("record.subject = ");
  println(subject);

  let version = gogs_record_get_version(record);
  println("record.version = ");
  println(version);
  println("");

  // [Stage 4] 수정: 필드 값 변경
  println("--- Stage 4: 필드 수정 ---");
  println("mut record 선언 시 필드 수정 가능:");
  let modified_record = record_set_version(record, 5.1);
  println("record.version을 5.1로 수정");
  println("");

  // [Stage 5] 소유권: 구조체의 생명주기
  println("--- Stage 5: 소유권과 생명주기 ---");
  println("구조체는 내부 데이터(String 등)의 소유권을 가짐");
  println("구조체가 scope를 벗어나면 내부 데이터도 해제됨");
  println("");

  // ========================================
  // 다양한 구조체 패턴
  // ========================================

  println("--- 패턴: 다양한 구조체 타입 ---");
  println("");

  // 패턴 1: User 구조체
  println("[패턴 1] User 구조체");
  let user = user_new("Bob", 30, "bob@example.com");
  println("User { name, age, email }");
  println("이름: ");
  println(user_get_name(user));
  println("");

  // 패턴 2: Server 구조체
  println("[패턴 2] Server 구조체");
  let server = create_server();
  println("Server { port, status, uptime }");
  println("포트: ");
  println(server_get_port());
  println("");

  // 패턴 3: Project 구조체
  println("[패턴 3] Project 구조체");
  let project = create_project("FreeLang", 5.0, true, 1);
  println("Project { name, version, is_active, member_count }");
  println("프로젝트: ");
  println(project);
  println("");

  // ========================================
  // 타입 안전성의 중요성
  // ========================================

  println("--- 타입 안전성 ---");
  println("v5.0: 구조체로 타입 안전성 확보");
  println("User, Server, Project는 서로 다른 타입");
  println("혼동이 줄어들고 의도가 명확해짐");
  println("");

  // ========================================
  // 구조체의 의의
  // ========================================

  println("--- v5.0의 의의 ---");
  println("");
  println("[설계도]");
  println("구조체는 메모리 레이아웃의 명확한 설계도");
  println("");
  println("[타입 안전]");
  println("String이나 i32 대신 User, Server 같은 자신만의 타입");
  println("");
  println("[도메인 모델링]");
  println("현실의 개체를 코드로 투영");
  println("User = 사용자라는 개념");
  println("Server = 서버라는 개념");
  println("");

  // 최종 메시지
  println("=== v5.0 완성 ===");
  println("");
  println("지금까지는 형체 없는 논리 덩어리였다면,");
  println("이제 당신의 시스템은 명확한 데이터 구조를 가진");
  println("'실체'가 되었습니다.");
  println("");
  println("저장 필수 너는 기록이 증명이다 gogs");
}
