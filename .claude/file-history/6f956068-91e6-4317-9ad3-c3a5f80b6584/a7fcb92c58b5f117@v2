// [Step 3 개념 1] 논리적 불변성 vs 물리적 가변성
// ============================================================

fn demonstrate_logical_immutability() {
    println!("\n=== 개념 1: 논리적 불변성 vs 물리적 가변성 ===");

    println!(\"관점 1: 호출하는 쪽\");
    println!(\"  let counter = LogCounter::new();\");
    println!(\"  counter.log(\\\"message\\\");  // 불변으로 호출\");
    println!(\"  → \\\"이 객체는 안전합니다\\\"\");
    println!(\"\");

    println!(\"관점 2: 구현하는 쪽\");
    println!(\"  fn log(&self, msg: &str) {{\");
    println!(\"      *self.count.borrow_mut() += 1;  // 내부 수정\");
    println!(\"  }}\");
    println!(\"  → \\\"내부에서 몰래 상태 업데이트\\\"\");
    println!(\"\");

    println!(\"조화:\");
    println!(\"  - 외부: 불변 인터페이스\");
    println!(\"  - 내부: 가변 구현\");
    println!(\"  - 둘 다 안전\");
    println!(\"\");

    println!(\"활용 사례:\");
    println!(\"  - 카운터와 통계\");
    println!(\"  - 로깅과 추적\");
    println!(\"  - 캐시와 최적화\");
    println!(\"  - Mock 객체\");
}

// ============================================================
// [Step 3 개념 2] RefCell vs 일반 Rust
// ============================================================

fn explain_refcell_vs_rust() {
    println!("\n=== 개념 2: RefCell vs 일반 Rust ===");

    println!(\"일반 Rust의 방식:\");
    println!(\"  struct MyStruct {{\");
    println!(\"      data: Vec<String>,\");
    println!(\"  }}\");
    println!(\"  fn modify(&mut self) {  // &mut self 필요\");
    println!(\"      self.data.push(String::new());\");
    println!(\"  }}\");
    println!(\"\");

    println!(\"RefCell의 방식:\");
    println!(\"  struct MyStruct {{\");
    println!(\"      data: RefCell<Vec<String>>,\");
    println!(\"  }}\");
    println!(\"  fn modify(&self) {  // &self만 사용\");
    println!(\"      self.data.borrow_mut().push(String::new());\");
    println!(\"  }}\");
    println!(\"\");

    println!(\"차이점:\");
    println!(\"  일반 Rust:\");
    println!(\"    - 컴파일 타임 검사\");
    println!(\"    - &mut self 필요\");
    println!(\"    - 안전 보증: 컴파일러\");
    println!(\"    - 성능: 최적\");
    println!(\"\");

    println!(\"  RefCell:\");
    println!(\"    - 런타임 검사\");
    println!(\"    - &self만 필요\");
    println!(\"    - 안전 보증: panic!\");
    println!(\"    - 성능: 약간의 오버헤드\");
    println!(\"\");

    println!(\"선택:\");
    println!(\"  가능하면: 일반 Rust 사용\");
    println!(\"  필요할 때만: RefCell 사용\");
}

