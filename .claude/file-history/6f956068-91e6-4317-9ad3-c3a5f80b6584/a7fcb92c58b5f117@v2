// [Step 3 개념 3] 메모리 모델
// ============================================================

fn explain_refcell_memory() {
    println!("\n=== 개념 3: RefCell의 메모리 모델 ===");

    println!(\"RefCell 내부 구조:\");
    println!(\"  ┌──────────────────────┐\");
    println!(\"  │ RefCell<T>           │\");
    println!(\"  ├──────────────────────┤\");
    println!(\"  │ borrow_flag: usize   │\");
    println!(\"  │   0: 미사용           │\");
    println!(\"  │   n: n개 불변 빌림   │\");
    println!(\"  │   -1: 1개 가변 빌림  │\");
    println!(\"  │                      │\");
    println!(\"  │ value: UnsafeCell<T> │\");
    println!(\"  │   실제 데이터        │\");
    println!(\"  └──────────────────────┘\");
    println!(\"\");

    println!(\"UnsafeCell:\");
    println!(\"  - Rust의 기본 원시 타입\");
    println!(\"  - unsafe 코드로 내부 변경 가능\");
    println!(\"  - 메모리 안전성 책임: 사용자\");
    println!(\"\");

    println!(\"borrow_flag의 역할:\");
    println!(\"  - RefCell이 메모리 안전성 보장\");
    println!(\"  - 규칙 위반 시 panic!\");
    println!(\"  - 런타임 오버헤드\");
    println!(\"\");

    println!(\"성능:\");
    println!(\"  - borrow_flag 검사: 매우 빠름 (몇 CPU 사이클)\");
    println!(\"  - UnsafeCell 접근: 일반 데이터 접근과 동일\");
    println!(\"  - 전체: 약간의 오버헤드 존재\");
}

