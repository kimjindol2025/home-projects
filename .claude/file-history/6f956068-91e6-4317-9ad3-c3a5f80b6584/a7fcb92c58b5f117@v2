// ============================================================
// [Step 3 패턴 1] 기본 RefCell<T> 사용
// ============================================================

fn demo_pattern_1() {
    println!("\n=== Pattern 1: 기본 RefCell<T> 사용 ===");

    println!("문제: 불변 참조에서 값을 바꾸고 싶은데?\");
    println!(\"\");

    println!(\"일반적인 Rust:\");
    let value = 5;
    println!(\"  let value = 5;\");
    println!(\"  value = 10;  // 컴파일 에러!\");
    println!(\"\");

    println!(\"RefCell<T>로 해결:\");
    println!(\"  let cell = RefCell::new(5);\");
    println!(\"  cell.borrow_mut()* = 10;  // OK!\");
    println!(\"\");

    println!(\"borrow() vs borrow_mut():\");
    println!(\"  borrow():      &T (불변 읽기)\");
    println!(\"  borrow_mut():  &mut T (가변 쓰기)\");
    println!(\"\");

    println!(\"런타임 검사:\");
    println!(\"  - 불변 빌림: 여러 개 동시 가능\");
    println!(\"  - 가변 빌림: 한 개만 가능\");
    println!(\"  - 위반: panic! 발생\");
    println!(\"\");

    println!(\"추론: RefCell은 컴파일 검사를 런타임으로 미룸\");
}

// ============================================================
// [Step 3 패턴 2] 내부 가변성 (Mock 객체)
// ============================================================

fn demo_pattern_2() {
    println!("\n=== Pattern 2: 내부 가변성 (Mock 객체) ===");

    println!(\"트레이트 구조상 문제:\");
    println!(\"\");
    println!(\"trait Messenger {{\");
    println!(\"    fn send(&self, msg: &str);  // &self만 가능\");
    println!(\"  }}\");
    println!(\"\");

    println!(\"구현하려면:\");
    println!(\"  struct GogsTracker {{\");
    println!(\"      sent: RefCell<Vec<String>>,  // RefCell로 해결\");
    println!(\"  }}\");
    println!(\"\");
    println!(\"  impl Messenger for GogsTracker {{\");
    println!(\"      fn send(&self, msg: &str) {{\");
    println!(\"          self.sent.borrow_mut().push(msg.to_string());\");
    println!(\"      }}\");
    println!(\"  }}\");
    println!(\"\");

    println!(\"의미:\");
    println!(\"  - &self (불변 참조)로 메서드 호출\");
    println!(\"  - 내부는 RefCell로 데이터 수정\");
    println!(\"  - 논리적으로는 불변 (메시지 전송)  \");
    println!(\"  - 물리적으로는 가변 (기록 저장)\");
    println!(\"\");

    println!(\"활용:\");
    println!(\"  - Mock 객체 테스트\");
    println!(\"  - 호출 기록 추적\");
    println!(\"  - 내부 상태 업데이트\");
    println!(\"\");

    println!(\"추론: RefCell은 트레이트 구조상 제약을 우회\");
}

// ============================================================
// [Step 3 패턴 3] Rc<RefCell<T>> 조합
// ============================================================

fn demo_pattern_3() {
    println!("\n=== Pattern 3: Rc<RefCell<T>> 조합 ===");

    println!(\"문제: 여러 곳에서 소유 + 내부 수정?\");
    println!(\"\");

    println!(\"v9.0 Box<T>:\");
    println!(\"  let boxed = Box::new(5);\");
    println!(\"  let a = boxed;  // 소유권 이동\");
    println!(\"  // a만 사용 가능\");
    println!(\"\");

    println!(\"v9.1 Rc<T>:\");
    println!(\"  let rc = Rc::new(5);\");
    println!(\"  let a = Rc::clone(&rc);\");
    println!(\"  let b = Rc::clone(&rc);\");
    println!(\"  // a, b 모두 소유하지만 불변 빌림만 가능\");
    println!(\"\");

    println!(\"v9.2 Rc<RefCell<T>>:\");
    println!(\"  let shared = Rc::new(RefCell::new(vec![1, 2, 3]));\");
    println!(\"  let a = Rc::clone(&shared);\");
    println!(\"  a.borrow_mut().push(4);  // 수정 가능!\");
    println!(\"\");

    println!(\"특징:\");
    println!(\"  - 다중 소유권 (Rc)\");
    println!(\"  - 내부 가변성 (RefCell)\");
    println!(\"  - 가장 강력한 조합\");
    println!(\"  - 성능 오버헤드 존재\");
    println!(\"\");

    println!(\"추론: Rc<RefCell<T>>는 복잡한 공유 구조의 핵심\");
}

// ============================================================
// [Step 3 패턴 4] 캐싱과 RefCell
// ============================================================

fn demo_pattern_4() {
    println!("\n=== Pattern 4: 캐싱과 RefCell ===");

    println!(\"상황: 계산 결과를 캐시하고 싶은데 &self만 가능?\");
    println!(\"\");

    println!(\"struct Calculator {{\");
    println!(\"    cache: RefCell<Option<i32>>,\");
    println!(\"  }}\");
    println!(\"\");

    println!(\"fn compute(&self, x: i32) -> i32 {{\");
    println!(\"    // &self이지만 캐시에 쓰기 가능\");
    println!(\"    if let Some(cached) = *self.cache.borrow() {{\");
    println!(\"        return cached;\");
    println!(\"    }}\");
    println!(\"    let result = x * 2;\");
    println!(\"    *self.cache.borrow_mut() = Some(result);\");
    println!(\"    result\");
    println!(\"  }}\");
    println!(\"\");

    println!(\"논리적 불변성:\");
    println!(\"  - 같은 입력 → 같은 결과\");
    println!(\"  - 호출하는 쪽은 불변으로 봄\");
    println!(\"\");

    println!(\"물리적 가변성:\");
    println!(\"  - 캐시 상태가 변함\");
    println!(\"  - 첫 호출 vs 재호출: 다른 경로\");
    println!(\"\");

    println!(\"활용:\");
    println!(\"  - Lazy initialization\");
    println!(\"  - 성능 최적화\");
    println!(\"  - Memoization\");
    println!(\"\");

    println!(\"추론: RefCell은 성능과 안전성의 타협점\");
}

// ============================================================
// [Step 3 패턴 5] borrow 위반과 panic
// ============================================================

fn demo_pattern_5() {
    println!("\n=== Pattern 5: 빌림 규칙과 panic ===");

    println!(\"RefCell의 안전성:\");
    println!(\"\");

    println!(\"컴파일 타임:\");
    println!(\"  - Rust 컴파일러: 빌림 규칙 검사 생략\");
    println!(\"  - 문법 에러 없음\");
    println!(\"\");

    println!(\"런타임:\");
    println!(\"  - borrow_flag로 규칙 추적\");
    println!(\"  - 위반 시 panic!\");
    println!(\"\");

    println!(\"예제:\");
    println!(\"  let cell = RefCell::new(5);\");
    println!(\"  let a = cell.borrow();      // OK\");
    println!(\"  let b = cell.borrow();      // OK (둘 다 불변)\");
    println!(\"  let c = cell.borrow_mut();  // panic! (가변과 불변 동시)\");
    println!(\"\");

    println!(\"규칙:\");
    println!(\"  - 불변 빌림: 여러 개 가능\");
    println!(\"  - 가변 빌림: 1개만 가능\");
    println!(\"  - 불변 + 가변: 불가능\");
    println!(\"\");

    println!(\"개발자의 책임:\");
    println!(\"  - 컴파일러가 잡아주지 않음\");
    println!(\"  - 코드 리뷰 중요\");
    println!(\"  - 테스트로 검증\");
    println!(\"\");

    println!(\"추론: RefCell은 신뢰에 기초한 설계\");
}

