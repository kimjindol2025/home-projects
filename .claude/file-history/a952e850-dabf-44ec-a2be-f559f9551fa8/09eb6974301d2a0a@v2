#!/usr/bin/env node

/**
 * FreeLang v4 Blog API - 메인 서버
 * 실전 프로덕션 애플리케이션
 */

import { HTTP } from 'freelang-v4';
import initializeDatabase from './models';
import setupRoutes from './routes';

async function main() {
  console.log('🚀 FreeLang v4 Blog API 시작...');

  // 1. 데이터베이스 초기화
  console.log('📦 ORM 초기화...');
  const orm = initializeDatabase();
  console.log('✅ 데이터베이스 준비 완료');

  // 2. HTTP 서버 생성
  console.log('🔧 HTTP 서버 생성...');
  const server = HTTP.create({ port: 3000 });
  console.log('✅ 서버 생성 완료 (포트: 3000)');

  // 3. 라우트 설정
  console.log('📍 라우트 설정 중...');
  setupRoutes(server, orm);
  console.log('✅ 라우트 설정 완료');

  // 4. 서버 시작
  console.log('🌍 서버 시작 중...');
  try {
    await server.serve();
    console.log('✅ 서버 실행 중 → http://localhost:3000');
    console.log('📚 API 문서:');
    console.log('  POST   /auth/register      - 회원가입');
    console.log('  POST   /auth/login         - 로그인');
    console.log('  POST   /posts              - 포스트 생성');
    console.log('  GET    /posts              - 포스트 목록');
    console.log('  GET    /posts/:id          - 포스트 조회');
    console.log('  PUT    /posts/:id          - 포스트 수정');
    console.log('  DELETE /posts/:id          - 포스트 삭제');
    console.log('  POST   /posts/:id/comments - 댓글 생성');
    console.log('  GET    /health             - 헬스 체크');
    console.log('  GET    /stats              - 통계');
  } catch (error) {
    console.error('❌ 서버 실행 실패:', error);
    process.exit(1);
  }
}

main();
