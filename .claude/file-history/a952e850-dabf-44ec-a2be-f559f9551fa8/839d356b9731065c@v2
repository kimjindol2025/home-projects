## 완전한 예제

```typescript
import { HTTP, Security, JSON as FlJSON } from 'freelang-v4';

const server = HTTP.create({ port: 3000 });

// GET /api/hello
server.get('/api/hello', async (req, res) => {
  return HTTP.response()
    .json({ message: 'Hello, World!' })
    .build();
});

// POST /api/login
server.post('/api/login', async (req, res) => {
  const body = req.body;
  const token = Security.createJWT(
    { userId: body.userId, role: 'user' },
    'secret-key',
    3600
  );

  return HTTP.response()
    .status(200)
    .json({ token: token.token })
    .build();
});

// GET /api/users/:id
server.get('/api/users/:id', async (req, res) => {
  const userId = req.params.id;
  const user = { id: userId, name: 'Alice' };

  return HTTP.response()
    .json(user)
    .build();
});

// GET /api/search?q=test
server.get('/api/search', async (req, res) => {
  const query = req.queryParams.q;
  const results = query ? [{ result: query }] : [];

  return HTTP.response()
    .json({ results })
    .build();
});

// 에러 핸들링
server.get('/api/error', async (req, res) => {
  return HTTP.internalError('Something went wrong');
});

// 통계
server.get('/stats', async (req, res) => {
  const report = server.getPerformanceReport();
  return HTTP.response()
    .json(report)
    .build();
});

// 서버 시작
await server.serve();
```

