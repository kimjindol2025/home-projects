describe("JSON Functions", () => {
  test("T33: json_parse — 기본 타입 변환", () => {
    const r = json_parse(V.str('{"name":"Alice","age":30,"active":true}'));
    expect(r.tag).toBe("ok");
    const val = (r as any).val;
    expect(val.tag).toBe("struct");
    expect(val.fields.get("name")).toEqual(V.str("Alice"));
    expect(val.fields.get("age")).toEqual(V.i32(30));
    expect(val.fields.get("active")).toEqual(V.bool(true));
  });

  test("T34: json_parse — 배열", () => {
    const r = json_parse(V.str('[1, 2, 3]'));
    expect(r.tag).toBe("ok");
    const arr = (r as any).val;
    expect(arr.tag).toBe("arr");
    expect(arr.elements).toHaveLength(3);
  });

  test("T35: json_parse — 오류 처리", () => {
    const r = json_parse(V.str("{invalid json}"));
    expect(r.tag).toBe("err");
  });

  test("T36: json_stringify — struct → JSON", () => {
    const v = V.struct({ name: V.str("Bob"), score: V.i32(100) });
    const r = json_stringify(v);
    expect(r.tag).toBe("str");
    const parsed = globalThis.JSON.parse((r as any).val);
    expect((parsed as any).name).toBe("Bob");
    expect((parsed as any).score).toBe(100);
  });

  test("T37: json_stringify — 배열", () => {
    const v = V.arr([V.i32(1), V.str("two"), V.bool(true)]);
    const r = json_stringify(v);
    expect((r as any).val).toBe('[1,"two",true]');
  });

  test("T38: json_parse → json_stringify 라운드트립", () => {
    const original = '{"x":1,"y":2}';
    const parsed   = json_parse(V.str(original));
    const back     = json_stringify((parsed as any).val);
    expect(globalThis.JSON.parse((back as any).val)).toEqual(globalThis.JSON.parse(original));
  });

  test("T39: json_validate — object 스키마 (required 키 확인)", () => {
    const schema = V.str(globalThis.JSON.stringify({
      type: "object",
      required: ["name", "age"],
    }));
    expect(json_validate(V.str('{"name":"Alice","age":30}'), schema)).toEqual(V.bool(true));
    expect(json_validate(V.str('{"name":"Alice"}'), schema)).toEqual(V.bool(false)); // age 없음
  });

  test("T40: json_validate — 숫자 범위 검증", () => {
    const schema = V.str(globalThis.JSON.stringify({ type: "number", minimum: 0, maximum: 100 }));
    expect(json_validate(V.str("50"), schema)).toEqual(V.bool(true));
    expect(json_validate(V.str("150"), schema)).toEqual(V.bool(false));
  });

  test("T41: json_pretty — 들여쓰기", () => {
    const v = V.struct({ a: V.i32(1) });
    const r = json_pretty(v, V.i32(2));
    expect((r as any).val).toContain("\n");
    expect((r as any).val).toContain("  ");
  });

  test("T42: json_get — 점 경로 접근", () => {
    const v = json_parse(V.str('{"user":{"name":"Alice","scores":[10,20,30]}}'));
    const struct = (v as any).val;
    const nameResult = json_get(struct, V.str("user.name"));
    expect(nameResult.tag).toBe("some");
    expect((nameResult as any).val).toEqual(V.str("Alice"));
    const missing = json_get(struct, V.str("user.email"));
    expect(missing.tag).toBe("none");
  });

  test("T43: json_merge — 두 struct 병합 (b 우선)", () => {
    const a = V.struct({ x: V.i32(1), y: V.i32(2) });
    const b = V.struct({ y: V.i32(99), z: V.i32(3) });
    const r = json_merge(a, b);
    expect(r.tag).toBe("ok");
    const merged = (r as any).val;
    expect(merged.fields.get("x")).toEqual(V.i32(1));
    expect(merged.fields.get("y")).toEqual(V.i32(99)); // b 우선
    expect(merged.fields.get("z")).toEqual(V.i32(3));
  });

  test("T44: json_merge — struct 아닌 타입 → err", () => {
    const r = json_merge(V.i32(1), V.str("oops"));
    expect(r.tag).toBe("err");
  });
});

