describe("Functional Programming", () => {
  const add1  = (v: Value): Value => V.i32((v as any).val + 1);
  const mul2  = (v: Value): Value => V.i32((v as any).val * 2);
  const str_v = (v: Value): Value => V.str(globalThis.String((v as any).val));

  test("T15: compose — 우→좌 합성 (mul2 → add1 순서)", () => {
    // compose(add1, mul2)(5) = add1(mul2(5)) = add1(10) = 11
    const fn = compose(add1, mul2);
    expect(fn(V.i32(5))).toEqual(V.i32(11));
  });

  test("T16: pipe — 좌→우 합성 (mul2 먼저)", () => {
    // pipe(mul2, add1)(5) = add1(mul2(5)) = 11
    const fn = pipe(mul2, add1);
    expect(fn(V.i32(5))).toEqual(V.i32(11));
  });

  test("T17: compose 3단계", () => {
    // compose(str_v, add1, mul2)(3) = str_v(add1(mul2(3))) = str_v(7) = "7"
    const fn = compose(str_v, add1, mul2);
    expect(fn(V.i32(3))).toEqual(V.str("7"));
  });

  test("T18: curry — 인자 하나씩 적용", () => {
    const add = (a: Value, b: Value): Value => V.i32((a as any).val + (b as any).val);
    const curried = curry(add, 2);
    const add5 = (curried(V.i32(5)) as unknown) as (...args: Value[]) => Value;
    expect(add5(V.i32(3))).toEqual(V.i32(8));
  });

  test("T19: memoize — 동일 인수 캐싱", () => {
    let callCount = 0;
    const expensive = (v: Value): Value => { callCount++; return V.i32((v as any).val * (v as any).val); };
    const memo = memoize(expensive);
    memo(V.i32(5));
    memo(V.i32(5));
    memo(V.i32(5));
    expect(callCount).toBe(1); // 최초 1회만 실행
    expect(memo(V.i32(6))).toEqual(V.i32(36));
    expect(callCount).toBe(2);
  });

  test("T20: memoize_tracked — 히트/미스 추적", () => {
    const { fn, hits, misses } = memoize_tracked((v) => V.i32((v as any).val + 1));
    fn(V.i32(1)); // miss
    fn(V.i32(1)); // hit
    fn(V.i32(2)); // miss
    expect(hits()).toBe(1);
    expect(misses()).toBe(2);
  });

  test("T21: partial — 부분 적용", () => {
    const add = (a: Value, b: Value, c: Value): Value =>
      V.i32((a as any).val + (b as any).val + (c as any).val);
    const add10 = partial(add, V.i32(10));
    expect(add10(V.i32(3), V.i32(2))).toEqual(V.i32(15));
  });

  test("T22: once — 최초 1회만 실행", () => {
    let n = 0;
    const fn = once(() => { n++; return V.i32(n); });
    expect(fn()).toEqual(V.i32(1));
    expect(fn()).toEqual(V.i32(1)); // 동일 결과
    expect(fn()).toEqual(V.i32(1));
    expect(n).toBe(1);
  });

  test("T23: flip — 첫 두 인수 순서 뒤집기", () => {
    const sub = (a: Value, b: Value): Value => V.i32((a as any).val - (b as any).val);
    const flipped = flip(sub);
    // flip(sub)(10, 3) = sub(3, 10) = -7
    expect(flipped(V.i32(10), V.i32(3))).toEqual(V.i32(-7));
  });

  test("T24: identity / constant", () => {
    expect(identity(V.i32(42))).toEqual(V.i32(42));
    const always5 = constant(V.i32(5));
    expect(always5(V.str("anything"))).toEqual(V.i32(5));
  });
});

