describe("Regex Functions", () => {
  test("T25: regex_test — 패턴 일치 여부", () => {
    expect(regex_test(V.str("hello@email.com"), V.str("^\\w+@\\w+\\.\\w+$"))).toEqual(V.bool(true));
    expect(regex_test(V.str("not-email"), V.str("^\\w+@\\w+\\.\\w+$"))).toEqual(V.bool(false));
  });

  test("T26: regex_match bool 모드 (g 플래그 없음)", () => {
    const r = regex_match(V.str("abc123"), V.str("\\d+"));
    expect(r).toEqual(V.bool(true));
  });

  test("T27: regex_match 전체 매치 모드 (g 플래그)", () => {
    const r = regex_match(V.str("abc 123 def 456"), V.str("\\d+"), V.str("g"));
    expect(r.tag).toBe("arr");
    const els = (r as any).elements;
    expect(els).toHaveLength(2);
    expect(els[0]).toEqual(V.str("123"));
    expect(els[1]).toEqual(V.str("456"));
  });

  test("T28: regex_split — 정규식 구분자", () => {
    const r = regex_split(V.str("one  two   three"), V.str("\\s+"));
    expect(r.tag).toBe("arr");
    expect((r as any).elements).toHaveLength(3);
  });

  test("T29: regex_replace — 첫 번째 치환", () => {
    const r = regex_replace(V.str("cat and cat"), V.str("cat"), V.str("dog"));
    expect(r).toEqual(V.str("dog and cat"));
  });

  test("T30: regex_replace 전체 치환 (g 플래그)", () => {
    const r = regex_replace(V.str("cat and cat"), V.str("cat"), V.str("dog"), V.str("g"));
    expect(r).toEqual(V.str("dog and dog"));
  });

  test("T31: regex_groups — 캡처 그룹", () => {
    const r = regex_groups(V.str("2025-12-25"), V.str("(\\d{4})-(\\d{2})-(\\d{2})"));
    expect(r.tag).toBe("some");
    const arr = (r as any).val;
    expect(arr.elements[0]).toEqual(V.str("2025"));
    expect(arr.elements[1]).toEqual(V.str("12"));
    expect(arr.elements[2]).toEqual(V.str("25"));
  });

  test("T32: regex_count + regex_valid", () => {
    expect(regex_count(V.str("aababab"), V.str("ab"))).toEqual(V.i32(3));
    expect(regex_valid(V.str("\\d+"))).toEqual(V.bool(true));
    expect(regex_valid(V.str("[invalid"))).toEqual(V.bool(false));
  });
});

