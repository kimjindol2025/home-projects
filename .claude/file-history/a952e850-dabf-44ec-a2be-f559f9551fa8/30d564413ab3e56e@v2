describe("🆕 Namespace Object APIs (Phase 2) — 가용성 확인", () => {
  test("NS01: String namespace 객체 존재 확인", () => {
    // namespace object가 제대로 export되는지 확인
    expect(typeof String).toBe("object");
    expect(String.len).toBeDefined();
    expect(String.upper).toBeDefined();
    expect(String.lower).toBeDefined();
  });

  test("NS02: Functional namespace 객체 존재 확인", () => {
    expect(typeof Functional).toBe("object");
    expect(Functional.compose).toBeDefined();
    expect(Functional.pipe).toBeDefined();
    expect(Functional.memoize).toBeDefined();
  });

  test("NS03: Regex namespace 객체 존재 확인", () => {
    expect(typeof Regex).toBe("object");
    expect(Regex.test).toBeDefined();
    expect(Regex.match).toBeDefined();
    expect(Regex.split).toBeDefined();
  });

  test("NS04: JSON namespace 객체 존재 확인", () => {
    // JSON namespace는 globalThis.JSON과 구분하기 위해 type cast 사용
    const JSONMethods = (JSON as any);
    expect(typeof JSONMethods).toBe("object");
    expect(JSONMethods.parse).toBeDefined();
    expect(JSONMethods.stringify).toBeDefined();
    expect(JSONMethods.pretty).toBeDefined();
  });

  test("NS05: Database namespace 객체 존재 확인", () => {
    // DatabaseType은 interface, Database는 namespace object
    expect(typeof Database).toBe("object");
    expect(Database.create).toBeDefined();
    expect(Database.insert).toBeDefined();
    expect(Database.query).toBeDefined();
  });

  test("NS06: 기존 함수와 namespace 병렬 가용", () => {
    // 기존 함수들도 여전히 동작 (Deprecation pattern)
    expect(typeof str_len).toBe("function");
    expect(typeof str_upper).toBe("function");
    expect(typeof compose).toBe("function");
    expect(typeof regex_test).toBe("function");
    expect(typeof json_parse).toBe("function");
    expect(typeof db_create).toBe("function");
  });

  test("NS07: String namespace 메서드 체크", () => {
    const methods = Object.keys(String as any);
    expect(methods).toContain("len");
    expect(methods).toContain("upper");
    expect(methods).toContain("lower");
    expect(methods).toContain("split");
    expect(methods).toContain("join");
    expect(methods).toHaveLength(18);
  });

  test("NS08: Functional namespace 메서드 체크", () => {
    const methods = Object.keys(Functional as any);
    expect(methods).toContain("compose");
    expect(methods).toContain("pipe");
    expect(methods).toContain("memoize");
    expect(methods).toHaveLength(10);
  });

  test("NS09: Regex namespace 메서드 체크", () => {
    const methods = Object.keys(Regex as any);
    expect(methods).toContain("test");
    expect(methods).toContain("match");
    expect(methods).toContain("split");
    expect(methods).toHaveLength(7);
  });

  test("NS10: Database namespace 메서드 체크", () => {
    const methods = Object.keys(Database as any);
    expect(methods).toContain("create");
    expect(methods).toContain("insert");
    expect(methods).toContain("query");
    expect(methods).toHaveLength(10);
  });
});
