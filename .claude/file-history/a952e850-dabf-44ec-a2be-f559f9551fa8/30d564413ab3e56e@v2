describe("String Functions", () => {
  test("T01: str_len — 한글 포함 길이", () => {
    expect(str_len(V.str("hello"))).toEqual(V.i32(5));
    expect(str_len(V.str("안녕"))).toEqual(V.i32(2));
    expect(str_len(V.str(""))).toEqual(V.i32(0));
  });

  test("T02: str_upper / str_lower", () => {
    expect(str_upper(V.str("hello World"))).toEqual(V.str("HELLO WORLD"));
    expect(str_lower(V.str("HELLO World"))).toEqual(V.str("hello world"));
  });

  test("T03: str_trim — 앞뒤 공백 제거", () => {
    expect(str_trim(V.str("  hello  "))).toEqual(V.str("hello"));
    expect(str_trim(V.str("\t\n text \n"))).toEqual(V.str("text"));
  });

  test("T04: str_split / str_join 라운드트립", () => {
    const arr = str_split(V.str("a,b,c"), V.str(","));
    expect(arr.tag).toBe("arr");
    const joined = str_join(arr, V.str(","));
    expect(joined).toEqual(V.str("a,b,c"));
  });

  test("T05: str_contains / starts_with / ends_with", () => {
    expect(str_contains(V.str("hello world"), V.str("world"))).toEqual(V.bool(true));
    expect(str_starts_with(V.str("hello"), V.str("hel"))).toEqual(V.bool(true));
    expect(str_ends_with(V.str("hello"), V.str("llo"))).toEqual(V.bool(true));
    expect(str_contains(V.str("hello"), V.str("xyz"))).toEqual(V.bool(false));
  });

  test("T06: str_replace (첫 번째) / str_replace_all (전체)", () => {
    expect(str_replace(V.str("aababc"), V.str("a"), V.str("X"))).toEqual(V.str("Xababc"));
    expect(str_replace_all(V.str("aababc"), V.str("a"), V.str("X"))).toEqual(V.str("XXbXbc"));
  });

  test("T07: str_slice — 양수/음수 인덱스", () => {
    expect(str_slice(V.str("hello"), V.i32(1), V.i32(4))).toEqual(V.str("ell"));
    expect(str_slice(V.str("hello"), V.i32(0), V.i32(-1))).toEqual(V.str("hell")); // 음수
  });

  test("T08: str_repeat — N회 반복", () => {
    expect(str_repeat(V.str("ab"), V.i32(3))).toEqual(V.str("ababab"));
    expect(str_repeat(V.str("x"), V.i32(0))).toEqual(V.str(""));
  });

  test("T09: str_index_of — 위치 탐색", () => {
    expect(str_index_of(V.str("hello world"), V.str("world"))).toEqual(V.i32(6));
    expect(str_index_of(V.str("hello"), V.str("xyz"))).toEqual(V.i32(-1));
  });

  test("T10: str_pad_start / str_pad_end", () => {
    expect(str_pad_start(V.str("5"), V.i32(3), V.str("0"))).toEqual(V.str("005"));
    expect(str_pad_end(V.str("hi"), V.i32(5), V.str("."))).toEqual(V.str("hi..."));
  });

  test("T11: str_char_at — some/none", () => {
    const r = str_char_at(V.str("hello"), V.i32(1));
    expect(r.tag).toBe("some");
    expect((r as any).val).toEqual(V.str("e"));
    expect(str_char_at(V.str("hi"), V.i32(10)).tag).toBe("none");
  });

  test("T12: str_to_chars — 문자 배열 분해", () => {
    const chars = str_to_chars(V.str("abc"));
    expect(chars.tag).toBe("arr");
    expect((chars as any).elements).toEqual([V.str("a"), V.str("b"), V.str("c")]);
  });

  test("T13: str 타입 오류 → 예외", () => {
    expect(() => str_len(V.i32(42))).toThrow("str 필요");
    expect(() => str_upper(V.bool(true))).toThrow("str 필요");
  });

  test("T14: str_join — 빈 배열", () => {
    const empty = str_join(V.arr([]), V.str(","));
    expect(empty).toEqual(V.str(""));
  });
});

