describe("Database Functions", () => {
  let db: Database;

  beforeEach(() => {
    db = db_create("test_db");
    db_create_table(db, "users", { name: "str", age: "i32", email: "str" });
  });

  test("T45: db_insert — 행 삽입 및 id 반환", () => {
    const r = db_insert(db, "users", { name: V.str("Alice"), age: V.i32(30), email: V.str("a@ex.com") });
    expect(r.tag).toBe("ok");
    expect((r as any).val).toEqual(V.i32(1));

    const r2 = db_insert(db, "users", { name: V.str("Bob"), age: V.i32(25), email: V.str("b@ex.com") });
    expect((r2 as any).val).toEqual(V.i32(2));
  });

  test("T46: db_query SELECT * FROM table", () => {
    db_insert(db, "users", { name: V.str("Alice"), age: V.i32(30) });
    db_insert(db, "users", { name: V.str("Bob"),   age: V.i32(25) });
    const r = db_query(db, "SELECT * FROM users", []);
    expect(r.tag).toBe("ok");
    const rows = (r as any).val;
    expect(rows.tag).toBe("arr");
    expect(rows.elements).toHaveLength(2);
  });

  test("T47: db_query SELECT WHERE 조건", () => {
    db_insert(db, "users", { name: V.str("Alice"), age: V.i32(30) });
    db_insert(db, "users", { name: V.str("Bob"),   age: V.i32(17) });
    db_insert(db, "users", { name: V.str("Carol"), age: V.i32(25) });

    const r = db_query(db, "SELECT * FROM users WHERE age >= 25", []);
    expect(r.tag).toBe("ok");
    expect((r as any).val.elements).toHaveLength(2);
  });

  test("T48: db_query 파라미터 바인딩 ($1)", () => {
    db_insert(db, "users", { name: V.str("Alice"), age: V.i32(30) });
    db_insert(db, "users", { name: V.str("Bob"),   age: V.i32(25) });

    const r = db_query(db, "SELECT * FROM users WHERE name = $1", [V.str("Alice")]);
    expect((r as any).val.elements).toHaveLength(1);
    const row = (r as any).val.elements[0];
    expect(row.fields.get("name")).toEqual(V.str("Alice"));
  });

  test("T49: db_query ORDER BY + LIMIT", () => {
    db_insert(db, "users", { name: V.str("C"), age: V.i32(30) });
    db_insert(db, "users", { name: V.str("A"), age: V.i32(10) });
    db_insert(db, "users", { name: V.str("B"), age: V.i32(20) });

    const r = db_query(db, "SELECT * FROM users ORDER BY age ASC LIMIT 2", []);
    const rows = (r as any).val.elements;
    expect(rows).toHaveLength(2);
    expect(rows[0].fields.get("name")).toEqual(V.str("A")); // 나이 가장 적음
  });

  test("T50: db_update — 조건부 업데이트", () => {
    db_insert(db, "users", { name: V.str("Alice"), age: V.i32(30) });
    db_insert(db, "users", { name: V.str("Bob"),   age: V.i32(30) });
    db_insert(db, "users", { name: V.str("Carol"), age: V.i32(25) });

    const r = db_update(db, "users", { age: V.i32(31) }, "age = 30");
    expect(r.tag).toBe("ok");
    expect((r as any).val).toEqual(V.i32(2)); // 2행 업데이트

    const q = db_query(db, "SELECT * FROM users WHERE age = 31", []);
    expect((q as any).val.elements).toHaveLength(2);
  });

  test("T51: db_delete — 조건부 삭제", () => {
    db_insert(db, "users", { name: V.str("Alice"), age: V.i32(30) });
    db_insert(db, "users", { name: V.str("Bob"),   age: V.i32(17) });

    const r = db_delete(db, "users", "age < 18");
    expect(r.tag).toBe("ok");
    expect((r as any).val).toEqual(V.i32(1)); // 1행 삭제

    expect(db_count(db, "users")).toEqual(V.i32(1));
  });

  test("T52: db_count — 전체/조건", () => {
    db_insert(db, "users", { name: V.str("Alice"), age: V.i32(30) });
    db_insert(db, "users", { name: V.str("Bob"),   age: V.i32(25) });
    db_insert(db, "users", { name: V.str("Carol"), age: V.i32(17) });

    expect(db_count(db, "users")).toEqual(V.i32(3));
    expect(db_count(db, "users", "age >= 25")).toEqual(V.i32(2));
  });

  test("T53: db_insert 없는 테이블 → err", () => {
    const r = db_insert(db, "no_table", { x: V.i32(1) });
    expect(r.tag).toBe("err");
  });

  test("T54: db_query 없는 테이블 → err", () => {
    const r = db_query(db, "SELECT * FROM ghost", []);
    expect(r.tag).toBe("err");
  });

  test("T55: 트랜잭션 — begin/commit", () => {
    db_begin(db);
    db_insert(db, "users", { name: V.str("TxUser"), age: V.i32(20) });
    const committed = db_commit(db);
    expect(committed.tag).toBe("ok");
    expect(db_count(db, "users")).toEqual(V.i32(1)); // commit 후 반영됨
  });

  test("T56: 통합 시나리오 — 가입→조회→수정→탈퇴", () => {
    // 가입
    const id = db_insert(db, "users", { name: V.str("Dave"), age: V.i32(28), email: V.str("d@ex.com") });
    expect(id.tag).toBe("ok");

    // 조회
    const found = db_query(db, "SELECT * FROM users WHERE name = $1", [V.str("Dave")]);
    expect((found as any).val.elements).toHaveLength(1);

    // 수정
    db_update(db, "users", { age: V.i32(29) }, "name = 'Dave'");
    const updated = db_query(db, "SELECT * FROM users WHERE name = $1", [V.str("Dave")]);
    const row = (updated as any).val.elements[0];
    expect(row.fields.get("age")).toEqual(V.i32(29));

    // 탈퇴
    const deleted = db_delete(db, "users", "name = 'Dave'");
    expect((deleted as any).val).toEqual(V.i32(1));
    expect(db_count(db, "users")).toEqual(V.i32(0));
  });
});

