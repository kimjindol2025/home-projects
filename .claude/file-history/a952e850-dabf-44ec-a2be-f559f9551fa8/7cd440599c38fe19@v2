## 완전한 예제

### 예제 1: API 응답 처리
```typescript
import { JSON as FlJSON } from 'freelang-v4';

const handleAPIResponse = (responseString) => {
  // 검증
  const validated = FlJSON.validate(responseString);
  if (!validated.valid) {
    console.error(`Invalid JSON: ${validated.error}`);
    return null;
  }

  // 파싱
  const data = FlJSON.parse(responseString);

  // 조회
  const userName = FlJSON.get(data, "user.profile.name");
  console.log(`User: ${userName}`);

  return data;
};
```

### 예제 2: 설정 파일 병합
```typescript
const defaultConfig = {
  port: 3000,
  database: { host: "localhost", port: 5432 },
  logging: { level: "info" }
};

const userConfig = {
  port: 8080,
  database: { port: 5433 }  // host는 유지
};

const finalConfig = FlJSON.merge(defaultConfig, userConfig, true);
// {
//   port: 8080,
//   database: { host: "localhost", port: 5433 },
//   logging: { level: "info" }
// }
```

### 예제 3: 로그 저장
```typescript
const log = {
  timestamp: new Date().toISOString(),
  level: "INFO",
  message: "Application started",
  context: { userId: 123, action: "login" }
};

const logString = FlJSON.stringify(log, true);
fs.appendFileSync("logs.json", logString + "\n");

// 읽기
const logs = fs.readFileSync("logs.json", "utf-8")
  .split("\n")
  .filter(line => line.length > 0)
  .map(line => FlJSON.parse(line));
```

### 예제 4: 깊은 복사
```typescript
const original = {
  user: { name: "Alice", tags: ["admin", "user"] }
};

// 깊은 복사
const copy = FlJSON.parse(FlJSON.stringify(original));

// 독립적으로 수정 가능
copy.user.name = "Bob";
copy.user.tags.push("guest");

console.log(original.user.name);  // "Alice" (변경 안됨)
```

