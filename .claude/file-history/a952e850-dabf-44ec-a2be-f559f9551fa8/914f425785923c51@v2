## 3️⃣ 설정 파일 관리

```typescript
import { JSON as FlJSON } from 'freelang-v4';
import * as fs from 'fs';

// 기본 설정
const defaultConfig = {
  app: { name: 'MyApp', version: '1.0.0' },
  server: { port: 3000, host: 'localhost' },
  database: { host: 'localhost', port: 5432 },
  logging: { level: 'info' }
};

// 사용자 설정 로드
const loadConfig = (filePath: string) => {
  try {
    const content = fs.readFileSync(filePath, 'utf-8');
    const userConfig = FlJSON.parse(content);

    // 검증
    const validated = FlJSON.validate(content);
    if (!validated.valid) {
      throw new Error(`Invalid JSON: ${validated.error}`);
    }

    // 병합
    return FlJSON.merge(defaultConfig, userConfig, true);
  } catch (error) {
    console.warn(`Failed to load config: ${error.message}`);
    return defaultConfig;
  }
};

// 저장
const saveConfig = (config: object, filePath: string) => {
  const json = FlJSON.stringify(config, true);  // 포매팅
  fs.writeFileSync(filePath, json, 'utf-8');
};

// 사용
const config = loadConfig('config.json');
console.log(`Server: ${config.server.port}`);
```

