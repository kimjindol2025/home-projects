## 1️⃣ 블로그 API 서버

```typescript
import { HTTP, Security, JSON as FlJSON, ORM, Crypto } from 'freelang-v4';

const server = HTTP.create({ port: 3000 });
const orm = ORM.create();

// 모델 정의
orm.define('User', {
  id: { type: 'INTEGER', primary: true },
  email: { type: 'STRING', unique: true },
  password_hash: { type: 'STRING' },
  created_at: { type: 'DATETIME' }
});

orm.define('Post', {
  id: { type: 'INTEGER', primary: true },
  user_id: { type: 'INTEGER' },
  title: { type: 'STRING' },
  content: { type: 'TEXT' },
  created_at: { type: 'DATETIME' }
});

// 관계 설정
orm.hasMany('User', 'Post', 'user_id');

// 라우트: 회원 가입
server.post('/auth/register', async (req, res) => {
  const body = FlJSON.parse(req.body);

  // 검증
  if (!Security.validateEmail(body.email)) {
    return HTTP.badRequest('Invalid email');
  }

  const strength = Security.validatePasswordStrength(body.password);
  if (!strength.valid) {
    return HTTP.badRequest(`Password too weak: ${strength.issues.join(', ')}`);
  }

  // 저장
  const hash = Security.hashPassword(body.password);
  const userId = orm.insert('User', {
    email: body.email,
    password_hash: hash.hash,
    created_at: new Date().toISOString()
  });

  // JWT 발급
  const token = Security.createJWT(
    { userId, email: body.email },
    'jwt-secret',
    86400  // 24시간
  );

  return HTTP.created({ token: token.token, userId });
});

// 라우트: 로그인
server.post('/auth/login', async (req, res) => {
  const body = FlJSON.parse(req.body);
  const users = orm.where('User', 'email', '=', body.email);

  if (users.length === 0) {
    return HTTP.unauthorized('Invalid credentials');
  }

  const user = users[0];
  const valid = Security.verifyPassword(body.password, user.password_hash);

  if (!valid) {
    return HTTP.unauthorized('Invalid credentials');
  }

  const token = Security.createJWT({ userId: user.id }, 'jwt-secret', 86400);
  return HTTP.ok({ token: token.token });
});

// 라우트: 포스트 생성
server.post('/posts', async (req, res) => {
  const auth = req.headers.authorization?.replace('Bearer ', '');
  if (!auth) return HTTP.unauthorized('Missing token');

  const verified = Security.verifyJWT(auth, 'jwt-secret');
  if (!verified.valid) return HTTP.unauthorized('Invalid token');

  const body = FlJSON.parse(req.body);
  const postId = orm.insert('Post', {
    user_id: verified.payload.userId,
    title: body.title,
    content: body.content,
    created_at: new Date().toISOString()
  });

  return HTTP.created({ id: postId });
});

// 라우트: 포스트 조회
server.get('/posts/:id', async (req, res) => {
  const postId = req.params.id;
  const posts = orm.where('Post', 'id', '=', postId);

  if (posts.length === 0) {
    return HTTP.notFound('Post not found');
  }

  return HTTP.ok(posts[0]);
});

await server.serve();
```

