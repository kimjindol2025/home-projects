## 6️⃣ 폼 검증 및 정제

```typescript
import { Security, Regex, String as FlString } from 'freelang-v4';

// 폼 데이터 정제 및 검증
const validateForm = (data: any) => {
  const errors: string[] = [];

  // 이름 검증
  if (!data.name || FlString.len(data.name) < 2) {
    errors.push('Name must be at least 2 characters');
  }

  // 이메일 검증
  if (!Security.validateEmail(data.email)) {
    errors.push('Invalid email format');
  }

  // 비밀번호 검증
  const strength = Security.validatePasswordStrength(data.password);
  if (!strength.valid) {
    errors.push(`Password: ${strength.issues.join(', ')}`);
  }

  // 전화번호 검증
  if (!Security.validatePhoneNumber(data.phone)) {
    errors.push('Invalid phone number');
  }

  // URL 검증
  if (data.website && !Security.validateURL(data.website)) {
    errors.push('Invalid website URL');
  }

  if (errors.length > 0) {
    return { valid: false, errors };
  }

  // 데이터 정제
  const sanitized = {
    name: FlString.trim(data.name),
    email: FlString.trim(data.email),
    password: data.password,  // 해싱 필요
    phone: FlString.trim(data.phone),
    website: data.website ? FlString.trim(data.website) : null,
    bio: data.bio ? Security.sanitizeHTML(data.bio) : null
  };

  return { valid: true, data: sanitized };
};

// 사용
const result = validateForm({
  name: '  Alice  ',
  email: 'alice@example.com',
  password: 'StrongPassword123!',
  phone: '+82101234567',
  website: 'https://example.com',
  bio: '<script>alert("xss")</script>'
});

if (result.valid) {
  console.log('Cleaned data:', result.data);
} else {
  console.error('Errors:', result.errors);
}
```

