## 5️⃣ 텍스트 처리 도구

```typescript
import {
  String as FlString,
  Regex,
  Functional
} from 'freelang-v4';

// 마크다운 제목 추출
const extractHeadings = (markdown: string) => {
  const lines = FlString.split(markdown, '\n');
  return lines
    .filter((line) => Regex.test(line, /^#+\s/))
    .map((line) => ({
      level: FlString.len(Regex.match(line, /^#+/)?.[0] || ''),
      text: Regex.replace(line, /^#+\s/, '')
    }));
};

// CSV 파싱
const parseCSV = (csv: string) => {
  const lines = FlString.split(csv, '\n');
  const headers = FlString.split(lines[0], ',');

  return lines.slice(1)
    .filter((line) => FlString.len(line) > 0)
    .map((line) => {
      const values = FlString.split(line, ',');
      const obj: any = {};
      headers.forEach((h, i) => {
        obj[h] = values[i];
      });
      return obj;
    });
};

// 사용
const markdown = '# Title\n## Subtitle\n### Third';
const headings = extractHeadings(markdown);
console.log(headings);
```

