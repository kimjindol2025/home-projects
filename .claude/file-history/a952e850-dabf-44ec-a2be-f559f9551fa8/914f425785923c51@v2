## 2️⃣ 데이터 처리 파이프라인

```typescript
import {
  Functional,
  String as FlString,
  Regex,
  JSON as FlJSON,
  Crypto
} from 'freelang-v4';

// 데이터 정규화
const normalizeData = (data: string[]) => {
  return data.map((item) =>
    FlString.trim(item)
  ).filter((item) =>
    FlString.len(item) > 0
  );
};

// 유효성 검증
const validateEmails = (emails: string[]) => {
  return emails.filter((email) =>
    Regex.test(email, /^[^\s@]+@[^\s@]+\.[^\s@]+$/)
  );
};

// 암호화
const encryptEmails = (emails: string[]) => {
  return emails.map((email) =>
    Crypto.encrypt(email, 'encryption-key')
  );
};

// 파이프라인 구성
const processEmails = Functional.pipe(
  normalizeData,
  validateEmails,
  encryptEmails
);

// 사용
const rawEmails = ["  alice@example.com  ", "invalid", "  bob@example.com  "];
const processed = processEmails(rawEmails);
console.log(processed);
```

