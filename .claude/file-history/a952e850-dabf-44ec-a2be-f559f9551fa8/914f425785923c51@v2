## 4️⃣ 캐싱 시스템

```typescript
import { Functional } from 'freelang-v4';

// 비용이 많이 드는 함수
const fetchUserData = (userId: number) => {
  // 데이터베이스 조회 (느림)
  console.log(`Fetching user ${userId}...`);
  return { id: userId, name: `User ${userId}` };
};

// 메모이제이션으로 캐싱
const cachedFetch = Functional.memoize(fetchUserData);

// 사용
console.time('first');
cachedFetch(1);  // 계산 (느림)
console.timeEnd('first');

console.time('second');
cachedFetch(1);  // 캐시 (빠름)
console.timeEnd('second');

console.time('third');
cachedFetch(2);  // 새로운 ID, 계산
console.timeEnd('third');
```

