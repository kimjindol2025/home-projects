section("2. 키 관리");

test("다른 키 → 다른 HMAC (키 격리)", () => {
  const msg = "same message";
  const mac1 = fl_hmac(msg, "key-alpha");
  const mac2 = fl_hmac(msg, "key-beta");
  assert(mac1 !== mac2, "동일 메시지라도 키가 다르면 MAC이 달라야 함");
});

test("같은 키 + 같은 메시지 → 같은 HMAC (결정론적)", () => {
  const mac1 = fl_hmac("message", "secret-key");
  const mac2 = fl_hmac("message", "secret-key");
  eq(mac1, mac2);
});

test("빈 키 — 에러 없이 처리", () => {
  const mac = fl_hmac("data", "");
  assert(mac.length === 64, "빈 키라도 HMAC 출력은 64자 hex");
});

test("1바이트 키 — 정상 처리", () => {
  const mac = fl_hmac("test", "k");
  assert(mac.length === 64);
  assert(/^[0-9a-f]{64}$/.test(mac), "hex 포맷이어야 함");
});

test("블록 크기 초과 키 (>64바이트) — 정상 처리", () => {
  // SHA256 블록 크기(64바이트)보다 긴 키 → 내부적으로 해시됨 (RFC 2104)
  const longKey = "k".repeat(100);
  const mac = fl_hmac("message", longKey);
  assert(mac.length === 64, "긴 키라도 HMAC 출력 64자");
});

test("키 회전 — 이전 키로 생성한 MAC은 새 키로 검증 실패", () => {
  const msg  = "payload";
  const mac1 = fl_hmac(msg, "old-secret");
  const mac2 = fl_hmac(msg, "new-secret");
  assert(mac1 !== mac2, "키 회전 시 MAC이 달라야 함");
  // 상수-시간 비교로 검증
  assert(!constantTimeEqual(mac1, mac2));
});

test("HMAC 출력에 키 정보 미포함 (정보 노출 없음)", () => {
  const secret = "MY_SUPER_SECRET_KEY_12345";
  const mac = fl_hmac("test", secret);
  assert(!mac.includes(secret), "MAC 출력이 키를 직접 포함하면 안 됨");
  // base64로 인코딩된 키도 없어야 함
  const b64key = fl_base64_encode(secret);
  assert(!mac.includes(b64key.substring(0, 8)), "MAC이 인코딩된 키 정보를 포함하면 안 됨");
});

test("유니코드 키 — 일관된 처리", () => {
  const mac1 = fl_hmac("data", "한글키");
  const mac2 = fl_hmac("data", "한글키");
  eq(mac1, mac2, "유니코드 키 결정론적");
  assert(mac1.length === 64);
});

