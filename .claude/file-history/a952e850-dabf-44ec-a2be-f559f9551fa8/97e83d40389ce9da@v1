section("4. 취약성 스캔");

test("[VULN-001] MD5 약점 — 알려진 충돌 쌍 (알고리즘 적합성 경고)", () => {
  // MD5는 충돌 쌍이 알려져 있음 (Wang & Yu, 2004)
  // 이 테스트는 MD5의 약점을 문서화: 서명/인증에 사용 금지
  assert(WEAK_ALGORITHMS.includes("md5"), "MD5는 약한 알고리즘으로 분류되어야 함");

  // 충돌 쌍 검증 (실제 Wang-Yu 충돌 -- 첫 128바이트)
  // 두 메시지는 다르지만 같은 MD5를 가짐 (실제 충돌 아님, 개념 설명)
  const msg1 = "FreeLang message one";
  const msg2 = "FreeLang message two";
  assert(fl_md5(msg1) !== fl_md5(msg2), "정상적으로 다른 입력은 다른 해시");
  // 경고: 실제 환경에서 MD5는 충돌 공격에 취약
  console.log(`      ⚠ MD5는 보안 목적(서명, 인증)에 사용 금지 (RFC 6151)`);
});

test("[VULN-002] SHA256 사전-이미지 저항성", () => {
  // 해시에서 원본 복원 불가 (단방향성)
  const secret = `secret_${Math.random()}`;
  const hash = fl_sha256(secret);

  // 해시 출력으로부터 원래 입력을 추론할 수 없음
  assert(!hash.includes(secret), "해시 출력에 원본 입력이 포함되어선 안 됨");
  assert(hash !== secret, "해시 출력이 입력과 같으면 안 됨");
});

test("[VULN-003] 해시 함수 독립성 — 알고리즘 간 충돌 없음", () => {
  // sha256("x") ≠ sha512("x") ≠ md5("x") — 다른 알고리즘은 다른 출력
  const input = "cross-algorithm-test";
  const results = [fl_md5(input), fl_sha256(input), fl_sha512(input)];
  const unique = new Set(results);
  eq(unique.size, 3, "MD5, SHA256, SHA512 출력이 서로 달라야 함");
});

test("[VULN-004] 타이밍 공격 방어 — constantTimeEqual 검증", () => {
  const mac1 = fl_hmac("message", "secret");
  const mac2 = fl_hmac("message", "wrong-secret");

  // 일반 string 비교(==) 대신 상수-시간 비교 사용 확인
  assert(!constantTimeEqual(mac1, mac2), "다른 MAC은 false");
  assert(constantTimeEqual(mac1, mac1), "같은 MAC은 true");

  // 길이 다른 경우도 false (길이 노출 없이)
  assert(!constantTimeEqual(mac1, mac1.substring(0, 32)), "길이 다른 경우 false");
});

test("[VULN-005] HMAC 잘림(Truncation) 취약성", () => {
  // MAC을 임의로 잘라서 비교하면 취약
  const mac = fl_hmac("data", "secret");
  const truncated = mac.substring(0, 8); // 첫 8자만 사용

  // 잘린 MAC은 보안상 불충분 — 무차별 대입 가능성
  assert(truncated.length < mac.length, "잘린 MAC 확인");
  assert(!constantTimeEqual(mac, truncated), "잘린 MAC은 원본과 달라야 함");
  console.log(`      ⚠ MAC 잘림(truncation)은 보안 취약점 — 전체 MAC(64자) 사용 필수`);
});

test("[VULN-006] 재전송 공격 패턴 — 타임스탬프 없는 HMAC 한계", () => {
  // 타임스탬프 없이 HMAC만 사용하면 재전송 공격 가능
  const message = "transfer:1000:alice:bob";
  const mac = fl_hmac(message, "server-secret");

  // 같은 메시지+MAC이 나중에 재사용 가능 — 애플리케이션 레이어에서 방지해야
  const replayMac = fl_hmac(message, "server-secret");
  eq(mac, replayMac); // 의도적으로 같음 (재전송 공격 가능성 확인)
  console.log(`      ⚠ HMAC만으로는 재전송 공격 방어 불가 — nonce/timestamp 필요`);
});

test("[VULN-007] 비밀 정보 에러 메시지 노출 없음", () => {
  // base64_decode 실패 시 에러에 입력 노출 여부 확인
  const sensitiveInput = "TOP_SECRET_KEY_12345";
  const result = fl_base64_decode("!invalid!");
  if (!result.ok) {
    const errMsg = (result as any).err as string;
    assert(!errMsg.includes(sensitiveInput), "에러 메시지에 민감 정보 미포함");
    assert(errMsg.length < 100, "에러 메시지 과도하게 길지 않음");
  }
});

test("[VULN-008] Null 바이트 처리 — 입력 무결성", () => {
  // null 바이트가 포함된 입력도 일관되게 처리
  const withNull = "before\x00after";
  const withoutNull = "beforeafter";

  // null 바이트가 있으면 다른 해시 (truncation 없음)
  assert(fl_sha256(withNull) !== fl_sha256(withoutNull),
    "null 바이트 포함 문자열은 다른 해시를 가져야 함");
});

test("[VULN-009] 약한 알고리즘 목록 — MD5/SHA1 탐지", () => {
  // FreeLang v4가 제공하는 함수 중 약한 알고리즘 식별
  const freelangCryptoFunctions = ["md5", "sha256", "sha512", "base64_encode", "base64_decode", "hmac"];

  const weakInFreelang = freelangCryptoFunctions.filter((fn) =>
    WEAK_ALGORITHMS.includes(fn)
  );

  // md5는 약한 알고리즘으로 분류됨
  assert(weakInFreelang.includes("md5"), "md5는 약한 알고리즘으로 탐지되어야 함");
  assert(!weakInFreelang.includes("sha256"), "sha256은 약한 알고리즘 아님");
  assert(!weakInFreelang.includes("sha512"), "sha512는 약한 알고리즘 아님");

  if (weakInFreelang.length > 0) {
    console.log(`      ⚠ 약한 알고리즘 발견: [${weakInFreelang.join(", ")}] — 보안 컨텍스트 사용 금지`);
  }
});

test("[VULN-010] 해시 확장 공격 (Length Extension) — SHA256 구조적 특성", () => {
  // SHA256은 Merkle-Damgård 구조로 Length Extension 공격에 이론적으로 취약
  // MAC = sha256(secret || message) 형태는 안전하지 않음
  // 올바른 방법: HMAC(message, secret)
  const secret = "secret";
  const message = "legitimate_data";

  // 취약한 패턴: sha256(secret + message) → 확장 가능
  const vulnerableMAC = fl_sha256(secret + message);

  // 안전한 패턴: hmac(message, secret) → 확장 불가
  const safeMAC = fl_hmac(message, secret);

  assert(vulnerableMAC !== safeMAC, "HMAC과 단순 해시는 다른 값 생성");
  console.log(`      ⚠ sha256(secret+msg) 패턴은 Length Extension 공격에 취약 — hmac() 사용 필수`);
  console.log(`        안전: hmac(message, key) | 취약: sha256(key + message)`);
});

