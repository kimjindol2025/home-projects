section("3. 검증 규칙");

test("빈 문자열 입력 — 모든 해시 함수 에러 없음", () => {
  assert(fl_md5("").length === 32,  "md5('') 32자");
  assert(fl_sha256("").length === 64, "sha256('') 64자");
  assert(fl_sha512("").length === 128,"sha512('') 128자");
});

test("해시 출력 포맷 — 소문자 hex", () => {
  const funcs = [fl_md5, fl_sha256, fl_sha512];
  const inputs = ["test", "Hello World", "123", ""];
  for (const fn of funcs) {
    for (const input of inputs) {
      const h = fn(input);
      assert(/^[0-9a-f]+$/.test(h), `비소문자 hex 발견: ${h.substring(0,10)}`);
    }
  }
});

test("해시 출력 길이 고정", () => {
  const inputs = ["", "a", "a".repeat(1000), "a".repeat(100_000)];
  for (const input of inputs) {
    eq(fl_md5(input).length, 32, `md5 길이 (input length=${input.length})`);
    eq(fl_sha256(input).length, 64, `sha256 길이`);
    eq(fl_sha512(input).length, 128, `sha512 길이`);
  }
});

test("대용량 입력 (100KB) — 처리 완료", () => {
  const bigInput = "A".repeat(100_000);
  const h = fl_sha256(bigInput);
  assert(h.length === 64, "대용량 입력도 64자 출력");
});

test("특수문자 입력 — 일관된 처리", () => {
  const specials = ["<script>alert(1)</script>", "'; DROP TABLE users;--", "\x00\x01\x02\x03", "🔐🛡️🔑"];
  for (const s of specials) {
    const h = fl_sha256(s);
    assert(h.length === 64, `특수문자 입력 처리 실패: ${s.substring(0,20)}`);
  }
});

test("Base64 잘못된 입력 → ok:false (에러 처리)", () => {
  // base64_decode의 Node.js Buffer 구현은 실제로 에러를 던지지 않고 silently 처리
  // FreeLang vm.ts도 try/catch 감싸 있음 — 최소한 crash는 없어야 함
  const invalidInputs = ["!@#$%^&*()", "====", "not valid base64!!!"];
  for (const inv of invalidInputs) {
    let crashed = false;
    try { fl_base64_decode(inv); }
    catch { crashed = true; }
    assert(!crashed, `base64_decode가 크래시하면 안 됨: ${inv}`);
  }
});

test("Base64 인코딩-디코딩 왕복 (Roundtrip)", () => {
  const testStrings = ["Hello, World!", "FreeLang v4", "한글 테스트", "abc123!@#", ""];
  for (const s of testStrings) {
    const encoded = fl_base64_encode(s);
    const decoded = fl_base64_decode(encoded);
    assert(decoded.ok, `decode 실패: ${s}`);
    eq((decoded as any).val, s, `roundtrip 실패: ${s}`);
  }
});

test("해시 결정론적 — 같은 입력 → 항상 같은 출력", () => {
  const input = "determinism test";
  const h1 = fl_sha256(input);
  const h2 = fl_sha256(input);
  const h3 = fl_sha256(input);
  eq(h1, h2);
  eq(h2, h3);
});

