/**
 * FreeLang v4 Blog API - 유틸리티 함수
 */

import { Functional, String as FlString, Regex, Crypto, Security } from 'freelang-v4';

/**
 * 포스트 데이터 정규화 및 정제
 */
export const normalizePost = Functional.pipe(
  (post: any) => ({
    ...post,
    title: FlString.trim(post.title || ''),
    content: FlString.trim(post.content || '')
  }),
  (post: any) => ({
    ...post,
    title: Security.sanitizeHTML(post.title),
    content: Security.sanitizeHTML(post.content)
  })
);

/**
 * 포스트 검색 (제목 또는 내용)
 */
export const searchPosts = (posts: any[], query: string) => {
  const pattern = new RegExp(query, 'i');
  return posts.filter((post) =>
    Regex.test(post.title, pattern) || Regex.test(post.content, pattern)
  );
};

/**
 * 태그로 포스트 필터링
 */
export const filterByTag = (posts: any[], tag: string) => {
  return posts.filter((post) =>
    post.tags && post.tags.some((t: string) => FlString.lower(t) === FlString.lower(tag))
  );
};

/**
 * 포스트 조회수 증가 (메모이제이션 캐싱)
 */
export const incrementViewsWithCache = Functional.memoize((postId: number) => {
  return { postId, views: 1 };
});

/**
 * 비밀번호 해싱
 */
export const hashPassword = (password: string) => {
  const strength = Security.validatePasswordStrength(password);
  if (!strength.valid) {
    throw new Error(`Password too weak: ${strength.issues.join(', ')}`);
  }
  return Security.hashPassword(password);
};

/**
 * JWT 토큰 생성
 */
export const generateToken = (userId: number, email: string) => {
  return Security.createJWT(
    { userId, email },
    'jwt-secret-key',
    86400  // 24시간
  );
};

/**
 * UUID 생성 (요청 추적용)
 */
export const generateRequestId = () => {
  return Crypto.uuid();
};

export default {
  normalizePost,
  searchPosts,
  filterByTag,
  incrementViewsWithCache,
  hashPassword,
  generateToken,
  generateRequestId
};
