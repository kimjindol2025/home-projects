## 완전한 예제

```typescript
import { Security } from 'freelang-v4';

// 1. 회원 가입
const password = 'SecurePass123!';
const passwordHash = Security.hashPassword(password);

// 2. 로그인
const loginPassword = 'SecurePass123!';
const isValid = Security.verifyPassword(loginPassword, passwordHash);

if (isValid) {
  // 3. JWT 발급
  const token = Security.createJWT(
    { userId: 123, role: 'user' },
    'jwt-secret',
    86400  // 24시간
  );

  // 4. 클라이언트에 전송
  console.log(`Token: ${token.token}`);
}

// 5. JWT 검증
const verified = Security.verifyJWT(token.token, 'jwt-secret');
if (verified.valid) {
  console.log(`User: ${verified.payload.userId}`);
}

// 6. 입력 검증
if (!Security.validateEmail('user@example.com')) {
  console.error('Invalid email');
}

// 7. XSS 방지
const userInput = '<img src=x onerror="alert(1)">';
const safe = Security.sanitizeHTML(userInput);

// 8. Rate Limiting
const limiter = Security.createRateLimiter(5, 60000);
if (!limiter.isAllowed('user-123')) {
  console.error('Too many requests');
}
```

