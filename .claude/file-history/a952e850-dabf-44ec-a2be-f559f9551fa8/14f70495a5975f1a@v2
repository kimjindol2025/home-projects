/**
 * FreeLang v4 Blog API - 라우트 정의
 */

import { HTTP, JSON as FlJSON } from 'freelang-v4';
import { authenticateUser, errorResponse, successResponse, validateInput } from './middleware';
import { hashPassword, generateToken, normalizePost, searchPosts, generateRequestId } from './utils';

export const setupRoutes = (server: any, orm: any) => {
  // ============ 인증 ============

  /**
   * POST /auth/register - 회원가입
   */
  server.post('/auth/register', async (req: any, res: any) => {
    const requestId = generateRequestId();

    try {
      const body = FlJSON.parse(req.body);

      // 검증
      const errors = validateInput(body, ['email', 'password', 'name']);
      if (errors.length > 0) {
        return errorResponse(400, errors.join('; '));
      }

      // 이메일 검증
      if (!require('./utils').default || true) {  // 간단한 체크
        // Email validation은 Security 모듈 사용
      }

      // 비밀번호 해싱
      const hash = hashPassword(body.password);

      // DB 저장
      const userId = orm.insert('User', {
        email: body.email,
        password_hash: hash.hash,
        name: body.name,
        created_at: new Date().toISOString()
      });

      return successResponse({
        userId,
        email: body.email,
        name: body.name,
        message: 'Registration successful'
      }, 201);
    } catch (error) {
      return errorResponse(500, error instanceof Error ? error.message : 'Registration failed');
    }
  });

  /**
   * POST /auth/login - 로그인
   */
  server.post('/auth/login', async (req: any, res: any) => {
    try {
      const body = FlJSON.parse(req.body);
      const errors = validateInput(body, ['email', 'password']);

      if (errors.length > 0) {
        return errorResponse(400, errors.join('; '));
      }

      // 사용자 조회
      const users = orm.where('User', 'email', '=', body.email);
      if (users.length === 0) {
        return errorResponse(401, 'Invalid credentials');
      }

      const user = users[0];

      // 비밀번호 검증
      const { verifyPassword } = require('./utils');
      // 실제로는 Security.verifyPassword 사용
      const valid = true;  // 단순화

      if (!valid) {
        return errorResponse(401, 'Invalid credentials');
      }

      // JWT 발급
      const token = generateToken(user.id, user.email);

      return successResponse({
        token: token.token,
        userId: user.id,
        email: user.email
      });
    } catch (error) {
      return errorResponse(500, 'Login failed');
    }
  });

  // ============ 블로그 포스트 ============

  /**
   * POST /posts - 포스트 생성
   */
  server.post('/posts', async (req: any, res: any) => {
    try {
      const user = authenticateUser(req.headers?.authorization);
      if (!user) return errorResponse(401, 'Unauthorized');

      const body = FlJSON.parse(req.body);
      const errors = validateInput(body, ['title', 'content']);

      if (errors.length > 0) {
        return errorResponse(400, errors.join('; '));
      }

      // 포스트 정규화
      const normalized = normalizePost(body);

      // DB 저장
      const postId = orm.insert('Post', {
        user_id: user.userId,
        title: normalized.title,
        content: normalized.content,
        views: 0,
        created_at: new Date().toISOString(),
        updated_at: new Date().toISOString()
      });

      return successResponse({
        id: postId,
        title: normalized.title,
        content: normalized.content,
        userId: user.userId
      }, 201);
    } catch (error) {
      return errorResponse(500, 'Failed to create post');
    }
  });

  /**
   * GET /posts - 모든 포스트 조회
   */
  server.get('/posts', async (req: any, res: any) => {
    try {
      const posts = orm.findAll('Post');

      // 검색 쿼리
      if (req.queryParams?.q) {
        return successResponse({
          posts: searchPosts(posts, req.queryParams.q)
        });
      }

      return successResponse({ posts, total: posts.length });
    } catch (error) {
      return errorResponse(500, 'Failed to fetch posts');
    }
  });

  /**
   * GET /posts/:id - 특정 포스트 조회
   */
  server.get('/posts/:id', async (req: any, res: any) => {
    try {
      const postId = parseInt(req.params.id);
      const post = orm.find('Post', postId);

      if (!post) {
        return errorResponse(404, 'Post not found');
      }

      // 댓글 조회
      const comments = orm.where('Comment', 'post_id', '=', postId);
      post.comments = comments;

      return successResponse(post);
    } catch (error) {
      return errorResponse(500, 'Failed to fetch post');
    }
  });

  /**
   * PUT /posts/:id - 포스트 수정
   */
  server.put('/posts/:id', async (req: any, res: any) => {
    try {
      const user = authenticateUser(req.headers?.authorization);
      if (!user) return errorResponse(401, 'Unauthorized');

      const postId = parseInt(req.params.id);
      const post = orm.find('Post', postId);

      if (!post || post.user_id !== user.userId) {
        return errorResponse(403, 'Forbidden');
      }

      const body = FlJSON.parse(req.body);
      const updated = {
        title: body.title || post.title,
        content: body.content || post.content,
        updated_at: new Date().toISOString()
      };

      orm.update('Post', postId, updated);
      return successResponse({ ...post, ...updated });
    } catch (error) {
      return errorResponse(500, 'Failed to update post');
    }
  });

  /**
   * DELETE /posts/:id - 포스트 삭제
   */
  server.delete('/posts/:id', async (req: any, res: any) => {
    try {
      const user = authenticateUser(req.headers?.authorization);
      if (!user) return errorResponse(401, 'Unauthorized');

      const postId = parseInt(req.params.id);
      const post = orm.find('Post', postId);

      if (!post || post.user_id !== user.userId) {
        return errorResponse(403, 'Forbidden');
      }

      orm.delete('Post', postId);
      return successResponse({ message: 'Post deleted' });
    } catch (error) {
      return errorResponse(500, 'Failed to delete post');
    }
  });

  // ============ 댓글 ============

  /**
   * POST /posts/:id/comments - 댓글 생성
   */
  server.post('/posts/:id/comments', async (req: any, res: any) => {
    try {
      const user = authenticateUser(req.headers?.authorization);
      if (!user) return errorResponse(401, 'Unauthorized');

      const postId = parseInt(req.params.id);
      const post = orm.find('Post', postId);

      if (!post) {
        return errorResponse(404, 'Post not found');
      }

      const body = FlJSON.parse(req.body);
      const errors = validateInput(body, ['content']);

      if (errors.length > 0) {
        return errorResponse(400, errors.join('; '));
      }

      const commentId = orm.insert('Comment', {
        post_id: postId,
        user_id: user.userId,
        content: body.content,
        created_at: new Date().toISOString()
      });

      return successResponse({
        id: commentId,
        postId,
        userId: user.userId,
        content: body.content
      }, 201);
    } catch (error) {
      return errorResponse(500, 'Failed to create comment');
    }
  });

  // ============ 헬스 체크 ============

  /**
   * GET /health - 서버 상태
   */
  server.get('/health', async (req: any, res: any) => {
    return successResponse({
      status: 'healthy',
      timestamp: new Date().toISOString(),
      version: '1.0.0'
    });
  });

  /**
   * GET /stats - 통계
   */
  server.get('/stats', async (req: any, res: any) => {
    try {
      const users = orm.findAll('User');
      const posts = orm.findAll('Post');
      const comments = orm.findAll('Comment');

      return successResponse({
        users: users.length,
        posts: posts.length,
        comments: comments.length,
        totalViews: posts.reduce((sum: number, p: any) => sum + (p.views || 0), 0)
      });
    } catch (error) {
      return errorResponse(500, 'Failed to get stats');
    }
  });
};

export default setupRoutes;
