## 4️⃣ 데이터베이스 쿼리

```typescript
import { Database } from 'freelang-v4';

// 테이블 생성
Database.createTable('users', {
  id: 'INTEGER PRIMARY KEY',
  name: 'TEXT NOT NULL',
  email: 'TEXT UNIQUE'
});

// 데이터 삽입
const userId = Database.insert('users', {
  name: 'Alice',
  email: 'alice@example.com'
});

// 조회
const user = Database.query('users', (row) => row.id === userId);
console.log(user);
```

