## 5️⃣ ORM 사용

```typescript
import { ORM } from 'freelang-v4';

const orm = ORM.create();

// 모델 정의
orm.define('User', {
  id: { type: 'INTEGER', primary: true },
  name: { type: 'STRING' },
  email: { type: 'STRING', unique: true }
});

// 데이터 삽입
const userId = orm.insert('User', {
  name: 'Bob',
  email: 'bob@example.com'
});

// 조회
const user = orm.find('User', userId);
console.log(user.name); // "Bob"

// 업데이트
orm.update('User', userId, { name: 'Robert' });

// 삭제
orm.delete('User', userId);
```

