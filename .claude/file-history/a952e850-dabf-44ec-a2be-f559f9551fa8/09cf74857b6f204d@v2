## 6️⃣ 보안 기능

```typescript
import { Security } from 'freelang-v4';

// 비밀번호 해싱
const hash = Security.hashPassword("myPassword123");
console.log(hash); // { hash, salt, iterations, algorithm }

// 비밀번호 검증
const isValid = Security.verifyPassword("myPassword123", hash);
console.log(isValid); // true

// JWT 토큰 생성
const token = Security.createJWT(
  { userId: 123, role: 'admin' },
  'secret-key',
  3600  // 1시간 만료
);

// JWT 검증
const verified = Security.verifyJWT(token.token, 'secret-key');
console.log(verified.valid); // true
console.log(verified.payload.userId); // 123
```

