/**
 * FreeLang v4 Blog API - ORM 모델 정의
 * 실제 데이터베이스 엔진 사용
 */

import { ORM } from './db/engine';

export const initializeDatabase = () => {
  const orm = ORM.create();

  // User 모델
  orm.define('User', {
    id: { type: 'INTEGER', primary: true },
    email: { type: 'STRING', unique: true },
    password_hash: { type: 'STRING' },
    name: { type: 'STRING' },
    created_at: { type: 'DATETIME' }
  });

  // Post 모델 (블로그 포스트)
  orm.define('Post', {
    id: { type: 'INTEGER', primary: true },
    user_id: { type: 'INTEGER' },
    title: { type: 'STRING' },
    content: { type: 'TEXT' },
    views: { type: 'INTEGER', default: 0 },
    created_at: { type: 'DATETIME' },
    updated_at: { type: 'DATETIME' }
  });

  // Comment 모델 (댓글)
  orm.define('Comment', {
    id: { type: 'INTEGER', primary: true },
    post_id: { type: 'INTEGER' },
    user_id: { type: 'INTEGER' },
    content: { type: 'TEXT' },
    created_at: { type: 'DATETIME' }
  });

  // Tag 모델
  orm.define('Tag', {
    id: { type: 'INTEGER', primary: true },
    name: { type: 'STRING', unique: true }
  });

  // PostTag 모델 (N:N 관계)
  orm.define('PostTag', {
    post_id: { type: 'INTEGER' },
    tag_id: { type: 'INTEGER' }
  });

  // 관계 설정
  orm.hasMany('User', 'Post', 'user_id');
  orm.hasMany('Post', 'Comment', 'post_id');
  orm.belongsTo('Post', 'User', 'user_id');
  orm.belongsTo('Comment', 'User', 'user_id');

  return orm;
};

export default initializeDatabase;
