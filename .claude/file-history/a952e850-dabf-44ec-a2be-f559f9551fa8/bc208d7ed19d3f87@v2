describe("Wallet", () => {
  test("T37: Wallet.create — 유효한 주소/공개키 생성", () => {
    const wallet = Wallet.create();
    expect(wallet.address).toHaveLength(40);
    expect(wallet.publicKey).toHaveLength(64);
  });

  test("T38: Wallet.fromPrivateKey — 복원 가능", () => {
    const original = Wallet.create();
    const pk       = (original as any).keyPair.privateKey as string;
    const restored = Wallet.fromPrivateKey(pk);
    expect(restored.address).toBe(original.address);
    expect(restored.publicKey).toBe(original.publicKey);
  });

  test("T39: Wallet.fromPrivateKey — 잘못된 키 예외", () => {
    expect(() => Wallet.fromPrivateKey("bad-key")).toThrow();
  });

  test("T40: wallet.send — 트랜잭션 생성 및 서명", () => {
    const alice  = Wallet.create();
    const bob    = Wallet.create();
    const tx     = alice.send(bob.address, 50, 2, 0);
    expect(tx.from).toBe(alice.address);
    expect(tx.to).toBe(bob.address);
    expect(tx.amount).toBe(50);
    expect(tx.fee).toBe(2);
  });

  test("T41: wallet.getBalance — 체인 잔고 조회", () => {
    const wallet = makeWallet();
    const chain  = makeFundedChain(wallet, 75);
    expect(wallet.getBalance(chain)).toBe(75);
  });

  test("T42: MultiSigWallet — 2-of-3 서명 트랜잭션 생성", () => {
    const signers = [Wallet.create(), Wallet.create(), Wallet.create()];
    const msig    = new MultiSigWallet(signers, 2);
    expect(msig.threshold).toBe(2);
    expect(msig.signerCount).toBe(3);
    expect(msig.address).toHaveLength(40);
  });
});

// ============================================================
// T43~T48: Mempool
// ============================================================

describe("Mempool", () => {
  let alice: Wallet;
  let bob:   Wallet;

  beforeEach(() => {
    alice = makeWallet();
    bob   = makeWallet();
  });

  test("T43: add — 정상 트랜잭션 추가", () => {
    const pool = new Mempool();
    const tx   = alice.send(bob.address, 10, 1, 0);
    const { ok } = pool.add(tx);
    expect(ok).toBe(true);
    expect(pool.size()).toBe(1);
  });

  test("T44: add — 중복 트랜잭션 거부", () => {
    const pool = new Mempool();
    const tx   = alice.send(bob.address, 10, 1, 0);
    pool.add(tx);
    const { ok, reason } = pool.add(tx);
    expect(ok).toBe(false);
    expect(reason).toBe("duplicate");
  });

  test("T45: add — minFee 미달 거부", () => {
    const pool = new Mempool({ minFee: 5 });
    const tx   = alice.send(bob.address, 10, 2, 0); // fee=2 < minFee=5
    const { ok, reason } = pool.add(tx);
    expect(ok).toBe(false);
    expect(reason).toContain("minFee");
  });

  test("T46: selectForBlock — 수수료 내림차순 정렬", () => {
    const pool = new Mempool();
    const tx1  = alice.send(bob.address, 10, 5, 0);
    const tx2  = alice.send(bob.address, 10, 2, 1);
    const tx3  = alice.send(bob.address, 10, 8, 2);
    pool.add(tx1); pool.add(tx2); pool.add(tx3);

    const selected = pool.selectForBlock(3);
    expect(selected[0].fee).toBeGreaterThanOrEqual(selected[1].fee);
    expect(selected[1].fee).toBeGreaterThanOrEqual(selected[2].fee);
  });

  test("T47: expire — 오래된 트랜잭션 제거", () => {
    const pool = new Mempool();
    // 타임스탬프를 과거로 조작한 트랜잭션 직접 삽입
    const tx: TxType = {
      id:        "a".repeat(64),
      from:      alice.address,
      to:        bob.address,
      amount:    10,
      fee:       1,
      timestamp: Date.now() - 7_200_000, // 2시간 전
      signature: "s".repeat(64),
      nonce:     0,
    };
    pool["pool"].set(tx.id, tx);
    expect(pool.size()).toBe(1);
    const removed = pool.expire(3_600_000); // 1시간 이상 → 만료
    expect(removed).toBe(1);
    expect(pool.size()).toBe(0);
  });

  test("T48: getStats — 통계 계산", () => {
    const pool = new Mempool();
    pool.add(alice.send(bob.address, 10, 3, 0));
    pool.add(alice.send(bob.address, 10, 7, 1));
    pool.add(alice.send(bob.address, 10, 1, 2));

    const stats = pool.getStats();
    expect(stats.count).toBe(3);
    expect(stats.maxFee).toBe(7);
    expect(stats.minFee).toBe(1);
    expect(stats.totalFees).toBe(11);
  });
});
