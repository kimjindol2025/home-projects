/**
 * SaaS 구독 관리 시스템
 * 플랜, 결제, 갱신, 취소
 */

// 구독 플랜
export interface Plan {
  id: string;
  name: string; // "Starter" | "Pro" | "Enterprise"
  price: number; // 월 가격 (달러)
  features: string[];
  maxUsers: number;
  maxStorage: number; // GB
  billingCycle: number; // 30일
}

export const plans: { [key: string]: Plan } = {
  starter: {
    id: 'plan_starter',
    name: 'Starter',
    price: 29,
    features: ['API Access', 'Basic Analytics', '5GB Storage'],
    maxUsers: 5,
    maxStorage: 5,
    billingCycle: 30,
  },
  pro: {
    id: 'plan_pro',
    name: 'Pro',
    price: 99,
    features: [
      'API Access',
      'Advanced Analytics',
      '100GB Storage',
      'Custom Domain',
      'Priority Support',
    ],
    maxUsers: 50,
    maxStorage: 100,
    billingCycle: 30,
  },
  enterprise: {
    id: 'plan_enterprise',
    name: 'Enterprise',
    price: 499,
    features: [
      'Unlimited API',
      'Custom Analytics',
      'Unlimited Storage',
      'Custom Domain',
      '24/7 Support',
      'SLA Guarantee',
    ],
    maxUsers: 10000,
    maxStorage: 10000,
    billingCycle: 30,
  },
};

// 구독 상태
export enum SubscriptionStatus {
  ACTIVE = 'active',
  PAUSED = 'paused',
  CANCELLED = 'cancelled',
  EXPIRED = 'expired',
}

// 결제 상태
export enum PaymentStatus {
  PENDING = 'pending',
  SUCCESS = 'success',
  FAILED = 'failed',
  REFUNDED = 'refunded',
}

// 구독 정보
export interface Subscription {
  id: string;
  userId: number;
  planId: string;
  status: SubscriptionStatus;
  startDate: string;
  endDate: string;
  nextBillingDate: string;
  usersUsed: number;
  storageUsed: number; // GB
  paymentMethod?: string; // 'card' | 'bank' | 'crypto'
  lastPayment?: Payment;
}

// 결제 기록
export interface Payment {
  id: string;
  subscriptionId: string;
  amount: number;
  currency: string; // 'USD' | 'KRW' | 'EUR'
  status: PaymentStatus;
  paymentDate: string;
  dueDate: string;
  invoiceUrl?: string;
}

// 구독 관리자
export class SubscriptionManager {
  private subscriptions: Map<string, Subscription> = new Map();
  private payments: Map<string, Payment[]> = new Map();
  private subscriptionIdCounter = 1;
  private paymentIdCounter = 1;

  // 구독 생성
  createSubscription(
    userId: number,
    planId: string,
    paymentMethod: string = 'card'
  ): Subscription {
    const plan = plans[planId] || plans.starter;
    const startDate = new Date().toISOString();
    const endDate = new Date(Date.now() + plan.billingCycle * 24 * 60 * 60 * 1000)
      .toISOString();
    const nextBillingDate = endDate;

    const subscription: Subscription = {
      id: `sub_${this.subscriptionIdCounter++}`,
      userId,
      planId,
      status: SubscriptionStatus.ACTIVE,
      startDate,
      endDate,
      nextBillingDate,
      usersUsed: 1,
      storageUsed: 0,
      paymentMethod,
    };

    this.subscriptions.set(subscription.id, subscription);

    // 초기 결제 처리
    const payment = this.processPayment(subscription.id, plan.price);
    subscription.lastPayment = payment;

    return subscription;
  }

  // 구독 조회
  getSubscription(subscriptionId: string): Subscription | null {
    return this.subscriptions.get(subscriptionId) || null;
  }

  // 사용자별 구독 조회
  getUserSubscriptions(userId: number): Subscription[] {
    return Array.from(this.subscriptions.values()).filter(
      (sub) => sub.userId === userId
    );
  }

  // 플랜 업그레이드
  upgradePlan(subscriptionId: string, newPlanId: string): Subscription | null {
    const subscription = this.subscriptions.get(subscriptionId);
    if (!subscription) return null;

    const oldPlan = plans[subscription.planId];
    const newPlan = plans[newPlanId];

    if (!oldPlan || !newPlan) return null;

    // 차액 계산
    const priceDiff = newPlan.price - oldPlan.price;

    subscription.planId = newPlanId;
    // 프로레이타 계산
    if (priceDiff > 0) {
      this.processPayment(subscriptionId, priceDiff);
    }

    return subscription;
  }

  // 플랜 다운그레이드
  downgradePlan(subscriptionId: string, newPlanId: string): Subscription | null {
    const subscription = this.subscriptions.get(subscriptionId);
    if (!subscription) return null;

    const oldPlan = plans[subscription.planId];
    const newPlan = plans[newPlanId];

    if (!oldPlan || !newPlan) return null;

    subscription.planId = newPlanId;
    // 환불 처리
    const refundAmount = oldPlan.price - newPlan.price;
    if (refundAmount > 0) {
      this.processRefund(subscriptionId, refundAmount);
    }

    return subscription;
  }

  // 구독 일시 중지
  pauseSubscription(subscriptionId: string): Subscription | null {
    const subscription = this.subscriptions.get(subscriptionId);
    if (!subscription) return null;

    subscription.status = SubscriptionStatus.PAUSED;
    return subscription;
  }

  // 구독 재개
  resumeSubscription(subscriptionId: string): Subscription | null {
    const subscription = this.subscriptions.get(subscriptionId);
    if (!subscription) return null;

    subscription.status = SubscriptionStatus.ACTIVE;
    return subscription;
  }

  // 구독 취소
  cancelSubscription(subscriptionId: string): Subscription | null {
    const subscription = this.subscriptions.get(subscriptionId);
    if (!subscription) return null;

    subscription.status = SubscriptionStatus.CANCELLED;
    return subscription;
  }

  // 결제 처리
  private processPayment(subscriptionId: string, amount: number): Payment {
    const payment: Payment = {
      id: `pay_${this.paymentIdCounter++}`,
      subscriptionId,
      amount,
      currency: 'USD',
      status: PaymentStatus.SUCCESS,
      paymentDate: new Date().toISOString(),
      dueDate: new Date(Date.now() + 30 * 24 * 60 * 60 * 1000).toISOString(),
      invoiceUrl: `https://invoices.example.com/${subscriptionId}`,
    };

    if (!this.payments.has(subscriptionId)) {
      this.payments.set(subscriptionId, []);
    }
    this.payments.get(subscriptionId)!.push(payment);

    return payment;
  }

  // 환불 처리
  private processRefund(subscriptionId: string, amount: number): Payment {
    const payment: Payment = {
      id: `pay_${this.paymentIdCounter++}`,
      subscriptionId,
      amount: -amount,
      currency: 'USD',
      status: PaymentStatus.REFUNDED,
      paymentDate: new Date().toISOString(),
      dueDate: new Date().toISOString(),
    };

    if (!this.payments.has(subscriptionId)) {
      this.payments.set(subscriptionId, []);
    }
    this.payments.get(subscriptionId)!.push(payment);

    return payment;
  }

  // 결제 기록 조회
  getPaymentHistory(subscriptionId: string): Payment[] {
    return this.payments.get(subscriptionId) || [];
  }

  // 만료된 구독 갱신
  renewSubscription(subscriptionId: string): Subscription | null {
    const subscription = this.subscriptions.get(subscriptionId);
    if (!subscription) return null;

    const plan = plans[subscription.planId];
    if (!plan) return null;

    subscription.endDate = new Date(
      Date.now() + plan.billingCycle * 24 * 60 * 60 * 1000
    ).toISOString();
    subscription.nextBillingDate = subscription.endDate;
    subscription.status = SubscriptionStatus.ACTIVE;

    this.processPayment(subscriptionId, plan.price);

    return subscription;
  }

  // 통계
  getMetrics() {
    const subscriptions = Array.from(this.subscriptions.values());
    const totalRevenue = Array.from(this.payments.values())
      .flat()
      .reduce((sum, p) => sum + p.amount, 0);

    return {
      totalSubscriptions: subscriptions.length,
      activeSubscriptions: subscriptions.filter(
        (s) => s.status === SubscriptionStatus.ACTIVE
      ).length,
      cancelledSubscriptions: subscriptions.filter(
        (s) => s.status === SubscriptionStatus.CANCELLED
      ).length,
      totalRevenue,
      monthlyRecurringRevenue: subscriptions
        .filter((s) => s.status === SubscriptionStatus.ACTIVE)
        .reduce((sum, s) => sum + plans[s.planId].price, 0),
    };
  }
}

export const subscriptionManager = new SubscriptionManager();
