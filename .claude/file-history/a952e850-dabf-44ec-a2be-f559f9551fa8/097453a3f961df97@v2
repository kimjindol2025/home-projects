/**
 * Comprehensive HTTP System Tests
 */

import { HTTPSystem } from './http-system';
import { HTTPResponseBuilder } from './response';
import { HTTPRouter } from './router';
import { HTTPHeaders } from './headers';
import { QueryParser } from './query';
import { HTTP } from './index';

describe('FreeLang v4 HTTP Functions', () => {
  let httpSystem: HTTPSystem;

  beforeEach(() => {
    jest.setTimeout(15000);
    httpSystem = new HTTPSystem({ port: 3001 });
  });

  // ============== 1. HTTP Server Tests ==============
  describe('1. http_serve - Server Setup', () => {
    it('should create HTTP server', async () => {
      expect(httpSystem).toBeDefined();
      expect(httpSystem.isRunning()).toBe(false);
    });

    it('should get server info', () => {
      const info = httpSystem.getServerInfo();
      expect(info).toBeDefined();
      expect(info.port).toBe(3001);
    });

    it('should have empty routes initially', () => {
      expect(httpSystem.getRouteCount()).toBe(0);
    });

    it('should provide response builder', () => {
      const response = httpSystem.response();
      expect(response).toBeDefined();
    });
  });

  // ============== 2. HTTP Routing Tests ==============
  describe('2. http_route - Path Routing', () => {
    it('should register GET route', () => {
      httpSystem.get('/api/users', async (req, res) => {
        res.statusCode = 200;
        return res;
      });

      expect(httpSystem.getRouteCount()).toBe(1);
    });

    it('should register POST route', () => {
      httpSystem.post('/api/users', async (req, res) => {
        res.statusCode = 201;
        return res;
      });

      expect(httpSystem.getRouteCount()).toBe(1);
    });

    it('should support dynamic parameters (/users/:id)', () => {
      httpSystem.get('/users/:id', async (req, res) => {
        expect(req.params?.id).toBeDefined();
        res.statusCode = 200;
        return res;
      });

      const routes = httpSystem.listRoutes();
      expect(routes.length).toBeGreaterThan(0);
    });

    it('should support multiple parameters', () => {
      httpSystem.get('/posts/:postId/comments/:commentId', async (req, res) => {
        res.statusCode = 200;
        return res;
      });

      const routes = httpSystem.listRoutes();
      expect(routes.some((r) => r.pattern.includes(':postId'))).toBe(true);
    });

    it('should support wildcard routes', () => {
      httpSystem.get('/files/*', async (req, res) => {
        res.statusCode = 200;
        return res;
      });

      expect(httpSystem.getRouteCount()).toBeGreaterThan(0);
    });

    it('should register method shortcuts', () => {
      httpSystem
        .get('/api/a', async (req, res) => res)
        .post('/api/b', async (req, res) => res)
        .put('/api/c', async (req, res) => res)
        .delete('/api/d', async (req, res) => res)
        .patch('/api/e', async (req, res) => res);

      expect(httpSystem.getRouteCount()).toBe(5);
    });

    it('should support route chaining', () => {
      const initialCount = httpSystem.getRouteCount();
      httpSystem.get('/chain1', async (req, res) => res).get('/chain2', async (req, res) => res);

      expect(httpSystem.getRouteCount()).toBeGreaterThan(initialCount);
    });

    it('should list all routes', () => {
      httpSystem.get('/test1', async (req, res) => res);
      httpSystem.post('/test2', async (req, res) => res);

      const routes = httpSystem.listRoutes();
      expect(Array.isArray(routes)).toBe(true);
      expect(routes.length).toBeGreaterThan(0);
    });
  });

  // ============== 3. HTTP Response Tests ==============
  describe('3. http_response - Response Building', () => {
    it('should build OK response', () => {
      const response = new HTTPResponseBuilder().ok({ message: 'Success' });
      expect((response as any).statusCode).toBe(200);
      expect((response as any).headers['Content-Type']).toBe('application/json');
    });

    it('should build JSON response', () => {
      const response = new HTTPResponseBuilder().json({ data: 'test' }).build();
      expect((response as any).body).toBeDefined();
      expect((response as any).headers['Content-Type']).toBe('application/json');
    });

    it('should build HTML response', () => {
      const response = new HTTPResponseBuilder().html('<h1>Test</h1>').build();
      expect((response as any).headers['Content-Type']).toBe('text/html; charset=utf-8');
    });

    it('should build text response', () => {
      const response = new HTTPResponseBuilder().text('Plain text').build();
      expect((response as any).headers['Content-Type']).toBe('text/plain; charset=utf-8');
    });

    it('should support streaming chunks', () => {
      const response = new HTTPResponseBuilder()
        .chunk('chunk1')
        .chunk('chunk2')
        .streaming(true)
        .build();

      expect(response.streaming).toBe(true);
      expect(response.chunks).toBeDefined();
      expect(response.chunks?.length).toBe(2);
    });

    it('should build error responses', () => {
      const badReq = new HTTPResponseBuilder().badRequest('Invalid input');
      const notFound = new HTTPResponseBuilder().notFound('Not found');
      const error = new HTTPResponseBuilder().internalError('Server error');

      expect((badReq as any).statusCode).toBe(400);
      expect((notFound as any).statusCode).toBe(404);
      expect((error as any).statusCode).toBe(500);
    });

    it('should support custom status codes', () => {
      const response = new HTTPResponseBuilder().status(201).json({ created: true }).build();
      expect((response as any).statusCode).toBe(201);
    });

    it('should support cache control', () => {
      const response = new HTTPResponseBuilder().cache(3600).build();
      expect(response.headers['Cache-Control']).toContain('max-age=3600');
    });

    it('should support CORS', () => {
      const response = new HTTPResponseBuilder().cors('https://example.com').build();
      expect(response.headers['Access-Control-Allow-Origin']).toBe('https://example.com');
    });

    it('should support security headers', () => {
      const response = new HTTPResponseBuilder().securityHeaders().build();
      expect(response.headers['X-Content-Type-Options']).toBe('nosniff');
      expect(response.headers['X-Frame-Options']).toBe('DENY');
    });

    it('should support download headers', () => {
      const response = new HTTPResponseBuilder()
        .download('data.json')
        .build();
      expect(response.headers['Content-Disposition']).toContain('attachment');
    });

    it('should support cookies', () => {
      const response = new HTTPResponseBuilder()
        .cookie('sessionId', 'abc123', { httpOnly: true })
        .build();

      const setCookie = response.headers['Set-Cookie'];
      expect(setCookie).toBeDefined();
      expect(String(setCookie)).toContain('sessionId');
    });

    it('should support redirects', () => {
      const response = HTTPResponseBuilder.prototype.redirect('/new-path');
      expect(response.statusCode).toBe(302);
      expect(response.headers['Location']).toBe('/new-path');
    });

    it('should chain methods', () => {
      const response = new HTTPResponseBuilder()
        .status(201)
        .header('X-Custom', 'value')
        .json({ success: true })
        .cache(3600)
        .build();

      expect(response.statusCode).toBe(201);
      expect(response.headers['X-Custom']).toBe('value');
    });
  });

  // ============== 4. HTTP Headers Tests ==============
  describe('4. http_header - Header Management', () => {
    it('should set and get headers', () => {
      const headers = new HTTPHeaders().set('X-Custom', 'value');
      expect(headers.get('X-Custom')).toBe('value');
    });

    it('should set Content-Type', () => {
      const headers = new HTTPHeaders().json();
      expect(headers.get('Content-Type')).toBe('application/json');
    });

    it('should set Bearer auth', () => {
      const headers = new HTTPHeaders().bearer('token123');
      expect(headers.get('Authorization')).toBe('Bearer token123');
    });

    it('should set Basic auth', () => {
      const headers = new HTTPHeaders().basic('user', 'pass');
      expect(headers.get('Authorization')).toContain('Basic');
    });

    it('should set cache control', () => {
      const headers = new HTTPHeaders().maxAge(3600);
      expect(headers.get('Cache-Control')).toContain('max-age=3600');
    });

    it('should set no-cache', () => {
      const headers = new HTTPHeaders().noCache();
      expect(headers.get('Cache-Control')).toContain('no-cache');
    });

    it('should set CORS headers', () => {
      const headers = new HTTPHeaders().cors();
      expect(headers.get('Access-Control-Allow-Origin')).toBe('*');
    });

    it('should set security headers', () => {
      const headers = new HTTPHeaders().security();
      expect(headers.get('X-Content-Type-Options')).toBe('nosniff');
    });

    it('should manage cookies', () => {
      const headers = new HTTPHeaders().setCookie({
        name: 'sessionId',
        value: 'abc123',
        maxAge: 86400,
      });

      const setCookie = headers.get('Set-Cookie');
      expect(String(setCookie)).toContain('sessionId=abc123');
    });

    it('should parse cookies', () => {
      const headers = new HTTPHeaders();
      const cookies = headers.parseCookies('name=value; path=/');
      expect(cookies.name).toBe('value');
    });

    it('should clear cookies', () => {
      const headers = new HTTPHeaders().setCookie({
        name: 'test',
        value: 'val',
      }).clearCookie('test');

      expect(headers.has('Set-Cookie')).toBe(true);
    });

    it('should validate headers', () => {
      const valid = HTTPHeaders.validate('X-Custom', 'value');
      const invalid = HTTPHeaders.validate('', 'value');
      expect(valid).toBe(true);
      expect(invalid).toBe(false);
    });

    it('should get header size', () => {
      const headers = new HTTPHeaders().set('Content-Type', 'application/json').set('Cache-Control', 'public');
      const size = headers.getSize();
      expect(size).toBeGreaterThan(0);
    });
  });

  // ============== 5. Query Parsing Tests ==============
  describe('5. http_parse_query - Query String Parsing', () => {
    it('should parse simple query', () => {
      const result = QueryParser.parse('name=John&age=30');
      expect(result.success).toBe(true);
      expect(result.data?.name).toBe('John');
      expect(result.data?.age).toBe('30');
    });

    it('should parse empty query', () => {
      const result = QueryParser.parse('');
      expect(result.success).toBe(true);
      expect(result.data).toEqual({});
    });

    it('should handle URL encoding', () => {
      const result = QueryParser.parse('search=hello%20world&tag=c%2B%2B');
      expect(result.data?.search).toBe('hello world');
      expect(result.data?.tag).toBe('c++');
    });

    it('should parse array values', () => {
      const result = QueryParser.parse('colors[]=red&colors[]=green&colors[]=blue');
      expect(Array.isArray(result.data?.colors)).toBe(true);
      expect((result.data?.colors as string[]).length).toBe(3);
    });

    it('should handle duplicate keys', () => {
      const result = QueryParser.parse('id=1&id=2&id=3');
      expect(Array.isArray(result.data?.id)).toBe(true);
    });

    it('should parse from URL', () => {
      const result = QueryParser.parseFromURL('https://example.com?search=test&page=1');
      expect(result.data?.search).toBe('test');
      expect(result.data?.page).toBe('1');
    });

    it('should build query string', () => {
      const query = QueryParser.build({ name: 'John', age: '30' });
      expect(query).toContain('name=John');
      expect(query).toContain('age=30');
    });

    it('should convert to map', () => {
      const map = QueryParser.toMap('name=John&city=NYC');
      expect(map.get('name')).toBe('John');
      expect(map.get('city')).toBe('NYC');
    });

    it('should get query statistics', () => {
      const stats = QueryParser.getStats('a=1&b=2&c=3');
      expect(stats.paramCount).toBe(3);
      expect(stats.size).toBeGreaterThan(0);
    });

    it('should validate query parameters', () => {
      const valid = QueryParser.validate('key', 'value');
      const invalid = QueryParser.validate('key', '<script>alert(1)</script>');
      expect(valid.valid).toBe(true);
      expect(invalid.valid).toBe(false);
    });

    it('should merge queries', () => {
      const merged = QueryParser.merge('a=1&b=2', 'c=3&d=4');
      expect(merged.a).toBe('1');
      expect(merged.c).toBe('3');
    });

    it('should filter query', () => {
      const query = { name: 'John', age: '30', password: 'secret' };
      const filtered = QueryParser.filter(query, (k) => k !== 'password');
      expect(filtered.password).toBeUndefined();
      expect(filtered.name).toBe('John');
    });
  });

  // ============== Router Tests ==============
  describe('Router - Dynamic Routing', () => {
    it('should validate route patterns', () => {
      const result = HTTPRouter.validatePattern('/users/:id');
      expect(result.valid).toBe(true);
    });

    it('should reject invalid patterns', () => {
      const result = HTTPRouter.validatePattern('');
      expect(result.valid).toBe(false);
    });

    it('should count routes', () => {
      const router = new HTTPRouter();
      router.get('/test1', async (req, res) => res);
      router.post('/test2', async (req, res) => res);
      expect(router.getRouteCount()).toBe(2);
    });

    it('should clear routes', () => {
      const router = new HTTPRouter();
      router.get('/test', async (req, res) => res);
      expect(router.getRouteCount()).toBe(1);
      router.clear();
      expect(router.getRouteCount()).toBe(0);
    });
  });

  // ============== Statistics Tests ==============
  describe('Statistics & Monitoring', () => {
    it('should provide server statistics', () => {
      const stats = httpSystem.getStatistics();
      expect(stats).toBeDefined();
      expect(stats.requestsReceived).toBe(0);
    });

    it('should reset statistics', () => {
      httpSystem.resetStatistics();
      const stats = httpSystem.getStatistics();
      expect(stats.requestsReceived).toBe(0);
    });

    it('should provide performance report', () => {
      const report = httpSystem.getPerformanceReport();
      expect(report).toBeDefined();
      expect(report.successRate).toBeDefined();
    });
  });

  // ============== Integration Tests ==============
  describe('Integration Tests', () => {
    it('should coordinate all modules', () => {
      httpSystem
        .get('/api/users/:id', async (req, res) => {
          const query = QueryParser.parse('search=test');
          const response = new HTTPResponseBuilder()
            .json({ userId: req.params?.id, query: query.data })
            .build();
          return response;
        });

      expect(httpSystem.getRouteCount()).toBe(1);
    });

    it('should handle complex workflows', () => {
      const response = httpSystem
        .response()
        .status(200)
        .json({ data: [1, 2, 3] })
        .cache(3600)
        .cors()
        .securityHeaders()
        .build();

      expect(response.statusCode).toBe(200);
      expect(response.headers['Cache-Control']).toBeDefined();
      expect(response.headers['Access-Control-Allow-Origin']).toBeDefined();
    });

    it('should parse and handle queries', () => {
      const result = httpSystem.parseQuery('search=freelang&limit=10&tags[]=http&tags[]=api');
      expect(result.data?.search).toBe('freelang');
      expect(result.data?.limit).toBe('10');
      expect(Array.isArray(result.data?.tags)).toBe(true);
    });

    it('should support complete request handling flow', () => {
      httpSystem.post('/data', async (req, res) => {
        // Parse request
        const params = req.params || {};

        // Build response
        return httpSystem
          .response()
          .status(201)
          .json({ created: true, params })
          .build();
      });

      const routes = httpSystem.listRoutes();
      expect(routes.length).toBeGreaterThan(0);
    });
  });

  // ============== Comprehensive Test ==============
  describe('Comprehensive HTTP Functions', () => {
    it('should pass all 5 HTTP functions', () => {
      // 1. http_serve
      const serverInfo = httpSystem.getServerInfo();
      expect(serverInfo).toBeDefined();

      // 2. http_route
      httpSystem.get('/api/test/:id', async (req, res) => {
        res.statusCode = 200;
        return res;
      });
      expect(httpSystem.getRouteCount()).toBeGreaterThan(0);

      // 3. http_response
      const response = httpSystem.response().json({ test: 'data' }).build();
      expect((response as any).statusCode).toBe(200);

      // 4. http_header
      const headers = new HTTPHeaders().bearer('token').json();
      expect(String(headers.get('Authorization'))).toContain('Bearer');

      // 5. http_parse_query
      const query = QueryParser.parse('key=value&page=1');
      expect(query.data?.key).toBe('value');
    });
  });

  // ============== HTTP Namespace (Phase 3.4) ==============
  describe('📋 HTTP Namespace (Phase 3.4)', () => {
    it('should have HTTP namespace object', () => {
      expect(HTTP).toBeDefined();
      expect(typeof HTTP).toBe('object');
    });

    it('should create independent HTTPSystem instances via HTTP.create()', () => {
      const http1 = HTTP.create({ port: 3002 });
      const http2 = HTTP.create({ port: 3003 });

      expect(http1).toBeDefined();
      expect(http2).toBeDefined();
      expect(http1).not.toBe(http2);
      expect(http1.getServerInfo().port).toBe(3002);
      expect(http2.getServerInfo().port).toBe(3003);
    });

    it('should create HTTPResponseBuilder via HTTP.response()', () => {
      const builder = HTTP.response();
      expect(builder).toBeDefined();
      expect(builder instanceof HTTPResponseBuilder).toBe(true);
    });

    it('should create HTTPHeaders via HTTP.headers()', () => {
      const headers = HTTP.headers();
      expect(headers).toBeDefined();
      expect(headers instanceof HTTPHeaders).toBe(true);
    });

    it('should provide QueryParser via HTTP.queryParser', () => {
      expect(HTTP.queryParser).toBeDefined();
      expect(typeof HTTP.queryParser.parse).toBe('function');
      const query = HTTP.queryParser.parse('test=value');
      expect(query.data?.test).toBe('value');
    });
  });
});
