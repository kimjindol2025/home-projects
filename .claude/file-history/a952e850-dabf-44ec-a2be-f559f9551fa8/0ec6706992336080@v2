use JSON as FlJSON;
use String as FlString;

// 테스트 결과
type TestResult = {
  passed: Number,
  failed: Number,
  tests: Array<String>
};

let result: TestResult = {
  passed: 0,
  failed: 0,
  tests: []
};

function assert(condition: Boolean, message: String) {
  if (condition) {
    print("✅ " + message);
    result.passed = result.passed + 1;
  } else {
    print("❌ " + message);
    result.failed = result.failed + 1;
  }
  result.tests.push(message);
}

print("\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
print("🧪 FreeLang Enterprise Platform 통합 테스트");
print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n");

// ============ 1. SaaS 테스트 ============
print("💳 1. SaaS 구독 관리 테스트");

// 구독 생성
let subId1 = createSubscription(1, "starter");
assert(subId1 != null && subId1 != "", "Starter 플랜 구독");

let subId2 = createSubscription(2, "pro");
assert(subId2 != null, "Pro 플랜 구독");

let subId3 = createSubscription(3, "enterprise");
assert(subId3 != null, "Enterprise 플랜 구독");

// 플랜 업그레이드
let upgraded = upgradePlan(subId1, "pro");
assert(upgraded, "Starter → Pro 업그레이드");

// SaaS 메트릭
let saasMetrics = FlJSON.parse(getSaaSMetrics());
assert(saasMetrics.activeSubscriptions == 3, "활성 구독 3개");
assert(saasMetrics.monthlyRecurringRevenue > 0, "월간 반복 수익 계산");

// ============ 2. 금융 API 테스트 ============
print("\n💰 2. 금융 API 테스트");

// 계좌 생성
let account1 = createAccount(1, 10000);
assert(account1.userId == 1, "사용자 1 계좌 생성");
assert(account1.cash == 10000, "초기 자금 10000");

let account2 = createAccount(2, 50000);
assert(account2.cash == 50000, "사용자 2 계좌 생성");

// 주가 업데이트
updateQuote("AAPL", 150.0, 149.5, 150.5);
updateQuote("GOOGL", 2800.0, 2799.0, 2801.0);
updateQuote("MSFT", 350.0, 349.5, 350.5);

assert(true, "3개 종목 가격 업데이트");

// 매수
let buyResult1 = buyStock(1, "AAPL", 10);
assert(buyResult1, "AAPL 10주 매수");

let buyResult2 = buyStock(2, "GOOGL", 5);
assert(buyResult2, "GOOGL 5주 매수");

let buyResult3 = buyStock(2, "MSFT", 20);
assert(buyResult3, "MSFT 20주 매수");

// 포트폴리오 조회
let portfolio1 = FlJSON.parse(getPortfolio(1));
assert(portfolio1.totalValue < 10000, "수수료로 인한 총자산 감소");
assert(portfolio1.positions != null, "포트폴리오 포지션");

let portfolio2 = FlJSON.parse(getPortfolio(2));
assert(portfolio2.positions != null, "다중 포지션 보유");

// ============ 3. 실시간 알림 테스트 ============
print("\n📢 3. 실시간 알림 시스템 테스트");

// 채널 구독
subscribe(1, "price_alerts");
subscribe(2, "price_alerts");
subscribe(1, "trade_updates");
subscribe(3, "payment_alerts");

assert(true, "4개 구독 생성");

// 알림 발송
publishNotification("price_alerts", "price_alert", "AAPL 가격이 150달러를 초과했습니다");
assert(true, "가격 알림 발송");

publishNotification("trade_updates", "trade_executed", "MSFT 20주 매수 완료");
assert(true, "거래 완료 알림");

publishNotification("payment_alerts", "payment_confirmed", "결제 처리 완료");
assert(true, "결제 확인 알림");

// 사용자 알림 조회
let notif1 = FlJSON.parse(getUserNotifications(1));
assert(notif1.totalNotifications == 2, "사용자 1의 2개 알림");
assert(notif1.unreadCount == 2, "모두 미읽음");

let notif2 = FlJSON.parse(getUserNotifications(2));
assert(notif2.totalNotifications == 2, "사용자 2의 2개 알림");

// ============ 4. IoT 센서 테스트 ============
print("\n🌡️  4. IoT 에지 컴퓨팅 테스트");

// 디바이스 등록
let device1 = registerDevice("device_001", "온실", "서울");
assert(device1.id == "device_001", "온실 센서 등록");
assert(device1.battery == 100, "초기 배터리 100%");

let device2 = registerDevice("device_002", "냉장고", "서울");
assert(device2.id == "device_002", "냉장고 센서 등록");

// 센서 데이터 기록
recordSensorData("device_001", "temperature", 25.5);
recordSensorData("device_001", "humidity", 65.0);
recordSensorData("device_001", "pressure", 1013.25);

recordSensorData("device_002", "temperature", 4.2);
recordSensorData("device_002", "humidity", 40.0);

assert(true, "5개 센서 데이터 기록");

// 온도 경고 테스트 (범위 밖)
recordSensorData("device_001", "temperature", 55.0);
assert(true, "비정상 온도 감지");

// 디바이스 메트릭
let metrics1 = FlJSON.parse(getDeviceMetrics("device_001"));
assert(metrics1.totalReadings == 4, "device_001: 4개 센서 읽기");
assert(metrics1.averageTemperature > 0, "온도 평균 계산");

let metrics2 = FlJSON.parse(getDeviceMetrics("device_002"));
assert(metrics2.totalReadings == 2, "device_002: 2개 센서 읽기");

// ============ 5. 엔터프라이즈 기능 테스트 ============
print("\n🏢 5. 엔터프라이즈 멀티테넌트 테스트");

// 테넌트 생성
let tenant1 = createTenant("Acme Corp");
assert(tenant1 != null && tenant1 != "", "Acme Corp 테넌트");

let tenant2 = createTenant("TechStart Inc");
assert(tenant2 != null, "TechStart Inc 테넌트");

let tenant3 = createTenant("Global Solutions");
assert(tenant3 != null, "Global Solutions 테넌트");

// 테넌트 사용자 추가
let userAdded1 = addTenantUser(tenant1, "admin@acme.com", "admin");
assert(userAdded1, "Acme 관리자 추가");

let userAdded2 = addTenantUser(tenant1, "user@acme.com", "user");
assert(userAdded2, "Acme 일반 사용자 추가");

let userAdded3 = addTenantUser(tenant2, "ceo@techstart.com", "admin");
assert(userAdded3, "TechStart 관리자 추가");

// 테넌트 정보 조회
let tenantInfo1 = FlJSON.parse(getTenantInfo(tenant1));
assert(tenantInfo1.userCount == 2, "Acme 2명 사용자");
assert(tenantInfo1.recentAuditLogs != null, "감시 로그 기록");

// 엔터프라이즈 메트릭
let entMetrics = FlJSON.parse(getEnterpriseMetrics());
assert(entMetrics.totalTenants == 3, "3개 테넌트");
assert(entMetrics.totalUsers == 3, "총 3명 사용자");

// ============ 통합 시나리오 ============
print("\n🎯 6. 통합 시나리오 테스트");

// 시나리오: SaaS 사용자 → 금융 거래 → 알림 → IoT 모니터링
print("   시나리오 1: 완전한 워크플로우");

// 1단계: SaaS 구독
let newSub = createSubscription(10, "pro");
assert(newSub != null, "신규 사용자 Pro 구독");

// 2단계: 금융 계좌
createAccount(10, 25000);
assert(true, "거래용 계좌 개설");

// 3단계: 거래
subscribe(10, "trade_updates");
updateQuote("TSLA", 250.0, 249.0, 251.0);
let buyTesla = buyStock(10, "TSLA", 15);
assert(buyTesla, "TSLA 15주 매수");

// 4단계: 알림
publishNotification("trade_updates", "trade_executed", "사용자 10의 TSLA 거래 완료");
let notif10 = FlJSON.parse(getUserNotifications(10));
assert(notif10.totalNotifications > 0, "거래 완료 알림 수신");

// 5단계: IoT 모니터링
registerDevice("trading_room_sensor", "거래실 센서", "뉴욕");
recordSensorData("trading_room_sensor", "temperature", 22.0);
assert(true, "거래실 환경 모니터링");

// ============ 결과 출력 ============
print("\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
print("📈 테스트 결과");
print("✅ 통과: " + String.from(result.passed) + "개");
print("❌ 실패: " + String.from(result.failed) + "개");

if (result.passed + result.failed > 0) {
  let percentage = (result.passed / (result.passed + result.failed)) * 100;
  print("📊 성공률: " + String.from(percentage) + "%");
}

print("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n");

if (result.failed == 0) {
  print("🎉 모든 테스트 통과!");
} else {
  print("⚠️  " + String.from(result.failed) + "개 테스트 실패");
}
