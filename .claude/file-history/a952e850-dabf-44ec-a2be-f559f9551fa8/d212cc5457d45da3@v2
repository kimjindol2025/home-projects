/**
 * FreeLang v4 Blog API - 통합 테스트
 * 실전 시나리오 검증
 */

import initializeDatabase from '../src/models';
import { hashPassword, generateToken, searchPosts, normalizePost } from '../src/utils';
import { String as FlString, Regex, Security } from 'freelang-v4';

let testResults = { passed: 0, failed: 0 };

const assert = (condition: boolean, message: string) => {
  if (condition) {
    console.log(`✅ ${message}`);
    testResults.passed++;
  } else {
    console.error(`❌ ${message}`);
    testResults.failed++;
  }
};

async function runTests() {
  console.log('\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
  console.log('🧪 FreeLang v4 Blog API 통합 테스트');
  console.log('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n');

  // ============ 1. 데이터베이스 초기화 ============
  console.log('📦 1. 데이터베이스 테스트');
  const orm = initializeDatabase();
  assert(orm !== null, 'ORM 초기화');

  // ============ 2. 사용자 관리 ============
  console.log('\n👤 2. 사용자 관리 테스트');

  // 비밀번호 해싱
  const passwordHash = hashPassword('SecurePassword123!');
  assert(passwordHash.hash && passwordHash.salt, '비밀번호 해싱');
  assert(passwordHash.algorithm === 'PBKDF2-SHA256', '해싱 알고리즘');

  // 사용자 생성
  const userId = orm.insert('User', {
    email: 'alice@example.com',
    password_hash: passwordHash.hash,
    name: 'Alice',
    created_at: new Date().toISOString()
  });
  assert(typeof userId === 'number', '사용자 생성');

  // 사용자 조회
  const user = orm.find('User', userId);
  assert(user && user.email === 'alice@example.com', '사용자 조회');

  // JWT 토큰 생성
  const token = generateToken(user.id, user.email);
  assert(token.token && token.token.length > 0, 'JWT 토큰 생성');

  // ============ 3. 블로그 포스트 ============
  console.log('\n📝 3. 블로그 포스트 테스트');

  // 포스트 생성
  const postData = {
    title: '  첫 번째 포스트  ',
    content: '<script>alert("xss")</script>'
  };

  const normalizedPost = normalizePost(postData);
  assert(FlString.len(normalizedPost.title) > 0, '포스트 정규화 (공백 제거)');

  const postId = orm.insert('Post', {
    user_id: userId,
    title: normalizedPost.title,
    content: normalizedPost.content,
    views: 0,
    created_at: new Date().toISOString(),
    updated_at: new Date().toISOString()
  });
  assert(typeof postId === 'number', '포스트 생성');

  // 포스트 조회
  const post = orm.find('Post', postId);
  assert(post && post.title, '포스트 조회');

  // 모든 포스트 조회
  const allPosts = orm.findAll('Post');
  assert(Array.isArray(allPosts) && allPosts.length > 0, '포스트 목록 조회');

  // 포스트 수정
  const updated = orm.update('Post', postId, { title: '수정된 제목' });
  assert(updated, '포스트 수정');

  // ============ 4. 검색 기능 ============
  console.log('\n🔍 4. 검색 기능 테스트');

  const postsToSearch = [
    { id: 1, title: 'TypeScript 배우기', content: 'TypeScript 기초' },
    { id: 2, title: 'JavaScript vs TypeScript', content: 'JS와 TS 비교' },
    { id: 3, title: 'React 튜토리얼', content: 'React 학습' }
  ];

  const searchResults = searchPosts(postsToSearch, 'TypeScript');
  assert(searchResults.length === 2, '검색 기능 (TypeScript)');

  const searchResults2 = searchPosts(postsToSearch, 'React');
  assert(searchResults2.length === 1, '검색 기능 (React)');

  // ============ 5. 댓글 시스템 ============
  console.log('\n💬 5. 댓글 시스템 테스트');

  const commentId = orm.insert('Comment', {
    post_id: postId,
    user_id: userId,
    content: '좋은 포스트입니다!',
    created_at: new Date().toISOString()
  });
  assert(typeof commentId === 'number', '댓글 생성');

  const comment = orm.find('Comment', commentId);
  assert(comment && comment.content, '댓글 조회');

  // ============ 6. 보안 검증 ============
  console.log('\n🔒 6. 보안 검증 테스트');

  // 이메일 검증
  const validEmail = Security.validateEmail('alice@example.com');
  assert(validEmail === true, '이메일 검증 (유효)');

  const invalidEmail = Security.validateEmail('invalid-email');
  assert(invalidEmail === false, '이메일 검증 (유효하지 않음)');

  // 비밀번호 강도 검증
  const weakPassword = Security.validatePasswordStrength('weak');
  assert(!weakPassword.valid, '약한 비밀번호 감지');

  const strongPassword = Security.validatePasswordStrength('StrongPassword123!@#');
  assert(strongPassword.valid, '강한 비밀번호 확인');

  // XSS 정제
  const xssContent = '<img src=x onerror="alert(1)">';
  const sanitized = Security.sanitizeHTML(xssContent);
  assert(sanitized !== xssContent, 'XSS 정제');

  // ============ 7. 데이터 일관성 ============
  console.log('\n📊 7. 데이터 일관성 테스트');

  const userCount = orm.count('User');
  assert(userCount > 0, '사용자 수 카운트');

  const postCount = orm.count('Post');
  assert(postCount > 0, '포스트 수 카운트');

  const commentCount = orm.count('Comment');
  assert(commentCount > 0, '댓글 수 카운트');

  // ============ 결과 출력 ============
  console.log('\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
  console.log(`📈 테스트 결과`);
  console.log(`✅ 통과: ${testResults.passed}개`);
  console.log(`❌ 실패: ${testResults.failed}개`);
  console.log(`📊 성공률: ${(testResults.passed / (testResults.passed + testResults.failed) * 100).toFixed(1)}%`);
  console.log('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n');

  process.exit(testResults.failed > 0 ? 1 : 0);
}

runTests().catch(error => {
  console.error('❌ 테스트 실행 오류:', error);
  process.exit(1);
});
