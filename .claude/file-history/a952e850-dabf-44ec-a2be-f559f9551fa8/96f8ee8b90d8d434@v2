## 6️⃣ 모듈 조합

여러 모듈을 조합해서 복잡한 로직 구현:

```typescript
import {
  Security,
  HTTP,
  JSON as FlJSON,
  ORM
} from 'freelang-v4';

const server = HTTP.create({ port: 3000 });

server.post('/api/register', async (req, res) => {
  try {
    const body = FlJSON.parse(req.body);

    // 검증
    if (!Security.validateEmail(body.email)) {
      return HTTP.badRequest('Invalid email');
    }

    // 비밀번호 해싱
    const passwordHash = Security.hashPassword(body.password);

    // DB 저장 (ORM)
    const orm = ORM.create();
    const userId = orm.insert('User', {
      email: body.email,
      password_hash: passwordHash
    });

    // JWT 발급
    const token = Security.createJWT(
      { userId, email: body.email },
      'secret-key',
      86400
    );

    return HTTP.created({ token: token.token });
  } catch (error) {
    return HTTP.internalError(error.message);
  }
});

await server.serve();
```

