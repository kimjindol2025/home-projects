## 9️⃣ 테스트 전략

```typescript
import { ORM, Security } from 'freelang-v4';

describe('User Registration', () => {
  let orm: any;

  beforeEach(() => {
    // 각 테스트마다 새 인스턴스 (격리)
    orm = ORM.create();
  });

  it('should validate email', () => {
    expect(Security.validateEmail('valid@example.com')).toBe(true);
    expect(Security.validateEmail('invalid')).toBe(false);
  });

  it('should hash password', () => {
    const hash = Security.hashPassword('password');
    expect(hash.hash).toBeDefined();
    expect(hash.salt).toBeDefined();
  });
});
```

