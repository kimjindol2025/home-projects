/**
 * FreeLang v4 Blog API - 미들웨어 (인증, 에러 처리)
 */

import { Security, HTTP, JSON as FlJSON } from 'freelang-v4';

export interface AuthUser {
  userId: number;
  email: string;
}

/**
 * JWT 인증 미들웨어
 */
export const authenticateUser = (authHeader?: string): AuthUser | null => {
  if (!authHeader) return null;

  const token = authHeader.replace('Bearer ', '');
  const verified = Security.verifyJWT(token, 'jwt-secret-key');

  if (!verified.valid || !verified.payload) return null;

  return {
    userId: verified.payload.userId as number,
    email: verified.payload.email as string
  };
};

/**
 * 에러 응답 생성
 */
export const errorResponse = (statusCode: number, message: string) => {
  return HTTP.response()
    .status(statusCode)
    .json({ error: message })
    .build();
};

/**
 * 성공 응답 생성
 */
export const successResponse = (data: any, statusCode: number = 200) => {
  return HTTP.response()
    .status(statusCode)
    .json(data)
    .build();
};

/**
 * 입력 검증
 */
export const validateInput = (data: any, required: string[]): string[] => {
  const errors: string[] = [];

  required.forEach((field) => {
    if (!data[field] || String(data[field]).trim() === '') {
      errors.push(`Missing required field: ${field}`);
    }
  });

  return errors;
};

export default { authenticateUser, errorResponse, successResponse, validateInput };
