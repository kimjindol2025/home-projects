## 완전한 예제

### 예제 1: 이메일 검증
```typescript
import { Regex } from 'freelang-v4';

const validateEmail = (email) => {
  const pattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  return Regex.test(email, pattern);
};

console.log(validateEmail("user@example.com"));    // true
console.log(validateEmail("invalid.email"));       // false
```

### 예제 2: 날짜 파싱
```typescript
const parseDate = (dateStr) => {
  const pattern = /(\d{4})-(\d{2})-(\d{2})/;
  const groups = Regex.groups(dateStr, pattern);

  if (groups) {
    return {
      year: parseInt(groups[1]),
      month: parseInt(groups[2]),
      day: parseInt(groups[3])
    };
  }
  return null;
};

console.log(parseDate("2024-02-27"));
// { year: 2024, month: 2, day: 27 }
```

### 예제 3: 문자열 정제
```typescript
const cleanText = (text) => {
  // HTML 태그 제거
  let clean = Regex.replace(text, /<[^>]*>/g, "");
  // 여러 공백을 하나로
  clean = Regex.replace(clean, /\s+/g, " ");
  // 양쪽 공백 제거
  return clean.trim();
};

console.log(cleanText("<p>  Hello   World  </p>"));
// "Hello World"
```

### 예제 4: URL 추출
```typescript
const extractUrls = (text) => {
  const pattern = /https?:\/\/[^\s]+/g;
  const matches = [];
  let match;
  const regex = new RegExp(pattern.source, pattern.flags);

  while ((match = regex.exec(text)) !== null) {
    matches.push(match[0]);
  }
  return matches;
};

const text = "Visit https://example.com and https://test.com";
console.log(extractUrls(text));
// ["https://example.com", "https://test.com"]
```

### 예제 5: 전화번호 포매팅
```typescript
const formatPhone = (phone) => {
  // 숫자만 추출
  const digits = Regex.replace(phone, /\D/g, "");

  if (Regex.count(digits, /\d/g) !== 10) {
    return null; // 유효하지 않음
  }

  // (XXX) XXX-XXXX 포맷
  const pattern = /(\d{3})(\d{3})(\d{4})/;
  return Regex.replace(digits, pattern, "($1) $2-$3");
};

console.log(formatPhone("555-123-4567"));
// "(555) 123-4567"
```

