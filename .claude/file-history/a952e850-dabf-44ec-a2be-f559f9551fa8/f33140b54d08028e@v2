// ============ 1. SaaS 구독 관리 ============

type Plan = {
  id: String,
  name: String,        // "Starter" | "Pro" | "Enterprise"
  price: Number,       // 월 가격 (달러)
  maxUsers: Number,
  maxStorage: Number   // GB
};

type Subscription = {
  id: String,
  userId: Number,
  planId: String,
  status: String,      // "active" | "paused" | "cancelled"
  startDate: String,
  nextBillingDate: String,
  usersUsed: Number,
  storageUsed: Number
};

type SaaSState = {
  subscriptions: Map<String, Subscription>,
  nextSubId: Number,
  plans: Map<String, Plan>
};

let saasState: SaaSState = {
  subscriptions: Map.new(),
  nextSubId: 1,
  plans: Map.new()
};

// SaaS 초기화
function initSaaS() {
  saasState.plans.set("starter", {
    id: "plan_starter",
    name: "Starter",
    price: 29,
    maxUsers: 5,
    maxStorage: 5
  });

  saasState.plans.set("pro", {
    id: "plan_pro",
    name: "Pro",
    price: 99,
    maxUsers: 50,
    maxStorage: 100
  });

  saasState.plans.set("enterprise", {
    id: "plan_enterprise",
    name: "Enterprise",
    price: 499,
    maxUsers: 10000,
    maxStorage: 10000
  });
}

function createSubscription(userId: Number, planId: String): String {
  let plan = saasState.plans.get(planId) || saasState.plans.get("starter");
  let subId = "sub_" + String.from(saasState.nextSubId++);
  let now = Date.now();

  let sub: Subscription = {
    id: subId,
    userId: userId,
    planId: planId,
    status: "active",
    startDate: Date.format(now, "yyyy-MM-dd"),
    nextBillingDate: Date.format(now + 30*24*60*60*1000, "yyyy-MM-dd"),
    usersUsed: 1,
    storageUsed: 0
  };

  saasState.subscriptions.set(subId, sub);
  return subId;
}

function upgradePlan(subId: String, newPlanId: String): Boolean {
  let sub = saasState.subscriptions.get(subId);
  if (sub == null) return false;

  sub.planId = newPlanId;
  return true;
}

function getSaaSMetrics(): String {
  let activeCount = 0;
  let totalRevenue = 0;

  saasState.subscriptions.forEach(|sub| {
    if (sub.status == "active") {
      activeCount = activeCount + 1;
      let plan = saasState.plans.get(sub.planId) || saasState.plans.get("starter");
      totalRevenue = totalRevenue + plan.price;
    }
  });

  return JSON.stringify({
    activeSubscriptions: activeCount,
    monthlyRecurringRevenue: totalRevenue,
    totalSubscriptions: saasState.subscriptions.size()
  });
}

// ============ 2. 금융 API ============

type Quote = {
  symbol: String,
  price: Number,
  bid: Number,
  ask: Number,
  change: Number
};

type Trade = {
  id: String,
  symbol: String,
  type: String,        // "buy" | "sell"
  quantity: Number,
  price: Number,
  timestamp: String
};

type Account = {
  userId: Number,
  cash: Number,
  positions: Map<String, Number>,  // symbol -> quantity
  trades: Array<Trade>
};

type FinanceState = {
  quotes: Map<String, Quote>,
  accounts: Map<Number, Account>,
  nextTradeId: Number
};

let financeState: FinanceState = {
  quotes: Map.new(),
  accounts: Map.new(),
  nextTradeId: 1
};

function createAccount(userId: Number, initialCash: Number): Account {
  let account: Account = {
    userId: userId,
    cash: initialCash,
    positions: Map.new(),
    trades: []
  };

  financeState.accounts.set(userId, account);
  return account;
}

function updateQuote(symbol: String, price: Number, bid: Number, ask: Number) {
  let quote: Quote = {
    symbol: symbol,
    price: price,
    bid: bid,
    ask: ask,
    change: 0.5  // 단순화
  };

  financeState.quotes.set(symbol, quote);
}

function buyStock(userId: Number, symbol: String, quantity: Number): Boolean {
  let account = financeState.accounts.get(userId);
  if (account == null) return false;

  let quote = financeState.quotes.get(symbol);
  if (quote == null) return false;

  let totalCost = quantity * quote.ask;
  let fee = totalCost * 0.001;  // 0.1% 수수료

  if (account.cash < totalCost + fee) return false;

  account.cash = account.cash - totalCost - fee;

  let currentQty = account.positions.get(symbol) || 0;
  account.positions.set(symbol, currentQty + quantity);

  let trade: Trade = {
    id: "trade_" + String.from(financeState.nextTradeId++),
    symbol: symbol,
    type: "buy",
    quantity: quantity,
    price: quote.ask,
    timestamp: Date.format(Date.now(), "yyyy-MM-dd HH:mm:ss")
  };

  account.trades.push(trade);
  return true;
}

function getPortfolio(userId: Number): String {
  let account = financeState.accounts.get(userId);
  if (account == null) return "{}";

  let value = account.cash;
  let positions = [];

  account.positions.forEach(|qty, symbol| {
    let quote = financeState.quotes.get(symbol);
    if (quote != null) {
      value = value + qty * quote.price;
      positions.push({
        symbol: symbol,
        quantity: qty,
        price: quote.price,
        value: qty * quote.price
      });
    }
  });

  return JSON.stringify({
    userId: userId,
    cash: account.cash,
    totalValue: value,
    positions: positions,
    tradeCount: account.trades.length()
  });
}

// ============ 3. 실시간 알림 시스템 ============

type Notification = {
  id: String,
  userId: Number,
  type: String,        // "price_alert" | "trade" | "payment"
  message: String,
  timestamp: String,
  read: Boolean
};

type RealtimeState = {
  notifications: Map<Number, Array<Notification>>,
  subscribers: Map<String, Array<Number>>,
  nextNotifId: Number
};

let realtimeState: RealtimeState = {
  notifications: Map.new(),
  subscribers: Map.new(),
  nextNotifId: 1
};

function subscribe(userId: Number, channel: String) {
  let subs = realtimeState.subscribers.get(channel) || [];
  subs.push(userId);
  realtimeState.subscribers.set(channel, subs);
}

function publishNotification(channel: String, type: String, message: String) {
  let subs = realtimeState.subscribers.get(channel) || [];

  subs.forEach(|userId| {
    let notif: Notification = {
      id: "notif_" + String.from(realtimeState.nextNotifId++),
      userId: userId,
      type: type,
      message: message,
      timestamp: Date.format(Date.now(), "yyyy-MM-dd HH:mm:ss"),
      read: false
    };

    let userNotifs = realtimeState.notifications.get(userId) || [];
    userNotifs.push(notif);
    realtimeState.notifications.set(userId, userNotifs);
  });
}

function getUserNotifications(userId: Number): String {
  let notifs = realtimeState.notifications.get(userId) || [];
  let unreadCount = 0;

  notifs.forEach(|notif| {
    if (!notif.read) unreadCount = unreadCount + 1;
  });

  return JSON.stringify({
    userId: userId,
    totalNotifications: notifs.length(),
    unreadCount: unreadCount,
    notifications: notifs.slice(0, 10)  // 최근 10개
  });
}

// ============ 4. IoT 센서 시스템 ============

type SensorReading = {
  deviceId: String,
  sensorType: String,  // "temperature" | "humidity" | "pressure"
  value: Number,
  timestamp: String
};

type IoTDevice = {
  id: String,
  name: String,
  location: String,
  battery: Number,
  lastSeen: String,
  readings: Array<SensorReading>
};

type IoTState = {
  devices: Map<String, IoTDevice>,
  alerts: Array<String>
};

let iotState: IoTState = {
  devices: Map.new(),
  alerts: []
};

function registerDevice(deviceId: String, name: String, location: String): IoTDevice {
  let device: IoTDevice = {
    id: deviceId,
    name: name,
    location: location,
    battery: 100,
    lastSeen: Date.format(Date.now(), "yyyy-MM-dd HH:mm:ss"),
    readings: []
  };

  iotState.devices.set(deviceId, device);
  return device;
}

function recordSensorData(deviceId: String, sensorType: String, value: Number) {
  let device = iotState.devices.get(deviceId);
  if (device == null) return;

  let reading: SensorReading = {
    deviceId: deviceId,
    sensorType: sensorType,
    value: value,
    timestamp: Date.format(Date.now(), "yyyy-MM-dd HH:mm:ss")
  };

  device.readings.push(reading);
  device.lastSeen = reading.timestamp;

  // 경고 체크
  if (sensorType == "temperature" && (value < -10 || value > 50)) {
    iotState.alerts.push(deviceId + " 온도 비정상: " + String.from(value) + "°C");
  }

  if (sensorType == "humidity" && (value < 10 || value > 95)) {
    iotState.alerts.push(deviceId + " 습도 비정상: " + String.from(value) + "%");
  }
}

function getDeviceMetrics(deviceId: String): String {
  let device = iotState.devices.get(deviceId);
  if (device == null) return "{}";

  let readings = device.readings;
  let tempAvg = 0;
  let count = 0;

  readings.forEach(|reading| {
    if (reading.sensorType == "temperature") {
      tempAvg = tempAvg + reading.value;
      count = count + 1;
    }
  });

  if (count > 0) tempAvg = tempAvg / count;

  return JSON.stringify({
    deviceId: deviceId,
    name: device.name,
    battery: device.battery,
    totalReadings: readings.length(),
    averageTemperature: tempAvg,
    lastSeen: device.lastSeen
  });
}

// ============ 5. 엔터프라이즈 기능 ============

type TenantUser = {
  id: Number,
  tenantId: String,
  email: String,
  role: String  // "admin" | "manager" | "user"
};

type Tenant = {
  id: String,
  name: String,
  users: Array<TenantUser>,
  auditLogs: Array<String>
};

type EnterpriseState = {
  tenants: Map<String, Tenant>,
  nextTenantId: Number,
  nextUserId: Number
};

let enterpriseState: EnterpriseState = {
  tenants: Map.new(),
  nextTenantId: 1,
  nextUserId: 1
};

function createTenant(name: String): String {
  let tenantId = "tenant_" + String.from(enterpriseState.nextTenantId++);

  let tenant: Tenant = {
    id: tenantId,
    name: name,
    users: [],
    auditLogs: []
  };

  enterpriseState.tenants.set(tenantId, tenant);

  tenant.auditLogs.push("[" + Date.format(Date.now(), "yyyy-MM-dd HH:mm:ss") + "] Tenant created");

  return tenantId;
}

function addTenantUser(tenantId: String, email: String, role: String): Boolean {
  let tenant = enterpriseState.tenants.get(tenantId);
  if (tenant == null) return false;

  let user: TenantUser = {
    id: enterpriseState.nextUserId++,
    tenantId: tenantId,
    email: email,
    role: role
  };

  tenant.users.push(user);
  tenant.auditLogs.push("[" + Date.format(Date.now(), "yyyy-MM-dd HH:mm:ss") + "] User added: " + email);

  return true;
}

function getTenantInfo(tenantId: String): String {
  let tenant = enterpriseState.tenants.get(tenantId);
  if (tenant == null) return "{}";

  return JSON.stringify({
    tenantId: tenantId,
    name: tenant.name,
    userCount: tenant.users.length(),
    recentAuditLogs: tenant.auditLogs.slice(0, 5)
  });
}

function getEnterpriseMetrics(): String {
  let totalTenants = 0;
  let totalUsers = 0;

  enterpriseState.tenants.forEach(|tenant| {
    totalTenants = totalTenants + 1;
    totalUsers = totalUsers + tenant.users.length();
  });

  return JSON.stringify({
    totalTenants: totalTenants,
    totalUsers: totalUsers,
    averageUsersPerTenant: if (totalTenants > 0) totalUsers / totalTenants else 0
  });
}

