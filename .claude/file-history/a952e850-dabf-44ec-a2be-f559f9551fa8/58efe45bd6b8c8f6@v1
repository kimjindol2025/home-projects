/**
 * FreeLang v5 Blockchain — Transaction
 *
 * 기능:
 *   TransactionBuilder  — 트랜잭션 생성/서명
 *   validateTx(tx)      — 기본 유효성 검증
 *   calcTxId(tx)        — 결정론적 ID 계산
 *   serializeTx(tx)     — 직렬화 (서명 대상 메시지)
 */

import { sha256, createSignature, verifySignature } from "./crypto-utils";
import { Transaction, CoinbaseTx } from "./types";

// ============================================================
// 직렬화
// ============================================================

export function serializeTx(tx: Omit<Transaction, "id" | "signature">): string {
  return JSON.stringify({
    from:      tx.from,
    to:        tx.to,
    amount:    tx.amount,
    fee:       tx.fee,
    timestamp: tx.timestamp,
    nonce:     tx.nonce,
  });
}

export function calcTxId(tx: Omit<Transaction, "id">): string {
  return sha256(serializeTx(tx) + tx.signature);
}

// ============================================================
// TransactionBuilder
// ============================================================

export class TransactionBuilder {
  private from:      string = "";
  private to:        string = "";
  private amount:    number = 0;
  private fee:       number = 0;
  private nonce:     number = 0;

  setFrom(address: string):   this { this.from   = address; return this; }
  setTo(address: string):     this { this.to     = address; return this; }
  setAmount(amount: number):  this { this.amount  = amount;  return this; }
  setFee(fee: number):        this { this.fee     = fee;     return this; }
  setNonce(nonce: number):    this { this.nonce   = nonce;   return this; }

  /** 트랜잭션 서명 후 완성 */
  sign(privateKey: string, publicKey: string): Transaction {
    if (!this.from || !this.to)       throw new Error("from/to 주소 필수");
    if (this.amount <= 0)             throw new Error("amount > 0 필수");
    if (this.fee < 0)                 throw new Error("fee >= 0 필수");
    if (this.amount + this.fee <= 0)  throw new Error("amount + fee > 0 필수");

    const timestamp = Date.now();
    const partial: Omit<Transaction, "id" | "signature"> = {
      from:      this.from,
      to:        this.to,
      amount:    this.amount,
      fee:       this.fee,
      timestamp,
      nonce:     this.nonce,
    };

    const message   = serializeTx(partial);
    const signature = createSignature(privateKey, publicKey, message);
    const id        = sha256(message + signature);

    return { ...partial, id, signature };
  }
}

// ============================================================
// 코인베이스 트랜잭션 (채굴 보상)
// ============================================================

export function createCoinbaseTx(
  to:     string,
  amount: number,
  height: number
): CoinbaseTx {
  const timestamp = Date.now();
  const id        = sha256(`coinbase:${to}:${amount}:${height}:${timestamp}`);
  return { id, to, amount, height, timestamp };
}

// ============================================================
// 유효성 검증
// ============================================================

export interface TxValidationResult {
  valid:  boolean;
  errors: string[];
}

export function validateTx(tx: Transaction, publicKey: string): TxValidationResult {
  const errors: string[] = [];

  if (!tx.id)           errors.push("id 누락");
  if (!tx.from)         errors.push("from 누락");
  if (!tx.to)           errors.push("to 누락");
  if (tx.amount <= 0)   errors.push("amount must be > 0");
  if (tx.fee < 0)       errors.push("fee must be >= 0");
  if (!tx.signature)    errors.push("signature 누락");
  if (tx.from === tx.to) errors.push("self-transfer 불가");

  // 서명 검증
  if (tx.signature && publicKey) {
    const message = serializeTx(tx);
    if (!verifySignature(publicKey, message, tx.signature)) {
      errors.push("서명 검증 실패");
    }
  }

  // ID 재계산 검증
  if (tx.id) {
    const expected = sha256(serializeTx(tx) + tx.signature);
    if (expected !== tx.id) {
      errors.push("tx ID 불일치");
    }
  }

  return { valid: errors.length === 0, errors };
}
