/**
 * 실제 작동하는 데이터베이스 엔진
 * 메모리 기반 저장소 + 인덱싱 + 관계 처리
 */

interface Column {
  type: 'INTEGER' | 'STRING' | 'TEXT' | 'DATETIME';
  primary?: boolean;
  unique?: boolean;
  default?: any;
}

interface Schema {
  [columnName: string]: Column;
}

interface Row {
  [columnName: string]: any;
}

interface Index {
  [value: string]: number[]; // value -> [row indices]
}

class Table {
  name: string;
  schema: Schema;
  rows: Row[] = [];
  autoIncrementId: number = 1;
  indices: { [column: string]: Index } = {};
  uniqueConstraints: Set<string> = new Set();

  constructor(name: string, schema: Schema) {
    this.name = name;
    this.schema = schema;

    // 인덱스 초기화
    for (const [colName, col] of Object.entries(schema)) {
      if (col.primary || col.unique) {
        this.indices[colName] = {};
        if (col.unique) {
          this.uniqueConstraints.add(colName);
        }
      }
    }
  }

  insert(data: Row): number {
    // 자동 증가 ID 처리
    if (!data.id) {
      data.id = this.autoIncrementId++;
    } else if (typeof data.id === 'number' && data.id >= this.autoIncrementId) {
      this.autoIncrementId = data.id + 1;
    }

    // UNIQUE 제약 검증
    for (const col of this.uniqueConstraints) {
      if (data[col] && this.indices[col]?.[data[col]]) {
        throw new Error(`UNIQUE constraint failed on ${col}`);
      }
    }

    // 기본값 적용
    for (const [colName, col] of Object.entries(this.schema)) {
      if (data[colName] === undefined && col.default !== undefined) {
        data[colName] = col.default;
      }
    }

    const rowIndex = this.rows.length;
    this.rows.push(data);

    // 인덱스 업데이트
    for (const [colName, index] of Object.entries(this.indices)) {
      const value = data[colName];
      if (value !== undefined) {
        const key = String(value);
        if (!index[key]) {
          index[key] = [];
        }
        index[key].push(rowIndex);
      }
    }

    return data.id;
  }

  find(id: number): Row | null {
    const index = this.indices['id']?.[id];
    if (index !== undefined && index.length > 0) {
      return this.rows[index[0]];
    }
    return null;
  }

  findAll(): Row[] {
    return this.rows.map((row) => ({ ...row }));
  }

  where(column: string, operator: string, value: any): Row[] {
    return this.rows.filter((row) => {
      if (row === null) return false; // 삭제된 행 건너뛰기
      const colValue = row[column];
      switch (operator) {
        case '=':
          return colValue === value;
        case '!=':
          return colValue !== value;
        case '>':
          return colValue > value;
        case '<':
          return colValue < value;
        case '>=':
          return colValue >= value;
        case '<=':
          return colValue <= value;
        case 'LIKE':
          return String(colValue).includes(value);
        default:
          return false;
      }
    });
  }

  update(id: number, data: Row): boolean {
    const index = this.indices['id']?.[id];
    if (index !== undefined && index.length > 0) {
      const rowIndex = index[0];
      const row = this.rows[rowIndex];

      // 업데이트
      for (const [key, value] of Object.entries(data)) {
        row[key] = value;
      }

      // 인덱스 재구성
      for (const [colName, idx] of Object.entries(this.indices)) {
        idx[String(row[colName])] = [rowIndex];
      }

      return true;
    }
    return false;
  }

  delete(id: number): boolean {
    const index = this.indices['id']?.[id];
    if (index !== undefined && index.length > 0) {
      const rowIndex = index[0];

      // 인덱스에서 제거
      const row = this.rows[rowIndex];
      for (const [colName, idx] of Object.entries(this.indices)) {
        const key = String(row[colName]);
        delete idx[key];
      }

      // 행 제거
      this.rows[rowIndex] = null as any;

      return true;
    }
    return false;
  }

  count(): number {
    return this.rows.filter((r) => r !== null).length;
  }
}

export class DatabaseEngine {
  private tables: { [name: string]: Table } = {};
  private relationships: {
    [key: string]: { parent: string; child: string; foreignKey: string };
  } = {};

  define(tableName: string, schema: Schema): void {
    this.tables[tableName] = new Table(tableName, schema);
  }

  insert(tableName: string, data: Row): number {
    const table = this.tables[tableName];
    if (!table) {
      throw new Error(`Table ${tableName} not found`);
    }
    return table.insert(data);
  }

  find(tableName: string, id: number): Row | null {
    const table = this.tables[tableName];
    if (!table) {
      throw new Error(`Table ${tableName} not found`);
    }
    return table.find(id);
  }

  findAll(tableName: string): Row[] {
    const table = this.tables[tableName];
    if (!table) {
      throw new Error(`Table ${tableName} not found`);
    }
    return table.findAll();
  }

  where(
    tableName: string,
    column: string,
    operator: string,
    value: any
  ): Row[] {
    const table = this.tables[tableName];
    if (!table) {
      throw new Error(`Table ${tableName} not found`);
    }
    return table.where(column, operator, value);
  }

  update(tableName: string, id: number, data: Row): boolean {
    const table = this.tables[tableName];
    if (!table) {
      throw new Error(`Table ${tableName} not found`);
    }
    return table.update(id, data);
  }

  delete(tableName: string, id: number): boolean {
    const table = this.tables[tableName];
    if (!table) {
      throw new Error(`Table ${tableName} not found`);
    }
    return table.delete(id);
  }

  count(tableName: string): number {
    const table = this.tables[tableName];
    if (!table) {
      throw new Error(`Table ${tableName} not found`);
    }
    return table.count();
  }

  // 관계 설정 (향후 확장)
  hasMany(
    parentTable: string,
    childTable: string,
    foreignKey: string
  ): void {
    this.relationships[`${parentTable}-${childTable}`] = {
      parent: parentTable,
      child: childTable,
      foreignKey,
    };
  }

  belongsTo(childTable: string, parentTable: string, foreignKey: string): void {
    this.relationships[`${childTable}-${parentTable}`] = {
      parent: parentTable,
      child: childTable,
      foreignKey,
    };
  }

  // 통계 조회
  getStats(): {
    tables: string[];
    counts: { [table: string]: number };
  } {
    const stats = {
      tables: Object.keys(this.tables),
      counts: {} as { [table: string]: number },
    };

    for (const [tableName, table] of Object.entries(this.tables)) {
      stats.counts[tableName] = table.count();
    }

    return stats;
  }
}

// ORM 호환 래퍼
export class ORM {
  private engine: DatabaseEngine;

  constructor() {
    this.engine = new DatabaseEngine();
  }

  define(tableName: string, schema: Schema): void {
    this.engine.define(tableName, schema);
  }

  insert(tableName: string, data: Row): number {
    return this.engine.insert(tableName, data);
  }

  find(tableName: string, id: number): Row | null {
    return this.engine.find(tableName, id);
  }

  findAll(tableName: string): Row[] {
    return this.engine.findAll(tableName);
  }

  where(
    tableName: string,
    column: string,
    operator: string,
    value: any
  ): Row[] {
    return this.engine.where(tableName, column, operator, value);
  }

  update(tableName: string, id: number, data: Row): boolean {
    return this.engine.update(tableName, id, data);
  }

  delete(tableName: string, id: number): boolean {
    return this.engine.delete(tableName, id);
  }

  count(tableName: string): number {
    return this.engine.count(tableName);
  }

  hasMany(parentTable: string, childTable: string, foreignKey: string): void {
    this.engine.hasMany(parentTable, childTable, foreignKey);
  }

  belongsTo(childTable: string, parentTable: string, foreignKey: string): void {
    this.engine.belongsTo(childTable, parentTable, foreignKey);
  }

  getStats(): any {
    return this.engine.getStats();
  }

  static create(): ORM {
    return new ORM();
  }
}
