## 완전한 예제

```typescript
const orm = ORM.create();

// 모델 정의
orm.define('User', {
  id: { type: 'INTEGER', primary: true },
  name: { type: 'STRING' },
  email: { type: 'STRING', unique: true }
});

orm.define('Post', {
  id: { type: 'INTEGER', primary: true },
  title: { type: 'STRING' },
  user_id: { type: 'INTEGER' }
});

// 관계 설정
orm.hasMany('User', 'Post', 'user_id');
orm.belongsTo('Post', 'User', 'user_id');

// 사용
const userId = orm.insert('User', { name: 'Alice', email: 'alice@example.com' });
const postId = orm.insert('Post', { title: 'Hello World', user_id: userId });

// 조회
const user = orm.find('User', userId);
const posts = orm.where('Post', 'user_id', '=', userId);

// Eager 로드 (N+1 방지)
orm.eagerLoad([user], 'posts');
```

