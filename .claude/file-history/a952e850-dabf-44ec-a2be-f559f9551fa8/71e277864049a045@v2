## 완전한 예제

```typescript
import { String as FlString } from 'freelang-v4';

// CSV 처리
const csv = "name,age,email";
const headers = FlString.split(csv, ",");
console.log(headers);  // ["name", "age", "email"]

// URL 포매팅
const path = "  /api/users  ";
const cleaned = FlString.trim(path);
console.log(cleaned);  // "/api/users"

// 문자열 검색 & 치환
const text = "hello world hello";
const first = FlString.replace(text, "hello", "hi");
const all = FlString.replaceAll(text, "hello", "hi");
console.log(first);    // "hi world hello"
console.log(all);      // "hi world hi"

// 패딩 (로그 포매팅)
const id = FlString.padStart("42", 5, "0");
const duration = FlString.padEnd("100ms", 10, " ");
console.log(`[${id}] Duration: ${duration}`);

// 배열 변환 & 조작
const chars = FlString.toChars("test");
const reversed = chars.reverse().join("");
console.log(reversed);  // "tset"
```

