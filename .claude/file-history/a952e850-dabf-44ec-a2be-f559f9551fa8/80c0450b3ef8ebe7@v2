## 완전한 예제

### 예제 1: 데이터 변환 파이프라인
```typescript
import { Functional, String as FlString } from 'freelang-v4';

const processText = Functional.pipe(
  (text) => FlString.trim(text),
  (text) => FlString.lower(text),
  (text) => FlString.split(text, " "),
  (words) => words.filter(w => FlString.len(w) > 3)
);

console.log(processText("  Hello WORLD Testing  "));
// ["hello", "world", "testing"]
```

### 예제 2: 커링으로 설정 고정
```typescript
const multiply = (a, b) => a * b;
const curriedMult = Functional.curry(multiply, 2);

const double = curriedMult(2);
const triple = curriedMult(3);

console.log(double(5));   // 10
console.log(triple(5));   // 15
```

### 예제 3: 비용이 많이 드는 함수 캐싱
```typescript
const fibonacci = (n) => {
  if (n <= 1) return n;
  return fibonacci(n - 1) + fibonacci(n - 2);
};

const cached = Functional.memoize(fibonacci);

console.time("first");
cached(40);
console.timeEnd("first");   // ~1000ms

console.time("second");
cached(40);
console.timeEnd("second");  // < 1ms
```

### 예제 4: 초기화 함수 (한 번만 실행)
```typescript
let initialized = false;

const init = Functional.once(() => {
  initialized = true;
  console.log("Initializing...");
});

init();   // "Initializing..."
init();   // (출력 없음)
init();   // (출력 없음)
console.log(initialized); // true
```

