/**
 * 실시간 알림 시스템
 * 구독, 발행, 채널 기반 메시징
 */

// 알림 유형
export enum NotificationType {
  PRICE_ALERT = 'price_alert', // 주가 알림
  TRADE_EXECUTION = 'trade_execution', // 거래 체결
  PORTFOLIO_UPDATE = 'portfolio_update', // 포트폴리오 변화
  ORDER_FILLED = 'order_filled', // 주문 체결
  PAYMENT_CONFIRMED = 'payment_confirmed', // 결제 확인
  SECURITY_ALERT = 'security_alert', // 보안 알림
  SYSTEM_NOTIFICATION = 'system_notification', // 시스템 알림
}

// 알림
export interface Notification {
  id: string;
  userId: number;
  type: NotificationType;
  title: string;
  message: string;
  data?: any; // 추가 데이터
  timestamp: string;
  read: boolean;
  priority: 'low' | 'medium' | 'high' | 'critical';
}

// 채널
export interface Channel {
  id: string;
  name: string;
  subscribers: Set<number>; // userId 집합
  messageQueue: Notification[];
}

// 실시간 이벤트
export interface RealtimeEvent {
  id: string;
  channel: string;
  event: string;
  data: any;
  timestamp: string;
}

// 실시간 엔진
export class RealtimeEngine {
  private channels: Map<string, Channel> = new Map();
  private userNotifications: Map<number, Notification[]> = new Map();
  private subscribers: Map<number, Set<string>> = new Map(); // userId -> channels
  private eventStream: RealtimeEvent[] = [];
  private notificationIdCounter = 1;
  private eventIdCounter = 1;

  // 채널 생성
  createChannel(channelName: string): Channel {
    if (this.channels.has(channelName)) {
      return this.channels.get(channelName)!;
    }

    const channel: Channel = {
      id: `ch_${channelName}`,
      name: channelName,
      subscribers: new Set(),
      messageQueue: [],
    };

    this.channels.set(channelName, channel);
    return channel;
  }

  // 채널 구독
  subscribe(userId: number, channelName: string): void {
    const channel = this.createChannel(channelName);
    channel.subscribers.add(userId);

    if (!this.subscribers.has(userId)) {
      this.subscribers.set(userId, new Set());
    }
    this.subscribers.get(userId)!.add(channelName);
  }

  // 채널 구독 해제
  unsubscribe(userId: number, channelName: string): void {
    const channel = this.channels.get(channelName);
    if (channel) {
      channel.subscribers.delete(userId);
    }

    const userChannels = this.subscribers.get(userId);
    if (userChannels) {
      userChannels.delete(channelName);
    }
  }

  // 알림 발송
  publish(
    channelName: string,
    notification: Omit<Notification, 'id' | 'timestamp' | 'read'>
  ): Notification[] {
    const channel = this.channels.get(channelName);
    if (!channel) return [];

    const sentNotifications: Notification[] = [];

    for (const userId of channel.subscribers) {
      const fullNotification: Notification = {
        ...notification,
        id: `notif_${this.notificationIdCounter++}`,
        timestamp: new Date().toISOString(),
        read: false,
      };

      // 사용자 알림 저장
      if (!this.userNotifications.has(userId)) {
        this.userNotifications.set(userId, []);
      }
      this.userNotifications.get(userId)!.push(fullNotification);

      sentNotifications.push(fullNotification);
    }

    return sentNotifications;
  }

  // 사용자에게 직접 알림 발송
  notifyUser(
    userId: number,
    type: NotificationType,
    title: string,
    message: string,
    priority: 'low' | 'medium' | 'high' | 'critical' = 'medium'
  ): Notification {
    const notification: Notification = {
      id: `notif_${this.notificationIdCounter++}`,
      userId,
      type,
      title,
      message,
      timestamp: new Date().toISOString(),
      read: false,
      priority,
    };

    if (!this.userNotifications.has(userId)) {
      this.userNotifications.set(userId, []);
    }
    this.userNotifications.get(userId)!.push(notification);

    return notification;
  }

  // 사용자 알림 조회
  getUserNotifications(userId: number, limit: number = 50): Notification[] {
    const notifications = this.userNotifications.get(userId) || [];
    return notifications
      .sort((a, b) => new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime())
      .slice(0, limit);
  }

  // 미읽은 알림 조회
  getUnreadNotifications(userId: number): Notification[] {
    return this.getUserNotifications(userId).filter((n) => !n.read);
  }

  // 알림 읽음 처리
  markAsRead(userId: number, notificationId: string): void {
    const notifications = this.userNotifications.get(userId);
    if (notifications) {
      const notification = notifications.find((n) => n.id === notificationId);
      if (notification) {
        notification.read = true;
      }
    }
  }

  // 모든 알림 읽음 처리
  markAllAsRead(userId: number): void {
    const notifications = this.userNotifications.get(userId);
    if (notifications) {
      notifications.forEach((n) => {
        n.read = true;
      });
    }
  }

  // 실시간 이벤트 발행
  emitEvent(
    channelName: string,
    eventName: string,
    data: any
  ): RealtimeEvent {
    const event: RealtimeEvent = {
      id: `evt_${this.eventIdCounter++}`,
      channel: channelName,
      event: eventName,
      data,
      timestamp: new Date().toISOString(),
    };

    this.eventStream.push(event);

    // 최근 1000개만 유지
    if (this.eventStream.length > 1000) {
      this.eventStream.shift();
    }

    return event;
  }

  // 이벤트 스트림 조회 (시뮬레이션)
  getEvents(channelName: string, limit: number = 100): RealtimeEvent[] {
    return this.eventStream
      .filter((e) => e.channel === channelName)
      .slice(-limit);
  }

  // 구독자 목록
  getSubscribers(channelName: string): number[] {
    const channel = this.channels.get(channelName);
    return channel ? Array.from(channel.subscribers) : [];
  }

  // 가격 알림 설정 (예제)
  setPriceAlert(
    userId: number,
    symbol: string,
    targetPrice: number,
    condition: 'above' | 'below'
  ): void {
    const alertKey = `price_alert_${symbol}`;
    this.subscribe(userId, alertKey);

    // 실제로는 주가 모니터링이 필요하지만, 여기서는 저장만
    const alert = {
      userId,
      symbol,
      targetPrice,
      condition,
    };

    console.log(`Price alert set: ${JSON.stringify(alert)}`);
  }

  // 통계
  getMetrics() {
    const totalChannels = this.channels.size;
    const totalSubscribers = Array.from(this.channels.values()).reduce(
      (sum, ch) => sum + ch.subscribers.size,
      0
    );
    const totalNotifications = Array.from(
      this.userNotifications.values()
    ).reduce((sum, notifs) => sum + notifs.length, 0);
    const unreadCount = Array.from(this.userNotifications.values()).reduce(
      (sum, notifs) => sum + notifs.filter((n) => !n.read).length,
      0
    );

    return {
      totalChannels,
      activeChannels: Array.from(this.channels.values()).filter(
        (ch) => ch.subscribers.size > 0
      ).length,
      totalSubscribers,
      totalNotifications,
      unreadNotifications: unreadCount,
      eventCount: this.eventStream.length,
    };
  }

  // 채널별 통계
  getChannelStats(channelName: string) {
    const channel = this.channels.get(channelName);
    if (!channel) return null;

    return {
      channelName,
      subscribers: channel.subscribers.size,
      queuedMessages: channel.messageQueue.length,
      events: this.getEvents(channelName).length,
    };
  }
}

export const realtimeEngine = new RealtimeEngine();
