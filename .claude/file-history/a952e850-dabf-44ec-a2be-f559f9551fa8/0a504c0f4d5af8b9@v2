/**
 * 금융 API - 실시간 거래, 포트폴리오, 수수료
 * 주식, 암호화폐, FX 지원
 */

// 자산 유형
export enum AssetType {
  STOCK = 'stock',
  CRYPTO = 'crypto',
  FOREX = 'forex',
  COMMODITY = 'commodity',
}

// 거래 유형
export enum TradeType {
  BUY = 'buy',
  SELL = 'sell',
}

// 거래 상태
export enum TradeStatus {
  PENDING = 'pending',
  EXECUTED = 'executed',
  FAILED = 'failed',
  CANCELLED = 'cancelled',
}

// 가격 데이터
export interface Quote {
  symbol: string;
  assetType: AssetType;
  price: number;
  bid: number; // 매도 호가
  ask: number; // 매수 호가
  volume: number;
  timestamp: string;
  change: number; // % 변화
}

// 거래
export interface Trade {
  id: string;
  userId: number;
  symbol: string;
  assetType: AssetType;
  type: TradeType; // buy | sell
  quantity: number;
  price: number; // 체결가
  totalAmount: number;
  fee: number;
  status: TradeStatus;
  executedAt: string;
  expiresAt?: string;
}

// 포트폴리오
export interface Position {
  symbol: string;
  assetType: AssetType;
  quantity: number;
  averagePrice: number;
  currentPrice: number;
  totalValue: number;
  unrealizedGain: number;
  gainPercent: number;
}

// 계좌
export interface Account {
  userId: number;
  cash: number; // 현금 잔액
  positions: Map<string, Position>;
  totalValue: number;
  buyingPower: number; // 사용 가능한 금액
  leverage: number; // 레버리지 배수
}

// 수수료 구조
export const feeStructure = {
  stock: 0.001, // 0.1%
  crypto: 0.0025, // 0.25%
  forex: 0.00025, // 0.025%
  commodity: 0.005, // 0.5%
};

// 금융 엔진
export class FinanceEngine {
  private quotes: Map<string, Quote> = new Map();
  private trades: Map<string, Trade> = new Map();
  private accounts: Map<number, Account> = new Map();
  private tradeIdCounter = 1;

  // 실시간 가격 업데이트 (시뮬레이션)
  updateQuote(quote: Quote): void {
    this.quotes.set(`${quote.assetType}_${quote.symbol}`, quote);
  }

  // 현재 가격 조회
  getQuote(symbol: string, assetType: AssetType): Quote | null {
    return this.quotes.get(`${assetType}_${symbol}`) || null;
  }

  // 계좌 생성
  createAccount(userId: number, initialCash: number = 10000): Account {
    const account: Account = {
      userId,
      cash: initialCash,
      positions: new Map(),
      totalValue: initialCash,
      buyingPower: initialCash,
      leverage: 1,
    };
    this.accounts.set(userId, account);
    return account;
  }

  // 계좌 조회
  getAccount(userId: number): Account | null {
    return this.accounts.get(userId) || null;
  }

  // 매수
  buy(
    userId: number,
    symbol: string,
    assetType: AssetType,
    quantity: number
  ): Trade | null {
    const account = this.accounts.get(userId);
    if (!account) return null;

    const quote = this.quotes.get(`${assetType}_${symbol}`);
    if (!quote) return null;

    const totalAmount = quantity * quote.ask;
    const fee = totalAmount * feeStructure[assetType];
    const totalCost = totalAmount + fee;

    if (account.cash < totalCost) {
      return null; // 자금 부족
    }

    const trade: Trade = {
      id: `trade_${this.tradeIdCounter++}`,
      userId,
      symbol,
      assetType,
      type: TradeType.BUY,
      quantity,
      price: quote.ask,
      totalAmount,
      fee,
      status: TradeStatus.EXECUTED,
      executedAt: new Date().toISOString(),
    };

    this.trades.set(trade.id, trade);

    // 계좌 업데이트
    account.cash -= totalCost;

    // 포지션 업데이트
    const key = `${assetType}_${symbol}`;
    const position = account.positions.get(key);
    if (position) {
      // 평균가 재계산
      const totalQuantity = position.quantity + quantity;
      position.averagePrice =
        (position.quantity * position.averagePrice + quantity * quote.ask) /
        totalQuantity;
      position.quantity = totalQuantity;
    } else {
      account.positions.set(key, {
        symbol,
        assetType,
        quantity,
        averagePrice: quote.ask,
        currentPrice: quote.ask,
        totalValue: quantity * quote.ask,
        unrealizedGain: 0,
        gainPercent: 0,
      });
    }

    this.updateAccountMetrics(account);
    return trade;
  }

  // 매도
  sell(
    userId: number,
    symbol: string,
    assetType: AssetType,
    quantity: number
  ): Trade | null {
    const account = this.accounts.get(userId);
    if (!account) return null;

    const quote = this.quotes.get(`${assetType}_${symbol}`);
    if (!quote) return null;

    const key = `${assetType}_${symbol}`;
    const position = account.positions.get(key);
    if (!position || position.quantity < quantity) {
      return null; // 보유 수량 부족
    }

    const totalAmount = quantity * quote.bid;
    const fee = totalAmount * feeStructure[assetType];
    const netProceeds = totalAmount - fee;

    const trade: Trade = {
      id: `trade_${this.tradeIdCounter++}`,
      userId,
      symbol,
      assetType,
      type: TradeType.SELL,
      quantity,
      price: quote.bid,
      totalAmount,
      fee,
      status: TradeStatus.EXECUTED,
      executedAt: new Date().toISOString(),
    };

    this.trades.set(trade.id, trade);

    // 계좌 업데이트
    account.cash += netProceeds;

    // 포지션 업데이트
    position.quantity -= quantity;
    if (position.quantity === 0) {
      account.positions.delete(key);
    } else {
      position.totalValue = position.quantity * position.currentPrice;
    }

    this.updateAccountMetrics(account);
    return trade;
  }

  // 포트폴리오 가치 계산
  updateAccountMetrics(account: Account): void {
    let totalStockValue = 0;

    for (const position of account.positions.values()) {
      const quote = this.quotes.get(
        `${position.assetType}_${position.symbol}`
      );
      if (quote) {
        position.currentPrice = quote.price;
        position.totalValue = position.quantity * quote.price;
        position.unrealizedGain =
          position.totalValue - position.quantity * position.averagePrice;
        position.gainPercent =
          (position.unrealizedGain /
            (position.quantity * position.averagePrice)) *
          100;
        totalStockValue += position.totalValue;
      }
    }

    account.totalValue = account.cash + totalStockValue;
    account.buyingPower = account.cash * account.leverage;
  }

  // 거래 기록 조회
  getTradeHistory(userId: number, limit: number = 50): Trade[] {
    return Array.from(this.trades.values())
      .filter((t) => t.userId === userId)
      .sort((a, b) => new Date(b.executedAt).getTime() - new Date(a.executedAt).getTime())
      .slice(0, limit);
  }

  // 포트폴리오 조회
  getPortfolio(userId: number): Position[] {
    const account = this.accounts.get(userId);
    if (!account) return [];
    return Array.from(account.positions.values());
  }

  // 성과 분석
  getPerformance(userId: number) {
    const account = this.accounts.get(userId);
    if (!account) return null;

    const trades = this.getTradeHistory(userId, 1000);
    const totalFees = trades.reduce((sum, t) => sum + t.fee, 0);
    const realizedGain = trades
      .filter((t) => t.type === TradeType.SELL)
      .reduce((sum, t) => sum + (t.price - t.price) * t.quantity, 0); // 단순화

    return {
      totalValue: account.totalValue,
      cash: account.cash,
      positions: account.positions.size,
      totalUnrealizedGain: Array.from(account.positions.values()).reduce(
        (sum, p) => sum + p.unrealizedGain,
        0
      ),
      totalFeesPaid: totalFees,
      realizedGain,
      winRate:
        trades.length > 0
          ? (
              (trades.filter((t) => t.type === TradeType.SELL).length /
                trades.length) *
              100
            ).toFixed(2)
          : '0',
    };
  }

  // 위험도 계산 (Sharpe Ratio 단순화)
  calculateRiskMetrics(userId: number) {
    const account = this.accounts.get(userId);
    if (!account) return null;

    let volatility = 0;
    for (const position of account.positions.values()) {
      volatility += (position.gainPercent / 100) ** 2;
    }

    return {
      portfolioVolatility: Math.sqrt(volatility / Math.max(account.positions.size, 1)),
      diversificationScore:
        account.positions.size > 0
          ? Math.min((account.positions.size / 10) * 100, 100)
          : 0, // 0-100%
      maxDrawdown: 0, // 단순화
      sharpeRatio: 0, // 단순화
    };
  }
}

export const financeEngine = new FinanceEngine();
