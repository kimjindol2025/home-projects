/**
 * 데이터베이스 엔진 작동 테스트
 * DATABASE_DESIGN.md의 설계를 실제로 검증
 */

import { ORM } from '../src/db/engine';

let testResults = { passed: 0, failed: 0 };

const assert = (condition: boolean, message: string) => {
  if (condition) {
    console.log(`✅ ${message}`);
    testResults.passed++;
  } else {
    console.error(`❌ ${message}`);
    testResults.failed++;
  }
};

async function runTests() {
  console.log('\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
  console.log('🧪 데이터베이스 엔진 통합 테스트');
  console.log('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n');

  // ============ 1. 데이터베이스 초기화 ============
  console.log('📦 1. 데이터베이스 초기화');
  const orm = ORM.create();
  assert(orm !== null, 'ORM 생성');

  // ============ 2. 스키마 정의 ============
  console.log('\n📋 2. 스키마 정의');

  orm.define('User', {
    id: { type: 'INTEGER', primary: true },
    email: { type: 'STRING', unique: true },
    password_hash: { type: 'STRING' },
    name: { type: 'STRING' },
    created_at: { type: 'DATETIME' },
  });
  assert(true, 'User 테이블 정의');

  orm.define('Post', {
    id: { type: 'INTEGER', primary: true },
    user_id: { type: 'INTEGER' },
    title: { type: 'STRING' },
    content: { type: 'TEXT' },
    views: { type: 'INTEGER', default: 0 },
    created_at: { type: 'DATETIME' },
    updated_at: { type: 'DATETIME' },
  });
  assert(true, 'Post 테이블 정의');

  orm.define('Comment', {
    id: { type: 'INTEGER', primary: true },
    post_id: { type: 'INTEGER' },
    user_id: { type: 'INTEGER' },
    content: { type: 'TEXT' },
    created_at: { type: 'DATETIME' },
  });
  assert(true, 'Comment 테이블 정의');

  orm.define('Tag', {
    id: { type: 'INTEGER', primary: true },
    name: { type: 'STRING', unique: true },
  });
  assert(true, 'Tag 테이블 정의');

  orm.define('PostTag', {
    post_id: { type: 'INTEGER' },
    tag_id: { type: 'INTEGER' },
  });
  assert(true, 'PostTag 테이블 정의');

  // ============ 3. INSERT 작동 ============
  console.log('\n➕ 3. INSERT 작동');

  const userId = orm.insert('User', {
    email: 'alice@example.com',
    password_hash: 'hashed_password_123',
    name: 'Alice',
    created_at: new Date().toISOString(),
  });
  assert(typeof userId === 'number', 'User INSERT (반환값 숫자)');
  assert(userId === 1, 'User INSERT (자동 ID = 1)');

  const userId2 = orm.insert('User', {
    email: 'bob@example.com',
    password_hash: 'hashed_password_456',
    name: 'Bob',
    created_at: new Date().toISOString(),
  });
  assert(userId2 === 2, 'User INSERT (자동 ID = 2)');

  // ============ 4. SELECT (find) 작동 ============
  console.log('\n🔍 4. SELECT (find) 작동');

  const user = orm.find('User', 1);
  assert(user !== null, 'User find (존재)');
  assert(user?.email === 'alice@example.com', 'User find (email 일치)');
  assert(user?.name === 'Alice', 'User find (name 일치)');

  const notFound = orm.find('User', 999);
  assert(notFound === null, 'User find (없는 ID는 null)');

  // ============ 5. SELECT (findAll) 작동 ============
  console.log('\n📊 5. SELECT (findAll) 작동');

  const allUsers = orm.findAll('User');
  assert(Array.isArray(allUsers), 'User findAll (배열)');
  assert(allUsers.length === 2, 'User findAll (2개)');

  // ============ 6. WHERE 조건 조회 ============
  console.log('\n🎯 6. WHERE 조건 조회');

  const result = orm.where('User', 'email', '=', 'alice@example.com');
  assert(result.length === 1, 'WHERE = 조건');
  assert(result[0].name === 'Alice', 'WHERE 결과 데이터');

  const notEqualResult = orm.where('User', 'email', '!=', 'alice@example.com');
  assert(notEqualResult.length === 1, 'WHERE != 조건');

  // ============ 7. UNIQUE 제약 ============
  console.log('\n🔒 7. UNIQUE 제약');

  try {
    orm.insert('User', {
      email: 'alice@example.com', // 중복
      password_hash: 'hashed',
      name: 'Alice2',
      created_at: new Date().toISOString(),
    });
    assert(false, 'UNIQUE 제약 (실패해야 함)');
  } catch (error) {
    assert(true, 'UNIQUE 제약 (정상 실패)');
  }

  // ============ 8. 기본값 처리 ============
  console.log('\n⚙️  8. 기본값 처리');

  const postId = orm.insert('Post', {
    user_id: 1,
    title: '첫 번째 포스트',
    content: '내용입니다',
    created_at: new Date().toISOString(),
    updated_at: new Date().toISOString(),
  });
  assert(typeof postId === 'number', 'Post INSERT');

  const post = orm.find('Post', postId);
  assert(post?.views === 0, '기본값 처리 (views = 0)');

  // ============ 9. 1:N 관계 ============
  console.log('\n🔗 9. 1:N 관계 (User → Post)');

  orm.hasMany('User', 'Post', 'user_id');
  assert(true, '1:N 관계 정의');

  const userPosts = orm.where('Post', 'user_id', '=', 1);
  assert(Array.isArray(userPosts), 'User의 Post 조회 (배열)');
  assert(userPosts.length > 0, 'User의 Post 조회 (데이터)');

  // ============ 10. 댓글 시스템 ============
  console.log('\n💬 10. 댓글 시스템');

  const commentId = orm.insert('Comment', {
    post_id: postId,
    user_id: 1,
    content: '좋은 포스트입니다!',
    created_at: new Date().toISOString(),
  });
  assert(typeof commentId === 'number', 'Comment INSERT');

  const comments = orm.where('Comment', 'post_id', '=', postId);
  assert(comments.length === 1, 'Post의 Comment 조회');
  assert(comments[0].content === '좋은 포스트입니다!', 'Comment 내용');

  // ============ 11. 태그 시스템 (N:N 관계) ============
  console.log('\n🏷️  11. 태그 시스템 (N:N 관계)');

  const tagId = orm.insert('Tag', { name: 'TypeScript' });
  assert(typeof tagId === 'number', 'Tag INSERT');

  const postTagId = orm.insert('PostTag', {
    post_id: postId,
    tag_id: tagId,
  });
  assert(typeof postTagId === 'number', 'PostTag INSERT (N:N 관계)');

  const postTags = orm.where('PostTag', 'post_id', '=', postId);
  assert(postTags.length === 1, 'Post의 Tag 조회');

  // ============ 12. UPDATE 작동 ============
  console.log('\n✏️  12. UPDATE 작동');

  const updated = orm.update('Post', postId, { title: '수정된 제목' });
  assert(updated === true, 'UPDATE (반환값 true)');

  const updatedPost = orm.find('Post', postId);
  assert(updatedPost?.title === '수정된 제목', 'UPDATE (데이터 변경)');

  // ============ 13. DELETE 작동 ============
  console.log('\n🗑️  13. DELETE 작동');

  const deleted = orm.delete('Post', postId);
  assert(deleted === true, 'DELETE (반환값 true)');

  const deletedPost = orm.find('Post', postId);
  assert(deletedPost === null, 'DELETE (데이터 제거)');

  // ============ 14. COUNT 집계 ============
  console.log('\n📈 14. COUNT 집계');

  const userCount = orm.count('User');
  assert(userCount === 2, 'COUNT (User = 2)');

  const commentCount = orm.count('Comment');
  assert(commentCount === 1, 'COUNT (Comment = 1)');

  // ============ 15. 데이터 일관성 ============
  console.log('\n🔄 15. 데이터 일관성');

  const stats = orm.getStats();
  assert(stats.tables.includes('User'), '테이블 목록 (User)');
  assert(stats.tables.includes('Post'), '테이블 목록 (Post)');
  assert(stats.counts['User'] === 2, '통계 (User = 2)');

  // ============ 16. 실제 블로그 시나리오 ============
  console.log('\n🚀 16. 실제 블로그 시나리오');

  // 새로운 사용자
  const newUserId = orm.insert('User', {
    email: 'charlie@example.com',
    password_hash: 'hashed_789',
    name: 'Charlie',
    created_at: new Date().toISOString(),
  });

  // 여러 포스트 생성
  const postIds = [];
  for (let i = 1; i <= 3; i++) {
    const pId = orm.insert('Post', {
      user_id: newUserId,
      title: `포스트 ${i}`,
      content: `내용 ${i}`,
      views: i * 10,
      created_at: new Date().toISOString(),
      updated_at: new Date().toISOString(),
    });
    postIds.push(pId);
  }

  const userNewPosts = orm.where('Post', 'user_id', '=', newUserId);
  assert(userNewPosts.length === 3, '사용자의 3개 포스트');

  // 포스트에 댓글 추가
  for (let i = 0; i < postIds.length; i++) {
    orm.insert('Comment', {
      post_id: postIds[i],
      user_id: 1,
      content: `댓글 ${i + 1}`,
      created_at: new Date().toISOString(),
    });
  }

  const totalComments = orm.count('Comment');
  assert(totalComments === 4, '전체 댓글 (1 + 3)');

  // ============ 결과 출력 ============
  console.log('\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
  console.log(`📈 테스트 결과`);
  console.log(`✅ 통과: ${testResults.passed}개`);
  console.log(`❌ 실패: ${testResults.failed}개`);
  console.log(
    `📊 성공률: ${(
      (testResults.passed / (testResults.passed + testResults.failed)) *
      100
    ).toFixed(1)}%`
  );
  console.log('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n');

  process.exit(testResults.failed > 0 ? 1 : 0);
}

runTests().catch((error) => {
  console.error('❌ 테스트 실행 오류:', error);
  process.exit(1);
});
