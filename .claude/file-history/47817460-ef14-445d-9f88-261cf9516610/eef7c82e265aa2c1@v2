use super::learning_state_machine::PatternLearningState;
use super::pattern_database::PatternStatistics;
use super::predictor::TrendPredictor;
use super::proactive_dispatcher::ProactiveDispatcher;

// ============================================================================
// PredictionOutcome: 예측 결과
// ============================================================================

struct PredictionOutcome {
    pattern_type: String,
    current_confidence: f64,
    predicted_next_state: f64,
    time_to_critical: Option<u32>,  // 위기까지의 시간 (ms)
    recommended_actions: Vec<String>,
    overall_confidence: f64,
}

impl PredictionOutcome {
    fn new(pattern_type: String) -> PredictionOutcome {
        PredictionOutcome {
            pattern_type,
            current_confidence: 0.0,
            predicted_next_state: 0.0,
            time_to_critical: None,
            recommended_actions: Vec::new(),
            overall_confidence: 0.0,
        }
    }
}

// ============================================================================
// SelfLearningPredictor: Week 1 + Week 2 통합 시스템
// ============================================================================
// 역할:
// 1. Week 1: 과거 패턴 인식 & 학습 상태 추적
// 2. Week 2: 미래 예측 & 프로액티브 조치
// 3. 신뢰도 기반 의사결정 (80% 이상만 실행)

pub struct SelfLearningPredictor {
    // Week 1 컴포넌트
    pattern_states: Vec<PatternLearningState>,
    pattern_statistics: Vec<PatternStatistics>,

    // Week 2 컴포넌트
    trend_predictors: Vec<TrendPredictor>,
    dispatcher: ProactiveDispatcher,

    // 신뢰도 임계값
    min_confidence_for_action: f64,  // 기본 0.80 (80% 이상)
    min_confidence_for_preparation: f64,  // 기본 0.70 (준비 단계)

    // 메타데이터
    predictions_made: u32,
    actions_executed: u32,
    successful_predictions: u32,
}

impl SelfLearningPredictor {
    pub fn new() -> SelfLearningPredictor {
        SelfLearningPredictor {
            pattern_states: Vec::new(),
            pattern_statistics: Vec::new(),
            trend_predictors: Vec::new(),
            dispatcher: ProactiveDispatcher::new(),
            min_confidence_for_action: 0.80,
            min_confidence_for_preparation: 0.70,
            predictions_made: 0,
            actions_executed: 0,
            successful_predictions: 0,
        }
    }

    // ========================================================================
    // 공개 API: 예측 & 조치 실행
    // ========================================================================

    /// 패턴 기반 예측 수행
    pub fn predict_pattern(
        &mut self,
        pattern_id: u32,
        pattern_type: String,
        current_saturation: f64,
    ) -> PredictionOutcome {
        let mut outcome = PredictionOutcome::new(pattern_type.clone());

        // Step 1: Week 1 데이터 조회
        let current_confidence = self.get_pattern_confidence(pattern_id);
        let stats = self.get_pattern_statistics(&pattern_type);
        outcome.current_confidence = current_confidence;

        // Step 2: Week 2 예측
        let predictor = self.get_or_create_trend_predictor(pattern_id as usize);
        let (next_saturation, _) = predictor.predict_next_value();
        outcome.predicted_next_state = next_saturation;

        // Step 3: 위기 시간 계산
        if next_saturation > 0.90 {
            outcome.time_to_critical = Some(self.estimate_time_to_critical(pattern_id, current_saturation));
        }

        // Step 4: 조치 추천
        let improvement_potential = self.calculate_improvement_potential(&pattern_type, &stats);
        outcome.recommended_actions =
            self.select_proactive_actions(&pattern_type, current_confidence, improvement_potential);

        // Step 5: 통합 신뢰도 계산
        outcome.overall_confidence = self.calculate_integrated_confidence(
            current_confidence,
            improvement_potential,
        );

        self.predictions_made += 1;
        outcome
    }

    /// 예측 결과 기반 조치 실행
    pub fn execute_based_on_prediction(&mut self, outcome: &PredictionOutcome, current_timestamp: u64) -> bool {
        // 신뢰도 확인
        if outcome.overall_confidence < self.min_confidence_for_action {
            return false;  // 신뢰도 부족: 조치 안 함
        }

        // 조치 스케줄
        for action_name in &outcome.recommended_actions {
            // 문자열을 ProactiveAction으로 변환
            if self.schedule_action_by_name(action_name, current_timestamp, outcome.overall_confidence) {
                self.actions_executed += 1;
            }
        }

        true
    }

    /// 예측 성공/실패 기록
    pub fn record_prediction_accuracy(
        &mut self,
        pattern_type: &str,
        predicted_saturation: f64,
        actual_saturation: f64,
    ) {
        let error = (actual_saturation - predicted_saturation).abs();
        let success = error < 0.05;  // ±5% 오차

        if success {
            self.successful_predictions += 1;
        }

        // 이 정보를 나중에 모델 재학습에 사용
    }

    // ========================================================================
    // 내부 메서드: Week 1 & Week 2 통합 로직
    // ========================================================================

    fn get_pattern_confidence(&self, pattern_id: u32) -> f64 {
        for state in &self.pattern_states {
            if state.pattern_id == pattern_id {
                return state.confidence;
            }
        }
        0.0
    }

    fn get_pattern_statistics(&self, pattern_type: &str) -> PatternStatistics {
        for stats in &self.pattern_statistics {
            if stats.pattern_type == pattern_type {
                return stats.clone();
            }
        }

        // 기본값 반환
        PatternStatistics {
            pattern_type: pattern_type.to_string(),
            total_occurrences: 0,
            success_count: 0,
            failure_count: 0,
            success_rate: 0.0,
            average_recovery_time_ms: 0,
            average_improvement_ratio: 0.0,
            min_recovery_time_ms: 0,
            max_recovery_time_ms: 0,
            last_occurrence_timestamp: 0,
        }
    }

    fn get_or_create_trend_predictor(&mut self, index: usize) -> &mut TrendPredictor {
        while self.trend_predictors.len() <= index {
            self.trend_predictors.push(TrendPredictor::new());
        }
        &mut self.trend_predictors[index]
    }

    fn estimate_time_to_critical(&self, pattern_id: u32, current_saturation: f64) -> u32 {
        // 임시 구현: 선형 추정
        if current_saturation > 0.95 {
            0  // 이미 위기 상태
        } else if current_saturation > 0.90 {
            100  // 100ms 내 위기
        } else if current_saturation > 0.80 {
            500  // 500ms 내 위기
        } else {
            1000  // 1초 내 위기
        }
    }

    fn calculate_improvement_potential(&self, pattern_type: &str, stats: &PatternStatistics) -> f64 {
        // 과거 평균 개선도 활용
        stats.average_improvement_ratio.min(0.5)  // 최대 50%
    }

    fn select_proactive_actions(
        &self,
        pattern_type: &str,
        confidence: f64,
        improvement_potential: f64,
    ) -> Vec<String> {
        // 패턴 타입에 따라 추천 조치 선택
        match pattern_type {
            "MemoryLeak" => vec!["AggressiveGC".to_string()],
            "IOBottleneck" => vec!["BufferPoolExpansion".to_string()],
            "ThreadContention" => vec!["ThreadPoolAdjustment".to_string()],
            "CacheThreshing" => vec!["CachePreemption".to_string()],
            "CombinedPressure" => vec![
                "AggressiveGC".to_string(),
                "BufferPoolExpansion".to_string(),
                "GracefulDegradationPreload".to_string(),
            ],
            _ => vec![],
        }
    }

    fn calculate_integrated_confidence(&self, pattern_confidence: f64, improvement_potential: f64) -> f64 {
        // 패턴 신뢰도 (70%) + 개선 가능성 (30%)
        pattern_confidence * 0.7 + improvement_potential * 0.3
    }

    fn schedule_action_by_name(
        &mut self,
        action_name: &str,
        current_timestamp: u64,
        confidence: f64,
    ) -> bool {
        // 조치 이름으로 ProactiveAction 결정
        // 실제 구현에서는 더 정교한 매핑 필요
        match action_name {
            "AggressiveGC" => {
                // 예정 시간 = 현재 + 100ms (조치 준비 시간)
                self.dispatcher.dispatch_action(
                    crate::predictive::proactive_dispatcher::ProactiveAction::AggressiveGC,
                    current_timestamp + 100,
                    confidence,
                )
            }
            _ => false,
        }
    }

    // ========================================================================
    // 통계 조회
    // ========================================================================

    pub fn get_system_health(&self) -> SystemHealth {
        let success_rate = if self.predictions_made > 0 {
            (self.successful_predictions as f64) / (self.predictions_made as f64)
        } else {
            0.0
        };

        SystemHealth {
            predictions_made: self.predictions_made,
            successful_predictions: self.successful_predictions,
            success_rate,
            actions_executed: self.actions_executed,
            min_confidence_threshold: self.min_confidence_for_action,
        }
    }
}

// ============================================================================
// 데이터 구조: 통계
// ============================================================================

pub struct SystemHealth {
    pub predictions_made: u32,
    pub successful_predictions: u32,
    pub success_rate: f64,
    pub actions_executed: u32,
    pub min_confidence_threshold: f64,
}

// Week 1 PatternStatistics 구조 (복사본)
#[derive(Clone)]
struct PatternStatistics {
    pattern_type: String,
    total_occurrences: usize,
    success_count: usize,
    failure_count: usize,
    success_rate: f64,
    average_recovery_time_ms: u32,
    average_improvement_ratio: f64,
    min_recovery_time_ms: u32,
    max_recovery_time_ms: u32,
    last_occurrence_timestamp: u64,
}

// ============================================================================
// 테스트 케이스 (10개)
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_self_learning_predictor_creation() {
        // 테스트 1: 예측기 생성
        let predictor = SelfLearningPredictor::new();
        assert_eq!(predictor.min_confidence_for_action, 0.80);
        assert_eq!(predictor.min_confidence_for_preparation, 0.70);
        assert_eq!(predictor.predictions_made, 0);
    }

    #[test]
    fn test_prediction_outcome_creation() {
        // 테스트 2: 예측 결과 생성
        let outcome = PredictionOutcome::new("MemoryLeak".to_string());
        assert_eq!(outcome.pattern_type, "MemoryLeak");
        assert_eq!(outcome.current_confidence, 0.0);
        assert!(outcome.recommended_actions.is_empty());
    }

    #[test]
    fn test_confidence_threshold_filtering() {
        // 테스트 3: 신뢰도 임계값 필터링
        let predictor = SelfLearningPredictor::new();

        // 80% 이상 신뢰도는 조치 실행
        assert!(predictor.min_confidence_for_action == 0.80);

        // 80% 미만은 실행 안 함
        let low_confidence_threshold = predictor.min_confidence_for_action;
        assert!(low_confidence_threshold > 0.70);
    }

    #[test]
    fn test_integrated_confidence_calculation() {
        // 테스트 4: 통합 신뢰도 계산
        let predictor = SelfLearningPredictor::new();

        let integrated = predictor.calculate_integrated_confidence(0.80, 0.50);
        // = 0.80 * 0.7 + 0.50 * 0.3 = 0.56 + 0.15 = 0.71
        assert!((integrated - 0.71).abs() < 0.01);
    }

    #[test]
    fn test_prediction_accuracy_tracking() {
        // 테스트 5: 예측 정확도 추적
        let mut predictor = SelfLearningPredictor::new();

        predictor.record_prediction_accuracy("MemoryLeak", 0.85, 0.87);  // ±2% (성공)
        predictor.record_prediction_accuracy("MemoryLeak", 0.80, 0.95);  // ±15% (실패)
        predictor.record_prediction_accuracy("MemoryLeak", 0.75, 0.78);  // ±3% (성공)

        let health = predictor.get_system_health();
        assert_eq!(health.successful_predictions, 2);
    }

    #[test]
    fn test_pattern_statistics_retrieval() {
        // 테스트 6: 패턴 통계 조회
        let predictor = SelfLearningPredictor::new();

        let stats = predictor.get_pattern_statistics("MemoryLeak");
        assert_eq!(stats.pattern_type, "MemoryLeak");
        assert_eq!(stats.total_occurrences, 0);  // 초기: 0
    }

    #[test]
    fn test_improvement_potential_calculation() {
        // 테스트 7: 개선 가능성 계산
        let predictor = SelfLearningPredictor::new();

        let potential = predictor.calculate_improvement_potential("MemoryLeak", &PatternStatistics {
            pattern_type: "MemoryLeak".to_string(),
            total_occurrences: 5,
            success_count: 4,
            failure_count: 1,
            success_rate: 0.8,
            average_recovery_time_ms: 150,
            average_improvement_ratio: 0.35,  // 35% 개선
            min_recovery_time_ms: 100,
            max_recovery_time_ms: 200,
            last_occurrence_timestamp: 0,
        });

        assert!((potential - 0.35).abs() < 0.01);  // 35% 반환
    }

    #[test]
    fn test_proactive_action_selection() {
        // 테스트 8: 프로액티브 조치 선택
        let predictor = SelfLearningPredictor::new();

        let actions = predictor.select_proactive_actions("MemoryLeak", 0.80, 0.35);
        assert!(actions.contains(&"AggressiveGC".to_string()));

        let actions = predictor.select_proactive_actions("IOBottleneck", 0.75, 0.40);
        assert!(actions.contains(&"BufferPoolExpansion".to_string()));

        let actions = predictor.select_proactive_actions("CombinedPressure", 0.85, 0.45);
        assert!(actions.len() >= 2);  // 여러 조치 추천
    }

    #[test]
    fn test_system_health_calculation() {
        // 테스트 9: 시스템 건강도 계산
        let mut predictor = SelfLearningPredictor::new();

        // 5개 예측 (3개 성공)
        for _ in 0..3 {
            predictor.record_prediction_accuracy("MemoryLeak", 0.80, 0.82);
        }
        for _ in 0..2 {
            predictor.record_prediction_accuracy("MemoryLeak", 0.80, 0.95);
        }

        let health = predictor.get_system_health();
        assert_eq!(health.predictions_made, 5);
        assert_eq!(health.successful_predictions, 3);
        assert!((health.success_rate - 0.6).abs() < 0.01);
    }

    #[test]
    fn test_time_to_critical_estimation() {
        // 테스트 10: 위기 시간 추정
        let predictor = SelfLearningPredictor::new();

        let time_critical = predictor.estimate_time_to_critical(1, 0.50);
        assert_eq!(time_critical, 1000);  // 1초 이상

        let time_urgent = predictor.estimate_time_to_critical(1, 0.92);
        assert_eq!(time_urgent, 100);  // 100ms 내

        let time_immediate = predictor.estimate_time_to_critical(1, 0.96);
        assert_eq!(time_immediate, 0);  // 즉시 대응
    }
}

