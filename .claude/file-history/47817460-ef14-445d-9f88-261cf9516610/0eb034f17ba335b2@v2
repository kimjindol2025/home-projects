// ============================================================================
// TrendType: 추세 분류
// ============================================================================

enum TrendType {
    Stable,          // 안정적 (변화 <2%/sample)
    Rising,          // 상승 추세 (증가율 >2%/sample)
    Falling,         // 하강 추세 (감소율 >2%/sample)
    Oscillating,     // 진동 (표준편차 높음)
}

impl TrendType {
    fn to_string(&self) -> String {
        match self {
            TrendType::Stable => "Stable".to_string(),
            TrendType::Rising => "Rising".to_string(),
            TrendType::Falling => "Falling".to_string(),
            TrendType::Oscillating => "Oscillating".to_string(),
        }
    }
}

// ============================================================================
// TimeSeriesData: 시계열 데이터
// ============================================================================

struct TimeSeriesData {
    timestamps: Vec<u64>,
    values: Vec<f64>,
    max_size: usize,         // 최대 윈도우 크기 (기본 100)
}

impl TimeSeriesData {
    fn new() -> TimeSeriesData {
        TimeSeriesData {
            timestamps: Vec::new(),
            values: Vec::new(),
            max_size: 100,
        }
    }

    fn add_sample(&mut self, timestamp: u64, value: f64) {
        self.timestamps.push(timestamp);
        self.values.push(value);

        // 윈도우 크기 초과 시 가장 오래된 항목 제거
        if self.values.len() > self.max_size {
            self.timestamps.remove(0);
            self.values.remove(0);
        }
    }

    fn len(&self) -> usize {
        self.values.len()
    }

    fn is_empty(&self) -> bool {
        self.values.is_empty()
    }

    fn get_mean(&self) -> f64 {
        if self.values.is_empty() {
            return 0.0;
        }
        let sum: f64 = self.values.iter().sum();
        sum / self.values.len() as f64
    }

    fn get_std_dev(&self) -> f64 {
        if self.values.len() < 2 {
            return 0.0;
        }
        let mean = self.get_mean();
        let variance: f64 = self.values
            .iter()
            .map(|v| (v - mean).powi(2))
            .sum::<f64>()
            / (self.values.len() - 1) as f64;
        variance.sqrt()
    }

    fn get_trend_type(&self) -> TrendType {
        if self.values.len() < 3 {
            return TrendType::Stable;
        }

        // 최근 3개 샘플로 추세 분석
        let recent_values = &self.values[self.values.len() - 3..];
        let diff1 = recent_values[1] - recent_values[0];
        let diff2 = recent_values[2] - recent_values[1];
        let avg_change = (diff1 + diff2) / 2.0;
        let mean = self.get_mean();

        if mean > 0.0 {
            let change_rate = avg_change / mean;
            if change_rate > 0.02 {
                return TrendType::Rising;
            } else if change_rate < -0.02 {
                return TrendType::Falling;
            }
        }

        let std_dev = self.get_std_dev();
        if std_dev > mean * 0.3 {
            return TrendType::Oscillating;
        }

        TrendType::Stable
    }
}

// ============================================================================
// PolynomialModel: 다항 회귀 모델
// ============================================================================

struct PolynomialModel {
    degree: u32,            // 1=선형, 2=이차, 3=삼차
    coefficients: Vec<f64>, // 최대 4개 (0차-3차 항)
    r_squared: f64,         // 결정계수 (0.0-1.0)
    rmse: f64,              // 제곱근 평균 오차
}

impl PolynomialModel {
    fn new(degree: u32) -> PolynomialModel {
        PolynomialModel {
            degree: degree.min(3),
            coefficients: vec![0.0; (degree.min(3) + 1) as usize],
            r_squared: 0.0,
            rmse: 0.0,
        }
    }

    fn fit(&mut self, x_data: &[f64], y_data: &[f64]) -> bool {
        // 최소 degree+1개 데이터 필요
        if x_data.len() < (self.degree + 1) as usize || x_data.len() != y_data.len() {
            return false;
        }

        // 간단한 선형 회귀 구현 (1차만 지원)
        if self.degree == 1 {
            return self.fit_linear(x_data, y_data);
        }

        // 2차/3차는 근사화 (간단한 구현)
        if self.degree == 2 || self.degree == 3 {
            return self.fit_polynomial_approx(x_data, y_data);
        }

        false
    }

    fn fit_linear(&mut self, x_data: &[f64], y_data: &[f64]) -> bool {
        let n = x_data.len() as f64;
        let mean_x = x_data.iter().sum::<f64>() / n;
        let mean_y = y_data.iter().sum::<f64>() / n;

        let mut numerator = 0.0;
        let mut denominator = 0.0;

        for i in 0..x_data.len() {
            numerator += (x_data[i] - mean_x) * (y_data[i] - mean_y);
            denominator += (x_data[i] - mean_x).powi(2);
        }

        if denominator == 0.0 {
            return false;
        }

        let slope = numerator / denominator;
        let intercept = mean_y - slope * mean_x;

        self.coefficients[0] = intercept;
        self.coefficients[1] = slope;

        // R² 계산
        let mut ss_res = 0.0;
        let mut ss_tot = 0.0;
        for i in 0..y_data.len() {
            let predicted = intercept + slope * x_data[i];
            ss_res += (y_data[i] - predicted).powi(2);
            ss_tot += (y_data[i] - mean_y).powi(2);
        }

        if ss_tot > 0.0 {
            self.r_squared = 1.0 - (ss_res / ss_tot);
        }

        self.rmse = (ss_res / n).sqrt();
        true
    }

    fn fit_polynomial_approx(&mut self, x_data: &[f64], y_data: &[f64]) -> bool {
        // 이차/삼차는 선형으로 근사 (간단한 구현)
        self.fit_linear(x_data, y_data)
    }

    fn predict(&self, x: f64) -> f64 {
        let mut result = 0.0;
        let mut x_power = 1.0;

        for i in 0..=self.degree.min(3) as usize {
            result += self.coefficients[i] * x_power;
            x_power *= x;
        }

        result
    }

    fn predict_with_error(&self, x: f64) -> (f64, f64) {
        let prediction = self.predict(x);
        let error_bound = self.rmse * 2.0; // 95% 신뢰 구간
        (prediction, error_bound)
    }
}

// ============================================================================
// TrendPredictor: 추세 기반 예측기
// ============================================================================

struct TrendPredictor {
    data: TimeSeriesData,
    model_linear: PolynomialModel,
    model_quadratic: PolynomialModel,
    last_prediction_accuracy: f64,
}

impl TrendPredictor {
    fn new() -> TrendPredictor {
        TrendPredictor {
            data: TimeSeriesData::new(),
            model_linear: PolynomialModel::new(1),
            model_quadratic: PolynomialModel::new(2),
            last_prediction_accuracy: 0.0,
        }
    }

    fn add_observation(&mut self, timestamp: u64, value: f64) {
        self.data.add_sample(timestamp, value);

        // 충분한 데이터가 있으면 모델 재학습
        if self.data.len() >= 5 {
            self.retrain_models();
        }
    }

    fn retrain_models(&mut self) {
        let n = self.data.len();
        if n < 2 {
            return;
        }

        // x 데이터를 정규화 (0부터 시작)
        let mut x_normalized = Vec::new();
        for i in 0..n {
            x_normalized.push(i as f64);
        }

        // 선형 모델 학습
        let _ = self.model_linear.fit(&x_normalized, &self.data.values);

        // 이차 모델 학습
        let _ = self.model_quadratic.fit(&x_normalized, &self.data.values);
    }

    fn predict_next_value(&self) -> (f64, f64) {
        // 다음 샘플 예측 (선형 모델 사용)
        let x_next = self.data.len() as f64;
        self.model_linear.predict_with_error(x_next)
    }

    fn predict_value_at(&self, steps_ahead: u32) -> (f64, f64) {
        // steps_ahead만큼 미래의 값 예측
        let x_future = (self.data.len() as u32 + steps_ahead) as f64;
        self.model_linear.predict_with_error(x_future)
    }

    fn get_trend_type(&self) -> TrendType {
        self.data.get_trend_type()
    }

    fn get_forecast_quality(&self) -> f64 {
        // R² 값을 품질로 반환 (0.0-1.0)
        self.model_linear.r_squared
    }
}

// ============================================================================
// TimeToEventPredictor: 특정 이벤트 발생 시간 예측
// ============================================================================

struct TimeToEventPredictor {
    saturation_data: TimeSeriesData,
    threshold: f64,                 // 위기 임계값 (기본 0.95)
    estimated_time_to_event: u32,   // 예상 시간 (ms)
    confidence: f64,                // 예측 신뢰도 (0.0-1.0)
}

impl TimeToEventPredictor {
    fn new(threshold: f64) -> TimeToEventPredictor {
        TimeToEventPredictor {
            saturation_data: TimeSeriesData::new(),
            threshold,
            estimated_time_to_event: 0,
            confidence: 0.0,
        }
    }

    fn add_saturation_sample(&mut self, timestamp: u64, saturation: f64) {
        self.saturation_data.add_sample(timestamp, saturation);

        // 데이터가 충분하면 위기 발생 시간 예측
        if self.saturation_data.len() >= 5 {
            self.estimate_time_to_event();
        }
    }

    fn estimate_time_to_event(&mut self) {
        let n = self.saturation_data.len();
        if n < 2 {
            return;
        }

        // 최근 샘플들의 변화율 계산
        let last_value = self.saturation_data.values[n - 1];
        let prev_value = self.saturation_data.values[n - 2];
        let change_rate = last_value - prev_value;

        // 현재 포화도에서 임계값까지 필요한 시간 추정
        if change_rate > 0.0 {
            let remaining = self.threshold - last_value;
            if remaining > 0.0 {
                // 100ms 샘플링 기준
                let estimated_samples = remaining / change_rate;
                self.estimated_time_to_event = (estimated_samples * 100.0) as u32;

                // 신뢰도 계산 (변화율 일관성 기반)
                if n >= 3 {
                    let prev_change = self.saturation_data.values[n - 2] - self.saturation_data.values[n - 3];
                    let consistency = 1.0 - (change_rate - prev_change).abs() / change_rate.max(0.001);
                    self.confidence = consistency.max(0.3).min(1.0);
                } else {
                    self.confidence = 0.5;
                }
            } else {
                // 이미 임계값 초과
                self.estimated_time_to_event = 0;
                self.confidence = 1.0;
            }
        } else {
            // 감소 중: 위기 발생 예상 안 함
            self.estimated_time_to_event = u32::MAX;
            self.confidence = 1.0;
        }
    }

    fn get_time_to_event(&self) -> Option<u32> {
        if self.estimated_time_to_event == u32::MAX {
            None
        } else if self.estimated_time_to_event > 0 {
            Some(self.estimated_time_to_event)
        } else {
            Some(0)  // 이미 임계값 초과
        }
    }

    fn get_prediction_confidence(&self) -> f64 {
        self.confidence
    }
}

// ============================================================================
// ForecastAccuracy: 예측 정확도 평가
// ============================================================================

struct ForecastAccuracy {
    predictions: Vec<(f64, f64)>,  // (예측값, 실제값)
    errors: Vec<f64>,
    mae: f64,                       // 평균 절대 오차
    rmse: f64,                      // 제곱근 평균 제곱 오차
    mape: f64,                      // 평균 절대 백분율 오차
    accuracy_percentage: f64,       // ±5% 이내 정확도 (%)
}

impl ForecastAccuracy {
    fn new() -> ForecastAccuracy {
        ForecastAccuracy {
            predictions: Vec::new(),
            errors: Vec::new(),
            mae: 0.0,
            rmse: 0.0,
            mape: 0.0,
            accuracy_percentage: 0.0,
        }
    }

    fn record_prediction(&mut self, predicted: f64, actual: f64) {
        self.predictions.push((predicted, actual));
        let error = actual - predicted;
        self.errors.push(error);

        self.update_metrics();
    }

    fn update_metrics(&mut self) {
        if self.predictions.is_empty() {
            return;
        }

        let n = self.predictions.len() as f64;

        // MAE (평균 절대 오차)
        self.mae = self.errors.iter().map(|e| e.abs()).sum::<f64>() / n;

        // RMSE (제곱근 평균 제곱 오차)
        let mse = self.errors.iter().map(|e| e.powi(2)).sum::<f64>() / n;
        self.rmse = mse.sqrt();

        // MAPE (평균 절대 백분율 오차)
        let mut mape_sum = 0.0;
        for (pred, actual) in &self.predictions {
            if actual.abs() > 0.0001 {
                mape_sum += ((actual - pred).abs() / actual.abs());
            }
        }
        self.mape = (mape_sum / n) * 100.0;

        // ±5% 이내 정확도
        let within_5_percent = self.predictions
            .iter()
            .filter(|(pred, actual)| {
                if actual.abs() > 0.0001 {
                    let error_percent = ((actual - pred).abs() / actual.abs()) * 100.0;
                    error_percent <= 5.0
                } else {
                    (pred - actual).abs() <= 0.05
                }
            })
            .count();
        self.accuracy_percentage = (within_5_percent as f64 / n) * 100.0;
    }

    fn get_summary(&self) -> String {
        format!(
            "MAE: {:.4}, RMSE: {:.4}, MAPE: {:.2}%, Accuracy(±5%): {:.1}%",
            self.mae, self.rmse, self.mape, self.accuracy_percentage
        )
    }
}

// ============================================================================
// 테스트 케이스 (8개)
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_timeseries_data_collection() {
        // 테스트 1: 시계열 데이터 수집
        let mut ts = TimeSeriesData::new();

        ts.add_sample(1000, 0.50);
        ts.add_sample(1100, 0.55);
        ts.add_sample(1200, 0.60);

        assert_eq!(ts.len(), 3);
        assert!((ts.get_mean() - 0.55).abs() < 0.01);
    }

    #[test]
    fn test_trend_type_detection() {
        // 테스트 2: 추세 타입 감지
        let mut ts = TimeSeriesData::new();

        // 상승 추세
        ts.add_sample(1000, 0.50);
        ts.add_sample(1100, 0.52);
        ts.add_sample(1200, 0.54);
        ts.add_sample(1300, 0.56);

        let trend = ts.get_trend_type();
        assert_eq!(trend.to_string(), "Rising");
    }

    #[test]
    fn test_polynomial_model_linear() {
        // 테스트 3: 선형 회귀 모델
        let x_data = vec![0.0, 1.0, 2.0, 3.0, 4.0];
        let y_data = vec![1.0, 3.0, 5.0, 7.0, 9.0];  // y = 2x + 1

        let mut model = PolynomialModel::new(1);
        assert!(model.fit(&x_data, &y_data));

        // x=5일 때 y≈11 예상
        let pred = model.predict(5.0);
        assert!((pred - 11.0).abs() < 0.1);

        // R² > 0.95 (매우 좋은 적합)
        assert!(model.r_squared > 0.95);
    }

    #[test]
    fn test_trend_predictor() {
        // 테스트 4: 추세 예측기
        let mut predictor = TrendPredictor::new();

        // 상승 추세 데이터 추가
        for i in 0..10 {
            predictor.add_observation(1000 + i * 100, 0.50 + (i as f64) * 0.05);
        }

        let (next_value, _) = predictor.predict_next_value();
        assert!(next_value > 0.95);  // 상승 추세 계속됨

        assert!(predictor.get_forecast_quality() > 0.8);  // R² > 0.8
    }

    #[test]
    fn test_time_to_event_prediction() {
        // 테스트 5: 위기 발생 시간 예측
        let mut predictor = TimeToEventPredictor::new(0.95);

        // 포화도 증가
        predictor.add_saturation_sample(1000, 0.50);
        predictor.add_saturation_sample(1100, 0.55);
        predictor.add_saturation_sample(1200, 0.60);
        predictor.add_saturation_sample(1300, 0.65);
        predictor.add_saturation_sample(1400, 0.70);

        let time_to_event = predictor.get_time_to_event();
        assert!(time_to_event.is_some());
        let time = time_to_event.unwrap();
        assert!(time > 0 && time < 10000);  // 수분 내 위기 발생

        assert!(predictor.get_prediction_confidence() > 0.3);
    }

    #[test]
    fn test_forecast_accuracy_calculation() {
        // 테스트 6: 예측 정확도 계산
        let mut accuracy = ForecastAccuracy::new();

        accuracy.record_prediction(10.0, 10.5);   // ±5%
        accuracy.record_prediction(20.0, 20.8);   // ±4%
        accuracy.record_prediction(30.0, 30.2);   // ±0.7%
        accuracy.record_prediction(40.0, 42.0);   // ±5%

        assert!(accuracy.accuracy_percentage >= 75.0);  // 75% 이상 정확
        assert!(accuracy.mae < 1.0);
        assert!(accuracy.rmse < 1.2);
    }

    #[test]
    fn test_threshold_exceeded_detection() {
        // 테스트 7: 임계값 초과 감지
        let mut predictor = TimeToEventPredictor::new(0.90);

        // 이미 임계값을 초과
        predictor.add_saturation_sample(1000, 0.92);
        predictor.add_saturation_sample(1100, 0.93);
        predictor.add_saturation_sample(1200, 0.94);

        let time_to_event = predictor.get_time_to_event();
        assert_eq!(time_to_event, Some(0));  // 즉시 대응 필요
        assert_eq!(predictor.get_prediction_confidence(), 1.0);  // 신뢰도 100%
    }

    #[test]
    fn test_multiple_predictions_evaluation() {
        // 테스트 8: 여러 예측 평가
        let mut accuracy = ForecastAccuracy::new();

        // 일관되게 좋은 예측
        for i in 1..=6 {
            let actual = (i * 10) as f64;
            let predicted = actual * 0.98;  // 2% 오차
            accuracy.record_prediction(predicted, actual);
        }

        // MAPE < 3% 기대
        assert!(accuracy.mape < 3.0);
        // 전부 ±5% 이내
        assert_eq!(accuracy.accuracy_percentage, 100.0);
    }
}

