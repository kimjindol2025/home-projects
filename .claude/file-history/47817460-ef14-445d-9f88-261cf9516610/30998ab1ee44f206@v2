pub struct IOBottleneckValidator;

impl IOBottleneckValidator {
    pub fn validate(scenario: &IOBottleneckScenario) -> SuccessCriteria {
        let mut criteria = SuccessCriteria::new("Scenario 3: I/O Bottleneck".to_string());

        // Criterion 1: Latency Spike (T+10s)
        let latency_spike = scenario.current_latency_ms > scenario.baseline_latency_ms * 5.0;
        criteria.add_criterion("I/O latency spike >5x at T+10s".to_string(), latency_spike);

        // Criterion 2: Cache Hit Drop
        let cache_drop = scenario.current_cache_hit_rate < scenario.baseline_cache_hit_rate * 0.2;
        criteria.add_criterion("Cache hit rate < 20% of baseline".to_string(), cache_drop);

        // Criterion 3: Queue Saturation
        let queue_saturated = scenario.current_queue_depth > 40;
        criteria.add_criterion("Queue depth > 40 ops".to_string(), queue_saturated);

        // Criterion 4: Policy Applied
        let policy_applied = scenario.enable_io_queue_prioritization_applied;
        criteria.add_criterion("Policy 'enable_io_queue_prioritization' applied".to_string(), policy_applied);

        // Criterion 5: Overall Verification
        let verified = scenario.verify();
        criteria.add_criterion("Scenario verification passed".to_string(), verified);

        criteria.calculate_pass();
        criteria
    }
}

// ============================================================================
// SCENARIO 4: CASCADING FAILURES VALIDATOR
// ============================================================================

pub struct CascadingFailuresValidator;

impl CascadingFailuresValidator {
    pub fn validate(scenario: &CascadingFailuresScenario) -> SuccessCriteria {
        let mut criteria = SuccessCriteria::new("Scenario 4: Cascading Failures".to_string());

        // Criterion 1: Multiple Metric Degradations
        let latency_bad = scenario.current_p99_latency_ms > 100.0;
        let gc_bad = scenario.current_gc_pause_ms > 150.0;
        let io_bad = scenario.current_latency_ms > 4.0;
        let multi_degrade = latency_bad && gc_bad && io_bad;
        criteria.add_criterion("3 metrics degraded simultaneously".to_string(), multi_degrade);

        // Criterion 2: Cascading Multiplier >1.0
        let cascading_multiplier_active = scenario.combined_degradation_factor > 1.0;
        criteria.add_criterion("Cascading multiplier >1.0".to_string(), cascading_multiplier_active);

        // Criterion 3: Multiple Policies Needed
        let multiple_policies = scenario.reduce_batch_size_applied &&
            scenario.enable_incremental_gc_applied &&
            scenario.enable_io_queue_prioritization_applied;
        criteria.add_criterion("All 3 policies applied in sequence".to_string(), multiple_policies);

        // Criterion 4: Improvement >10% (lower than single-fault due to complexity)
        let improvement = (scenario.baseline_p99_latency_ms - scenario.current_p99_latency_ms)
            / scenario.baseline_p99_latency_ms;
        let improvement_sufficient = improvement > 0.1;
        criteria.add_criterion("Metric improvement >10%".to_string(), improvement_sufficient);

        // Criterion 5: Overall Verification
        let verified = scenario.verify();
        criteria.add_criterion("Scenario verification passed".to_string(), verified);

        criteria.calculate_pass();
        criteria
    }
}

// ============================================================================
// SCENARIO 5: NETWORK PARTITION VALIDATOR
// ============================================================================

pub struct NetworkPartitionValidator;

impl NetworkPartitionValidator {
    pub fn validate(scenario: &NetworkPartitionScenario) -> SuccessCriteria {
        let mut criteria = SuccessCriteria::new("Scenario 5: Network Partition & Recovery".to_string());

        // Criterion 1: Complete Disconnect (T+10s)
        let throughput_zero = scenario.current_throughput_mb_s == 0;
        let latency_timeout = scenario.current_network_latency_us > 50_000_000;
        let complete_disconnect = throughput_zero && latency_timeout;
        criteria.add_criterion("Complete network disconnect at T+10s".to_string(), complete_disconnect);

        // Criterion 2: State Inconsistency Detection
        let inconsistency = scenario.state_inconsistency_detected;
        criteria.add_criterion("State inconsistency detected (coherency < 90%)".to_string(), inconsistency);

        // Criterion 3: Circuit Breaker Active
        let breaker_active = scenario.circuit_breaker_trips > 0;
        criteria.add_criterion("Circuit breaker activated".to_string(), breaker_active);

        // Criterion 4: Recovery Phase (Healing)
        let healing = scenario.current_partition_state < 1.0 && scenario.healing_active;
        criteria.add_criterion("Healing phase initiated".to_string(), healing);

        // Criterion 5: Recovery Successful
        let recovered = scenario.recovery_successful;
        criteria.add_criterion("Full recovery achieved".to_string(), recovered);

        criteria.calculate_pass();
        criteria
    }
}

// ============================================================================
// CHAOS VALIDATOR ENGINE
// ============================================================================

pub struct ChaosValidatorEngine {
    results: HashMap<String, SuccessCriteria>,
    total_scenarios: u32,
    passed_scenarios: u32,
}

impl ChaosValidatorEngine {
    pub fn new() -> Self {
        ChaosValidatorEngine {
            results: HashMap::new(),
            total_scenarios: 0,
            passed_scenarios: 0,
        }
    }

    pub fn validate_all_scenarios(&mut self,
        s1: &TailLatencyScenario,
        s2: &MemoryDegradationScenario,
        s3: &IOBottleneckScenario,
        s4: &CascadingFailuresScenario,
        s5: &NetworkPartitionScenario) {

        // Validate Scenario 1
        let c1 = TailLatencyValidator::validate(s1);
        if c1.overall_pass { self.passed_scenarios += 1; }
        self.results.insert(c1.scenario_id.clone(), c1);
        self.total_scenarios += 1;

        // Validate Scenario 2
        let c2 = MemoryDegradationValidator::validate(s2);
        if c2.overall_pass { self.passed_scenarios += 1; }
        self.results.insert(c2.scenario_id.clone(), c2);
        self.total_scenarios += 1;

        // Validate Scenario 3
        let c3 = IOBottleneckValidator::validate(s3);
        if c3.overall_pass { self.passed_scenarios += 1; }
        self.results.insert(c3.scenario_id.clone(), c3);
        self.total_scenarios += 1;

        // Validate Scenario 4
        let c4 = CascadingFailuresValidator::validate(s4);
        if c4.overall_pass { self.passed_scenarios += 1; }
        self.results.insert(c4.scenario_id.clone(), c4);
        self.total_scenarios += 1;

        // Validate Scenario 5
        let c5 = NetworkPartitionValidator::validate(s5);
        if c5.overall_pass { self.passed_scenarios += 1; }
        self.results.insert(c5.scenario_id.clone(), c5);
        self.total_scenarios += 1;
    }

    pub fn get_overall_pass_rate(&self) -> f64 {
        if self.total_scenarios == 0 {
            0.0
        } else {
            (self.passed_scenarios as f64 / self.total_scenarios as f64) * 100.0
        }
    }

    pub fn generate_validation_report(&self) -> String {
        let mut report = String::new();
        report.push_str("╔═════════════════════════════════════════════════════════════╗\n");
        report.push_str("║         CHAOS ENGINEERING VALIDATION REPORT                 ║\n");
        report.push_str("║         Phase I Week 3: Days 15-17                          ║\n");
        report.push_str("╚═════════════════════════════════════════════════════════════╝\n\n");

        report.push_str(&format!("Total Scenarios: {}\n", self.total_scenarios));
        report.push_str(&format!("Passed: {}\n", self.passed_scenarios));
        report.push_str(&format!("Overall Pass Rate: {:.1}%\n\n", self.get_overall_pass_rate()));

        report.push_str("Scenario Results:\n");
        report.push_str("─────────────────────────────────────────────────────────────\n\n");

        for (_, criteria) in &self.results {
            report.push_str(&criteria.get_report());
            report.push_str("\n");
        }

        report
    }
}

