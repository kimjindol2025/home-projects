// ============================================================================
// SUCCESS CRITERIA FOR EACH SCENARIO
// ============================================================================

pub struct SuccessCriteria {
    pub scenario_id: String,
    pub criteria: Vec<(String, bool)>,  // (criterion_name, is_met)
    pub overall_pass: bool,
    pub completion_percentage: f64,
}

impl SuccessCriteria {
    pub fn new(scenario_id: String) -> Self {
        SuccessCriteria {
            scenario_id,
            criteria: Vec::new(),
            overall_pass: false,
            completion_percentage: 0.0,
        }
    }

    pub fn add_criterion(&mut self, name: String, result: bool) {
        self.criteria.push((name, result));
    }

    pub fn calculate_pass(&mut self) -> bool {
        if self.criteria.is_empty() {
            self.overall_pass = false;
            self.completion_percentage = 0.0;
            return false;
        }

        let met_count = self.criteria.iter().filter(|(_, result)| *result).count();
        self.completion_percentage = (met_count as f64 / self.criteria.len() as f64) * 100.0;
        self.overall_pass = met_count == self.criteria.len();
        self.overall_pass
    }

    pub fn get_report(&self) -> String {
        let mut report = format!("Scenario: {}\n", self.scenario_id);
        report.push_str(&format!("Pass Status: {}\n", if self.overall_pass { "✅" } else { "❌" }));
        report.push_str(&format!("Completion: {:.1}%\n\n", self.completion_percentage));
        report.push_str("Criteria:\n");
        for (name, result) in &self.criteria {
            report.push_str(&format!("  {} {}\n", if *result { "✅" } else { "❌" }, name));
        }
        report
    }
}

// ============================================================================
// SCENARIO 1: TAIL LATENCY VALIDATOR
// ============================================================================

pub struct TailLatencyValidator;

impl TailLatencyValidator {
    pub fn validate(scenario: &TailLatencyScenario) -> SuccessCriteria {
        let mut criteria = SuccessCriteria::new("Scenario 1: Tail Latency Under Load".to_string());

        // Criterion 1: SLO Violation Detection (T+10s)
        let slo_detected = scenario.current_p99_latency_ms > scenario.baseline_p99_latency_ms * 1.5;
        criteria.add_criterion("SLO violation detected at T+10s".to_string(), slo_detected);

        // Criterion 2: Policy Applied (T+20s)
        let policy_applied = scenario.reduce_batch_size_applied;
        criteria.add_criterion("Policy 'reduce_batch_size' applied at T+20s".to_string(), policy_applied);

        // Criterion 3: Improvement >20% (T+60s)
        let improvement = (scenario.baseline_p99_latency_ms - scenario.current_p99_latency_ms)
            / scenario.baseline_p99_latency_ms;
        let improvement_sufficient = improvement > 0.2;
        criteria.add_criterion("Metric improvement >20%".to_string(), improvement_sufficient);

        // Criterion 4: Final P99 <50ms
        let final_acceptable = scenario.current_p99_latency_ms < 50.0;
        criteria.add_criterion("Final P99 latency < 50ms".to_string(), final_acceptable);

        // Criterion 5: Verify Success
        let verified = scenario.verify();
        criteria.add_criterion("Scenario verification passed".to_string(), verified);

        criteria.calculate_pass();
        criteria
    }
}

// ============================================================================
// SCENARIO 2: MEMORY DEGRADATION VALIDATOR
// ============================================================================

pub struct MemoryDegradationValidator;

impl MemoryDegradationValidator {
    pub fn validate(scenario: &MemoryDegradationScenario) -> SuccessCriteria {
        let mut criteria = SuccessCriteria::new("Scenario 2: Memory Degradation".to_string());

        // Criterion 1: GC Pause Spike (T+10s)
        let gc_spike = scenario.current_gc_pause_ms > scenario.baseline_gc_pause_ms * 5.0;
        criteria.add_criterion("GC pause spike >5x at T+10s".to_string(), gc_spike);

        // Criterion 2: Allocation Stall Detection
        let stall_detected = scenario.allocation_stall_incidents > 0;
        criteria.add_criterion("Allocation stalls detected".to_string(), stall_detected);

        // Criterion 3: Policy Applied
        let policy_applied = scenario.enable_incremental_gc_applied;
        criteria.add_criterion("Policy 'enable_incremental_gc' applied".to_string(), policy_applied);

        // Criterion 4: Young Gen Pressure Reduction
        let pressure_reduced = scenario.current_young_gen_pressure < scenario.baseline_young_gen_pressure + 0.3;
        criteria.add_criterion("Young gen pressure < baseline + 0.3".to_string(), pressure_reduced);

        // Criterion 5: Overall Verification
        let verified = scenario.verify();
        criteria.add_criterion("Scenario verification passed".to_string(), verified);

        criteria.calculate_pass();
        criteria
    }
}

