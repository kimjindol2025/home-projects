    let allocator = create_bump_pointer(4096);

    // Allocate 5 objects
    print("Allocating 5 objects:");
    let i = 0;
    while (i < 5) {
        let size = 256u64;
        if (bump_pointer_allocate(&allocator, size) != None) {
            print("  Obj " + i + ": allocated 256 bytes");
        };
        i = i + 1;
    };

    print("");
    bump_pointer_statistics(&allocator);
    print("");
}

fn example_card_marking() {
    print("╔════════════════════════════════════════════╗");
    print("║  Card Marking (Write Barrier) Example       ║");
    print("║  Old→Young Reference Tracking               ║");
    print("╚════════════════════════════════════════════╝");
    print("");

    let table = create_card_table(4096);

    print("Recording Old→Young references:");
    write_barrier(&table, 2048, 256);  // Old object → Young object
    write_barrier(&table, 2560, 512);  // Another Old → Young
    write_barrier(&table, 2048, 768);  // Same Old object → different Young

    print("");
    scan_dirty_cards(&table);

    print("");
    clear_dirty_cards(&table);
    print("");
}

fn main_heap_manager() {
    example_bump_pointer_allocation();
