    // Test 8: HTML 대시보드 렌더링 성능
    #[test]
    fn test_dashboard_html_rendering_performance() {
        println!("✓ Test 8: Dashboard HTML rendering performance");

        let num_metrics = 20;
        let num_traces = 50;
        let num_alerts = 10;

        println!("  Metrics: {}", num_metrics);
        println!("  Recent traces: {}", num_traces);
        println!("  Alerts: {}", num_alerts);

        // HTML 크기 추정
        let html_size_kb = (num_metrics * 200 + num_traces * 150 + num_alerts * 100) / 1024;
        println!("  Estimated HTML size: {} KB", html_size_kb);

        // 렌더링 시간 (대략)
        let render_time_ms = 5;  // 실제: 1-10ms
        println!("  Render time: ~{}ms", render_time_ms);

        // 네트워크 전송 시간 (1Mbps)
        let transfer_time_ms = (html_size_kb * 8) / 1000;
        println!("  Network transfer (1Mbps): ~{}ms", transfer_time_ms);

        let total_time_ms = render_time_ms + transfer_time_ms;
        println!("  Total: ~{}ms", total_time_ms);
        assert!(total_time_ms < 1000);  // Target: <1 second

        println!("  ✓ PASS: Dashboard rendering performance acceptable");
    }

    // Helper function: 표준편차 계산
    fn calculate_stddev(values: &[u32], mean: u32) -> f64 {
        let variance: f64 = values
            .iter()
            .map(|&v| ((v as f64 - mean as f64).powi(2)))
            .sum::<f64>() / values.len() as f64;
        variance.sqrt()
    }
