    // Test 3: SLO 위반 감지 및 알람
    #[test]
    fn test_slo_violation_alert_chain() {
        println!("✓ Test 3: SLO violation alert chain");

        // SLO 목표 설정
        let slo_target = 100.0;  // P99 latency < 100ms
        println!("  SLO target: P99 latency < {}ms", slo_target);

        // 메트릭 수집
        let p99_latency = 150.0;
        println!("  Measured P99 latency: {}ms", p99_latency);

        // 위반 감지
