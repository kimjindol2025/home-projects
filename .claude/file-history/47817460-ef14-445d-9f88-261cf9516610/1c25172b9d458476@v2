    #[test]
    fn test_history_retention_and_memory() {
        println!("✓ Test 7: History retention and memory management");

        let max_history = 3600;  // 1 hour at 1-second interval
        let bytes_per_metric = 200;  // approximate

        let total_memory_mb = (max_history as f64 * bytes_per_metric as f64) / (1024.0 * 1024.0);
        println!("  Max history: {} entries", max_history);
        println!("  Bytes per metric: {} bytes", bytes_per_metric);
        println!("  Total memory: {:.2} MB", total_memory_mb);

        // 최대 알람 보유
        let max_alerts = 500;
        println!("  Max alerts retained: {}", max_alerts);

        // 최대 트레이스 보유
        let max_traces = 100;
        println!("  Max recent traces: {}", max_traces);

        let total_dashboard_memory = total_memory_mb + 0.2;  // alerts + traces
        println!("  Total dashboard memory: {:.2} MB", total_dashboard_memory);
