        // 알람 생성
        let alert_msg = format!("P99 latency {} exceeds SLO {}", p99_latency, slo_target);
        println!("  Alert: {}", alert_msg);

        // 대시보드에 표시
        println!("  Alert rendered in dashboard");

        println!("  ✓ PASS: SLO violation detection chain working");
    }

