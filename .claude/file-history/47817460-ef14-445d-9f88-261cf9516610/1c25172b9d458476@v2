    // Test 5: 메트릭 통계 분석
    #[test]
    fn test_metric_statistical_analysis() {
        println!("✓ Test 5: Metric statistical analysis");

        // 메트릭 데이터
        let latencies = vec![50, 60, 70, 80, 90, 100, 110, 120, 130, 1000];
        println!("  Collected {} latency samples", latencies.len());

        // 평균 계산
        let avg: u32 = latencies.iter().sum::<u32>() / latencies.len() as u32;
        println!("  Average: {}ms", avg);

        // P99 계산 (대략)
        let p99_idx = (latencies.len() as f64 * 0.99) as usize;
        let p99 = if p99_idx < latencies.len() { latencies[p99_idx] } else { latencies[latencies.len()-1] };
        println!("  P99: {}ms", p99);

        // 변화율 계산
        let rate_of_change = (latencies[latencies.len()-1] as f64 - latencies[0] as f64) / 10.0;
        println!("  Rate of change: {:.1}ms/sec", rate_of_change);

        // 이상 감지 (3σ)
        let stddev = calculate_stddev(&latencies, avg);
        println!("  Stddev: {:.1}ms", stddev);

        let anomalies = latencies.iter()
            .filter(|&l| (*l as f64 - avg as f64).abs() > 3.0 * stddev)
            .count();
        println!("  Anomalies detected: {}", anomalies);

        println!("  ✓ PASS: Metric statistical analysis working");
    }

    // Test 6: Trace 샘플링 및 오버헤드 제어
    #[test]
    fn test_trace_sampling_overhead() {
        println!("✓ Test 6: Trace sampling and overhead control");

        let sampling_rates = vec![0.1, 0.5, 1.0];

        for rate in sampling_rates {
            let total_requests = 1000;
            let traced_requests = (total_requests as f64 * rate) as u32;
            let overhead_percent = rate * 100.0;

            println!("  Sampling rate: {:.0}%", overhead_percent);
            println!("    Total requests: {}", total_requests);
            println!("    Traced: {}", traced_requests);
            println!("    Overhead: {:.1}%", overhead_percent);
        }

        // 기본값 100% sampling은 프로덕션에서 조정 필요
        println!("  Production recommendation: Start at 10%, adjust based on load");

        println!("  ✓ PASS: Trace sampling configuration working");
    }

