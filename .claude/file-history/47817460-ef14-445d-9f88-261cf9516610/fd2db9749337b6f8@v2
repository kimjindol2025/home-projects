#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_recovery_pattern_creation() {
        let pattern = RecoveryPattern::new("MemoryLeak".to_string());
        assert_eq!(pattern.pattern_type, "MemoryLeak");
        assert_eq!(pattern.confidence, 0.0);
        assert_eq!(pattern.frequency, 0);
    }

    #[test]
    fn test_pattern_type_conversion() {
        let pattern_type = PatternType::MemoryLeak;
        assert_eq!(pattern_type.to_string(), "MemoryLeak");
    }

    #[test]
    fn test_memory_leak_detection() {
        let mut matcher = PatternMatcher::new();
        let history = vec![0.5, 0.52, 0.54, 0.56, 0.58];

        let pattern = matcher.detect_memory_leak(&history, 1000);
        assert!(pattern.is_some());
    }

    #[test]
    fn test_io_bottleneck_detection() {
        let mut matcher = PatternMatcher::new();

        let pattern = matcher.detect_io_bottleneck(60000, 0.85, 1000);
        assert!(pattern.is_some());
    }

    #[test]
    fn test_thread_contention_detection() {
        let mut matcher = PatternMatcher::new();

        let pattern = matcher.detect_thread_contention(6_000_000, 0.85, 1000);
        assert!(pattern.is_some());
    }

    #[test]
    fn test_cache_thrashing_detection() {
        let mut matcher = PatternMatcher::new();

        let pattern = matcher.detect_cache_thrashing(400, 0.85, 1000);
        assert!(pattern.is_some());
    }

    #[test]
    fn test_combined_pressure_detection() {
        let mut matcher = PatternMatcher::new();

        let pattern = matcher.detect_combined_pressure(0.90, 0.90, 35000, 4_000_000, 1000);
        assert!(pattern.is_some());
    }

    #[test]
    fn test_pattern_matcher_add() {
        let mut matcher = PatternMatcher::new();
        let pattern = RecoveryPattern::new("MemoryLeak".to_string());

        matcher.add_pattern(pattern);
        assert_eq!(matcher.patterns.len(), 1);
    }

    #[test]
    fn test_pattern_is_reliable() {
        let mut pattern = RecoveryPattern::new("MemoryLeak".to_string());
        pattern.confidence = 0.75;
        pattern.frequency = 5;

        assert!(pattern.is_reliable());
    }

    #[test]
    fn test_probability_calculator() {
        let calc = ProbabilityCalculator::new();
        let mut pattern = RecoveryPattern::new("MemoryLeak".to_string());
        pattern.confidence = 0.80;
        pattern.success_rate = 0.75;
        pattern.frequency = 5;

        let probability = calc.calculate_pattern_probability(&pattern);
        assert!(probability > 0.0 && probability < 1.0);
    }

    #[test]
    fn test_pattern_actionability() {
        let calc = ProbabilityCalculator::new();
        let mut pattern = RecoveryPattern::new("MemoryLeak".to_string());
        pattern.confidence = 0.75;
        pattern.success_rate = 0.70;
        pattern.frequency = 3;

        assert!(calc.is_pattern_actionable(&pattern));
    }
}

