// ============================================================================
// RecoveryPattern: 복구 패턴 정의
// ============================================================================

struct RecoveryPattern {
    pattern_id: u32,
    pattern_type: String,           // "MemoryLeak", "IOBottleneck", etc.
    confidence: f64,                // 0.0-1.0 (신뢰도)
    timestamp: u64,                 // 패턴 감지 시간
    duration_ms: u32,               // 지속 시간
    recovery_time_ms: u32,          // 복구 소요 시간
    success_rate: f64,              // 0.0-1.0 (과거 성공률)
    frequency: u32,                 // 과거 발생 횟수
    last_occurrence: u64,           // 마지막 발생 시간
}

impl RecoveryPattern {
    fn new(pattern_type: String) -> RecoveryPattern {
        RecoveryPattern {
            pattern_id: 0,
            pattern_type,
            confidence: 0.0,
            timestamp: 0,
            duration_ms: 0,
            recovery_time_ms: 0,
            success_rate: 0.0,
            frequency: 0,
            last_occurrence: 0,
        }
    }

    fn update_confidence(&mut self, new_evidence: f64) {
        // 베이지안 업데이트: 새로운 증거로 신뢰도 갱신
        // confidence = (confidence + new_evidence) / 2.0 (단순화)
        self.confidence = ((self.confidence * (self.frequency as f64)) + new_evidence)
            / ((self.frequency as f64) + 1.0);
    }

    fn increment_frequency(&mut self, timestamp: u64) {
        self.frequency += 1;
        self.last_occurrence = timestamp;
    }

    fn is_reliable(&self) -> bool {
        // 신뢰할 수 있는 패턴: 신뢰도 >70% AND 발생 >3회
        self.confidence > 0.70 && self.frequency > 3
    }
}

// ============================================================================
// PatternType: 6가지 인식 가능한 패턴
// ============================================================================

enum PatternType {
    MemoryLeak,          // 포화도 지속 상승 (>5%/min)
    IOBottleneck,        // I/O ops >50k/sec + Memory 증가
    ThreadContention,    // Context switches >5M/sec + CPU >80%
    PeriodicLoad,        // 시간 기반 주기적 부하
    CacheThreshing,      // Cache miss >30% + Memory >80%
    CombinedPressure,    // 3+ 압박 동시 발생
}

impl PatternType {
    fn from_string(s: &str) -> PatternType {
        match s {
            "MemoryLeak" => PatternType::MemoryLeak,
            "IOBottleneck" => PatternType::IOBottleneck,
            "ThreadContention" => PatternType::ThreadContention,
            "PeriodicLoad" => PatternType::PeriodicLoad,
            "CacheThreshing" => PatternType::CacheThreshing,
            "CombinedPressure" => PatternType::CombinedPressure,
            _ => PatternType::CombinedPressure,
        }
    }

    fn to_string(&self) -> String {
        match self {
            PatternType::MemoryLeak => "MemoryLeak".to_string(),
            PatternType::IOBottleneck => "IOBottleneck".to_string(),
            PatternType::ThreadContention => "ThreadContention".to_string(),
            PatternType::PeriodicLoad => "PeriodicLoad".to_string(),
            PatternType::CacheThreshing => "CacheThreshing".to_string(),
            PatternType::CombinedPressure => "CombinedPressure".to_string(),
        }
    }

    fn description(&self) -> String {
        match self {
            PatternType::MemoryLeak => "지속적 메모리 상승 (포화도 >5%/min)".to_string(),
            PatternType::IOBottleneck => "I/O 병목 (ops >50k/sec)".to_string(),
            PatternType::ThreadContention => "스레드 경합 (CS >5M/sec)".to_string(),
            PatternType::PeriodicLoad => "주기적 부하 (시간 기반 반복)".to_string(),
            PatternType::CacheThreshing => "캐시 쓰레싱 (miss >30%)".to_string(),
            PatternType::CombinedPressure => "복합 압박 (3+ 동시)".to_string(),
        }
    }
}

// ============================================================================
// PatternMatcher: 패턴 인식 엔진
// ============================================================================

struct PatternMatcher {
    patterns: Vec<RecoveryPattern>,
    max_patterns: usize,
}

impl PatternMatcher {
    fn new() -> PatternMatcher {
        PatternMatcher {
            patterns: Vec::new(),
            max_patterns: 1000,  // 최근 1000개 패턴 유지
        }
    }

    // ========================================================================
    // Pattern 1: Memory Leak Detection
    // ========================================================================

    fn detect_memory_leak(
        &mut self,
        saturation_history: &Vec<f64>,
        timestamp: u64
    ) -> Option<RecoveryPattern> {
        if saturation_history.len() < 5 {
            return None;
        }

        let recent = saturation_history.len();
        let early = saturation_history[recent - 5];
        let latest = saturation_history[recent - 1];

        // 포화도 증가율 계산
        let increase_rate = (latest - early) / 5.0;  // per sample

        // 메모리 누수 신호: 지속적 상승 >1%/sample
        if increase_rate > 0.01 {
            let mut pattern = RecoveryPattern::new("MemoryLeak".to_string());
            pattern.confidence = (increase_rate * 100.0).min(1.0);  // Normalize
            pattern.timestamp = timestamp;
            pattern.frequency = 1;
            pattern.last_occurrence = timestamp;

            self.add_pattern(pattern.clone());
            return Some(pattern);
        }

        None
    }

    // ========================================================================
    // Pattern 2: I/O Bottleneck Detection
    // ========================================================================

    fn detect_io_bottleneck(
        &mut self,
        io_ops: u64,
        memory_saturation: f64,
        timestamp: u64
    ) -> Option<RecoveryPattern> {
        // I/O ops >50k/sec AND Memory >80%
        if io_ops > 50000 && memory_saturation > 0.80 {
            let mut pattern = RecoveryPattern::new("IOBottleneck".to_string());

            // 신뢰도: I/O 강도와 메모리 상관계수
            let io_factor = (io_ops as f64 / 100000.0).min(1.0);  // Normalize
            let mem_factor = (memory_saturation - 0.80) / 0.20;    // 80-100% range
            pattern.confidence = ((io_factor + mem_factor) / 2.0).min(1.0);

            pattern.timestamp = timestamp;
            pattern.frequency = 1;
            pattern.last_occurrence = timestamp;

            self.add_pattern(pattern.clone());
            return Some(pattern);
        }

        None
    }

    // ========================================================================
    // Pattern 3: Thread Contention Detection
    // ========================================================================

    fn detect_thread_contention(
        &mut self,
        context_switches: u64,
        cpu_utilization: f64,
        timestamp: u64
    ) -> Option<RecoveryPattern> {
        // Context switches >5M/sec AND CPU >80%
        if context_switches > 5_000_000 && cpu_utilization > 0.80 {
            let mut pattern = RecoveryPattern::new("ThreadContention".to_string());

            let cs_factor = (context_switches as f64 / 10_000_000.0).min(1.0);
            let cpu_factor = (cpu_utilization - 0.80) / 0.20;
            pattern.confidence = ((cs_factor + cpu_factor) / 2.0).min(1.0);

            pattern.timestamp = timestamp;
            pattern.frequency = 1;
            pattern.last_occurrence = timestamp;

            self.add_pattern(pattern.clone());
            return Some(pattern);
        }

        None
    }

    // ========================================================================
    // Pattern 4: Periodic Load Detection
    // ========================================================================

    fn detect_periodic_load(
        &mut self,
        hour_of_day: u32,
        memory_saturation: f64,
        past_occurrences: u32,
        timestamp: u64
    ) -> Option<RecoveryPattern> {
        // 시간 기반 주기성 확인
        // 같은 시간대에 반복적으로 높은 포화도 발생
        if memory_saturation > 0.75 && past_occurrences > 5 {
            let mut pattern = RecoveryPattern::new("PeriodicLoad".to_string());

            // 신뢰도: 과거 발생 횟수
            pattern.confidence = (past_occurrences as f64 / 20.0).min(1.0);

            pattern.timestamp = timestamp;
            pattern.frequency = past_occurrences;
            pattern.last_occurrence = timestamp;

            self.add_pattern(pattern.clone());
            return Some(pattern);
        }

        None
    }

    // ========================================================================
    // Pattern 5: Cache Thrashing Detection
    // ========================================================================

    fn detect_cache_thrashing(
        &mut self,
        page_faults: u64,
        memory_saturation: f64,
        timestamp: u64
    ) -> Option<RecoveryPattern> {
        // Cache miss rate (page faults) >30% + Memory >80%
        let estimated_miss_rate = (page_faults as f64) / 1000.0;  // Normalize

        if estimated_miss_rate > 0.30 && memory_saturation > 0.80 {
            let mut pattern = RecoveryPattern::new("CacheThreshing".to_string());

            pattern.confidence = ((estimated_miss_rate + memory_saturation) / 2.0).min(1.0);
            pattern.timestamp = timestamp;
            pattern.frequency = 1;
            pattern.last_occurrence = timestamp;

            self.add_pattern(pattern.clone());
            return Some(pattern);
        }

        None
    }

    // ========================================================================
    // Pattern 6: Combined Pressure Detection
    // ========================================================================

    fn detect_combined_pressure(
        &mut self,
        memory_saturation: f64,
        cpu_utilization: f64,
        io_ops: u64,
        context_switches: u64,
        timestamp: u64
    ) -> Option<RecoveryPattern> {
        // 3개 이상의 압박 동시 발생
        let mut high_metric_count = 0;

        if memory_saturation > 0.85 { high_metric_count += 1; }
        if cpu_utilization > 0.85 { high_metric_count += 1; }
        if io_ops > 30000 { high_metric_count += 1; }
        if context_switches > 3_000_000 { high_metric_count += 1; }

        if high_metric_count >= 3 {
            let mut pattern = RecoveryPattern::new("CombinedPressure".to_string());

            // 신뢰도: 높은 메트릭 개수
            pattern.confidence = ((high_metric_count as f64) / 4.0).min(1.0);
            pattern.timestamp = timestamp;
            pattern.frequency = 1;
            pattern.last_occurrence = timestamp;

            self.add_pattern(pattern.clone());
            return Some(pattern);
        }

        None
    }

    // ========================================================================
    // 헬퍼 메서드
    // ========================================================================

    fn add_pattern(&mut self, pattern: RecoveryPattern) {
        self.patterns.push(pattern);

        // 최근 패턴만 유지
        if self.patterns.len() > self.max_patterns {
            self.patterns.remove(0);
        }
    }

    fn find_pattern(&self, pattern_type: &str) -> Option<&RecoveryPattern> {
        for pattern in &self.patterns {
            if pattern.pattern_type == pattern_type {
                return Some(pattern);
            }
        }
        None
    }

    fn get_reliability_score(&self, pattern_type: &str) -> f64 {
        match self.find_pattern(pattern_type) {
            Some(pattern) => {
                if pattern.is_reliable() {
                    pattern.success_rate
                } else {
                    0.0
                }
            },
            None => 0.0,
        }
    }

    fn get_pattern_history_count(&self, pattern_type: &str) -> u32 {
        let mut count = 0;
        for pattern in &self.patterns {
            if pattern.pattern_type == pattern_type {
                count += 1;
            }
        }
        count
    }

    fn predict_next_occurrence(&self, pattern_type: &str) -> Option<u64> {
        if let Some(pattern) = self.find_pattern(pattern_type) {
            // 단순화: 마지막 발생 시간 + 평균 주기
            let avg_interval = 3600000;  // 1시간 (밀리초)
            Some(pattern.last_occurrence + avg_interval)
        } else {
            None
        }
    }
}

// ============================================================================
// ProbabilityCalculator: 확률 계산 엔진
// ============================================================================

struct ProbabilityCalculator {
    threshold_confidence: f64,  // 0.7 (70% 이상만 신뢰)
}

impl ProbabilityCalculator {
    fn new() -> ProbabilityCalculator {
        ProbabilityCalculator {
            threshold_confidence: 0.70,
        }
    }

    fn calculate_pattern_probability(
        &self,
        pattern: &RecoveryPattern
    ) -> f64 {
        // 확률 = Confidence × Success_rate × Frequency_factor
        let frequency_factor = ((pattern.frequency as f64) / 10.0).min(1.0);
        let probability = pattern.confidence * pattern.success_rate * frequency_factor;
        probability
    }

    fn is_pattern_actionable(&self, pattern: &RecoveryPattern) -> bool {
        // 신뢰도가 임계값 이상이고 성공률이 높으면 행동 가능
        pattern.confidence > self.threshold_confidence &&
        pattern.success_rate > 0.60 &&
        pattern.frequency > 2
    }

    fn rank_patterns(
        &self,
        patterns: &Vec<RecoveryPattern>
    ) -> Vec<&RecoveryPattern> {
        let mut ranked = patterns.iter().collect::<Vec<_>>();

        // 신뢰도로 정렬
        ranked.sort_by(|a, b| {
            let prob_a = self.calculate_pattern_probability(a);
            let prob_b = self.calculate_pattern_probability(b);
            prob_b.partial_cmp(&prob_a).unwrap()
        });

        ranked
    }
}

