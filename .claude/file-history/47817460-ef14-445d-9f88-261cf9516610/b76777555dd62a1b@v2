    // Read from all
    let v1 = db_read(db, "client:1:key");
    let v2 = db_read(db, "client:2:key");
    let v3 = db_read(db, "client:3:key");

    let all_ok = (v1 == "value1") && (v2 == "value2") && (v3 == "value3");

    return assert_true(all_ok, "test_concurrent_clients");
}

