    let results = [];

    results.push(test_full_cluster_initialization());
    results.push(test_end_to_end_write_read());
    results.push(test_sharded_db_operations());
    results.push(test_leader_election_in_sharded_db());
    results.push(test_cross_shard_consistency());
    results.push(test_node_failure_no_data_loss());
    results.push(test_scaling_add_node());
    results.push(test_scaling_remove_node());
    results.push(test_chaos_random_failures());
    results.push(test_performance_1000_writes());
    results.push(test_concurrent_clients());
    results.push(test_read_write_consistency());
    results.push(test_snapshot_and_restore());
    results.push(test_cluster_restart());
    results.push(test_production_scenario());

    let i = 0;
    let passed = 0;
    while (i < results.len()) {
        print_test_result(results[i]);
        if (results[i].passed) {
            passed = passed + 1;
        };
        i = i + 1;
    };

    print("");
    print("===============================================");
    print("Results: " + passed + " / " + results.len() + " tests passed");
    print("===============================================");
}

