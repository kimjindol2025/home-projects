fn test_concurrent_clients() -> TestResult {
    let db = new_raft_sharded_db(1, 3, 3);

    db.raft_nodes[0].state = RaftState.Leader;

    // Simulate 3 concurrent clients
    // Client 1
    db = db_write(db, "client:1:key", "value1");

    // Client 2
    db = db_write(db, "client:2:key", "value2");

    // Client 3
