#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_chaos_engine_creation() {
        let engine = ChaosTestEngine::new();
        assert_eq!(engine.total_tests, 0);
        assert_eq!(engine.passed_tests, 0);
    }

    #[test]
    fn test_sudden_memory_spike_scenario() {
        let mut engine = ChaosTestEngine::new();
        let metrics = engine.test_sudden_memory_spike();
        assert_eq!(metrics.system_crashes, 0);
        assert!(!metrics.data_loss_detected);
    }

    #[test]
    fn test_memory_leak_scenario() {
        let mut engine = ChaosTestEngine::new();
        let metrics = engine.test_memory_leak();
        assert_eq!(metrics.system_crashes, 0);  // 중요: 누수에도 크래시 없음
        assert!(metrics.recovery_success_rate > 0.70);
    }

    #[test]
    fn test_graceful_degradation_never_crashes() {
        let mut engine = ChaosTestEngine::new();
        let metrics = engine.test_graceful_degradation_under_load();
        assert_eq!(metrics.system_crashes, 0);
        assert!(!metrics.data_loss_detected);
    }

    #[test]
    fn test_combined_pressure_scenario() {
        let mut engine = ChaosTestEngine::new();
        let metrics = engine.test_combined_pressure();
        assert_eq!(metrics.system_crashes, 0);
        assert_eq!(metrics.inconsistencies, 0);
    }

    #[test]
    fn test_all_tests_completed() {
        let mut engine = ChaosTestEngine::new();
        engine.run_all_tests();
        assert_eq!(engine.total_tests, 8);
        assert!(engine.passed_tests >= 6);  // 최소 6개 이상 통과
    }

    #[test]
    fn test_no_critical_failures() {
        let mut engine = ChaosTestEngine::new();
        engine.run_all_tests();
        let critical = engine.get_critical_failures();
        assert_eq!(critical.len(), 0);  // 크래시/데이터손실/불일치 0개
    }

    #[test]
    fn test_recovery_rate_tracking() {
        let mut engine = ChaosTestEngine::new();
        let metrics = engine.test_sudden_memory_spike();
        assert!(metrics.recovery_success_rate > 0.0);
        assert!(metrics.recovery_success_rate <= 1.0);
    }

    #[test]
    fn test_performance_impact_measured() {
        let mut engine = ChaosTestEngine::new();
        let metrics = engine.test_cpu_spike();
        assert!(metrics.performance_degradation >= 0.0);
        assert!(metrics.performance_degradation <= 1.0);
    }

    #[test]
    fn test_user_experience_calculation() {
        let mut engine = ChaosTestEngine::new();
        let metrics = engine.test_sustained_high_load();
        assert!(metrics.user_experience_impact >= 0.0);
        assert!(metrics.user_experience_impact <= 1.0);
    }

    #[test]
    fn test_pass_fail_status_generation() {
        let mut engine = ChaosTestEngine::new();
        let metrics = engine.test_cpu_spike();
        let status = metrics.pass_fail_status();
        assert!(status.contains("PASS") || status.contains("FAIL"));
    }
}

