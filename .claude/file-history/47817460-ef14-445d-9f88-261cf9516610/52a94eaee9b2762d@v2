// ChaosScenario: 테스트 시나리오
enum ChaosScenario {
    SuddenMemorySpike,        // 갑작스러운 메모리 사용 증가
    SustainedHighLoad,         // 지속적 고부하
    MemoryLeak,               // 메모리 누수 시뮬레이션
    CPUSpike,                 // CPU 급상승
    IOOverload,               // I/O 병목
    NetworkCongestion,        // 네트워크 혼잡
    CacheThrottling,          // 캐시 제약
    ThreadPoolExhaustion,     // 스레드 풀 고갈
    CombinedPressure,         // 복합 압박 (3+ 동시)
    RecoveryUnderLoad,        // 복구 중 지속적 부하
}

// ChaosScenarioConfig: 시나리오 설정
struct ChaosScenarioConfig {
    scenario: ChaosScenario,
    duration_ms: u32,           // 시나리오 지속 시간
    intensity: f64,             // 강도 (0.0-1.0)
    spike_count: u32,           // 스파이크 횟수
    expected_recovery_rate: f64, // 예상 복구율
}

// ============================================================================
// ChaosMetrics: 카오스 테스트 메트릭
// ============================================================================

struct ChaosMetrics {
    scenario_name: String,
    start_saturation: f64,
    peak_saturation: f64,
    end_saturation: f64,

    // 복구 지표
    recovery_attempts: u32,
    successful_recoveries: u32,
    recovery_success_rate: f64,
    avg_recovery_time_ms: u32,

    // 성능 지표
    performance_degradation: f64,  // Level 변화
    user_experience_impact: f64,   // 0.0-1.0

    // 신뢰성 지표
    system_crashes: u32,           // 0이어야 함
    data_loss_detected: bool,      // false이어야 함
    inconsistencies: u32,          // 0이어야 함

    // 시간 정보
    test_duration_ms: u32,
    recovery_duration_ms: u32,
}

impl ChaosMetrics {
    fn new(scenario_name: String) -> ChaosMetrics {
        ChaosMetrics {
            scenario_name,
            start_saturation: 0.0,
            peak_saturation: 0.0,
            end_saturation: 0.0,
            recovery_attempts: 0,
            successful_recoveries: 0,
            recovery_success_rate: 0.0,
            avg_recovery_time_ms: 0,
            performance_degradation: 0.0,
            user_experience_impact: 1.0,
            system_crashes: 0,
            data_loss_detected: false,
            inconsistencies: 0,
            test_duration_ms: 0,
            recovery_duration_ms: 0,
        }
    }

    fn is_successful(&self) -> bool {
        // 성공 기준:
        // 1. 시스템 크래시 0회
        // 2. 데이터 손실 없음
        // 3. 불일치 0개
        // 4. 복구율 >= 80%
        self.system_crashes == 0 &&
        !self.data_loss_detected &&
        self.inconsistencies == 0 &&
        self.recovery_success_rate >= 0.80
    }

    fn pass_fail_status(&self) -> String {
        if self.is_successful() {
            format!("✅ PASS (복구율: {:.1}%)", self.recovery_success_rate * 100.0)
        } else {
            let failures = vec![
                if self.system_crashes > 0 { Some("CRASH".to_string()) } else { None },
                if self.data_loss_detected { Some("DATA_LOSS".to_string()) } else { None },
                if self.inconsistencies > 0 { Some("INCONSISTENCY".to_string()) } else { None },
                if self.recovery_success_rate < 0.80 { Some("LOW_RECOVERY".to_string()) } else { None },
            ].into_iter().filter_map(|x| x).collect::<Vec<_>>();

            format!("❌ FAIL ({})", failures.join(", "))
        }
    }
}

// ============================================================================
// ChaosTestEngine: 카오스 테스트 실행 엔진
// ============================================================================

struct ChaosTestEngine {
    scenarios: Vec<ChaosScenarioConfig>,
    metrics: Vec<ChaosMetrics>,
    total_tests: u32,
    passed_tests: u32,
    failed_tests: u32,
}

impl ChaosTestEngine {
    fn new() -> ChaosTestEngine {
        ChaosTestEngine {
            scenarios: Vec::new(),
            metrics: Vec::new(),
            total_tests: 0,
            passed_tests: 0,
            failed_tests: 0,
        }
    }

    fn add_scenario(&mut self, config: ChaosScenarioConfig) {
        self.scenarios.push(config);
    }

    // ========================================================================
    // Scenario 1: Sudden Memory Spike (Day 15)
    // ========================================================================

    fn test_sudden_memory_spike(&mut self) -> ChaosMetrics {
        let mut metrics = ChaosMetrics::new("SuddenMemorySpike".to_string());

        metrics.start_saturation = 0.50;  // 정상 상태
        metrics.peak_saturation = 0.95;   // 급격히 95%로 상승

        // 복구 시뮬레이션
        // - Intelligent Analyzer: MemoryCriticalRising rule 트리거
        // - Resource Reallocator: Cache evict + Buffer shrink
        // - Graceful Degradation: Level 3 진입

        metrics.recovery_attempts = 3;
        metrics.successful_recoveries = 2;  // 2/3 성공
        metrics.recovery_success_rate = 0.67;  // 67%
        metrics.avg_recovery_time_ms = 120;    // 120ms 평균

        metrics.end_saturation = 0.72;  // 복구 후 72%

        metrics.performance_degradation = 0.15;  // 15% 성능 저하
        metrics.user_experience_impact = 0.85;   // 85% 사용자 경험
        metrics.system_crashes = 0;               // 0 크래시
        metrics.data_loss_detected = false;
        metrics.inconsistencies = 0;
        metrics.test_duration_ms = 3000;
        metrics.recovery_duration_ms = 360;       // 3 attempts × 120ms

        self.record_test(&metrics);
        metrics
    }

    // ========================================================================
    // Scenario 2: Sustained High Load (Day 15)
    // ========================================================================

    fn test_sustained_high_load(&mut self) -> ChaosMetrics {
        let mut metrics = ChaosMetrics::new("SustainedHighLoad".to_string());

        metrics.start_saturation = 0.70;
        metrics.peak_saturation = 0.88;   // 지속적으로 88%

        // 지속적 부하 상황: 계속 메트릭 수집 & 모니터링
        metrics.recovery_attempts = 5;
        metrics.successful_recoveries = 4;  // 4/5 성공
        metrics.recovery_success_rate = 0.80;
        metrics.avg_recovery_time_ms = 150;

        metrics.end_saturation = 0.75;  // 조절됨

        metrics.performance_degradation = 0.25;
        metrics.user_experience_impact = 0.75;
        metrics.system_crashes = 0;
        metrics.data_loss_detected = false;
        metrics.inconsistencies = 0;
        metrics.test_duration_ms = 5000;
        metrics.recovery_duration_ms = 750;

        self.record_test(&metrics);
        metrics
    }

    // ========================================================================
    // Scenario 3: Memory Leak Simulation (Day 16)
    // ========================================================================

    fn test_memory_leak(&mut self) -> ChaosMetrics {
        let mut metrics = ChaosMetrics::new("MemoryLeak".to_string());

        metrics.start_saturation = 0.50;
        metrics.peak_saturation = 0.99;   // 거의 100%에 도달

        // 메모리 누수: 지속적 증가, 자동 GC로 대응
        metrics.recovery_attempts = 8;
        metrics.successful_recoveries = 6;  // 6/8 성공
        metrics.recovery_success_rate = 0.75;
        metrics.avg_recovery_time_ms = 200;

        metrics.end_saturation = 0.82;  // 완전 복구 아님 (누수이므로)

        metrics.performance_degradation = 0.45;
        metrics.user_experience_impact = 0.55;
        metrics.system_crashes = 0;       // 중요: 누수에도 크래시 없음
        metrics.data_loss_detected = false;
        metrics.inconsistencies = 0;
        metrics.test_duration_ms = 8000;
        metrics.recovery_duration_ms = 1600;

        self.record_test(&metrics);
        metrics
    }

    // ========================================================================
    // Scenario 4: CPU Spike (Day 16)
    // ========================================================================

    fn test_cpu_spike(&mut self) -> ChaosMetrics {
        let mut metrics = ChaosMetrics::new("CPUSpike".to_string());

        metrics.start_saturation = 0.60;
        metrics.peak_saturation = 0.92;   // CPU 95%, Memory 92%

        // CPU 부하: 컨텍스트 스위칭 증가
        metrics.recovery_attempts = 2;
        metrics.successful_recoveries = 2;  // 2/2 성공
        metrics.recovery_success_rate = 1.0;  // 100% (최고의 케이스)
        metrics.avg_recovery_time_ms = 80;

        metrics.end_saturation = 0.65;   // 빠른 복구

        metrics.performance_degradation = 0.20;
        metrics.user_experience_impact = 0.80;
        metrics.system_crashes = 0;
        metrics.data_loss_detected = false;
        metrics.inconsistencies = 0;
        metrics.test_duration_ms = 2000;
        metrics.recovery_duration_ms = 160;

        self.record_test(&metrics);
        metrics
    }

    // ========================================================================
    // Scenario 5: I/O Overload (Day 17)
    // ========================================================================

    fn test_io_overload(&mut self) -> ChaosMetrics {
        let mut metrics = ChaosMetrics::new("IOOverload".to_string());

        metrics.start_saturation = 0.55;
        metrics.peak_saturation = 0.85;   // I/O ops 100k+/sec

        // I/O 병목: Disk throttling으로 대응
        metrics.recovery_attempts = 3;
        metrics.successful_recoveries = 2;  // 2/3 성공
        metrics.recovery_success_rate = 0.67;
        metrics.avg_recovery_time_ms = 110;

        metrics.end_saturation = 0.70;

        metrics.performance_degradation = 0.30;
        metrics.user_experience_impact = 0.70;
        metrics.system_crashes = 0;
        metrics.data_loss_detected = false;
        metrics.inconsistencies = 0;
        metrics.test_duration_ms = 4000;
        metrics.recovery_duration_ms = 330;

        self.record_test(&metrics);
        metrics
    }

    // ========================================================================
    // Scenario 6: Combined Pressure (3+ simultaneous) (Day 17)
    // ========================================================================

    fn test_combined_pressure(&mut self) -> ChaosMetrics {
        let mut metrics = ChaosMetrics::new("CombinedPressure".to_string());

        metrics.start_saturation = 0.65;
        metrics.peak_saturation = 0.97;   // Memory + CPU + I/O 모두 높음

        // 복합 압박: 모든 메커니즘 활성화
        metrics.recovery_attempts = 6;
        metrics.successful_recoveries = 4;  // 4/6 성공
        metrics.recovery_success_rate = 0.67;
        metrics.avg_recovery_time_ms = 250;

        metrics.end_saturation = 0.78;

        metrics.performance_degradation = 0.50;
        metrics.user_experience_impact = 0.50;
        metrics.system_crashes = 0;
        metrics.data_loss_detected = false;
        metrics.inconsistencies = 0;
        metrics.test_duration_ms = 6000;
        metrics.recovery_duration_ms = 1500;

        self.record_test(&metrics);
        metrics
    }

    // ========================================================================
    // Scenario 7: Graceful Degradation Under Load (Day 18)
    // ========================================================================

    fn test_graceful_degradation_under_load(&mut self) -> ChaosMetrics {
        let mut metrics = ChaosMetrics::new("GracefulDegradationUnderLoad".to_string());

        metrics.start_saturation = 0.75;
        metrics.peak_saturation = 0.99;   // 긴급 상황

        // Level 4 진입: 성능 30%로 저하되지만 항상 생존
        metrics.recovery_attempts = 1;
        metrics.successful_recoveries = 1;  // 1/1 성공
        metrics.recovery_success_rate = 1.0;  // 100%
        metrics.avg_recovery_time_ms = 50;

        metrics.end_saturation = 0.99;  // 여전히 높음

        metrics.performance_degradation = 0.70;  // 70% 저하 (30% 성능)
        metrics.user_experience_impact = 0.30;   // 30% 사용자 경험
        metrics.system_crashes = 0;               // 중요: 0!
        metrics.data_loss_detected = false;
        metrics.inconsistencies = 0;
        metrics.test_duration_ms = 3000;
        metrics.recovery_duration_ms = 50;

        self.record_test(&metrics);
        metrics
    }

    // ========================================================================
    // Scenario 8: Recovery Under Continuous Load (Day 18)
    // ========================================================================

    fn test_recovery_under_continuous_load(&mut self) -> ChaosMetrics {
        let mut metrics = ChaosMetrics::new("RecoveryUnderContinuousLoad".to_string());

        metrics.start_saturation = 0.80;
        metrics.peak_saturation = 0.95;

        // 복구 중에도 지속적 부하: 재복구 필요
        metrics.recovery_attempts = 10;
        metrics.successful_recoveries = 7;  // 7/10 성공
        metrics.recovery_success_rate = 0.70;
        metrics.avg_recovery_time_ms = 180;

        metrics.end_saturation = 0.76;

        metrics.performance_degradation = 0.35;
        metrics.user_experience_impact = 0.65;
        metrics.system_crashes = 0;
        metrics.data_loss_detected = false;
        metrics.inconsistencies = 0;
        metrics.test_duration_ms = 10000;
        metrics.recovery_duration_ms = 1800;

        self.record_test(&metrics);
        metrics
    }

    // ========================================================================
    // 헬퍼 메서드
    // ========================================================================

    fn record_test(&mut self, metrics: &ChaosMetrics) {
        self.total_tests += 1;

        if metrics.is_successful() {
            self.passed_tests += 1;
        } else {
            self.failed_tests += 1;
        }

        self.metrics.push(ChaosMetrics {
            scenario_name: metrics.scenario_name.clone(),
            start_saturation: metrics.start_saturation,
            peak_saturation: metrics.peak_saturation,
            end_saturation: metrics.end_saturation,
            recovery_attempts: metrics.recovery_attempts,
            successful_recoveries: metrics.successful_recoveries,
            recovery_success_rate: metrics.recovery_success_rate,
            avg_recovery_time_ms: metrics.avg_recovery_time_ms,
            performance_degradation: metrics.performance_degradation,
            user_experience_impact: metrics.user_experience_impact,
            system_crashes: metrics.system_crashes,
            data_loss_detected: metrics.data_loss_detected,
            inconsistencies: metrics.inconsistencies,
            test_duration_ms: metrics.test_duration_ms,
            recovery_duration_ms: metrics.recovery_duration_ms,
        });
    }

    fn run_all_tests(&mut self) -> f64 {
        // Day 15: Tests 1-2
        self.test_sudden_memory_spike();
        self.test_sustained_high_load();

        // Day 16: Tests 3-4
        self.test_memory_leak();
        self.test_cpu_spike();

        // Day 17: Tests 5-6
        self.test_io_overload();
        self.test_combined_pressure();

        // Day 18: Tests 7-8
        self.test_graceful_degradation_under_load();
        self.test_recovery_under_continuous_load();

        if self.total_tests == 0 {
            return 0.0;
        }

        (self.passed_tests as f64) / (self.total_tests as f64)
    }

    fn get_summary(&self) -> String {
        let pass_rate = if self.total_tests > 0 {
            (self.passed_tests as f64) / (self.total_tests as f64) * 100.0
        } else {
            0.0
        };

        format!(
            "Chaos Testing Summary: {}/{} passed ({:.1}%)",
            self.passed_tests, self.total_tests, pass_rate
        )
    }

    fn get_critical_failures(&self) -> Vec<String> {
        let mut failures = Vec::new();

        for metric in &self.metrics {
            if metric.system_crashes > 0 {
                failures.push(format!(
                    "{}: {} system crash(es) detected",
                    metric.scenario_name, metric.system_crashes
                ));
            }

            if metric.data_loss_detected {
                failures.push(format!(
                    "{}: Data loss detected",
                    metric.scenario_name
                ));
            }

            if metric.inconsistencies > 0 {
                failures.push(format!(
                    "{}: {} inconsistencies detected",
                    metric.scenario_name, metric.inconsistencies
                ));
            }
        }

        failures
    }
}

