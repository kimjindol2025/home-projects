    let results = [];

    // Run all 20 tests
    results.push(test_initial_follower_state());
    results.push(test_term_increment_on_election());
    results.push(test_candidate_vote_request());
    results.push(test_vote_granted_conditions());
    results.push(test_vote_rejected_on_old_term());
    results.push(test_leader_election_majority());
    results.push(test_split_vote_reelection());
    results.push(test_leader_heartbeat());
    results.push(test_log_replication_3nodes());
    results.push(test_commit_requires_majority());
    results.push(test_safety_no_two_leaders());
    results.push(test_log_matching_property());
    results.push(test_leader_completeness());
    results.push(test_follower_catchup());
    results.push(test_stale_leader_detection());
    results.push(test_term_monotonic_increase());
    results.push(test_apply_committed_entries());
    results.push(test_network_partition_recovery());
    results.push(test_leader_crash_reelection());
    results.push(test_5node_cluster());

    // Print results
    let i = 0;
    let passed = 0;
    while (i < results.len()) {
        print_test_result(results[i]);
        if (results[i].passed) {
            passed = passed + 1;
        };
        i = i + 1;
    };

    print("");
    print("===============================================");
    print("Results: " + passed + " / " + results.len() + " tests passed");
    print("===============================================");
}

