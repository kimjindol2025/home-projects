include "../src/raft_core.fl"

// Test framework
struct TestResult {
    name: string,
    passed: bool,
    message: string,
}

fn assert_equal(actual: u64, expected: u64, test_name: string) -> TestResult {
    TestResult {
        name: test_name,
        passed: actual == expected,
        message: if (actual == expected) "PASS" else "FAIL: expected " + expected + " got " + actual,
    }
}

fn assert_true(condition: bool, test_name: string) -> TestResult {
    TestResult {
        name: test_name,
        passed: condition,
        message: if (condition) "PASS" else "FAIL: condition is false",
    }
}

fn assert_state(node: RaftNode, expected_state: RaftState, test_name: string) -> TestResult {
    let state_match = false;
    match node.state {
        RaftState.Follower => { if (expected_state == RaftState.Follower) state_match = true; },
        RaftState.Candidate => { if (expected_state == RaftState.Candidate) state_match = true; },
        RaftState.Leader => { if (expected_state == RaftState.Leader) state_match = true; },
    };

    TestResult {
        name: test_name,
        passed: state_match,
        message: if (state_match) "PASS" else "FAIL: state mismatch",
    }
}

fn print_test_result(result: TestResult) {
    if (result.passed) {
        print("✓ " + result.name + ": " + result.message);
    } else {
        print("✗ " + result.name + ": " + result.message);
    };
}

