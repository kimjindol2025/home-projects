fn test_leader_heartbeat() -> TestResult {
    let leader = new_raft_node(0, 3);
    leader = start_election(leader);
    leader = become_leader(leader);

    let follower = new_raft_node(1, 3);
    let election_before = follower.election_elapsed_ms;

    let req = AppendEntriesRequest {
        term: leader.current_term,
        leader_id: leader.id,
        prev_log_index: 0,
        prev_log_term: 0,
        entries: [],
        leader_commit: 0,
    };

    let resp = handle_append_entries(follower, req);
    let election_after = follower.election_elapsed_ms;

    return assert_equal(election_after, 0, "test_leader_heartbeat");
}

