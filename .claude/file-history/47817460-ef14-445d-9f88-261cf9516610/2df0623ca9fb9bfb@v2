fn test_commit_requires_majority() -> TestResult {
    let leader = new_raft_node(0, 3);
    leader = start_election(leader);
    leader = become_leader(leader);

    let entry = LogEntry {
        term: leader.current_term,
        index: 1,
        command: "SET x=1",
    };

    leader = replicate_log(leader, entry);

