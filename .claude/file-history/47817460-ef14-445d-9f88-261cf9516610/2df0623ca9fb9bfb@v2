// ============================================================================
// Test 11: Safety - No Two Leaders
// ============================================================================

fn test_safety_no_two_leaders() -> TestResult {
    let node1 = new_raft_node(0, 3);
    let node2 = new_raft_node(1, 3);

    // Node1 becomes leader in term 5
    node1.current_term = 5;
    node1 = start_election(node1);
    node1.votes_received = 2;
    node1 = become_leader(node1);

    // Node2 cannot become leader in same term (Safety 1)
    node2.current_term = 5;
    node2 = start_election(node2);

    let result1 = assert_state(node1, RaftState.Leader, "test_safety_no_two_leaders");

    return result1;
}

