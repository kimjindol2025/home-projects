// Test 20: 5-Node Cluster
// ============================================================================

fn test_5node_cluster() -> TestResult {
    let node0 = new_raft_node(0, 5);
    let node1 = new_raft_node(1, 5);
    let node2 = new_raft_node(2, 5);
    let node3 = new_raft_node(3, 5);
    let node4 = new_raft_node(4, 5);

    // All start as followers
    let all_followers = (node0.state == RaftState.Follower) &&
                       (node1.state == RaftState.Follower) &&
                       (node2.state == RaftState.Follower) &&
                       (node3.state == RaftState.Follower) &&
                       (node4.state == RaftState.Follower);

    return assert_true(all_followers, "test_5node_cluster");
}

