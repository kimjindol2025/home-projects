// FreeLang Phase 7 Week 3 Days 19-21: Cache Optimizer
// 캐시 최적화 및 프리페치 전략

use std::collections::HashMap;

// ============================================================================
// Cache Block: 캐시 블록 정보
// ============================================================================

pub struct CacheBlock {
    block_id: u64,
    address: u64,                 // 시작 주소
    size: u64,                    // 바이트
    access_count: u32,            // 접근 횟수
    last_access_time: u64,
    priority: f64,                // 0.0-1.0 (높을수록 중요)
    is_dirty: bool,               // 더티 플래그
}

impl Clone for CacheBlock {
    fn clone(&self) -> Self {
        CacheBlock {
            block_id: self.block_id,
            address: self.address,
            size: self.size,
            access_count: self.access_count,
            last_access_time: self.last_access_time,
            priority: self.priority,
            is_dirty: self.is_dirty,
        }
    }
}

// ============================================================================
// Cache Eviction Policy: 캐시 제거 정책
// ============================================================================

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum EvictionPolicy {
    LRU,                          // Least Recently Used
    LFU,                          // Least Frequently Used
    Predictive,                   // 패턴 기반 예측
}

impl EvictionPolicy {
    pub fn to_string(&self) -> String {
        match self {
            EvictionPolicy::LRU => "LRU".to_string(),
            EvictionPolicy::LFU => "LFU".to_string(),
            EvictionPolicy::Predictive => "Predictive".to_string(),
        }
    }
}

// ============================================================================
// Cache Optimizer: 캐시 최적화 엔진
// ============================================================================

pub struct CacheOptimizer {
    blocks: HashMap<u64, CacheBlock>,      // address → CacheBlock
    max_cache_size_mb: u64,
    current_size_mb: u64,
    eviction_policy: EvictionPolicy,
    phase6_patterns: Vec<(String, f64)>,   // (pattern, confidence)
    hit_count: u64,
    miss_count: u64,
    current_time: u64,
}

impl CacheOptimizer {
    pub fn new(max_size_mb: u64, policy: EvictionPolicy) -> Self {
        CacheOptimizer {
            blocks: HashMap::new(),
            max_cache_size_mb: max_size_mb,
            current_size_mb: 0,
            eviction_policy: policy,
            phase6_patterns: vec![],
            hit_count: 0,
            miss_count: 0,
            current_time: 0,
        }
    }

    // 캐시 접근 (Hit/Miss)
    pub fn access_block(&mut self, address: u64) -> bool {
        if let Some(block) = self.blocks.get_mut(&address) {
            block.access_count += 1;
            block.last_access_time = self.current_time;
            self.hit_count += 1;
            true
        } else {
            self.miss_count += 1;
            false
        }
    }

    // 블록 추가 (필요시 제거)
    pub fn add_block(&mut self, block: CacheBlock) -> bool {
        if self.current_size_mb + (block.size / (1024 * 1024)).max(1) <= self.max_cache_size_mb {
            self.current_size_mb += block.size / (1024 * 1024);
            self.blocks.insert(block.address, block);
            true
        } else {
            // 공간 확보 필요
            self.evict_one();
            self.add_block(block)
        }
    }

    // 패턴 기반 캐시 최적화
    pub fn optimize_for_pattern(&mut self, pattern: &str) {
        let cache_line = match pattern {
            "SequentialRead" => 4096,     // 4KB (큰 청크)
            "SequentialWrite" => 4096,
            "RandomRead" => 512,          // 512B (작은 청크)
            "RandomWrite" => 512,
            "Mixed" => 2048,              // 중간값
            "Bursty" => 1024,
            _ => 2048,
        };

        // 캐시 라인 크기 기반 조정
        self.max_cache_size_mb = (self.max_cache_size_mb * cache_line) / 2048;
    }

    // 순차 접근 프리페치
    pub fn prefetch_sequential_blocks(&mut self, current_address: u64, stride: u64) {
        for i in 1..5 {
            let next_address = current_address + (stride * i);
            let prefetch_block = CacheBlock {
                block_id: (next_address / 4096) as u64,
                address: next_address,
                size: 4096,
                access_count: 0,
                last_access_time: self.current_time,
                priority: 0.5,  // 프리페치는 중간 우선순위
                is_dirty: false,
            };

            if !self.blocks.contains_key(&next_address) {
                let _ = self.add_block(prefetch_block);
            }
        }
    }

    // 캐시 적중률
    pub fn get_hit_rate(&self) -> f64 {
        let total = self.hit_count + self.miss_count;
        if total == 0 {
            0.0
        } else {
            (self.hit_count as f64) / (total as f64)
        }
    }

    // 워킹 세트 크기 추정 (MB)
    pub fn estimate_working_set_size(&self) -> u64 {
        let mut sizes: Vec<u64> = self.blocks.values().map(|b| b.size).collect();
        sizes.sort();

        // 상위 80% 누적 합
        let mut sum = 0u64;
        let target = (sizes.len() as u64 * 80) / 100;
        for (idx, size) in sizes.iter().enumerate() {
            sum += size;
            if idx as u64 >= target {
                break;
            }
        }

        sum / (1024 * 1024)  // MB로 변환
    }

    // 권장 캐시 크기 (Phase 6 연동)
    pub fn recommend_cache_size(&self, pattern: &str) -> u64 {
        let base = self.estimate_working_set_size();

        match pattern {
            "SequentialRead" => (base as f64 * 2.0) as u64,     // 2배
            "SequentialWrite" => (base as f64 * 1.5) as u64,    // 1.5배
            "RandomRead" => (base as f64 * 4.0) as u64,         // 4배 (캐시 효율 중요)
            "RandomWrite" => (base as f64 * 3.0) as u64,
            "Mixed" => (base as f64 * 2.5) as u64,
            "Bursty" => (base as f64 * 1.2) as u64,             // 1.2배 (임시)
            _ => base,
        }
    }

    // Phase 6 패턴 동기화
    pub fn sync_with_phase6(&mut self, pattern: &str, confidence: f64) {
        self.phase6_patterns.push((pattern.to_string(), confidence));

        if self.phase6_patterns.len() > 10 {
            self.phase6_patterns.remove(0);
        }

        // 패턴에 따라 캐시 최적화
        self.optimize_for_pattern(pattern);
    }

    // 시간 경과
    pub fn advance_time(&mut self, delta_ms: u64) {
        self.current_time += delta_ms;

        // 오래된 블록 제거 (2초 이상 미접근)
        let cutoff_time = self.current_time.saturating_sub(2000);
        self.blocks.retain(|_, block| block.last_access_time > cutoff_time || block.access_count > 0);
    }

    // ========================================================================
    // Helper Methods
    // ========================================================================

    fn evict_one(&mut self) {
        if self.blocks.is_empty() {
            return;
        }

        let victim_address = match self.eviction_policy {
            EvictionPolicy::LRU => self.find_lru_victim(),
            EvictionPolicy::LFU => self.find_lfu_victim(),
            EvictionPolicy::Predictive => self.find_predictive_victim(),
        };

        if let Some(addr) = victim_address {
            if let Some(block) = self.blocks.remove(&addr) {
                self.current_size_mb = self.current_size_mb.saturating_sub(block.size / (1024 * 1024));
            }
        }
    }

    fn find_lru_victim(&self) -> Option<u64> {
        self.blocks
            .iter()
            .min_by_key(|(_, b)| b.last_access_time)
            .map(|(addr, _)| *addr)
    }

    fn find_lfu_victim(&self) -> Option<u64> {
        self.blocks
            .iter()
            .min_by_key(|(_, b)| b.access_count)
            .map(|(addr, _)| *addr)
    }

    fn find_predictive_victim(&self) -> Option<u64> {
        // 우선순위 + 접근 빈도 고려
        self.blocks
            .iter()
            .min_by(|(_, b1), (_, b2)| {
                let score1 = b1.priority * (b1.access_count as f64);
                let score2 = b2.priority * (b2.access_count as f64);
                score1.partial_cmp(&score2).unwrap()
            })
            .map(|(addr, _)| *addr)
    }
}

// ============================================================================
// TEST CASES
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    // Test 1: LRU 제거 정책
    #[test]
    fn test_lru_eviction() {
        let mut cache = CacheOptimizer::new(2, EvictionPolicy::LRU);

        let block1 = CacheBlock {
            block_id: 1,
            address: 0,
            size: 1024 * 1024,
            access_count: 5,
            last_access_time: 100,
            priority: 0.5,
            is_dirty: false,
        };

        let block2 = CacheBlock {
            block_id: 2,
            address: 4096,
            size: 1024 * 1024,
            access_count: 3,
            last_access_time: 200,
            priority: 0.5,
            is_dirty: false,
        };

        assert!(cache.add_block(block1));
        assert!(cache.add_block(block2));

        // 3번째 블록 추가 시 가장 오래된 블록 제거
        let block3 = CacheBlock {
            block_id: 3,
            address: 8192,
            size: 1024 * 1024,
            access_count: 1,
            last_access_time: 150,
            priority: 0.5,
            is_dirty: false,
        };

        assert!(cache.add_block(block3));
        assert_eq!(cache.blocks.len(), 2);
    }

    // Test 2: 캐시 적중률
    #[test]
    fn test_hit_rate_calculation() {
        let mut cache = CacheOptimizer::new(10, EvictionPolicy::LRU);

        let block = CacheBlock {
            block_id: 1,
            address: 0,
            size: 1024 * 1024,
            access_count: 0,
            last_access_time: 0,
            priority: 0.5,
            is_dirty: false,
        };

        cache.add_block(block);
        cache.access_block(0);    // Hit
        cache.access_block(4096); // Miss
        cache.access_block(0);    // Hit

        assert!(cache.get_hit_rate() > 0.5);
    }

    // Test 3: 프리페치 기능
    #[test]
    fn test_sequential_prefetch() {
        let mut cache = CacheOptimizer::new(20, EvictionPolicy::Predictive);

        cache.prefetch_sequential_blocks(0, 4096);

        // 최소 1개 프리페치 블록 추가
        assert!(cache.blocks.len() >= 1);
    }

    // Test 4: 패턴 기반 최적화
    #[test]
    fn test_pattern_optimization() {
        let mut cache = CacheOptimizer::new(10, EvictionPolicy::LRU);
        let initial_size = cache.max_cache_size_mb;

        cache.optimize_for_pattern("SequentialRead");
        assert!(cache.max_cache_size_mb >= initial_size);
    }

    // Test 5: 워킹 세트 크기 추정
    #[test]
    fn test_working_set_estimation() {
        let mut cache = CacheOptimizer::new(20, EvictionPolicy::LRU);

        for i in 0..5 {
            let block = CacheBlock {
                block_id: i,
                address: i as u64 * 4096,
                size: 1024 * 1024,
                access_count: (5 - i) as u32,
                last_access_time: i as u64 * 100,
                priority: (i as f64) / 5.0,
                is_dirty: false,
            };
            let _ = cache.add_block(block);
        }

        let ws = cache.estimate_working_set_size();
        assert!(ws > 0);
    }

    // Test 6: 권장 캐시 크기
    #[test]
    fn test_cache_size_recommendation() {
        let mut cache = CacheOptimizer::new(10, EvictionPolicy::LFU);

        for i in 0..3 {
            let block = CacheBlock {
                block_id: i,
                address: i as u64 * 4096,
                size: 1024 * 1024,
                access_count: 1,
                last_access_time: 0,
                priority: 0.5,
                is_dirty: false,
            };
            let _ = cache.add_block(block);
        }

        let rec_size = cache.recommend_cache_size("RandomRead");
        assert!(rec_size > 0);
    }

    // Test 7: Phase 6 패턴 동기화
    #[test]
    fn test_phase6_sync() {
        let mut cache = CacheOptimizer::new(10, EvictionPolicy::Predictive);
        cache.sync_with_phase6("MemoryLeak", 0.95);

        assert_eq!(cache.phase6_patterns.len(), 1);
    }

    // Test 8: 더티 블록 추적
    #[test]
    fn test_dirty_block_tracking() {
        let mut cache = CacheOptimizer::new(10, EvictionPolicy::LRU);

        let mut block = CacheBlock {
            block_id: 1,
            address: 0,
            size: 1024 * 1024,
            access_count: 0,
            last_access_time: 0,
            priority: 0.5,
            is_dirty: true,
        };

        assert!(cache.add_block(block));
        assert!(cache.blocks.get(&0).unwrap().is_dirty);
    }
}
