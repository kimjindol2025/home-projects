#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_fault_type_severity() {
        let latency_spike = FaultType::LatencySpike(250);
        assert_eq!(latency_spike.severity(), 4);

        let memory_leak = FaultType::MemoryLeak(50_000_000);
        assert_eq!(memory_leak.severity(), 4);

        let network_partition = FaultType::NetworkPartition;
        assert_eq!(network_partition.severity(), 5);
    }

    #[test]
    fn test_fault_instance_active() {
        let fault = FaultInstance {
            fault_id: "FAULT-1".to_string(),
            fault_type: FaultType::LatencySpike(100),
            start_time_us: 1000_000_000,
            duration_ms: 5000,
            end_time_us: None,
            status: "active".to_string(),
        };

        // Before start time
        assert!(!fault.is_active(999_000_000));

        // During fault
        assert!(fault.is_active(1000_000_000));
        assert!(fault.is_active(1002_500_000));

        // After fault
        assert!(!fault.is_active(1006_000_000));
    }

    #[test]
    fn test_fault_elapsed_and_remaining() {
        let fault = FaultInstance {
            fault_id: "FAULT-1".to_string(),
            fault_type: FaultType::LatencySpike(100),
            start_time_us: 1000_000_000,
            duration_ms: 5000,
            end_time_us: None,
            status: "active".to_string(),
        };

        assert_eq!(fault.get_elapsed_ms(1001_000_000), 1000);
        assert_eq!(fault.get_remaining_ms(1001_000_000), 4000);

        assert_eq!(fault.get_elapsed_ms(1005_500_000), 5500);
        assert_eq!(fault.get_remaining_ms(1005_500_000), 0);
    }

    #[test]
    fn test_metric_degradation_latency_spike() {
        let degradation = MetricDegradation::from_fault_type(&FaultType::LatencySpike(300));

        assert!(degradation.p99_latency_increase_percent > 100.0);
        assert!(degradation.scheduler_queue_increase_percent > 40.0);
        assert!(degradation.context_switch_increase_percent > 100.0);
        assert_eq!(degradation.memory_usage_increase_percent, 0.0);
    }

    #[test]
    fn test_metric_degradation_memory_leak() {
        let degradation = MetricDegradation::from_fault_type(&FaultType::MemoryLeak(50_000_000));

        assert!(degradation.memory_usage_increase_percent > 50.0);
        assert!(degradation.gc_pause_increase_percent > 50.0);
        assert!(degradation.allocation_stall_percent > 10.0);
        assert_eq!(degradation.p99_latency_increase_percent, 0.0);
    }

    #[test]
    fn test_metric_degradation_network_partition() {
        let degradation = MetricDegradation::from_fault_type(&FaultType::NetworkPartition);

        assert_eq!(degradation.cache_hit_drop_total, 0.7); // Catastrophic
        assert_eq!(degradation.throughput_reduction_percent, 100.0);
    }

    #[test]
    fn test_fault_injection_engine() {
        let mut engine = FaultInjectionEngine::new();

        let fault_id = engine.inject_fault(
            FaultType::LatencySpike(150),
            5000,
            1000_000_000,
        );

        assert_eq!(fault_id, "FAULT-1");

        let active = engine.check_fault_active(1000_000_000);
        assert_eq!(active.len(), 1);

        let active_after = engine.check_fault_active(1006_000_000);
        assert_eq!(active_after.len(), 0);
    }

    #[test]
    fn test_combined_degradation_multiple_faults() {
        let mut engine = FaultInjectionEngine::new();

        let fault1 = engine.inject_fault(
            FaultType::LatencySpike(100),
            5000,
            1000_000_000,
        );
        let fault2 = engine.inject_fault(
            FaultType::GCPause(100),
            3000,
            1000_000_000,
        );

        let combined = engine.get_combined_degradation(1000_000_000);

        // Both faults active, so combined effect > single fault
        let single_latency = MetricDegradation::from_fault_type(&FaultType::LatencySpike(100));
        assert!(combined.p99_latency_increase_percent > single_latency.p99_latency_increase_percent);
    }

    #[test]
    fn test_fault_timeline_logging() {
        let mut engine = FaultInjectionEngine::new();

        engine.inject_fault(FaultType::LatencySpike(100), 5000, 1000_000_000);
        engine.inject_fault(FaultType::MemoryLeak(10_000_000), 3000, 1000_000_500);
        engine.remove_fault("FAULT-1", 1005_000_000);

        let timeline = engine.get_timeline();
        assert!(timeline.contains("LatencySpike"));
        assert!(timeline.contains("MemoryLeak"));
        assert!(timeline.contains("REMOVED"));
    }

    #[test]
    fn test_fault_severity_consistency() {
        let mild_latency = FaultType::LatencySpike(50);
        let severe_latency = FaultType::LatencySpike(400);

        assert!(mild_latency.severity() < severe_latency.severity());
    }

    #[test]
    fn test_degradation_capping() {
        let mut engine = FaultInjectionEngine::new();

        // Inject multiple high-severity faults
        for i in 0..5 {
            engine.inject_fault(
                FaultType::LatencySpike(400),
                5000,
                1000_000_000,
            );
        }

        let combined = engine.get_combined_degradation(1000_000_000);

        // Verify capping at reasonable values
        assert!(combined.p99_latency_increase_percent <= 500.0);
        assert!(combined.memory_pressure_increase <= 1.0);
        assert!(combined.cache_hit_drop_total <= 1.0);
    }
}
