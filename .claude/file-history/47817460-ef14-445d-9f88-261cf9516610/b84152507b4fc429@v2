#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_analyzer_creation() {
        let analyzer = PressureAnalyzer::new();
        assert_eq!(analyzer.action_history.len(), 0);
        assert!(analyzer.ml_model_accuracy > 0.9);
    }

    #[test]
    fn test_rule_1_high_cpu_memory() {
        let analyzer = PressureAnalyzer::new();
        let result = analyzer.check_rule_1_high_cpu_memory(0.90, 0.85);
        assert!(result);

        let result_false = analyzer.check_rule_1_high_cpu_memory(0.70, 0.75);
        assert!(!result_false);
    }

    #[test]
    fn test_rule_2_high_page_faults() {
        let analyzer = PressureAnalyzer::new();
        let result = analyzer.check_rule_2_high_page_faults(1500, 1000);
        assert!(result);

        let result_false = analyzer.check_rule_2_high_page_faults(500, 1000);
        assert!(!result_false);
    }

    #[test]
    fn test_rule_4_memory_critical_rising() {
        let analyzer = PressureAnalyzer::new();
        let result = analyzer.check_rule_4_memory_critical_rising(0.99, true);
        assert!(result);

        let result_false = analyzer.check_rule_4_memory_critical_rising(0.95, false);
        assert!(!result_false);
    }

    #[test]
    fn test_analyze_normal_state() {
        let mut analyzer = PressureAnalyzer::new();

        let result = analyzer.analyze(
            0.5,    // cpu_util
            0.5,    // memory_saturation
            5_000_000,    // context_switches
            500,    // page_faults
            32,     // thread_count
            50_000, // io_operations
            false,  // is_rising_trend
            1000    // timestamp
        );

        match result.recommended_action {
            RecommendedAction::Monitor => assert!(true),
            _ => assert!(false),
        }
    }

    #[test]
    fn test_analyze_high_cpu_memory() {
        let mut analyzer = PressureAnalyzer::new();

        let result = analyzer.analyze(
            0.90,   // cpu_util (높음)
            0.85,   // memory_saturation (높음)
            5_000_000,    // context_switches
            500,    // page_faults
            32,     // thread_count
            50_000, // io_operations
            false,  // is_rising_trend
            1000    // timestamp
        );

        assert_eq!(result.triggered_rules.len(), 1);
        assert!(result.confidence > 0.7);
    }

    #[test]
    fn test_analyze_critical_memory() {
        let mut analyzer = PressureAnalyzer::new();

        let result = analyzer.analyze(
            0.5,    // cpu_util
            0.99,   // memory_saturation (긴급)
            5_000_000,    // context_switches
            500,    // page_faults
            32,     // thread_count
            50_000, // io_operations
            true,   // is_rising_trend (상승 중!)
            1000    // timestamp
        );

        match result.recommended_action {
            RecommendedAction::EmergencyShutdown => assert!(true),
            _ => assert!(false),
        }

        assert_eq!(result.priority, 10);  // 최고 우선순위
    }

    #[test]
    fn test_confidence_calculation() {
        let mut analyzer = PressureAnalyzer::new();

        // 0개 규칙
        let result_0 = analyzer.analyze(0.5, 0.5, 5_000_000, 500, 32, 50_000, false, 1000);
        assert!(result_0.confidence < 0.6);

        // 2개 규칙
        let mut analyzer2 = PressureAnalyzer::new();
        let result_2 = analyzer2.analyze(0.90, 0.85, 1_500_000, 1500, 32, 50_000, false, 2000);
        assert!(result_2.confidence > 0.8);
    }

    #[test]
    fn test_action_history() {
        let mut analyzer = PressureAnalyzer::new();

        analyzer.analyze(0.5, 0.5, 5_000_000, 500, 32, 50_000, false, 1000);
        analyzer.analyze(0.90, 0.85, 5_000_000, 500, 32, 50_000, false, 2000);

        assert_eq!(analyzer.action_history.len(), 2);
    }

    #[test]
    fn test_action_frequency() {
        let mut analyzer = PressureAnalyzer::new();

        // Normal
        analyzer.analyze(0.5, 0.5, 5_000_000, 500, 32, 50_000, false, 1000);
        // High CPU+Memory
        analyzer.analyze(0.90, 0.85, 5_000_000, 500, 32, 50_000, false, 2000);

        let freq = analyzer.get_action_frequency();
        assert!(freq.monitor > 0 || freq.suspend > 0);
    }
}

