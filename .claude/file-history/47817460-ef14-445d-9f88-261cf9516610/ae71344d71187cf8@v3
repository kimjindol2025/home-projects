#[cfg(test)]
mod integration_tests {
    use super::*;

    #[test]
    fn test_full_observability_stack_week1() {
        let mut stack = ObservabilityStack::new();

        // 시작 추적
        stack.start_trace("trace-001");

        // 스팬 시작
        let span_id = stack.start_span("trace-001", "api_request").unwrap();

        // 메트릭 기록
        stack.record_cpu_metric(75.0, 250, Some("trace-001".to_string()));
        stack.record_memory_metric(1024, 50, 0.2, Some("trace-001".to_string()));

        // SLO 설정
        stack.set_slo_target("cpu.utilization".to_string(), 90.0);

        // 시간 경과
        stack.advance_time(1_000_000);

        // 대시보드 업데이트
        stack.add_dashboard_trace("trace-001".to_string(), "api_request".to_string(), 150, "completed".to_string());

        // 위반 확인
        stack.check_violations();

        // HTML 렌더링
        let html = stack.render_dashboard_html();
        assert!(html.contains("Phase H Monitoring Dashboard"));
    }

    #[test]
    fn test_design_by_failure_workflow() {
        let mut stack = ObservabilityStack::new();

        // Step 1: Failure Detection (Week 2 Step 1)
        let failures = stack.detect_failures(
            150,   // P99 latency (SLO breach: >100ms)
            75,    // Scheduler queue (>50%)
            1200,  // Context switch rate
            500,   // Previous rate
            0.75,  // Fragmentation (>0.7)
            120,   // GC pause (>100ms)
            0.85,  // Memory pressure (>0.8)
            5,     // Allocation failures
            100,   // I/O queue depth
            2000,  // I/O latency
            0.5,   // Cache hit rate
            0.8,   // Previous cache hit
        );

        assert!(failures.len() >= 2); // At least Latency + Memory

        // Step 2: Causality Event Collection (Week 2 Step 2)
        stack.add_causality_event(1000_000_000, "GC".to_string(), 120.0, 4);
        stack.add_causality_event(1000_000_500, "Scheduler".to_string(), 75.0, 3);
        stack.add_causality_event(1000_001_500, "LatencySpike".to_string(), 150.0, 5);

        // Step 3: Causality Inference (Week 2 Step 3)
        stack.infer_causality_and_identify_root_causes();

        // Step 4: Root Cause Identification (Week 2 Step 4)
        let root_causes = stack.get_root_causes();
        assert!(!root_causes.is_empty());
    }

    #[test]
    fn test_latency_explosion_to_policy() {
        let mut stack = ObservabilityStack::new();

        // Latency explosion 감지
        let failures = stack.detect_failures(
            150,   // P99 > threshold
            75,    // Queue depth high
            1200,  // CS spike
            500,
            0.3,   // Normal memory
            50,    // Normal GC
            0.5,   // Normal memory pressure
            0,
            50,    // Normal I/O
            500,
            0.9,   // Good cache
            0.9,
        );

        assert!(!failures.is_empty());
        let failure = &failures[0];
        assert_eq!(failure.class, "LatencyExplosion");
        assert!(failure.confidence > 0.5);
    }

    #[test]
    fn test_memory_collapse_to_policy() {
        let mut stack = ObservabilityStack::new();

        // Memory collapse 감지
        let failures = stack.detect_failures(
            80,    // Normal P99
            30,    // Normal queue
            500,   // Normal CS
            500,
            0.8,   // High fragmentation
            150,   // High GC pause
            0.85,  // High memory pressure
            10,    // Allocation failures
            20,    // Normal I/O
            200,
            0.9,   // Good cache
            0.9,
        );

        assert!(!failures.is_empty());
        let memory_failure = failures.iter().find(|f| f.class == "MemoryCollapse");
        assert!(memory_failure.is_some());
    }

    #[test]
    fn test_no_false_positives_all_normal() {
        let mut stack = ObservabilityStack::new();

        // All metrics normal
        let failures = stack.detect_failures(
            50,    // P99 normal
            25,    // Queue normal
            500,   // CS normal
            500,
            0.3,   // Fragmentation normal
            30,    // GC pause normal
            0.4,   // Memory pressure normal
            0,
            15,    // I/O queue normal
            300,
            0.92,  // Cache hit good
            0.92,
        );

        assert_eq!(failures.len(), 0); // No false positives
    }

    #[test]
    fn test_week2_integration_with_phase7() {
        // Phase 7 (Adaptive Resource Allocation)과의 통합 시뮬레이션
        let mut stack = ObservabilityStack::new();

        // 1. Failure 감지
        let failures = stack.detect_failures(
            150, 75, 1200, 500, 0.75, 120, 0.85, 5, 100, 2000, 0.5, 0.8
        );

        // 2. Causality 분석
        stack.add_causality_event(1000_000_000, "GC".to_string(), 120.0, 4);
        stack.add_causality_event(1000_000_500, "Scheduler".to_string(), 75.0, 3);
        stack.add_causality_event(1000_001_500, "P99Spike".to_string(), 150.0, 5);
        stack.infer_causality_and_identify_root_causes();
        let root_causes = stack.get_root_causes();

        // 3. 결과 검증
        assert!(!failures.is_empty());
        assert!(!root_causes.is_empty());
    }
}
