    // Test 8: DistributedPredictionSystem 의사결정 이력
    #[test]
    fn test_decision_history_tracking() {
        let mut dps = DistributedPredictionSystem::new();

        let forecasts = vec![NodeForecast {
            node_id: 1,
            pattern_type: "MemoryLeak".to_string(),
            predicted_saturation: 0.9,
            confidence: 0.95,
            time_to_critical: 100,
            freshness_score: 100.0,
        }];

        let votes = vec![Vote {
            node_id: 1,
            decision: "execute".to_string(),
            confidence: 0.95,
            reasoning: "Critical memory leak".to_string(),
        }];

        let trust_scores = HashMap::new();

        // 첫 번째 의사결정
        dps.execute_distributed_prediction(
            &forecasts,
            &votes,
            &trust_scores,
            None,
            100,
        );

        assert_eq!(dps.get_decision_history().len(), 1);
        assert!(dps.get_last_decision().is_some());

        // 두 번째 의사결정
        dps.execute_distributed_prediction(
            &forecasts,
            &votes,
            &trust_scores,
            None,
            200,
        );

        assert_eq!(dps.get_decision_history().len(), 2);
    }
}
