use std::collections::HashMap;

// ============================================================================
// Memory Pressure Level: 메모리 압박 단계
// ============================================================================

#[derive(Debug, Clone, Copy, PartialEq, Eq, PartialOrd, Ord)]
pub enum MemoryPressureLevel {
    Normal,                // < 60% 사용
    Warning,               // 60-80% 사용
    Critical,              // 80-95% 사용
    Emergency,             // 95-100% 사용
}

impl MemoryPressureLevel {
    pub fn to_string(&self) -> String {
        match self {
            MemoryPressureLevel::Normal => "Normal".to_string(),
            MemoryPressureLevel::Warning => "Warning".to_string(),
            MemoryPressureLevel::Critical => "Critical".to_string(),
            MemoryPressureLevel::Emergency => "Emergency".to_string(),
        }
    }

    pub fn urgency_score(&self) -> f64 {
        match self {
            MemoryPressureLevel::Normal => 0.0,
            MemoryPressureLevel::Warning => 0.3,
            MemoryPressureLevel::Critical => 0.7,
            MemoryPressureLevel::Emergency => 1.0,
        }
    }
}

// ============================================================================
// Memory Action: 메모리 압박 대응 조치
// ============================================================================

#[derive(Debug, Clone, Copy, PartialEq, Eq)]
pub enum MemoryAction {
    CompactMemory,              // 메모리 컴팩션
    DropPageCache,              // 페이지 캐시 제거
    ShrinkHeap,                 // 힙 축소
    TriggerGC,                  // GC 강제 실행
    PageOutToSwap,              // Swap으로 페이지 아웃
    KillNonEssentialProcess,    // 비필수 프로세스 종료
}

impl MemoryAction {
    pub fn to_string(&self) -> String {
        match self {
            MemoryAction::CompactMemory => "CompactMemory".to_string(),
            MemoryAction::DropPageCache => "DropPageCache".to_string(),
            MemoryAction::ShrinkHeap => "ShrinkHeap".to_string(),
            MemoryAction::TriggerGC => "TriggerGC".to_string(),
            MemoryAction::PageOutToSwap => "PageOutToSwap".to_string(),
            MemoryAction::KillNonEssentialProcess => "KillNonEssentialProcess".to_string(),
        }
    }

    pub fn estimated_freed_mb(&self) -> u64 {
        match self {
            MemoryAction::CompactMemory => 256,        // 256MB
            MemoryAction::DropPageCache => 512,        // 512MB
            MemoryAction::ShrinkHeap => 128,           // 128MB
            MemoryAction::TriggerGC => 512,            // 512MB
            MemoryAction::PageOutToSwap => 1024,       // 1GB
            MemoryAction::KillNonEssentialProcess => 2048,  // 2GB
        }
    }

    pub fn estimated_time_ms(&self) -> u32 {
        match self {
            MemoryAction::CompactMemory => 500,        // 500ms
            MemoryAction::DropPageCache => 100,        // 100ms
            MemoryAction::ShrinkHeap => 200,           // 200ms
            MemoryAction::TriggerGC => 2000,           // 2000ms
            MemoryAction::PageOutToSwap => 5000,       // 5000ms
            MemoryAction::KillNonEssentialProcess => 1000,  // 1000ms
        }
    }
}

// ============================================================================
// Memory Pressure Response: 메모리 압박 대응
// ============================================================================

pub struct MemoryPressureResponse {
    actions: Vec<MemoryAction>,
    estimated_freed_mb: u64,
    time_required_ms: u32,
    pressure_level: MemoryPressureLevel,
}

impl MemoryPressureResponse {
    pub fn new(level: MemoryPressureLevel) -> Self {
        MemoryPressureResponse {
            actions: vec![],
            estimated_freed_mb: 0,
            time_required_ms: 0,
            pressure_level: level,
        }
    }

    pub fn add_action(&mut self, action: MemoryAction) {
        if !self.actions.contains(&action) {
            self.estimated_freed_mb += action.estimated_freed_mb();
            self.time_required_ms += action.estimated_time_ms();
            self.actions.push(action);
        }
    }

    pub fn is_sufficient(&self, target_freed_mb: u64) -> bool {
        self.estimated_freed_mb >= target_freed_mb
    }

    pub fn execute_time_acceptable(&self, max_ms: u32) -> bool {
        self.time_required_ms <= max_ms
    }
}

impl Clone for MemoryPressureResponse {
    fn clone(&self) -> Self {
        MemoryPressureResponse {
            actions: self.actions.clone(),
            estimated_freed_mb: self.estimated_freed_mb,
            time_required_ms: self.time_required_ms,
            pressure_level: self.pressure_level,
        }
    }
}

// ============================================================================
// Memory Pressure Handler: 메모리 압박 처리기
// ============================================================================

pub struct MemoryPressureHandler {
    threshold_by_level: HashMap<MemoryPressureLevel, f64>,
    action_priority: Vec<MemoryAction>,
    phase6_patterns: Vec<(String, f64)>,
}

impl MemoryPressureHandler {
    pub fn new() -> Self {
        let mut thresholds = HashMap::new();
        thresholds.insert(MemoryPressureLevel::Normal, 0.6);      // 60%
        thresholds.insert(MemoryPressureLevel::Warning, 0.8);     // 80%
        thresholds.insert(MemoryPressureLevel::Critical, 0.95);   // 95%
        thresholds.insert(MemoryPressureLevel::Emergency, 1.0);   // 100%

        MemoryPressureHandler {
            threshold_by_level: thresholds,
            action_priority: vec![
                MemoryAction::TriggerGC,
                MemoryAction::DropPageCache,
                MemoryAction::CompactMemory,
                MemoryAction::ShrinkHeap,
                MemoryAction::PageOutToSwap,
                MemoryAction::KillNonEssentialProcess,
            ],
            phase6_patterns: vec![],
        }
    }

    // 메모리 압박 상태 처리 (적절한 조치 선택)
    pub fn handle_memory_pressure(
        &mut self,
        current_usage: u64,
        limit: u64,
    ) -> MemoryPressureResponse {
        let level = self.get_pressure_level(current_usage, limit);
        let mut response = MemoryPressureResponse::new(level);

        // 압박 수준에 따라 조치 선택
        match level {
            MemoryPressureLevel::Normal => {
                // 조치 불필요
            }
            MemoryPressureLevel::Warning => {
                // 주의: GC 유도
                response.add_action(MemoryAction::TriggerGC);
            }
            MemoryPressureLevel::Critical => {
                // 심각: GC + 페이지 캐시
                response.add_action(MemoryAction::TriggerGC);
                response.add_action(MemoryAction::DropPageCache);
                response.add_action(MemoryAction::CompactMemory);
            }
            MemoryPressureLevel::Emergency => {
                // 긴급: 모든 조치
                for action in self.action_priority.iter() {
                    response.add_action(*action);
                    if response.is_sufficient((limit / 10) as u64) {
                        break;
                    }
                }
            }
        }

        response
    }

    // 예측 기반 사전 조치 실행
    pub fn execute_preemptive_action(&mut self, pattern: &str) -> bool {
        match pattern {
            "MemoryLeak" => {
                // 누수 예상: 사전 GC
                true
            }
            "CacheThreshing" => {
                // 캐시 쓰레싱 예상: 페이지 캐시 드롭
                true
            }
            _ => false,
        }
    }

    // 조치 효과 추정 (MB)
    pub fn estimate_action_effectiveness(&self, action: &MemoryAction) -> u64 {
        action.estimated_freed_mb()
    }

    // 현재 압박 수준 판정
    pub fn get_pressure_level(&self, usage: u64, limit: u64) -> MemoryPressureLevel {
        if limit == 0 {
            return MemoryPressureLevel::Normal;
        }

        let ratio = usage as f64 / limit as f64;

        if ratio >= 0.95 {
            MemoryPressureLevel::Emergency
        } else if ratio >= 0.80 {
            MemoryPressureLevel::Critical
        } else if ratio >= 0.60 {
            MemoryPressureLevel::Warning
        } else {
            MemoryPressureLevel::Normal
        }
    }

    // 압박 추이 예측 (5초 후 예상 수준)
    pub fn predict_pressure_in_seconds(
        &self,
        current_usage: u64,
        growth_rate_mb_per_sec: f64,
        limit: u64,
        seconds_ahead: u32,
    ) -> MemoryPressureLevel {
        let estimated_growth = (growth_rate_mb_per_sec * seconds_ahead as f64) as u64;
        let estimated_usage = current_usage + estimated_growth;

        self.get_pressure_level(estimated_usage, limit)
    }

    // 회복 시간 추정 (조치 후 정상 상태까지)
    pub fn estimate_recovery_time(&self, response: &MemoryPressureResponse) -> u32 {
        response.time_required_ms + 1000  // 조치 시간 + 1초 여유
    }

    // 반복된 압박 처리 (적응)
    pub fn handle_repeated_pressure(&mut self, pattern: &str, frequency: u32) {
        self.phase6_patterns.push((pattern.to_string(), frequency as f64));

        // 최대 10개 패턴 보유
        if self.phase6_patterns.len() > 10 {
            self.phase6_patterns.remove(0);
        }

        // 반복 패턴에 따라 우선순위 조정
        if frequency > 5 {
            // 자주 발생: GC를 맨 앞으로
            if !self.action_priority.is_empty() {
                let gc_idx = self.action_priority
                    .iter()
                    .position(|a| matches!(a, MemoryAction::TriggerGC));
                if let Some(idx) = gc_idx {
                    let gc = self.action_priority.remove(idx);
                    self.action_priority.insert(0, gc);
                }
            }
        }
    }

    // 조치 가능성 평가
    pub fn can_execute_action(&self, action: &MemoryAction, max_time_ms: u32) -> bool {
        action.estimated_time_ms() <= max_time_ms
    }
}

// ============================================================================
// TEST CASES
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    // Test 1: 압박 수준 감지
    #[test]
    fn test_pressure_level_detection() {
        let handler = MemoryPressureHandler::new();

        assert_eq!(handler.get_pressure_level(4000, 10000), MemoryPressureLevel::Normal);
        assert_eq!(handler.get_pressure_level(7000, 10000), MemoryPressureLevel::Warning);
        assert_eq!(handler.get_pressure_level(8500, 10000), MemoryPressureLevel::Critical);
        assert_eq!(handler.get_pressure_level(9600, 10000), MemoryPressureLevel::Emergency);
    }

    // Test 2: 대응 조치 순서
    #[test]
    fn test_response_action_ordering() {
        let mut handler = MemoryPressureHandler::new();

        let response = handler.handle_memory_pressure(8500, 10000);  // Critical

        // 첫 번째 조치는 GC여야 함
        assert!(!response.actions.is_empty());
        if let Some(first) = response.actions.first() {
            assert_eq!(*first, MemoryAction::TriggerGC);
        }
    }

    // Test 3: 사전 예방적 GC 트리거
    #[test]
    fn test_preemptive_gc_triggering() {
        let mut handler = MemoryPressureHandler::new();

        let result = handler.execute_preemptive_action("MemoryLeak");
        assert!(result);  // 사전 조치 가능
    }

    // Test 4: 페이지 아웃 의사결정
    #[test]
    fn test_pageout_decision() {
        let handler = MemoryPressureHandler::new();

        // Emergency 수준에서는 pageout 포함
        let response = MemoryPressureResponse {
            actions: vec![MemoryAction::PageOutToSwap],
            estimated_freed_mb: 1024,
            time_required_ms: 5000,
            pressure_level: MemoryPressureLevel::Emergency,
        };

        assert!(response.is_sufficient(512));
    }

    // Test 5: 응급 대응
    #[test]
    fn test_emergency_response() {
        let mut handler = MemoryPressureHandler::new();

        let response = handler.handle_memory_pressure(9900, 10000);  // Emergency

        // 여러 조치가 순차 실행되어야 함
        assert!(response.actions.len() >= 2);
    }

    // Test 6: 압박 예측
    #[test]
    fn test_pressure_prediction() {
        let handler = MemoryPressureHandler::new();

        // 현재 5GB, 2초 후 1GB/sec 증가 예상
        let future = handler.predict_pressure_in_seconds(5000, 500.0, 10000, 5);

        // 5초 후 7.5GB 예상 → Critical
        assert!(future >= MemoryPressureLevel::Critical);
    }

    // Test 7: 회복 시간 추정
    #[test]
    fn test_recovery_time_estimation() {
        let handler = MemoryPressureHandler::new();
        let mut response = MemoryPressureResponse::new(MemoryPressureLevel::Critical);
        response.add_action(MemoryAction::TriggerGC);

        let recovery_time = handler.estimate_recovery_time(&response);
        assert!(recovery_time > 0);
    }

    // Test 8: 반복된 압박 처리
    #[test]
    fn test_repeated_pressure_handling() {
        let mut handler = MemoryPressureHandler::new();

        // 5번 메모리 누수 감지
        for _ in 0..5 {
            handler.handle_repeated_pressure("MemoryLeak", 5);
        }

        assert!(!handler.phase6_patterns.is_empty());
    }
}
