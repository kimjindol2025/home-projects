// FreeLang Phase H Week 1: Metrics Collector
// 실시간 메트릭 수집 (CPU/Memory/I/O) + Phase 7 통합

use std::collections::HashMap;

// ============================================================================
// Metric: 단일 메트릭 데이터
// ============================================================================

pub struct Metric {
    name: String,                       // "cpu.utilization" / "memory.gc_pause_ms"
    timestamp_us: u64,
    value: f64,
    tags: HashMap<String, String>,      // {phase: "Phase7", pattern: "MemoryLeak"}
    exemplar: Option<String>,           // trace_id 연결
}

impl Metric {
    pub fn new(name: String, timestamp_us: u64, value: f64) -> Self {
        Metric {
            name,
            timestamp_us,
            value,
            tags: HashMap::new(),
            exemplar: None,
        }
    }

    pub fn add_tag(&mut self, key: String, value: String) {
        self.tags.insert(key, value);
    }

    pub fn set_exemplar(&mut self, trace_id: String) {
        self.exemplar = Some(trace_id);
    }
}

impl Clone for Metric {
    fn clone(&self) -> Self {
        Metric {
            name: self.name.clone(),
            timestamp_us: self.timestamp_us,
            value: self.value,
            tags: self.tags.clone(),
            exemplar: self.exemplar.clone(),
        }
    }
}

// ============================================================================
// MetricsCollector: 전체 메트릭 수집 및 분석
// ============================================================================

pub struct MetricsCollector {
    metrics: Vec<Metric>,
    max_history: usize,                 // 최대 3600개 (1시간, 1초 interval)
    current_time_us: u64,

    // Phase 7 통합
    phase7_decisions: Vec<(u64, String, String)>,  // (time, phase, decision)
}

impl MetricsCollector {
    pub fn new(max_history: usize) -> Self {
        MetricsCollector {
            metrics: vec![],
            max_history,
            current_time_us: 0,
            phase7_decisions: vec![],
        }
    }

    // CPU 메트릭 기록
    pub fn record_cpu_metric(&mut self, util: f64, ctx_switches: u32, trace_id: Option<String>) {
        // CPU utilization
        let mut metric = Metric::new(
            "cpu.utilization".to_string(),
            self.current_time_us,
            util.max(0.0).min(100.0),
        );
        if let Some(tid) = trace_id.clone() {
            metric.set_exemplar(tid);
        }
        self.metrics.push(metric);

        // Context switches
        let mut metric = Metric::new(
            "cpu.context_switches_per_sec".to_string(),
            self.current_time_us,
            ctx_switches as f64,
        );
        if let Some(tid) = trace_id {
            metric.set_exemplar(tid);
        }
        self.metrics.push(metric);

        self.trim_history();
    }

    // Memory 메트릭 기록
    pub fn record_memory_metric(&mut self, usage_mb: u64, gc_pause_ms: u32, fragmentation: f64, trace_id: Option<String>) {
        // Memory usage
        let mut metric = Metric::new(
            "memory.usage_mb".to_string(),
            self.current_time_us,
            usage_mb as f64,
        );
        if let Some(tid) = trace_id.clone() {
            metric.set_exemplar(tid);
        }
        self.metrics.push(metric);

        // GC pause
        let mut metric = Metric::new(
            "memory.gc_pause_ms".to_string(),
            self.current_time_us,
            gc_pause_ms as f64,
        );
        if let Some(tid) = trace_id.clone() {
            metric.set_exemplar(tid);
        }
        self.metrics.push(metric);

        // Fragmentation
        let mut metric = Metric::new(
            "memory.fragmentation_ratio".to_string(),
            self.current_time_us,
            fragmentation,
        );
        if let Some(tid) = trace_id {
            metric.set_exemplar(tid);
        }
        self.metrics.push(metric);

        self.trim_history();
    }

    // I/O 메트릭 기록
    pub fn record_io_metric(&mut self, read_latency_us: u64, write_latency_us: u64, queue_depth: u32, cache_hit_rate: f64, trace_id: Option<String>) {
        // Read latency
        let mut metric = Metric::new(
            "io.read_latency_us".to_string(),
            self.current_time_us,
            read_latency_us as f64,
        );
        if let Some(tid) = trace_id.clone() {
            metric.set_exemplar(tid.clone());
        }
        self.metrics.push(metric);

        // Write latency
        let mut metric = Metric::new(
            "io.write_latency_us".to_string(),
            self.current_time_us,
            write_latency_us as f64,
        );
        if let Some(tid) = trace_id.clone() {
            metric.set_exemplar(tid.clone());
        }
        self.metrics.push(metric);

        // Queue depth
        let mut metric = Metric::new(
            "io.queue_depth".to_string(),
            self.current_time_us,
            queue_depth as f64,
        );
        if let Some(tid) = trace_id.clone() {
            metric.set_exemplar(tid.clone());
        }
        self.metrics.push(metric);

        // Cache hit rate
        let mut metric = Metric::new(
            "io.cache_hit_rate".to_string(),
            self.current_time_us,
            cache_hit_rate,
        );
        if let Some(tid) = trace_id {
            metric.set_exemplar(tid);
        }
        self.metrics.push(metric);

        self.trim_history();
    }

    // Phase 7 적응 결정 기록
    pub fn record_adaptation(&mut self, phase: &str, decision: &str, trace_id: String) {
        self.phase7_decisions.push((self.current_time_us, phase.to_string(), decision.to_string()));

        // Metric으로도 기록
        let mut metric = Metric::new(
            format!("phase7.{}_decisions", phase.to_lowercase()),
            self.current_time_us,
            1.0,
        );
        metric.add_tag("decision".to_string(), decision.to_string());
        metric.set_exemplar(trace_id);
        self.metrics.push(metric);

        self.trim_history();
    }

    // Percentile 계산 (P99, P95 등)
    pub fn get_percentile(&self, metric_name: &str, percentile: u32) -> Option<f64> {
        let mut values: Vec<f64> = self.metrics
            .iter()
            .filter(|m| m.name == metric_name)
            .map(|m| m.value)
            .collect();

        if values.is_empty() {
            return None;
        }

        values.sort_by(|a, b| a.partial_cmp(b).unwrap());
        let index = ((values.len() as f64) * (percentile as f64 / 100.0)) as usize;
        Some(values[index.min(values.len() - 1)])
    }

    // 변화율 계산 (MB/sec, ops/sec 등)
    pub fn get_rate_of_change(&self, metric_name: &str, window_sec: u32) -> Option<f64> {
        let window_us = (window_sec as u64) * 1_000_000;
        let cutoff_time = self.current_time_us.saturating_sub(window_us);

        let mut relevant_metrics: Vec<_> = self.metrics
            .iter()
            .filter(|m| m.name == metric_name && m.timestamp_us >= cutoff_time)
            .collect();

        if relevant_metrics.len() < 2 {
            return None;
        }

        relevant_metrics.sort_by_key(|m| m.timestamp_us);

        let first = relevant_metrics.first().unwrap().value;
        let last = relevant_metrics.last().unwrap().value;
        let delta_sec = window_sec as f64;

        Some((last - first) / delta_sec)
    }

    // 이상 감지 (표준편차 > 3)
    pub fn detect_anomaly(&self, metric_name: &str) -> bool {
        let values: Vec<f64> = self.metrics
            .iter()
            .filter(|m| m.name == metric_name)
            .map(|m| m.value)
            .collect();

        if values.len() < 10 {
            return false;
        }

        // 평균
        let mean = values.iter().sum::<f64>() / values.len() as f64;

        // 표준편차
        let variance = values.iter()
            .map(|v| (v - mean).powi(2))
            .sum::<f64>() / values.len() as f64;
        let stddev = variance.sqrt();

        // 최근 값이 평균에서 3σ 벗어났는가?
        if let Some(recent) = values.last() {
            (recent - mean).abs() > 3.0 * stddev
        } else {
            false
        }
    }

    // Prometheus 형식으로 내보내기
    pub fn export_prometheus(&self) -> String {
        let mut output = String::new();

        let mut metric_groups: HashMap<String, Vec<&Metric>> = HashMap::new();
        for metric in &self.metrics {
            metric_groups.entry(metric.name.clone())
                .or_insert_with(Vec::new)
                .push(metric);
        }

        for (name, metrics_list) in metric_groups {
            output.push_str(&format!("# HELP {} Real-time metric\n", name));
            output.push_str(&format!("# TYPE {} gauge\n", name));

            for metric in metrics_list {
                let tags = metric.tags.iter()
                    .map(|(k, v)| format!("{}=\"{}\"", k, v))
                    .collect::<Vec<_>>()
                    .join(",");

                if tags.is_empty() {
                    output.push_str(&format!("{} {}\n", name, metric.value));
                } else {
                    output.push_str(&format!("{}{{{}}} {}\n", name, tags, metric.value));
                }
            }
        }

        output
    }

    // 평균 지연시간
    pub fn get_average_latency(&self, metric_name: &str) -> Option<f64> {
        let metrics: Vec<_> = self.metrics
            .iter()
            .filter(|m| m.name == metric_name)
            .collect();

        if metrics.is_empty() {
            return None;
        }

        let sum: f64 = metrics.iter().map(|m| m.value).sum();
        Some(sum / metrics.len() as f64)
    }

    // Phase 7 결정 타임라인
    pub fn get_adaptation_timeline(&self) -> Vec<(u64, String, String)> {
        self.phase7_decisions.clone()
    }

    // 시간 경과
    pub fn advance_time(&mut self, delta_us: u64) {
        self.current_time_us += delta_us;
    }

    // 이력 정리
    fn trim_history(&mut self) {
        if self.metrics.len() > self.max_history {
            let remove_count = self.metrics.len() - self.max_history;
            self.metrics.drain(0..remove_count);
        }
    }

    // 메트릭 개수
    pub fn get_metric_count(&self) -> usize {
        self.metrics.len()
    }
}

// ============================================================================
// TEST CASES
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    // Test 1: CPU 메트릭 기록
    #[test]
    fn test_cpu_metric_recording() {
        let mut collector = MetricsCollector::new(1000);

        collector.record_cpu_metric(75.0, 250, Some("trace-001".to_string()));
        assert_eq!(collector.get_metric_count(), 2);  // utilization + context_switches

        let util_p99 = collector.get_percentile("cpu.utilization", 99);
        assert!(util_p99.is_some());
    }

    // Test 2: Percentile 계산
    #[test]
    fn test_percentile_calculation() {
        let mut collector = MetricsCollector::new(1000);

        // 10개 메트릭 추가
        for i in 0..10 {
            let mut metric = Metric::new("test_metric".to_string(), i as u64, (i * 10) as f64);
            collector.metrics.push(metric);
        }

        let p50 = collector.get_percentile("test_metric", 50);
        assert!(p50.is_some());
        assert!(p50.unwrap() > 0.0);
    }

    // Test 3: 변화율 계산
    #[test]
    fn test_rate_of_change() {
        let mut collector = MetricsCollector::new(1000);

        collector.record_memory_metric(1000, 50, 0.2, None);
        collector.advance_time(1_000_000);  // 1초
        collector.record_memory_metric(1100, 50, 0.2, None);

        let rate = collector.get_rate_of_change("memory.usage_mb", 1);
        assert!(rate.is_some());
    }

    // Test 4: 이상 감지
    #[test]
    fn test_anomaly_detection() {
        let mut collector = MetricsCollector::new(1000);

        // 10개 정상 메트릭
        for i in 0..10 {
            let mut metric = Metric::new("latency".to_string(), i as u64, 100.0);
            collector.metrics.push(metric);
        }

        // 1개 비정상 메트릭
        let mut metric = Metric::new("latency".to_string(), 10, 1000.0);
        collector.metrics.push(metric);

        assert!(collector.detect_anomaly("latency"));
    }

    // Test 5: Phase 7 메트릭 통합
    #[test]
    fn test_phase7_metric_integration() {
        let mut collector = MetricsCollector::new(1000);

        collector.record_adaptation("CPU", "priority_boost", "trace-001".to_string());
        collector.advance_time(100_000);
        collector.record_adaptation("Memory", "prealloc", "trace-002".to_string());

        let timeline = collector.get_adaptation_timeline();
        assert_eq!(timeline.len(), 2);
    }

    // Test 6: Prometheus 내보내기
    #[test]
    fn test_prometheus_export() {
        let mut collector = MetricsCollector::new(1000);

        collector.record_cpu_metric(75.0, 250, None);
        let prometheus = collector.export_prometheus();

        assert!(prometheus.contains("cpu.utilization"));
        assert!(prometheus.contains("75"));
    }

    // Test 7: 평균 지연시간
    #[test]
    fn test_average_latency() {
        let mut collector = MetricsCollector::new(1000);

        collector.record_io_metric(100, 100, 5, 0.8, None);
        collector.advance_time(1000);
        collector.record_io_metric(120, 120, 5, 0.8, None);

        let avg = collector.get_average_latency("io.read_latency_us");
        assert!(avg.is_some());
    }

    // Test 8: 메트릭 이력 관리
    #[test]
    fn test_metric_retention() {
        let mut collector = MetricsCollector::new(10);  // max 10개

        for i in 0..20 {
            collector.record_cpu_metric((i as f64 * 5.0) % 100.0, i as u32, None);
        }

        assert!(collector.get_metric_count() <= 10);
    }
}
