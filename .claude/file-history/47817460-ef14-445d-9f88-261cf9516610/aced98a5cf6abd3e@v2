// Section 5: Thread-Safe GC Coordination (100 lines)
// ============================================================================

fn coordinate_concurrent_gc(manager: &SafepointManager) {
    print(\"═══════════════════════════════════════════\");
    print(\"🔄 Concurrent GC with Safepoint Coordination\");
    print(\"═══════════════════════════════════════════\");
    print(\"\");

    // Phase 1: Initial Mark (STW, 짧음)
    print(\"Phase 1: Initial Mark\");
    let pause1 = initiate_stw(manager, \"Initial Mark\", 1000);
    // ... perform initial marking ...
    print(\"  [GC: Initial mark complete]\");
    resume_threads(manager);
    print(\"\");

    // Phase 2: Concurrent Marking (STW 없음)
    print(\"Phase 2: Concurrent Marking\");
    print(\"  [Running concurrently with application]\");
    print(\"  Processing gray objects...\");
    print(\"  Handling write barriers...\");
    print(\"\");

    // Phase 3: Remark (STW, 매우 짧음)
    print(\"Phase 3: Remark (Final Marking)\");
    let pause2 = initiate_stw(manager, \"Remark\", 2000);
    // ... perform final marking ...
    print(\"  [GC: Remark complete]\");
    resume_threads(manager);
    print(\"\");

    // Phase 4: Concurrent Sweep (STW 없음)
    print(\"Phase 4: Concurrent Sweep\");
    print(\"  [Running concurrently with application]\");
    print(\"  Collecting white objects...\");
    print(\"\");

    // Summary
    print(\"═══════════════════════════════════════════\");
    print(\"📊 Safepoint Coordination Summary\");
    print(\"═══════════════════════════════════════════\");
    print(\"Total STW time: \" + (pause1 + pause2) + \"ms\");
    print(\"Max pause target: \" + manager.max_pause_time_target_ms + \"ms\");
    print(\"Safepoint count: \" + manager.safepoint_count);
    print(\"═══════════════════════════════════════════\");
}

// ============================================================================
// Section 6: Example Usage (80 lines)
// ============================================================================

fn example_safepoint_coordination() {
    print(\"╔════════════════════════════════════════════╗\");
    print(\"║  Safepoint Coordination Example            ║\");
    print(\"║  STW Minimization with Thread Safety       ║\");
    print(\"╚════════════════════════════════════════════╝\");
    print(\"\");

    // Create manager for 4 threads
    let manager = create_safepoint_manager(4);

    print(\"Scenario: GC Coordinator initiating STW\");
    print(\"\");

    // Coordinator requests safepoint from threads 1, 2, 3
    let target_threads: vector = [1, 2, 3];
    request_safepoint(&manager, \"Mark Phase\", target_threads, 1000);
    print(\"\");

    // Threads reach safepoint
    poll_safepoint(&manager, 1);
    print(\"\");
    poll_safepoint(&manager, 2);
    print(\"\");
    poll_safepoint(&manager, 3);
    print(\"\");

    // All threads now at safepoint - perform GC
    print(\"[All threads at safepoint - GC running]\");
    print(\"\");

    // Resume
    resume_threads(&manager);
    print(\"\");

    // Verify safety
    verify_safepoint_safety(manager);
}

// Run example
example_safepoint_coordination();
