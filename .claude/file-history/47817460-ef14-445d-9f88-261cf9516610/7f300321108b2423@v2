#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_pressure_monitor_creation() {
        let monitor = PressureMonitor::new();
        assert_eq!(monitor.alert_callbacks.len(), 0);
        assert!(monitor.monitoring_active == false);
    }

    #[test]
    fn test_alert_callback_registration() {
        let mut monitor = PressureMonitor::new();

        let callback = |_alert: AlertLevel, _sat: f64| {
            // 더미 콜백
        };

        monitor.register_alert_callback(callback);
        assert_eq!(monitor.alert_callbacks.len(), 1);
    }

    #[test]
    fn test_pressure_trend_rising() {
        let mut monitor = PressureMonitor::new();

        // 점진적 상승
        for i in 0..5 {
            let memory = (100 + i * 100) * 1024 * 1024;
            monitor.monitor(memory as u64, 0.5, 1000, 10, 4, 100);
        }

        match monitor.analyze_pressure_trend() {
            PressureTrend::Rising => assert!(true),
            _ => assert!(false),
        }
    }

    #[test]
    fn test_pressure_trend_declining() {
        let mut monitor = PressureMonitor::new();

        // 점진적 하강
        for i in 0..5 {
            let memory = (500 - i * 50) * 1024 * 1024;
            monitor.monitor(memory as u64, 0.5, 1000, 10, 4, 100);
        }

        match monitor.analyze_pressure_trend() {
            PressureTrend::Declining => assert!(true),
            _ => assert!(false),
        }
    }

    #[test]
    fn test_escalation_policy_default() {
        let policy = EscalationPolicy::default();
        assert_eq!(policy.warning_to_critical_threshold_sec, 60);
        assert_eq!(policy.critical_to_emergency_threshold_sec, 30);
        assert!(policy.escalation_enabled);
    }

    #[test]
    fn test_monitoring_lifecycle() {
        let mut monitor = PressureMonitor::new();

        assert!(!monitor.monitoring_active);
        monitor.start();
        assert!(monitor.monitoring_active);
        monitor.stop();
        assert!(!monitor.monitoring_active);
    }

    #[test]
    fn test_average_saturation() {
        let mut monitor = PressureMonitor::new();

        // 50% 포화도로 5번 수집
        for _ in 0..5 {
            monitor.monitor(500 * 1024 * 1024, 0.5, 1000, 10, 4, 100);
        }

        let avg = monitor.avg_saturation();
        assert!(avg > 0.49 && avg < 0.51);
    }

    #[test]
    fn test_max_saturation() {
        let mut monitor = PressureMonitor::new();

        // 50%, 60%, 70% 포화도
        monitor.monitor(500 * 1024 * 1024, 0.5, 1000, 10, 4, 100);
        monitor.monitor(600 * 1024 * 1024, 0.6, 1000, 10, 4, 100);
        monitor.monitor(700 * 1024 * 1024, 0.7, 1000, 10, 4, 100);

        let max = monitor.max_saturation();
        assert!(max > 0.69 && max < 0.71);
    }

    #[test]
    fn test_saturation_volatility() {
        let mut monitor = PressureMonitor::new();

        // 안정적인 포화도
        for _ in 0..5 {
            monitor.monitor(500 * 1024 * 1024, 0.5, 1000, 10, 4, 100);
        }

        let volatility = monitor.saturation_volatility();
        assert!(volatility < 0.01);  // 변동성 매우 낮음
    }

    #[test]
    fn test_snapshot() {
        let mut monitor = PressureMonitor::new();

        monitor.monitor(600 * 1024 * 1024, 0.6, 1000, 10, 4, 100);

        let snapshot = monitor.snapshot();
        assert!(snapshot.saturation > 0.59 && snapshot.saturation < 0.61);
    }
}

