use super::metrics_collector::*;

// PressureTrend: 포화도 추세
enum PressureTrend {
    Rising,      // 포화도 상승 중 (위험)
    Steady,      // 안정적
    Declining,   // 포화도 하강 중 (회복)
}

// AlertCallback: 알람 핸들러 함수 타입
type AlertCallback = fn(alert: AlertLevel, saturation: f64);

// ============================================================================
// PressureMonitor: 리소스 압박 감시 엔진
// ============================================================================

struct PressureMonitor {
    collector: MetricsCollector,
    alert_callbacks: Vec<AlertCallback>,
    last_alert_level: AlertLevel,
    alert_history: Vec<(u64, AlertLevel)>,  // (timestamp, alert_level)
    max_alert_history: usize,
    escalation_policy: EscalationPolicy,
    monitoring_active: bool,
}

// EscalationPolicy: 알람 상향 정책
struct EscalationPolicy {
    warning_to_critical_threshold_sec: u32,  // Warning 지속 시간
    critical_to_emergency_threshold_sec: u32,  // Critical 지속 시간
    escalation_enabled: bool,
}

impl EscalationPolicy {
    fn default() -> EscalationPolicy {
        EscalationPolicy {
            warning_to_critical_threshold_sec: 60,
            critical_to_emergency_threshold_sec: 30,
            escalation_enabled: true,
        }
    }
}

impl PressureMonitor {
    // 초기화
    fn new() -> PressureMonitor {
        PressureMonitor {
            collector: MetricsCollector::new(),
            alert_callbacks: Vec::new(),
            last_alert_level: AlertLevel::Info,
            alert_history: Vec::new(),
            max_alert_history: 1000,
            escalation_policy: EscalationPolicy::default(),
            monitoring_active: false,
        }
    }

    // 알람 핸들러 등록
    fn register_alert_callback(&mut self, callback: AlertCallback) {
        self.alert_callbacks.push(callback);
    }

    // 메트릭 수집 및 감시
    fn monitor(&mut self,
        memory_used: u64,
        cpu_util: f64,
        ctx_switches: u64,
        page_faults: u64,
        thread_count: u32,
        io_ops: u64) {

        // 메트릭 수집
        let metrics = self.collector.collect_metrics(
            memory_used,
            cpu_util,
            ctx_switches,
            page_faults,
            thread_count,
            io_ops
        );

        // 알람 레벨 판정
        let current_alert = self.collector.threshold_to_alert();
        let saturation = self.collector.saturation_level();

        // 알람 레벨 변화 감지
        if self.should_trigger_alert(&current_alert) {
            self.trigger_alert(current_alert, saturation, metrics.timestamp);
        }

        // 상향 정책 적용
        if self.escalation_policy.escalation_enabled {
            self.check_escalation(metrics.timestamp);
        }

        self.last_alert_level = current_alert;
        self.monitoring_active = true;
    }

    // 알람 트리거 판정
    fn should_trigger_alert(&self, current: &AlertLevel) -> bool {
        // 알람 레벨이 변화했거나, Emergency 상태가 계속되면 트리거
        match (&self.last_alert_level, current) {
            (AlertLevel::Info, AlertLevel::Warning) => true,
            (AlertLevel::Info, AlertLevel::Critical) => true,
            (AlertLevel::Info, AlertLevel::Emergency) => true,
            (AlertLevel::Warning, AlertLevel::Critical) => true,
            (AlertLevel::Warning, AlertLevel::Emergency) => true,
            (AlertLevel::Critical, AlertLevel::Emergency) => true,
            (AlertLevel::Emergency, AlertLevel::Emergency) => true,  // 지속 알람
            _ => false,
        }
    }

    // 알람 실행
    fn trigger_alert(&mut self, alert: AlertLevel, saturation: f64, timestamp: u64) {
        // 히스토리 기록
        self.alert_history.push((timestamp, alert.clone()));

        // 히스토리 크기 제한
        if self.alert_history.len() > self.max_alert_history {
            self.alert_history.remove(0);
        }

        // 모든 콜백 실행
        for callback in &self.alert_callbacks {
            callback(alert, saturation);
        }
    }

    // 상향 정책 확인
    fn check_escalation(&mut self, current_time: u64) {
        if self.alert_history.len() < 2 {
            return;
        }

        let last_alert = &self.alert_history[self.alert_history.len() - 1];
        let (last_time, _) = last_alert;

        // Warning → Critical 상향 확인
        if self.has_been_warning_for(
            current_time,
            self.escalation_policy.warning_to_critical_threshold_sec as u64
        ) {
            // Critical로 상향하는 로직
            // (실제 구현에서는 알람 레벨 강제 상향)
        }

        // Critical → Emergency 상향 확인
        if self.has_been_critical_for(
            current_time,
            self.escalation_policy.critical_to_emergency_threshold_sec as u64
        ) {
            // Emergency로 상향하는 로직
        }
    }

    // Warning 상태 지속 시간 확인
    fn has_been_warning_for(&self, current_time: u64, duration_sec: u64) -> bool {
        if self.alert_history.len() < 2 {
            return false;
        }

        let warning_start = self.find_alert_start(AlertLevel::Warning);
        if let Some(start_time) = warning_start {
            (current_time - start_time) >= (duration_sec * 1000)
        } else {
            false
        }
    }

    // Critical 상태 지속 시간 확인
    fn has_been_critical_for(&self, current_time: u64, duration_sec: u64) -> bool {
        if self.alert_history.len() < 2 {
            return false;
        }

        let critical_start = self.find_alert_start(AlertLevel::Critical);
        if let Some(start_time) = critical_start {
            (current_time - start_time) >= (duration_sec * 1000)
        } else {
            false
        }
    }

    // 특정 알람 레벨의 시작 시간 찾기
    fn find_alert_start(&self, target: AlertLevel) -> Option<u64> {
        for (idx, (time, alert)) in self.alert_history.iter().enumerate() {
            if idx == 0 {
                continue;  // 첫 항목은 건너뛰기
            }

            // 이전 항목과 다르고, 현재가 target이면
            let (_, prev_alert) = self.alert_history[idx - 1];
            if prev_alert != target && alert == target {
                return Some(*time);
            }
        }
        None
    }

    // 현재 상태 스냅샷
    fn snapshot(&self) -> PressureSnapshot {
        let saturation = self.collector.saturation_level();
        let trend = self.analyze_pressure_trend();
        let alert = self.collector.threshold_to_alert();

        PressureSnapshot {
            timestamp: self.collector.current_metrics.timestamp,
            saturation,
            trend,
            alert,
            memory_available: self.collector.memory_available(),
            is_escalating: self.is_escalating(),
        }
    }

    // 포화도 추세 분석
    fn analyze_pressure_trend(&self) -> PressureTrend {
        if self.collector.metrics_history.len() < 5 {
            return PressureTrend::Steady;
        }

        let history = &self.collector.metrics_history;
        let recent_size = history.len();

        let early_saturation = (history[recent_size - 5].memory_used as f64) /
                              (history[recent_size - 5].memory_total as f64);
        let latest_saturation = (history[recent_size - 1].memory_used as f64) /
                               (history[recent_size - 1].memory_total as f64);

        let delta = latest_saturation - early_saturation;

        if delta > 0.05 {
            PressureTrend::Rising
        } else if delta < -0.05 {
            PressureTrend::Declining
        } else {
            PressureTrend::Steady
        }
    }

    // 상향 중인지 확인
    fn is_escalating(&self) -> bool {
        match self.analyze_pressure_trend() {
            PressureTrend::Rising => true,
            _ => false,
        }
    }

    // 모니터링 시작
    fn start(&mut self) {
        self.monitoring_active = true;
    }

    // 모니터링 중지
    fn stop(&mut self) {
        self.monitoring_active = false;
    }

    // 알람 히스토리 조회
    fn get_alert_history(&self, limit: usize) -> Vec<(u64, String)> {
        let mut result = Vec::new();
        let start_idx = if self.alert_history.len() > limit {
            self.alert_history.len() - limit
        } else {
            0
        };

        for i in start_idx..self.alert_history.len() {
            let (timestamp, alert) = self.alert_history[i];
            let alert_str = format!("{:?}", alert);
            result.push((timestamp, alert_str));
        }

        result
    }

    // 평균 포화도 (최근 10개)
    fn avg_saturation(&self) -> f64 {
        if self.collector.metrics_history.len() == 0 {
            return 0.0;
        }

        let recent_size = if self.collector.metrics_history.len() > 10 {
            10
        } else {
            self.collector.metrics_history.len()
        };

        let start_idx = self.collector.metrics_history.len() - recent_size;
        let mut sum = 0.0;

        for i in start_idx..self.collector.metrics_history.len() {
            let m = &self.collector.metrics_history[i];
            let sat = (m.memory_used as f64) / (m.memory_total as f64);
            sum += sat;
        }

        sum / (recent_size as f64)
    }

    // 최대 포화도 (히스토리)
    fn max_saturation(&self) -> f64 {
        let mut max = 0.0;

        for m in &self.collector.metrics_history {
            let sat = (m.memory_used as f64) / (m.memory_total as f64);
            if sat > max {
                max = sat;
            }
        }

        max
    }

    // 포화도 변동성 (표준편차)
    fn saturation_volatility(&self) -> f64 {
        if self.collector.metrics_history.len() < 2 {
            return 0.0;
        }

        let avg = self.avg_saturation();
        let mut sum_sq_diff = 0.0;

        for m in &self.collector.metrics_history {
            let sat = (m.memory_used as f64) / (m.memory_total as f64);
            let diff = sat - avg;
            sum_sq_diff += diff * diff;
        }

        let variance = sum_sq_diff / (self.collector.metrics_history.len() as f64);
        variance.sqrt()
    }
}

// PressureSnapshot: 특정 시점의 압박 상태
struct PressureSnapshot {
    timestamp: u64,
    saturation: f64,
    trend: PressureTrend,
    alert: AlertLevel,
    memory_available: u64,
    is_escalating: bool,
}

