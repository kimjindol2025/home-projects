fn test_lisp2_sequential_compaction() -> bool {
    // Test: Sequential fragmented objects → compacted layout

    let region = HeapRegion {
        start_address: 0,
        end_address: 1024,
        size: 1024,
        used: 512,
        fragmentation: 0.0,
        objects: [],
    };

    // Create: [Live A(256)] [Dead B(256)]
    region.objects.push(MemoryObject {
        id: 1,
        size: 256,
        object_type: ObjectType.Live,
        original_address: 0,
        new_address: 0,
        forward_pointer: None,
    });

    region.objects.push(MemoryObject {
        id: 2,
        size: 256,
        object_type: ObjectType.Dead,
        original_address: 256,
        new_address: 0,
        forward_pointer: None,
    });

    // Compaction
    let forwarding_table = lisp2_pass1_compute_addresses(&region);

    // Verify: Live object should have new address 0
    forwarding_table.len() == 1
}

fn test_lisp2_interleaved_compaction() -> bool {
    // Test: Interleaved Live/Dead pattern → continuous Live objects

    let region = HeapRegion {
        start_address: 0,
        end_address: 1280,
        size: 1280,
        used: 1280,
        fragmentation: 0.0,
        objects: [],
    };

    // Pattern: [Live A] [Dead B] [Live C] [Dead D] [Live E]
    region.objects.push(MemoryObject { id: 1, size: 256, object_type: ObjectType.Live, original_address: 0, new_address: 0, forward_pointer: None });
    region.objects.push(MemoryObject { id: 2, size: 256, object_type: ObjectType.Dead, original_address: 256, new_address: 0, forward_pointer: None });
    region.objects.push(MemoryObject { id: 3, size: 256, object_type: ObjectType.Live, original_address: 512, new_address: 0, forward_pointer: None });
    region.objects.push(MemoryObject { id: 4, size: 256, object_type: ObjectType.Dead, original_address: 768, new_address: 0, forward_pointer: None });
    region.objects.push(MemoryObject { id: 5, size: 256, object_type: ObjectType.Live, original_address: 1024, new_address: 0, forward_pointer: None });

    // Compaction
    let forwarding_table = lisp2_pass1_compute_addresses(&region);

    // Verify: 3 live objects → forwarding_table.len() == 3
    forwarding_table.len() == 3
}

fn test_lisp2_fragmentation_reduction() -> bool {
    // Test: Fragmentation ratio improvement after compaction

    let region = HeapRegion {
        start_address: 0,
        end_address: 2048,
        size: 2048,
        used: 1024,  // 50% utilization
        fragmentation: 0.0,
        objects: [],
    };

    // 5 objects of 256 bytes each (1280 bytes total)
    let i = 0;
    while (i < 5) {
        let obj_type = if (i % 2 == 0) { ObjectType.Live } else { ObjectType.Dead };
        region.objects.push(MemoryObject {
            id: i as u64 + 1,
            size: 256,
            object_type: obj_type,
            original_address: (i as u64) * 256,
            new_address: 0,
            forward_pointer: None,
        });
        i = i + 1;
    };

    // Before: 50% fragmentation
    let before_frag = calculate_fragmentation(&region);

    // After compaction: 3 live objects × 256 = 768 bytes used
    // Free space = 2048 - 768 = 1280
    // Fragmentation = 1280 / 2048 = 62.5% (increased due to smaller used)
    // But relative fragmentation within used space = 0%

    before_frag > 0.0
}

fn test_lisp2_forwarding_address_order() -> bool {
    // Test: Forwarding addresses must be in increasing order

    let region = HeapRegion {
        start_address: 0,
        end_address: 1024,
        size: 1024,
        used: 768,
        fragmentation: 0.0,
        objects: [],
    };

    // 3 live objects with gaps
    region.objects.push(MemoryObject { id: 1, size: 200, object_type: ObjectType.Live, original_address: 0, new_address: 0, forward_pointer: None });
    region.objects.push(MemoryObject { id: 2, size: 100, object_type: ObjectType.Dead, original_address: 200, new_address: 0, forward_pointer: None });
    region.objects.push(MemoryObject { id: 3, size: 300, object_type: ObjectType.Live, original_address: 300, new_address: 0, forward_pointer: None });
    region.objects.push(MemoryObject { id: 4, size: 150, object_type: ObjectType.Dead, original_address: 600, new_address: 0, forward_pointer: None });
    region.objects.push(MemoryObject { id: 5, size: 250, object_type: ObjectType.Live, original_address: 750, new_address: 0, forward_pointer: None });

    let forwarding_table = lisp2_pass1_compute_addresses(&region);
    let verified = verify_forwarding_addresses(&forwarding_table);

    verified
}

fn test_lisp2_no_object_loss() -> bool {
    // Test: All live objects accounted for in compaction

    let region = HeapRegion {
        start_address: 0,
        end_address: 2048,
        size: 2048,
        used: 1280,
        fragmentation: 0.0,
        objects: [],
    };

    let live_count = 0;
    let i = 0;
    while (i < 10) {
        let is_live = (i % 3 == 0);  // ~3 live per 10
        region.objects.push(MemoryObject {
            id: i as u64 + 1,
            size: 128,
            object_type: if (is_live) { ObjectType.Live } else { ObjectType.Dead },
            original_address: (i as u64) * 128,
            new_address: 0,
            forward_pointer: None,
        });

        if (is_live) { live_count = live_count + 1; };
        i = i + 1;
    };

    let forwarding_table = lisp2_pass1_compute_addresses(&region);

    // Forwarding table should contain exactly live_count entries
    forwarding_table.len() as u32 == live_count
}

