// Test infrastructure
struct CompactionTest {
    name: string,
    passed: bool,
    message: string,
}

struct CompactionTestSuite {
    tests: vector,  // [CompactionTest, ...]
    passed_count: u32,
    total_count: u32,
}

fn create_test_suite() -> CompactionTestSuite {
    CompactionTestSuite {
        tests: [],
        passed_count: 0,
        total_count: 0,
    }
}

fn run_test(suite: &CompactionTestSuite, name: string, condition: bool, message: string) {
    let test = CompactionTest {
        name: name,
        passed: condition,
        message: message,
    };

    suite.tests.push(test);

    if (condition) {
        suite.passed_count = suite.passed_count + 1;
        print(\"  ✅ \" + name);
    } else {
        print(\"  ❌ \" + name + \": \" + message);
    };

    suite.total_count = suite.total_count + 1;
}

fn print_test_summary(suite: CompactionTestSuite) {
    print(\"\");
    print(\"═══════════════════════════════════════════\");
    print(\"📊 Compaction Test Summary\");
    print(\"═══════════════════════════════════════════\");
    print(\"Passed: \" + suite.passed_count + \" / \" + suite.total_count);
    print(\"Success Rate: \" + ((suite.passed_count as f64) / (suite.total_count as f64) * 100.0) + \"%\");
    print(\"═══════════════════════════════════════════\");
}

