    objects.push(MemoryObject { id: 1, size: 256, object_type: ObjectType.Live, original_address: 0, new_address: 0, forward_pointer: None });
    objects.push(MemoryObject { id: 2, size: 256, object_type: ObjectType.Dead, original_address: 256, new_address: 0, forward_pointer: None });
    objects.push(MemoryObject { id: 3, size: 256, object_type: ObjectType.Live, original_address: 512, new_address: 0, forward_pointer: None });
