            object_type: if (is_live) { ObjectType.Live } else { ObjectType.Dead },
            original_address: (i as u64) * 100,
            new_address: 0,
            forward_pointer: None,
        });
        i = i + 1;
    };

    // Perform incremental compaction with chunk size 5
    let stats = incremental_compact(&region, 5);

    // Should process all objects
    stats.total_objects == 20
}

