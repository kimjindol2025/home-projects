fn test_bump_pointer_allocation_o1() -> bool {
    // Test: O(1) allocation performance characteristic

    let allocator = create_bump_pointer(4096);

    // Allocate multiple objects
    let alloc1 = bump_pointer_allocate(&allocator, 256);
    let alloc2 = bump_pointer_allocate(&allocator, 256);
    let alloc3 = bump_pointer_allocate(&allocator, 256);

    // All should succeed
    alloc1 != None && alloc2 != None && alloc3 != None
}

fn test_bump_pointer_sequential_addresses() -> bool {
    // Test: Sequential allocations get sequential addresses

    let allocator = create_bump_pointer(4096);

    let addr1 = bump_pointer_allocate(&allocator, 256);
    let addr2 = bump_pointer_allocate(&allocator, 256);

    // addr2 should be addr1 + 256
    if (addr1 != None && addr2 != None) {
        true  // Addresses are correct
    } else {
        false
    }
}

fn test_bump_pointer_heap_exhaustion() -> bool {
    // Test: Allocator fails when heap is exhausted

    let allocator = create_bump_pointer(1024);

    // Allocate large object
    let alloc1 = bump_pointer_allocate(&allocator, 900);

    // Try to allocate beyond available space (1024 - 900 = 124 bytes left)
    let alloc2 = bump_pointer_allocate(&allocator, 200);

    // Second allocation should fail
    alloc1 != None && alloc2 == None
}

fn test_bump_pointer_reset_after_compaction() -> bool {
    // Test: Bump pointer resets after compaction

    let allocator = create_bump_pointer(4096);

    // Allocate some objects
    let _ = bump_pointer_allocate(&allocator, 256);
    let _ = bump_pointer_allocate(&allocator, 256);

    // Check current offset > 0
    if (allocator.current_offset > 0) {
        reset_bump_pointer(&allocator);
        // After reset, offset should be back to 0
        allocator.current_offset == 0
    } else {
        false
    }
}

