// ============================================================================
// Test 3: Add Node Minimal Movement
// ============================================================================

fn test_add_node_minimal_movement() -> TestResult {
    let ring = new_consistent_hash_ring(100);
    ring = add_node_to_ring(ring, 0);
    ring = add_node_to_ring(ring, 1);

    // Count keys before
    let key_positions_before = [];
    let i = 0;
    while (i < 100) {
        let key = "key:" + i;
        let node = get_node_for_key(ring, key);
        key_positions_before.push(node);
        i = i + 1;
    };

    // Add new node
    ring = add_node_to_ring(ring, 2);

    // Count keys after
    let moved = 0;
    let j = 0;
    while (j < 100) {
        let key = "key:" + j;
        let node = get_node_for_key(ring, key);
        if (node != key_positions_before[j]) {
            moved = moved + 1;
        };
        j = j + 1;
    };

    // With 3 nodes, expect ~33% of keys to move (1/3)
    // But consistent hashing should minimize this
    let ratio = moved / 100;
    let acceptable = ratio < 50;  // Less than 50% moved

    return assert_true(acceptable, "test_add_node_minimal_movement");
}

