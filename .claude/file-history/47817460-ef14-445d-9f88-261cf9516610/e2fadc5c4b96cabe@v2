// Test framework
struct TestResult {
    name: string,
    passed: bool,
    message: string,
}

fn assert_equal_u32(actual: u32, expected: u32, test_name: string) -> TestResult {
    TestResult {
        name: test_name,
        passed: actual == expected,
        message: if (actual == expected) "PASS" else "FAIL: expected " + expected + " got " + actual,
    }
}

fn assert_equal_u64(actual: u64, expected: u64, test_name: string) -> TestResult {
    TestResult {
        name: test_name,
        passed: actual == expected,
        message: if (actual == expected) "PASS" else "FAIL: expected " + expected + " got " + actual,
    }
}

fn assert_true(condition: bool, test_name: string) -> TestResult {
    TestResult {
        name: test_name,
        passed: condition,
        message: if (condition) "PASS" else "FAIL: condition is false",
    }
}

fn assert_false(condition: bool, test_name: string) -> TestResult {
    TestResult {
        name: test_name,
        passed: !condition,
        message: if (!condition) "PASS" else "FAIL: condition is true",
    }
}

fn print_test_result(result: TestResult) {
    if (result.passed) {
        print("✓ " + result.name + ": " + result.message);
    } else {
        print("✗ " + result.name + ": " + result.message);
    };
}

