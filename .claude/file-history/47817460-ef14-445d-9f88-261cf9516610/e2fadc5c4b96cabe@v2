// Test 5: Virtual Node Balance
// ============================================================================

fn test_virtual_node_balance() -> TestResult {
    let ring = new_consistent_hash_ring(150);
    ring = add_node_to_ring(ring, 0);

    // Each physical node should have 150 virtual nodes
    let virtual_count = 0;
    let i = 0;
    while (i < ring.nodes.len()) {
        if (ring.nodes[i].node_id == 0) {
            virtual_count = virtual_count + 1;
        };
        i = i + 1;
    };

    return assert_equal_u32(virtual_count, 150, "test_virtual_node_balance");
}

