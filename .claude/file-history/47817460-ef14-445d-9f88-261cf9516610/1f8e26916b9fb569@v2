#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_metrics_collector_creation() {
        let collector = MetricsCollector::new();
        assert_eq!(collector.saturation_level(), 0.0);
        assert_eq!(collector.saturation_percent(), 0);
    }

    #[test]
    fn test_saturation_level_calculation() {
        let mut collector = MetricsCollector::new();

        // 50% 포화도
        collector.collect_metrics(
            512 * 1024 * 1024,  // 512MB
            0.5,
            1000,
            10,
            4,
            100
        );

        let saturation = collector.saturation_level();
        assert!(saturation > 0.49 && saturation < 0.51);
    }

    #[test]
    fn test_threshold_level_normal() {
        let mut collector = MetricsCollector::new();

        // 50% 사용 → Normal
        collector.collect_metrics(512 * 1024 * 1024, 0.5, 1000, 10, 4, 100);

        match collector.threshold_exceeded() {
            ThresholdLevel::Normal => assert!(true),
            _ => assert!(false),
        }
    }

    #[test]
    fn test_threshold_level_warning() {
        let mut collector = MetricsCollector::new();

        // 80% 사용 → Warning
        collector.collect_metrics(800 * 1024 * 1024, 0.8, 1000, 10, 4, 100);

        match collector.threshold_exceeded() {
            ThresholdLevel::Warning => assert!(true),
            _ => assert!(false),
        }
    }

    #[test]
    fn test_threshold_level_critical() {
        let mut collector = MetricsCollector::new();

        // 95% 사용 → Critical
        collector.collect_metrics(950 * 1024 * 1024, 0.95, 1000, 10, 4, 100);

        match collector.threshold_exceeded() {
            ThresholdLevel::Critical => assert!(true),
            _ => assert!(false),
        }
    }

    #[test]
    fn test_threshold_level_emergency() {
        let mut collector = MetricsCollector::new();

        // 99% 사용 → Emergency
        collector.collect_metrics(990 * 1024 * 1024, 0.99, 1000, 10, 4, 100);

        match collector.threshold_exceeded() {
            ThresholdLevel::Emergency => assert!(true),
            _ => assert!(false),
        }
    }

    #[test]
    fn test_memory_available() {
        let mut collector = MetricsCollector::new();

        collector.collect_metrics(600 * 1024 * 1024, 0.6, 1000, 10, 4, 100);

        let available = collector.memory_available();
        assert_eq!(available, 400 * 1024 * 1024);
    }

    #[test]
    fn test_saturation_percent() {
        let mut collector = MetricsCollector::new();

        collector.collect_metrics(500 * 1024 * 1024, 0.5, 1000, 10, 4, 100);

        let percent = collector.saturation_percent();
        assert_eq!(percent, 50);
    }

    #[test]
    fn test_alert_level_mapping() {
        let mut collector = MetricsCollector::new();

        // Normal → Info
        collector.collect_metrics(500 * 1024 * 1024, 0.5, 1000, 10, 4, 100);
        match collector.threshold_to_alert() {
            AlertLevel::Info => assert!(true),
            _ => assert!(false),
        }

        // Emergency → Emergency
        collector.collect_metrics(990 * 1024 * 1024, 0.99, 1000, 10, 4, 100);
        match collector.threshold_to_alert() {
            AlertLevel::Emergency => assert!(true),
            _ => assert!(false),
        }
    }

    #[test]
    fn test_metrics_history() {
        let mut collector = MetricsCollector::new();

        for i in 0..10 {
            let memory = (100 * i * 1024 * 1024) as u64;
            collector.collect_metrics(memory, 0.5, 1000, 10, 4, 100);
        }

        assert_eq!(collector.metrics_history.len(), 10);
    }

    #[test]
    fn test_cpu_utilization_clamping() {
        let mut collector = MetricsCollector::new();

        // CPU 사용률을 1.5로 설정 → 1.0으로 자동 제한
        collector.collect_metrics(500 * 1024 * 1024, 1.5, 1000, 10, 4, 100);

        assert_eq!(collector.current_metrics.cpu_utilization, 1.0);
    }

    #[test]
    fn test_snapshot() {
        let mut collector = MetricsCollector::new();

        collector.collect_metrics(750 * 1024 * 1024, 0.85, 5000, 100, 8, 500);

        let snapshot = collector.snapshot();
        assert!(snapshot.saturation > 0.74 && snapshot.saturation < 0.76);
    }
}

