// ResourceMetrics: 리소스 사용 현황
struct ResourceMetrics {
    timestamp: u64,              // 수집 시간 (ms)
    memory_used: u64,            // 사용 메모리 (bytes)
    memory_total: u64,           // 전체 메모리 (bytes)
    cpu_utilization: f64,        // CPU 사용률 (0.0-1.0)
    context_switches: u64,       // 컨텍스트 스위칭 수
    page_faults: u64,            // 페이지 폴트 수
    thread_count: u32,           // 활성 스레드 수
    io_operations: u64,          // I/O 작업 수
}

// ThresholdLevel: 포화도 레벨
enum ThresholdLevel {
    Normal,      // 0-75%: 정상
    Warning,     // 75-90%: 경고
    Critical,    // 90-98%: 위험
    Emergency,   // 98-100%: 긴급
}

// AlertLevel: 알람 단계
enum AlertLevel {
    Info,        // 정보성 알람
    Warning,     // 경고
    Critical,    // 심각
    Emergency,   // 긴급
}

// ============================================================================
// MetricsCollector: 메트릭 수집 엔진
// ============================================================================

struct MetricsCollector {
    current_metrics: ResourceMetrics,
    metrics_history: Vec<ResourceMetrics>,
    max_history_size: usize,
    collection_interval_ms: u32,
    last_collection_time: u64,
}

impl MetricsCollector {
    // 초기화
    fn new() -> MetricsCollector {
        MetricsCollector {
            current_metrics: ResourceMetrics {
                timestamp: 0,
                memory_used: 0,
                memory_total: 1024 * 1024 * 1024,  // 1GB 기본값
                cpu_utilization: 0.0,
                context_switches: 0,
                page_faults: 0,
                thread_count: 1,
                io_operations: 0,
            },
            metrics_history: Vec::new(),
            max_history_size: 100,  // 최근 100개 메트릭 유지
            collection_interval_ms: 100,  // 100ms마다 수집
            last_collection_time: 0,
        }
    }

    // 메트릭 수집
    fn collect_metrics(&mut self,
        memory_used: u64,
        cpu_util: f64,
        ctx_switches: u64,
        page_faults: u64,
        thread_count: u32,
        io_ops: u64) -> ResourceMetrics {

        let timestamp = current_time_ms();

        let metrics = ResourceMetrics {
            timestamp,
            memory_used,
            memory_total: self.current_metrics.memory_total,
            cpu_utilization: clamp(cpu_util, 0.0, 1.0),
            context_switches: ctx_switches,
            page_faults,
            thread_count,
            io_operations: io_ops,
        };

        self.current_metrics = metrics.clone();

        // 히스토리 추가
        self.metrics_history.push(metrics.clone());

        // 히스토리 크기 제한
        if self.metrics_history.len() > self.max_history_size {
            self.metrics_history.remove(0);
        }

        self.last_collection_time = timestamp;
        metrics
    }

    // 포화도 계산 (0.0 ~ 1.0)
    fn saturation_level(&self) -> f64 {
        let used = self.current_metrics.memory_used as f64;
        let total = self.current_metrics.memory_total as f64;

        if total == 0.0 {
            return 0.0;
        }

        let saturation = used / total;
        clamp(saturation, 0.0, 1.0)
    }

    // 포화도 레벨 판정
    fn threshold_exceeded(&self) -> ThresholdLevel {
        let level = self.saturation_level();

        match level {
            0.0..=0.75 => ThresholdLevel::Normal,
            0.76..=0.90 => ThresholdLevel::Warning,
            0.91..=0.98 => ThresholdLevel::Critical,
            0.99..=1.0 => ThresholdLevel::Emergency,
            _ => ThresholdLevel::Emergency,  // 기본값
        }
    }

    // 포화도 레벨을 알람으로 변환
    fn threshold_to_alert(&self) -> AlertLevel {
        match self.threshold_exceeded() {
            ThresholdLevel::Normal => AlertLevel::Info,
            ThresholdLevel::Warning => AlertLevel::Warning,
            ThresholdLevel::Critical => AlertLevel::Critical,
            ThresholdLevel::Emergency => AlertLevel::Emergency,
        }
    }

    // 추세 분석: 상승/안정/하강
    enum Trend {
        Rising,     // 포화도 상승 중
        Steady,     // 안정적
        Declining,  // 포화도 하강 중
    }

    fn analyze_trend(&self) -> Trend {
        if self.metrics_history.len() < 10 {
            return Trend::Steady;
        }

        // 최근 10개 메트릭으로 추세 분석
        let recent = &self.metrics_history[self.metrics_history.len() - 10..];

        let first_saturation = (recent[0].memory_used as f64) / (recent[0].memory_total as f64);
        let last_saturation = (recent[9].memory_used as f64) / (recent[9].memory_total as f64);

        let delta = last_saturation - first_saturation;

        if delta > 0.02 {
            Trend::Rising
        } else if delta < -0.02 {
            Trend::Declining
        } else {
            Trend::Steady
        }
    }

    // 현재 상태 스냅샷
    fn snapshot(&self) -> MetricsSnapshot {
        MetricsSnapshot {
            timestamp: self.current_metrics.timestamp,
            saturation: self.saturation_level(),
            threshold: self.threshold_exceeded(),
            alert: self.threshold_to_alert(),
            trend: self.analyze_trend(),
            memory_used: self.current_metrics.memory_used,
            memory_total: self.current_metrics.memory_total,
            cpu_util: self.current_metrics.cpu_utilization,
            ctx_switches: self.current_metrics.context_switches,
            page_faults: self.current_metrics.page_faults,
        }
    }

    // 포화도 백분율 (0-100)
    fn saturation_percent(&self) -> u32 {
        (self.saturation_level() * 100.0) as u32
    }

    // 포화도 문자열 표현
    fn saturation_str(&self) -> String {
        let percent = self.saturation_percent();
        format!("{}%", percent)
    }

    // 메모리 여유 (bytes)
    fn memory_available(&self) -> u64 {
        if self.current_metrics.memory_used > self.current_metrics.memory_total {
            0
        } else {
            self.current_metrics.memory_total - self.current_metrics.memory_used
        }
    }

    // 메모리 여유 비율 (0.0-1.0)
    fn memory_available_ratio(&self) -> f64 {
        let available = self.memory_available() as f64;
        let total = self.current_metrics.memory_total as f64;

        if total == 0.0 {
            1.0
        } else {
            available / total
        }
    }
}

// MetricsSnapshot: 특정 시점의 메트릭 스냅샷
struct MetricsSnapshot {
    timestamp: u64,
    saturation: f64,
    threshold: ThresholdLevel,
    alert: AlertLevel,
    trend: MetricsCollector::Trend,
    memory_used: u64,
    memory_total: u64,
    cpu_util: f64,
    ctx_switches: u64,
    page_faults: u64,
}

// ============================================================================
// 헬퍼 함수
// ============================================================================

fn clamp(value: f64, min: f64, max: f64) -> f64 {
    if value < min {
        min
    } else if value > max {
        max
    } else {
        value
    }
}

fn current_time_ms() -> u64 {
