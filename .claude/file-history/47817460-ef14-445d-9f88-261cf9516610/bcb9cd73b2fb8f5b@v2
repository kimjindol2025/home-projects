// FreeLang Phase H Week 2: Adaptive Feedback Loop
// Design by Failure - Complete System Closure
// Detect → Analyze → Decide → Execute → Measure → Learn

use std::collections::HashMap;

// ============================================================================
// Feedback Loop State Machine
// ============================================================================

pub enum AdaptiveLoopPhase {
    Idle,              // 정상 상태, 모니터링만 수행
    FailureDetected,   // 장애 감지 (metrics breach)
    CausalityAnalyzing, // 원인 분석 중
    PolicyDeciding,    // 정책 결정 중
    PolicyExecuting,   // 정책 실행 중
    Measuring,         // 개선도 측정 중
    Learning,          // 시스템 학습 (다음 재발 방지)
    RollingBack,       // 정책 롤백 중
}

pub struct AdaptiveLoopState {
    current_phase: AdaptiveLoopPhase,
    phase_start_us: u64,
    failure_id: Option<String>,
    confidence_in_decision: f64,
}

// ============================================================================
// Feedback Loop Metrics
// ============================================================================

pub struct LoopMetrics {
    total_failures_detected: u32,
    total_policies_applied: u32,
    total_policies_successful: u32,  // Confidence > 0.7 and improvement > 30%
    total_rollbacks: u32,
    average_decision_latency_us: u64,
    average_improvement_percent: f64,
}

impl LoopMetrics {
    pub fn new() -> Self {
        LoopMetrics {
            total_failures_detected: 0,
            total_policies_applied: 0,
            total_policies_successful: 0,
            total_rollbacks: 0,
            average_decision_latency_us: 0,
            average_improvement_percent: 0.0,
        }
    }

    pub fn get_success_rate(&self) -> f64 {
        if self.total_policies_applied == 0 {
            return 0.0;
        }
        (self.total_policies_successful as f64 / self.total_policies_applied as f64).min(1.0)
    }

    pub fn to_string(&self) -> String {
        format!(
            "Loop Health: {} failures detected, {} policies applied, {} successful ({:.1}% success rate), \
             avg decision latency: {}µs, avg improvement: {:.1}%",
            self.total_failures_detected,
            self.total_policies_applied,
            self.total_policies_successful,
            self.get_success_rate() * 100.0,
            self.average_decision_latency_us,
            self.average_improvement_percent,
        )
    }
}

// ============================================================================
// Adaptive Loop Learning Module
// ============================================================================

pub struct LearningEngine {
    // 장애 패턴 학습: 어떤 failure class가 얼마나 자주 발생하는가
    failure_frequency: HashMap<String, u32>,

    // 정책 효과 학습: GCMode(aggressive)를 적용했을 때 개선도는?
    policy_effectiveness: HashMap<String, Vec<f64>>, // policy_name → [improvement%, improvement%, ...]

    // 예측 신뢰도: 다음 발생할 장애 유형 예측
    predicted_failure_class: Option<String>,
    predicted_confidence: f64,
}

impl LearningEngine {
    pub fn new() -> Self {
        LearningEngine {
            failure_frequency: HashMap::new(),
            policy_effectiveness: HashMap::new(),
            predicted_failure_class: None,
            predicted_confidence: 0.0,
        }
    }

    pub fn record_failure(&mut self, failure_class: String) {
        *self.failure_frequency.entry(failure_class).or_insert(0) += 1;
    }

    pub fn record_policy_outcome(&mut self, policy_name: String, improvement_percent: f64) {
        self.policy_effectiveness
            .entry(policy_name)
            .or_insert_with(Vec::new)
            .push(improvement_percent);
    }

    pub fn predict_next_failure(&mut self) -> Option<(String, f64)> {
        // 가장 자주 발생했던 failure class 예측
        if let Some((failure_class, count)) = self.failure_frequency
            .iter()
            .max_by_key(|&(_, count)| count)
        {
            // Confidence = 빈도 기반 (낮을수록 uncertain)
            let total: u32 = self.failure_frequency.values().sum();
            let frequency_ratio = *count as f64 / total as f64;
            let confidence = (frequency_ratio * 0.7 + 0.3).min(1.0); // Min 0.3, Max 1.0

            self.predicted_failure_class = Some(failure_class.clone());
            self.predicted_confidence = confidence;
            return Some((failure_class.clone(), confidence));
        }
        None
    }

    pub fn get_best_policy_for_failure(&self, failure_class: &str) -> Option<(String, f64)> {
        // 같은 failure_class에 대해 과거에 가장 효과가 좋았던 정책 추천
        let mut best_policy = None;
        let mut best_avg_improvement = 0.0;

        for (policy_name, improvements) in self.policy_effectiveness.iter() {
            if policy_name.contains(failure_class) {
                let avg = improvements.iter().sum::<f64>() / improvements.len() as f64;
                if avg > best_avg_improvement {
                    best_avg_improvement = avg;
                    best_policy = Some((policy_name.clone(), avg));
                }
            }
        }

        best_policy
    }
}

// ============================================================================
// Complete Adaptive Loop System
// ============================================================================

pub struct AdaptiveLoopSystem {
    state: AdaptiveLoopState,
    metrics: LoopMetrics,
    learning_engine: LearningEngine,

    // Phase 7 & Phase 8 integration
    current_metrics: HashMap<String, f64>,
    baseline_metrics: HashMap<String, f64>,
}

impl AdaptiveLoopSystem {
    pub fn new() -> Self {
        AdaptiveLoopSystem {
            state: AdaptiveLoopState {
                current_phase: AdaptiveLoopPhase::Idle,
                phase_start_us: 0,
                failure_id: None,
                confidence_in_decision: 0.0,
            },
            metrics: LoopMetrics::new(),
            learning_engine: LearningEngine::new(),
            current_metrics: HashMap::new(),
            baseline_metrics: HashMap::new(),
        }
    }

    // ========================================================================
    // Phase 1: Failure Detection → Phase 2: Causality Analysis
    // ========================================================================

    pub fn on_failure_detected(
        &mut self,
        failure_id: String,
        failure_class: String,
        current_time_us: u64,
    ) {
        self.state.current_phase = AdaptiveLoopPhase::FailureDetected;
        self.state.phase_start_us = current_time_us;
        self.state.failure_id = Some(failure_id.clone());

        self.metrics.total_failures_detected += 1;
        self.learning_engine.record_failure(failure_class);
    }

    pub fn on_causality_analysis_complete(
        &mut self,
        root_cause: String,
        confidence: f64,
    ) {
        self.state.current_phase = AdaptiveLoopPhase::CausalityAnalyzing;
        self.state.confidence_in_decision = confidence;
    }

    // ========================================================================
    // Phase 3: Policy Decision → Phase 4: Policy Execution
    // ========================================================================

    pub fn on_policy_decided(
        &mut self,
        policy_name: String,
        expected_impact: f64,
        confidence: f64,
        current_time_us: u64,
    ) {
        self.state.current_phase = AdaptiveLoopPhase::PolicyDeciding;

        // Decision latency 계산 (Failure detection → Policy decision)
        if let Some(failure_id) = &self.state.failure_id {
            let decision_latency = current_time_us - self.state.phase_start_us;

            // 평균 계산
            let prev_total = self.metrics.average_decision_latency_us * self.metrics.total_policies_applied as u64;
            self.metrics.total_policies_applied += 1;
            self.metrics.average_decision_latency_us =
                (prev_total + decision_latency) / self.metrics.total_policies_applied as u64;
        }

        self.state.confidence_in_decision = confidence;
    }

    pub fn execute_policy(
        &mut self,
        policy_name: String,
        current_time_us: u64,
    ) {
        self.state.current_phase = AdaptiveLoopPhase::PolicyExecuting;
        self.state.phase_start_us = current_time_us;

        // 이 정책을 Phase 7의 resource allocator로 전달 (시뮬레이션)
        // 실제: phase7_adapter.apply_policy(&policy_name)
    }

    // ========================================================================
    // Phase 5: Measurement & Phase 6: Learning
    // ========================================================================

    pub fn measure_improvement(
        &mut self,
        metric_name: String,
        before_value: f64,
        after_value: f64,
        policy_name: String,
    ) -> f64 {
        self.state.current_phase = AdaptiveLoopPhase::Measuring;

        // Improvement 계산 (%)
        let improvement = if before_value != 0.0 {
            ((before_value - after_value) / before_value * 100.0).max(0.0)
        } else {
            0.0
        };

        // Learning: 이 정책이 얼마나 효과적이었는가?
        self.learning_engine.record_policy_outcome(policy_name, improvement);

        // Metrics 업데이트
        let prev_total = self.metrics.average_improvement_percent
            * (self.metrics.total_policies_successful as f64);
        self.metrics.total_policies_successful =
            (self.metrics.total_policies_successful as f64 * 0.9) as u32 + // exponential decay
            (if improvement > 30.0 { 1 } else { 0 });
        self.metrics.average_improvement_percent =
            (prev_total + improvement) / (self.metrics.total_policies_successful as f64).max(1.0);

        improvement
    }

    pub fn on_learning_complete(
        &mut self,
        was_successful: bool,
    ) {
        self.state.current_phase = AdaptiveLoopPhase::Learning;

        if was_successful {
            // 다음 같은 failure가 발생하면 이 정책을 우선 적용
            if let Some(next_failure) = self.learning_engine.predict_next_failure() {
                // 예측 완료
            }
        } else {
            // 실패한 정책 -> Learning engine에 기록하여 다음 피함
        }
    }

    // ========================================================================
    // Phase 7: Rollback (if necessary)
    // ========================================================================

    pub fn should_rollback(&self, improvement_percent: f64, elapsed_time_us: u64) -> bool {
        // Rollback 조건:
        // 1. 90초 경과했는데 개선 < 20%
        // 2. 개선 < 10% at any time
        // 3. 상황 악화 감지

        if elapsed_time_us > 90_000_000 && improvement_percent < 20.0 {
            return true;
        }

        if improvement_percent < 10.0 {
            return true;
        }

        false
    }

    pub fn execute_rollback(
        &mut self,
        policy_name: String,
        current_time_us: u64,
    ) {
        self.state.current_phase = AdaptiveLoopPhase::RollingBack;
        self.metrics.total_rollbacks += 1;

        // Policy 롤백 요청 (Phase 7 adapter)
        // 실제: phase7_adapter.rollback_policy(&policy_name)
    }

    // ========================================================================
    // Loop 종료 & 정상화
    // ========================================================================

    pub fn return_to_idle(
        &mut self,
        current_time_us: u64,
    ) {
        self.state.current_phase = AdaptiveLoopPhase::Idle;
        self.state.failure_id = None;
        self.state.confidence_in_decision = 0.0;
    }

    // ========================================================================
    // Observability & Reporting
    // ========================================================================

    pub fn get_loop_health(&self) -> String {
        self.metrics.to_string()
    }

    pub fn get_current_phase(&self) -> String {
        match self.state.current_phase {
            AdaptiveLoopPhase::Idle => "Idle",
            AdaptiveLoopPhase::FailureDetected => "FailureDetected",
            AdaptiveLoopPhase::CausalityAnalyzing => "CausalityAnalyzing",
            AdaptiveLoopPhase::PolicyDeciding => "PolicyDeciding",
            AdaptiveLoopPhase::PolicyExecuting => "PolicyExecuting",
            AdaptiveLoopPhase::Measuring => "Measuring",
            AdaptiveLoopPhase::Learning => "Learning",
            AdaptiveLoopPhase::RollingBack => "RollingBack",
        }.to_string()
    }

    pub fn get_loop_statistics(&self) -> HashMap<String, f64> {
        let mut stats = HashMap::new();
        stats.insert("failures_detected".to_string(), self.metrics.total_failures_detected as f64);
        stats.insert("policies_applied".to_string(), self.metrics.total_policies_applied as f64);
        stats.insert("success_rate".to_string(), self.metrics.get_success_rate());
        stats.insert("rollbacks".to_string(), self.metrics.total_rollbacks as f64);
        stats.insert("decision_latency_us".to_string(), self.metrics.average_decision_latency_us as f64);
        stats.insert("average_improvement_percent".to_string(), self.metrics.average_improvement_percent);
        stats
    }

    pub fn get_next_predicted_failure(&self) -> Option<(String, f64)> {
        // Learning engine의 예측 반환 (read-only)
        if let Some(ref class) = self.learning_engine.predicted_failure_class {
            return Some((class.clone(), self.learning_engine.predicted_confidence));
        }
        None
    }
}

// ============================================================================
// Bidirectional Integration with Phase 7
// ============================================================================

pub struct Phase7Adapter {
    // Phase 7 (Adaptive Resource Allocation)과의 통신 인터페이스
    pending_policies: Vec<String>,
    applied_policies: Vec<String>,
    rollback_queue: Vec<String>,
}

impl Phase7Adapter {
    pub fn new() -> Self {
        Phase7Adapter {
            pending_policies: vec![],
            applied_policies: vec![],
            rollback_queue: vec![],
        }
    }

    pub fn queue_policy(&mut self, policy_name: String) {
        self.pending_policies.push(policy_name);
    }

    pub fn confirm_policy_applied(&mut self, policy_name: String) {
        if let Some(pos) = self.pending_policies.iter().position(|p| p == &policy_name) {
            self.pending_policies.remove(pos);
            self.applied_policies.push(policy_name);
        }
    }

    pub fn queue_rollback(&mut self, policy_name: String) {
        self.rollback_queue.push(policy_name);
    }

    pub fn confirm_rollback(&mut self, policy_name: String) {
        if let Some(pos) = self.applied_policies.iter().position(|p| p == &policy_name) {
            self.applied_policies.remove(pos);
        }
        if let Some(pos) = self.rollback_queue.iter().position(|p| p == &policy_name) {
            self.rollback_queue.remove(pos);
        }
    }
}

// ============================================================================
// TEST CASES
