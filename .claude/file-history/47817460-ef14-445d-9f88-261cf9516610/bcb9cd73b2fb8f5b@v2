#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_adaptive_loop_initialization() {
        let loop_system = AdaptiveLoopSystem::new();
        assert_eq!(loop_system.get_current_phase(), "Idle");
        assert_eq!(loop_system.metrics.total_failures_detected, 0);
    }

    #[test]
    fn test_failure_detection_phase() {
        let mut loop_system = AdaptiveLoopSystem::new();
        loop_system.on_failure_detected(
            "FAIL-001".to_string(),
            "LatencyExplosion".to_string(),
            1000_000_000,
        );

        assert_eq!(loop_system.get_current_phase(), "FailureDetected");
        assert_eq!(loop_system.metrics.total_failures_detected, 1);
    }

    #[test]
    fn test_causality_analysis_phase() {
        let mut loop_system = AdaptiveLoopSystem::new();
        loop_system.on_failure_detected("FAIL-002".to_string(), "MemoryCollapse".to_string(), 1000_000_000);
        loop_system.on_causality_analysis_complete("GC".to_string(), 0.9);

        assert_eq!(loop_system.state.confidence_in_decision, 0.9);
    }

    #[test]
    fn test_policy_decision_and_execution() {
        let mut loop_system = AdaptiveLoopSystem::new();
        loop_system.on_failure_detected("FAIL-003".to_string(), "LatencyExplosion".to_string(), 1000_000_000);
        loop_system.on_policy_decided("GCMode(aggressive)".to_string(), 40.0, 0.88, 1000_001_000);
        loop_system.execute_policy("GCMode(aggressive)".to_string(), 1000_001_000);

        assert_eq!(loop_system.get_current_phase(), "PolicyExecuting");
        assert_eq!(loop_system.metrics.total_policies_applied, 1);
    }

    #[test]
    fn test_measurement_phase() {
        let mut loop_system = AdaptiveLoopSystem::new();

        let improvement = loop_system.measure_improvement(
            "P99_latency".to_string(),
            150.0,  // before
            90.0,   // after
            "GCMode(aggressive)".to_string(),
        );

        assert!(improvement > 30.0); // 40% improvement
        assert_eq!(loop_system.get_current_phase(), "Measuring");
    }

    #[test]
    fn test_learning_engine() {
        let mut learning = LearningEngine::new();
        learning.record_failure("LatencyExplosion".to_string());
        learning.record_failure("LatencyExplosion".to_string());
        learning.record_failure("MemoryCollapse".to_string());
        learning.record_policy_outcome("GCMode(aggressive)".to_string(), 45.0);

        if let Some((failure_class, confidence)) = learning.predict_next_failure() {
            assert_eq!(failure_class, "LatencyExplosion");
            assert!(confidence > 0.5);
        }
    }

    #[test]
    fn test_rollback_detection() {
        let loop_system = AdaptiveLoopSystem::new();

        // Case 1: 90초 경과, 개선 < 20%
        assert!(loop_system.should_rollback(15.0, 95_000_000));

        // Case 2: 개선 < 10%
        assert!(loop_system.should_rollback(5.0, 30_000_000));

        // Case 3: 정상 (40%, 60초)
        assert!(!loop_system.should_rollback(40.0, 60_000_000));
    }

    #[test]
    fn test_phase7_adapter() {
        let mut adapter = Phase7Adapter::new();
        adapter.queue_policy("Policy-1".to_string());
        assert_eq!(adapter.pending_policies.len(), 1);

        adapter.confirm_policy_applied("Policy-1".to_string());
        assert_eq!(adapter.pending_policies.len(), 0);
        assert_eq!(adapter.applied_policies.len(), 1);
    }

    #[test]
    fn test_complete_loop_cycle() {
        let mut loop_system = AdaptiveLoopSystem::new();

        // Cycle: Detect → Analyze → Decide → Execute → Measure → Learn → Idle
        loop_system.on_failure_detected("FAIL-004".to_string(), "LatencyExplosion".to_string(), 1000_000_000);
        loop_system.on_causality_analysis_complete("Scheduler".to_string(), 0.85);
        loop_system.on_policy_decided("ThreadAffinity(numa)".to_string(), 20.0, 0.85, 1000_001_000);
        loop_system.execute_policy("ThreadAffinity(numa)".to_string(), 1000_001_000);

        let improvement = loop_system.measure_improvement(
            "P99_latency".to_string(),
            150.0,
            110.0,
            "ThreadAffinity(numa)".to_string(),
        );

        assert!(improvement > 20.0);

        loop_system.on_learning_complete(true);
        loop_system.return_to_idle(1000_010_000);

        assert_eq!(loop_system.get_current_phase(), "Idle");
    }

    #[test]
    fn test_loop_statistics() {
        let mut loop_system = AdaptiveLoopSystem::new();

        // 3개 failures 시뮬레이션
        for i in 0..3 {
            loop_system.on_failure_detected(
                format!("FAIL-{}", i),
                "LatencyExplosion".to_string(),
                1000_000_000 + i as u64 * 1_000_000,
            );
        }

        let stats = loop_system.get_loop_statistics();
        assert_eq!(stats.get("failures_detected").unwrap(), &3.0);
    }

    #[test]
    fn test_feedback_loop_health() {
        let loop_system = AdaptiveLoopSystem::new();
        let health = loop_system.get_loop_health();
        assert!(health.contains("Loop Health"));
        assert!(health.contains("failures detected"));
    }

    #[test]
    fn test_no_policies_no_side_effects() {
        let loop_system = AdaptiveLoopSystem::new();
        // Idle 상태에서는 아무것도 하지 않음
        assert_eq!(loop_system.metrics.total_policies_applied, 0);
        assert_eq!(loop_system.metrics.total_rollbacks, 0);
    }
}
