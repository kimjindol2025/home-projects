#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_root_cause_hypothesis_generation() {
        let mut analyzer = RootCauseAnalyzer::new();
        let mut metrics = HashMap::new();
        metrics.insert("GC_pause_ms".to_string(), 150.0);
        metrics.insert("scheduler_queue_depth_percent".to_string(), 75.0);

        let analysis = analyzer.analyze(
            "FAIL-001".to_string(),
            "LatencyExplosion".to_string(),
            1000_000_000,
            vec![
                ("EVT-1".to_string(), "GC".to_string(), 0.9),
                ("EVT-2".to_string(), "Scheduler".to_string(), 0.7),
            ],
            metrics,
        );

        assert!(analysis.hypothesis_list.len() >= 2);
        assert!(analysis.primary_root_cause.is_some());
        let primary = analysis.primary_root_cause.unwrap();
        assert!(primary.confidence > 0.7);
        assert!(!primary.supporting_evidence.is_empty());
    }

    #[test]
    fn test_confidence_scoring() {
        let mut analyzer = RootCauseAnalyzer::new();
        let mut metrics = HashMap::new();

        // High-confidence scenario: strong GC evidence
        metrics.insert("GC_pause_ms".to_string(), 200.0);
        metrics.insert("fragmentation_ratio".to_string(), 0.75);

        let analysis = analyzer.analyze(
            "FAIL-002".to_string(),
            "MemoryCollapse".to_string(),
            1000_000_000,
            vec![("EVT-3".to_string(), "GC".to_string(), 0.95)],
            metrics,
        );

        if let Some(primary) = analysis.primary_root_cause {
            assert!(primary.confidence > 0.8);
        }
    }

    #[test]
    fn test_secondary_causes() {
        let mut analyzer = RootCauseAnalyzer::new();
        let metrics = HashMap::new();

        let analysis = analyzer.analyze(
            "FAIL-003".to_string(),
            "LatencyExplosion".to_string(),
            1000_000_000,
            vec![
                ("EVT-4".to_string(), "GC".to_string(), 0.9),
                ("EVT-5".to_string(), "Scheduler".to_string(), 0.75),
                ("EVT-6".to_string(), "IOSystem".to_string(), 0.6),
            ],
            metrics,
        );

        assert_eq!(analysis.secondary_causes.len(), 2);
        assert!(analysis.secondary_causes[0].confidence >= analysis.secondary_causes[1].confidence);
    }

    #[test]
    fn test_postmortem_report_generation() {
        let mut analyzer = RootCauseAnalyzer::new();
        let generator = PostMortemReportGenerator::new("FreeLang".to_string());

        let mut metrics = HashMap::new();
        metrics.insert("GC_pause_ms".to_string(), 120.0);

        let analysis = analyzer.analyze(
            "FAIL-004".to_string(),
            "MemoryCollapse".to_string(),
            1000_000_000,
            vec![("EVT-7".to_string(), "GC".to_string(), 0.88)],
            metrics,
        );

        let mut improvements = HashMap::new();
        improvements.insert("GC_pause_reduction_percent".to_string(), 45.0);

        let report = generator.generate_report(
            &analysis,
            vec!["GCMode(aggressive)".to_string()],
            improvements,
        );

