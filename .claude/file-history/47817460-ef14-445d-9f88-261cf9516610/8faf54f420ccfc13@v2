fn example_fragmented_heap() -> HeapRegion {
    print("Creating fragmented heap example...");
    print("");

    let region = HeapRegion {
        start_address: 0,
        end_address: 4096,
        size: 4096,
        used: 0,
        fragmentation: 0.0,
        objects: [],
    };

    // Simulate fragmented memory:
    // [Live A] [Dead B] [Live C] [Dead D] [Live E]

    let obj_a = MemoryObject {
        id: 1,
        size: 256,
        object_type: ObjectType.Live,
        original_address: 0,
        new_address: 0,
        forward_pointer: None,
    };

    let obj_b = MemoryObject {
        id: 2,
        size: 256,
        object_type: ObjectType.Dead,
        original_address: 256,
        new_address: 0,
        forward_pointer: None,
    };

    let obj_c = MemoryObject {
        id: 3,
        size: 256,
        object_type: ObjectType.Live,
        original_address: 512,
        new_address: 0,
        forward_pointer: None,
    };

    let obj_d = MemoryObject {
        id: 4,
        size: 256,
        object_type: ObjectType.Dead,
        original_address: 768,
        new_address: 0,
        forward_pointer: None,
    };

    let obj_e = MemoryObject {
        id: 5,
        size: 256,
        object_type: ObjectType.Live,
        original_address: 1024,
        new_address: 0,
        forward_pointer: None,
    };

    region.objects.push(obj_a);
    region.objects.push(obj_b);
    region.objects.push(obj_c);
    region.objects.push(obj_d);
    region.objects.push(obj_e);

    region.used = 1280;  // 5 objects × 256 bytes, but with gaps

    print("Fragmented heap created:");
    print("  [Live A] [Dead B] [Live C] [Dead D] [Live E]");
    print("  Used: " + region.used + " bytes");
    print("  Total: " + region.size + " bytes");
    print("");

    region
}

