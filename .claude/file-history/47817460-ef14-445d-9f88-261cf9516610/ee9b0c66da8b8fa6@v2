#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_scenario_lifecycle() {
        let mut injector = FaultInjector::new();

        let scenario_id = injector.start_scenario(
            "Test Scenario".to_string(),
            10000,
            1000_000_000,
        );

        assert_eq!(scenario_id, "SCENARIO-1");
        assert!(injector.current_scenario.is_some());

        let info = injector.get_current_scenario_info();
        assert!(info.is_some());
        let (name, elapsed, remaining) = info.unwrap();
        assert_eq!(name, "Test Scenario");

        injector.end_scenario();
        assert!(injector.current_scenario.is_none());
        assert_eq!(injector.scenario_history.len(), 1);
    }

    #[test]
    fn test_baseline_and_degradation() {
        let mut injector = FaultInjector::new();

        let mut baseline = HashMap::new();
        baseline.insert("p99_latency_ms".to_string(), 100.0);
        baseline.insert("memory_pressure".to_string(), 0.5);
        baseline.insert("gc_pause_ms".to_string(), 50.0);
        baseline.insert("cache_hit_rate".to_string(), 0.9);

        injector.record_baseline_metrics(baseline);

        // After fault injection, degradation should be applied
        let current = injector.get_all_metrics();
        assert_eq!(current.len(), 4);
    }

    #[test]
    fn test_slo_target_and_violation() {
        let mut injector = FaultInjector::new();

        let mut baseline = HashMap::new();
        baseline.insert("p99_latency_ms".to_string(), 100.0);
        injector.record_baseline_metrics(baseline);

        injector.set_slo_target("p99_latency_ms".to_string(), 100.0);

        // Simulate degradation by updating metric
        injector.current_metrics.insert("p99_latency_ms".to_string(), 150.0);

        // First check: 1 breach
        let violations1 = injector.check_slo_violations(1000_000_000);
        assert_eq!(violations1.len(), 0); // Need 3 consecutive breaches

        // Second check: 2 breaches
        let violations2 = injector.check_slo_violations(1001_000_000);
        assert_eq!(violations2.len(), 0);

        // Third check: 3 breaches (violation triggered)
        let violations3 = injector.check_slo_violations(1002_000_000);
        assert_eq!(violations3.len(), 1);
        assert_eq!(violations3[0].metric_name, "p99_latency_ms");
    }

    #[test]
    fn test_metric_improvement_calculation() {
        let mut injector = FaultInjector::new();

        let mut baseline = HashMap::new();
        baseline.insert("p99_latency_ms".to_string(), 150.0);
        baseline.insert("cache_hit_rate".to_string(), 0.5);
        injector.record_baseline_metrics(baseline);

        // Simulate improvement
        injector.current_metrics.insert("p99_latency_ms".to_string(), 90.0); // Improved
        injector.current_metrics.insert("cache_hit_rate".to_string(), 0.7);   // Improved

        let latency_improvement = injector.get_metric_improvement("p99_latency_ms");
        assert!(latency_improvement.is_some());
        assert!(latency_improvement.unwrap() > 30.0); // 40% improvement

        let cache_improvement = injector.get_metric_improvement("cache_hit_rate");
        assert!(cache_improvement.is_some());
        assert!(cache_improvement.unwrap() > 30.0); // 40% improvement
    }

    #[test]
    fn test_fault_injection_in_scenario() {
        let mut injector = FaultInjector::new();

        let mut baseline = HashMap::new();
        baseline.insert("p99_latency_ms".to_string(), 100.0);
        injector.record_baseline_metrics(baseline);

        injector.start_scenario(
            "Latency Test".to_string(),
            5000,
            1000_000_000,
        );

        let fault_id = injector.inject_fault(
            crate::fault_injection::FaultType::LatencySpike(200),
            3000,
            1000_000_000,
        );

        assert!(!fault_id.is_empty());

        if let Some(scenario) = &injector.current_scenario {
            assert_eq!(scenario.faults_injected.len(), 1);
        }
    }

    #[test]
    fn test_root_cause_identification() {
        let mut injector = FaultInjector::new();

        let mut baseline = HashMap::new();
        baseline.insert("p99_latency_ms".to_string(), 100.0);
        injector.record_baseline_metrics(baseline);

        injector.start_scenario("Test".to_string(), 5000, 1000_000_000);
        injector.inject_fault(
            crate::fault_injection::FaultType::LatencySpike(300),
            3000,
            1000_000_000,
        );

        let root_cause = injector.identify_expected_root_cause("p99_latency_ms");
        assert!(root_cause.contains("LatencySpike") || root_cause.contains("Unknown"));
    }
}
