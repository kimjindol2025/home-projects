fn generate_optimization_recommendations(controller: GCAdaptiveController) {
    print(\"💡 GC Optimization Recommendations\");
    print(\"\");

    // Recommendation 1: Pause Time
    if (controller.metrics.pause_time_max_ms > 5.0) {
        print(\"1. High Maximum Pause Time (\" + controller.metrics.pause_time_max_ms + \"ms)\");
        print(\"   → Consider increasing concurrent marking speed\");
        print(\"   → Consider reducing Old generation size\");
        print(\"\");
    };

    // Recommendation 2: Allocation Rate
    if (controller.metrics.young_allocation_rate > 150.0) {
        print(\"2. High Young Generation Allocation Rate\");
        print(\"   → Consider increasing Young generation size\");
        print(\"   → Consider optimizing object creation patterns\");
        print(\"\");
    };

    // Recommendation 3: Survival Rate
    if (controller.metrics.young_survival_rate > 0.5) {
        print(\"3. High Young Generation Survival Rate (\" + (controller.metrics.young_survival_rate * 100.0) + \"%)\");
        print(\"   → Many objects surviving to Old generation\");
        print(\"   → Consider increasing Young generation size\");
        print(\"\");
    };

    // Recommendation 4: GC Frequency
    if (controller.metrics.gc_frequency > 2.0) {
        print(\"4. High GC Frequency (\" + controller.metrics.gc_frequency + \" cycles/sec)\");
        print(\"   → Frequent memory pressure\");
        print(\"   → Consider increasing total heap size\");
        print(\"\");
    };

    // Recommendation 5: Heap Utilization
    if (controller.metrics.heap_utilization > 0.85) {
        print(\"5. High Heap Utilization (\" + (controller.metrics.heap_utilization * 100.0) + \"%)\");
        print(\"   → Risk of GC thrashing\");
        print(\"   → Consider increasing heap size\");
        print(\"\");
    };

    print(\"✅ Review recommendations and adjust if needed\");
}

