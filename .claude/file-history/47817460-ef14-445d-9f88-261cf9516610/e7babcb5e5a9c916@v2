// ============================================================================
// LearningState: 5단계 학습 상태
// ============================================================================
// 1. NoData: 아직 데이터 없음 (confidence 0%)
// 2. Observing: 관찰 중 (1-3회, confidence 20-50%)
// 3. Emerging: 패턴 나타남 (4-9회, confidence 50-70%)
// 4. Established: 패턴 확실 (10-29회, confidence 70-90%)
// 5. Mature: 완전 성숙 (30+회, confidence >90%)

enum LearningState {
    NoData,
    Observing,
    Emerging,
    Established,
    Mature,
}

impl LearningState {
    fn from_frequency(frequency: u32) -> LearningState {
        match frequency {
            0 => LearningState::NoData,
            1..=3 => LearningState::Observing,
            4..=9 => LearningState::Emerging,
            10..=29 => LearningState::Established,
            30..=u32::MAX => LearningState::Mature,
        }
    }

    fn to_string(&self) -> String {
        match self {
            LearningState::NoData => "NoData".to_string(),
            LearningState::Observing => "Observing".to_string(),
            LearningState::Emerging => "Emerging".to_string(),
            LearningState::Established => "Established".to_string(),
            LearningState::Mature => "Mature".to_string(),
        }
    }

    fn confidence_range(&self) -> (f64, f64) {
        // (최소값, 최대값)
        match self {
            LearningState::NoData => (0.0, 0.1),
            LearningState::Observing => (0.2, 0.5),
            LearningState::Emerging => (0.5, 0.7),
            LearningState::Established => (0.7, 0.9),
            LearningState::Mature => (0.9, 1.0),
        }
    }

    fn min_frequency(&self) -> u32 {
        match self {
            LearningState::NoData => 0,
            LearningState::Observing => 1,
            LearningState::Emerging => 4,
            LearningState::Established => 10,
            LearningState::Mature => 30,
        }
    }

    fn actionability(&self) -> f64 {
        // 이 상태에서 조치를 취할 때의 신뢰도 가중치 (0.0-1.0)
        match self {
            LearningState::NoData => 0.0,          // 조치 금지
            LearningState::Observing => 0.2,       // 매우 신중한 조치
            LearningState::Emerging => 0.5,        // 조건부 조치
            LearningState::Established => 0.8,     // 적극적 조치
            LearningState::Mature => 1.0,          // 완전한 조치
        }
    }
}

// ============================================================================
// PatternLearningState: 각 패턴별 학습 상태 추적
// ============================================================================

struct PatternLearningState {
    pattern_id: u32,
    pattern_type: String,
    current_state: String,              // LearningState를 문자열로 저장
    frequency: u32,                     // 발생 횟수
    confidence: f64,                    // 현재 신뢰도 (0.0-1.0)
    last_transition_time: u64,          // 마지막 상태 전이 시간
    total_observations: u32,            // 누적 관찰 수
    successful_predictions: u32,        // 성공한 예측 수
    failed_predictions: u32,            // 실패한 예측 수
    prediction_accuracy: f64,           // 예측 정확도 (0.0-1.0)
    state_entry_time: u64,              // 현재 상태 진입 시간
    time_in_state_ms: u32,              // 현재 상태 소요 시간 (ms)
}

impl PatternLearningState {
    fn new(pattern_id: u32, pattern_type: String) -> PatternLearningState {
        PatternLearningState {
            pattern_id,
            pattern_type,
            current_state: "NoData".to_string(),
            frequency: 0,
            confidence: 0.0,
            last_transition_time: 0,
            total_observations: 0,
            successful_predictions: 0,
            failed_predictions: 0,
            prediction_accuracy: 0.0,
            state_entry_time: 0,
            time_in_state_ms: 0,
        }
    }

    fn observe(&mut self, timestamp: u64, evidence_confidence: f64) {
        // 새로운 관찰 데이터 기록
        self.total_observations += 1;
        self.frequency += 1;

        // 베이지안 신뢰도 갱신
        let weight = (self.frequency as f64) / ((self.frequency as f64) + 1.0);
        self.confidence = self.confidence * weight + evidence_confidence * (1.0 - weight);

        // 신뢰도를 0.0-1.0 범위로 제한
        if self.confidence > 1.0 {
            self.confidence = 1.0;
        }
        if self.confidence < 0.0 {
            self.confidence = 0.0;
        }
    }

    fn try_transition(&mut self, timestamp: u64) -> bool {
        // 상태 전이 시도: frequency 기반으로 다음 상태로 진행 가능한지 확인
        let old_state = self.current_state.clone();
        let new_state = self.calculate_next_state();

        if new_state != old_state {
            self.current_state = new_state.clone();
            self.last_transition_time = timestamp;
            self.state_entry_time = timestamp;
            return true;
        }
        false
    }

    fn calculate_next_state(&self) -> String {
        // frequency 기반 상태 결정
        match self.frequency {
            0 => "NoData".to_string(),
            1..=3 => "Observing".to_string(),
            4..=9 => "Emerging".to_string(),
            10..=29 => "Established".to_string(),
            30..=u32::MAX => "Mature".to_string(),
        }
    }

    fn update_state_time(&mut self, current_timestamp: u64) {
        // 현재 상태 소요 시간 업데이트
        if self.state_entry_time > 0 {
            self.time_in_state_ms = (current_timestamp - self.state_entry_time) as u32;
        }
    }

    fn record_prediction_result(&mut self, success: bool) {
        // 예측 결과 기록
        if success {
            self.successful_predictions += 1;
        } else {
            self.failed_predictions += 1;
        }

        // 예측 정확도 계산
        let total = self.successful_predictions + self.failed_predictions;
        if total > 0 {
            self.prediction_accuracy =
                (self.successful_predictions as f64) / (total as f64);
        }
    }

    fn is_actionable(&self) -> bool {
        // 이 패턴으로 조치를 취할 수 있는가?
        // 요구사항:
        // 1. Emerging 상태 이상 (confidence >50%)
        // 2. 최소 4회 관찰 (frequency >=4)
        // 3. 예측 정확도 >60% (또는 아직 예측 없음)
        self.frequency >= 4 &&
        self.confidence > 0.5 &&
        (self.successful_predictions + self.failed_predictions == 0 ||
         self.prediction_accuracy > 0.6)
    }

    fn get_action_confidence(&self) -> f64 {
        // 조치를 취할 때의 신뢰도 (0.0-1.0)
        // = (상태 기반 actionability) × (신뢰도) × (예측 정확도 또는 1.0)
        let state_actionability = match self.current_state.as_str() {
            "NoData" => 0.0,
            "Observing" => 0.2,
            "Emerging" => 0.5,
            "Established" => 0.8,
            "Mature" => 1.0,
            _ => 0.0,
        };

        let accuracy_factor = if self.successful_predictions + self.failed_predictions > 0 {
            self.prediction_accuracy
        } else {
            1.0  // 예측 기록이 없으면 신뢰도만 사용
        };

        state_actionability * self.confidence * accuracy_factor
    }
}

// ============================================================================
// StateTransitionLog: 상태 전이 로그
// ============================================================================

struct StateTransition {
    pattern_id: u32,
    timestamp: u64,
    from_state: String,
    to_state: String,
    frequency_at_transition: u32,
    confidence_at_transition: f64,
    reason: String,
}

impl StateTransition {
    fn new(
        pattern_id: u32,
        timestamp: u64,
        from_state: String,
        to_state: String,
        frequency: u32,
        confidence: f64,
        reason: String,
    ) -> StateTransition {
        StateTransition {
            pattern_id,
            timestamp,
            from_state,
            to_state,
            frequency_at_transition: frequency,
            confidence_at_transition: confidence,
            reason,
        }
    }
}

// ============================================================================
// StateMachineManager: 전체 상태 머신 관리
// ============================================================================

struct StateMachineManager {
    patterns: Vec<PatternLearningState>,
    transitions: Vec<StateTransition>,
}

impl StateMachineManager {
    fn new() -> StateMachineManager {
        StateMachineManager {
            patterns: Vec::new(),
            transitions: Vec::new(),
        }
    }

    fn add_pattern(&mut self, pattern_id: u32, pattern_type: String) {
        let state = PatternLearningState::new(pattern_id, pattern_type);
        self.patterns.push(state);
    }

    fn observe_pattern(&mut self, pattern_id: u32, timestamp: u64, evidence: f64) {
        // 패턴 관찰 및 상태 전이 시도
        for pattern in &mut self.patterns {
            if pattern.pattern_id == pattern_id {
                let old_state = pattern.current_state.clone();
                pattern.observe(timestamp, evidence);

                if pattern.try_transition(timestamp) {
                    // 상태 전이 발생 -> 로그에 기록
                    let transition = StateTransition::new(
                        pattern_id,
                        timestamp,
                        old_state,
                        pattern.current_state.clone(),
                        pattern.frequency,
                        pattern.confidence,
                        format!("Frequency increased to {}", pattern.frequency),
                    );
                    self.transitions.push(transition);
                }
                return;
            }
        }
    }

    fn record_prediction(&mut self, pattern_id: u32, success: bool) {
        for pattern in &mut self.patterns {
            if pattern.pattern_id == pattern_id {
                pattern.record_prediction_result(success);
                return;
            }
        }
    }

    fn get_actionable_patterns(&self) -> Vec<u32> {
        // 현재 조치 가능한 패턴 ID 목록
        self.patterns
            .iter()
            .filter(|p| p.is_actionable())
            .map(|p| p.pattern_id)
            .collect()
    }

    fn get_pattern_state(&self, pattern_id: u32) -> Option<String> {
        for pattern in &self.patterns {
            if pattern.pattern_id == pattern_id {
                return Some(pattern.current_state.clone());
            }
        }
        None
    }

    fn get_pattern_confidence(&self, pattern_id: u32) -> Option<f64> {
        for pattern in &self.patterns {
            if pattern.pattern_id == pattern_id {
                return Some(pattern.confidence);
            }
        }
        None
    }

    fn get_action_confidence(&self, pattern_id: u32) -> Option<f64> {
        for pattern in &self.patterns {
            if pattern.pattern_id == pattern_id {
                return Some(pattern.get_action_confidence());
            }
        }
        None
    }

    fn update_all_times(&mut self, current_timestamp: u64) {
        for pattern in &mut self.patterns {
            pattern.update_state_time(current_timestamp);
        }
    }

    fn get_transition_count(&self) -> usize {
        self.transitions.len()
    }

    fn get_total_patterns(&self) -> usize {
        self.patterns.len()
    }
}

