#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_learning_state_from_frequency() {
        // 테스트 1: 빈도에 따른 상태 변화
        assert_eq!(LearningState::from_frequency(0).to_string(), "NoData");
        assert_eq!(LearningState::from_frequency(1).to_string(), "Observing");
        assert_eq!(LearningState::from_frequency(5).to_string(), "Emerging");
        assert_eq!(LearningState::from_frequency(15).to_string(), "Established");
        assert_eq!(LearningState::from_frequency(50).to_string(), "Mature");
    }

    #[test]
    fn test_confidence_range() {
        // 테스트 2: 각 상태별 신뢰도 범위 확인
        let (min, max) = LearningState::NoData.confidence_range();
        assert!(min >= 0.0 && max <= 0.1);

        let (min, max) = LearningState::Observing.confidence_range();
        assert!(min >= 0.2 && max <= 0.5);

        let (min, max) = LearningState::Mature.confidence_range();
        assert!(min >= 0.9 && max <= 1.0);
    }

    #[test]
    fn test_pattern_observe_and_confidence_update() {
        // 테스트 3: 패턴 관찰 및 신뢰도 베이지안 업데이트
        let mut pattern = PatternLearningState::new(1, "MemoryLeak".to_string());

        // 초기 신뢰도는 0
        assert!(pattern.confidence < 0.01);

        // 관찰 1: 증거 신뢰도 0.8
        pattern.observe(1000, 0.8);
        assert!(pattern.confidence > 0.3 && pattern.confidence < 0.9);
        assert_eq!(pattern.frequency, 1);

        // 관찰 2: 증거 신뢰도 0.9
        pattern.observe(2000, 0.9);
        assert!(pattern.confidence > 0.4);
        assert_eq!(pattern.frequency, 2);
    }

    #[test]
    fn test_state_transition() {
        // 테스트 4: 상태 전이 추적
        let mut pattern = PatternLearningState::new(2, "IOBottleneck".to_string());
        assert_eq!(pattern.current_state, "NoData");

        // frequency 1 -> Observing
        pattern.frequency = 1;
        let transitioned = pattern.try_transition(1000);
        assert!(transitioned);
        assert_eq!(pattern.current_state, "Observing");

        // frequency 5 -> Emerging
        pattern.frequency = 5;
        let transitioned = pattern.try_transition(2000);
        assert!(transitioned);
        assert_eq!(pattern.current_state, "Emerging");

        // frequency 15 -> Established
        pattern.frequency = 15;
        let transitioned = pattern.try_transition(3000);
        assert!(transitioned);
        assert_eq!(pattern.current_state, "Established");
    }

    #[test]
    fn test_prediction_accuracy_tracking() {
        // 테스트 5: 예측 정확도 추적
        let mut pattern = PatternLearningState::new(3, "CacheThreshing".to_string());

        pattern.record_prediction_result(true);
        assert_eq!(pattern.successful_predictions, 1);
        assert_eq!(pattern.prediction_accuracy, 1.0);

        pattern.record_prediction_result(false);
        assert_eq!(pattern.failed_predictions, 1);
        assert!((pattern.prediction_accuracy - 0.5).abs() < 0.01);

        pattern.record_prediction_result(true);
        assert_eq!(pattern.successful_predictions, 2);
        assert!((pattern.prediction_accuracy - 0.666).abs() < 0.01);
    }

    #[test]
    fn test_actionability_conditions() {
        // 테스트 6: 조치 가능 조건 확인
        let mut pattern = PatternLearningState::new(4, "ThreadContention".to_string());

        // 초기: 조치 불가능 (frequency=0)
        assert!(!pattern.is_actionable());

        // frequency 4, confidence 0.6: 조치 가능
        pattern.frequency = 4;
        pattern.confidence = 0.6;
        assert!(pattern.is_actionable());

        // frequency 4, confidence 0.3: 조치 불가능
        pattern.confidence = 0.3;
        assert!(!pattern.is_actionable());

        // frequency 4, confidence 0.6, 예측 정확도 0.3: 조치 불가능
        pattern.confidence = 0.6;
        pattern.record_prediction_result(false);
        assert!(!pattern.is_actionable());
    }

    #[test]
    fn test_state_machine_manager() {
        // 테스트 7: 전체 상태 머신 관리
        let mut manager = StateMachineManager::new();

        manager.add_pattern(1, "MemoryLeak".to_string());
        manager.add_pattern(2, "IOBottleneck".to_string());
        assert_eq!(manager.get_total_patterns(), 2);

        // 패턴 관찰
        manager.observe_pattern(1, 1000, 0.8);
        manager.observe_pattern(1, 2000, 0.85);
        manager.observe_pattern(1, 3000, 0.9);
        manager.observe_pattern(1, 4000, 0.85);
        manager.observe_pattern(1, 5000, 0.9);

        // 5회 관찰 후 Emerging 상태
        let state = manager.get_pattern_state(1);
        assert_eq!(state, Some("Emerging".to_string()));
    }

    #[test]
    fn test_actionable_patterns_filtering() {
        // 테스트 8: 조치 가능 패턴 필터링
        let mut manager = StateMachineManager::new();

        manager.add_pattern(1, "MemoryLeak".to_string());
        manager.add_pattern(2, "IOBottleneck".to_string());
        manager.add_pattern(3, "CacheThreshing".to_string());

        // 패턴 1: 조치 가능 상태로 만들기
        for i in 0..4 {
            manager.observe_pattern(1, 1000 + (i * 1000) as u64, 0.7);
        }

        // 패턴 2: 조치 불가능 상태 유지 (frequency=0)

        // 패턴 3: 조치 가능 상태로 만들기
        for i in 0..10 {
            manager.observe_pattern(3, 1000 + (i * 1000) as u64, 0.8);
        }

        let actionable = manager.get_actionable_patterns();
        assert!(actionable.contains(&1));
        assert!(!actionable.contains(&2));
        assert!(actionable.contains(&3));
    }
}

