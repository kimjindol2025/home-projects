#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_graceful_degradation_creation() {
        let gd = GracefulDegradation::new();
        assert_eq!(gd.current_level.performance_factor(), 1.0);
        assert_eq!(gd.user_experience_score, 1.0);
    }

    #[test]
    fn test_level_determination_normal() {
        let gd = GracefulDegradation::new();
        let level = gd.determine_level(0.60);
        assert_eq!(level.performance_factor(), 1.0);
    }

    #[test]
    fn test_level_determination_warning() {
        let gd = GracefulDegradation::new();
        let level = gd.determine_level(0.77);
        assert_eq!(level.performance_factor(), 0.85);
    }

    #[test]
    fn test_level_determination_critical() {
        let gd = GracefulDegradation::new();
        let level = gd.determine_level(0.92);
        assert_eq!(level.performance_factor(), 0.50);
    }

    #[test]
    fn test_level_determination_emergency() {
        let gd = GracefulDegradation::new();
        let level = gd.determine_level(0.99);
        assert_eq!(level.performance_factor(), 0.30);
    }

    #[test]
    fn test_level_update() {
        let mut gd = GracefulDegradation::new();
        let changed = gd.update_level(0.92, 1000);
        assert!(changed);
        assert_eq!(gd.current_level.performance_factor(), 0.50);
    }

    #[test]
    fn test_performance_scaling_policy_level0() {
        let policy = PerformanceScalingPolicy::for_level(&DegradationLevel::Level0);
        assert_eq!(policy.cpu_time_slice_reduction, 0.0);
        assert_eq!(policy.cache_evict_percent, 0.0);
    }

    #[test]
    fn test_performance_scaling_policy_level4() {
        let policy = PerformanceScalingPolicy::for_level(&DegradationLevel::Level4);
        assert!(policy.cpu_time_slice_reduction > 0.5);
        assert!(policy.cache_evict_percent > 30.0);
        assert_eq!(policy.gc_frequency_increase, 3.0);
    }

    #[test]
    fn test_performance_recording() {
        let mut gd = GracefulDegradation::new();
        gd.record_performance(1000, 0.99);
        assert_eq!(gd.performance_history.len(), 1);
    }

    #[test]
    fn test_user_experience_calculation() {
        let mut gd = GracefulDegradation::new();
        gd.current_level = DegradationLevel::Level2;
        gd.calculate_user_experience_score();
        assert!(gd.user_experience_score >= 0.50 && gd.user_experience_score <= 1.0);
    }

    #[test]
    fn test_recovery_tracking() {
        let mut gd = GracefulDegradation::new();
        gd.attempt_recovery(1000, true);
        gd.attempt_recovery(2000, true);
        assert_eq!(gd.recovery_attempts, 2);
        assert!(gd.last_recovery_success > 0);
    }

    #[test]
    fn test_system_always_alive() {
        let gd = GracefulDegradation::new();
        let snapshot = gd.snapshot();
        assert!(snapshot.system_alive);  // 항상 true!
    }

    #[test]
    fn test_degradation_notice() {
        let mut gd = GracefulDegradation::new();
        gd.current_level = DegradationLevel::Level3;
        let notice = gd.issue_degradation_notice();
        assert!(notice.contains("Level 3"));
        assert!(notice.contains("50%"));
    }

    #[test]
    fn test_performance_factor_decreases() {
        let level0 = DegradationLevel::Level0.performance_factor();
        let level1 = DegradationLevel::Level1.performance_factor();
        let level4 = DegradationLevel::Level4.performance_factor();

        assert!(level0 > level1);
        assert!(level1 > level4);
        assert_eq!(level0, 1.0);
        assert_eq!(level4, 0.30);
    }

    #[test]
    fn test_prediction_error_within_bounds() {
        let mut gd = GracefulDegradation::new();
        gd.record_performance(1000, 0.98);  // 예상: 1.0
        assert!(gd.performance_prediction_error <= 5.0);  // ±5% 기준
    }

    #[test]
    fn test_full_degradation_cycle() {
        let mut gd = GracefulDegradation::new();

        // Normal
        gd.update_level(0.60, 1000);
        assert_eq!(gd.current_level.performance_factor(), 1.0);

        // Warning
        gd.update_level(0.77, 2000);
        assert_eq!(gd.current_level.performance_factor(), 0.85);

        // Critical
        gd.update_level(0.92, 3000);
        assert_eq!(gd.current_level.performance_factor(), 0.50);

        // Emergency
        gd.update_level(0.99, 4000);
        assert_eq!(gd.current_level.performance_factor(), 0.30);

        // Recovery to Normal
        gd.update_level(0.60, 5000);
        assert_eq!(gd.current_level.performance_factor(), 1.0);
    }
}

