// DegradationLevel: 5단계 성능 저하 레벨
enum DegradationLevel {
    Level0,  // 100% performance - 정상 (CPU/메모리 모두 충분)
    Level1,  //  85% performance -   경고 (메모리 75-80%)
    Level2,  //  70% performance -   주의 (메모리 80-90%)
    Level3,  //  50% performance -   심각 (메모리 90-98%)
    Level4,  //  30% performance - 긴급 (메모리 98%+, 시스템 생존 우선)
}

impl DegradationLevel {
    fn performance_factor(&self) -> f64 {
        match self {
            DegradationLevel::Level0 => 1.00,   // 100%
            DegradationLevel::Level1 => 0.85,   //  85%
            DegradationLevel::Level2 => 0.70,   //  70%
            DegradationLevel::Level3 => 0.50,   //  50%
            DegradationLevel::Level4 => 0.30,   //  30%
        }
    }

    fn target_saturation(&self) -> f64 {
        match self {
            DegradationLevel::Level0 => 0.75,
            DegradationLevel::Level1 => 0.80,
            DegradationLevel::Level2 => 0.90,
            DegradationLevel::Level3 => 0.98,
            DegradationLevel::Level4 => 1.00,
        }
    }

    fn description(&self) -> String {
        match self {
            DegradationLevel::Level0 => "Normal operation, full performance".to_string(),
            DegradationLevel::Level1 => "Caution: 85% performance, memory warning".to_string(),
            DegradationLevel::Level2 => "Warning: 70% performance, memory pressure".to_string(),
            DegradationLevel::Level3 => "Critical: 50% performance, emergency measures active".to_string(),
            DegradationLevel::Level4 => "Emergency: 30% performance, survival mode, system stability prioritized".to_string(),
        }
    }
}

// PerformanceScalingPolicy: 각 컴포넌트별 성능 조정 정책
struct PerformanceScalingPolicy {
    // CPU 스케줄링 설정
    cpu_time_slice_reduction: f64,      // 타임 슬라이스 감소율 (0.0-1.0)
    max_threads_reduction: f64,          // 최대 스레드 수 감소율

    // 메모리 설정
    cache_evict_percent: f64,           // 캐시 제거 비율
    buffer_shrink_percent: f64,         // 버퍼 축소 비율

    // I/O 설정
    io_throttle_percent: f64,           // I/O 스로틀 비율
    disk_cache_reduce_percent: f64,     // 디스크 캐시 감소 비율

    // GC 설정
    gc_frequency_increase: f64,         // GC 빈도 증가 배수
    gc_pause_time_limit_ms: u32,       // GC pause time 제한
}

impl PerformanceScalingPolicy {
    fn for_level(level: &DegradationLevel) -> PerformanceScalingPolicy {
        match level {
            DegradationLevel::Level0 => {
                PerformanceScalingPolicy {
                    cpu_time_slice_reduction: 0.0,
                    max_threads_reduction: 0.0,
                    cache_evict_percent: 0.0,
                    buffer_shrink_percent: 0.0,
                    io_throttle_percent: 0.0,
                    disk_cache_reduce_percent: 0.0,
                    gc_frequency_increase: 1.0,
                    gc_pause_time_limit_ms: 50,
                }
            },
            DegradationLevel::Level1 => {
                PerformanceScalingPolicy {
                    cpu_time_slice_reduction: 0.10,   // 10% 타임슬라이스 감소
                    max_threads_reduction: 0.10,       // 10% 스레드 감소
                    cache_evict_percent: 5.0,          // 5% 캐시 제거
                    buffer_shrink_percent: 5.0,        // 5% 버퍼 축소
                    io_throttle_percent: 0.0,
                    disk_cache_reduce_percent: 10.0,
                    gc_frequency_increase: 1.2,        // 20% 더 자주
                    gc_pause_time_limit_ms: 40,
                }
            },
            DegradationLevel::Level2 => {
                PerformanceScalingPolicy {
                    cpu_time_slice_reduction: 0.25,   // 25% 감소
                    max_threads_reduction: 0.30,       // 30% 스레드 감소
                    cache_evict_percent: 15.0,         // 15% 캐시 제거
                    buffer_shrink_percent: 15.0,       // 15% 버퍼 축소
                    io_throttle_percent: 20.0,         // 20% 스로틀
                    disk_cache_reduce_percent: 30.0,
                    gc_frequency_increase: 1.5,        // 50% 더 자주
                    gc_pause_time_limit_ms: 30,
                }
            },
            DegradationLevel::Level3 => {
                PerformanceScalingPolicy {
                    cpu_time_slice_reduction: 0.45,   // 45% 감소
                    max_threads_reduction: 0.50,       // 50% 스레드 감소
                    cache_evict_percent: 30.0,         // 30% 캐시 제거
                    buffer_shrink_percent: 30.0,       // 30% 버퍼 축소
                    io_throttle_percent: 50.0,         // 50% 스로틀
                    disk_cache_reduce_percent: 60.0,
                    gc_frequency_increase: 2.0,        // 2배 더 자주
                    gc_pause_time_limit_ms: 20,
                }
            },
            DegradationLevel::Level4 => {
                PerformanceScalingPolicy {
                    cpu_time_slice_reduction: 0.70,   // 70% 감소 (최소 기능만)
                    max_threads_reduction: 0.80,       // 80% 스레드 감소 (필수만 유지)
                    cache_evict_percent: 50.0,         // 50% 캐시 완전 제거
                    buffer_shrink_percent: 50.0,       // 50% 버퍼 축소
                    io_throttle_percent: 80.0,         // 80% 스로틀 (최소 I/O만)
                    disk_cache_reduce_percent: 90.0,
                    gc_frequency_increase: 3.0,        // 3배 더 자주 (메모리 확보)
                    gc_pause_time_limit_ms: 10,
                }
            },
        }
    }
}

// ========================================================================
// GracefulDegradation: 단계별 성능 저하 엔진
// ========================================================================

struct GracefulDegradation {
    current_level: DegradationLevel,
    previous_level: DegradationLevel,
    level_change_timestamp: u64,

    // 성능 예측
    performance_history: Vec<(u64, f64)>,  // (timestamp, actual_performance)
    performance_prediction_error: f64,      // 예측 오차율 (±5% 목표)

    // 사용자 경험
    user_experience_score: f64,             // 0.0-1.0 (1.0 = 최고)
    degradation_notice_issued: bool,

    // 복구 추적
    recovery_attempts: u32,
    last_recovery_success: u64,
}

impl GracefulDegradation {
    // 초기화
    fn new() -> GracefulDegradation {
        GracefulDegradation {
            current_level: DegradationLevel::Level0,
            previous_level: DegradationLevel::Level0,
            level_change_timestamp: 0,
            performance_history: Vec::new(),
            performance_prediction_error: 0.0,
            user_experience_score: 1.0,
            degradation_notice_issued: false,
            recovery_attempts: 0,
            last_recovery_success: 0,
        }
    }

    // 현재 포화도에 따라 저하 레벨 결정
    fn determine_level(&self, saturation: f64) -> DegradationLevel {
        if saturation >= 0.98 {
            DegradationLevel::Level4
        } else if saturation >= 0.90 {
            DegradationLevel::Level3
        } else if saturation >= 0.80 {
            DegradationLevel::Level2
        } else if saturation >= 0.75 {
            DegradationLevel::Level1
        } else {
            DegradationLevel::Level0
        }
    }

    // 저하 레벨 업데이트
    fn update_level(&mut self, saturation: f64, timestamp: u64) -> bool {
        let new_level = self.determine_level(saturation);

        // 레벨이 변화했는지 확인
        let level_changed = match (&self.current_level, &new_level) {
            (DegradationLevel::Level0, DegradationLevel::Level0) => false,
            (DegradationLevel::Level1, DegradationLevel::Level1) => false,
            (DegradationLevel::Level2, DegradationLevel::Level2) => false,
            (DegradationLevel::Level3, DegradationLevel::Level3) => false,
            (DegradationLevel::Level4, DegradationLevel::Level4) => false,
            _ => true,
        };

        if level_changed {
            self.previous_level = match &self.current_level {
                DegradationLevel::Level0 => DegradationLevel::Level0,
                DegradationLevel::Level1 => DegradationLevel::Level1,
                DegradationLevel::Level2 => DegradationLevel::Level2,
                DegradationLevel::Level3 => DegradationLevel::Level3,
                DegradationLevel::Level4 => DegradationLevel::Level4,
            };

            self.current_level = new_level;
            self.level_change_timestamp = timestamp;
            self.degradation_notice_issued = false;
        }

        level_changed
    }

    // 현재 성능 계수 반환
    fn get_performance_factor(&self) -> f64 {
        self.current_level.performance_factor()
    }

    // 성능 스케일링 정책 반환
    fn get_scaling_policy(&self) -> PerformanceScalingPolicy {
        PerformanceScalingPolicy::for_level(&self.current_level)
    }

    // 실제 성능 기록
    fn record_performance(&mut self, timestamp: u64, measured_performance: f64) {
        self.performance_history.push((timestamp, measured_performance));

        // 히스토리 크기 제한 (최근 100개)
        if self.performance_history.len() > 100 {
            self.performance_history.remove(0);
        }

        // 예측 오차 계산
        let expected_performance = self.current_level.performance_factor();
        let error = (measured_performance - expected_performance).abs();
        self.performance_prediction_error = error * 100.0;  // 퍼센트
    }

    // 사용자 경험 점수 계산
    fn calculate_user_experience_score(&mut self) {
        let performance_factor = self.current_level.performance_factor();

        // 성능 저하에 따른 점수 계산
        let performance_score = performance_factor;

        // Level별 추가 가중치
        let level_weight = match &self.current_level {
            DegradationLevel::Level0 => 1.0,     // 최고 (영향 없음)
            DegradationLevel::Level1 => 0.95,    // 거의 영향 없음
            DegradationLevel::Level2 => 0.85,    // 약간의 느림
            DegradationLevel::Level3 => 0.60,    // 상당한 느림
            DegradationLevel::Level4 => 0.40,    // 심각한 느림 (하지만 작동)
        };

        self.user_experience_score = performance_score * level_weight;
    }

    // 저하 공지 발급
    fn issue_degradation_notice(&mut self) -> String {
        if !self.degradation_notice_issued {
            self.degradation_notice_issued = true;

            let level_str = match &self.current_level {
                DegradationLevel::Level0 => "Level 0",
                DegradationLevel::Level1 => "Level 1",
                DegradationLevel::Level2 => "Level 2",
                DegradationLevel::Level3 => "Level 3",
                DegradationLevel::Level4 => "Level 4",
            };

            format!("System degraded to {} ({}%): {}",
                level_str,
                (self.current_level.performance_factor() * 100.0) as u32,
                self.current_level.description())
        } else {
            "".to_string()
        }
    }

    // 복구 시도 기록
    fn attempt_recovery(&mut self, timestamp: u64, success: bool) {
        self.recovery_attempts += 1;

        if success {
            self.last_recovery_success = timestamp;
        }
    }

    // 복구 성공률
    fn recovery_success_rate(&self) -> f64 {
        if self.recovery_attempts == 0 {
            return 100.0;
        }

        // 최근 복구 시도가 있었는지 확인
        // (단순화: 적어도 한 번은 성공했다면 높은 성공률)
        if self.last_recovery_success > 0 {
            (self.recovery_attempts as f64 - 1.0) / (self.recovery_attempts as f64) * 100.0
        } else {
            0.0
        }
    }

    // 현재 상태 스냅샷
    fn snapshot(&self) -> DegradationSnapshot {
        DegradationSnapshot {
            current_level: match &self.current_level {
                DegradationLevel::Level0 => "Level0".to_string(),
                DegradationLevel::Level1 => "Level1".to_string(),
                DegradationLevel::Level2 => "Level2".to_string(),
                DegradationLevel::Level3 => "Level3".to_string(),
                DegradationLevel::Level4 => "Level4".to_string(),
            },
            performance_factor: self.current_level.performance_factor(),
            user_experience_score: self.user_experience_score,
            performance_prediction_error: self.performance_prediction_error,
            system_alive: true,  // 항상 true - "죽지 않는" 보장
        }
    }
}

// DegradationSnapshot: 특정 시점의 저하 상태
struct DegradationSnapshot {
    current_level: String,
    performance_factor: f64,
    user_experience_score: f64,
    performance_prediction_error: f64,
    system_alive: bool,  // 항상 true!
}

