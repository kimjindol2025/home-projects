// ============================================================================
// Test 13: Replication Under Partition
// ============================================================================

fn test_replication_under_partition() -> TestResult {
    let engine = new_simulation_engine(3, 12345);

    // Write to leader
    let write = SimEvent {
        time_ms: 100,
        event_type: SimEventType.ClientRequest,
        node_id: 0,
        from_node: 0,
        to_node: 0,
        key: "key1",
        value: "value1",
        delay_ms: 0,
        loss_rate: 0.0,
    };

    engine = add_event(engine, write);

    // Partition happens
    let partition = SimEvent {
        time_ms: 200,
        event_type: SimEventType.NetworkPartition,
        node_id: 0,
        from_node: 0,
        to_node: 1,
        key: "",
        value: "",
        delay_ms: 0,
        loss_rate: 0.0,
    };

    engine = add_event(engine, partition);
    engine = sort_events(engine);

    // Write should happen before partition
    let write_before_partition = false;
    let i = 0;
    while (i < engine.events.len() - 1) {
        if (engine.events[i].event_type == SimEventType.ClientRequest &&
            engine.events[i + 1].event_type == SimEventType.NetworkPartition) {
            write_before_partition = true;
            break;
        };
        i = i + 1;
    };

    return assert_true(write_before_partition, "test_replication_under_partition");
}

