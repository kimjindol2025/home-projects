// ============================================================================
// Test 7: Log Divergence Resolution
// ============================================================================

fn test_log_divergence_resolution() -> TestResult {
    let engine = new_simulation_engine(3, 12345);
    engine = scenario_log_divergence(engine);

    let events = engine.events;
    let write_count = 0;
    let partition_count = 0;

    let i = 0;
    while (i < events.len()) {
        if (events[i].event_type == SimEventType.ClientRequest) {
            write_count = write_count + 1;
        } else if (events[i].event_type == SimEventType.NetworkPartition) {
            partition_count = partition_count + 1;
        };
        i = i + 1;
    };

    // Should have write + partition + recovery
    let resolved = write_count > 0 && partition_count == 2;

    return assert_true(resolved, "test_log_divergence_resolution");
}

