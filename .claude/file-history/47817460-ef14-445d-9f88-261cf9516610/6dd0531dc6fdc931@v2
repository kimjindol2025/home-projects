// ============================================================================
// Test 3: No Data Loss On Crash
// ============================================================================

fn test_no_data_loss_on_crash() -> TestResult {
    let engine = new_simulation_engine(3, 12345);

    // Write before crash
    let write_before_crash = SimEvent {
        time_ms: 50,
        event_type: SimEventType.ClientRequest,
        node_id: 0,
        from_node: 0,
        to_node: 0,
        key: "critical_key",
        value: "critical_value",
        delay_ms: 0,
        loss_rate: 0.0,
    };

    engine = add_event(engine, write_before_crash);

    // Leader crashes
    let crash_event = SimEvent {
        time_ms: 100,
        event_type: SimEventType.NodeCrash,
        node_id: 0,
        from_node: 0,
        to_node: 0,
        key: "",
        value: "",
        delay_ms: 0,
        loss_rate: 0.0,
    };

    engine = add_event(engine, crash_event);
    engine = sort_events(engine);

    // Data should be replicated before crash
    let has_write = false;
    let i = 0;
    while (i < engine.events.len()) {
        if (engine.events[i].key == "critical_key") {
            has_write = true;
            break;
        };
        i = i + 1;
    };

    return assert_true(has_write, "test_no_data_loss_on_crash");
}

