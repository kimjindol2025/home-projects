// PHASE I + PHASE H INTEGRATION CONTROLLER
// ============================================================================

pub struct IntegrationController {
    pub test_results: Vec<IntegrationTestResult>,
    pub total_tests: u32,
    pub passed_tests: u32,
}

impl IntegrationController {
    pub fn new() -> Self {
        IntegrationController {
            test_results: Vec::new(),
            total_tests: 0,
            passed_tests: 0,
        }
    }

    // =========================================================================
    // Test 1: Scenario 1 Integration (Tail Latency)
    // =========================================================================
    pub fn test_scenario1_integration(&mut self, mut scenario: TailLatencyScenario) -> IntegrationTestResult {
        let mut result = IntegrationTestResult::new("Scenario 1: Tail Latency Integration".to_string());
        let mut current_time_ms = 0u64;

        // T-5s: Setup
        result.add_state_transition(current_time_ms, IntegrationState::Setup);
        current_time_ms += 5000;

        // T-0s: Fault Injection (Phase I)
        result.add_state_transition(current_time_ms, IntegrationState::FaultInjected);
        result.fault_injected = true;
        current_time_ms += 10;  // T+10ms

        // T+10s: Metric Degradation Observed
        result.add_state_transition(current_time_ms, IntegrationState::MetricDegraded);
        current_time_ms += 9990;  // Advance to T+10s

        // T+10s: SLO Violation Detected (Phase H)
        // Phase H detects when P99 > baseline * 1.5
        let slo_violated = scenario.current_p99_latency_ms > scenario.baseline_p99_latency_ms * 1.5;
        result.add_state_transition(current_time_ms, IntegrationState::SLOViolated);
        result.slo_violation_detected = slo_violated;
        result.slo_detection_latency_ms = current_time_ms;
        current_time_ms += 10;

        // T+20s: Policy Decision Made (Phase H decides on policy)
        result.add_state_transition(current_time_ms, IntegrationState::PolicyDecided);
        // Policy: reduce_batch_size (will improve latency)
        current_time_ms += 9990;

        // T+20s: Policy Applied (Phase H → Phase I)
        result.add_state_transition(current_time_ms, IntegrationState::PolicyApplied);
        scenario.reduce_batch_size_applied = true;
        result.policy_applied = true;
        current_time_ms += 10;

        // T+30-60s: System Recovering
        result.add_state_transition(current_time_ms + 30000, IntegrationState::Recovering);
        current_time_ms += 40000;  // Advance to T+60s

        // T+60s: Recovery Complete
        result.add_state_transition(current_time_ms, IntegrationState::Recovered);
        result.recovery_successful = scenario.current_p99_latency_ms < 50.0;
        result.recovery_time_ms = current_time_ms - result.slo_detection_latency_ms;
        current_time_ms += 40;

        // T+100s: Validation
        result.add_state_transition(current_time_ms, IntegrationState::Validated);

        // Verify via chaos_validator
        let criteria = TailLatencyValidator::validate(&scenario);
        let test_passed = criteria.overall_pass && result.slo_violation_detected &&
                         result.policy_applied && result.recovery_successful;

        result.add_state_transition(current_time_ms, IntegrationState::Complete);
        result.total_duration_ms = current_time_ms;
        result.test_passed = test_passed;

        // Capture metrics snapshot
        result.metrics_snapshot.insert("P99_latency_ms".to_string(), scenario.current_p99_latency_ms);
        result.metrics_snapshot.insert("improvement_pct".to_string(),
            (scenario.baseline_p99_latency_ms - scenario.current_p99_latency_ms) /
            scenario.baseline_p99_latency_ms * 100.0);

        self.total_tests += 1;
        if result.test_passed { self.passed_tests += 1; }
        result
    }

