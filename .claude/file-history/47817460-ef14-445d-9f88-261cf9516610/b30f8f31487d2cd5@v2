// ============================================================================
// INTEGRATION LIFECYCLE STATES
// ============================================================================

#[derive(Debug, Clone, PartialEq)]
pub enum IntegrationState {
    Setup,              // Initial configuration
    FaultInjected,      // Fault injected (Phase I)
    MetricDegraded,     // Metrics degraded (Phase I monitors)
    SLOViolated,        // SLO violation detected (Phase H)
    PolicyDecided,      // Policy decision made (Phase H)
    PolicyApplied,      // Policy executed (Phase H controls Phase I)
    Recovering,         // System recovering (Phase I + Phase H)
    Recovered,          // Full recovery achieved
    Validated,          // Validation criteria met
    Complete,           // Integration test complete
}

// ============================================================================
// INTEGRATION TEST RESULT
// ============================================================================

pub struct IntegrationTestResult {
    pub scenario_id: String,
    pub state_progression: Vec<(u64, IntegrationState)>,  // (timestamp_ms, state)
    pub fault_injected: bool,
    pub slo_violation_detected: bool,
    pub policy_applied: bool,
    pub recovery_successful: bool,
    pub total_duration_ms: u64,
    pub slo_detection_latency_ms: u64,  // Time from fault to SLO detection
    pub recovery_time_ms: u64,           // Time from SLO detection to recovery
    pub final_state: IntegrationState,
    pub metrics_snapshot: HashMap<String, f64>,
    pub test_passed: bool,
}

impl IntegrationTestResult {
    pub fn new(scenario_id: String) -> Self {
        IntegrationTestResult {
            scenario_id,
            state_progression: Vec::new(),
            fault_injected: false,
            slo_violation_detected: false,
            policy_applied: false,
            recovery_successful: false,
            total_duration_ms: 0,
            slo_detection_latency_ms: 0,
            recovery_time_ms: 0,
            final_state: IntegrationState::Setup,
            metrics_snapshot: HashMap::new(),
            test_passed: false,
        }
    }

    pub fn add_state_transition(&mut self, timestamp_ms: u64, state: IntegrationState) {
        self.state_progression.push((timestamp_ms, state.clone()));
        self.final_state = state;
    }

    pub fn get_state_progression_report(&self) -> String {
        let mut report = String::new();
        report.push_str(&format!("Scenario: {}\n", self.scenario_id));
        report.push_str("State Progression Timeline:\n");
        report.push_str("─────────────────────────────────────────────────\n");
        for (timestamp, state) in &self.state_progression {
            report.push_str(&format!("T+{:6}ms: {:?}\n", timestamp, state));
        }
        report
    }
}

