    use super::*;

    #[test]
    fn test_recovery_history_entry() {
        // 테스트 1: 복구 이력 엔트리 생성 및 완료
        let mut entry = RecoveryHistoryEntry::new(1, 1000, "MemoryLeak".to_string(), 0.85, "GC Trigger".to_string());
        assert_eq!(entry.pattern_type, "MemoryLeak");
        assert_eq!(entry.saturation_before, 0.85);
        assert!(!entry.success);

        entry.complete_recovery(0.60, 150, true);
        assert!(entry.success);
        assert_eq!(entry.recovery_time_ms, 150);
        assert!(entry.improvement_ratio() > 0.25);
    }

    #[test]
    fn test_metrics_snapshot() {
        // 테스트 2: 메트릭 스냅샷 생성
        let snapshot = MetricsSnapshot::from_values(
            1000,
            0.75,
            0.85,
            60000,
            5000000,
            1000,
            128,
            0.25,
        );

        assert_eq!(snapshot.memory_saturation, 0.75);
        assert_eq!(snapshot.cpu_usage, 0.85);
        assert_eq!(snapshot.io_ops_per_sec, 60000);
    }

    #[test]
    fn test_recovery_history_db_add_and_retrieve() {
        // 테스트 3: DB에 엔트리 추가 및 검색
        let mut db = RecoveryHistoryDB::new();

        let entry1 = RecoveryHistoryEntry::new(1, 1000, "MemoryLeak".to_string(), 0.85, "GC".to_string());
        let entry2 = RecoveryHistoryEntry::new(2, 2000, "IOBottleneck".to_string(), 0.75, "Throttle".to_string());

        db.add_entry(entry1);
        db.add_entry(entry2);

        assert_eq!(db.get_entry_count(), 2);
        assert!(db.get_entry(1).is_some());
        assert!(db.get_entry(2).is_some());
    }

    #[test]
    fn test_query_by_pattern_type() {
        // 테스트 4: 패턴 타입별 검색
        let mut db = RecoveryHistoryDB::new();

        db.add_entry(RecoveryHistoryEntry::new(1, 1000, "MemoryLeak".to_string(), 0.85, "GC".to_string()));
        db.add_entry(RecoveryHistoryEntry::new(2, 2000, "MemoryLeak".to_string(), 0.80, "GC".to_string()));
        db.add_entry(RecoveryHistoryEntry::new(3, 3000, "IOBottleneck".to_string(), 0.75, "Throttle".to_string()));

        let memory_entries = db.get_entries_by_pattern_type("MemoryLeak");
        assert_eq!(memory_entries.len(), 2);

        let io_entries = db.get_entries_by_pattern_type("IOBottleneck");
