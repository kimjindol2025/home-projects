// ============================================================================
// RecoveryHistoryEntry: 복구 이력 엔트리
// ============================================================================

struct RecoveryHistoryEntry {
    entry_id: u64,
    timestamp: u64,
    pattern_type: String,
    saturation_before: f64,        // 복구 전 포화도
    saturation_after: f64,         // 복구 후 포화도
    recovery_time_ms: u32,
    success: bool,                 // 복구 성공 여부
    metrics_before: MetricsSnapshot,
    metrics_after: MetricsSnapshot,
    recovery_action: String,       // 실행된 복구 조치
    recovery_confidence: f64,      // 예측 신뢰도 (0.0-1.0)
}

impl RecoveryHistoryEntry {
    fn new(
        entry_id: u64,
        timestamp: u64,
        pattern_type: String,
        saturation_before: f64,
        recovery_action: String,
    ) -> RecoveryHistoryEntry {
        RecoveryHistoryEntry {
            entry_id,
            timestamp,
            pattern_type,
            saturation_before,
            saturation_after: 0.0,
            recovery_time_ms: 0,
            success: false,
            metrics_before: MetricsSnapshot::new(),
            metrics_after: MetricsSnapshot::new(),
            recovery_action,
            recovery_confidence: 0.0,
        }
    }

    fn complete_recovery(&mut self, saturation_after: f64, recovery_time_ms: u32, success: bool) {
        self.saturation_after = saturation_after;
        self.recovery_time_ms = recovery_time_ms;
        self.success = success;
    }

    fn improvement_ratio(&self) -> f64 {
        // 포화도 개선도 (0.0-1.0)
        if self.saturation_before > 0.0 {
            (self.saturation_before - self.saturation_after) / self.saturation_before
        } else {
            0.0
        }
    }
}

// ============================================================================
// MetricsSnapshot: 메트릭 스냅샷
// ============================================================================

struct MetricsSnapshot {
    timestamp: u64,
    memory_saturation: f64,
    cpu_usage: f64,
    io_ops_per_sec: u32,
    context_switches_per_sec: u32,
    page_faults_per_sec: u32,
    thread_count: u32,
    cache_miss_rate: f64,
}

impl MetricsSnapshot {
    fn new() -> MetricsSnapshot {
        MetricsSnapshot {
            timestamp: 0,
            memory_saturation: 0.0,
            cpu_usage: 0.0,
            io_ops_per_sec: 0,
            context_switches_per_sec: 0,
            page_faults_per_sec: 0,
            thread_count: 0,
            cache_miss_rate: 0.0,
        }
    }

    fn from_values(
        timestamp: u64,
        memory_saturation: f64,
        cpu_usage: f64,
        io_ops_per_sec: u32,
        context_switches_per_sec: u32,
        page_faults_per_sec: u32,
        thread_count: u32,
        cache_miss_rate: f64,
    ) -> MetricsSnapshot {
        MetricsSnapshot {
            timestamp,
            memory_saturation,
            cpu_usage,
            io_ops_per_sec,
            context_switches_per_sec,
            page_faults_per_sec,
            thread_count,
            cache_miss_rate,
        }
    }
}

// ============================================================================
// RecoveryHistoryDB: 복구 이력 데이터베이스
// ============================================================================

struct RecoveryHistoryDB {
    entries: Vec<RecoveryHistoryEntry>,
    max_entries: usize,             // 최대 1,000개 보유
    next_entry_id: u64,
}

impl RecoveryHistoryDB {
    fn new() -> RecoveryHistoryDB {
        RecoveryHistoryDB {
            entries: Vec::new(),
            max_entries: 1000,
            next_entry_id: 1,
        }
    }

    fn add_entry(&mut self, mut entry: RecoveryHistoryEntry) -> u64 {
        entry.entry_id = self.next_entry_id;
        self.next_entry_id += 1;

        self.entries.push(entry);

        // 최대값 초과 시 가장 오래된 항목 제거
        if self.entries.len() > self.max_entries {
            self.entries.remove(0);
        }

        self.next_entry_id - 1
    }

    fn get_entry(&self, entry_id: u64) -> Option<&RecoveryHistoryEntry> {
        self.entries.iter().find(|e| e.entry_id == entry_id)
    }

    fn get_entries_by_pattern_type(&self, pattern_type: &str) -> Vec<&RecoveryHistoryEntry> {
        self.entries
            .iter()
            .filter(|e| e.pattern_type == pattern_type)
            .collect()
    }

    fn get_recent_entries(&self, count: usize) -> Vec<&RecoveryHistoryEntry> {
        let start = if self.entries.len() > count {
            self.entries.len() - count
        } else {
            0
        };
        self.entries[start..].iter().collect()
    }

    fn get_successful_recovery_rate(&self, pattern_type: &str) -> f64 {
        let entries = self.get_entries_by_pattern_type(pattern_type);
        if entries.is_empty() {
            return 0.0;
        }

        let successful = entries.iter().filter(|e| e.success).count();
        (successful as f64) / (entries.len() as f64)
    }

    fn get_average_recovery_time(&self, pattern_type: &str) -> u32 {
        let entries = self.get_entries_by_pattern_type(pattern_type);
        if entries.is_empty() {
            return 0;
        }

        let total_time: u32 = entries.iter().map(|e| e.recovery_time_ms).sum();
        total_time / entries.len() as u32
    }

    fn get_average_improvement(&self, pattern_type: &str) -> f64 {
        let entries = self.get_entries_by_pattern_type(pattern_type);
        if entries.is_empty() {
            return 0.0;
        }

        let total_improvement: f64 = entries.iter().map(|e| e.improvement_ratio()).sum();
        total_improvement / entries.len() as f64
    }

    fn query_by_saturation_range(&self, min: f64, max: f64) -> Vec<&RecoveryHistoryEntry> {
        self.entries
            .iter()
            .filter(|e| e.saturation_before >= min && e.saturation_before <= max)
            .collect()
    }

    fn query_by_time_range(&self, start_timestamp: u64, end_timestamp: u64) -> Vec<&RecoveryHistoryEntry> {
        self.entries
            .iter()
            .filter(|e| e.timestamp >= start_timestamp && e.timestamp <= end_timestamp)
            .collect()
    }

    fn query_by_recovery_time_range(
        &self,
        min_time: u32,
        max_time: u32,
    ) -> Vec<&RecoveryHistoryEntry> {
        self.entries
            .iter()
            .filter(|e| e.recovery_time_ms >= min_time && e.recovery_time_ms <= max_time)
            .collect()
    }

    fn query_successful_only(&self) -> Vec<&RecoveryHistoryEntry> {
        self.entries.iter().filter(|e| e.success).collect()
    }

    fn query_failed_only(&self) -> Vec<&RecoveryHistoryEntry> {
        self.entries.iter().filter(|e| !e.success).collect()
    }

    fn get_entry_count(&self) -> usize {
        self.entries.len()
    }

    fn clear(&mut self) {
        self.entries.clear();
    }

    fn get_pattern_statistics(&self, pattern_type: &str) -> PatternStatistics {
        let entries = self.get_entries_by_pattern_type(pattern_type);

        if entries.is_empty() {
            return PatternStatistics {
                pattern_type: pattern_type.to_string(),
                total_occurrences: 0,
                success_count: 0,
                failure_count: 0,
                success_rate: 0.0,
                average_recovery_time_ms: 0,
                average_improvement_ratio: 0.0,
                min_recovery_time_ms: 0,
                max_recovery_time_ms: 0,
                last_occurrence_timestamp: 0,
            };
        }

        let success_count = entries.iter().filter(|e| e.success).count();
        let failure_count = entries.len() - success_count;

        let total_time: u32 = entries.iter().map(|e| e.recovery_time_ms).sum();
        let average_time = total_time / entries.len() as u32;

        let total_improvement: f64 = entries.iter().map(|e| e.improvement_ratio()).sum();
        let average_improvement = total_improvement / entries.len() as f64;

        let min_time = entries.iter().map(|e| e.recovery_time_ms).min().unwrap_or(0);
        let max_time = entries.iter().map(|e| e.recovery_time_ms).max().unwrap_or(0);

        let last_timestamp = entries.last().map(|e| e.timestamp).unwrap_or(0);

        PatternStatistics {
            pattern_type: pattern_type.to_string(),
            total_occurrences: entries.len(),
            success_count,
            failure_count,
            success_rate: (success_count as f64) / (entries.len() as f64),
            average_recovery_time_ms: average_time,
            average_improvement_ratio: average_improvement,
            min_recovery_time_ms: min_time,
            max_recovery_time_ms: max_time,
            last_occurrence_timestamp: last_timestamp,
        }
    }
}

// ============================================================================
// PatternStatistics: 패턴 통계
// ============================================================================

struct PatternStatistics {
    pattern_type: String,
    total_occurrences: usize,
    success_count: usize,
    failure_count: usize,
    success_rate: f64,
    average_recovery_time_ms: u32,
    average_improvement_ratio: f64,
    min_recovery_time_ms: u32,
    max_recovery_time_ms: u32,
    last_occurrence_timestamp: u64,
}

// ============================================================================
// PatternQueryInterface: 패턴 검색 인터페이스
// ============================================================================

trait PatternQueryInterface {
    fn query_recent(&self, count: usize) -> Vec<&RecoveryHistoryEntry>;
    fn query_by_pattern(&self, pattern_type: &str) -> Vec<&RecoveryHistoryEntry>;
    fn query_by_time(&self, start: u64, end: u64) -> Vec<&RecoveryHistoryEntry>;
    fn get_statistics(&self, pattern_type: &str) -> PatternStatistics;
}

impl PatternQueryInterface for RecoveryHistoryDB {
    fn query_recent(&self, count: usize) -> Vec<&RecoveryHistoryEntry> {
        self.get_recent_entries(count)
    }

    fn query_by_pattern(&self, pattern_type: &str) -> Vec<&RecoveryHistoryEntry> {
        self.get_entries_by_pattern_type(pattern_type)
    }

    fn query_by_time(&self, start: u64, end: u64) -> Vec<&RecoveryHistoryEntry> {
        self.query_by_time_range(start, end)
    }

    fn get_statistics(&self, pattern_type: &str) -> PatternStatistics {
        self.get_pattern_statistics(pattern_type)
    }
}

