    }

    #[test]
    fn test_success_rate_calculation() {
        // 테스트 5: 복구 성공률 계산
        let mut db = RecoveryHistoryDB::new();

        let mut entry1 = RecoveryHistoryEntry::new(1, 1000, "MemoryLeak".to_string(), 0.85, "GC".to_string());
        entry1.success = true;
        db.add_entry(entry1);

        let mut entry2 = RecoveryHistoryEntry::new(2, 2000, "MemoryLeak".to_string(), 0.80, "GC".to_string());
        entry2.success = true;
        db.add_entry(entry2);

        let mut entry3 = RecoveryHistoryEntry::new(3, 3000, "MemoryLeak".to_string(), 0.75, "GC".to_string());
        entry3.success = false;
        db.add_entry(entry3);

        let success_rate = db.get_successful_recovery_rate("MemoryLeak");
        assert!((success_rate - 0.667).abs() < 0.01);
    }

    #[test]
    fn test_average_recovery_time() {
        // 테스트 6: 평균 복구 시간 계산
        let mut db = RecoveryHistoryDB::new();

        let mut entry1 = RecoveryHistoryEntry::new(1, 1000, "MemoryLeak".to_string(), 0.85, "GC".to_string());
        entry1.recovery_time_ms = 100;
        db.add_entry(entry1);

        let mut entry2 = RecoveryHistoryEntry::new(2, 2000, "MemoryLeak".to_string(), 0.80, "GC".to_string());
        entry2.recovery_time_ms = 200;
        db.add_entry(entry2);

        let avg_time = db.get_average_recovery_time("MemoryLeak");
        assert_eq!(avg_time, 150);
    }

    #[test]
    fn test_query_by_saturation_range() {
        // 테스트 7: 포화도 범위로 검색
        let mut db = RecoveryHistoryDB::new();

        db.add_entry(RecoveryHistoryEntry::new(1, 1000, "MemoryLeak".to_string(), 0.85, "GC".to_string()));
        db.add_entry(RecoveryHistoryEntry::new(2, 2000, "MemoryLeak".to_string(), 0.75, "GC".to_string()));
        db.add_entry(RecoveryHistoryEntry::new(3, 3000, "MemoryLeak".to_string(), 0.65, "GC".to_string()));

        let high_saturation = db.query_by_saturation_range(0.80, 0.90);
        assert_eq!(high_saturation.len(), 1);

        let medium_saturation = db.query_by_saturation_range(0.70, 0.80);
        assert_eq!(medium_saturation.len(), 1);
    }

    #[test]
    fn test_successful_vs_failed_queries() {
        // 테스트 8: 성공/실패 분리 검색
        let mut db = RecoveryHistoryDB::new();

        let mut entry1 = RecoveryHistoryEntry::new(1, 1000, "MemoryLeak".to_string(), 0.85, "GC".to_string());
        entry1.success = true;
        db.add_entry(entry1);

        let mut entry2 = RecoveryHistoryEntry::new(2, 2000, "MemoryLeak".to_string(), 0.80, "GC".to_string());
        entry2.success = false;
        db.add_entry(entry2);

        let successful = db.query_successful_only();
        let failed = db.query_failed_only();

        assert_eq!(successful.len(), 1);
        assert_eq!(failed.len(), 1);
    }

    #[test]
    fn test_pattern_statistics() {
        // 테스트 9: 패턴 통계 계산
        let mut db = RecoveryHistoryDB::new();

        let mut entry1 = RecoveryHistoryEntry::new(1, 1000, "MemoryLeak".to_string(), 0.90, "GC".to_string());
        entry1.complete_recovery(0.60, 150, true);
        db.add_entry(entry1);

        let mut entry2 = RecoveryHistoryEntry::new(2, 2000, "MemoryLeak".to_string(), 0.85, "GC".to_string());
        entry2.complete_recovery(0.65, 100, true);
        db.add_entry(entry2);

        let stats = db.get_pattern_statistics("MemoryLeak");
        assert_eq!(stats.total_occurrences, 2);
        assert_eq!(stats.success_count, 2);
        assert_eq!(stats.failure_count, 0);
        assert_eq!(stats.success_rate, 1.0);
        assert_eq!(stats.average_recovery_time_ms, 125);
    }

    #[test]
    fn test_max_entries_enforcement() {
        // 테스트 10: 최대 엔트리 수 제한 (1,000개)
        let mut db = RecoveryHistoryDB::new();
        db.max_entries = 10;  // 테스트용 작은 값

        for i in 0..15 {
            db.add_entry(RecoveryHistoryEntry::new(
                i,
                1000 + i as u64 * 100,
                "MemoryLeak".to_string(),
                0.75,
                "GC".to_string(),
            ));
        }

        // 최대값을 초과하면 가장 오래된 항목이 제거되어야 함
        assert_eq!(db.get_entry_count(), 10);
        // 첫 5개는 제거되고, 6-15가 남아야 함
        assert!(db.get_entry(6).is_some());
        assert!(db.get_entry(15).is_some());
    }
}

