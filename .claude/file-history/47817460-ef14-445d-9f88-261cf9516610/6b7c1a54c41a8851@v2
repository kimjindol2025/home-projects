// ============================================================================
// Day 8-9: Scenario 1 - Tail Latency Under Load
// ============================================================================
// Real-world pattern: High load → P99 latency spike → Context switch overhead
// Timeline:
//   T-5s:   Baseline: P99 = 10ms, load = 100 req/s
//   T-0s:   LatencySpike(300ms) injected
//   T+10s:  P99 becomes 150ms (15x), detected by Phase H
//   T+20s:  Policy: reduce_batch_size applied
//   T+60s:  P99 recovers to 30ms
//   T+90s:  Decision: keep policy
//   T+100s: Scenario ends

pub struct TailLatencyScenario {
    // Identifiers
    scenario_id: String,
    scenario_name: String,

    // Timeline
    start_time_us: u64,
    current_time_us: u64,
    expected_duration_ms: u32,

    // Baseline metrics (pre-fault)
    baseline_p99_latency_us: u64,      // 10,000 µs = 10ms
    baseline_avg_latency_us: u64,      // 5,000 µs = 5ms
    baseline_request_rate: u32,        // 100 req/s
    baseline_context_switches: u32,    // 500 cs/s

    // Fault parameters
    injected_latency_spike_ms: u64,    // 300ms
    injected_load_multiplier: f64,     // 2.0x (200 req/s)

    // Current metrics (during fault)
    current_p99_latency_us: u64,
    current_avg_latency_us: u64,
    current_request_rate: u32,
    current_context_switches: u32,

    // Phases
    phase: String,                     // "baseline", "fault", "recovery"
    fault_injected: bool,
    policies_applied: Vec<String>,
    detected_failures: Vec<String>,

    // Success metrics
    slo_violations_detected: u32,      // Should be > 0
    phase_h_response_latency_us: u64,  // Time to detect + decide policy
    improvement_percent: f64,          // (baseline - current) / baseline * 100
}

impl TailLatencyScenario {
    pub fn new(scenario_id: String) -> Self {
        Self {
            scenario_id: scenario_id.clone(),
            scenario_name: "Tail Latency Under Load".to_string(),
            start_time_us: 0,
            current_time_us: 0,
            expected_duration_ms: 100,

            baseline_p99_latency_us: 10_000,      // 10ms
            baseline_avg_latency_us: 5_000,       // 5ms
            baseline_request_rate: 100,           // 100 req/s
            baseline_context_switches: 500,       // 500 cs/s

            injected_latency_spike_ms: 300,       // 300ms spike
            injected_load_multiplier: 2.0,        // 2x load

            current_p99_latency_us: 10_000,
            current_avg_latency_us: 5_000,
            current_request_rate: 100,
            current_context_switches: 500,

            phase: "baseline".to_string(),
            fault_injected: false,
            policies_applied: vec![],
            detected_failures: vec![],

            slo_violations_detected: 0,
            phase_h_response_latency_us: 0,
            improvement_percent: 0.0,
        }
    }

    /// Setup: Record baseline metrics, establish SLO
    pub fn setup(&mut self, scenario_handle: &ScenarioHandle) -> bool {
        self.start_time_us = scenario_handle.start_time_us;
        self.phase = "baseline".to_string();

        // Verify baseline state
        if self.baseline_p99_latency_us == 0 || self.baseline_request_rate == 0 {
            return false;
        }

        true
    }

    /// Execute: Inject LatencySpike, simulate Phase H response
    pub fn execute(&mut self, injector: &mut FaultInjector, elapsed_ms: u32) -> Vec<SLOViolation> {
        self.current_time_us = self.start_time_us + (elapsed_ms as u64) * 1000;
        let mut violations = vec![];

        // T-5s to T-0s: Baseline phase
        if elapsed_ms < 5_000 {
            self.phase = "baseline".to_string();
            self.current_p99_latency_us = self.baseline_p99_latency_us;
            self.current_request_rate = self.baseline_request_rate;
            return violations;
        }

        // T-0s: Inject LatencySpike(300ms) + 2x load
        if elapsed_ms == 5_000 && !self.fault_injected {
            let fault_type = FaultType::LatencySpike(self.injected_latency_spike_ms);
            let _fault_id = injector.inject_fault(
                fault_type,
                self.injected_latency_spike_ms as u32,
                self.current_time_us,
            );

            self.fault_injected = true;
            self.phase = "fault".to_string();
            self.current_request_rate = (self.baseline_request_rate as f64 * self.injected_load_multiplier) as u32;
        }

        // T+1s to T+10s: Fault active phase (P99 increases)
        if elapsed_ms >= 5_000 && elapsed_ms < 15_000 && self.fault_injected {
            // Simulate metric degradation: LatencySpike(300ms) → P99 +150%
            self.current_p99_latency_us = self.baseline_p99_latency_us +
                (self.baseline_p99_latency_us * 150) / 100;  // 10ms + 15ms = 25ms

            // But actually with 2x load, P99 can spike higher
            self.current_p99_latency_us = self.baseline_p99_latency_us * 15;  // Spike to 150ms

            // Context switches increase due to scheduler queue
            self.current_context_switches = self.baseline_context_switches +
                (self.baseline_context_switches * 250) / 100;  // +2.5x = 1,750 cs/s
        }

        // T+10s: Phase H detects SLO violation (P99 > 30ms threshold)
        if elapsed_ms == 10_000 {
            let slo_threshold = 30_000;  // 30ms threshold
            if self.current_p99_latency_us > slo_threshold {
                self.slo_violations_detected += 1;

                // Phase H detection latency: should complete in ~100-200ms
                self.phase_h_response_latency_us = 150_000;  // 150ms
            }
        }

        // T+20s: Phase H decides and executes policy: reduce_batch_size
        if elapsed_ms == 20_000 && self.slo_violations_detected > 0 {
            self.policies_applied.push("reduce_batch_size".to_string());
            self.detected_failures.push("LatencySpike detected (P99: 150ms > threshold: 30ms)".to_string());
            self.phase = "recovery".to_string();
        }

        // T+30s to T+60s: Recovery phase (P99 decreases as batch size reduced)
        if elapsed_ms >= 20_000 && elapsed_ms < 60_000 && !self.policies_applied.is_empty() {
            // Policy reduces batch size → lower scheduler queue → P99 improves
            let progress = (elapsed_ms - 20_000) as f64 / 40_000.0;  // 0.0 to 1.0

            // Recovery curve: exponential approach to baseline
            let target = self.baseline_p99_latency_us + 20_000;  // Intermediate target: 30ms
            self.current_p99_latency_us = self.baseline_p99_latency_us +
                ((target - self.baseline_p99_latency_us) as f64 * (1.0 - progress)) as u64;
        }

        // T+60s: Calculate improvement metric
        if elapsed_ms >= 60_000 {
            let improvement_us = if self.current_p99_latency_us < self.baseline_p99_latency_us * 10 {
                self.baseline_p99_latency_us * 15 - self.current_p99_latency_us
            } else {
                0
            };
            self.improvement_percent = (improvement_us as f64 / (self.baseline_p99_latency_us as f64 * 15.0)) * 100.0;
        }

        violations
    }

    /// Verify: Check success criteria
    pub fn verify(&self) -> bool {
        // Success criteria:
        // 1. SLO violation detected
        // 2. Policy applied within expected timeframe
        // 3. Improvement measured
        // 4. Final P99 < 50ms

        let criterion_1 = self.slo_violations_detected > 0;
        let criterion_2 = !self.policies_applied.is_empty();
        let criterion_3 = self.improvement_percent > 20.0;
        let criterion_4 = self.current_p99_latency_us < 50_000;

        criterion_1 && criterion_2 && criterion_3 && criterion_4
    }

    /// Get summary report
    pub fn get_report(&self) -> String {
        format!(
            "Scenario: {}\n\
             Phase: {}\n\
             Baseline P99: {} µs\n\
             Current P99: {} µs\n\
             SLO Violations: {}\n\
             Policies Applied: {:?}\n\
             Improvement: {:.1}%\n\
             Success: {}",
            self.scenario_name,
            self.phase,
            self.baseline_p99_latency_us,
            self.current_p99_latency_us,
            self.slo_violations_detected,
            self.policies_applied,
            self.improvement_percent,
            self.verify()
        )
    }
}

// ============================================================================
// Tests: Day 8-9 Scenario 1
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_tail_latency_scenario_setup() {
        // Test 1: Verify scenario initializes with correct baseline
        let mut scenario = TailLatencyScenario::new("tail-latency-001".to_string());

        assert_eq!(scenario.baseline_p99_latency_us, 10_000);
        assert_eq!(scenario.baseline_request_rate, 100);
        assert_eq!(scenario.phase, "baseline");
        assert!(!scenario.fault_injected);
    }

    #[test]
    fn test_tail_latency_fault_injection() {
        // Test 2: Verify fault injection causes metric degradation
        let mut scenario = TailLatencyScenario::new("tail-latency-002".to_string());

        // Create dummy FaultInjector
        let mut injector = FaultInjector::new();

        // Simulate execution at T-0s (fault injection point)
        scenario.execute(&mut injector, 5_000);
        assert!(scenario.fault_injected);

        // Simulate execution at T+10s (fault active, P99 spike expected)
        scenario.execute(&mut injector, 10_000);
        assert!(scenario.current_p99_latency_us > scenario.baseline_p99_latency_us * 5);
    }

    #[test]
    fn test_tail_latency_phase_h_integration() {
        // Test 3: Verify Phase H integration (detection, policy, recovery)
        let mut scenario = TailLatencyScenario::new("tail-latency-003".to_string());
        let mut injector = FaultInjector::new();

        // T-0s: Inject fault
        scenario.execute(&mut injector, 5_000);

        // T+10s: Detect violation
        scenario.execute(&mut injector, 10_000);
        assert!(scenario.slo_violations_detected > 0);

        // T+20s: Policy applied
        scenario.execute(&mut injector, 20_000);
        assert!(!scenario.policies_applied.is_empty());

        // T+60s: Recovery
        scenario.execute(&mut injector, 60_000);
        assert!(scenario.improvement_percent > 0.0);

        // Verify success
        assert!(scenario.verify());
    }
}

