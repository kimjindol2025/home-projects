// Test infrastructure
struct ConcurrentTest {
    name: string,
    passed: bool,
    message: string,
}

struct ConcurrentTestSuite {
    tests: vector,
    passed_count: u32,
    total_count: u32,
}

fn create_concurrent_test_suite() -> ConcurrentTestSuite {
    ConcurrentTestSuite {
        tests: [],
        passed_count: 0,
        total_count: 0,
    }
}

fn run_concurrent_test(suite: &ConcurrentTestSuite, name: string, condition: bool, message: string) {
    let test = ConcurrentTest {
        name: name,
        passed: condition,
        message: message,
    };

    suite.tests.push(test);

    if (condition) {
        suite.passed_count = suite.passed_count + 1;
        print(\"  ✅ \" + name);
    } else {
        print(\"  ❌ \" + name + \": \" + message);
    };

    suite.total_count = suite.total_count + 1;
}

fn print_concurrent_summary(suite: ConcurrentTestSuite) {
    print(\"\");
    print(\"═══════════════════════════════════════════\");
    print(\"📊 Concurrent GC Test Summary\");
    print(\"═══════════════════════════════════════════\");
    print(\"Passed: \" + suite.passed_count + \" / \" + suite.total_count);
    print(\"Success Rate: \" + ((suite.passed_count as f64) / (suite.total_count as f64) * 100.0) + \"%\");
    print(\"═══════════════════════════════════════════\");
}

