#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_proactive_action_definitions() {
        // 테스트 1: 조치 정의 확인
        let action = ProactiveAction::AggressiveGC;
        assert_eq!(action.to_string(), "AggressiveGC");
        assert!(action.minimum_confidence() >= 0.6 && action.minimum_confidence() <= 0.95);

        let (improvement, memory) = action.impact_estimate();
        assert!(improvement >= 0.0 && improvement <= 0.3);
    }

    #[test]
    fn test_scheduled_action_lifecycle() {
        // 테스트 2: 스케줄된 조치 생명주기
        let mut action = ScheduledAction::new(ProactiveAction::CachePreemption, 2000, 0.80);

        assert!(!action.executed);
        assert!(action.is_due(2000));
        assert!(!action.is_due(1999));

        action.execute(2050);
        assert!(action.executed);
        assert_eq!(action.execution_timestamp, 2050);
    }

    #[test]
    fn test_action_scheduler_confidence_filter() {
        // 테스트 3: 신뢰도 필터링
        let mut scheduler = ActionScheduler::new();

        // 신뢰도 불충분: 실패해야 함
        let result = scheduler.schedule_action(
            ProactiveAction::EmergencyShutdownPrep,  // 최소 신뢰도 0.90
            1000,
            0.80,  // 신뢰도 0.80 < 0.90
        );
        assert!(!result);

        // 신뢰도 충분: 성공해야 함
        let result = scheduler.schedule_action(
            ProactiveAction::AggressiveGC,  // 최소 신뢰도 0.70
            1000,
            0.75,  // 신뢰도 0.75 > 0.70
        );
        assert!(result);
    }

    #[test]
    fn test_action_scheduler_execution_queue() {
        // 테스트 4: 실행 큐
        let mut scheduler = ActionScheduler::new();

        scheduler.schedule_action(ProactiveAction::AggressiveGC, 1000, 0.75);
        scheduler.schedule_action(ProactiveAction::CachePreemption, 2000, 0.80);

        // 시간 1500: 첫 번째 조치만 실행 대기
        scheduler.check_and_queue_due_actions(1500);
        assert_eq!(scheduler.executed_count, 1);

        // 시간 2500: 두 번째 조치도 실행 대기
        scheduler.check_and_queue_due_actions(2500);
        assert_eq!(scheduler.executed_count, 2);
    }

    #[test]
    fn test_success_ratio_tracking() {
        // 테스트 5: 성공률 추적
        let mut tracker = SuccessRatioTracker::new();
        tracker.initialize_all_actions();

        tracker.record_execution("AggressiveGC", true, 0.05, 1000);
        tracker.record_execution("AggressiveGC", true, 0.06, 1100);
        tracker.record_execution("AggressiveGC", false, 0.0, 1200);

        let success_rate = tracker.get_success_rate("AggressiveGC");
        assert!((success_rate - 0.667).abs() < 0.01);  // 2/3 ≈ 66.7%

        let avg_improvement = tracker.get_average_improvement("AggressiveGC");
        assert!((avg_improvement - 0.055).abs() < 0.001);
    }

    #[test]
    fn test_best_action_selection() {
        // 테스트 6: 최적 조치 선택
        let mut tracker = SuccessRatioTracker::new();
        tracker.initialize_all_actions();

        // AggressiveGC: 4/5 (80%)
        for _ in 0..4 {
            tracker.record_execution("AggressiveGC", true, 0.05, 1000);
        }
        tracker.record_execution("AggressiveGC", false, 0.0, 1100);

        // CachePreemption: 3/3 (100%)
        for _ in 0..3 {
            tracker.record_execution("CachePreemption", true, 0.20, 1200);
        }

        let best = tracker.get_best_action();
        assert_eq!(best, Some("CachePreemption".to_string()));
    }

    #[test]
    fn test_proactive_dispatcher_workflow() {
        // 테스트 7: 프로액티브 디스패처 워크플로우
        let mut dispatcher = ProactiveDispatcher::new();

        // 조치 스케줄
        assert!(dispatcher.dispatch_action(ProactiveAction::AggressiveGC, 1000, 0.75));
        assert!(dispatcher.dispatch_action(ProactiveAction::BufferPoolExpansion, 1500, 0.85));

        // 시간 진행 & 조치 실행
        dispatcher.process_due_actions(1200);
        let action = dispatcher.execute_next_action();
        assert!(action.is_some());

        // 결과 기록
        dispatcher.record_action_outcome("AggressiveGC", true, 0.05, 1200);
        assert!(dispatcher.get_action_success_rate("AggressiveGC") > 0.9);
    }

    #[test]
    fn test_multiple_action_scheduling() {
        // 테스트 8: 여러 조치 스케줄
        let mut dispatcher = ProactiveDispatcher::new();

        // 5가지 조치 스케줄
        dispatcher.dispatch_action(ProactiveAction::AggressiveGC, 1000, 0.75);
        dispatcher.dispatch_action(ProactiveAction::CachePreemption, 1200, 0.80);
        dispatcher.dispatch_action(ProactiveAction::ThreadPoolAdjustment, 1400, 0.75);
        dispatcher.dispatch_action(ProactiveAction::BufferPoolExpansion, 1600, 0.85);
        dispatcher.dispatch_action(ProactiveAction::CPUAffinity, 1800, 0.70);

        // 모두 실행
        dispatcher.process_due_actions(2000);

        // 성공 기록
        for i in 0..5 {
            dispatcher.process_due_actions(1000 + i * 200 + 100);
            if let Some(action) = dispatcher.execute_next_action() {
                dispatcher.record_action_outcome(&action, true, 0.15, 1000 + i * 200 + 100);
            }
        }

        let status = dispatcher.get_status();
        assert!(status.contains("Success Ratio"));
    }
}

