#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_performance_metric_creation() {
        let metric = PerformanceMetric::new(
            "TestComponent".to_string(),
            "test_op".to_string()
        );
        assert_eq!(metric.execution_time_us, 0);
        assert_eq!(metric.memory_peak_bytes, 0);
    }

    #[test]
    fn test_throughput_calculation() {
        let mut metric = PerformanceMetric::new(
            "TestComponent".to_string(),
            "test_op".to_string()
        );
        metric.execution_time_us = 1000000;  // 1 second
        metric.iterations = 1000;             // 1000 ops
        metric.calculate_throughput();
        assert_eq!(metric.throughput as u32, 1000);  // 1000 ops/sec
    }

    #[test]
    fn test_component_profile_analysis() {
        let mut comp = ComponentProfile::new("TestComponent".to_string());
        let mut metric = PerformanceMetric::new(
            "TestComponent".to_string(),
            "op1".to_string()
        );
        metric.execution_time_us = 100;
        metric.memory_peak_bytes = 1024 * 10;
        comp.add_metric(metric);
        comp.analyze();

        assert!(comp.avg_latency_us > 0);
    }

    #[test]
    fn test_performance_profile_creation() {
        let profile = PerformanceProfile::new(1024);
        assert_eq!(profile.components.len(), 0);
        assert_eq!(profile.total_cpu_time_ms, 0);
    }

    #[test]
    fn test_profiler_metrics_collector() {
        let mut profiler = PerformanceProfiler::new(1024);
        profiler.profile_metrics_collector();
        assert_eq!(profiler.profile.components.len(), 1);
    }

    #[test]
    fn test_profiler_all_components() {
        let mut profiler = PerformanceProfiler::new(1024);
        profiler.run_all_profiles();
        assert_eq!(profiler.profile.components.len(), 6);
    }

    #[test]
    fn test_performance_score_calculation() {
        let mut profiler = PerformanceProfiler::new(1024);
        let score = profiler.run_all_profiles();
        assert!(score >= 0.0 && score <= 100.0);
    }

    #[test]
    fn test_optimization_recommendations() {
        let mut profiler = PerformanceProfiler::new(1024);
        profiler.run_all_profiles();
        let recs = profiler.get_optimization_recommendations();
        assert!(recs.len() >= 0);
    }

    #[test]
    fn test_bottleneck_identification() {
        let mut profiler = PerformanceProfiler::new(1024);
        profiler.run_all_profiles();
        let bottleneck = profiler.profile.get_bottleneck();
        assert!(bottleneck.contains("Bottleneck"));
    }

    #[test]
    fn test_memory_intensive_identification() {
        let mut profiler = PerformanceProfiler::new(1024);
        profiler.run_all_profiles();
        let memory = profiler.profile.get_memory_intensive();
        assert!(memory.contains("Memory intensive"));
    }

    #[test]
    fn test_cpu_overhead_calculation() {
        let mut profiler = PerformanceProfiler::new(1024);
        profiler.run_all_profiles();
        assert!(profiler.profile.total_cpu_time_ms > 0);
    }
}

