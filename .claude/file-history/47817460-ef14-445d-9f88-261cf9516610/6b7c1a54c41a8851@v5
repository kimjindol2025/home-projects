// ============================================================================
// Day 10-11: Scenario 3 - I/O Bottleneck
// ============================================================================
// Real-world pattern: Disk queue saturation → cache hit drop → I/O latency spike
// Timeline:
//   T-5s:   Baseline: IO latency = 500µs, cache hit = 80%, queue depth = 10
//   T-0s:   IOSaturation(50 pending ops) injected
//   T+10s:  IO latency becomes 5ms (10x), cache hit drops to 10% (10x drop)
//   T+20s:  Policy: enable_io_queue_prioritization applied
//   T+60s:  IO latency recovers to 1ms, cache hit to 50%
//   T+90s:  Decision: keep policy
//   T+100s: Scenario ends

pub struct IOBottleneckScenario {
    // Identifiers
    scenario_id: String,
    scenario_name: String,

    // Timeline
    start_time_us: u64,
    current_time_us: u64,
    expected_duration_ms: u32,

    // Baseline metrics (pre-fault)
    baseline_io_latency_us: u64,            // 500 µs
    baseline_cache_hit_rate: f64,           // 0.8 (80%)
    baseline_io_queue_depth: u32,           // 10 pending ops
    baseline_disk_throughput_mb_s: u32,     // 200 MB/s
    baseline_read_latency_us: u64,          // 1000 µs

    // Fault parameters
    injected_queue_depth: u32,              // 50 pending ops saturation
    injected_queue_growth_rate: u32,        // 2 ops/ms

    // Current metrics (during fault)
    current_io_latency_us: u64,
    current_cache_hit_rate: f64,
    current_io_queue_depth: u32,
    current_disk_throughput_mb_s: u32,
    current_read_wait_queue: u32,           // Read queue depth tracking

    // Phases
    phase: String,                          // "baseline", "fault", "recovery"
    fault_injected: bool,
    policies_applied: Vec<String>,
    detected_failures: Vec<String>,

    // Success metrics
    slo_violations_detected: u32,           // IO latency > threshold
    cache_miss_incidents: u32,              // Count of cache miss events
    phase_h_response_latency_us: u64,
    improvement_percent: f64,
}

impl IOBottleneckScenario {
    pub fn new(scenario_id: String) -> Self {
        Self {
            scenario_id: scenario_id.clone(),
            scenario_name: "I/O Bottleneck".to_string(),
            start_time_us: 0,
            current_time_us: 0,
            expected_duration_ms: 100,

            baseline_io_latency_us: 500,           // 500 µs
            baseline_cache_hit_rate: 0.8,          // 80%
            baseline_io_queue_depth: 10,           // 10 ops
            baseline_disk_throughput_mb_s: 200,    // 200 MB/s
            baseline_read_latency_us: 1000,        // 1 ms

            injected_queue_depth: 50,              // 50 ops saturation
            injected_queue_growth_rate: 2,         // 2 ops/ms

            current_io_latency_us: 500,
            current_cache_hit_rate: 0.8,
            current_io_queue_depth: 10,
            current_disk_throughput_mb_s: 200,
            current_read_wait_queue: 0,

            phase: "baseline".to_string(),
            fault_injected: false,
            policies_applied: vec![],
            detected_failures: vec![],

            slo_violations_detected: 0,
            cache_miss_incidents: 0,
            phase_h_response_latency_us: 0,
            improvement_percent: 0.0,
        }
    }

    /// Setup: Record baseline metrics, establish SLO
    pub fn setup(&mut self, scenario_handle: &ScenarioHandle) -> bool {
        self.start_time_us = scenario_handle.start_time_us;
        self.phase = "baseline".to_string();

        // Verify baseline state
        if self.baseline_io_latency_us == 0 || self.baseline_cache_hit_rate == 0.0 {
            return false;
        }

        true
    }

    /// Execute: Inject IOSaturation, simulate Phase H response
    pub fn execute(&mut self, injector: &mut FaultInjector, elapsed_ms: u32) -> Vec<SLOViolation> {
        self.current_time_us = self.start_time_us + (elapsed_ms as u64) * 1000;
        let mut violations = vec![];

        // T-5s to T-0s: Baseline phase
        if elapsed_ms < 5_000 {
            self.phase = "baseline".to_string();
            self.current_io_latency_us = self.baseline_io_latency_us;
            self.current_cache_hit_rate = self.baseline_cache_hit_rate;
            self.current_io_queue_depth = self.baseline_io_queue_depth;
            return violations;
        }

        // T-0s: Inject IOSaturation(50 pending ops)
        if elapsed_ms == 5_000 && !self.fault_injected {
            let fault_type = FaultType::IOSaturation(self.injected_queue_depth);
            let _fault_id = injector.inject_fault(
                fault_type,
                60,  // 60ms expected duration
                self.current_time_us,
            );

            self.fault_injected = true;
            self.phase = "fault".to_string();
        }

        // T+1s to T+10s: Fault active phase (queue saturation + cache hit drop)
        if elapsed_ms >= 5_000 && elapsed_ms < 15_000 && self.fault_injected {
            // Queue depth grows: starts at 10, grows at 2 ops/ms
            let queue_growth_ms = (elapsed_ms - 5_000) as f64;
            let queue_growth_ops = (queue_growth_ms / 1000.0) * (self.injected_queue_growth_rate as f64);
            self.current_io_queue_depth = (self.baseline_io_queue_depth as f64 + queue_growth_ops) as u32;

            // Cap at saturation point
            if self.current_io_queue_depth > self.injected_queue_depth {
                self.current_io_queue_depth = self.injected_queue_depth;
            }

            // IOSaturation → IO latency +10x (queue wait dominates)
            self.current_io_latency_us = self.baseline_io_latency_us +
                (queue_growth_ms / 10_000.0) * (self.baseline_io_latency_us * 9);

            // Cap at saturation latency
            if self.current_io_latency_us > self.baseline_io_latency_us * 10 {
                self.current_io_latency_us = self.baseline_io_latency_us * 10;  // 5ms spike
            }

            // Queue saturation → cache hit drop (read cache evicted to make room)
            // Cache hit rate: 80% → drops by 70% (10x reduction)
            self.current_cache_hit_rate = self.baseline_cache_hit_rate *
                (1.0 - (queue_growth_ms / 10_000.0) * 0.875);  // 0.8 → 0.1

            // Read wait queue increases with saturation
            self.current_read_wait_queue = ((queue_growth_ms / 10_000.0) * 40.0) as u32;  // Up to 40

            // Disk throughput decreases due to queue congestion
            self.current_disk_throughput_mb_s = (self.baseline_disk_throughput_mb_s as f64 *
                (1.0 - (queue_growth_ms / 10_000.0) * 0.6)) as u32;  // 200 → 80 MB/s

            // Cache miss incidents trigger when cache hit drops
            if self.current_cache_hit_rate < 0.3 {
                self.cache_miss_incidents += 1;
            }
        }

        // T+10s: Phase H detects SLO violation (IO latency > 1ms threshold)
        if elapsed_ms == 10_000 {
            let slo_threshold_us = 1000;  // 1ms threshold
            if self.current_io_latency_us > slo_threshold_us {
                self.slo_violations_detected += 1;
                self.phase_h_response_latency_us = 150_000;  // 150ms detection latency
            }
        }

        // T+20s: Phase H decides and executes policy
        if elapsed_ms == 20_000 && self.slo_violations_detected > 0 {
            self.policies_applied.push("enable_io_queue_prioritization".to_string());
            self.detected_failures.push(
                format!("IOBottleneck detected (latency: {}µs > threshold: 1000µs)",
                    self.current_io_latency_us)
            );
            self.phase = "recovery".to_string();
        }

        // T+30s to T+60s: Recovery phase (queue drains with priority scheduling)
        if elapsed_ms >= 20_000 && elapsed_ms < 60_000 && !self.policies_applied.is_empty() {
            // Priority scheduling drains queue faster
            let progress = (elapsed_ms - 20_000) as f64 / 40_000.0;  // 0.0 to 1.0

            // Queue depth decreases
            self.current_io_queue_depth = (self.injected_queue_depth as f64 *
                (1.0 - progress * 0.8)) as u32;  // 50 → 10 ops

            // IO latency recovers
            let target_latency = self.baseline_io_latency_us * 2;  // 1ms target
            self.current_io_latency_us = (self.baseline_io_latency_us * 10) as u64 -
                (((self.baseline_io_latency_us * 10) as f64 - target_latency as f64) * progress) as u64;

            // Cache hit rate recovers as queue pressure eases
            self.current_cache_hit_rate = self.baseline_cache_hit_rate *
                (0.125 + (1.0 - progress) * 0.875);  // 0.1 → 0.8

            // Read wait queue diminishes
            self.current_read_wait_queue = (40.0 * (1.0 - progress)) as u32;

            // Disk throughput recovers
            self.current_disk_throughput_mb_s = (80 as f64 +
                (self.baseline_disk_throughput_mb_s as f64 - 80.0) * progress) as u32;  // 80 → 200 MB/s
        }

        // T+60s: Calculate improvement metric
        if elapsed_ms >= 60_000 {
            let original_spike = self.baseline_io_latency_us * 10;  // 5ms
            let improvement_us = original_spike as f64 - self.current_io_latency_us as f64;
            self.improvement_percent = (improvement_us / original_spike as f64) * 100.0;
        }

        violations
    }

    /// Verify: Check success criteria
    pub fn verify(&self) -> bool {
        // Success criteria:
        // 1. SLO violation detected
        // 2. Policy applied
        // 3. Cache miss incidents recorded
        // 4. Improvement > 20%
        // 5. Final IO latency < 2ms

        let criterion_1 = self.slo_violations_detected > 0;
        let criterion_2 = !self.policies_applied.is_empty();
        let criterion_3 = self.cache_miss_incidents > 0;
        let criterion_4 = self.improvement_percent > 20.0;
        let criterion_5 = self.current_io_latency_us < 2000;

        criterion_1 && criterion_2 && criterion_3 && criterion_4 && criterion_5
    }

    /// Get summary report
    pub fn get_report(&self) -> String {
        format!(
            "Scenario: {}\n\
             Phase: {}\n\
             Baseline IO Latency: {} µs\n\
             Current IO Latency: {} µs\n\
             Cache Hit Rate: {:.1}%\n\
             IO Queue Depth: {} ops\n\
             Read Wait Queue: {}\n\
             Disk Throughput: {} MB/s\n\
             Cache Miss Incidents: {}\n\
             SLO Violations: {}\n\
             Policies Applied: {:?}\n\
             Improvement: {:.1}%\n\
             Success: {}",
            self.scenario_name,
            self.phase,
            self.baseline_io_latency_us,
            self.current_io_latency_us,
            self.current_cache_hit_rate * 100.0,
            self.current_io_queue_depth,
            self.current_read_wait_queue,
            self.current_disk_throughput_mb_s,
            self.cache_miss_incidents,
            self.slo_violations_detected,
            self.policies_applied,
            self.improvement_percent,
            self.verify()
        )
    }
}

