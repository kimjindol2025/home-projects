    print(\"║  Tri-color Marking + Write Barriers        ║\");
    print(\"╚════════════════════════════════════════════╝\");
    print(\"\");

    let heap = create_concurrent_gc_heap();

    // Create objects
    print(\"Creating objects...\");
    let obj1 = ConcurrentObject {
        id: 1,
        size: 256,
        color: TricolorStatus.White,
        generation: GCGeneration.Young,
        marked_in_cycle: 0,
    };

    let obj2 = ConcurrentObject {
        id: 2,
        size: 256,
        color: TricolorStatus.White,
        generation: GCGeneration.Young,
        marked_in_cycle: 0,
    };

    let obj3 = ConcurrentObject {
        id: 3,
        size: 256,
        color: TricolorStatus.White,
        generation: GCGeneration.Young,
        marked_in_cycle: 0,
    };

    add_concurrent_object(&heap, obj1);
    add_concurrent_object(&heap, obj2);
    add_concurrent_object(&heap, obj3);

    print(\"Created 3 objects\");
    print(\"\");

    // Root set: [1]
    let root_ids = [1];

    // Run concurrent GC
    run_concurrent_gc_cycle(&heap, root_ids);

    print(\"\");

    // Verify safety
    verify_concurrent_safety(heap);
}

// Run example
example_concurrent_gc();
