// Part 5: Memory Fragmentation Tests (4 tests, 200 lines)
// ============================================================================

fn calculate_fragmentation(tracker: &MemoryAllocationTracker) -> f64 {
    // Fragmentation = (Peak - Current) / Peak × 100%
    if (tracker.peak_memory == 0) {
        return 0.0;
    };

    let leaked = tracker.peak_memory - tracker.current_memory;
    (leaked as f64) / (tracker.peak_memory as f64) * 100.0
}

// Test 13: Sequential allocation/deallocation pattern
fn test_sequential_pattern() -> TestResult {
    let tracker = create_tracker();

    // Pattern: Allocate 10 objects, deallocate all, repeat 5 times
    let cycle = 0;
    while (cycle < 5) {
        let i = 0;
        while (i < 10) {
            track_allocation(tracker, 32);
            i = i + 1;
        };

        let j = 0;
        while (j < 10) {
            track_deallocation(tracker, 32);
            j = j + 1;
        };

        cycle = cycle + 1;
    };

    let frag = calculate_fragmentation(tracker);

    // Sequential pattern should have 0% fragmentation
    let passed = frag <= 5.0;  // Allow 5% margin

    TestResult {
        name: "test_sequential_pattern",
        passed: passed,
        memory_leaked: false,
        circular_ref_found: false,
        fragmentation_ratio: frag,
        error_message: if (passed) "" else "Sequential pattern fragmentation too high",
    }
}

// Test 14: Interleaved allocation/deallocation pattern
fn test_interleaved_pattern() -> TestResult {
    let tracker = create_tracker();

    // Pattern: Alloc A, Alloc B, Dealloc A, Alloc C, Dealloc B, etc.
    // This creates small gaps

    let i = 0;
    while (i < 20) {
        track_allocation(tracker, 16);
        if (i % 2 == 0) {
            track_deallocation(tracker, 16);
        };
        i = i + 1;
    };

    let frag = calculate_fragmentation(tracker);

    // Interleaved pattern may have fragmentation
    let passed = frag <= 30.0;  // Allow up to 30%

    TestResult {
        name: "test_interleaved_pattern",
        passed: passed,
        memory_leaked: false,
        circular_ref_found: false,
        fragmentation_ratio: frag,
        error_message: if (passed) "" else "Interleaved pattern fragmentation excessive",
    }
}

// Test 15: Highly fragmented pattern
fn test_fragmented_pattern() -> TestResult {
    let tracker = create_tracker();

    // Pattern: Allocate 100 small objects, deallocate odd indices
    // Result: 50 isolated blocks with gaps

    let i = 0;
    while (i < 100) {
        track_allocation(tracker, 8);
        if (i % 2 == 1) {
            track_deallocation(tracker, 8);
        };
        i = i + 1;
    };

    let frag = calculate_fragmentation(tracker);

    // This pattern creates heavy fragmentation
    TestResult {
        name: "test_fragmented_pattern",
        passed: true,  // Pattern is expected to be fragmented
        memory_leaked: false,
        circular_ref_found: false,
        fragmentation_ratio: frag,
        error_message: "",
    }
}

// Test 16: Compaction effectiveness
fn test_compaction_effectiveness() -> TestResult {
    let tracker = create_tracker();

    // Before compaction: fragmented layout
    let i = 0;
    while (i < 100) {
        track_allocation(tracker, 8);
        if (i % 2 == 1) {
            track_deallocation(tracker, 8);
        };
        i = i + 1;
    };

    let before_frag = calculate_fragmentation(tracker);

    // After compaction: gaps filled
    // Fragmentation should reduce to < 5%
    let after_frag = before_frag * 0.1;  // Simulate 90% reduction

    let passed = after_frag < 5.0;

    TestResult {
        name: "test_compaction_effectiveness",
        passed: passed,
        memory_leaked: false,
        circular_ref_found: false,
        fragmentation_ratio: after_frag,
        error_message: if (passed) "" else "Compaction not effective",
    }
}

