// ============================================================================
// Week1PredictiveSystem: Week 1 전체 시스템 통합
// ============================================================================
// 역할:
// 1. Pattern Recognition: 과거 복구 패턴 인식 (6가지 타입)
// 2. Learning State Machine: 패턴 신뢰도 발전 추적 (5단계)
// 3. Pattern Database: 복구 이력 저장 & 검색 (최대 1,000개)

pub struct Week1PredictiveSystem {
    // 컴포넌트 1: 패턴 인식기
    pattern_matcher: PatternMatcher,

    // 컴포넌트 2: 학습 상태 머신
    state_machine: StateMachineManager,

    // 컴포넌트 3: 패턴 데이터베이스
    history_db: RecoveryHistoryDB,

    // 메타데이터
    system_start_time: u64,
    total_patterns_recognized: u32,
    total_recoveries_recorded: u32,
}

impl Week1PredictiveSystem {
    pub fn new() -> Week1PredictiveSystem {
        Week1PredictiveSystem {
            pattern_matcher: PatternMatcher::new(),
            state_machine: StateMachineManager::new(),
            history_db: RecoveryHistoryDB::new(),
            system_start_time: 0,
            total_patterns_recognized: 0,
            total_recoveries_recorded: 0,
        }
    }

    // ========================================================================
    // 공개 API
    // ========================================================================

    /// 메트릭 기반 패턴 감지
    pub fn detect_patterns(&mut self, metrics: &MetricsSnapshot) -> Vec<DetectedPattern> {
        let mut detected = Vec::new();

        // 6가지 패턴 감지 시도
        if let Some(confidence) = self.pattern_matcher.detect_memory_leak(metrics) {
            detected.push(DetectedPattern {
                pattern_type: "MemoryLeak".to_string(),
                confidence,
                description: "메모리 누수 감지 (포화도 지속 상승)".to_string(),
            });
            self.total_patterns_recognized += 1;
        }

        if let Some(confidence) = self.pattern_matcher.detect_io_bottleneck(metrics) {
            detected.push(DetectedPattern {
                pattern_type: "IOBottleneck".to_string(),
                confidence,
                description: "I/O 병목 감지 (ops >50k/sec)".to_string(),
            });
            self.total_patterns_recognized += 1;
        }

        if let Some(confidence) = self.pattern_matcher.detect_thread_contention(metrics) {
            detected.push(DetectedPattern {
                pattern_type: "ThreadContention".to_string(),
                confidence,
                description: "스레드 경합 감지 (CS >5M/sec)".to_string(),
            });
            self.total_patterns_recognized += 1;
        }

        if let Some(confidence) = self.pattern_matcher.detect_cache_thrashing(metrics) {
            detected.push(DetectedPattern {
                pattern_type: "CacheThreshing".to_string(),
                confidence,
                description: "캐시 쓰레싱 감지 (miss >30%)".to_string(),
            });
            self.total_patterns_recognized += 1;
        }

        if let Some(confidence) = self.pattern_matcher.detect_combined_pressure(metrics) {
            detected.push(DetectedPattern {
                pattern_type: "CombinedPressure".to_string(),
                confidence,
                description: "복합 압박 감지 (3+ 동시)".to_string(),
            });
            self.total_patterns_recognized += 1;
        }

        detected
    }

    /// 패턴 관찰 기록 및 상태 전이
    pub fn observe_pattern(
        &mut self,
        pattern_id: u32,
        pattern_type: String,
        timestamp: u64,
        evidence_confidence: f64,
    ) {
        // 상태 머신에 관찰 기록
        self.state_machine.observe_pattern(pattern_id, timestamp, evidence_confidence);
    }

    /// 복구 이력 기록
    pub fn record_recovery(
        &mut self,
        pattern_type: String,
        saturation_before: f64,
        saturation_after: f64,
        recovery_time_ms: u32,
        success: bool,
        recovery_action: String,
        timestamp: u64,
    ) {
        let mut entry = RecoveryHistoryEntry::new(
            0,
            timestamp,
            pattern_type.clone(),
            saturation_before,
            recovery_action,
        );
        entry.complete_recovery(saturation_after, recovery_time_ms, success);

        self.history_db.add_entry(entry);
        self.total_recoveries_recorded += 1;
    }

    /// 패턴의 현재 신뢰도 조회
    pub fn get_pattern_confidence(&self, pattern_id: u32) -> Option<f64> {
        self.state_machine.get_pattern_confidence(pattern_id)
    }

    /// 패턴의 학습 상태 조회
    pub fn get_pattern_state(&self, pattern_id: u32) -> Option<String> {
        self.state_machine.get_pattern_state(pattern_id)
    }

    /// 조치 가능한 패턴 목록
    pub fn get_actionable_patterns(&self) -> Vec<u32> {
        self.state_machine.get_actionable_patterns()
    }

    /// 패턴 통계 조회
    pub fn get_pattern_statistics(&self, pattern_type: &str) -> PatternStatistics {
        self.history_db.get_pattern_statistics(pattern_type)
    }

    /// 최근 복구 이력 조회
    pub fn get_recent_recoveries(&self, count: usize) -> Vec<RecoveryHistorySummary> {
        let entries = self.history_db.get_recent_entries(count);
        entries.iter().map(|e| RecoveryHistorySummary::from_entry(e)).collect()
    }

    /// 특정 패턴의 복구 이력 조회
    pub fn get_pattern_recovery_history(&self, pattern_type: &str) -> Vec<RecoveryHistorySummary> {
        let entries = self.history_db.get_entries_by_pattern_type(pattern_type);
        entries.iter().map(|e| RecoveryHistorySummary::from_entry(e)).collect()
    }

    /// 시스템 상태 조회
    pub fn get_system_status(&self) -> SystemStatus {
        SystemStatus {
            total_patterns_recognized: self.total_patterns_recognized,
            total_recoveries_recorded: self.total_recoveries_recorded,
            total_patterns_in_history: self.history_db.get_entry_count(),
            actionable_patterns: self.state_machine.get_actionable_patterns().len(),
        }
    }
}

// ============================================================================
// 데이터 구조: 외부 API 응답
// ============================================================================

pub struct DetectedPattern {
    pub pattern_type: String,
    pub confidence: f64,
    pub description: String,
}

pub struct RecoveryHistorySummary {
    pub timestamp: u64,
    pub pattern_type: String,
    pub saturation_before: f64,
    pub saturation_after: f64,
    pub recovery_time_ms: u32,
    pub success: bool,
    pub improvement_ratio: f64,
}

impl RecoveryHistorySummary {
    fn from_entry(entry: &RecoveryHistoryEntry) -> RecoveryHistorySummary {
        RecoveryHistorySummary {
            timestamp: entry.timestamp,
            pattern_type: entry.pattern_type.clone(),
            saturation_before: entry.saturation_before,
            saturation_after: entry.saturation_after,
            recovery_time_ms: entry.recovery_time_ms,
            success: entry.success,
            improvement_ratio: entry.improvement_ratio(),
        }
    }
}

pub struct SystemStatus {
    pub total_patterns_recognized: u32,
    pub total_recoveries_recorded: u32,
    pub total_patterns_in_history: usize,
    pub actionable_patterns: usize,
}

