#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_reallocator_creation() {
        let reallocator = ResourceReallocator::new(ReallocationStrategy::Moderate);
        assert_eq!(reallocator.total_recovered, 0);
        assert_eq!(reallocator.reallocations.len(), 0);
    }

    #[test]
    fn test_cache_evict() {
        let mut reallocator = ResourceReallocator::new(ReallocationStrategy::Moderate);

        let result = reallocator.execute_cache_evict(100 * 1024 * 1024, 0.20);  // 100MB cache, 20% evict

        assert_eq!(result.recovered_bytes, 20 * 1024 * 1024);
        assert!(result.recovery_percent > 19.0 && result.recovery_percent < 21.0);
    }

    #[test]
    fn test_thread_reduction() {
        let mut reallocator = ResourceReallocator::new(ReallocationStrategy::Moderate);

        let result = reallocator.execute_thread_reduction(64, 32);  // 64 → 32 threads

        assert_eq!(result.recovered_bytes, 32 * 2 * 1024 * 1024);  // 32 threads × 2MB
        assert_eq!(result.execution_time_ms, 100);
    }

    #[test]
    fn test_buffer_shrink() {
        let mut reallocator = ResourceReallocator::new(ReallocationStrategy::Moderate);

        let result = reallocator.execute_buffer_shrink(200 * 1024 * 1024, 0.25);  // 50MB shrink

        assert!(result.recovered_bytes > 0);
        assert!(result.recovery_percent > 24.0 && result.recovery_percent < 26.0);
    }

    #[test]
    fn test_priority_adjustment() {
        let mut reallocator = ResourceReallocator::new(ReallocationStrategy::Moderate);

        let result = reallocator.execute_priority_adjustment(4, 8);

        assert!(result.recovered_bytes > 0);
        assert_eq!(result.execution_time_ms, 20);
    }

    #[test]
    fn test_execute_action_suspend() {
        let mut reallocator = ResourceReallocator::new(ReallocationStrategy::Moderate);

        let snapshot = ResourceSnapshot {
            timestamp: 1000,
            total_memory: 1024 * 1024 * 1024,  // 1GB
            used_memory: 900 * 1024 * 1024,   // 900MB
            cache_size: 200 * 1024 * 1024,    // 200MB
            thread_count: 64,
            buffer_size: 100 * 1024 * 1024,   // 100MB
        };

        let results = reallocator.execute_action(
            RecommendedAction::SuspendNonCritical,
            &snapshot
        );

        assert!(results.len() > 0);
        assert!(reallocator.total_recovered > 0);
    }

    #[test]
    fn test_total_recovery() {
        let mut reallocator = ResourceReallocator::new(ReallocationStrategy::Moderate);

        let snapshot = ResourceSnapshot {
            timestamp: 1000,
            total_memory: 1024 * 1024 * 1024,
            used_memory: 900 * 1024 * 1024,
            cache_size: 200 * 1024 * 1024,
            thread_count: 64,
            buffer_size: 100 * 1024 * 1024,
        };

        reallocator.execute_action(RecommendedAction::EvictCaches, &snapshot);

        let recovery_percent = reallocator.get_total_recovery_percent(snapshot.total_memory);
        assert!(recovery_percent > 0.0);
    }

    #[test]
    fn test_recovery_stats() {
        let mut reallocator = ResourceReallocator::new(ReallocationStrategy::Moderate);

        let snapshot = ResourceSnapshot {
            timestamp: 1000,
            total_memory: 1024 * 1024 * 1024,
            used_memory: 900 * 1024 * 1024,
            cache_size: 200 * 1024 * 1024,
            thread_count: 64,
            buffer_size: 100 * 1024 * 1024,
        };

        reallocator.execute_action(RecommendedAction::SuspendNonCritical, &snapshot);

        let stats = reallocator.get_recovery_stats();
        assert!(stats.total_reallocations > 0);
    }
}

