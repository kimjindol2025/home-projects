#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_alert_manager_creation() {
        let manager = AlertManager::new();
        assert_eq!(manager.pending_alerts(), 0);
        assert!(manager.suppression_enabled);
    }

    #[test]
    fn test_threshold_default() {
        let thresholds = AlertThreshold::default();
        assert_eq!(thresholds.info_level, 0.75);
        assert_eq!(thresholds.warning_level, 0.85);
        assert_eq!(thresholds.critical_level, 0.95);
        assert_eq!(thresholds.emergency_level, 0.99);
    }

    #[test]
    fn test_check_threshold_info() {
        let manager = AlertManager::new();
        let level = manager.check_threshold(0.76);

        match level {
            AlertLevel::Info => assert!(true),
            _ => assert!(false),
        }
    }

    #[test]
    fn test_check_threshold_warning() {
        let manager = AlertManager::new();
        let level = manager.check_threshold(0.87);

        match level {
            AlertLevel::Warning => assert!(true),
            _ => assert!(false),
        }
    }

    #[test]
    fn test_check_threshold_critical() {
        let manager = AlertManager::new();
        let level = manager.check_threshold(0.96);

        match level {
            AlertLevel::Critical => assert!(true),
            _ => assert!(false),
        }
    }

    #[test]
    fn test_check_threshold_emergency() {
        let manager = AlertManager::new();
        let level = manager.check_threshold(0.99);

        match level {
            AlertLevel::Emergency => assert!(true),
            _ => assert!(false),
        }
    }

    #[test]
    fn test_alert_message_generation() {
        let manager = AlertManager::new();
        let msg = manager.generate_alert_message(&AlertLevel::Critical, 0.95);

        assert!(msg.contains("CRITICAL"));
        assert!(msg.contains("95%"));
    }

    #[test]
    fn test_handler_registration() {
        let mut manager = AlertManager::new();

        let handler = |_event: &AlertEvent| -> bool {
            true
        };

        manager.register_handler(handler);
        assert_eq!(manager.handlers.len(), 1);
    }

    #[test]
    fn test_alert_delivery() {
        let mut manager = AlertManager::new();

        let delivered = manager.deliver_alert(
            AlertLevel::Critical,
            0.96,
            1000
        );

        assert!(delivered || !delivered);  // 둘 다 가능
    }

    #[test]
    fn test_alert_queue() {
        let mut manager = AlertManager::new();

        manager.deliver_alert(AlertLevel::Warning, 0.85, 1000);
        manager.deliver_alert(AlertLevel::Critical, 0.96, 1100);

        assert!(manager.pending_alerts() > 0);
    }

    #[test]
    fn test_alert_strategy_aggressive() {
        let thresholds = AlertStrategy::Aggressive.get_thresholds();
        assert_eq!(thresholds.info_level, 0.60);
        assert_eq!(thresholds.warning_level, 0.75);
    }

    #[test]
    fn test_alert_stats() {
        let mut manager = AlertManager::new();

        manager.deliver_alert(AlertLevel::Warning, 0.85, 1000);
        manager.deliver_alert(AlertLevel::Critical, 0.96, 1100);

        let stats = manager.get_stats();
        assert!(stats.total_alerts > 0);
    }
}

