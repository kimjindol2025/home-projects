use super::metrics_collector::*;
use super::pressure_monitor::*;

// AlertThreshold: 임계값 정의
struct AlertThreshold {
    info_level: f64,          // 75% - 정보성
    warning_level: f64,       // 85% - 경고
    critical_level: f64,      // 95% - 심각
    emergency_level: f64,     // 99% - 긴급
}

impl AlertThreshold {
    fn default() -> AlertThreshold {
        AlertThreshold {
            info_level: 0.75,
            warning_level: 0.85,
            critical_level: 0.95,
            emergency_level: 0.99,
        }
    }

    fn custom(info: f64, warn: f64, crit: f64, emer: f64) -> AlertThreshold {
        AlertThreshold {
            info_level: info,
            warning_level: warn,
            critical_level: crit,
            emergency_level: emer,
        }
    }
}

// AlertEvent: 알람 이벤트
struct AlertEvent {
    timestamp: u64,
    alert_level: AlertLevel,
    saturation: f64,
    message: String,
    action_taken: bool,
}

// AlertHandler: 알람 처리 함수 타입
type AlertHandler = fn(event: &AlertEvent) -> bool;

// ============================================================================
// AlertManager: 알람 관리 엔진
// ============================================================================

struct AlertManager {
    thresholds: AlertThreshold,
    handlers: Vec<AlertHandler>,
    alert_queue: Vec<AlertEvent>,
    max_queue_size: usize,
    delivery_reliability: f64,  // 0.0-1.0 (알람 전달 신뢰성)
    suppression_enabled: bool,   // 같은 레벨 반복 알람 억제
    last_alert_time: u64,        // 마지막 알람 시간
    min_alert_interval_ms: u32,  // 최소 알람 간격
}

impl AlertManager {
    // 초기화
    fn new() -> AlertManager {
        AlertManager {
            thresholds: AlertThreshold::default(),
            handlers: Vec::new(),
            alert_queue: Vec::new(),
            max_queue_size: 10000,
            delivery_reliability: 0.999,  // 99.9% 신뢰성
            suppression_enabled: true,
            last_alert_time: 0,
            min_alert_interval_ms: 100,
        }
    }

    // 임계값 설정
    fn set_thresholds(&mut self, thresholds: AlertThreshold) {
        self.thresholds = thresholds;
    }

    // 알람 핸들러 등록
    fn register_handler(&mut self, handler: AlertHandler) {
        self.handlers.push(handler);
    }

    // 임계값 초과 확인
    fn check_threshold(&self, saturation: f64) -> AlertLevel {
        if saturation >= self.thresholds.emergency_level {
            AlertLevel::Emergency
        } else if saturation >= self.thresholds.critical_level {
            AlertLevel::Critical
        } else if saturation >= self.thresholds.warning_level {
            AlertLevel::Warning
        } else if saturation >= self.thresholds.info_level {
            AlertLevel::Info
        } else {
            AlertLevel::Info
        }
    }

    // 알람 생성 및 전달
    fn deliver_alert(&mut self,
        alert_level: AlertLevel,
        saturation: f64,
        timestamp: u64) -> bool {

        // 억제 확인
        if self.suppression_enabled {
            if !self.should_deliver(&alert_level, timestamp) {
                return false;
            }
        }

        // 알람 메시지 생성
        let message = self.generate_alert_message(&alert_level, saturation);

        // 알람 이벤트 생성
        let mut event = AlertEvent {
            timestamp,
            alert_level,
            saturation,
            message,
            action_taken: false,
        };

        // 신뢰성 기반 전달 확인
        if !self.reliable_deliver(&event) {
            return false;
        }

        // 모든 핸들러 실행
        let mut any_handled = false;
        for handler in &self.handlers {
            let handled = handler(&event);
            if handled {
                event.action_taken = true;
                any_handled = true;
            }
        }

        // 큐에 추가
        self.alert_queue.push(event);

        // 큐 크기 제한
        if self.alert_queue.len() > self.max_queue_size {
            self.alert_queue.remove(0);
        }

        self.last_alert_time = timestamp;
        any_handled
    }

    // 전달 여부 판정 (억제)
    fn should_deliver(&self, level: &AlertLevel, timestamp: u64) -> bool {
        let time_since_last = timestamp - self.last_alert_time;

        // 최소 간격 충족 확인
        if time_since_last < (self.min_alert_interval_ms as u64) {
            return false;
        }

        true
    }

    // 신뢰성 기반 전달
    fn reliable_deliver(&self, event: &AlertEvent) -> bool {
        // 시뮬레이션: delivery_reliability 확률로 전달
        // 실제 구현에서는 재시도 로직 등이 포함됨
        true  // 현재는 항상 전달
    }

    // 알람 메시지 생성
    fn generate_alert_message(&self, level: &AlertLevel, saturation: f64) -> String {
        let level_str = match level {
            AlertLevel::Info => "INFO",
            AlertLevel::Warning => "WARNING",
            AlertLevel::Critical => "CRITICAL",
            AlertLevel::Emergency => "EMERGENCY",
        };

        let percent = (saturation * 100.0) as u32;
        format!("{}: Memory saturation at {}%", level_str, percent)
    }

    // 알람 큐 조회
    fn peek_alert(&self) -> Option<&AlertEvent> {
        self.alert_queue.last()
    }

    // 알람 큐에서 제거
    fn pop_alert(&mut self) -> Option<AlertEvent> {
        if self.alert_queue.is_empty() {
            None
        } else {
            Some(self.alert_queue.remove(0))
        }
    }

    // 대기 중인 알람 수
    fn pending_alerts(&self) -> usize {
        self.alert_queue.len()
    }

    // 알람 통계
    fn get_stats(&self) -> AlertStats {
        let mut info_count = 0;
        let mut warning_count = 0;
        let mut critical_count = 0;
        let mut emergency_count = 0;
        let mut actions_taken = 0;

        for event in &self.alert_queue {
            match event.alert_level {
                AlertLevel::Info => info_count += 1,
                AlertLevel::Warning => warning_count += 1,
                AlertLevel::Critical => critical_count += 1,
                AlertLevel::Emergency => emergency_count += 1,
            }

            if event.action_taken {
                actions_taken += 1;
            }
        }

        AlertStats {
            total_alerts: self.alert_queue.len(),
            info_alerts: info_count,
            warning_alerts: warning_count,
            critical_alerts: critical_count,
            emergency_alerts: emergency_count,
            actions_taken,
        }
    }

    // 억제 활성화/비활성화
    fn set_suppression(&mut self, enabled: bool) {
        self.suppression_enabled = enabled;
    }

    // 최소 알람 간격 설정
    fn set_min_alert_interval(&mut self, interval_ms: u32) {
        self.min_alert_interval_ms = interval_ms;
    }

    // 전달 신뢰성 설정
    fn set_delivery_reliability(&mut self, reliability: f64) {
        self.delivery_reliability = clamp(reliability, 0.0, 1.0);
    }

    // 알람 큐 초기화
    fn clear_queue(&mut self) {
        self.alert_queue.clear();
    }
}

// AlertStats: 알람 통계
struct AlertStats {
    total_alerts: usize,
    info_alerts: usize,
    warning_alerts: usize,
    critical_alerts: usize,
    emergency_alerts: usize,
    actions_taken: usize,
}

// ============================================================================
// AlertStrategy: 알람 전략
// ============================================================================

enum AlertStrategy {
    Aggressive,    // 모든 임계값 변화에 알람
    Moderate,      // 주요 변화만 알람
    Conservative,  // 심각한 변화만 알람
}

impl AlertStrategy {
    fn get_thresholds(&self) -> AlertThreshold {
        match self {
            AlertStrategy::Aggressive => {
                AlertThreshold::custom(0.60, 0.75, 0.90, 0.98)
            },
            AlertStrategy::Moderate => {
                AlertThreshold::custom(0.75, 0.85, 0.95, 0.99)
            },
            AlertStrategy::Conservative => {
                AlertThreshold::custom(0.85, 0.92, 0.97, 0.99)
            },
        }
    }
}

// ============================================================================
// 헬퍼 함수
// ============================================================================

fn clamp(value: f64, min: f64, max: f64) -> f64 {
    if value < min {
        min
    } else if value > max {
        max
    } else {
        value
    }
}

