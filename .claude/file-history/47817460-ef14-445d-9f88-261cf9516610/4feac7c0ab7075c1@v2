#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_node_info_creation_and_health() {
        // 테스트 1: 노드 정보 생성 및 건강도 확인
        let mut node = NodeInfo::new(1, "Node-1".to_string(), "127.0.0.1".to_string(), 8080);
        node.last_heartbeat = 5000;

        assert!(node.is_healthy(10000));  // 5초 차이
        assert!(!node.is_healthy(40000)); // 35초 차이 (임계값 30초)
    }

    #[test]
    fn test_peer_discovery() {
        // 테스트 2: 노드 발견 및 등록
        let mut discovery = PeerDiscovery::new();

        let node1 = NodeInfo::new(1, "Node-1".to_string(), "127.0.0.1".to_string(), 8080);
        let node2 = NodeInfo::new(2, "Node-2".to_string(), "127.0.0.2".to_string(), 8081);

        assert!(discovery.register_peer(node1));
        assert!(discovery.register_peer(node2));
        assert_eq!(discovery.get_peer_count(), 2);

        // 중복 등록 방지
        let node1_dup = NodeInfo::new(1, "Node-1-Dup".to_string(), "127.0.0.1".to_string(), 8080);
        assert!(!discovery.register_peer(node1_dup));
    }

    #[test]
    fn test_peer_health_filtering() {
        // 테스트 3: 건강한 피어 필터링
        let mut discovery = PeerDiscovery::new();

        let mut node1 = NodeInfo::new(1, "Node-1".to_string(), "127.0.0.1".to_string(), 8080);
        let mut node2 = NodeInfo::new(2, "Node-2".to_string(), "127.0.0.2".to_string(), 8081);

        node1.last_heartbeat = 5000;
        node2.last_heartbeat = 35000;  // 30초 이상 지남

        discovery.register_peer(node1);
        discovery.register_peer(node2);

        let healthy = discovery.get_healthy_peers(10000);
        assert_eq!(healthy.len(), 1);  // Node-1만 건강함
    }

    #[test]
    fn test_pattern_sharing() {
        // 테스트 4: 패턴 공유
        let mut manager = PatternSharingManager::new();

        let pattern1 = SharedPattern::new(
            1,
            "MemoryLeak".to_string(),
            1,
            0.85,
            10,
            0.90,
            5000,
        );

        assert!(manager.share_pattern(pattern1));
        assert_eq!(manager.pattern_count(), 1);

        // 중복 방지
        let pattern1_dup = SharedPattern::new(1, "MemoryLeak".to_string(), 1, 0.85, 10, 0.90, 5000);
        assert!(!manager.share_pattern(pattern1_dup));
    }

    #[test]
    fn test_pattern_freshness() {
        // 테스트 5: 패턴 신선도
        let pattern = SharedPattern::new(1, "MemoryLeak".to_string(), 1, 0.85, 10, 0.90, 5000);

        assert!(pattern.is_fresh(10000));      // 5초 경과
        assert!(pattern.is_fresh(600000));     // 595초 경과 (임계값 600초)
        assert!(!pattern.is_fresh(610000));    // 605초 경과
    }

    #[test]
    fn test_consensus_voting() {
        // 테스트 6: 합의 투표
        let mut engine = ConsensusLearningEngine::new();

        engine.initiate_vote(1, "MemoryLeak".to_string());
        engine.add_vote(1, 1, 0.80);
        engine.add_vote(1, 2, 0.85);
        engine.add_vote(1, 3, 0.90);

        let completed = engine.check_consensus();

        // 3개 노드 합의 도달
        assert!(completed.len() > 0 || engine.active_vote_count() > 0);
    }

    #[test]
    fn test_consensus_agreement_level() {
        // 테스트 7: 합의 수준 계산
        let mut engine = ConsensusLearningEngine::new();

        engine.initiate_vote(1, "IOBottleneck".to_string());
        engine.add_vote(1, 1, 0.70);
        engine.add_vote(1, 2, 0.80);
        engine.add_vote(1, 3, 0.75);

        let completed = engine.check_consensus();
        if !completed.is_empty() {
            let agreement = engine.get_agreement_level(1);
            assert!(agreement.is_some());
            let level = agreement.unwrap();
            assert!((level - 0.75).abs() < 0.01);  // 평균 75%
        }
    }

    #[test]
    fn test_node_trust_score_update() {
        // 테스트 8: 노드 신뢰도 업데이트
        let mut node = NodeInfo::new(1, "Node-1".to_string(), "127.0.0.1".to_string(), 8080);

        // 초기: 0.5
        assert_eq!(node.trust_score, 0.5);

        // 정확도 0.9, 응답시간 100ms
        node.update_trust_score(0.9, 100);
        // = 0.9 * 0.7 + 0.9 * 0.3 = 0.63 + 0.27 = 0.90
        assert!(node.trust_score > 0.85);

        // 정확도 0.5, 응답시간 500ms
        node.update_trust_score(0.5, 500);
        // = 0.5 * 0.7 + 0.5 * 0.3 = 0.35 + 0.15 = 0.50
        assert!((node.trust_score - 0.5).abs() < 0.05);
    }
}

