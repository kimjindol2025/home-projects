// ============================================================================
// NodeInfo: 노드 정보
// ============================================================================

struct NodeInfo {
    node_id: u32,
    node_name: String,
    ip_address: String,           // "127.0.0.1:8080"
    port: u16,
    active: bool,
    last_heartbeat: u64,          // 마지막 하트비트 시간
    response_time_ms: u32,        // 평균 응답 시간
    trust_score: f64,             // 신뢰도 (0.0-1.0)
    pattern_count: u32,           // 보유 패턴 수
    prediction_accuracy: f64,     // 예측 정확도
}

impl NodeInfo {
    fn new(node_id: u32, node_name: String, ip_address: String, port: u16) -> NodeInfo {
        NodeInfo {
            node_id,
            node_name,
            ip_address,
            port,
            active: true,
            last_heartbeat: 0,
            response_time_ms: 0,
            trust_score: 0.5,          // 초기값 50%
            pattern_count: 0,
            prediction_accuracy: 0.0,
        }
    }

    fn is_healthy(&self, current_timestamp: u64) -> bool {
        // 30초 이내에 하트비트가 있어야 함
        self.active && (current_timestamp - self.last_heartbeat) < 30000
    }

    fn update_trust_score(&mut self, accuracy: f64, response_time: u32) {
        // 신뢰도 = 정확도 (70%) + 응답성 (30%)
        let accuracy_factor = accuracy;  // 0.0-1.0
        let response_factor = 1.0 - ((response_time as f64) / 1000.0).min(1.0);  // 1초 기준

        self.trust_score = accuracy_factor * 0.7 + response_factor * 0.3;
    }
}

// ============================================================================
// PeerDiscovery: 노드 발견 & 등록
// ============================================================================

struct PeerDiscovery {
    known_nodes: Vec<NodeInfo>,
    max_nodes: usize,             // 최대 노드 수 (기본 16)
    discovery_interval_ms: u32,   // 발견 주기 (기본 5000ms)
    last_discovery: u64,
}

impl PeerDiscovery {
    fn new() -> PeerDiscovery {
        PeerDiscovery {
            known_nodes: Vec::new(),
            max_nodes: 16,
            discovery_interval_ms: 5000,
            last_discovery: 0,
        }
    }

    fn register_peer(&mut self, node_info: NodeInfo) -> bool {
        // 중복 확인
        if self.known_nodes.iter().any(|n| n.node_id == node_info.node_id) {
            return false;
        }

        // 최대값 확인
        if self.known_nodes.len() >= self.max_nodes {
            return false;
        }

        self.known_nodes.push(node_info);
        true
    }

    fn unregister_peer(&mut self, node_id: u32) -> bool {
        if let Some(pos) = self.known_nodes.iter().position(|n| n.node_id == node_id) {
            self.known_nodes.remove(pos);
            return true;
        }
        false
    }

    fn get_peer(&self, node_id: u32) -> Option<&NodeInfo> {
        self.known_nodes.iter().find(|n| n.node_id == node_id)
    }

    fn get_healthy_peers(&self, current_timestamp: u64) -> Vec<&NodeInfo> {
        self.known_nodes
            .iter()
            .filter(|n| n.is_healthy(current_timestamp))
            .collect()
    }

    fn get_peer_count(&self) -> usize {
        self.known_nodes.len()
    }

    fn get_healthy_peer_count(&self, current_timestamp: u64) -> usize {
        self.get_healthy_peers(current_timestamp).len()
    }

    fn should_discover(&self, current_timestamp: u64) -> bool {
        current_timestamp - self.last_discovery >= self.discovery_interval_ms as u64
    }

    fn update_discovery_time(&mut self, timestamp: u64) {
        self.last_discovery = timestamp;
    }
}

// ============================================================================
// PatternSharing: 패턴 공유
// ============================================================================

struct SharedPattern {
    pattern_id: u32,
    pattern_type: String,
    source_node_id: u32,
    confidence: f64,
    shared_timestamp: u64,
    frequency: u32,
    success_rate: f64,
}

impl SharedPattern {
    fn new(
        pattern_id: u32,
        pattern_type: String,
        source_node_id: u32,
        confidence: f64,
        frequency: u32,
        success_rate: f64,
        timestamp: u64,
    ) -> SharedPattern {
        SharedPattern {
            pattern_id,
            pattern_type,
            source_node_id,
            confidence,
            shared_timestamp: timestamp,
            frequency,
            success_rate,
        }
    }

    fn is_fresh(&self, current_timestamp: u64) -> bool {
        // 10분 이내의 패턴을 신선하다고 간주
        current_timestamp - self.shared_timestamp < 600000
    }

    fn value_score(&self) -> f64 {
        // 패턴의 가치도 = 신뢰도 (50%) + 빈도 (30%) + 성공률 (20%)
        let frequency_factor = (self.frequency as f64 / 10.0).min(1.0);
        self.confidence * 0.5 + frequency_factor * 0.3 + self.success_rate * 0.2
    }
}

// ============================================================================
// PatternSharingManager: 패턴 공유 관리
// ============================================================================

struct PatternSharingManager {
    shared_patterns: Vec<SharedPattern>,
    max_patterns: usize,          // 최대 공유 패턴 (기본 1000)
    sharing_interval_ms: u32,     // 공유 주기 (기본 300000ms = 5분)
}

impl PatternSharingManager {
    fn new() -> PatternSharingManager {
        PatternSharingManager {
            shared_patterns: Vec::new(),
            max_patterns: 1000,
            sharing_interval_ms: 300000,
        }
    }

    fn share_pattern(&mut self, pattern: SharedPattern) -> bool {
        // 중복 확인
        if self.shared_patterns.iter().any(|p| p.pattern_id == pattern.pattern_id) {
            return false;
        }

        // 최대값 확인
        if self.shared_patterns.len() >= self.max_patterns {
            // 가장 낮은 가치도의 패턴 제거
            if let Some(pos) = self
                .shared_patterns
                .iter()
                .position(|p| p.value_score() == self.shared_patterns.iter().map(|p| p.value_score()).fold(f64::INFINITY, f64::min))
            {
                self.shared_patterns.remove(pos);
            }
        }

        self.shared_patterns.push(pattern);
        true
    }

    fn get_pattern(&self, pattern_id: u32) -> Option<&SharedPattern> {
        self.shared_patterns.iter().find(|p| p.pattern_id == pattern_id)
    }

    fn get_fresh_patterns(&self, current_timestamp: u64) -> Vec<&SharedPattern> {
        self.shared_patterns
            .iter()
            .filter(|p| p.is_fresh(current_timestamp))
            .collect()
    }

    fn get_patterns_by_type(&self, pattern_type: &str) -> Vec<&SharedPattern> {
        self.shared_patterns
            .iter()
            .filter(|p| p.pattern_type == pattern_type)
            .collect()
    }

    fn get_top_patterns(&self, count: usize) -> Vec<&SharedPattern> {
        let mut sorted = self.shared_patterns.iter().collect::<Vec<_>>();
        sorted.sort_by(|a, b| b.value_score().partial_cmp(&a.value_score()).unwrap());
        sorted.into_iter().take(count).collect()
    }

    fn pattern_count(&self) -> usize {
        self.shared_patterns.len()
    }
}

// ============================================================================
// ConsensusLearning: 합의 기반 학습
// ============================================================================

struct ConsensusVote {
    pattern_id: u32,
    pattern_type: String,
    votes: Vec<(u32, f64)>,      // (node_id, confidence)
    consensus_confidence: f64,
    voter_count: u32,
}

impl ConsensusVote {
    fn new(pattern_id: u32, pattern_type: String) -> ConsensusVote {
        ConsensusVote {
            pattern_id,
            pattern_type,
            votes: Vec::new(),
            consensus_confidence: 0.0,
            voter_count: 0,
        }
    }

    fn add_vote(&mut self, node_id: u32, confidence: f64) {
        self.votes.push((node_id, confidence));
        self.voter_count += 1;
        self.update_consensus();
    }

    fn update_consensus(&mut self) {
        if self.votes.is_empty() {
            self.consensus_confidence = 0.0;
            return;
        }

        let total: f64 = self.votes.iter().map(|(_, conf)| conf).sum();
        self.consensus_confidence = total / self.votes.len() as f64;
    }

    fn get_consensus(&self) -> f64 {
        self.consensus_confidence
    }

    fn is_consensus_reached(&self, threshold: f64) -> bool {
        self.consensus_confidence >= threshold && self.voter_count >= 3
    }
}

// ============================================================================
// ConsensusLearningEngine: 합의 학습 엔진
// ============================================================================

struct ConsensusLearningEngine {
    active_votes: Vec<ConsensusVote>,
    completed_votes: Vec<ConsensusVote>,
    consensus_threshold: f64,     // 기본 0.75 (75%)
    min_voters: u32,              // 최소 투표자 수 (기본 3)
}

impl ConsensusLearningEngine {
    fn new() -> ConsensusLearningEngine {
        ConsensusLearningEngine {
            active_votes: Vec::new(),
            completed_votes: Vec::new(),
            consensus_threshold: 0.75,
            min_voters: 3,
        }
    }

    fn initiate_vote(&mut self, pattern_id: u32, pattern_type: String) -> bool {
        // 중복 확인
        if self.active_votes.iter().any(|v| v.pattern_id == pattern_id) {
            return false;
        }

        let vote = ConsensusVote::new(pattern_id, pattern_type);
        self.active_votes.push(vote);
        true
    }

    fn add_vote(&mut self, pattern_id: u32, node_id: u32, confidence: f64) -> bool {
        for vote in &mut self.active_votes {
            if vote.pattern_id == pattern_id {
                vote.add_vote(node_id, confidence);
                return true;
            }
        }
        false
    }

    fn check_consensus(&mut self) -> Vec<ConsensusVote> {
        let mut completed = Vec::new();

        // 합의에 도달한 투표 확인
        let mut i = 0;
        while i < self.active_votes.len() {
            if self.active_votes[i].is_consensus_reached(self.consensus_threshold) {
                let vote = self.active_votes.remove(i);
                self.completed_votes.push(vote.clone());
                completed.push(vote);
            } else {
                i += 1;
            }
        }

        completed
    }

    fn get_consensus_patterns(&self) -> Vec<&ConsensusVote> {
        self.completed_votes.iter().collect()
    }

    fn get_agreement_level(&self, pattern_id: u32) -> Option<f64> {
        for vote in &self.completed_votes {
            if vote.pattern_id == pattern_id {
                return Some(vote.consensus_confidence);
            }
        }
        None
    }

    fn active_vote_count(&self) -> usize {
        self.active_votes.len()
    }
}

