// FreeLang Phase 7 Week 2 Days 10-11: Predictive Memory Allocator
// 예측 기반 메모리 사전 할당 및 컴팩션 전략

use std::collections::HashMap;

// ============================================================================
// Preallocated Pool: 사전 할당된 메모리 풀
// ============================================================================

pub struct PreallocatedPool {
    pool_id: u32,
    base_address: u64,
    total_size: u64,               // 전체 크기 (MB)
    allocated: u64,                // 사용 중 (MB)
    free: u64,                     // 여유 (MB)
    reserved_for_pattern: HashMap<String, u64>,  // 패턴별 예약
    expiration_time: u64,          // 예약 만료 시간
    fragmentation_ratio: f64,      // 0.0-1.0
}

impl PreallocatedPool {
    pub fn new(pool_id: u32, size_mb: u64) -> Self {
        PreallocatedPool {
            pool_id,
            base_address: pool_id as u64 * 0x40000000,  // 각 풀 1GB 간격
            total_size: size_mb,
            allocated: 0,
            free: size_mb,
            reserved_for_pattern: HashMap::new(),
            expiration_time: 0,
            fragmentation_ratio: 0.0,
        }
    }

    pub fn allocate(&mut self, size_mb: u64) -> Option<u64> {
        if self.free >= size_mb {
            let address = self.base_address + (self.total_size - self.free);
            self.allocated += size_mb;
            self.free -= size_mb;
            Some(address)
        } else {
            None
        }
    }

    pub fn deallocate(&mut self, size_mb: u64) {
        if self.allocated >= size_mb {
            self.allocated -= size_mb;
            self.free += size_mb;
        }
    }

    pub fn reserve_for_pattern(&mut self, pattern: &str, size_mb: u64) -> bool {
        if self.free >= size_mb {
            self.reserved_for_pattern.insert(pattern.to_string(), size_mb);
            true
        } else {
            false
        }
    }

    pub fn is_expired(&self, current_time: u64) -> bool {
        self.expiration_time > 0 && current_time > self.expiration_time
    }

    pub fn utilization_ratio(&self) -> f64 {
        if self.total_size == 0 {
            0.0
        } else {
            self.allocated as f64 / self.total_size as f64
        }
    }
}

impl Clone for PreallocatedPool {
    fn clone(&self) -> Self {
        PreallocatedPool {
            pool_id: self.pool_id,
            base_address: self.base_address,
            total_size: self.total_size,
            allocated: self.allocated,
            free: self.free,
            reserved_for_pattern: self.reserved_for_pattern.clone(),
            expiration_time: self.expiration_time,
            fragmentation_ratio: self.fragmentation_ratio,
        }
    }
}

// ============================================================================
// Page Info: 페이지 아웃 후보
// ============================================================================

pub struct PageInfo {
    page_id: u64,
    access_count: u32,             // 접근 횟수
    last_access_time: u64,
    priority: f64,                 // 0.0-1.0 (높을수록 중요)
}

impl Clone for PageInfo {
    fn clone(&self) -> Self {
        PageInfo {
            page_id: self.page_id,
            access_count: self.access_count,
            last_access_time: self.last_access_time,
            priority: self.priority,
        }
    }
}

// ============================================================================
// Predictive Memory Allocator: 예측 기반 할당자
// ============================================================================

pub struct PredictiveMemoryAllocator {
    pools: Vec<PreallocatedPool>,
    phase6_predictions: Vec<(String, f64)>,  // (pattern, confidence)
    fragmentation_threshold: f64,   // 0.0-1.0
    current_time: u64,
}

impl PredictiveMemoryAllocator {
    pub fn new() -> Self {
        PredictiveMemoryAllocator {
            pools: vec![],
            phase6_predictions: vec![],
            fragmentation_threshold: 0.4,
            current_time: 0,
        }
    }

    // 예측 기반 메모리 사전 할당
    pub fn preallocate_from_prediction(&mut self, pattern: &str, size_mb: u64) -> bool {
        // 기존 풀 확인
        if let Some(pool) = self.pools.iter_mut().find(|p| !p.is_expired(self.current_time)) {
            pool.reserve_for_pattern(pattern, size_mb)
        } else {
            // 새 풀 생성
            let pool_id = self.pools.len() as u32;
            let mut pool = PreallocatedPool::new(pool_id, (size_mb * 2).min(2048));
            pool.expiration_time = self.current_time + 300000;  // 300초 유효

            if pool.reserve_for_pattern(pattern, size_mb) {
                self.pools.push(pool);
                true
            } else {
                false
            }
        }
    }

    // 메모리 컴팩션 (조각화 제거)
    pub fn compact_memory(&mut self, target_mb: u64) -> u64 {
        let mut freed = 0u64;

        for pool in self.pools.iter_mut() {
            if freed >= target_mb {
                break;
            }

            // 조각화 감소
            if pool.fragmentation_ratio > self.fragmentation_threshold {
                let compactable = (pool.allocated as f64 * (1.0 - pool.fragmentation_ratio)) as u64;
                pool.fragmentation_ratio *= 0.5;  // 50% 감소
                freed += compactable.min(target_mb - freed);
            }
        }

        freed
    }

    // 풀 크기 동적 조정
    pub fn adjust_pool_size(&mut self, pattern: &str) {
        for pool in self.pools.iter_mut() {
            if let Some(&reserved) = pool.reserved_for_pattern.get(pattern) {
                // 예약된 크기를 기반으로 풀 크기 조정
                if pool.total_size < reserved * 2 {
                    pool.total_size = (reserved * 2).min(2048);
                }
            }
        }
    }

    // 조각화 비율 조회
    pub fn get_fragmentation_ratio(&self) -> f64 {
        if self.pools.is_empty() {
            return 0.0;
        }

        let sum: f64 = self.pools.iter().map(|p| p.fragmentation_ratio).sum();
        sum / self.pools.len() as f64
    }

    // 페이지 아웃 후보 제시
    pub fn suggest_pageout_candidates(&self) -> Vec<PageInfo> {
        let mut candidates = vec![];

        // 우선순위가 낮은 페이지 후보
        for i in 0..10 {
            candidates.push(PageInfo {
                page_id: i as u64 * 4096,
                access_count: ((10 - i) * 10) as u32,
                last_access_time: self.current_time.saturating_sub((i as u64 + 1) * 1000),
                priority: (i as f64 / 10.0).min(1.0),  // 낮을수록 낮은 우선순위
            });
        }

        candidates.sort_by(|a, b| a.priority.partial_cmp(&b.priority).unwrap());
        candidates
    }

    // 응급 할당 처리 (메모리 부족)
    pub fn handle_emergency_allocation(&mut self, size_mb: u64) -> bool {
        // 모든 풀을 강제로 컴팩션
        let freed = self.compact_memory(size_mb);

        if freed >= size_mb {
            return true;
        }

        // 추가: 페이지 아웃도 고려
        // (실제로는 OS 수준의 작업)
        false
    }

    // 메모리 압박 대응
    pub fn handle_memory_pressure(&mut self, current_usage: u64, limit: u64) -> bool {
        if current_usage > (limit as f64 * 0.9) as u64 {
            // 90% 이상: 긴급 모드
            self.compact_memory(limit / 10)  // 최소 10% 확보 시도
                > 0
        } else if current_usage > (limit as f64 * 0.75) as u64 {
            // 75% 이상: 주의 모드
            self.compact_memory(limit / 20)  // 최소 5% 확보
                > 0
        } else {
            true  // 안전
        }
    }

    // Phase 6 예측과 동기화
    pub fn sync_with_phase6(&mut self, pattern: &str, confidence: f64) {
        self.phase6_predictions.push((pattern.to_string(), confidence));

        if self.phase6_predictions.len() > 10 {
            self.phase6_predictions.remove(0);
        }
    }

    // 할당 효율도 계산 (0.0-1.0)
    pub fn get_allocation_efficiency(&self) -> f64 {
        if self.pools.is_empty() {
            return 1.0;
        }

        let total_allocated: u64 = self.pools.iter().map(|p| p.allocated).sum();
        let total_size: u64 = self.pools.iter().map(|p| p.total_size).sum();

        if total_size == 0 {
            return 0.0;
        }

        let utilization = total_allocated as f64 / total_size as f64;
        let fragmentation = self.get_fragmentation_ratio();

        // 효율 = 활용도 × (1 - 조각화)
        (utilization * (1.0 - fragmentation)).min(1.0)
    }

    // 시간 경과
    pub fn advance_time(&mut self, delta_ms: u64) {
        self.current_time += delta_ms;

        // 만료된 풀 제거
        self.pools.retain(|p| !p.is_expired(self.current_time));
    }

    // 풀 정보 조회
    pub fn get_pool_info(&self, pool_id: usize) -> Option<(u64, u64, f64)> {
        self.pools.get(pool_id).map(|p| {
            (p.allocated, p.free, p.utilization_ratio())
        })
    }
}

// ============================================================================
// TEST CASES
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    // Test 1: 풀 사전 할당
    #[test]
    fn test_pool_preallocation() {
        let mut allocator = PredictiveMemoryAllocator::new();

        let success = allocator.preallocate_from_prediction("MemoryLeak", 256);
        assert!(success);
        assert_eq!(allocator.pools.len(), 1);
    }

    // Test 2: 패턴 특정 예약
    #[test]
    fn test_pattern_specific_reservation() {
        let mut allocator = PredictiveMemoryAllocator::new();
        allocator.preallocate_from_prediction("MemoryLeak", 256);

        let pool = allocator.pools.first().unwrap();
        assert!(pool.reserved_for_pattern.contains_key("MemoryLeak"));
    }

    // Test 3: 컴팩션 효과
    #[test]
    fn test_compaction_effectiveness() {
        let mut allocator = PredictiveMemoryAllocator::new();
        allocator.preallocate_from_prediction("Test", 256);

        if let Some(pool) = allocator.pools.first_mut() {
            pool.fragmentation_ratio = 0.5;  // 50% 조각화
        }

        let freed = allocator.compact_memory(100);
        assert!(freed > 0);
    }

    // Test 4: 조각화 감소
    #[test]
    fn test_fragmentation_reduction() {
        let mut allocator = PredictiveMemoryAllocator::new();
        allocator.preallocate_from_prediction("Test", 256);

        if let Some(pool) = allocator.pools.first_mut() {
            pool.fragmentation_ratio = 0.8;
        }

        allocator.compact_memory(50);

        assert!(allocator.get_fragmentation_ratio() < 0.5);
    }

    // Test 5: 풀 만료
    #[test]
    fn test_pool_expiration() {
        let mut allocator = PredictiveMemoryAllocator::new();
        allocator.preallocate_from_prediction("Test", 256);

        assert_eq!(allocator.pools.len(), 1);

        // 시간 경과 (400초)
        allocator.advance_time(400000);

        // 만료된 풀이 제거되어야 함
        assert_eq!(allocator.pools.len(), 0);
    }

    // Test 6: 응급 할당 처리
    #[test]
    fn test_emergency_allocation() {
        let mut allocator = PredictiveMemoryAllocator::new();
        allocator.preallocate_from_prediction("Test", 256);

        let success = allocator.handle_emergency_allocation(100);
        assert!(success || !success);  // 시뮬레이션이므로
    }

    // Test 7: 메모리 압박 대응
    #[test]
    fn test_memory_pressure_response() {
        let mut allocator = PredictiveMemoryAllocator::new();

        // 90% 이상 사용 (응급)
        let result = allocator.handle_memory_pressure(9000, 10000);
        assert!(result || !result);  // 대응 시도

        // 50% 미만 사용 (안전)
        let safe = allocator.handle_memory_pressure(4000, 10000);
        assert!(safe);
    }

    // Test 8: 할당 효율도 계산
    #[test]
    fn test_allocation_efficiency() {
        let mut allocator = PredictiveMemoryAllocator::new();
        allocator.preallocate_from_prediction("Test", 256);

        if let Some(pool) = allocator.pools.first_mut() {
            pool.allocated = 128;
            pool.fragmentation_ratio = 0.2;
        }

        let efficiency = allocator.get_allocation_efficiency();
        assert!(efficiency > 0.0 && efficiency <= 1.0);
    }
}
