pub mod distributed_tracer;
pub mod metrics_collector;
pub mod monitoring_dashboard;

pub use distributed_tracer::{Span, TraceContext, DistributedTracer};
pub use metrics_collector::{Metric, MetricsCollector};
pub use monitoring_dashboard::{Dashboard, MetricSnapshot, TraceMetadata, AlertRule, Alert};

// ============================================================================
// ObservabilityStack: 전체 관찰성 시스템 통합
// ============================================================================

pub struct ObservabilityStack {
    tracer: DistributedTracer,
    collector: MetricsCollector,
    dashboard: Dashboard,
}

impl ObservabilityStack {
    pub fn new() -> Self {
        ObservabilityStack {
            tracer: DistributedTracer::new(1.0),  // 100% sampling by default
            collector: MetricsCollector::new(3600),  // 1-hour history
            dashboard: Dashboard::new(),
        }
    }

    pub fn start_trace(&mut self, trace_id: &str) -> bool {
        self.tracer.start_trace(trace_id.to_string())
    }

    pub fn start_span(&mut self, trace_id: &str, operation_name: &str) -> Option<String> {
        self.tracer.start_span(trace_id.to_string(), operation_name.to_string())
    }

    pub fn end_span(&mut self, trace_id: &str, span_id: &str) -> Option<u64> {
        self.tracer.end_span(trace_id.to_string(), span_id.to_string())
    }

    pub fn record_cpu_metric(&mut self, util: f64, ctx_switches: u32, trace_id: Option<String>) {
        self.collector.record_cpu_metric(util, ctx_switches, trace_id.clone());

        // Dashboard 업데이트
        if let Some(p99) = self.collector.get_percentile("cpu.utilization", 99) {
            if let Some(avg) = self.collector.get_average_latency("cpu.utilization") {
                self.dashboard.update_metric_snapshot(
                    "cpu.utilization".to_string(),
                    util,
                    avg,
                    p99,
                );
            }
        }
    }

    pub fn record_memory_metric(&mut self, usage_mb: u64, gc_pause_ms: u32, fragmentation: f64, trace_id: Option<String>) {
        self.collector.record_memory_metric(usage_mb, gc_pause_ms, fragmentation, trace_id);

        // Dashboard 업데이트
        if let Some(p99) = self.collector.get_percentile("memory.usage_mb", 99) {
            self.dashboard.update_metric_snapshot(
                "memory.usage_mb".to_string(),
                usage_mb as f64,
                usage_mb as f64,
                p99,
            );
        }
    }

    pub fn record_io_metric(&mut self, read_latency_us: u64, write_latency_us: u64, queue_depth: u32, cache_hit_rate: f64, trace_id: Option<String>) {
        self.collector.record_io_metric(read_latency_us, write_latency_us, queue_depth, cache_hit_rate, trace_id);

        // Dashboard 업데이트
        if let Some(p99) = self.collector.get_percentile("io.read_latency_us", 99) {
            self.dashboard.update_metric_snapshot(
                "io.read_latency_us".to_string(),
                read_latency_us as f64,
                read_latency_us as f64,
                p99,
            );
        }
    }

    pub fn add_dashboard_trace(&mut self, trace_id: String, operation: String, latency_us: u64, status: String) {
        self.dashboard.add_recent_trace(trace_id, operation, latency_us, status);
    }

    pub fn set_slo_target(&mut self, metric_name: String, target: f64) {
        self.dashboard.set_slo_target(metric_name, target);
    }

    pub fn check_violations(&mut self) {
        self.dashboard.check_slo_violations();
    }

    pub fn advance_time(&mut self, delta_us: u64) {
        self.collector.advance_time(delta_us);
        self.dashboard.advance_time(delta_us);
    }

    pub fn render_dashboard_html(&self) -> String {
        self.dashboard.render_html()
    }

    pub fn get_slo_report(&self) -> String {
        self.dashboard.get_slo_compliance_report()
    }

    pub fn export_metrics_prometheus(&self) -> String {
        self.collector.export_prometheus()
    }

    pub fn export_traces_jaeger(&self) -> String {
        self.tracer.export_jaeger_format()
    }
}

