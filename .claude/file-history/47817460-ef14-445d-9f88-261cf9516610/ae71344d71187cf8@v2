#[cfg(test)]
mod integration_tests {
    use super::*;

    #[test]
    fn test_full_observability_stack() {
        let mut stack = ObservabilityStack::new();

        // 시작 추적
        stack.start_trace("trace-001");

        // 스팬 시작
        let span_id = stack.start_span("trace-001", "api_request").unwrap();

        // 메트릭 기록
        stack.record_cpu_metric(75.0, 250, Some("trace-001".to_string()));
        stack.record_memory_metric(1024, 50, 0.2, Some("trace-001".to_string()));

        // SLO 설정
        stack.set_slo_target("cpu.utilization".to_string(), 90.0);

        // 시간 경과
        stack.advance_time(1_000_000);

        // 대시보드 업데이트
        stack.add_dashboard_trace("trace-001".to_string(), "api_request".to_string(), 150, "completed".to_string());

        // 위반 확인
        stack.check_violations();

        // HTML 렌더링
        let html = stack.render_dashboard_html();
        assert!(html.contains("Phase H Monitoring Dashboard"));
    }
}
