// netcat v3: 데이터 송수신

type Connection {
    host: string
    port: u64
    protocol: string
    is_connected: bool
    sent_bytes: u64
    recv_bytes: u64
}

fn send_data(mut conn: Connection, data: string) -> Connection {
    if !conn.is_connected {
        return conn
    }
    conn.sent_bytes = conn.sent_bytes + data.len()
    println!("Sent: " ++ data.len().to_string() ++ " bytes")
    conn
}

fn recv_data(mut conn: Connection) -> (Connection, string) {
    if !conn.is_connected {
        return (conn, "")
    }
    conn.recv_bytes = conn.recv_bytes + 100u64
    (conn, "Response data from server")
}

fn main() {
    let mut conn = Connection {
        host: "localhost",
        port: 8080u64,
        protocol: "TCP",
        is_connected: true,
        sent_bytes: 0u64,
        recv_bytes: 0u64
    }

    conn = send_data(conn, "GET / HTTP/1.1")
    let (conn, response) = recv_data(conn)

    println!("Stats - Sent: " ++ conn.sent_bytes.to_string() ++ ", Recv: " ++ conn.recv_bytes.to_string())
}
