## 🔧 설정 파일 템플릿

### ~/.bashrc 또는 ~/.zshrc

```bash
# 알리아스 설정
alias ll='ls -lah'
alias la='ls -A'
alias l='ls -CF'
alias gst='git status'
alias gco='git checkout'
alias gad='git add'
alias gci='git commit'
alias gpu='git push'
alias gpl='git pull'
alias tmux='tmux -2'

# 환경 변수
export EDITOR='nvim'
export LANG='ko_KR.UTF-8'
export LC_ALL='ko_KR.UTF-8'

# Python 가상환경
alias venv='source ~/myenv/bin/activate'
alias deactivate='deactivate'

# Termux 특화
export PATH="$PATH:$HOME/.local/bin"

# tmux 자동 시작
if [ -z "$TMUX" ]; then
    tmux attach -t main || tmux new-session -s main
fi
```

