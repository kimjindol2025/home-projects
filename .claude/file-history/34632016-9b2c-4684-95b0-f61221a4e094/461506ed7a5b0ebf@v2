# 📦 Termux 필수 앱 설치 가이드

> **모든 10가지 도구를 단계별로 설치하는 완벽한 가이드**

---

## 🚀 한번에 설치하기 (권장)

```bash
#!/bin/bash
# install-all.sh

# 1. Termux 시스템 업데이트
pkg update && pkg upgrade -y

# 2. 모든 도구 한번에 설치
pkg install -y \
    tmux \
    git \
    btop \
    neovim \
    python \
    nmap \
    ffmpeg \
    zsh \
    curl \
    wget \
    nodejs

# 3. Python 추가 패키지
pip install --upgrade pip
pip install numpy pandas matplotlib jupyter

# 4. zsh 설정 (Oh My Zsh)
sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"

# 5. proot-distro 설치
pkg install proot-distro

echo "✅ 모든 설치 완료!"
```

