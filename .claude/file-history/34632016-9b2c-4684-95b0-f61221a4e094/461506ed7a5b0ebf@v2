## ✅ 설치 완료 확인

```bash
#!/bin/bash
# verify-install.sh

echo "=== Termux 설치 상태 확인 ==="
echo ""

tools=("tmux" "git" "btop" "nvim" "python" "nmap" "ffmpeg" "zsh" "curl" "wget")

for tool in "${tools[@]}"; do
    if command -v $tool &> /dev/null; then
        echo "✅ $tool: 설치됨"
    else
        echo "❌ $tool: 미설치"
    fi
done

echo ""
echo "=== 버전 확인 ==="
echo "tmux: $(tmux -V)"
echo "git: $(git --version)"
echo "python: $(python --version)"
echo "nvim: $(nvim --version | head -1)"

echo ""
echo "✨ 설치 확인 완료!"
```

