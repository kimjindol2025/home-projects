// zsh Phase 1: 기본 쉘 명령 해석
type CommandID = u64
type Timestamp = u64

enum CommandType {
    Builtin
    External
    Alias
    Function
}

type Command {
    id: CommandID
    name: string
    cmd_type: CommandType
    executed_at: Timestamp
    exit_code: u64
}

type Shell {
    commands: Vec<Command>
    history: Vec<string>
    next_command_id: CommandID
    prompt: string
}

impl Shell {
    fn new() -> Shell {
        Shell {
            commands: Vec::new(),
            history: Vec::new(),
            next_command_id: 1000u64,
            prompt: "zsh$ "
        }
    }

    fn parse_command(mut self, cmd_str: string) -> (Shell, CommandID) {
        let cmd_id = self.next_command_id
        self.next_command_id = self.next_command_id + 1u64

        let cmd_type = if cmd_str == "cd" || cmd_str == "echo" || cmd_str == "pwd" {
            CommandType::Builtin
        } else {
            CommandType::External
        }

        let command = Command {
            id: cmd_id,
            name: cmd_str,
            cmd_type: cmd_type,
            executed_at: get_timestamp(),
            exit_code: 0u64
        }

        self.commands.push(command)
        self.history.push(cmd_str)
        (self, cmd_id)
    }

    fn execute_command(mut self, cmd_id: CommandID, exit_code: u64) -> Shell {
        let mut i = 0u64

        while i < self.commands.len() {
            let cmd = self.commands.get(i)

            match cmd {
                Some(c) => {
                    if c.id == cmd_id {
                        let updated = Command {
                            id: c.id,
                            name: c.name,
                            cmd_type: c.cmd_type,
                            executed_at: c.executed_at,
                            exit_code: exit_code
                        }
                        self.commands.set(i, updated)
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        self
    }

    fn get_history(ref self) -> Vec<string> {
        self.history
    }

    fn get_command_count(ref self) -> u64 {
        self.history.len()
    }
}

fn get_timestamp() -> Timestamp { 12345678u64 }

fn main() {
    println!("=== zsh Phase 1: 기본 쉘 ===")

    let mut shell = Shell::new()
    println!("🐚 zsh 초기화")

    let (shell2, id1) = shell.parse_command("pwd")
    shell = shell2
    shell = shell.execute_command(id1, 0u64)
    println!("✅ pwd 실행")

    let (shell2, id2) = shell.parse_command("ls -la")
    shell = shell2
    shell = shell.execute_command(id2, 0u64)
    println!("✅ ls -la 실행")

    let (shell2, id3) = shell.parse_command("echo hello")
    shell = shell2
    shell = shell.execute_command(id3, 0u64)
    println!("✅ echo hello 실행")

    let history = shell.get_history()
    println!("\n📜 히스토리:")
    let mut i = 0u64
    while i < history.len() {
        let cmd = history.get(i).unwrap()
        println!("  " ++ cmd)
        i = i + 1u64
    }

    let count = shell.get_command_count()
    println!("\n📊 총 명령: " ++ count.to_string())
}
