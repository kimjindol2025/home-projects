// nmap Phase 4: 프로덕션 (보안, 성능, 리포트)
type ScanID = u64

enum RiskLevel {
    Low
    Medium
    High
}

type Vulnerability {
    port: u64
    service: string
    risk: RiskLevel
}

type ScanReport {
    scan_id: ScanID
    target: string
    vulnerabilities: Vec<Vulnerability>
    scan_time: u64
}

type SecureScanner {
    reports: Vec<ScanReport>
    next_scan_id: ScanID
}

impl SecureScanner {
    fn new() -> SecureScanner {
        SecureScanner {
            reports: Vec::new(),
            next_scan_id: 1000u64
        }
    }

    fn scan_target(mut self, target: string, scan_time: u64) -> (SecureScanner, ScanID) {
        let scan_id = self.next_scan_id
        self.next_scan_id = self.next_scan_id + 1u64

        let report = ScanReport {
            scan_id: scan_id,
            target: target,
            vulnerabilities: Vec::new(),
            scan_time: scan_time
        }

        self.reports.push(report)
        (self, scan_id)
    }

    fn add_vulnerability(mut self, scan_id: ScanID, port: u64, service: string, risk: RiskLevel) -> SecureScanner {
        let mut i = 0u64

        while i < self.reports.len() {
            let report = self.reports.get(i)

            match report {
                Some(r) => {
                    if r.scan_id == scan_id {
                        let mut updated = ScanReport {
                            scan_id: r.scan_id,
                            target: r.target,
                            vulnerabilities: r.vulnerabilities,
                            scan_time: r.scan_time
                        }

                        updated.vulnerabilities.push(Vulnerability {
                            port: port,
                            service: service,
                            risk: risk
                        })

                        self.reports.set(i, updated)
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        self
    }

    fn get_report(ref self, scan_id: ScanID) -> Option<(u64, u64)> {
        let mut i = 0u64

        while i < self.reports.len() {
            let report = self.reports.get(i)

            match report {
                Some(r) => {
                    if r.scan_id == scan_id {
                        return Some((r.vulnerabilities.len(), r.scan_time))
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        None
    }

    fn get_high_risk(ref self, scan_id: ScanID) -> Vec<(u64, string)> {
        let mut result = Vec::new()
        let mut i = 0u64

        while i < self.reports.len() {
            let report = self.reports.get(i)

            match report {
                Some(r) => {
                    if r.scan_id == scan_id {
                        let mut j = 0u64
                        while j < r.vulnerabilities.len() {
                            let vuln = r.vulnerabilities.get(j)

                            match vuln {
                                Some(v) => {
                                    match v.risk {
                                        RiskLevel::High => {
                                            result.push((v.port, v.service))
                                        }
                                        _ => {}
                                    }
                                }
                                None => {}
                            }

                            j = j + 1u64
                        }
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        result
    }
}

type Option<T> {
    Some(T)
    None
}

fn main() {
    println!("=== nmap Phase 4: 보안 분석 ===")

    let mut scanner = SecureScanner::new()
    println!("🔍 보안 스캐너 초기화")

    let (scanner2, scan1) = scanner.scan_target("192.168.1.50", 45u64)
    scanner = scanner2
    println!("✅ 스캔 시작")

    scanner = scanner.add_vulnerability(scan1, 22u64, "ssh", RiskLevel::Low)
    scanner = scanner.add_vulnerability(scan1, 80u64, "http", RiskLevel::High)
    scanner = scanner.add_vulnerability(scan1, 3306u64, "mysql", RiskLevel::High)
    println!("✅ 취약점 감지")

    let report = scanner.get_report(scan1)
    match report {
        Some((vuln_count, time)) => {
            println!("\n📊 스캔 보고서:")
            println!("  취약점: " ++ vuln_count.to_string())
            println!("  시간: " ++ time.to_string() ++ "ms")
        }
        None => {}
    }

    let high_risk = scanner.get_high_risk(scan1)
    println!("\n🚨 위험 (High):")
    let mut i = 0u64
    while i < high_risk.len() {
        let (port, service) = high_risk.get(i).unwrap()
        println!("  " ++ port.to_string() ++ " - " ++ service)
        i = i + 1u64
    }
}
