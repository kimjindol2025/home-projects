// python Phase 3: 스크립트 실행 및 모듈 로딩
// 목표: Python 스크립트 실행, 모듈 임포트, 결과 처리

type ScriptID = u64
type ModuleID = u64
type Timestamp = u64
type ScriptName = string
type ModuleName = string
type Output = string

enum ExecutionStatus {
    Pending
    Running
    Success
    Failed
    Timeout
}

type PythonScript {
    id: ScriptID
    name: ScriptName
    code: string
    status: ExecutionStatus
    created_at: Timestamp
    executed_at: Timestamp
}

type Module {
    id: ModuleID
    name: ModuleName
    version: string
    loaded: bool
    loaded_at: Timestamp
}

type ScriptResult {
    script_id: ScriptID
    exit_code: u64
    stdout: Output
    stderr: Output
    execution_time: u64
    timestamp: Timestamp
}

type PythonRuntime {
    scripts: Vec<PythonScript>
    modules: Vec<Module>
    results: Vec<ScriptResult>
    next_script_id: ScriptID
    next_module_id: ModuleID
}

impl PythonRuntime {

    fn new() -> PythonRuntime {
        PythonRuntime {
            scripts: Vec::new(),
            modules: Vec::new(),
            results: Vec::new(),
            next_script_id: 1000u64,
            next_module_id: 100000u64
        }
    }

    // 모듈 로드
    fn load_module(mut self, module_name: ModuleName, version: string) -> (PythonRuntime, ModuleID) {
        let module_id = self.next_module_id
        self.next_module_id = self.next_module_id + 1u64

        let module = Module {
            id: module_id,
            name: module_name,
            version: version,
            loaded: true,
            loaded_at: get_timestamp()
        }

        self.modules.push(module)
        (self, module_id)
    }

    // 모듈 언로드
    fn unload_module(mut self, module_id: ModuleID) -> (PythonRuntime, bool) {
        let mut found = false
        let mut i = 0u64

        while i < self.modules.len() {
            let module = self.modules.get(i)

            match module {
                Some(m) => {
                    if m.id == module_id {
                        let updated = Module {
                            id: m.id,
                            name: m.name,
                            version: m.version,
                            loaded: false,
                            loaded_at: m.loaded_at
                        }
                        self.modules.set(i, updated)
                        found = true
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        (self, found)
    }

    // 스크립트 작성
    fn create_script(mut self, script_name: ScriptName, code: string) -> (PythonRuntime, ScriptID) {
        let script_id = self.next_script_id
        self.next_script_id = self.next_script_id + 1u64

        let script = PythonScript {
            id: script_id,
            name: script_name,
            code: code,
            status: ExecutionStatus::Pending,
            created_at: get_timestamp(),
            executed_at: 0u64
        }

        self.scripts.push(script)
        (self, script_id)
    }

    // 스크립트 실행
    fn execute_script(mut self, script_id: ScriptID, stdout: string, stderr: string, exit_code: u64, exec_time: u64) -> (PythonRuntime, bool) {
        let mut script_found = false
        let mut i = 0u64

        while i < self.scripts.len() {
            let script = self.scripts.get(i)

            match script {
                Some(s) => {
                    if s.id == script_id {
                        let status = if exit_code == 0u64 {
                            ExecutionStatus::Success
                        } else {
                            ExecutionStatus::Failed
                        }

                        let updated = PythonScript {
                            id: s.id,
                            name: s.name,
                            code: s.code,
                            status: status,
                            created_at: s.created_at,
                            executed_at: get_timestamp()
                        }
                        self.scripts.set(i, updated)
                        script_found = true
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        if script_found {
            let result = ScriptResult {
                script_id: script_id,
                exit_code: exit_code,
                stdout: stdout,
                stderr: stderr,
                execution_time: exec_time,
                timestamp: get_timestamp()
            }
            self.results.push(result)
        }

        (self, script_found)
    }

    // 스크립트 목록
    fn list_scripts(ref self) -> Vec<(ScriptID, ScriptName, string)> {
        let mut result = Vec::new()
        let mut i = 0u64

        while i < self.scripts.len() {
            let script = self.scripts.get(i)

            match script {
                Some(s) => {
                    let status_str = match s.status {
                        ExecutionStatus::Pending => "pending",
                        ExecutionStatus::Running => "running",
                        ExecutionStatus::Success => "success",
                        ExecutionStatus::Failed => "failed",
                        ExecutionStatus::Timeout => "timeout"
                    }

                    result.push((s.id, s.name, status_str))
                }
                None => {}
            }

            i = i + 1u64
        }

        result
    }

    // 모듈 목록
    fn list_modules(ref self) -> Vec<(ModuleID, ModuleName, string, bool)> {
        let mut result = Vec::new()
        let mut i = 0u64

        while i < self.modules.len() {
            let module = self.modules.get(i)

            match module {
                Some(m) => {
                    result.push((m.id, m.name, m.version, m.loaded))
                }
                None => {}
            }

            i = i + 1u64
        }

        result
    }

    // 스크립트 결과 조회
    fn get_result(ref self, script_id: ScriptID) -> Option<(u64, Output, Output, u64)> {
        let mut i = 0u64

        while i < self.results.len() {
            let result = self.results.get(i)

            match result {
                Some(r) => {
                    if r.script_id == script_id {
                        return Some((r.exit_code, r.stdout, r.stderr, r.execution_time))
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        None
    }

    // 성공한 스크립트 수
    fn successful_count(ref self) -> u64 {
        let mut count = 0u64
        let mut i = 0u64

        while i < self.scripts.len() {
            let script = self.scripts.get(i)

            match script {
                Some(s) => {
                    match s.status {
                        ExecutionStatus::Success => {
                            count = count + 1u64
                        }
                        _ => {}
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        count
    }

    // 로드된 모듈 수
    fn loaded_module_count(ref self) -> u64 {
        let mut count = 0u64
        let mut i = 0u64

        while i < self.modules.len() {
            let module = self.modules.get(i)

            match module {
                Some(m) => {
                    if m.loaded {
                        count = count + 1u64
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        count
    }
}

// === ExecutionStatus 동등 비교 ===

fn execution_status_eq(a: ExecutionStatus, b: ExecutionStatus) -> bool {
    match a {
        ExecutionStatus::Success => {
            match b {
                ExecutionStatus::Success => true
                _ => false
            }
        }
        ExecutionStatus::Failed => {
            match b {
                ExecutionStatus::Failed => true
                _ => false
            }
        }
        _ => false
    }
}

// === Option 타입 ===

type Option<T> {
    Some(T)
    None
}

// === 유틸리티 ===

fn get_timestamp() -> Timestamp {
    12345678u64
}

// === 테스트 ===

fn main() {
    println!("=== python Phase 3: 스크립트 실행 + 모듈 ===")

    let mut runtime = PythonRuntime::new()
    println!("🐍 Python 런타임 초기화")

    // 모듈 로드
    println!("\n📚 모듈 로드:")
    let (runtime2, mod_numpy) = runtime.load_module("numpy", "1.24.0")
    runtime = runtime2
    println!("✅ numpy 1.24.0 로드")

    let (runtime2, mod_pandas) = runtime.load_module("pandas", "2.0.0")
    runtime = runtime2
    println!("✅ pandas 2.0.0 로드")

    let (runtime2, mod_matplotlib) = runtime.load_module("matplotlib", "3.7.0")
    runtime = runtime2
    println!("✅ matplotlib 3.7.0 로드")

    // 스크립트 작성
    println!("\n📝 스크립트 작성:")
    let (runtime2, script1_id) = runtime.create_script("data_analysis.py", "import numpy as np\ndata = np.array([1,2,3,4,5])\nprint(data.mean())")
    runtime = runtime2
    println!("✅ data_analysis.py")

    let (runtime2, script2_id) = runtime.create_script("error_script.py", "import sys\nsys.exit(1)")
    runtime = runtime2
    println!("✅ error_script.py")

    let (runtime2, script3_id) = runtime.create_script("hello.py", "print('Hello, World!')")
    runtime = runtime2
    println!("✅ hello.py")

    // 스크립트 실행
    println!("\n▶️  스크립트 실행:")
    let (runtime2, success) = runtime.execute_script(script1_id, "3.0\n", "", 0u64, 45u64)
    runtime = runtime2
    println!("✅ data_analysis.py 실행 (45ms)")

    let (runtime2, success) = runtime.execute_script(script2_id, "", "Error occurred\n", 1u64, 12u64)
    runtime = runtime2
    println!("✅ error_script.py 실행 (12ms, exit code 1)")

    let (runtime2, success) = runtime.execute_script(script3_id, "Hello, World!\n", "", 0u64, 8u64)
    runtime = runtime2
    println!("✅ hello.py 실행 (8ms)")

    // 스크립트 목록
    println!("\n📋 스크립트 목록:")
    let scripts = runtime.list_scripts()
    let mut i = 0u64
    while i < scripts.len() {
        let (id, name, status) = scripts.get(i).unwrap()
        println!("  [" ++ status ++ "] " ++ name)
        i = i + 1u64
    }

    // 모듈 목록
    println!("\n📚 모듈 목록:")
    let modules = runtime.list_modules()
    let mut i = 0u64
    while i < modules.len() {
        let (id, name, version, loaded) = modules.get(i).unwrap()
        let status = if loaded { "로드됨" } else { "언로드됨" }
        println!("  " ++ name ++ " " ++ version ++ " (" ++ status ++ ")")
        i = i + 1u64
    }

    // 스크립트 결과 조회
    println!("\n📊 스크립트 결과 (data_analysis.py):")
    let result = runtime.get_result(script1_id)
    match result {
        Some((exit_code, stdout, stderr, time)) => {
            println!("  Exit Code: " ++ exit_code.to_string())
            println!("  Output: " ++ stdout)
            println!("  Time: " ++ time.to_string() ++ "ms")
        }
        None => {}
    }

    // 통계
    println!("\n📈 통계:")
    let successful = runtime.successful_count()
    let loaded_mods = runtime.loaded_module_count()
    println!("  성공한 스크립트: " ++ successful.to_string())
    println!("  로드된 모듈: " ++ loaded_mods.to_string())
}
