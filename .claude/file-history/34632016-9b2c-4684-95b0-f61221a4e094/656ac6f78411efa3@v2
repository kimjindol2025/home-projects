// netcat v2: TCP 및 UDP 지원

type Connection {
    host: string
    port: u64
    protocol: string
    is_connected: bool
}

fn create_connection(host: string, port: u64, protocol: string) -> Connection {
    Connection {
        host: host,
        port: port,
        protocol: protocol,
        is_connected: false
    }
}

fn connect(conn: Connection) -> Connection {
    let mut c = conn
    c.is_connected = true
    println!("Connected via " ++ c.protocol ++ " to " ++ c.host)
    c
}

fn main() {
    let tcp = create_connection("localhost", 8080u64, "TCP")
    let connected = connect(tcp)
    println!(connected.is_connected.to_string())
}
