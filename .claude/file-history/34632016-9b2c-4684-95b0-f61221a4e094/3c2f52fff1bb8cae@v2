// git Phase 3: 원격 저장소 및 동기화
// 목표: push, pull, fetch, remote 관리 기능

type CommitID = u64
type BranchID = u64
type RemoteID = u64
type Timestamp = u64
type AuthorName = string
type CommitMessage = string
type BranchName = string
type RemoteURL = string
type FilePath = string

enum FileStatus {
    Added
    Modified
    Deleted
}

enum SyncStatus {
    InSync       // 동기화됨
    AheadLocal   // 로컬이 앞음
    AheadRemote  // 원격이 앞음
    Diverged     // 분기됨
}

type FileChange {
    path: FilePath
    status: FileStatus
}

type Commit {
    id: CommitID
    author: AuthorName
    message: CommitMessage
    timestamp: Timestamp
    files: Vec<FileChange>
    parent_id: Option<CommitID>
}

type Branch {
    id: BranchID
    name: BranchName
    commits: Vec<CommitID>
    is_current: bool
    created_at: Timestamp
}

type Remote {
    id: RemoteID
    name: string
    url: RemoteURL
    last_sync: Timestamp
}

type Repository {
    name: string
    branches: Vec<Branch>
    all_commits: Vec<Commit>
    remotes: Vec<Remote>
    next_branch_id: BranchID
    next_commit_id: CommitID
    next_remote_id: RemoteID
}

impl Repository {

    fn init(name: string) -> Repository {
        let main_branch = Branch {
            id: 1000u64,
            name: "main",
            commits: Vec::new(),
            is_current: true,
            created_at: get_timestamp()
        }

        let mut branches = Vec::new()
        branches.push(main_branch)

        Repository {
            name: name,
            branches: branches,
            all_commits: Vec::new(),
            remotes: Vec::new(),
            next_branch_id: 1001u64,
            next_commit_id: 10000u64,
            next_remote_id: 100000u64
        }
    }

    // 원격 저장소 추가
    fn add_remote(mut self, remote_name: string, url: RemoteURL) -> (Repository, RemoteID) {
        let remote_id = self.next_remote_id
        self.next_remote_id = self.next_remote_id + 1u64

        let remote = Remote {
            id: remote_id,
            name: remote_name,
            url: url,
            last_sync: 0u64
        }

        self.remotes.push(remote)
        (self, remote_id)
    }

    // 원격 저장소 목록
    fn list_remotes(ref self) -> Vec<(RemoteID, string, RemoteURL)> {
        let mut result = Vec::new()
        let mut i = 0u64

        while i < self.remotes.len() {
            let remote = self.remotes.get(i)

            match remote {
                Some(r) => {
                    result.push((r.id, r.name, r.url))
                }
                None => {}
            }

            i = i + 1u64
        }

        result
    }

    // 커밋 생성
    fn commit(mut self, author: AuthorName, message: CommitMessage, files: Vec<FileChange>) -> (Repository, CommitID) {
        let commit_id = self.next_commit_id
        self.next_commit_id = self.next_commit_id + 1u64

        let now = get_timestamp()

        let parent_id = if self.all_commits.len() > 0u64 {
            let last_commit = self.all_commits.get(self.all_commits.len() - 1u64)
            match last_commit {
                Some(c) => {
                    Some(c.id)
                }
                None => {
                    None
                }
            }
        } else {
            None
        }

        let commit = Commit {
            id: commit_id,
            author: author,
            message: message,
            timestamp: now,
            files: files,
            parent_id: parent_id
        }

        self.all_commits.push(commit)

        // 현재 브랜치에 커밋 추가
        let mut i = 0u64
        while i < self.branches.len() {
            let branch = self.branches.get(i)

            match branch {
                Some(b) => {
                    if b.is_current {
                        let mut updated_branch = Branch {
                            id: b.id,
                            name: b.name,
                            commits: b.commits,
                            is_current: b.is_current,
                            created_at: b.created_at
                        }
                        updated_branch.commits.push(commit_id)
                        self.branches.set(i, updated_branch)
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        (self, commit_id)
    }

    // Push (원격에 업로드) - 시뮬레이션
    fn push(mut self, remote_name: string, branch_name: BranchName) -> (Repository, bool) {
        let mut remote_found = false
        let mut branch_found = false
        let now = get_timestamp()

        // 원격 저장소 확인
        let mut i = 0u64
        while i < self.remotes.len() {
            let remote = self.remotes.get(i)

            match remote {
                Some(r) => {
                    if r.name == remote_name {
                        let updated_remote = Remote {
                            id: r.id,
                            name: r.name,
                            url: r.url,
                            last_sync: now
                        }
                        self.remotes.set(i, updated_remote)
                        remote_found = true
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        // 브랜치 확인
        i = 0u64
        while i < self.branches.len() {
            let branch = self.branches.get(i)

            match branch {
                Some(b) => {
                    if b.name == branch_name {
                        branch_found = true
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        (self, remote_found && branch_found)
    }

    // Pull (원격에서 다운로드) - 시뮬레이션
    fn pull(mut self, remote_name: string) -> (Repository, SyncStatus) {
        let mut remote_found = false
        let now = get_timestamp()

        let mut i = 0u64
        while i < self.remotes.len() {
            let remote = self.remotes.get(i)

            match remote {
                Some(r) => {
                    if r.name == remote_name {
                        let updated_remote = Remote {
                            id: r.id,
                            name: r.name,
                            url: r.url,
                            last_sync: now
                        }
                        self.remotes.set(i, updated_remote)
                        remote_found = true
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        if remote_found {
            (self, SyncStatus::InSync)
        } else {
            (self, SyncStatus::Diverged)
        }
    }

    // Fetch (원격 정보 조회) - 시뮬레이션
    fn fetch(mut self, remote_name: string) -> (Repository, bool) {
        let mut found = false
        let now = get_timestamp()

        let mut i = 0u64
        while i < self.remotes.len() {
            let remote = self.remotes.get(i)

            match remote {
                Some(r) => {
                    if r.name == remote_name {
                        let updated_remote = Remote {
                            id: r.id,
                            name: r.name,
                            url: r.url,
                            last_sync: now
                        }
                        self.remotes.set(i, updated_remote)
                        found = true
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        (self, found)
    }

    // 동기화 상태 확인
    fn sync_status(ref self, remote_name: string) -> SyncStatus {
        let mut i = 0u64

        while i < self.remotes.len() {
            let remote = self.remotes.get(i)

            match remote {
                Some(r) => {
                    if r.name == remote_name {
                        let now = get_timestamp()
                        let time_diff = now - r.last_sync

                        if time_diff == 0u64 {
                            return SyncStatus::InSync
                        } else if time_diff < 100u64 {
                            return SyncStatus::AheadLocal
                        } else {
                            return SyncStatus::AheadRemote
                        }
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        SyncStatus::Diverged
    }

    // 원격 저장소 정보
    fn remote_info(ref self, remote_name: string) -> Option<(string, RemoteURL, Timestamp)> {
        let mut i = 0u64

        while i < self.remotes.len() {
            let remote = self.remotes.get(i)

            match remote {
                Some(r) => {
                    if r.name == remote_name {
                        return Some((r.name, r.url, r.last_sync))
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        None
    }

    // 커밋 생성
    fn create_commit(mut self, author: AuthorName, message: CommitMessage) -> (Repository, CommitID) {
        let mut files = Vec::new()
        files.push(FileChange { path: "default.fl", status: FileStatus::Modified })
        self.commit(author, message, files)
    }

    // 커밋 카운트
    fn commit_count(ref self) -> u64 {
        self.all_commits.len()
    }
}

// === Option 타입 ===

type Option<T> {
    Some(T)
    None
}

// === 유틸리티 ===

fn get_timestamp() -> Timestamp {
    12345678u64
}

// === 테스트 ===

fn main() {
    println!("=== git Phase 3: 원격 저장소 및 동기화 ===")

    let mut repo = Repository::init("my-project")
    println!("📁 저장소 초기화: my-project")

    // 원격 저장소 추가
    println!("\n🌐 원격 저장소 추가:")
    let (repo2, _) = repo.add_remote("origin", "https://github.com/user/my-project.git")
    repo = repo2
    println!("✅ origin 추가: https://github.com/user/my-project.git")

    let (repo2, _) = repo.add_remote("upstream", "https://github.com/upstream/my-project.git")
    repo = repo2
    println!("✅ upstream 추가: https://github.com/upstream/my-project.git")

    // 원격 저장소 목록
    println!("\n📋 원격 저장소 목록:")
    let remotes = repo.list_remotes()
    let mut i = 0u64
    while i < remotes.len() {
        let (id, name, url) = remotes.get(i).unwrap()
        println!("  " ++ name ++ " -> " ++ url)
        i = i + 1u64
    }

    // 커밋 생성
    println!("\n📝 커밋 생성:")
    let (repo2, _) = repo.create_commit("kim@localhost", "Initial commit")
    repo = repo2
    println!("✅ 첫 번째 커밋")

    let (repo2, _) = repo.create_commit("kim@localhost", "Add features")
    repo = repo2
    println!("✅ 두 번째 커밋")

    // Fetch
    println!("\n📥 Fetch:")
    let (repo2, success) = repo.fetch("origin")
    repo = repo2
    println!("✅ origin에서 fetch - " ++ (if success { "성공" } else { "실패" }))

    // 동기화 상태
    println!("\n🔄 동기화 상태:")
    let status = repo.sync_status("origin")
    let status_str = match status {
        SyncStatus::InSync => "동기화됨",
        SyncStatus::AheadLocal => "로컬이 앞음",
        SyncStatus::AheadRemote => "원격이 앞음",
        SyncStatus::Diverged => "분기됨"
    }
    println!("  origin: " ++ status_str)

    // Push
    println!("\n📤 Push:")
    let (repo2, success) = repo.push("origin", "main")
    repo = repo2
    println!("✅ origin/main에 push - " ++ (if success { "성공" } else { "실패" }))

    // Pull
    println!("\n📥 Pull:")
    let (repo2, sync_status) = repo.pull("origin")
    repo = repo2

    let sync_result = match sync_status {
        SyncStatus::InSync => "동기화됨",
        SyncStatus::AheadLocal => "로컬이 앞음",
        SyncStatus::AheadRemote => "원격이 앞음",
        SyncStatus::Diverged => "분기됨"
    }

    println!("✅ origin에서 pull - " ++ sync_result)

    // 원격 정보
    println!("\n ℹ️  원격 저장소 정보:")
    let info = repo.remote_info("origin")
    match info {
        Some((name, url, last_sync)) => {
            println!("  이름: " ++ name)
            println!("  URL: " ++ url)
            println!("  마지막 동기화: " ++ last_sync.to_string())
        }
        None => {
            println!("  (원격 없음)")
        }
    }

    // 통계
    println!("\n📊 통계:")
    let commit_count = repo.commit_count()
    println!("  총 커밋: " ++ commit_count.to_string())
    let remotes = repo.list_remotes()
    println!("  원격 저장소: " ++ remotes.len().to_string())
}
