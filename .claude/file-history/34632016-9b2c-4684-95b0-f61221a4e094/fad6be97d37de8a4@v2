// zsh Phase 3: 자동완성 및 키바인딩
type CompletionID = u64
type KeybindID = u64

type Completion {
    id: CompletionID
    pattern: string
    suggestions: Vec<string>
}

type Keybind {
    id: KeybindID
    key: string
    action: string
}

type SmartShell {
    completions: Vec<Completion>
    keybinds: Vec<Keybind>
    next_comp_id: CompletionID
    next_key_id: KeybindID
}

impl SmartShell {
    fn new() -> SmartShell {
        SmartShell {
            completions: Vec::new(),
            keybinds: Vec::new(),
            next_comp_id: 1000u64,
            next_key_id: 10000u64
        }
    }

    fn add_completion(mut self, pattern: string) -> (SmartShell, CompletionID) {
        let id = self.next_comp_id
        self.next_comp_id = self.next_comp_id + 1u64

        let mut suggestions = Vec::new()
        if pattern == "git" {
            suggestions.push("add")
            suggestions.push("commit")
            suggestions.push("push")
        }

        let comp = Completion {
            id: id,
            pattern: pattern,
            suggestions: suggestions
        }

        self.completions.push(comp)
        (self, id)
    }

    fn bind_key(mut self, key: string, action: string) -> (SmartShell, KeybindID) {
        let id = self.next_key_id
        self.next_key_id = self.next_key_id + 1u64

        let keybind = Keybind {
            id: id,
            key: key,
            action: action
        }

        self.keybinds.push(keybind)
        (self, id)
    }

    fn get_suggestions(ref self, pattern: string) -> Vec<string> {
        let mut i = 0u64

        while i < self.completions.len() {
            let comp = self.completions.get(i)

            match comp {
                Some(c) => {
                    if c.pattern == pattern {
                        return c.suggestions
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        Vec::new()
    }

    fn list_keybinds(ref self) -> Vec<(string, string)> {
        let mut result = Vec::new()
        let mut i = 0u64

        while i < self.keybinds.len() {
            let kb = self.keybinds.get(i)

            match kb {
                Some(k) => {
                    result.push((k.key, k.action))
                }
                None => {}
            }

            i = i + 1u64
        }

        result
    }
}

fn main() {
    println!("=== zsh Phase 3: 자동완성 + 키바인딩 ===")

    let mut shell = SmartShell::new()
    println!("✨ 스마트 쉘 초기화")

    let (shell2, _) = shell.add_completion("git")
    shell = shell2
    println!("✅ git 자동완성 등록")

    let (shell2, _) = shell.add_completion("docker")
    shell = shell2
    println!("✅ docker 자동완성 등록")

    let (shell2, _) = shell.bind_key("C-u", "clear-line")
    shell = shell2
    println!("✅ Ctrl+U → clear-line")

    let (shell2, _) = shell.bind_key("C-r", "search-history")
    shell = shell2
    println!("✅ Ctrl+R → search-history")

    let suggestions = shell.get_suggestions("git")
    println!("\n💡 git 자동완성:")
    let mut i = 0u64
    while i < suggestions.len() {
        let sug = suggestions.get(i).unwrap()
        println!("  " ++ sug)
        i = i + 1u64
    }

    let keybinds = shell.list_keybinds()
    println!("\n⌨️  키바인딩:")
    let mut i = 0u64
    while i < keybinds.len() {
        let (key, action) = keybinds.get(i).unwrap()
        println!("  " ++ key ++ " → " ++ action)
        i = i + 1u64
    }
}
