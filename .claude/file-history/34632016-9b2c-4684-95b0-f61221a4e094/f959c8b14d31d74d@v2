// git Phase 1: 기본 커밋 관리
// 목표: 저장소 초기화, 커밋 생성, 커밋 히스토리 조회

type CommitID = u64
type Timestamp = u64
type AuthorName = string
type CommitMessage = string
type FilePath = string

enum FileStatus {
    Added      // 새로 추가됨
    Modified   // 수정됨
    Deleted    // 삭제됨
}

type FileChange {
    path: FilePath
    status: FileStatus
}

type Commit {
    id: CommitID
    author: AuthorName
    message: CommitMessage
    timestamp: Timestamp
    files: Vec<FileChange>
    parent_id: Option<CommitID>
}

type Repository {
    name: string
    commits: Vec<Commit>
    current_branch: string
    next_commit_id: CommitID
}

impl Repository {

    // 저장소 초기화
    fn init(name: string) -> Repository {
        Repository {
            name: name,
            commits: Vec::new(),
            current_branch: "main",
            next_commit_id: 1000u64
        }
    }

    // 커밋 생성
    fn commit(mut self, author: AuthorName, message: CommitMessage, files: Vec<FileChange>) -> (Repository, CommitID) {
        let commit_id = self.next_commit_id
        self.next_commit_id = self.next_commit_id + 1u64

        let now = get_timestamp()

        // 부모 커밋 ID 결정
        let parent_id = if self.commits.len() > 0u64 {
            let last_commit = self.commits.get(self.commits.len() - 1u64)
            match last_commit {
                Some(c) => {
                    Some(c.id)
                }
                None => {
                    None
                }
            }
        } else {
            None
        }

        let commit = Commit {
            id: commit_id,
            author: author,
            message: message,
            timestamp: now,
            files: files,
            parent_id: parent_id
        }

        self.commits.push(commit)
        (self, commit_id)
    }

    // 커밋 히스토리 조회
    fn log(ref self) -> Vec<(CommitID, AuthorName, CommitMessage, u64)> {
        let mut result = Vec::new()
        let mut i = 0u64

        while i < self.commits.len() {
            let commit = self.commits.get(i)

            match commit {
                Some(c) => {
                    result.push((c.id, c.author, c.message, c.files.len()))
                }
                None => {}
            }

            i = i + 1u64
        }

        result
    }

    // 특정 커밋 조회
    fn get_commit(ref self, commit_id: CommitID) -> Option<(CommitID, AuthorName, CommitMessage, Timestamp)> {
        let mut i = 0u64

        while i < self.commits.len() {
            let commit = self.commits.get(i)

            match commit {
                Some(c) => {
                    if c.id == commit_id {
                        return Some((c.id, c.author, c.message, c.timestamp))
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        None
    }

    // 변경 사항 상세 조회
    fn show_commit(ref self, commit_id: CommitID) -> Option<Vec<(FilePath, string)>> {
        let mut i = 0u64

        while i < self.commits.len() {
            let commit = self.commits.get(i)

            match commit {
                Some(c) => {
                    if c.id == commit_id {
                        let mut result = Vec::new()

                        let mut j = 0u64
                        while j < c.files.len() {
                            let file = c.files.get(j)

                            match file {
                                Some(f) => {
                                    let status_str = match f.status {
                                        FileStatus::Added => "added",
                                        FileStatus::Modified => "modified",
                                        FileStatus::Deleted => "deleted"
                                    }

                                    result.push((f.path, status_str))
                                }
                                None => {}
                            }

                            j = j + 1u64
                        }

                        return Some(result)
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        None
    }

    // 커밋 수
    fn commit_count(ref self) -> u64 {
        self.commits.len()
    }

    // 마지막 커밋 조회
    fn get_latest_commit(ref self) -> Option<(CommitID, AuthorName, CommitMessage)> {
        if self.commits.len() == 0u64 {
            return None
        }

        let last_idx = self.commits.len() - 1u64
        let commit = self.commits.get(last_idx)

        match commit {
            Some(c) => {
                Some((c.id, c.author, c.message))
            }
            None => {
                None
            }
        }
    }

    // 저장소 상태 조회
    fn status(ref self) -> string {
        let commit_count = self.commits.len()
        "On branch " ++ self.current_branch ++ " | " ++ commit_count.to_string() ++ " commits"
    }
}

// === Option 타입 ===

type Option<T> {
    Some(T)
    None
}

// === 유틸리티 ===

fn get_timestamp() -> Timestamp {
    12345678u64
}

// === 테스트 ===

fn main() {
    println!("=== git Phase 1: 기본 커밋 관리 ===")

    // 저장소 초기화
    let mut repo = Repository::init("my-project")
    println!("📁 저장소 초기화: my-project")

    // 첫 번째 커밋
    println!("\n📝 커밋 생성:")
    let mut files = Vec::new()
    files.push(FileChange {
        path: "README.md",
        status: FileStatus::Added
    })
    files.push(FileChange {
        path: "main.fl",
        status: FileStatus::Added
    })

    let (repo2, commit1_id) = repo.commit("kim@localhost", "Initial commit", files)
    repo = repo2
    println!("✅ 커밋 1 (ID: " ++ commit1_id.to_string() ++ ")")

    // 두 번째 커밋
    let mut files = Vec::new()
    files.push(FileChange {
        path: "main.fl",
        status: FileStatus::Modified
    })

    let (repo2, commit2_id) = repo.commit("kim@localhost", "Add core functionality", files)
    repo = repo2
    println!("✅ 커밋 2 (ID: " ++ commit2_id.to_string() ++ ")")

    // 세 번째 커밋
    let mut files = Vec::new()
    files.push(FileChange {
        path: "config.fl",
        status: FileStatus::Added
    })
    files.push(FileChange {
        path: "main.fl",
        status: FileStatus::Modified
    })

    let (repo2, commit3_id) = repo.commit("kim@localhost", "Add configuration system", files)
    repo = repo2
    println!("✅ 커밋 3 (ID: " ++ commit3_id.to_string() ++ ")")

    // 저장소 상태
    println!("\n📊 저장소 상태:")
    let status = repo.status()
    println!("  " ++ status)

    // 커밋 히스토리
    println!("\n📜 커밋 히스토리:")
    let log = repo.log()
    let mut i = 0u64
    while i < log.len() {
        let (id, author, msg, file_count) = log.get(i).unwrap()
        println!("  [" ++ id.to_string() ++ "] " ++ author ++ " - " ++ msg ++ " (" ++ file_count.to_string() ++ " 파일)")
        i = i + 1u64
    }

    // 마지막 커밋
    println!("\n🔝 마지막 커밋:")
    let latest = repo.get_latest_commit()
    match latest {
        Some((id, author, msg)) => {
            println!("  [" ++ id.to_string() ++ "] " ++ author ++ " - " ++ msg)
        }
        None => {
            println!("  (커밋 없음)")
        }
    }

    // 특정 커밋 상세 보기
    println!("\n🔍 커밋 2 상세:")
    let changes = repo.show_commit(commit2_id)
    match changes {
        Some(files) => {
            let mut j = 0u64
            while j < files.len() {
                let (path, status) = files.get(j).unwrap()
                println!("  " ++ status ++ ": " ++ path)
                j = j + 1u64
            }
        }
        None => {
            println!("  (커밋 없음)")
        }
    }

    // 커밋 수
    println!("\n📈 커밋 통계:")
    let count = repo.commit_count()
    println!("  총 커밋: " ++ count.to_string() ++ "개")
}
