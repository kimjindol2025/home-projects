// neovim Phase 3: 고급 편집 (레지스터, 북마크)
type RegisterID = u64
type BookmarkID = u64
type LineNumber = u64

type Register {
    id: RegisterID
    name: string
    content: string
}

type Bookmark {
    id: BookmarkID
    file: string
    line: LineNumber
}

type AdvancedEditor {
    registers: Vec<Register>
    bookmarks: Vec<Bookmark>
    undo_stack: Vec<string>
    next_register_id: RegisterID
    next_bookmark_id: BookmarkID
}

impl AdvancedEditor {
    fn new() -> AdvancedEditor {
        AdvancedEditor {
            registers: Vec::new(),
            bookmarks: Vec::new(),
            undo_stack: Vec::new(),
            next_register_id: 1000u64,
            next_bookmark_id: 100000u64
        }
    }

    fn yank_to_register(mut self, reg_name: string, content: string) -> AdvancedEditor {
        let id = self.next_register_id
        self.next_register_id = self.next_register_id + 1u64

        let register = Register {
            id: id,
            name: reg_name,
            content: content
        }

        self.registers.push(register)
        self
    }

    fn get_register(ref self, reg_name: string) -> Option<string> {
        let mut i = 0u64

        while i < self.registers.len() {
            let reg = self.registers.get(i)

            match reg {
                Some(r) => {
                    if r.name == reg_name {
                        return Some(r.content)
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        None
    }

    fn set_bookmark(mut self, file: string, line: LineNumber) -> (AdvancedEditor, BookmarkID) {
        let id = self.next_bookmark_id
        self.next_bookmark_id = self.next_bookmark_id + 1u64

        let bookmark = Bookmark {
            id: id,
            file: file,
            line: line
        }

        self.bookmarks.push(bookmark)
        (self, id)
    }

    fn list_bookmarks(ref self) -> Vec<(string, LineNumber)> {
        let mut result = Vec::new()
        let mut i = 0u64

        while i < self.bookmarks.len() {
            let bookmark = self.bookmarks.get(i)

            match bookmark {
                Some(b) => {
                    result.push((b.file, b.line))
                }
                None => {}
            }

            i = i + 1u64
        }

        result
    }

    fn push_undo(mut self, state: string) -> AdvancedEditor {
        self.undo_stack.push(state)
        self
    }

    fn undo(mut self) -> (AdvancedEditor, Option<string>) {
        if self.undo_stack.len() > 0u64 {
            let last_idx = self.undo_stack.len() - 1u64
            let state = self.undo_stack.get(last_idx)
            (self, state)
        } else {
            (self, None)
        }
    }
}

type Option<T> {
    Some(T)
    None
}

fn main() {
    println!("=== neovim Phase 3: 레지스터 + 북마크 ===")

    let mut editor = AdvancedEditor::new()
    println!("📝 고급 에디터 초기화")

    editor = editor.yank_to_register("a", "fn main() { println!(\"Hello\") }")
    println!("✅ 레지스터 a에 저장")

    editor = editor.yank_to_register("b", "import numpy as np")
    println!("✅ 레지스터 b에 저장")

    let content = editor.get_register("a")
    match content {
        Some(c) => println!("\n📋 레지스터 a: " ++ c)
        None => {}
    }

    let (editor2, bid1) = editor.set_bookmark("main.fl", 42u64)
    editor = editor2
    println!("\n🔖 북마크 1: main.fl:42")

    let (editor2, bid2) = editor.set_bookmark("utils.fl", 15u64)
    editor = editor2
    println!("🔖 북마크 2: utils.fl:15")

    let bookmarks = editor.list_bookmarks()
    println!("\n📌 북마크 목록:")
    let mut i = 0u64
    while i < bookmarks.len() {
        let (file, line) = bookmarks.get(i).unwrap()
        println!("  " ++ file ++ ":" ++ line.to_string())
        i = i + 1u64
    }

    editor = editor.push_undo("Original state")
    editor = editor.push_undo("After change 1")
    editor = editor.push_undo("After change 2")
    println!("\n↩️  undo 스택에 3개 상태 저장")
}
