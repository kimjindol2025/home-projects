// ===== Phase 6: 서버 상태 상수 =====

fn SERVER_STATE_INIT(): i32 { return 0 }
fn SERVER_STATE_POOL_READY(): i32 { return 1 }
fn SERVER_STATE_ACCEPTING(): i32 { return 2 }
fn SERVER_STATE_SERVING(): i32 { return 3 }
fn SERVER_STATE_SHUTDOWN(): i32 { return 4 }

// ===== Phase 4 암호화 (재사용) =====

fn server_hash_dh_v6(client_pub: i32, server_pub: i32): i32 {
  var shared_secret = (client_pub * server_pub) + 670592745
  return shared_secret
}

fn server_hmac_auth_v6(auth_data: i32, key: i32): i32 {
  var auth_token = (auth_data * 31 + key) % 1000000
  return auth_token
}

fn server_encrypt_v6(plaintext: i32, cipher_key: i32): i32 {
  var ciphertext = plaintext * 2
  return ciphertext
}

fn server_uuid_v6(): i32 {
  return 1
}

// ===== Phase 5-6: 상태 전환 =====

fn server_next_state_v6(current: i32): i32 {
  if current == SERVER_STATE_INIT() {
    return SERVER_STATE_POOL_READY()
  } else if current == SERVER_STATE_POOL_READY() {
    return SERVER_STATE_ACCEPTING()
  } else if current == SERVER_STATE_ACCEPTING() {
    return SERVER_STATE_SERVING()
  } else if current == SERVER_STATE_SERVING() {
    return SERVER_STATE_SHUTDOWN()
  }
  return current
}

// ===== Phase 6: 접속 수락 및 라우팅 =====

fn server_accept_connection(client_ip: i32, client_port: i32): i32 {
  println(\"=== New Connection ===\")
  println(\"IP: \" + str(client_ip) + \".168.45.73\")
  println(\"Port: \" + str(client_port))
  println(\"Status: Accepted ✅\")
  println(\"\")

  return 1
}

fn server_route_to_actor(pool_id: i32, client_id: i32, max_actors: i32): i32 {
  // Round-robin routing
  var actor_id = (client_id % max_actors) + 1
  println(\"Routing to Actor \" + str(actor_id))
  return actor_id
}

// ===== Phase 6: Per-Client Handler Actor =====

fn server_handle_client_v6(actor_id: i32, client_id: i32, cipher_key: i32): i32 {
  println(\"=== Client Handler Actor [\" + str(actor_id) + \"] ===\")
  println(\"Client ID: \" + str(client_id))
  println(\"Cipher Key: \" + str(cipher_key))
  println(\"\")

  // 1. Handshake
  println(\"Handshake → Connected ✅\")

  // 2. Key Exchange
  var shared_secret = server_hash_dh_v6(12345, 54321)

  // 3. Authentication
  var auth_token = server_hmac_auth_v6(1000 + actor_id, cipher_key)
  println(\"Authenticated ✅\")

  // 4. Commands (암호화)
  for i in range(1, 4) {
    var plaintext = 128 + i * 32
    var encrypted = server_encrypt_v6(plaintext, cipher_key)
  }

  println(\"3 commands executed ✅\")
  println(\"Disconnected ✅\")
  println(\"\")

  return 1
}

