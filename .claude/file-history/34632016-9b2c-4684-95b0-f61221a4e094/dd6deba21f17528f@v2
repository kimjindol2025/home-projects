// ===== Phase 6: 접속 처리 루프 =====

fn server_accept_clients_v6(pool_id: i32, max_clients: i32, num_simulated: i32): i32 {
  println(\"╔═══════════════════════════════════════╗\")
  println(\"║  Accepting Clients (Phase 6)          ║\")
  println(\"║  Actor Pool: \" + str(max_clients) + \" capacity\")
  println(\"╚═══════════════════════════════════════╝\")
  println(\"\")

  println(\"=== Simulating Client Connections ===\")
  println(\"Accepting \" + str(num_simulated) + \" concurrent clients...\")
  println(\"\")

  var active_connections = 0

  for i in range(1, num_simulated + 1) {
    var client_ip = 192
    var client_port = 50000 + i
    var client_id = i

    // Accept connection
    server_accept_connection(client_ip, client_port)

    // Route to actor
    var actor_id = server_route_to_actor(pool_id, client_id, max_clients)

    // Handle client (암호화 통합)
    var cipher_key = 100000000 + actor_id
    var result = server_handle_client_v6(actor_id, client_id, cipher_key)

    active_connections = i
  }

  println(\"=== Active Connections ===\")
  println(\"Total: \" + str(active_connections))
  println(\"All handled by Actor Pool ✅\")
  println(\"\")

  return active_connections
}

// ===== Phase 6: 서버 통계 =====

fn server_print_statistics_v6(max_actors: i32, active_clients: i32): i32 {
  println(\"╔═══════════════════════════════════════╗\")
  println(\"║  Server Statistics (Phase 6)          ║\")
  println(\"╚═══════════════════════════════════════╝\")
  println(\"\")

  println(\"=== Pool Statistics ===\")
  println(\"Max Capacity: \" + str(max_actors) + \" actors\")
  println(\"Active Clients: \" + str(active_clients))
  println(\"Idle Actors: \" + str(max_actors - active_clients))
  println(\"\")

  println(\"=== Load Analysis ===\")
  var utilization = (active_clients * 100) / max_actors
  println(\"Utilization: \" + str(utilization) + \"%\")
  println(\"Avg per Actor: \" + str(active_clients / max_actors))
  println(\"\")

  println(\"=== Encryption ===\")
  var total_encrypted = active_clients * 3 * 256
  println(\"Total data encrypted: \" + str(total_encrypted) + \" bytes (100%)\")
  println(\"Per-session keys: \" + str(active_clients))
  println(\"\")

  println(\"=== Performance ===\")
  println(\"Throughput: \" + str(active_clients) + \" concurrent sessions\")
  println(\"Response time: Per-actor isolated\")
  println(\"Memory: ~\" + str(active_clients * 10) + \"KB (actors)\")
  println(\"\")

  return utilization
}

