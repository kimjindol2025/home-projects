}

// ===== Phase 1: 세션 종료 (정리) =====

fn close_session(): i32 {
  println("╔═══════════════════════════════════════╗")
  println("║   Closing Session                     ║")
  println("╚═══════════════════════════════════════╝")
  println("")

  println("=== SSH Disconnect ===")
  println("Reason: User requested")
  println("Commands executed in session: " + str(commands_executed))
  println("")

  println("Cleaning up...")
  current_user = 0
  session_id = 0
  commands_executed = 0

  transition_session_state(SESSION_STATE_CLOSED())
  println("State: CLOSED")
  println("✅ Session terminated")
  println("✅ Connection closed")
  println("")

  return 1
}

