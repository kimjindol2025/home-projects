// 🔐 FreeLang SSH Interactive Session v2.0
// Phase 1-3: 타입 안전성 + 상태 머신 + 명령 관리

// ===== Phase 1: 상수 정의 =====

fn SESSION_STATE_DISCONNECTED(): i32 { return 0 }
fn SESSION_STATE_CONNECTING(): i32 { return 1 }
fn SESSION_STATE_AUTHENTICATED(): i32 { return 2 }
fn SESSION_STATE_READY(): i32 { return 3 }
fn SESSION_STATE_CLOSED(): i32 { return 4 }

fn CMD_LS(): i32 { return 1 }
fn CMD_PWD(): i32 { return 2 }
fn CMD_WHOAMI(): i32 { return 3 }
fn CMD_UPTIME(): i32 { return 4 }
fn CMD_DATE(): i32 { return 5 }
fn CMD_GIT(): i32 { return 6 }
fn CMD_NPM(): i32 { return 7 }
fn CMD_NODE(): i32 { return 8 }
fn CMD_CAT(): i32 { return 9 }
fn CMD_EXIT(): i32 { return 0 }

// ===== Phase 2: 세션 상태 관리 =====

var session_state = SESSION_STATE_DISCONNECTED()
var remote_host = 192
var remote_port = 22
var current_user = 0
var session_start = 1708416000
var commands_executed = 0
var session_id = 0
var connected = 0

// ===== Phase 1: 상태 검증 함수 =====

fn is_session_ready(): i32 {
  if session_state == SESSION_STATE_READY() {
    return 1
  }
  return 0
}

fn can_execute_command(): i32 {
  if session_state == SESSION_STATE_AUTHENTICATED() {
    return 1
  }
  if session_state == SESSION_STATE_READY() {
    return 1
  }
  return 0
}

// ===== Phase 2: 세션 상태 전환 =====

fn transition_session_state(new_state: i32): i32 {
  if new_state >= SESSION_STATE_DISCONNECTED() {
    if new_state <= SESSION_STATE_CLOSED() {
      session_state = new_state
      return 1
    }
  }
  return 0
}

// ===== Phase 1: 연결 초기화 =====

fn init_session(host: i32, port: i32, user: i32): i32 {
  println("╔═══════════════════════════════════════╗")
  println("║   SSH Session v2.0 (Interactive)      ║")
  println("║  Phase 1-3 State Management           ║")
  println("╚═══════════════════════════════════════╝")
  println("")

  println("=== SSH Connection ===")
  println("Connecting to kim@" + str(host) + ".168.45.73:" + str(port) + "...")

  remote_host = host
  remote_port = port
  current_user = user
  session_id = 12345

  transition_session_state(SESSION_STATE_CONNECTING())
  println("State: CONNECTING")
  println("Connection ID: " + str(session_id))
  println("")

  println("=== SSH Authentication ===")
  println("User: kim")
  println("Auth Method: password")
  println("✅ Connected")
  println("✅ Authenticated (password)")
  println("")

  transition_session_state(SESSION_STATE_AUTHENTICATED())
  println("State: AUTHENTICATED")
  println("")

  transition_session_state(SESSION_STATE_READY())
  println("State: READY")
  println("Shell prompt available")
  println("")

  return 1
}

// ===== Phase 3: 명령 처리 (상태 검증 포함) =====

fn execute_command(cmd: i32): i32 {
  if can_execute_command() == 0 {
    println("ERROR: Session not ready")
    return 0
  }

  if cmd == CMD_LS() {
    println("$ ls -la")
    println("total 256")
    println("-rw-r--r-- 1 kim kim 1024 Feb 20 client-v2.fl")
    println("-rw-r--r-- 1 kim kim 2048 Feb 20 server-v2.fl")
    println("-rw-r--r-- 1 kim kim 1536 Feb 20 interactive-v2.fl")
    println("drwx------ 2 kim kim 4096 Feb 20 examples/")
    commands_executed = commands_executed + 1
    return 1

  } else if cmd == CMD_PWD() {
    println("$ pwd")
    println("/home/kim/freelang-v4")
    commands_executed = commands_executed + 1
    return 1

  } else if cmd == CMD_WHOAMI() {
    println("$ whoami")
    println("kim")
    commands_executed = commands_executed + 1
    return 1

  } else if cmd == CMD_UPTIME() {
    println("$ uptime")
    println(" 12:34:56 up 2 days, 15:34, load average: 0.25, 0.18, 0.12")
    commands_executed = commands_executed + 1
    return 1

  } else if cmd == CMD_DATE() {
    println("$ date")
    println("Thu Feb 20 12:34:56 UTC 2025")
    commands_executed = commands_executed + 1
    return 1

  } else if cmd == CMD_GIT() {
    println("$ git status")
    println("On branch main")
    println("Your branch is up to date with 'origin/main'.")
    println("nothing to commit, working tree clean")
    commands_executed = commands_executed + 1
    return 1

  } else if cmd == CMD_NPM() {
    println("$ npm run build")
    println("> freelang-v4@4.0.0 build")
    println("> tsc")
    println("✅ Build successful (54 files)")
    commands_executed = commands_executed + 1
    return 1

  } else if cmd == CMD_NODE() {
    println("$ node -v")
    println("v20.10.0")
    commands_executed = commands_executed + 1
    return 1

  } else if cmd == CMD_CAT() {
    println("$ cat package.json | grep name")
    println("  \"name\": \"freelang-v4\",")
    commands_executed = commands_executed + 1
    return 1

  } else if cmd == CMD_EXIT() {
    println("$ exit")
    println("Goodbye!")
    commands_executed = commands_executed + 1
    return 0

  } else {
    println("$ unknown command")
    println("command not found")
    return 0
  }
}

// ===== Phase 2: 대화형 세션 루프 (상태 머신) =====

fn run_interactive_session(): i32 {
  println("╔═══════════════════════════════════════╗")
  println("║   Interactive Command Loop             ║")
  println("║   State: READY (Phase 2)               ║")
  println("╚═══════════════════════════════════════╝")
  println("")

  println("Available commands:")
  println("  1 = ls -la")
  println("  2 = pwd")
  println("  3 = whoami")
  println("  4 = uptime")
  println("  5 = date")
  println("  6 = git status")
  println("  7 = npm run build")
  println("  8 = node -v")
  println("  9 = cat package.json")
  println("  0 = exit")
  println("")

  // 명령 실행 루프
  var loop_count = 0
  for i in range(1, 10) {
    println("=== Command " + str(i) + " ===")
    var result = execute_command(i)
    println("")
    loop_count = i
  }

  return loop_count
}

// ===== Phase 1: 세션 통계 =====

