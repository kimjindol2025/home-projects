// nmap Phase 1: 기본 네트워크 스캔
type ScanID = u64
type Timestamp = u64
type HostAddress = string
type PortNumber = u64

enum ScanType {
    SynScan
    ConnectScan
    UdpScan
}

type Port {
    number: PortNumber
    status: string
    service: string
}

type HostScan {
    id: ScanID
    target: HostAddress
    scan_type: ScanType
    ports: Vec<Port>
    started_at: Timestamp
}

type Scanner {
    scans: Vec<HostScan>
    next_scan_id: ScanID
}

impl Scanner {
    fn new() -> Scanner {
        Scanner {
            scans: Vec::new(),
            next_scan_id: 1000u64
        }
    }

    fn start_scan(mut self, target: HostAddress, scan_type: ScanType) -> (Scanner, ScanID) {
        let scan_id = self.next_scan_id
        self.next_scan_id = self.next_scan_id + 1u64

        let scan = HostScan {
            id: scan_id,
            target: target,
            scan_type: scan_type,
            ports: Vec::new(),
            started_at: get_timestamp()
        }

        self.scans.push(scan)
        (self, scan_id)
    }

    fn add_port_result(mut self, scan_id: ScanID, port: PortNumber, status: string, service: string) -> Scanner {
        let mut i = 0u64

        while i < self.scans.len() {
            let scan = self.scans.get(i)

            match scan {
                Some(s) => {
                    if s.id == scan_id {
                        let mut updated = HostScan {
                            id: s.id,
                            target: s.target,
                            scan_type: s.scan_type,
                            ports: s.ports,
                            started_at: s.started_at
                        }

                        updated.ports.push(Port {
                            number: port,
                            status: status,
                            service: service
                        })

                        self.scans.set(i, updated)
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        self
    }

    fn get_open_ports(ref self, scan_id: ScanID) -> Vec<(PortNumber, string)> {
        let mut result = Vec::new()
        let mut i = 0u64

        while i < self.scans.len() {
            let scan = self.scans.get(i)

            match scan {
                Some(s) => {
                    if s.id == scan_id {
                        let mut j = 0u64
                        while j < s.ports.len() {
                            let port = s.ports.get(j)

                            match port {
                                Some(p) => {
                                    if p.status == "open" {
                                        result.push((p.number, p.service))
                                    }
                                }
                                None => {}
                            }

                            j = j + 1u64
                        }
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        result
    }

    fn list_scans(ref self) -> Vec<(ScanID, HostAddress, u64)> {
        let mut result = Vec::new()
        let mut i = 0u64

        while i < self.scans.len() {
            let scan = self.scans.get(i)

            match scan {
                Some(s) => {
                    result.push((s.id, s.target, s.ports.len()))
                }
                None => {}
            }

            i = i + 1u64
        }

        result
    }
}

fn get_timestamp() -> Timestamp { 12345678u64 }

fn main() {
    println!("=== nmap Phase 1: 기본 스캔 ===")

    let mut scanner = Scanner::new()
    println!("🔍 스캐너 초기화")

    let (scanner2, scan1) = scanner.start_scan("192.168.1.1", ScanType::SynScan)
    scanner = scanner2
    println!("✅ 192.168.1.1 스캔 시작")

    scanner = scanner.add_port_result(scan1, 22u64, "open", "ssh")
    scanner = scanner.add_port_result(scan1, 80u64, "open", "http")
    scanner = scanner.add_port_result(scan1, 443u64, "open", "https")
    scanner = scanner.add_port_result(scan1, 3306u64, "closed", "mysql")
    println!("✅ 포트 스캔 결과 추가")

    let (scanner2, scan2) = scanner.start_scan("10.0.0.1", ScanType::ConnectScan)
    scanner = scanner2
    println!("✅ 10.0.0.1 스캔 시작")

    scanner = scanner.add_port_result(scan2, 22u64, "open", "ssh")
    scanner = scanner.add_port_result(scan2, 8080u64, "open", "http-alt")
    println!("✅ 포트 스캔 결과 추가")

    let open_ports = scanner.get_open_ports(scan1)
    println!("\n🔓 열린 포트 (192.168.1.1):")
    let mut i = 0u64
    while i < open_ports.len() {
        let (port, service) = open_ports.get(i).unwrap()
        println!("  " ++ port.to_string() ++ " - " ++ service)
        i = i + 1u64
    }

    let scans = scanner.list_scans()
    println!("\n📋 스캔 목록:")
    let mut i = 0u64
    while i < scans.len() {
        let (id, target, port_count) = scans.get(i).unwrap()
        println!("  [" ++ id.to_string() ++ "] " ++ target ++ " (" ++ port_count.to_string() ++ " 포트)")
        i = i + 1u64
    }
}
