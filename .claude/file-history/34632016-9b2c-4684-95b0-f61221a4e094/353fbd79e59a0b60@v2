// tmux Phase 3: 고급 기능 (자동화, 바인딩, 설정)
// 목표: 키 바인딩, 커스텀 설정, 세션 자동 생성 스크립트

// === Phase 2 타입 확장 ===

type SessionID = u64
type WindowID = u64
type PaneID = u64
type SessionName = string
type WindowName = string
type Timestamp = u64

enum SplitDirection {
    Horizontal
    Vertical
}

enum SessionState {
    Active(Timestamp)
    Detached(Timestamp)
    Terminated
}

enum KeyBinding {
    CreateWindow       // c
    NextWindow         // n
    PrevWindow         // p
    SplitHorizontal    // "
    SplitVertical      // %
    DetachSession      // d
    ScrollMode         // [
    CommandMode        // :
    Custom(string)
}

type Config {
    prefix: string
    base_index: u64
    mouse_enabled: bool
    default_terminal: string
    status_bg: string
    status_fg: string
}

type Pane {
    id: PaneID
    content: string
    created_at: Timestamp
    focused: bool
}

type Window {
    id: WindowID
    name: WindowName
    panes: Vec<Pane>
    active_pane_index: u64
    created_at: Timestamp
}

type Session {
    id: SessionID
    name: SessionName
    state: SessionState
    windows: Vec<Window>
    active_window_index: u64
    created_at: Timestamp
}

// === 향상된 세션 관리자 (설정 + 바인딩 지원) ===

type SessionManager {
    sessions: Vec<Session>
    config: Config
    key_bindings: Vec<(KeyBinding, string)>
    next_session_id: SessionID
    next_window_id: WindowID
    next_pane_id: PaneID
    command_history: Vec<string>
}

impl SessionManager {

    fn new() -> SessionManager {
        let default_config = Config {
            prefix: "C-a",
            base_index: 1u64,
            mouse_enabled: true,
            default_terminal: "screen-256color",
            status_bg: "black",
            status_fg: "white"
        }

        let mut bindings = Vec::new()
        bindings.push((KeyBinding::CreateWindow, "c"))
        bindings.push((KeyBinding::NextWindow, "n"))
        bindings.push((KeyBinding::PrevWindow, "p"))
        bindings.push((KeyBinding::SplitHorizontal, "\""))
        bindings.push((KeyBinding::SplitVertical, "%"))
        bindings.push((KeyBinding::DetachSession, "d"))
        bindings.push((KeyBinding::ScrollMode, "["))
        bindings.push((KeyBinding::CommandMode, ":"))

        SessionManager {
            sessions: Vec::new(),
            config: default_config,
            key_bindings: bindings,
            next_session_id: 1000u64,
            next_window_id: 10000u64,
            next_pane_id: 100000u64,
            command_history: Vec::new()
        }
    }

    // 설정 업데이트
    fn set_config(mut self, new_config: Config) -> SessionManager {
        self.config = new_config
        self
    }

    // 키 바인딩 커스터마이징
    fn bind_key(mut self, binding: KeyBinding, key: string) -> SessionManager {
        self.key_bindings.push((binding, key))
        self
    }

    // 커맨드 실행 및 히스토리 기록
    fn execute_command(mut self, cmd: string) -> (SessionManager, string) {
        self.command_history.push(cmd)

        let result = match cmd {
            "list-sessions" => "Session list requested",
            "list-windows" => "Window list requested",
            "show-config" => "Configuration requested",
            "show-bindings" => "Key bindings requested",
            _ => "Unknown command"
        }

        (self, result)
    }

    // 세션 생성
    fn create_session(mut self, name: SessionName) -> (SessionManager, SessionID) {
        let session_id = self.next_session_id
        self.next_session_id = self.next_session_id + 1u64

        let window_id = self.next_window_id
        self.next_window_id = self.next_window_id + 1u64

        let pane_id = self.next_pane_id
        self.next_pane_id = self.next_pane_id + 1u64

        let now = get_timestamp()

        let pane = Pane {
            id: pane_id,
            content: "",
            created_at: now,
            focused: true
        }

        let mut panes = Vec::new()
        panes.push(pane)

        let window = Window {
            id: window_id,
            name: "default",
            panes: panes,
            active_pane_index: 0u64,
            created_at: now
        }

        let mut windows = Vec::new()
        windows.push(window)

        let session = Session {
            id: session_id,
            name: name,
            state: SessionState::Active(now),
            windows: windows,
            active_window_index: 0u64,
            created_at: now
        }

        self.sessions.push(session)
        (self, session_id)
    }

    // 세션 자동 생성 스크립트
    fn create_session_batch(mut self, names: Vec<SessionName>) -> (SessionManager, u64) {
        let mut count = 0u64
        let mut i = 0u64

        while i < names.len() {
            let name = names.get(i)
            match name {
                Some(n) => {
                    let (mgr2, _) = self.create_session(n)
                    self = mgr2
                    count = count + 1u64
                }
                None => {}
            }
            i = i + 1u64
        }

        (self, count)
    }

    // 설정 조회
    fn get_config(ref self) -> (string, u64, bool, string) {
        (
            self.config.prefix,
            self.config.base_index,
            self.config.mouse_enabled,
            self.config.default_terminal
        )
    }

    // 바인딩 조회
    fn get_bindings(ref self) -> Vec<(string, string)> {
        let mut result = Vec::new()
        let mut i = 0u64

        while i < self.key_bindings.len() {
            let (binding, key) = self.key_bindings.get(i).unwrap()

            let binding_name = match binding {
                KeyBinding::CreateWindow => "create-window",
                KeyBinding::NextWindow => "next-window",
                KeyBinding::PrevWindow => "prev-window",
                KeyBinding::SplitHorizontal => "split-horizontal",
                KeyBinding::SplitVertical => "split-vertical",
                KeyBinding::DetachSession => "detach-session",
                KeyBinding::ScrollMode => "scroll-mode",
                KeyBinding::CommandMode => "command-mode",
                KeyBinding::Custom(s) => s
            }

            result.push((binding_name, key))
            i = i + 1u64
        }

        result
    }

    // 커맨드 히스토리 조회
    fn get_history(ref self) -> Vec<string> {
        self.command_history
    }

    // 상태바 정보 생성
    fn get_status_bar(ref self) -> string {
        let active_sessions = self.count_active_sessions()
        "Prefix: " ++ self.config.prefix ++ " | Sessions: " ++ active_sessions.to_string()
    }

    // 활성 세션 수 계산
    fn count_active_sessions(ref self) -> u64 {
        let mut count = 0u64
        let mut i = 0u64

        while i < self.sessions.len() {
            let sess = self.sessions.get(i)
            match sess {
                Some(s) => {
                    match s.state {
                        SessionState::Active(_) => {
                            count = count + 1u64
                        }
                        _ => {}
                    }
                }
                None => {}
            }
            i = i + 1u64
        }

        count
    }
}

// === 세션 빌더 (Fluent API) ===

type SessionBuilder {
    mgr: SessionManager
    session_id: SessionID
}

impl SessionBuilder {

    fn new(mgr: SessionManager, session_id: SessionID) -> SessionBuilder {
        SessionBuilder {
            mgr: mgr,
            session_id: session_id
        }
    }

    fn with_window(self, window_name: WindowName) -> SessionBuilder {
        let (mgr2, _) = self.mgr.create_window(self.session_id, window_name)
        SessionBuilder {
            mgr: mgr2,
            session_id: self.session_id
        }
    }

    fn build(self) -> SessionManager {
        self.mgr
    }
}

// === 유틸리티 ===

fn get_timestamp() -> Timestamp {
    12345678u64
}

// === 테스트 ===

fn main() {
    println!("=== tmux Phase 3: 고급 기능 ===")

    let mut mgr = SessionManager::new()

    // 커스텀 설정
    println!("⚙️  설정 변경:")
    let custom_config = Config {
        prefix: "C-a",
        base_index: 1u64,
        mouse_enabled: true,
        default_terminal: "screen-256color",
        status_bg: "blue",
        status_fg: "white"
    }
    mgr = mgr.set_config(custom_config)
    println!("✅ 설정 업데이트 완료")

    // 커스텀 바인딩
    println!("\n🔑 키 바인딩 추가:")
    mgr = mgr.bind_key(KeyBinding::Custom("reload-config"), "r")
    mgr = mgr.bind_key(KeyBinding::Custom("list-commands"), "?")
    println!("✅ 커스텀 바인딩 추가 완료")

    // 세션 자동 생성
    println!("\n📦 배치 세션 생성:")
    let mut session_names = Vec::new()
    session_names.push("frontend")
    session_names.push("backend")
    session_names.push("database")

    let (mgr2, created) = mgr.create_session_batch(session_names)
    mgr = mgr2
    println!("✅ " ++ created.to_string() ++ "개 세션 생성")

    // Fluent API로 세션 구성
    println!("\n🏗️  Fluent API로 세션 구성:")
    let (mgr2, sess_id) = mgr.create_session("dev")
    mgr = mgr2

    let builder = SessionBuilder::new(mgr, sess_id)
    let builder = builder.with_window("editor")
    let builder = builder.with_window("server")
    let builder = builder.with_window("logs")
    mgr = builder.build()
    println!("✅ 세션 구성 완료 (3개 윈도우)")

    // 설정 조회
    println!("\n⚙️  현재 설정:")
    let (prefix, base_idx, mouse, terminal) = mgr.get_config()
    println!("  Prefix: " ++ prefix)
    println!("  Base Index: " ++ base_idx.to_string())
    println!("  Mouse: " ++ (if mouse { "enabled" } else { "disabled" }))
    println!("  Terminal: " ++ terminal)

    // 바인딩 조회
    println!("\n🔑 현재 바인딩:")
    let bindings = mgr.get_bindings()
    let mut i = 0u64
    while i < bindings.len() {
        let (name, key) = bindings.get(i).unwrap()
        println!("  " ++ key ++ " → " ++ name)
        i = i + 1u64
    }

    // 커맨드 실행
    println!("\n💬 커맨드 실행:")
    let (mgr2, result) = mgr.execute_command("show-bindings")
    mgr = mgr2
    println!("✅ " ++ result)

    let (mgr2, result) = mgr.execute_command("list-sessions")
    mgr = mgr2
    println!("✅ " ++ result)

    // 상태바
    println!("\n📊 상태바:")
    let status = mgr.get_status_bar()
    println!("  " ++ status)

    // 활성 세션 수
    let active = mgr.count_active_sessions()
    println!("\n📈 활성 세션: " ++ active.to_string() ++ "개")
}
