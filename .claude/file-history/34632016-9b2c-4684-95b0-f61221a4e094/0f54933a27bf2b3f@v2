// python Phase 2: 의존성 관리 및 가상환경
// 목표: 의존성 해석, 가상환경 생성/관리, requirements.txt

type PackageID = u64
type EnvironmentID = u64
type Timestamp = u64
type PackageName = string
type Version = string
type EnvironmentName = string

enum PackageStatus {
    Available
    Installed
    Outdated
    Broken
}

type Package {
    id: PackageID
    name: PackageName
    version: Version
    status: PackageStatus
    installed_at: Timestamp
    size: u64
}

type Dependency {
    package_name: PackageName
    version_constraint: string
}

type VirtualEnvironment {
    id: EnvironmentID
    name: EnvironmentName
    python_version: string
    packages: Vec<PackageID>
    created_at: Timestamp
    active: bool
}

type PackageManager {
    packages: Vec<Package>
    environments: Vec<VirtualEnvironment>
    dependencies: Vec<(PackageID, Vec<Dependency>)>
    next_package_id: PackageID
    next_env_id: EnvironmentID
}

impl PackageManager {

    fn new() -> PackageManager {
        PackageManager {
            packages: Vec::new(),
            environments: Vec::new(),
            dependencies: Vec::new(),
            next_package_id: 1000u64,
            next_env_id: 100000u64
        }
    }

    // 패키지 등록
    fn register_package(mut self, name: PackageName, version: Version, size: u64) -> (PackageManager, PackageID) {
        let package_id = self.next_package_id
        self.next_package_id = self.next_package_id + 1u64

        let package = Package {
            id: package_id,
            name: name,
            version: version,
            status: PackageStatus::Available,
            installed_at: 0u64,
            size: size
        }

        self.packages.push(package)
        (self, package_id)
    }

    // 의존성 추가
    fn add_dependency(mut self, package_id: PackageID, dep_name: PackageName, version_constraint: string) -> PackageManager {
        let mut found = false
        let mut i = 0u64

        while i < self.dependencies.len() {
            let (pkg_id, deps) = self.dependencies.get(i).unwrap()

            if pkg_id == package_id {
                let mut new_deps = deps
                new_deps.push(Dependency {
                    package_name: dep_name,
                    version_constraint: version_constraint
                })

                self.dependencies.set(i, (pkg_id, new_deps))
                found = true
            }

            i = i + 1u64
        }

        if !found {
            let mut deps = Vec::new()
            deps.push(Dependency {
                package_name: dep_name,
                version_constraint: version_constraint
            })
            self.dependencies.push((package_id, deps))
        }

        self
    }

    // 의존성 조회
    fn get_dependencies(ref self, package_id: PackageID) -> Vec<(PackageName, string)> {
        let mut result = Vec::new()
        let mut i = 0u64

        while i < self.dependencies.len() {
            let (pkg_id, deps) = self.dependencies.get(i).unwrap()

            if pkg_id == package_id {
                let mut j = 0u64
                while j < deps.len() {
                    let dep = deps.get(j).unwrap()
                    result.push((dep.package_name, dep.version_constraint))
                    j = j + 1u64
                }
            }

            i = i + 1u64
        }

        result
    }

    // 가상환경 생성
    fn create_venv(mut self, env_name: EnvironmentName, python_version: string) -> (PackageManager, EnvironmentID) {
        let env_id = self.next_env_id
        self.next_env_id = self.next_env_id + 1u64

        let venv = VirtualEnvironment {
            id: env_id,
            name: env_name,
            python_version: python_version,
            packages: Vec::new(),
            created_at: get_timestamp(),
            active: false
        }

        self.environments.push(venv)
        (self, env_id)
    }

    // 가상환경 활성화
    fn activate_venv(mut self, env_id: EnvironmentID) -> (PackageManager, bool) {
        let mut found = false
        let mut i = 0u64

        while i < self.environments.len() {
            let env = self.environments.get(i)

            match env {
                Some(e) => {
                    if e.id == env_id {
                        let updated = VirtualEnvironment {
                            id: e.id,
                            name: e.name,
                            python_version: e.python_version,
                            packages: e.packages,
                            created_at: e.created_at,
                            active: true
                        }
                        self.environments.set(i, updated)
                        found = true
                    } else {
                        let updated = VirtualEnvironment {
                            id: e.id,
                            name: e.name,
                            python_version: e.python_version,
                            packages: e.packages,
                            created_at: e.created_at,
                            active: false
                        }
                        self.environments.set(i, updated)
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        (self, found)
    }

    // 가상환경에 패키지 설치
    fn install_to_venv(mut self, env_id: EnvironmentID, package_id: PackageID) -> (PackageManager, bool) {
        let mut found = false
        let mut i = 0u64

        while i < self.environments.len() {
            let env = self.environments.get(i)

            match env {
                Some(e) => {
                    if e.id == env_id {
                        let mut updated = VirtualEnvironment {
                            id: e.id,
                            name: e.name,
                            python_version: e.python_version,
                            packages: e.packages,
                            created_at: e.created_at,
                            active: e.active
                        }

                        let mut already_installed = false
                        let mut j = 0u64

                        while j < updated.packages.len() {
                            let pkg = updated.packages.get(j)
                            if pkg == package_id {
                                already_installed = true
                            }
                            j = j + 1u64
                        }

                        if !already_installed {
                            updated.packages.push(package_id)
                        }

                        self.environments.set(i, updated)
                        found = true
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        (self, found)
    }

    // 가상환경 목록
    fn list_venvs(ref self) -> Vec<(EnvironmentID, EnvironmentName, string, u64, bool)> {
        let mut result = Vec::new()
        let mut i = 0u64

        while i < self.environments.len() {
            let env = self.environments.get(i)

            match env {
                Some(e) => {
                    result.push((e.id, e.name, e.python_version, e.packages.len(), e.active))
                }
                None => {}
            }

            i = i + 1u64
        }

        result
    }

    // 가상환경의 패키지 조회
    fn get_venv_packages(ref self, env_id: EnvironmentID) -> Vec<PackageID> {
        let mut i = 0u64

        while i < self.environments.len() {
            let env = self.environments.get(i)

            match env {
                Some(e) => {
                    if e.id == env_id {
                        return e.packages
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        Vec::new()
    }

    // requirements.txt 생성
    fn generate_requirements(ref self, env_id: EnvironmentID) -> string {
        let packages = self.get_venv_packages(env_id)
        let mut reqs = ""
        let mut i = 0u64

        while i < packages.len() {
            let pkg_id = packages.get(i)

            match pkg_id {
                Some(id) => {
                    let mut j = 0u64
                    while j < self.packages.len() {
                        let pkg = self.packages.get(j)

                        match pkg {
                            Some(p) => {
                                if p.id == id {
                                    reqs = reqs ++ p.name ++ "==" ++ p.version ++ "\n"
                                }
                            }
                            None => {}
                        }

                        j = j + 1u64
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        reqs
    }
}

// === 유틸리티 ===

fn get_timestamp() -> Timestamp {
    12345678u64
}

// === 테스트 ===

fn main() {
    println!("=== python Phase 2: 의존성 관리 + 가상환경 ===")

    let mut pm = PackageManager::new()
    println!("📦 패키지 매니저 초기화")

    // 패키지 등록
    println!("\n📝 패키지 등록:")
    let (pm2, pkg_flask) = pm.register_package("flask", "2.3.0", 10485760u64)
    pm = pm2
    let (pm2, pkg_werkzeug) = pm.register_package("werkzeug", "2.3.0", 2097152u64)
    pm = pm2
    let (pm2, pkg_jinja) = pm.register_package("jinja2", "3.1.0", 1048576u64)
    pm = pm2
    println!("✅ flask, werkzeug, jinja2 등록")

    // 의존성 추가
    println!("\n🔗 의존성 추가:")
    pm = pm.add_dependency(pkg_flask, "werkzeug", ">=2.0")
    pm = pm.add_dependency(pkg_flask, "jinja2", ">=3.0")
    println!("✅ flask → werkzeug, jinja2")

    // 의존성 조회
    println!("\n 의존성 조회 (flask):")
    let deps = pm.get_dependencies(pkg_flask)
    let mut i = 0u64
    while i < deps.len() {
        let (name, constraint) = deps.get(i).unwrap()
        println!("  - " ++ name ++ " " ++ constraint)
        i = i + 1u64
    }

    // 가상환경 생성
    println!("\n🔨 가상환경 생성:")
    let (pm2, venv_dev) = pm.create_venv("dev", "3.10")
    pm = pm2
    println!("✅ dev 환경 (Python 3.10)")

    let (pm2, venv_prod) = pm.create_venv("prod", "3.10")
    pm = pm2
    println!("✅ prod 환경 (Python 3.10)")

    // 가상환경 활성화
    println!("\n✨ 가상환경 활성화:")
    let (pm2, success) = pm.activate_venv(venv_dev)
    pm = pm2
    println!("✅ dev 활성화")

    // 가상환경에 패키지 설치
    println!("\n📥 패키지 설치 (dev 환경):")
    let (pm2, success) = pm.install_to_venv(venv_dev, pkg_flask)
    pm = pm2
    println!("✅ flask 설치")

    let (pm2, success) = pm.install_to_venv(venv_dev, pkg_werkzeug)
    pm = pm2
    println!("✅ werkzeug 설치")

    let (pm2, success) = pm.install_to_venv(venv_dev, pkg_jinja)
    pm = pm2
    println!("✅ jinja2 설치")

    // prod 환경에만 flask 설치
    let (pm2, success) = pm.install_to_venv(venv_prod, pkg_flask)
    pm = pm2
    println!("✅ flask 설치 (prod)")

    // 가상환경 목록
    println!("\n📋 가상환경 목록:")
    let venvs = pm.list_venvs()
    let mut i = 0u64
    while i < venvs.len() {
        let (id, name, py_ver, pkg_count, active) = venvs.get(i).unwrap()
        let marker = if active { "* " } else { "  " }
        println!(marker ++ name ++ " (Python " ++ py_ver ++ ", " ++ pkg_count.to_string() ++ " 패키지)")
        i = i + 1u64
    }

    // requirements.txt 생성
    println!("\n📄 requirements.txt 생성:")
    let reqs = pm.generate_requirements(venv_dev)
    println!("dev 환경:")
    println!(reqs)

    let reqs_prod = pm.generate_requirements(venv_prod)
    println!("prod 환경:")
    println!(reqs_prod)
}
