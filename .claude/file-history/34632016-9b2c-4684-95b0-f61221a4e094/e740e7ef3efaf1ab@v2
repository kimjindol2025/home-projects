## 사용 예제

### 예제 1: 기본 CRUD

```freelang
fn main() {
    // 1. 스키마 정의
    db_define("users", {
        id: "u64",
        name: "string",
        email: "string",
        age: "u32"
    }).unwrap()

    // 2. 생성
    let user = db_insert("users", {
        name: "Alice",
        email: "alice@example.com",
        age: 28u32
    }).unwrap()

    let user_id = user.id

    // 3. 읽기
    let found = db_find("users", user_id)
    match found {
        Some(u) => println!(u.name),
        None => println!("Not found")
    }

    // 4. 수정
    db_update("users", user_id, {
        age: 29u32
    }).unwrap()

    // 5. 삭제
    db_delete("users", user_id).unwrap()
}
```

### 예제 2: 쿼리 빌더

```freelang
fn main() {
    db_define("users", {
        name: "string",
        age: "u32",
        status: "string"
    }).unwrap()

    // 데이터 삽입
    db_insert("users", { name: "Alice", age: 28u32, status: "active" }).unwrap()
    db_insert("users", { name: "Bob", age: 35u32, status: "active" }).unwrap()
    db_insert("users", { name: "Charlie", age: 22u32, status: "inactive" }).unwrap()

    // 쿼리
    let active_adults = db_query("users")
        .filter("status", "=", "active")
        .filter("age", ">=", 25u32)
        .order("age", "asc")
        .limit(10u64)
        .exec()

    for user in active_adults {
        println!(user.name ++ " (" ++ user.age.to_string() ++ ")")
    }
}
```

### 예제 3: 관계

```freelang
fn main() {
    // 스키마
    db_define("users", { name: "string" }).unwrap()
    db_define("posts", { user_id: "u64", title: "string" }).unwrap()

    // 관계 정의
    db_belongs_to("posts", "users", "user_id", "author")
    db_has_many("users", "posts", "user_id", "posts")

    // 생성
    let user = db_insert("users", { name: "Alice" }).unwrap()
    db_insert("posts", { user_id: user.id, title: "Post 1" }).unwrap()
    db_insert("posts", { user_id: user.id, title: "Post 2" }).unwrap()

    // 관계 로드 (Eager Loading)
    let users = db_eager_load(db_find_all("users"), "posts")
    let first_user = users.get(0).unwrap()

    // first_user.posts는 자동으로 로드됨
    println!(first_user.posts.len().to_string() ++ " posts")
}
```

