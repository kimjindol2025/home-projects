// zsh Phase 2: 알리아스 및 함수
type AliasID = u64
type FunctionID = u64

type Alias {
    id: AliasID
    name: string
    command: string
}

type Function {
    id: FunctionID
    name: string
    body: string
}

type ShellConfig {
    aliases: Vec<Alias>
    functions: Vec<Function>
    next_alias_id: AliasID
    next_function_id: FunctionID
}

impl ShellConfig {
    fn new() -> ShellConfig {
        ShellConfig {
            aliases: Vec::new(),
            functions: Vec::new(),
            next_alias_id: 1000u64,
            next_function_id: 100000u64
        }
    }

    fn create_alias(mut self, name: string, command: string) -> (ShellConfig, AliasID) {
        let id = self.next_alias_id
        self.next_alias_id = self.next_alias_id + 1u64

        let alias = Alias {
            id: id,
            name: name,
            command: command
        }

        self.aliases.push(alias)
        (self, id)
    }

    fn delete_alias(mut self, alias_id: AliasID) -> ShellConfig {
        let mut i = 0u64

        while i < self.aliases.len() {
            let alias = self.aliases.get(i)

            match alias {
                Some(a) => {
                    if a.id == alias_id {
                        // Remove would be needed here
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        self
    }

    fn define_function(mut self, name: string, body: string) -> (ShellConfig, FunctionID) {
        let id = self.next_function_id
        self.next_function_id = self.next_function_id + 1u64

        let function = Function {
            id: id,
            name: name,
            body: body
        }

        self.functions.push(function)
        (self, id)
    }

    fn list_aliases(ref self) -> Vec<(string, string)> {
        let mut result = Vec::new()
        let mut i = 0u64

        while i < self.aliases.len() {
            let alias = self.aliases.get(i)

            match alias {
                Some(a) => {
                    result.push((a.name, a.command))
                }
                None => {}
            }

            i = i + 1u64
        }

        result
    }

    fn list_functions(ref self) -> Vec<string> {
        let mut result = Vec::new()
        let mut i = 0u64

        while i < self.functions.len() {
            let func = self.functions.get(i)

            match func {
                Some(f) => {
                    result.push(f.name)
                }
                None => {}
            }

            i = i + 1u64
        }

        result
    }
}

fn main() {
    println!("=== zsh Phase 2: 알리아스 + 함수 ===")

    let mut config = ShellConfig::new()
    println!("⚙️  쉘 설정 초기화")

    let (config2, _) = config.create_alias("ll", "ls -lah")
    config = config2
    println!("✅ 알리아스 ll = ls -lah")

    let (config2, _) = config.create_alias("gst", "git status")
    config = config2
    println!("✅ 알리아스 gst = git status")

    let (config2, _) = config.define_function("greet", "echo Hello $1")
    config = config2
    println!("✅ 함수 greet 정의")

    let (config2, _) = config.define_function("mkcd", "mkdir -p $1 && cd $1")
    config = config2
    println!("✅ 함수 mkcd 정의")

    let aliases = config.list_aliases()
    println!("\n📌 알리아스:")
    let mut i = 0u64
    while i < aliases.len() {
        let (name, cmd) = aliases.get(i).unwrap()
        println!("  " ++ name ++ " = " ++ cmd)
        i = i + 1u64
    }

    let functions = config.list_functions()
    println!("\n🔧 함수:")
    let mut i = 0u64
    while i < functions.len() {
        let name = functions.get(i).unwrap()
        println!("  " ++ name)
        i = i + 1u64
    }
}
