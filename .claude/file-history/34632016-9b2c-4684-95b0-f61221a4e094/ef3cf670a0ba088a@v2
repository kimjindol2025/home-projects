// tmux Phase 2: 윈도우 및 패인 관리
// 목표: 세션 내 윈도우 생성, 패인 분할, 포커스 관리 추가

// === Phase 1 타입 확장 ===

type SessionID = u64
type WindowID = u64
type PaneID = u64
type SessionName = string
type WindowName = string
type Timestamp = u64

enum SplitDirection {
    Horizontal  // 가로 분할
    Vertical    // 세로 분할
}

enum SessionState {
    Active(Timestamp)
    Detached(Timestamp)
    Terminated
}

type Pane {
    id: PaneID
    content: string
    created_at: Timestamp
    focused: bool
}

type Window {
    id: WindowID
    name: WindowName
    panes: Vec<Pane>
    active_pane_index: u64
    created_at: Timestamp
}

type Session {
    id: SessionID
    name: SessionName
    state: SessionState
    windows: Vec<Window>
    active_window_index: u64
    created_at: Timestamp
}

// === 확장된 세션 관리자 ===

type SessionManager {
    sessions: Vec<Session>
    next_session_id: SessionID
    next_window_id: WindowID
    next_pane_id: PaneID
}

impl SessionManager {

    fn new() -> SessionManager {
        SessionManager {
            sessions: Vec::new(),
            next_session_id: 1000u64,
            next_window_id: 10000u64,
            next_pane_id: 100000u64
        }
    }

    // 세션 생성
    fn create_session(mut self, name: SessionName) -> (SessionManager, SessionID) {
        let session_id = self.next_session_id
        self.next_session_id = self.next_session_id + 1u64

        let window_id = self.next_window_id
        self.next_window_id = self.next_window_id + 1u64

        let pane_id = self.next_pane_id
        self.next_pane_id = self.next_pane_id + 1u64

        let now = get_timestamp()

        // 첫 윈도우 생성
        let pane = Pane {
            id: pane_id,
            content: "",
            created_at: now,
            focused: true
        }

        let mut panes = Vec::new()
        panes.push(pane)

        let window = Window {
            id: window_id,
            name: "default",
            panes: panes,
            active_pane_index: 0u64,
            created_at: now
        }

        let mut windows = Vec::new()
        windows.push(window)

        let session = Session {
            id: session_id,
            name: name,
            state: SessionState::Active(now),
            windows: windows,
            active_window_index: 0u64,
            created_at: now
        }

        self.sessions.push(session)
        (self, session_id)
    }

    // 새 윈도우 생성
    fn create_window(mut self, session_id: SessionID, window_name: WindowName) -> (SessionManager, bool) {
        let window_id = self.next_window_id
        self.next_window_id = self.next_window_id + 1u64

        let pane_id = self.next_pane_id
        self.next_pane_id = self.next_pane_id + 1u64

        let now = get_timestamp()

        let mut pane = Pane {
            id: pane_id,
            content: "",
            created_at: now,
            focused: true
        }

        let mut panes = Vec::new()
        panes.push(pane)

        let window = Window {
            id: window_id,
            name: window_name,
            panes: panes,
            active_pane_index: 0u64,
            created_at: now
        }

        let mut found = false
        let mut i = 0u64

        while i < self.sessions.len() {
            let sess = self.sessions.get(i)

            match sess {
                Some(s) => {
                    if s.id == session_id {
                        let mut updated_session = Session {
                            id: s.id,
                            name: s.name,
                            state: s.state,
                            windows: s.windows,
                            active_window_index: s.active_window_index,
                            created_at: s.created_at
                        }
                        updated_session.windows.push(window)
                        self.sessions.set(i, updated_session)
                        found = true
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        (self, found)
    }

    // 패인 분할
    fn split_pane(mut self, session_id: SessionID, direction: SplitDirection) -> (SessionManager, bool) {
        let pane_id = self.next_pane_id
        self.next_pane_id = self.next_pane_id + 1u64

        let now = get_timestamp()

        let new_pane = Pane {
            id: pane_id,
            content: "",
            created_at: now,
            focused: true
        }

        let mut found = false
        let mut i = 0u64

        while i < self.sessions.len() {
            let sess = self.sessions.get(i)

            match sess {
                Some(s) => {
                    if s.id == session_id {
                        let mut updated_session = Session {
                            id: s.id,
                            name: s.name,
                            state: s.state,
                            windows: s.windows,
                            active_window_index: s.active_window_index,
                            created_at: s.created_at
                        }

                        let window_idx = updated_session.active_window_index
                        let win = updated_session.windows.get(window_idx)

                        match win {
                            Some(w) => {
                                let mut updated_window = Window {
                                    id: w.id,
                                    name: w.name,
                                    panes: w.panes,
                                    active_pane_index: w.active_pane_index,
                                    created_at: w.created_at
                                }

                                // 포커스된 패인 비활성화
                                let pane_idx = updated_window.active_pane_index
                                let pane = updated_window.panes.get(pane_idx)

                                match pane {
                                    Some(p) => {
                                        let unfocused = Pane {
                                            id: p.id,
                                            content: p.content,
                                            created_at: p.created_at,
                                            focused: false
                                        }
                                        updated_window.panes.set(pane_idx, unfocused)
                                    }
                                    None => {}
                                }

                                updated_window.panes.push(new_pane)
                                updated_session.windows.set(window_idx, updated_window)
                                self.sessions.set(i, updated_session)
                                found = true
                            }
                            None => {}
                        }
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        (self, found)
    }

    // 패인 포커스 변경
    fn focus_pane(mut self, session_id: SessionID, pane_index: u64) -> (SessionManager, bool) {
        let mut found = false
        let mut i = 0u64

        while i < self.sessions.len() {
            let sess = self.sessions.get(i)

            match sess {
                Some(s) => {
                    if s.id == session_id {
                        let mut updated_session = Session {
                            id: s.id,
                            name: s.name,
                            state: s.state,
                            windows: s.windows,
                            active_window_index: s.active_window_index,
                            created_at: s.created_at
                        }

                        let window_idx = updated_session.active_window_index
                        let win = updated_session.windows.get(window_idx)

                        match win {
                            Some(w) => {
                                if pane_index < w.panes.len() {
                                    let mut updated_window = Window {
                                        id: w.id,
                                        name: w.name,
                                        panes: w.panes,
                                        active_pane_index: pane_index,
                                        created_at: w.created_at
                                    }

                                    // 모든 패인의 포커스 상태 업데이트
                                    let mut j = 0u64
                                    while j < updated_window.panes.len() {
                                        let pane = updated_window.panes.get(j)
                                        match pane {
                                            Some(p) => {
                                                let is_focused = j == pane_index
                                                let updated_pane = Pane {
                                                    id: p.id,
                                                    content: p.content,
                                                    created_at: p.created_at,
                                                    focused: is_focused
                                                }
                                                updated_window.panes.set(j, updated_pane)
                                            }
                                            None => {}
                                        }
                                        j = j + 1u64
                                    }

                                    updated_session.windows.set(window_idx, updated_window)
                                    self.sessions.set(i, updated_session)
                                    found = true
                                }
                            }
                            None => {}
                        }
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        (self, found)
    }

    // 윈도우 정보 조회
    fn get_window_info(ref self, session_id: SessionID, window_idx: u64) -> Option<(WindowID, u64, u64)> {
        let mut i = 0u64

        while i < self.sessions.len() {
            let sess = self.sessions.get(i)

            match sess {
                Some(s) => {
                    if s.id == session_id && window_idx < s.windows.len() {
                        let win = s.windows.get(window_idx)
                        match win {
                            Some(w) => {
                                return Some((w.id, w.panes.len(), w.active_pane_index))
                            }
                            None => {}
                        }
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        None
    }

    // 세션의 모든 윈도우 정보
    fn list_windows(ref self, session_id: SessionID) -> Vec<(WindowID, WindowName, u64)> {
        let mut result = Vec::new()
        let mut i = 0u64

        while i < self.sessions.len() {
            let sess = self.sessions.get(i)

            match sess {
                Some(s) => {
                    if s.id == session_id {
                        let mut j = 0u64
                        while j < s.windows.len() {
                            let win = s.windows.get(j)
                            match win {
                                Some(w) => {
                                    result.push((w.id, w.name, w.panes.len()))
                                }
                                None => {}
                            }
                            j = j + 1u64
                        }
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        result
    }
}

// === 유틸리티 ===

fn get_timestamp() -> Timestamp {
    12345678u64
}

// === 테스트 ===

fn main() {
    println!("=== tmux Phase 2: 윈도우 및 패인 관리 ===")

    let mut mgr = SessionManager::new()

    // 세션 생성
    let (mgr2, sess_id) = mgr.create_session("dev")
    mgr = mgr2
    println!("✅ 세션 생성: dev")

    // 윈도우 생성
    let (mgr2, success) = mgr.create_window(sess_id, "editor")
    mgr = mgr2
    println!("✅ 윈도우 생성: editor - " ++ (if success { "성공" } else { "실패" }))

    let (mgr2, success) = mgr.create_window(sess_id, "server")
    mgr = mgr2
    println!("✅ 윈도우 생성: server - " ++ (if success { "성공" } else { "실패" }))

    // 윈도우 목록
    let windows = mgr.list_windows(sess_id)
    println!("\n📋 윈도우 목록 (총 " ++ windows.len().to_string() ++ "개):")
    let mut i = 0u64
    while i < windows.len() {
        let (id, name, pane_count) = windows.get(i).unwrap()
        println!("  [" ++ i.to_string() ++ "] " ++ name ++ " (ID: " ++ id.to_string() ++ ", 패인: " ++ pane_count.to_string() ++ ")")
        i = i + 1u64
    }

    // 패인 분할
    let (mgr2, success) = mgr.split_pane(sess_id, SplitDirection::Horizontal)
    mgr = mgr2
    println!("\n✂️  패인 분할 (가로) - " ++ (if success { "성공" } else { "실패" }))

    // 윈도우 정보 조회
    let info = mgr.get_window_info(sess_id, 0u64)
    match info {
        Some((id, pane_count, active_idx)) => {
            println!("ℹ️  윈도우 0 정보: 패인 수=" ++ pane_count.to_string() ++ ", 활성 패인=" ++ active_idx.to_string())
        }
        None => {
            println!("❌ 윈도우를 찾을 수 없음")
        }
    }

    // 패인 포커스 변경
    let (mgr2, success) = mgr.focus_pane(sess_id, 1u64)
    mgr = mgr2
    println!("\n🎯 패인 포커스 변경 (인덱스 1) - " ++ (if success { "성공" } else { "실패" }))

    // 최종 정보
    let info = mgr.get_window_info(sess_id, 0u64)
    match info {
        Some((id, pane_count, active_idx)) => {
            println!("ℹ️  최종 상태: 패인 수=" ++ pane_count.to_string() ++ ", 활성 패인=" ++ active_idx.to_string())
        }
        None => {}
    }
}
