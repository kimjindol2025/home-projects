fn verify_session_integrity(session_data: i32, hmac_tag: i32): i32 {
  println("=== Phase 4: Session Integrity (HMAC) ===")

  // 실제: let computed = hmac(str(session_data), str(key), "sha256")
  var computed_hmac = (session_data * 27 + 54321) % 1000000

  println("Session Data: " + str(session_data))
