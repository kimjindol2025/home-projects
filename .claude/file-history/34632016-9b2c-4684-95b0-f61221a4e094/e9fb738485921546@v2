// ===== Phase 4: 상태 관리 =====

fn SESS_CONNECTING(): i32 { return 0 }
fn SESS_AUTHENTICATED(): i32 { return 1 }
fn SESS_READY(): i32 { return 2 }
fn SESS_CLOSED(): i32 { return 3 }

fn session_next_state(current: i32): i32 {
  if current == SESS_CONNECTING() {
    return SESS_AUTHENTICATED()
  } else if current == SESS_AUTHENTICATED() {
    return SESS_READY()
  } else if current == SESS_READY() {
    return SESS_CLOSED()
  }
  return current
}

