// btop Phase 1-4: 시스템 모니터링
type ProcessID = u64

type Process {
    id: ProcessID
    name: string
    cpu: u64
    memory: u64
}

type Monitor {
    processes: Vec<Process>
    next_pid: ProcessID
}

impl Monitor {
    fn new() -> Monitor {
        Monitor {
            processes: Vec::new(),
            next_pid: 1000u64
        }
    }

    fn add_process(mut self, name: string, cpu: u64, mem: u64) -> Monitor {
        let pid = self.next_pid
        self.next_pid = self.next_pid + 1u64

        self.processes.push(Process {
            id: pid,
            name: name,
            cpu: cpu,
            memory: mem
        })
        self
    }

    fn get_top_processes(ref self, limit: u64) -> Vec<(string, u64, u64)> {
        let mut result = Vec::new()
        let mut i = 0u64

        while i < self.processes.len() && i < limit {
            let proc = self.processes.get(i)

            match proc {
                Some(p) => {
                    result.push((p.name, p.cpu, p.memory))
                }
                None => {}
            }

            i = i + 1u64
        }

        result
    }

    fn total_memory(ref self) -> u64 {
        let mut total = 0u64
        let mut i = 0u64

        while i < self.processes.len() {
            let proc = self.processes.get(i)

            match proc {
                Some(p) => {
                    total = total + p.memory
                }
                None => {}
            }

            i = i + 1u64
        }

        total
    }
}

fn main() {
    println!("=== btop Phase 1-4: 모니터링 ===")

    let mut monitor = Monitor::new()
    println!("📊 모니터 초기화")

    monitor = monitor.add_process("chrome", 25u64, 512u64)
    monitor = monitor.add_process("firefox", 18u64, 384u64)
    monitor = monitor.add_process("code", 15u64, 256u64)
    println!("✅ 프로세스 추가")

    let top = monitor.get_top_processes(3u64)
    println!("\n🔝 상위 프로세스:")
    let mut i = 0u64
    while i < top.len() {
        let (name, cpu, mem) = top.get(i).unwrap()
        println!("  " ++ name ++ " - CPU:" ++ cpu.to_string() ++ "% MEM:" ++ mem.to_string() ++ "MB")
        i = i + 1u64
    }

    let total = monitor.total_memory()
    println!("\n💾 총 메모리: " ++ total.to_string() ++ "MB")
}
