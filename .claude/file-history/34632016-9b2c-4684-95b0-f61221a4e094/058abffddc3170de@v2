// 명령 처리 함수
fn process_command(cmd: i32): i32 {
  if cmd == 1 {
    println("$ ls -la")
    println("total 256")
    println("-rw-r--r-- 1 kim kim  1024 Feb 20 ssh.fl")
    println("-rw-r--r-- 1 kim kim  2048 Feb 20 ssh-server.fl")
    println("-rw-r--r-- 1 kim kim  1536 Feb 20 ssh-interactive.fl")
    println("drwx------ 2 kim kim  4096 examples/")
    println("drwx------ 2 kim kim  4096 dist/")
    return 1
  } else if cmd == 2 {
    println("$ pwd")
    println("/home/kim/freelang-v4")
    return 1
  } else if cmd == 3 {
    println("$ whoami")
    println("kim")
    return 1
  } else if cmd == 4 {
    println("$ uptime")
    println(" 11:52:15 up 2 days, 15:34, load average: 0.25, 0.18, 0.12")
    return 1
  } else if cmd == 5 {
    println("$ date")
    println("Thu Feb 20 11:52:15 UTC 2025")
    return 1
  } else if cmd == 6 {
    println("$ git status")
    println("On branch main")
    println("Your branch is up to date with 'origin/main'.")
    println("nothing to commit, working tree clean")
    return 1
  } else if cmd == 7 {
    println("$ npm run build")
    println("> freelang-v4@4.0.0 build")
    println("> tsc")
    println("✅ Build successful (54 files)")
    return 1
  } else if cmd == 8 {
    println("$ node -v")
    println("v20.10.0")
    return 1
  } else if cmd == 9 {
    println("$ cat package.json | grep name")
    println("  \"name\": \"freelang-v4\",")
    return 1
  } else {
    println("$ exit")
    println("Goodbye!")
    return 0
  }
}

// SSH 세션 관리
fn ssh_session_loop(): i32 {
  println("╔════════════════════════════════════════╗")
  println("║   FreeLang Interactive SSH v1.0        ║")
  println("║      Connected to 192.168.45.73        ║")
  println("╚════════════════════════════════════════╝")
  println("")
  println("Available commands: 1-9 (1=ls, 2=pwd, 3=whoami, etc)")
  println("")

  // 명령 실행
  var count = 0
  for i in range(1, 10) {
    var result = process_command(i)
    println("")
    count = i
  }

  return count
}

