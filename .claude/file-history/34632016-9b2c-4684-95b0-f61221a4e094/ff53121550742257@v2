// nmap Phase 2: 서비스 감지 및 버전 탐지
type ScanID = u64
type HostAddress = string

enum ScanType { SynScan ConnectScan UdpScan }

type ServiceInfo {
    port: u64
    service: string
    version: string
    product: string
}

type HostScan {
    id: ScanID
    target: HostAddress
    scan_type: ScanType
    services: Vec<ServiceInfo>
}

type ServiceDetector {
    scans: Vec<HostScan>
    next_scan_id: ScanID
}

impl ServiceDetector {
    fn new() -> ServiceDetector {
        ServiceDetector {
            scans: Vec::new(),
            next_scan_id: 1000u64
        }
    }

    fn create_scan(mut self, target: HostAddress) -> (ServiceDetector, ScanID) {
        let scan_id = self.next_scan_id
        self.next_scan_id = self.next_scan_id + 1u64

        let scan = HostScan {
            id: scan_id,
            target: target,
            scan_type: ScanType::SynScan,
            services: Vec::new()
        }

        self.scans.push(scan)
        (self, scan_id)
    }

    fn detect_service(mut self, scan_id: ScanID, port: u64, service: string, version: string, product: string) -> ServiceDetector {
        let mut i = 0u64

        while i < self.scans.len() {
            let scan = self.scans.get(i)

            match scan {
                Some(s) => {
                    if s.id == scan_id {
                        let mut updated = HostScan {
                            id: s.id,
                            target: s.target,
                            scan_type: s.scan_type,
                            services: s.services
                        }

                        updated.services.push(ServiceInfo {
                            port: port,
                            service: service,
                            version: version,
                            product: product
                        })

                        self.scans.set(i, updated)
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        self
    }

    fn get_services(ref self, scan_id: ScanID) -> Vec<(u64, string, string)> {
        let mut result = Vec::new()
        let mut i = 0u64

        while i < self.scans.len() {
            let scan = self.scans.get(i)

            match scan {
                Some(s) => {
                    if s.id == scan_id {
                        let mut j = 0u64
                        while j < s.services.len() {
                            let svc = s.services.get(j)

                            match svc {
                                Some(srv) => {
                                    result.push((srv.port, srv.service, srv.version))
                                }
                                None => {}
                            }

                            j = j + 1u64
                        }
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        result
    }
}

fn main() {
    println!("=== nmap Phase 2: 서비스 감지 ===")

    let mut detector = ServiceDetector::new()
    println!("🔍 서비스 감지기 초기화")

    let (detector2, scan1) = detector.create_scan("192.168.1.100")
    detector = detector2
    println!("✅ 192.168.1.100 스캔 생성")

    detector = detector.detect_service(scan1, 22u64, "ssh", "OpenSSH 7.4", "OpenSSH")
    detector = detector.detect_service(scan1, 80u64, "http", "Apache 2.4.6", "Apache")
    detector = detector.detect_service(scan1, 443u64, "https", "Apache 2.4.6", "Apache")
    println!("✅ 서비스 감지 완료")

    let services = detector.get_services(scan1)
    println!("\n🔧 감지된 서비스:")
    let mut i = 0u64
    while i < services.len() {
        let (port, service, version) = services.get(i).unwrap()
        println!("  " ++ port.to_string() ++ "/" ++ service ++ " (" ++ version ++ ")")
        i = i + 1u64
    }
}
