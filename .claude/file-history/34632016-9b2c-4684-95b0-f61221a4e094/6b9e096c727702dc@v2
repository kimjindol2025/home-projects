#!/usr/bin/env python3
"""
Message Queue Manager - Async message queue orchestration and management
Supports RabbitMQ, Kafka, SQS, and local queues with routing and dead-letter handling
"""

from dataclasses import dataclass, field
from enum import Enum
from typing import Dict, List, Optional, Callable, Any
import hashlib
import json
import time
import random


class QueueBackend(Enum):
    """Supported message queue backends"""
    RABBITMQ = "RABBITMQ"
    KAFKA = "KAFKA"
    SQS = "SQS"
    REDIS = "REDIS"
    LOCAL = "LOCAL"


class MessageStatus(Enum):
    """Status of a queued message"""
    PENDING = "PENDING"
    PROCESSING = "PROCESSING"
    COMPLETED = "COMPLETED"
    FAILED = "FAILED"
    DEAD_LETTERED = "DEAD_LETTERED"
    RETRYING = "RETRYING"
    TIMEOUT = "TIMEOUT"


class QueuePriority(Enum):
    """Message priority in queue"""
    CRITICAL = "CRITICAL"
    HIGH = "HIGH"
    NORMAL = "NORMAL"
    LOW = "LOW"
    DEFERRED = "DEFERRED"


class RoutingStrategy(Enum):
    """Message routing strategies"""
    DIRECT = "DIRECT"
    FANOUT = "FANOUT"
    TOPIC = "TOPIC"
    HEADERS = "HEADERS"
    ROUND_ROBIN = "ROUND_ROBIN"
    WEIGHTED = "WEIGHTED"


@dataclass
class QueueMessage:
    """Message in queue"""
    message_id: str
    queue_name: str
    content: Dict[str, Any]
    priority: QueuePriority
    status: MessageStatus
    created_at: float
    sent_at: Optional[float] = None
    processed_at: Optional[float] = None
    retry_count: int = 0
    max_retries: int = 3
    ttl: int = 86400  # 24 hours
    headers: Dict[str, str] = field(default_factory=dict)
    correlation_id: Optional[str] = None
    tags: List[str] = field(default_factory=list)
    processing_time_ms: float = 0.0


@dataclass
class Queue:
    """Message queue"""
    queue_id: str
    name: str
    backend: QueueBackend
    created_at: float
    messages: List[QueueMessage] = field(default_factory=list)
    dead_letter_queue: Optional[str] = None
    max_length: Optional[int] = None
    retention_seconds: int = 86400
    routing_strategy: RoutingStrategy = RoutingStrategy.DIRECT
    durable: bool = True
    exclusive: bool = False
    auto_delete: bool = False
    consumer_count: int = 0


@dataclass
class Consumer:
    """Queue consumer"""
    consumer_id: str
    consumer_group: str
    queue_name: str
    created_at: float
    status: str = "IDLE"  # IDLE, PROCESSING, ERROR
    processed_messages: int = 0
    failed_messages: int = 0
    last_activity: float = field(default_factory=time.time)
    prefetch_count: int = 1


@dataclass
class DeadLetterEntry:
    """Entry in dead-letter queue"""
    entry_id: str
    original_message_id: str
    queue_name: str
    reason: str
    original_message: Dict
    created_at: float
    retry_attempts: int = 0


@dataclass
class QueueMetrics:
    """Metrics for queue system"""
    total_messages_processed: int = 0
    total_messages_failed: int = 0
    messages_in_queue: int = 0
    avg_processing_time: float = 0.0
    throughput_mps: float = 0.0
    dead_letters: int = 0
    active_consumers: int = 0
    queue_depth: Dict[str, int] = field(default_factory=dict)


class MessageQueueManager:
    """
    Enterprise message queue orchestration system

    Provides:
    - Multiple backend support (RabbitMQ, Kafka, SQS, Redis)
    - Message routing and load balancing
    - Consumer group management
    - Dead-letter queue handling
    - Message persistence and reliability
    - Retry logic with exponential backoff
    - Queue monitoring and metrics
    """

    def __init__(self, default_backend: QueueBackend = QueueBackend.RABBITMQ):
        self.backend = default_backend
        self.queues: Dict[str, Queue] = {}
        self.messages: Dict[str, QueueMessage] = {}
        self.consumers: Dict[str, Consumer] = {}
        self.dead_letter_queues: Dict[str, List[DeadLetterEntry]] = {}
        self.metrics = QueueMetrics()
        self.handlers: Dict[str, Callable] = {}

    def create_queue(self,
                    name: str,
                    backend: Optional[QueueBackend] = None,
                    routing_strategy: RoutingStrategy = RoutingStrategy.DIRECT,
                    dead_letter_queue: Optional[str] = None) -> Queue:
        """
        Create message queue

        Args:
            name: Queue name
            backend: Queue backend (uses default if None)
            routing_strategy: Message routing strategy
            dead_letter_queue: Name of dead-letter queue

        Returns:
            Created Queue
        """
        queue_id = hashlib.md5(f"{name}:{time.time()}".encode()).hexdigest()[:8]

        queue = Queue(
            queue_id=queue_id,
            name=name,
            backend=backend or self.backend,
            created_at=time.time(),
            routing_strategy=routing_strategy,
            dead_letter_queue=dead_letter_queue
        )

        self.queues[queue_id] = queue

        # Create dead-letter queue if specified
        if dead_letter_queue:
            self.dead_letter_queues[dead_letter_queue] = []

        return queue

    def publish_message(self,
                       queue_name: str,
                       content: Dict[str, Any],
                       priority: QueuePriority = QueuePriority.NORMAL,
                       correlation_id: Optional[str] = None,
                       ttl: Optional[int] = None) -> QueueMessage:
        """
        Publish message to queue

        Args:
            queue_name: Target queue name
            content: Message content
            priority: Message priority
            correlation_id: Correlation ID for tracing
            ttl: Time to live in seconds

        Returns:
            Published QueueMessage
        """
        # Find queue by name
        queue = next((q for q in self.queues.values() if q.name == queue_name), None)
        if not queue:
            return None

        message_id = hashlib.md5(f"{queue_name}:{time.time()}:{random.random()}".encode()).hexdigest()[:8]

        message = QueueMessage(
            message_id=message_id,
            queue_name=queue_name,
            content=content,
            priority=priority,
            status=MessageStatus.PENDING,
            created_at=time.time(),
            correlation_id=correlation_id,
            ttl=ttl or queue.retention_seconds
        )

        queue.messages.append(message)
        self.messages[message_id] = message

        return message

    def consume_message(self,
                       queue_name: str,
                       consumer_group: str,
                       auto_ack: bool = True) -> Optional[QueueMessage]:
        """
        Consume message from queue

        Args:
            queue_name: Source queue name
            consumer_group: Consumer group name
            auto_ack: Auto-acknowledge message

        Returns:
            Next message or None
        """
        # Find queue by name
        queue = next((q for q in self.queues.values() if q.name == queue_name), None)
        if not queue or not queue.messages:
            return None

        # Get next message (sorted by priority)
        queue.messages.sort(
            key=lambda m: (
                [QueuePriority.CRITICAL, QueuePriority.HIGH, QueuePriority.NORMAL, QueuePriority.LOW, QueuePriority.DEFERRED].index(m.priority),
                m.created_at
            )
        )

        message = queue.messages.pop(0)

        # Update message status
        message.status = MessageStatus.PROCESSING
        message.sent_at = time.time()

        # Create consumer if needed
        consumer_id = f"{consumer_group}_{queue_name}_{message.message_id}"
        if consumer_id not in self.consumers:
            consumer = Consumer(
                consumer_id=consumer_id,
                consumer_group=consumer_group,
                queue_name=queue_name,
                created_at=time.time()
            )
            self.consumers[consumer_id] = consumer
            queue.consumer_count += 1

        return message

    def acknowledge_message(self,
                           message_id: str,
                           processing_time_ms: float = 0.0) -> bool:
        """
        Acknowledge message processing

        Args:
            message_id: Message ID
            processing_time_ms: Processing time in milliseconds

        Returns:
            Acknowledgment success
        """
        message = self.messages.get(message_id)
        if not message:
            return False

        message.status = MessageStatus.COMPLETED
        message.processed_at = time.time()
        message.processing_time_ms = processing_time_ms

        self.metrics.total_messages_processed += 1
        self.metrics.avg_processing_time = (
            (self.metrics.avg_processing_time * (self.metrics.total_messages_processed - 1) + processing_time_ms) /
            self.metrics.total_messages_processed
        )

        return True

    def nack_message(self,
                    message_id: str,
                    reason: str = "Processing failed") -> bool:
        """
        Negative acknowledge message (NACK)

        Args:
            message_id: Message ID
            reason: Reason for NACK

        Returns:
            NACK success
        """
        message = self.messages.get(message_id)
        if not message:
            return False

        # Increment retry count
        message.retry_count += 1

        if message.retry_count >= message.max_retries:
            # Send to dead-letter queue
            return self._send_to_dlq(message, reason)
        else:
            # Retry with exponential backoff
            backoff_seconds = 2 ** message.retry_count
            message.status = MessageStatus.RETRYING
            self.metrics.total_messages_failed += 1
            return True

    def _send_to_dlq(self, message: QueueMessage, reason: str) -> bool:
        """Send message to dead-letter queue"""
        queue = next((q for q in self.queues.values() if q.name == message.queue_name), None)
        if not queue or not queue.dead_letter_queue:
            return False

        dlq_entry = DeadLetterEntry(
            entry_id=hashlib.md5(f"{message.message_id}:{time.time()}".encode()).hexdigest()[:8],
            original_message_id=message.message_id,
            queue_name=message.queue_name,
            reason=reason,
            original_message=message.content,
            created_at=time.time(),
            retry_attempts=message.retry_count
        )

        if queue.dead_letter_queue not in self.dead_letter_queues:
            self.dead_letter_queues[queue.dead_letter_queue] = []

        self.dead_letter_queues[queue.dead_letter_queue].append(dlq_entry)
        message.status = MessageStatus.DEAD_LETTERED
        self.metrics.dead_letters += 1

        return True

    def create_consumer_group(self,
                            group_name: str,
                            queue_names: List[str]) -> List[Consumer]:
        """
        Create consumer group

        Args:
            group_name: Consumer group name
            queue_names: List of queue names to consume from

        Returns:
            List of created consumers
        """
        consumers = []

        for queue_name in queue_names:
            consumer_id = hashlib.md5(f"{group_name}:{queue_name}".encode()).hexdigest()[:8]

            consumer = Consumer(
                consumer_id=consumer_id,
                consumer_group=group_name,
                queue_name=queue_name,
                created_at=time.time()
            )

            self.consumers[consumer_id] = consumer
            consumers.append(consumer)

        return consumers

    def get_queue_metrics(self) -> QueueMetrics:
        """Get queue system metrics"""
        self.metrics.active_consumers = sum(
            1 for c in self.consumers.values()
            if c.status in ["IDLE", "PROCESSING"]
        )

        self.metrics.messages_in_queue = sum(
            len(q.messages) for q in self.queues.values()
        )

        self.metrics.queue_depth = {
            q.name: len(q.messages)
            for q in self.queues.values()
        }

        self.metrics.throughput_mps = self.metrics.total_messages_processed / max(1, time.time())

        return self.metrics

    def drain_queue(self, queue_name: str) -> int:
        """
        Drain queue (remove all messages)

        Args:
            queue_name: Queue to drain

        Returns:
            Number of messages drained
        """
        queue = next((q for q in self.queues.values() if q.name == queue_name), None)
        if not queue:
            return 0

        count = len(queue.messages)
        queue.messages.clear()

        return count

    def generate_queue_report(self) -> str:
        """Generate message queue system report"""
        metrics = self.get_queue_metrics()

        report = f"""
╔════════════════════════════════════════════════════════════════════════════╗
║                         MESSAGE QUEUE REPORT                               ║
║                         Backend: {self.backend.value}                              ║
╚════════════════════════════════════════════════════════════════════════════╝

📊 METRICS:
├─ Messages Processed: {metrics.total_messages_processed:,}
├─ Failed Messages: {metrics.total_messages_failed}
├─ Dead Letters: {metrics.dead_letters}
├─ Messages in Queue: {metrics.messages_in_queue}
├─ Avg Processing Time: {metrics.avg_processing_time:.1f}ms
├─ Throughput: {metrics.throughput_mps:.2f} msg/s
└─ Active Consumers: {metrics.active_consumers}

📋 QUEUES:
"""

        for queue_name, depth in metrics.queue_depth.items():
            status = "✅" if depth == 0 else "🟡" if depth < 100 else "🔴"
            report += f"\n{status} {queue_name}: {depth} messages\n"

        # Dead-letter summary
        total_dlq = sum(len(entries) for entries in self.dead_letter_queues.values())
        if total_dlq > 0:
            report += f"\n⚠️  DEAD-LETTER QUEUE: {total_dlq} messages\n"

        return report

    def export_state(self) -> str:
        """Export queue manager state as JSON"""
        export_data = {
            "timestamp": time.time(),
            "backend": self.backend.value,
            "queues": {
                q.name: {
                    "messages": len(q.messages),
                    "consumers": q.consumer_count,
                    "routing_strategy": q.routing_strategy.value,
                    "durable": q.durable,
                }
                for q in self.queues.values()
            },
            "metrics": {
                "total_processed": self.metrics.total_messages_processed,
                "total_failed": self.metrics.total_messages_failed,
                "dead_letters": self.metrics.dead_letters,
                "active_consumers": self.metrics.active_consumers,
                "avg_processing_time": self.metrics.avg_processing_time,
            },
            "consumers": {
                c.consumer_id: {
                    "group": c.consumer_group,
                    "queue": c.queue_name,
                    "processed": c.processed_messages,
                    "failed": c.failed_messages,
                }
                for c in self.consumers.values()
            },
        }
        return json.dumps(export_data, indent=2)


def main():
    """CLI interface"""
    print("📨 Message Queue Manager - Async Message Orchestration")
    print("=" * 70)

    manager = MessageQueueManager(default_backend=QueueBackend.RABBITMQ)

    # Create queues
    print("\n🔨 Creating message queues...")
    email_queue = manager.create_queue(
        "email-service",
        routing_strategy=RoutingStrategy.TOPIC,
        dead_letter_queue="email-service-dlq"
    )

    notification_queue = manager.create_queue(
        "notifications",
        routing_strategy=RoutingStrategy.FANOUT,
        dead_letter_queue="notifications-dlq"
    )

    task_queue = manager.create_queue(
        "background-tasks",
        routing_strategy=RoutingStrategy.ROUND_ROBIN
    )

    print(f"✅ Created {len(manager.queues)} queues")

    # Create consumer groups
    print("\n👥 Creating consumer groups...")
    email_consumers = manager.create_consumer_group(
        "email-workers",
        ["email-service", "notifications"]
    )

    task_consumers = manager.create_consumer_group(
        "task-workers",
        ["background-tasks"]
    )

    print(f"✅ Created consumers for 2 groups")

    # Publish messages
    print("\n📤 Publishing messages...")
    for i in range(10):
        manager.publish_message(
            "email-service",
            {
                "to": f"user{i}@example.com",
                "subject": f"Welcome message {i}",
                "body": f"Welcome to our service!"
            },
            priority=QueuePriority.HIGH if i % 3 == 0 else QueuePriority.NORMAL
        )

    for i in range(5):
        manager.publish_message(
            "background-tasks",
            {
                "task_type": "data_export",
                "user_id": f"user_{i}",
                "format": "csv"
            },
            priority=QueuePriority.NORMAL
        )

    print(f"✅ Published 15 messages")

    # Simulate processing
    print("\n⚙️  Processing messages...")
    processed = 0
    for _ in range(8):
        msg = manager.consume_message("email-service", "email-workers")
        if msg:
            processing_time = random.uniform(10, 100)
            if random.random() > 0.1:  # 90% success rate
                manager.acknowledge_message(msg.message_id, processing_time)
                processed += 1
            else:
                manager.nack_message(msg.message_id, "SMTP connection failed")

    print(f"✅ Processed {processed} messages")

    # Generate report
    print(manager.generate_queue_report())

    # Export state
    print("\n📄 Exporting queue state...")
    export = manager.export_state()
    print(f"✅ Exported {len(export)} characters of queue state")

    print("\n" + "=" * 70)
    print("✨ Message queue management complete")


if __name__ == "__main__":
    main()
