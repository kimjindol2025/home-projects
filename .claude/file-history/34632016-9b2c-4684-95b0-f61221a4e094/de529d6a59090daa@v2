// git Phase 2: 브랜치 관리
// 목표: 브랜치 생성, 전환, 병합 기능 추가

type CommitID = u64
type BranchID = u64
type Timestamp = u64
type AuthorName = string
type CommitMessage = string
type BranchName = string
type FilePath = string

enum FileStatus {
    Added
    Modified
    Deleted
}

enum MergeStatus {
    Success
    Conflict
    Failed
}

type FileChange {
    path: FilePath
    status: FileStatus
}

type Commit {
    id: CommitID
    author: AuthorName
    message: CommitMessage
    timestamp: Timestamp
    files: Vec<FileChange>
    parent_id: Option<CommitID>
}

type Branch {
    id: BranchID
    name: BranchName
    commits: Vec<CommitID>
    is_current: bool
    created_at: Timestamp
}

type Repository {
    name: string
    branches: Vec<Branch>
    all_commits: Vec<Commit>
    next_branch_id: BranchID
    next_commit_id: CommitID
}

impl Repository {

    fn init(name: string) -> Repository {
        // main 브랜치 생성
        let main_branch = Branch {
            id: 1000u64,
            name: "main",
            commits: Vec::new(),
            is_current: true,
            created_at: get_timestamp()
        }

        let mut branches = Vec::new()
        branches.push(main_branch)

        Repository {
            name: name,
            branches: branches,
            all_commits: Vec::new(),
            next_branch_id: 1001u64,
            next_commit_id: 10000u64
        }
    }

    // 현재 브랜치 조회
    fn get_current_branch(ref self) -> Option<BranchID> {
        let mut i = 0u64

        while i < self.branches.len() {
            let branch = self.branches.get(i)

            match branch {
                Some(b) => {
                    if b.is_current {
                        return Some(b.id)
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        None
    }

    // 커밋 생성
    fn commit(mut self, author: AuthorName, message: CommitMessage, files: Vec<FileChange>) -> (Repository, CommitID) {
        let commit_id = self.next_commit_id
        self.next_commit_id = self.next_commit_id + 1u64

        let now = get_timestamp()

        let parent_id = if self.all_commits.len() > 0u64 {
            let last_commit = self.all_commits.get(self.all_commits.len() - 1u64)
            match last_commit {
                Some(c) => {
                    Some(c.id)
                }
                None => {
                    None
                }
            }
        } else {
            None
        }

        let commit = Commit {
            id: commit_id,
            author: author,
            message: message,
            timestamp: now,
            files: files,
            parent_id: parent_id
        }

        self.all_commits.push(commit)

        // 현재 브랜치에 커밋 추가
        let mut i = 0u64
        while i < self.branches.len() {
            let branch = self.branches.get(i)

            match branch {
                Some(b) => {
                    if b.is_current {
                        let mut updated_branch = Branch {
                            id: b.id,
                            name: b.name,
                            commits: b.commits,
                            is_current: b.is_current,
                            created_at: b.created_at
                        }
                        updated_branch.commits.push(commit_id)
                        self.branches.set(i, updated_branch)
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        (self, commit_id)
    }

    // 새 브랜치 생성
    fn create_branch(mut self, branch_name: BranchName) -> (Repository, BranchID) {
        let branch_id = self.next_branch_id
        self.next_branch_id = self.next_branch_id + 1u64

        // 현재 브랜치의 커밋 복사
        let mut current_commits = Vec::new()
        let mut i = 0u64

        while i < self.branches.len() {
            let branch = self.branches.get(i)

            match branch {
                Some(b) => {
                    if b.is_current {
                        current_commits = b.commits
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        let new_branch = Branch {
            id: branch_id,
            name: branch_name,
            commits: current_commits,
            is_current: false,
            created_at: get_timestamp()
        }

        self.branches.push(new_branch)
        (self, branch_id)
    }

    // 브랜치 전환
    fn checkout(mut self, branch_name: BranchName) -> (Repository, bool) {
        let mut found = false
        let mut i = 0u64

        // 현재 브랜치 비활성화
        while i < self.branches.len() {
            let branch = self.branches.get(i)

            match branch {
                Some(b) => {
                    if b.is_current {
                        let updated = Branch {
                            id: b.id,
                            name: b.name,
                            commits: b.commits,
                            is_current: false,
                            created_at: b.created_at
                        }
                        self.branches.set(i, updated)
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        // 새로운 브랜치 활성화
        i = 0u64
        while i < self.branches.len() {
            let branch = self.branches.get(i)

            match branch {
                Some(b) => {
                    if b.name == branch_name {
                        let updated = Branch {
                            id: b.id,
                            name: b.name,
                            commits: b.commits,
                            is_current: true,
                            created_at: b.created_at
                        }
                        self.branches.set(i, updated)
                        found = true
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        (self, found)
    }

    // 브랜치 목록
    fn list_branches(ref self) -> Vec<(BranchID, BranchName, bool, u64)> {
        let mut result = Vec::new()
        let mut i = 0u64

        while i < self.branches.len() {
            let branch = self.branches.get(i)

            match branch {
                Some(b) => {
                    result.push((b.id, b.name, b.is_current, b.commits.len()))
                }
                None => {}
            }

            i = i + 1u64
        }

        result
    }

    // 브랜치 병합 (간단한 구현)
    fn merge(mut self, source_branch_name: BranchName) -> (Repository, MergeStatus) {
        let mut source_commits = Vec::new()
        let mut source_found = false
        let mut i = 0u64

        // 소스 브랜치 찾기
        while i < self.branches.len() {
            let branch = self.branches.get(i)

            match branch {
                Some(b) => {
                    if b.name == source_branch_name {
                        source_commits = b.commits
                        source_found = true
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        if !source_found {
            return (self, MergeStatus::Failed)
        }

        // 현재 브랜치에 커밋 병합
        i = 0u64
        while i < self.branches.len() {
            let branch = self.branches.get(i)

            match branch {
                Some(b) => {
                    if b.is_current {
                        let mut updated_branch = Branch {
                            id: b.id,
                            name: b.name,
                            commits: b.commits,
                            is_current: b.is_current,
                            created_at: b.created_at
                        }

                        // 소스 커밋 추가 (중복 제거)
                        let mut j = 0u64
                        while j < source_commits.len() {
                            let commit_id = source_commits.get(j)

                            match commit_id {
                                Some(cid) => {
                                    let mut already_exists = false
                                    let mut k = 0u64

                                    while k < updated_branch.commits.len() {
                                        let existing = updated_branch.commits.get(k)

                                        match existing {
                                            Some(ec) => {
                                                if ec == cid {
                                                    already_exists = true
                                                }
                                            }
                                            None => {}
                                        }

                                        k = k + 1u64
                                    }

                                    if !already_exists {
                                        updated_branch.commits.push(cid)
                                    }
                                }
                                None => {}
                            }

                            j = j + 1u64
                        }

                        self.branches.set(i, updated_branch)
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        (self, MergeStatus::Success)
    }

    // 브랜치 삭제
    fn delete_branch(mut self, branch_name: BranchName) -> (Repository, bool) {
        let mut found = false
        let mut i = 0u64

        while i < self.branches.len() {
            let branch = self.branches.get(i)

            match branch {
                Some(b) => {
                    if b.name == branch_name && !b.is_current {
                        // 현재 브랜치는 삭제할 수 없음
                        found = true
                        // 논리적 삭제 (프레임워크 제약으로 실제 삭제 제한)
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        (self, found)
    }

    // 브랜치 통계
    fn branch_stats(ref self) -> (u64, u64) {
        let total_branches = self.branches.len()
        let mut total_commits = 0u64

        let mut i = 0u64
        while i < self.branches.len() {
            let branch = self.branches.get(i)

            match branch {
                Some(b) => {
                    total_commits = total_commits + b.commits.len()
                }
                None => {}
            }

            i = i + 1u64
        }

        (total_branches, total_commits)
    }
}

// === Option 타입 ===

type Option<T> {
    Some(T)
    None
}

// === 유틸리티 ===

fn get_timestamp() -> Timestamp {
    12345678u64
}

// === 테스트 ===

fn main() {
    println!("=== git Phase 2: 브랜치 관리 ===")

    let mut repo = Repository::init("my-project")
    println!("📁 저장소 초기화: my-project")

    // 초기 커밋
    println!("\n📝 main 브랜치에 커밋:")
    let mut files = Vec::new()
    files.push(FileChange { path: "main.fl", status: FileStatus::Added })

    let (repo2, _) = repo.commit("kim@localhost", "Initial commit", files)
    repo = repo2
    println!("✅ 커밋 1")

    let mut files = Vec::new()
    files.push(FileChange { path: "main.fl", status: FileStatus::Modified })

    let (repo2, _) = repo.commit("kim@localhost", "Add features", files)
    repo = repo2
    println!("✅ 커밋 2")

    // 브랜치 생성
    println!("\n🌿 브랜치 생성:")
    let (repo2, _) = repo.create_branch("develop")
    repo = repo2
    println!("✅ develop 브랜치 생성")

    let (repo2, _) = repo.create_branch("feature/new-feature")
    repo = repo2
    println!("✅ feature/new-feature 브랜치 생성")

    // 브랜치 목록
    println!("\n📋 브랜치 목록:")
    let branches = repo.list_branches()
    let mut i = 0u64
    while i < branches.len() {
        let (id, name, is_current, commit_count) = branches.get(i).unwrap()
        let marker = if is_current { "* " } else { "  " }
        println!(marker ++ name ++ " (커밋: " ++ commit_count.to_string() ++ ")")
        i = i + 1u64
    }

    // 브랜치 전환
    println!("\n🔄 브랜치 전환:")
    let (repo2, success) = repo.checkout("develop")
    repo = repo2
    println!("✅ develop 브랜치로 전환")

    // develop 브랜치에서 커밋
    println!("\n📝 develop 브랜치에 커밋:")
    let mut files = Vec::new()
    files.push(FileChange { path: "api.fl", status: FileStatus::Added })

    let (repo2, _) = repo.commit("kim@localhost", "Add API module", files)
    repo = repo2
    println!("✅ develop에 커밋 추가")

    // 다시 main으로
    println!("\n🔄 브랜치 전환:")
    let (repo2, success) = repo.checkout("main")
    repo = repo2
    println!("✅ main 브랜치로 전환")

    // 병합
    println!("\n🔀 브랜치 병합:")
    let (repo2, merge_status) = repo.merge("develop")
    repo = repo2

    let merge_result = match merge_status {
        MergeStatus::Success => "성공",
        MergeStatus::Conflict => "충돌",
        MergeStatus::Failed => "실패"
    }

    println!("✅ develop을 main에 병합: " ++ merge_result)

    // 최종 브랜치 목록
    println!("\n📋 최종 브랜치 목록:")
    let branches = repo.list_branches()
    let mut i = 0u64
    while i < branches.len() {
        let (id, name, is_current, commit_count) = branches.get(i).unwrap()
        let marker = if is_current { "* " } else { "  " }
        println!(marker ++ name ++ " (커밋: " ++ commit_count.to_string() ++ ")")
        i = i + 1u64
    }

    // 통계
    println!("\n📊 통계:")
    let (branch_count, commit_count) = repo.branch_stats()
    println!("  브랜치: " ++ branch_count.to_string())
    println!("  커밋: " ++ commit_count.to_string())
}
