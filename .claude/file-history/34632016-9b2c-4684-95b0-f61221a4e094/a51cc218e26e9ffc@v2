// 🔐 FreeLang SSH Interactive Session v2.0 (Fixed)
// Phase 1-3: 타입 안전성 + 명령 관리

// ===== Phase 1: 명령 상수 =====

fn CMD_LS(): i32 { return 1 }
fn CMD_PWD(): i32 { return 2 }
fn CMD_WHOAMI(): i32 { return 3 }
fn CMD_UPTIME(): i32 { return 4 }
fn CMD_DATE(): i32 { return 5 }
fn CMD_GIT(): i32 { return 6 }
fn CMD_NPM(): i32 { return 7 }
fn CMD_NODE(): i32 { return 8 }
fn CMD_CAT(): i32 { return 9 }

// ===== Phase 1: 상태 상수 =====

fn SESS_STATE_CONNECTING(): i32 { return 0 }
fn SESS_STATE_AUTHENTICATED(): i32 { return 1 }
fn SESS_STATE_READY(): i32 { return 2 }
fn SESS_STATE_CLOSED(): i32 { return 3 }

// ===== Phase 1: 상태 이름 =====

fn session_state_name(s: i32): i32 {
  if s == SESS_STATE_CONNECTING() {
    println("[SESSION: CONNECTING]")
  } else if s == SESS_STATE_AUTHENTICATED() {
    println("[SESSION: AUTHENTICATED]")
  } else if s == SESS_STATE_READY() {
    println("[SESSION: READY]")
  } else if s == SESS_STATE_CLOSED() {
    println("[SESSION: CLOSED]")
  }
  return s
}

// ===== Phase 2: 상태 전환 =====

fn session_next_state(current: i32): i32 {
  if current == SESS_STATE_CONNECTING() {
    return SESS_STATE_AUTHENTICATED()
  } else if current == SESS_STATE_AUTHENTICATED() {
    return SESS_STATE_READY()
  } else if current == SESS_STATE_READY() {
    return SESS_STATE_CLOSED()
  }
  return current
}

// ===== Phase 1: 세션 초기화 =====

fn init_session_v2(host: i32, port: i32, state: i32): i32 {
  println("╔═══════════════════════════════════════╗")
  println("║  FreeLang SSH Interactive Session     ║")
  println("║  v2.0 - Phase 1-3                     ║")
  println("║  With State Management                ║")
  println("╚═══════════════════════════════════════╝")
  println("")

  println("=== SSH Connection ===")
  session_state_name(state)
  println("Connecting to kim@" + str(host) + ".168.45.73:" + str(port) + "...")
  println("✅ Connected")
  println("✅ Authenticated (password)")
  println("")

  var next = session_next_state(state)
  return next
}

// ===== Phase 3: 명령 실행 (상태 안전성) =====

fn execute_command_v2(cmd: i32, state: i32): i32 {
  if state < SESS_STATE_AUTHENTICATED() {
    println("ERROR: Not authenticated")
    return 0
  }

  if cmd == CMD_LS() {
    println("$ ls -la")
    println("total 256")
    println("-rw-r--r-- 1 kim kim 1024 Feb 20 client-v2.fl")
    println("-rw-r--r-- 1 kim kim 2048 Feb 20 server-v2.fl")
    println("-rw-r--r-- 1 kim kim 1536 Feb 20 interactive-v2.fl")
    println("drwx------ 2 kim kim 4096 Feb 20 examples/")
    return 1

  } else if cmd == CMD_PWD() {
    println("$ pwd")
    println("/home/kim/freelang-v4")
    return 1

  } else if cmd == CMD_WHOAMI() {
    println("$ whoami")
    println("kim")
    return 1

  } else if cmd == CMD_UPTIME() {
    println("$ uptime")
    println(" 12:34:56 up 2 days, 15:34, load average: 0.25, 0.18, 0.12")
    return 1

  } else if cmd == CMD_DATE() {
    println("$ date")
    println("Thu Feb 20 12:34:56 UTC 2025")
    return 1

  } else if cmd == CMD_GIT() {
    println("$ git status")
    println("On branch main")
    println("Your branch is up to date with 'origin/main'.")
    println("nothing to commit, working tree clean")
    return 1

  } else if cmd == CMD_NPM() {
    println("$ npm run build")
    println("> freelang-v4@4.0.0 build")
    println("> tsc")
    println("✅ Build successful (54 files)")
    return 1

  } else if cmd == CMD_NODE() {
    println("$ node -v")
    println("v20.10.0")
    return 1

  } else if cmd == CMD_CAT() {
    println("$ cat package.json | grep name")
    println("  \"name\": \"freelang-v4\",")
    return 1
  }

  return 0
}

// ===== Phase 2: 명령 루프 =====

fn run_commands_v2(state: i32): i32 {
  println("╔═══════════════════════════════════════╗")
  println("║   Interactive Command Loop             ║")
  println("╚═══════════════════════════════════════╝")
  println("")

  println("Available commands:")
  println("  1 = ls -la         2 = pwd")
  println("  3 = whoami         4 = uptime")
  println("  5 = date           6 = git status")
  println("  7 = npm run build  8 = node -v")
  println("  9 = cat package.json")
  println("")

  var count = 0
  for i in range(1, 10) {
    println("=== Command " + str(i) + " ===")
    var result = execute_command_v2(i, state)
    println("")
    count = i
  }

  return count
}

// ===== Phase 1: 세션 정보 =====

fn print_session_stats_v2(count: i32, state: i32): i32 {
  println("╔═══════════════════════════════════════╗")
  println("║   Session Statistics                  ║")
  println("╚═══════════════════════════════════════╝")
  println("")

  println("Remote Host: 192.168.45.73")
  println("Remote Port: 22")
  println("Current User: kim")
  println("Session ID: 12345")
  session_state_name(state)
  println("Commands Executed: " + str(count))
  println("")

  return 1
}

// ===== Phase 1: 세션 종료 =====

fn close_session_v2(state: i32): i32 {
  println("╔═══════════════════════════════════════╗")
  println("║   Closing Session                     ║")
  println("╚═══════════════════════════════════════╝")
  println("")

  println("=== SSH Disconnect ===")
  println("Reason: User requested")
  println("Status: Closing connection...")

  var next = session_next_state(state)
  session_state_name(next)
  println("✅ Session terminated")
  println("✅ Connection closed")
  println("")

  return 1
}

// ===== MAIN: 전체 대화형 세션 =====

println("")

// 1. Initialize
var state = SESS_STATE_CONNECTING()
state = init_session_v2(192, 22, state)

// 2. Run Commands
var executed = run_commands_v2(state)

// 3. Print Stats
print_session_stats_v2(executed, state)

// 4. Close
close_session_v2(state)

println("╔═══════════════════════════════════════╗")
println("║  FreeLang SSH v2.0 Complete ✅        ║")
println("║  Ready for next session                ║")
println("╚═══════════════════════════════════════╝")
