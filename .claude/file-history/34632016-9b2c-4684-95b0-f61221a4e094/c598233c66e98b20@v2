// netcat v1: 기본 TCP 연결

fn connect_tcp(host: string, port: u64) -> bool {
    println!("Connecting to " ++ host ++ ":" ++ port.to_string())
    true
}

fn main() {
    if connect_tcp("localhost", 8080u64) {
        println!("Connected successfully")
    } else {
        println!("Connection failed")
    }
}
