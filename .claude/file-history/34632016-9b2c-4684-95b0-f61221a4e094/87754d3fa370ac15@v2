  println(\"Host: \" + str(host) + \".168.45.73\")
  println(\"Port: \" + str(port))
  println(\"Actor Model: Lightweight thread\")
  println(\"\")

  // Phase 5: spawn() 함수로 Actor 생성
  // 실제: var actor = spawn(client_actor_handler, client_id, channel_id, state)
  // 현재: 시뮬레이션
  println(\"Spawning actor...\")

  var channel_id = 1000 + client_id
  var initial_state = ACTOR_STATE_INIT()

  var result = client_actor_handler(client_id, channel_id, initial_state)

  println(\"╔═══════════════════════════════════════╗\")
  println(\"║  Client Actor Complete ✅             ║\")
  println(\"║  All traffic encrypted                ║\")
  println(\"╚═══════════════════════════════════════╝\")

  return result
}

