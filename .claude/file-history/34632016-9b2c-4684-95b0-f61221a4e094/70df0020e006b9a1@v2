  │                                       │
  ├──────────[Service Request]───────────▶│
  │                                       │
  │◀──────────[Service Accept]───────────┤
  │                                       │
  ├──────────[Authentication]────────────▶│
  │                                       │
  │◀─────────[Auth Success]───────────────┤
  │                                       │
  ├──────────[Channel Open]──────────────▶│
  │                                       │
  │◀─────────[Channel Open Confirmation]─┤
  │                                       │
