// curl Phase 1: 기본 HTTP 요청
// 목표: GET/POST 요청, 응답 처리, URL 파싱

type RequestID = u64
type Timestamp = u64
type URL = string
type Header = string
type Body = string
type StatusCode = u64

enum HttpMethod {
    Get
    Post
    Put
    Delete
    Head
    Patch
}

enum ProtocolType {
    Http
    Https
}

type ParsedURL {
    protocol: ProtocolType
    host: string
    port: u64
    path: string
}

type HttpRequest {
    id: RequestID
    method: HttpMethod
    url: URL
    parsed_url: ParsedURL
    headers: Vec<Header>
    body: Option<Body>
    timestamp: Timestamp
}

type HttpResponse {
    request_id: RequestID
    status_code: StatusCode
    headers: Vec<Header>
    body: Body
    timestamp: Timestamp
}

type HttpClient {
    requests: Vec<HttpRequest>
    responses: Vec<HttpResponse>
    next_request_id: RequestID
    user_agent: string
}

impl HttpClient {

    fn new() -> HttpClient {
        HttpClient {
            requests: Vec::new(),
            responses: Vec::new(),
            next_request_id: 1000u64,
            user_agent: "curl/1.0 FreeLang"
        }
    }

    // URL 파싱
    fn parse_url(url: URL) -> ParsedURL {
        let protocol = if url.starts_with("https") {
            ProtocolType::Https
        } else {
            ProtocolType::Http
        }

        let port = match protocol {
            ProtocolType::Https => 443u64,
            ProtocolType::Http => 80u64
        }

        // 간단한 파싱 (실제 구현은 더 복잡함)
        ParsedURL {
            protocol: protocol,
            host: "example.com",
            port: port,
            path: "/"
        }
    }

    // GET 요청 생성
    fn get(mut self, url: URL) -> (HttpClient, RequestID) {
        let request_id = self.next_request_id
        self.next_request_id = self.next_request_id + 1u64

        let parsed = HttpClient::parse_url(url)

        let mut headers = Vec::new()
        headers.push("User-Agent: " ++ self.user_agent)
        headers.push("Accept: */*")

        let request = HttpRequest {
            id: request_id,
            method: HttpMethod::Get,
            url: url,
            parsed_url: parsed,
            headers: headers,
            body: None,
            timestamp: get_timestamp()
        }

        self.requests.push(request)
        (self, request_id)
    }

    // POST 요청 생성
    fn post(mut self, url: URL, body: Body) -> (HttpClient, RequestID) {
        let request_id = self.next_request_id
        self.next_request_id = self.next_request_id + 1u64

        let parsed = HttpClient::parse_url(url)

        let mut headers = Vec::new()
        headers.push("User-Agent: " ++ self.user_agent)
        headers.push("Content-Type: application/json")
        headers.push("Content-Length: " ++ body.len().to_string())

        let request = HttpRequest {
            id: request_id,
            method: HttpMethod::Post,
            url: url,
            parsed_url: parsed,
            headers: headers,
            body: Some(body),
            timestamp: get_timestamp()
        }

        self.requests.push(request)
        (self, request_id)
    }

    // PUT 요청
    fn put(mut self, url: URL, body: Body) -> (HttpClient, RequestID) {
        let request_id = self.next_request_id
        self.next_request_id = self.next_request_id + 1u64

        let parsed = HttpClient::parse_url(url)

        let mut headers = Vec::new()
        headers.push("User-Agent: " ++ self.user_agent)
        headers.push("Content-Type: application/json")

        let request = HttpRequest {
            id: request_id,
            method: HttpMethod::Put,
            url: url,
            parsed_url: parsed,
            headers: headers,
            body: Some(body),
            timestamp: get_timestamp()
        }

        self.requests.push(request)
        (self, request_id)
    }

    // DELETE 요청
    fn delete(mut self, url: URL) -> (HttpClient, RequestID) {
        let request_id = self.next_request_id
        self.next_request_id = self.next_request_id + 1u64

        let parsed = HttpClient::parse_url(url)

        let mut headers = Vec::new()
        headers.push("User-Agent: " ++ self.user_agent)

        let request = HttpRequest {
            id: request_id,
            method: HttpMethod::Delete,
            url: url,
            parsed_url: parsed,
            headers: headers,
            body: None,
            timestamp: get_timestamp()
        }

        self.requests.push(request)
        (self, request_id)
    }

    // 응답 시뮬레이션
    fn simulate_response(mut self, request_id: RequestID, status_code: StatusCode, body: Body) -> HttpClient {
        let response = HttpResponse {
            request_id: request_id,
            status_code: status_code,
            headers: Vec::new(),
            body: body,
            timestamp: get_timestamp()
        }

        self.responses.push(response)
        self
    }

    // 요청 정보 조회
    fn get_request(ref self, request_id: RequestID) -> Option<(RequestID, string, URL)> {
        let mut i = 0u64

        while i < self.requests.len() {
            let request = self.requests.get(i)

            match request {
                Some(r) => {
                    if r.id == request_id {
                        let method_str = match r.method {
                            HttpMethod::Get => "GET",
                            HttpMethod::Post => "POST",
                            HttpMethod::Put => "PUT",
                            HttpMethod::Delete => "DELETE",
                            HttpMethod::Head => "HEAD",
                            HttpMethod::Patch => "PATCH"
                        }

                        return Some((r.id, method_str, r.url))
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        None
    }

    // 응답 정보 조회
    fn get_response(ref self, request_id: RequestID) -> Option<(StatusCode, Body)> {
        let mut i = 0u64

        while i < self.responses.len() {
            let response = self.responses.get(i)

            match response {
                Some(r) => {
                    if r.request_id == request_id {
                        return Some((r.status_code, r.body))
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        None
    }

    // 요청 목록
    fn list_requests(ref self) -> Vec<(RequestID, string, StatusCode)> {
        let mut result = Vec::new()
        let mut i = 0u64

        while i < self.requests.len() {
            let request = self.requests.get(i)

            match request {
                Some(r) => {
                    let method_str = match r.method {
                        HttpMethod::Get => "GET",
                        HttpMethod::Post => "POST",
                        HttpMethod::Put => "PUT",
                        HttpMethod::Delete => "DELETE",
                        HttpMethod::Head => "HEAD",
                        HttpMethod::Patch => "PATCH"
                    }

                    // 응답 상태 코드 찾기
                    let mut status = 0u64
                    let mut j = 0u64

                    while j < self.responses.len() {
                        let response = self.responses.get(j)

                        match response {
                            Some(resp) => {
                                if resp.request_id == r.id {
                                    status = resp.status_code
                                }
                            }
                            None => {}
                        }

                        j = j + 1u64
                    }

                    result.push((r.id, method_str, status))
                }
                None => {}
            }

            i = i + 1u64
        }

        result
    }

    // User-Agent 설정
    fn set_user_agent(mut self, ua: string) -> HttpClient {
        self.user_agent = ua
        self
    }

    // 헤더 추가
    fn add_header(mut self, request_id: RequestID, header: Header) -> HttpClient {
        let mut i = 0u64

        while i < self.requests.len() {
            let request = self.requests.get(i)

            match request {
                Some(r) => {
                    if r.id == request_id {
                        let mut updated_request = HttpRequest {
                            id: r.id,
                            method: r.method,
                            url: r.url,
                            parsed_url: r.parsed_url,
                            headers: r.headers,
                            body: r.body,
                            timestamp: r.timestamp
                        }
                        updated_request.headers.push(header)
                        self.requests.set(i, updated_request)
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        self
    }

    // 요청 총 수
    fn request_count(ref self) -> u64 {
        self.requests.len()
    }

    // 응답 총 수
    fn response_count(ref self) -> u64 {
        self.responses.len()
    }
}

// === Option 타입 ===

type Option<T> {
    Some(T)
    None
}

// === 유틸리티 ===

fn get_timestamp() -> Timestamp {
    12345678u64
}

// === 테스트 ===

fn main() {
    println!("=== curl Phase 1: 기본 HTTP 요청 ===")

    let mut client = HttpClient::new()
    println!("🔌 HTTP 클라이언트 초기화")

    // GET 요청
    println!("\n📤 GET 요청:")
    let (client2, req1_id) = client.get("https://api.example.com/users")
    client = client2
    println!("✅ GET /users (ID: " ++ req1_id.to_string() ++ ")")

    let (client2, req2_id) = client.get("https://api.example.com/posts")
    client = client2
    println!("✅ GET /posts (ID: " ++ req2_id.to_string() ++ ")")

    // POST 요청
    println!("\n📤 POST 요청:")
    let (client2, req3_id) = client.post("https://api.example.com/users", "{\"name\":\"kim\",\"email\":\"kim@example.com\"}")
    client = client2
    println!("✅ POST /users (ID: " ++ req3_id.to_string() ++ ")")

    // PUT 요청
    println!("\n📤 PUT 요청:")
    let (client2, req4_id) = client.put("https://api.example.com/users/1", "{\"name\":\"kim2\"}")
    client = client2
    println!("✅ PUT /users/1 (ID: " ++ req4_id.to_string() ++ ")")

    // DELETE 요청
    println!("\n📤 DELETE 요청:")
    let (client2, req5_id) = client.delete("https://api.example.com/users/1")
    client = client2
    println!("✅ DELETE /users/1 (ID: " ++ req5_id.to_string() ++ ")")

    // 응답 시뮬레이션
    println!("\n📥 응답 수신:")
    let client2 = client.simulate_response(req1_id, 200u64, "[{\"id\":1,\"name\":\"kim\"},{\"id\":2,\"name\":\"lee\"}]")
    client = client2
    println!("✅ 200 OK (ID: " ++ req1_id.to_string() ++ ")")

    let client2 = client.simulate_response(req3_id, 201u64, "{\"id\":3,\"name\":\"kim\",\"email\":\"kim@example.com\"}")
    client = client2
    println!("✅ 201 Created (ID: " ++ req3_id.to_string() ++ ")")

    let client2 = client.simulate_response(req5_id, 204u64, "")
    client = client2
    println!("✅ 204 No Content (ID: " ++ req5_id.to_string() ++ ")")

    // 요청 정보
    println!("\n ℹ️  요청 정보:")
    let info = client.get_request(req1_id)
    match info {
        Some((id, method, url)) => {
            println!("  [" ++ id.to_string() ++ "] " ++ method ++ " " ++ url)
        }
        None => {
            println!("  (요청 없음)")
        }
    }

    // 응답 정보
    println!("\n ℹ️  응답 정보:")
    let resp = client.get_response(req1_id)
    match resp {
        Some((status, body)) => {
            println!("  상태: " ++ status.to_string())
            println!("  본문: " ++ body)
        }
        None => {
            println!("  (응답 없음)")
        }
    }

    // 요청 목록
    println!("\n📋 요청 목록:")
    let requests = client.list_requests()
    let mut i = 0u64
    while i < requests.len() {
        let (id, method, status) = requests.get(i).unwrap()
        let status_str = if status == 0u64 { "대기" } else { status.to_string() }
        println!("  [" ++ method ++ "] " ++ id.to_string() ++ " (상태: " ++ status_str ++ ")")
        i = i + 1u64
    }

    // 통계
    println!("\n📊 통계:")
    let req_count = client.request_count()
    let resp_count = client.response_count()
    println!("  요청: " ++ req_count.to_string())
    println!("  응답: " ++ resp_count.to_string())
}
