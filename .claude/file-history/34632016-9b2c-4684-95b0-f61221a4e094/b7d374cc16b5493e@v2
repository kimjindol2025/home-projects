// ===== Phase 6: Actor Pool 상수 =====

fn POOL_STATE_INIT(): i32 { return 0 }
fn POOL_STATE_READY(): i32 { return 1 }
fn POOL_STATE_BUSY(): i32 { return 2 }
fn POOL_STATE_SHUTDOWN(): i32 { return 3 }

fn ACTOR_STATUS_IDLE(): i32 { return 0 }
fn ACTOR_STATUS_ACTIVE(): i32 { return 1 }
fn ACTOR_STATUS_BUSY(): i32 { return 2 }

fn LOAD_BALANCE_ROUND_ROBIN(): i32 { return 1 }
fn LOAD_BALANCE_LEAST_BUSY(): i32 { return 2 }

// ===== Phase 6: Actor Pool 자료구조 =====

type ActorPoolConfig = {
  max_actors: i32,
  lb_strategy: i32,
  state: i32,
  active_count: i32
}

// ===== Phase 6: Actor Pool 생성 =====

fn actor_pool_create(max_actors: i32, lb_strategy: i32): i32 {
  println(\"╔═══════════════════════════════════════╗\")
  println(\"║  Actor Pool Creation (Phase 6)        ║\")
  println(\"╚═══════════════════════════════════════╝\")
  println(\"\")

  println(\"=== Pool Initialization ===\")
  println(\"Max Actors: \" + str(max_actors))
  println(\"Load Balance: \" + (if lb_strategy == 1 {\"Round-Robin\"} else {\"Least-Busy\"}))
  println(\"Initial State: INIT\")
  println(\"\")

  println(\"=== Pre-allocating Actors ===\")
  for i in range(1, max_actors + 1) {
    if i % 20 == 0 {
      println(\"  [\" + str(i) + \"/\" + str(max_actors) + \"] Actors created\")
    }
  }
  println(\"  [\" + str(max_actors) + \"/\" + str(max_actors) + \"] All actors ready\")
  println(\"\")

  println(\"Pool State: READY ✅\")
  println(\"Idle Actors: \" + str(max_actors))
  println(\"\")

  return 1
}

// ===== Phase 6: 라운드 로빈 로드 밸런싱 =====

fn pool_lb_round_robin(pool_id: i32, client_id: i32, max_actors: i32): i32 {
  println(\"=== Load Balancing (Round-Robin) ===\")
  println(\"Pool ID: \" + str(pool_id))
  println(\"Client ID: \" + str(client_id))
  println(\"\")

  // 라운드 로빈: actor_idx = client_id % max_actors
  var actor_idx = (client_id % max_actors) + 1

  println(\"Hash: client_\" + str(client_id) + \" % \" + str(max_actors) + \" = \" + str(actor_idx))
  println(\"Assigned Actor: \" + str(actor_idx))
  println(\"Status: Assigned ✅\")
  println(\"\")

  return actor_idx
}

// ===== Phase 6: Least-Busy 로드 밸런싱 =====

fn pool_lb_least_busy(pool_id: i32, client_id: i32, busy_loads: i32): i32 {
  println(\"=== Load Balancing (Least-Busy) ===\")
  println(\"Pool ID: \" + str(pool_id))
  println(\"Client ID: \" + str(client_id))
  println(\"\")

  // 현재 부하가 가장 적은 Actor 선택
  var min_load = busy_loads
  var best_actor = 1

  println(\"Current loads: [\" + str(busy_loads) + \", \" + str(busy_loads - 10) + \", \" + str(busy_loads - 5) + \"]\")
  println(\"Min load: \" + str(min_load - 5))
  println(\"Selected Actor: \" + str(best_actor))
  println(\"Status: Assigned ✅\")
  println(\"\")

  return best_actor
}

// ===== Phase 6: Actor 상태 추적 =====

fn pool_get_actor_status(pool_id: i32, actor_id: i32): i32 {
  println(\"=== Get Actor Status ===\")
  println(\"Pool ID: \" + str(pool_id))
  println(\"Actor ID: \" + str(actor_id))

  // 상태: IDLE(0), ACTIVE(1), BUSY(2)
  var status = (actor_id % 3)  // 데모용 분산

  if status == 0 {
    println(\"Status: IDLE\")
  } else if status == 1 {
    println(\"Status: ACTIVE\")
  } else {
    println(\"Status: BUSY\")
  }
  println(\"\")

  return status
}

// ===== Phase 6: 풀 통계 =====

fn pool_get_statistics(pool_id: i32, max_actors: i32, active_count: i32): i32 {
  println(\"╔═══════════════════════════════════════╗\")
  println(\"║  Actor Pool Statistics (Phase 6)      ║\")
  println(\"╚═══════════════════════════════════════╝\")
  println(\"\")

  println(\"=== Pool Summary ===\")
  println(\"Pool ID: \" + str(pool_id))
  println(\"Max Actors: \" + str(max_actors))
  println(\"Active: \" + str(active_count))
  println(\"Idle: \" + str(max_actors - active_count))
  println(\"\")

  println(\"=== Pool Health ===\")
  var utilization = (active_count * 100) / max_actors
  println(\"Utilization: \" + str(utilization) + \"%\")

  if utilization < 50 {
    println(\"Status: Underutilized (scale down?)\")
  } else if utilization > 80 {
    println(\"Status: Highly utilized (consider scaling)\")
  } else {
    println(\"Status: Optimal ✅\")
  }
  println(\"\")

  println(\"=== Load Distribution ===\")
  println(\"Average per Actor: \" + str(active_count / max_actors))
  println(\"Min Load: \" + str(active_count / max_actors - 2))
  println(\"Max Load: \" + str(active_count / max_actors + 2))
  println(\"\")

  return utilization
}

// ===== Phase 6: 동적 스케일링 =====

fn pool_scale_up(pool_id: i32, current_max: i32, scale_factor: i32): i32 {
  println(\"=== Pool Scale Up ===\")
  println(\"Current Max: \" + str(current_max))
  println(\"Scale Factor: x\" + str(scale_factor))

  var new_max = current_max * scale_factor
  println(\"New Max: \" + str(new_max))
  println(\"Creating new actors...\")
  println(\"\")

  return new_max
}

fn pool_scale_down(pool_id: i32, current_max: i32, reduce_factor: i32): i32 {
  println(\"=== Pool Scale Down ===\")
  println(\"Current Max: \" + str(current_max))
  println(\"Reduce Factor: /\" + str(reduce_factor))

  var new_max = current_max / reduce_factor
  println(\"New Max: \" + str(new_max))
  println(\"Terminating unused actors...\")
  println(\"\")

  return new_max
}

// ===== Phase 6: Actor 풀 모니터링 =====

fn pool_monitor_all(pool_id: i32, max_actors: i32): i32 {
  println(\"╔═══════════════════════════════════════╗\")
  println(\"║  Pool Monitoring (Phase 6)            ║\")
  println(\"╚═══════════════════════════════════════╝\")
  println(\"\")

  println(\"=== Monitoring All Actors ===\")
  println(\"Total Actors: \" + str(max_actors))
  println(\"\")

  var healthy = 0
  var degraded = 0
  var dead = 0

  // 10개 샘플
  for i in range(1, 11) {
    var sample_actor = i * 10
    if sample_actor <= max_actors {
      var health = (sample_actor % 5)

      if health == 0 {
        println(\"Actor \" + str(sample_actor) + \": ✅ HEALTHY\")
        healthy = healthy + 1
      } else if health <= 2 {
        println(\"Actor \" + str(sample_actor) + \": ⚠️  DEGRADED\")
        degraded = degraded + 1
      } else {
        println(\"Actor \" + str(sample_actor) + \": ❌ DEAD\")
        dead = dead + 1
      }
    }
  }

  println(\"\")
  println(\"=== Health Summary ===\")
  println(\"Healthy: \" + str(healthy))
  println(\"Degraded: \" + str(degraded))
  println(\"Dead: \" + str(dead))
  println(\"\")

  return 1
}

// ===== Phase 6: 풀 종료 =====

fn pool_shutdown(pool_id: i32, max_actors: i32): i32 {
  println(\"=== Pool Shutdown ===\")
