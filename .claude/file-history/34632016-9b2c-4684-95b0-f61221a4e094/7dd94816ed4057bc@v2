## 사용 예제

### 예제 1: 스택 연산

```javascript
// 1. 세션 생성
ws.send(JSON.stringify({
  type: "command",
  command: "create_session",
  payload: { programName: "Math" }
}));

// 2. 값 푸시
ws.send(JSON.stringify({
  type: "command",
  command: "stack_push",
  payload: { type: "i32", value: 10 }
}));

ws.send(JSON.stringify({
  type: "command",
  command: "stack_push",
  payload: { type: "i32", value: 20 }
}));

// 3. 스택 상태 조회
ws.send(JSON.stringify({
  type: "command",
  command: "stack_get_state"
}));
```

### 예제 2: Actor 메시징

```javascript
// 1. Actor 생성
ws.send(JSON.stringify({
  type: "command",
  command: "actor_spawn",
  payload: { name: "Producer" }
}));

ws.send(JSON.stringify({
  type: "command",
  command: "actor_spawn",
  payload: { name: "Consumer" }
}));

// 2. 메시지 전송
ws.send(JSON.stringify({
  type: "command",
  command: "actor_send_message",
  payload: {
    fromActorId: "actor_0",
    toActorId: "actor_1",
    value: "data",
    messageType: "data"
  }
}));

// 3. 데드락 검사
ws.send(JSON.stringify({
  type: "command",
  command: "actor_detect_deadlock"
}));
```

