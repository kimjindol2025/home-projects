    "toActorId": "actor_1",
    "value": "hello",
    "messageType": "data"
  }
}
```

---

### message_delivered

```json
{
  "type": "event",
  "payload": {
    "type": "message_delivered",
    "fromActorId": "actor_0",
    "toActorId": "actor_1",
    "messageId": "msg_123"
  }
}
```

---

### deadlock_detected

```json
{
  "type": "event",
  "payload": {
    "type": "deadlock_detected",
    "actors": ["actor_0", "actor_1", "actor_2"],
