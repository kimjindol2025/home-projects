// ===== Phase 1: 상태 검증 =====

fn is_server_state_valid(state: i32): i32 {
  if state >= SSH_SERVER_STATE_INIT() {
    if state <= SSH_SERVER_STATE_CLOSED() {
      return 1
    }
  }
  return 0
}

fn is_user_authenticated(): i32 {
  if authenticated_username > 0 {
    return 1
  }
  return 0
}

fn can_accept_commands(): i32 {
  if server_state == SSH_SERVER_STATE_SESSION_ACTIVE() {
    return 1
  }
  return 0
}

// ===== Phase 2: 서버 상태 머신 =====

fn handle_server_event(event: i32): i32 {
  if server_state == SSH_SERVER_STATE_INIT() {
    if event == SSH_SERVER_EVENT_INIT() {
      server_state = SSH_SERVER_STATE_LISTENING()
      server_last_event = event
      return 1
    }
  } else if server_state == SSH_SERVER_STATE_LISTENING() {
    if event == SSH_SERVER_EVENT_CLIENT_CONNECT() {
      server_state = SSH_SERVER_STATE_CONNECTING()
      server_last_event = event
      return 1
    }
  } else if server_state == SSH_SERVER_STATE_CONNECTING() {
    if event == SSH_SERVER_EVENT_HANDSHAKE_COMPLETE() {
      server_state = SSH_SERVER_STATE_HANDSHAKE()
      server_last_event = event
      return 1
    }
  } else if server_state == SSH_SERVER_STATE_HANDSHAKE() {
    if event == SSH_SERVER_EVENT_KEY_EXCHANGE_COMPLETE() {
      server_state = SSH_SERVER_STATE_KEY_EXCHANGE()
      server_last_event = event
      return 1
    }
  } else if server_state == SSH_SERVER_STATE_KEY_EXCHANGE() {
    if event == SSH_SERVER_EVENT_AUTH_COMPLETE() {
      server_state = SSH_SERVER_STATE_AUTHENTICATED()
      server_last_event = event
      return 1
    }
  } else if server_state == SSH_SERVER_STATE_AUTHENTICATED() {
    if event == SSH_SERVER_EVENT_CHANNEL_OPEN() {
      server_state = SSH_SERVER_STATE_CHANNEL_OPEN()
      server_last_event = event
      return 1
    }
  } else if server_state == SSH_SERVER_STATE_CHANNEL_OPEN() {
    if event == SSH_SERVER_EVENT_READY() {
      server_state = SSH_SERVER_STATE_SESSION_ACTIVE()
      server_last_event = event
      return 1
    }
  } else if server_state == SSH_SERVER_STATE_SESSION_ACTIVE() {
    if event == SSH_SERVER_EVENT_DISCONNECT() {
      server_state = SSH_SERVER_STATE_CLOSED()
      server_last_event = event
      return 1
    }
  }

  return 0
}

