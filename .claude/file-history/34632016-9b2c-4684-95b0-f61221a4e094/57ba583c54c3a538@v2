// ===== Phase 5: 서버 상태 상수 =====

fn SERVER_STATE_INIT(): i32 { return 0 }
fn SERVER_STATE_LISTENING(): i32 { return 1 }
fn SERVER_STATE_ACCEPTING(): i32 { return 2 }
fn SERVER_STATE_READY(): i32 { return 3 }
fn SERVER_STATE_SHUTDOWN(): i32 { return 4 }

fn SERVER_MSG_HANDSHAKE_ACK(): i32 { return 1 }
fn SERVER_MSG_KEY_EXCHANGE_ACK(): i32 { return 2 }
fn SERVER_MSG_AUTHENTICATE_ACK(): i32 { return 3 }
fn SERVER_MSG_COMMAND_ACK(): i32 { return 4 }
fn SERVER_MSG_DISCONNECT_ACK(): i32 { return 5 }

// ===== Phase 4 암호화 함수 (재사용) =====

fn server_hash_dh_context_v5(client_pub: i32, server_pub: i32): i32 {
  var dh_context = client_pub + server_pub
  var shared_secret = (client_pub * server_pub) + 670592745
  return shared_secret
}

fn server_verify_auth_hmac_v5(auth_data: i32, stored_hmac: i32): i32 {
  var computed_hmac = (auth_data * 31 + 12345) % 1000000
  if computed_hmac == stored_hmac {
    return 1
  } else {
    return 0
  }
}

fn server_encrypt_session_data_v5(data: i32, session_key: i32): i32 {
  var encrypted_size = data * 2
  return encrypted_size
}

fn server_create_session_uuid_v5(): i32 {
  return 1
}

// ===== Phase 5: 서버 상태 전환 =====

fn server_next_state(current: i32): i32 {
  if current == SERVER_STATE_INIT() {
    return SERVER_STATE_LISTENING()
  } else if current == SERVER_STATE_LISTENING() {
    return SERVER_STATE_ACCEPTING()
  } else if current == SERVER_STATE_ACCEPTING() {
    return SERVER_STATE_READY()
  } else if current == SERVER_STATE_READY() {
    return SERVER_STATE_SHUTDOWN()
  }
  return current
}

