// curl Phase 3: 데이터 처리 (JSON, 다운로드, 폼)
// 목표: JSON 처리, 파일 다운로드, 폼 데이터

type RequestID = u64
type FileID = u64
type Timestamp = u64
type URL = string
type StatusCode = u64
type FileName = string
type FileSize = u64

enum HttpMethod {
    Get
    Post
    Put
    Delete
}

enum ContentType {
    Json
    FormUrlencoded
    FormData
    Binary
    Text
}

type JsonValue {
    content: string
}

type FormField {
    name: string
    value: string
}

type DownloadedFile {
    id: FileID
    name: FileName
    size: FileSize
    url: URL
    downloaded_at: Timestamp
    status: u64
}

type HttpRequest {
    id: RequestID
    method: HttpMethod
    url: URL
    content_type: ContentType
    json_body: Option<JsonValue>
    form_fields: Vec<FormField>
    timestamp: Timestamp
}

type HttpResponse {
    request_id: RequestID
    status_code: StatusCode
    content_type: ContentType
    body: string
    size: FileSize
    timestamp: Timestamp
}

type HttpClient {
    requests: Vec<HttpRequest>
    responses: Vec<HttpResponse>
    downloads: Vec<DownloadedFile>
    next_request_id: RequestID
    next_file_id: FileID
}

impl HttpClient {

    fn new() -> HttpClient {
        HttpClient {
            requests: Vec::new(),
            responses: Vec::new(),
            downloads: Vec::new(),
            next_request_id: 1000u64,
            next_file_id: 100000u64
        }
    }

    // JSON 데이터와 함께 POST
    fn post_json(mut self, url: URL, json: string) -> (HttpClient, RequestID) {
        let request_id = self.next_request_id
        self.next_request_id = self.next_request_id + 1u64

        let request = HttpRequest {
            id: request_id,
            method: HttpMethod::Post,
            url: url,
            content_type: ContentType::Json,
            json_body: Some(JsonValue { content: json }),
            form_fields: Vec::new(),
            timestamp: get_timestamp()
        }

        self.requests.push(request)
        (self, request_id)
    }

    // 폼 데이터와 함께 POST
    fn post_form(mut self, url: URL, fields: Vec<FormField>) -> (HttpClient, RequestID) {
        let request_id = self.next_request_id
        self.next_request_id = self.next_request_id + 1u64

        let request = HttpRequest {
            id: request_id,
            method: HttpMethod::Post,
            url: url,
            content_type: ContentType::FormUrlencoded,
            json_body: None,
            form_fields: fields,
            timestamp: get_timestamp()
        }

        self.requests.push(request)
        (self, request_id)
    }

    // GET 요청 (다운로드)
    fn download(mut self, url: URL, filename: FileName) -> (HttpClient, RequestID) {
        let request_id = self.next_request_id
        self.next_request_id = self.next_request_id + 1u64

        let request = HttpRequest {
            id: request_id,
            method: HttpMethod::Get,
            url: url,
            content_type: ContentType::Binary,
            json_body: None,
            form_fields: Vec::new(),
            timestamp: get_timestamp()
        }

        self.requests.push(request)
        (self, request_id)
    }

    // 다운로드 완료 처리
    fn complete_download(mut self, request_id: RequestID, filename: FileName, file_size: FileSize, url: URL) -> HttpClient {
        let file_id = self.next_file_id
        self.next_file_id = self.next_file_id + 1u64

        let downloaded_file = DownloadedFile {
            id: file_id,
            name: filename,
            size: file_size,
            url: url,
            downloaded_at: get_timestamp(),
            status: 200u64
        }

        self.downloads.push(downloaded_file)
        self
    }

    // JSON 응답 처리
    fn parse_json_response(response_body: string) -> Option<JsonValue> {
        if response_body.len() > 0u64 {
            Some(JsonValue { content: response_body })
        } else {
            None
        }
    }

    // 응답 저장
    fn save_response(mut self, request_id: RequestID, status_code: StatusCode, body: string) -> HttpClient {
        let response = HttpResponse {
            request_id: request_id,
            status_code: status_code,
            content_type: ContentType::Json,
            body: body,
            size: body.len(),
            timestamp: get_timestamp()
        }

        self.responses.push(response)
        self
    }

    // 다운로드 목록
    fn list_downloads(ref self) -> Vec<(FileID, FileName, FileSize)> {
        let mut result = Vec::new()
        let mut i = 0u64

        while i < self.downloads.len() {
            let download = self.downloads.get(i)

            match download {
                Some(d) => {
                    result.push((d.id, d.name, d.size))
                }
                None => {}
            }

            i = i + 1u64
        }

        result
    }

    // 요청 목록
    fn list_requests(ref self) -> Vec<(RequestID, string)> {
        let mut result = Vec::new()
        let mut i = 0u64

        while i < self.requests.len() {
            let request = self.requests.get(i)

            match request {
                Some(r) => {
                    let method_str = match r.method {
                        HttpMethod::Get => "GET",
                        HttpMethod::Post => "POST",
                        HttpMethod::Put => "PUT",
                        HttpMethod::Delete => "DELETE"
                    }

                    result.push((r.id, method_str))
                }
                None => {}
            }

            i = i + 1u64
        }

        result
    }

    // 응답 조회
    fn get_response(ref self, request_id: RequestID) -> Option<(StatusCode, string)> {
        let mut i = 0u64

        while i < self.responses.len() {
            let response = self.responses.get(i)

            match response {
                Some(r) => {
                    if r.request_id == request_id {
                        return Some((r.status_code, r.body))
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        None
    }

    // 통계
    fn get_stats(ref self) -> (u64, u64, u64) {
        (self.requests.len(), self.responses.len(), self.downloads.len())
    }
}

// === Option 타입 ===

type Option<T> {
    Some(T)
    None
}

// === 유틸리티 ===

fn get_timestamp() -> Timestamp {
    12345678u64
}

// === 테스트 ===

fn main() {
    println!("=== curl Phase 3: 데이터 처리 ===")

    let mut client = HttpClient::new()
    println!("🔌 HTTP 클라이언트 초기화")

    // JSON POST
    println!("\n📤 JSON POST:")
    let json_data = "{\"name\":\"kim\",\"email\":\"kim@example.com\",\"age\":30}"
    let (client2, req1_id) = client.post_json("https://api.example.com/users", json_data)
    client = client2
    println!("✅ POST /users (JSON)")

    let json_data = "{\"title\":\"New Post\",\"content\":\"This is a test post\"}"
    let (client2, req2_id) = client.post_json("https://api.example.com/posts", json_data)
    client = client2
    println!("✅ POST /posts (JSON)")

    // 폼 데이터 POST
    println!("\n📤 폼 데이터 POST:")
    let mut fields = Vec::new()
    fields.push(FormField { name: "username", value: "kim" })
    fields.push(FormField { name: "password", value: "securepass123" })
    fields.push(FormField { name: "remember", value: "true" })

    let (client2, req3_id) = client.post_form("https://api.example.com/login", fields)
    client = client2
    println!("✅ POST /login (폼 데이터)")

    // 파일 다운로드
    println!("\n📥 파일 다운로드:")
    let (client2, req4_id) = client.download("https://example.com/files/document.pdf", "document.pdf")
    client = client2
    println!("✅ GET document.pdf")

    let (client2, req5_id) = client.download("https://example.com/files/image.jpg", "image.jpg")
    client = client2
    println!("✅ GET image.jpg")

    // 다운로드 완료
    println!("\n✅ 다운로드 완료:")
    let client2 = client.complete_download(req4_id, "document.pdf", 1048576u64, "https://example.com/files/document.pdf")
    client = client2
    println!("✅ document.pdf (1 MB)")

    let client2 = client.complete_download(req5_id, "image.jpg", 524288u64, "https://example.com/files/image.jpg")
    client = client2
    println!("✅ image.jpg (512 KB)")

    // 응답 저장
    println!("\n📥 응답 저장:")
    let response_body = "{\"id\":1,\"name\":\"kim\",\"email\":\"kim@example.com\",\"created\":\"2024-01-01\"}"
    let client2 = client.save_response(req1_id, 201u64, response_body)
    client = client2
    println!("✅ 201 Created")

    let response_body = "{\"id\":1,\"title\":\"New Post\",\"content\":\"This is a test post\",\"author\":\"kim\"}"
    let client2 = client.save_response(req2_id, 201u64, response_body)
    client = client2
    println!("✅ 201 Created")

    // 응답 조회
    println!("\n ℹ️  응답 조회 (요청 1):")
    let resp = client.get_response(req1_id)
    match resp {
        Some((status, body)) => {
            println!("  상태: " ++ status.to_string())
            println!("  크기: " ++ body.len().to_string() ++ " bytes")
        }
        None => {}
    }

    // 요청 목록
    println!("\n📋 요청 목록:")
    let requests = client.list_requests()
    let mut i = 0u64
    while i < requests.len() {
        let (id, method) = requests.get(i).unwrap()
        println!("  [" ++ method ++ "] " ++ id.to_string())
        i = i + 1u64
    }

    // 다운로드 목록
    println!("\n📥 다운로드 목록:")
    let downloads = client.list_downloads()
    let mut i = 0u64
    while i < downloads.len() {
        let (id, name, size) = downloads.get(i).unwrap()
        println!("  " ++ name ++ " (" ++ size.to_string() ++ " bytes)")
        i = i + 1u64
    }

    // 통계
    println!("\n📊 통계:")
    let (req_count, resp_count, dl_count) = client.get_stats()
    println!("  요청: " ++ req_count.to_string())
    println!("  응답: " ++ resp_count.to_string())
    println!("  다운로드: " ++ dl_count.to_string())
}
