// neovim Phase 2: 플러그인 및 설정
type PluginID = u64
type Timestamp = u64

type Plugin {
    id: PluginID
    name: string
    enabled: bool
    loaded_at: Timestamp
}

type EditorConfig {
    line_numbers: bool
    tab_size: u64
    syntax_highlight: bool
    auto_indent: bool
}

type PluginManager {
    plugins: Vec<Plugin>
    config: EditorConfig
    next_plugin_id: PluginID
}

impl PluginManager {
    fn new() -> PluginManager {
        PluginManager {
            plugins: Vec::new(),
            config: EditorConfig {
                line_numbers: true,
                tab_size: 4u64,
                syntax_highlight: true,
                auto_indent: true
            },
            next_plugin_id: 1000u64
        }
    }

    fn install_plugin(mut self, plugin_name: string) -> (PluginManager, PluginID) {
        let id = self.next_plugin_id
        self.next_plugin_id = self.next_plugin_id + 1u64

        let plugin = Plugin {
            id: id,
            name: plugin_name,
            enabled: true,
            loaded_at: get_timestamp()
        }

        self.plugins.push(plugin)
        (self, id)
    }

    fn disable_plugin(mut self, plugin_id: PluginID) -> (PluginManager, bool) {
        let mut found = false
        let mut i = 0u64

        while i < self.plugins.len() {
            let plugin = self.plugins.get(i)

            match plugin {
                Some(p) => {
                    if p.id == plugin_id {
                        let updated = Plugin {
                            id: p.id,
                            name: p.name,
                            enabled: false,
                            loaded_at: p.loaded_at
                        }
                        self.plugins.set(i, updated)
                        found = true
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        (self, found)
    }

    fn list_plugins(ref self) -> Vec<(PluginID, string, bool)> {
        let mut result = Vec::new()
        let mut i = 0u64

        while i < self.plugins.len() {
            let plugin = self.plugins.get(i)

            match plugin {
                Some(p) => {
                    result.push((p.id, p.name, p.enabled))
                }
                None => {}
            }

            i = i + 1u64
        }

        result
    }

    fn update_config(mut self, tab_size: u64, line_numbers: bool) -> PluginManager {
        self.config.tab_size = tab_size
        self.config.line_numbers = line_numbers
        self
    }

    fn get_config(ref self) -> (u64, bool, bool, bool) {
        (
            self.config.tab_size,
            self.config.line_numbers,
            self.config.syntax_highlight,
            self.config.auto_indent
        )
    }
}

fn get_timestamp() -> Timestamp { 12345678u64 }

fn main() {
    println!("=== neovim Phase 2: 플러그인 + 설정 ===")

    let mut pm = PluginManager::new()
    println!("🔧 플러그인 매니저 초기화")

    let (pm2, id1) = pm.install_plugin("vim-airline")
    pm = pm2
    println!("✅ vim-airline 설치")

    let (pm2, id2) = pm.install_plugin("nvim-treesitter")
    pm = pm2
    println!("✅ nvim-treesitter 설치")

    let (pm2, id3) = pm.install_plugin("telescope.nvim")
    pm = pm2
    println!("✅ telescope.nvim 설치")

    let plugins = pm.list_plugins()
    println!("\n📋 플러그인:")
    let mut i = 0u64
    while i < plugins.len() {
        let (_, name, enabled) = plugins.get(i).unwrap()
        let status = if enabled { "활성화" } else { "비활성화" }
        println!("  " ++ name ++ " (" ++ status ++ ")")
        i = i + 1u64
    }

    pm = pm.update_config(2u64, true)
    println!("\n⚙️  설정 업데이트: tab=2, line_numbers=true")

    let (tab, lines, syntax, indent) = pm.get_config()
    println!("\n📊 현재 설정:")
    println!("  Tab: " ++ tab.to_string())
    println!("  Line numbers: " ++ (if lines { "on" } else { "off" }))
    println!("  Syntax: " ++ (if syntax { "on" } else { "off" }))
}
