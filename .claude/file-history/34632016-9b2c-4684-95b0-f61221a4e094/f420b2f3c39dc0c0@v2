// nmap Phase 3: OS 감지 및 필터링
type ScanID = u64

type OsInfo {
    name: string
    confidence: u64
}

type ScanFilter {
    port_range: (u64, u64)
    service_filter: string
    status_filter: string
}

type AdvancedScanner {
    scans: Vec<(ScanID, string)>
    os_info: Vec<(ScanID, OsInfo)>
    filters: Vec<ScanFilter>
    next_scan_id: ScanID
}

impl AdvancedScanner {
    fn new() -> AdvancedScanner {
        AdvancedScanner {
            scans: Vec::new(),
            os_info: Vec::new(),
            filters: Vec::new(),
            next_scan_id: 1000u64
        }
    }

    fn create_scan(mut self, target: string) -> (AdvancedScanner, ScanID) {
        let scan_id = self.next_scan_id
        self.next_scan_id = self.next_scan_id + 1u64

        self.scans.push((scan_id, target))
        (self, scan_id)
    }

    fn detect_os(mut self, scan_id: ScanID, os_name: string, confidence: u64) -> AdvancedScanner {
        self.os_info.push((scan_id, OsInfo {
            name: os_name,
            confidence: confidence
        }))
        self
    }

    fn add_filter(mut self, start_port: u64, end_port: u64, service: string) -> AdvancedScanner {
        self.filters.push(ScanFilter {
            port_range: (start_port, end_port),
            service_filter: service,
            status_filter: "open"
        })
        self
    }

    fn get_os_detection(ref self, scan_id: ScanID) -> Option<(string, u64)> {
        let mut i = 0u64

        while i < self.os_info.len() {
            let (sid, os) = self.os_info.get(i)

            match sid {
                Some(id) => {
                    if id == scan_id {
                        return Some((os.name, os.confidence))
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        None
    }
}

type Option<T> {
    Some(T)
    None
}

fn main() {
    println!("=== nmap Phase 3: OS 감지 ===")

    let mut scanner = AdvancedScanner::new()
    println!("🔍 고급 스캐너 초기화")

    let (scanner2, scan1) = scanner.create_scan("192.168.1.1")
    scanner = scanner2
    println!("✅ 스캔 생성")

    scanner = scanner.detect_os(scan1, "Linux 3.10", 95u64)
    println!("✅ OS 감지: Linux (신뢰도 95%)")

    scanner = scanner.add_filter(1u64, 1024u64, "common")
    println!("✅ 필터 추가: well-known ports")

    let os = scanner.get_os_detection(scan1)
    match os {
        Some((name, conf)) => {
            println!("\n🖥️  OS 정보: " ++ name ++ " (" ++ conf.to_string() ++ "%)")
        }
        None => {}
    }
}
