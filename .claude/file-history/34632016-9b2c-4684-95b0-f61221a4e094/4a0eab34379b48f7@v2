/**
 * Environment Configuration Manager
 * Manages .env variables and Gogs API settings
 */

import path from 'path';

// Load .env file
const envPath = path.join(__dirname, '../.env');
try {
  require('dotenv').config({ path: envPath });
} catch (e) {
  console.warn('dotenv not installed, using process.env directly');
}

export const config = {
  // Server
  port: parseInt(process.env.PORT || '50101', 10),
  nodeEnv: process.env.NODE_ENV || 'development',
  logLevel: process.env.LOG_LEVEL || 'info',

  // Gogs API
  gogs: {
    url: process.env.GOGS_URL || 'https://gogs.dclub.kr',
    apiToken: process.env.GOGS_API_TOKEN || '826b3705d8a0602cf89a02327dcee25e991dd630',
    repoOwner: process.env.GOGS_REPO_OWNER || 'kim',
    repoName: process.env.GOGS_REPO_NAME || 'freelang-v4-ide',
    repoFull: process.env.GOGS_REPO_FULL || 'kim/freelang-v4-ide'
  },

  // IDE
  ide: {
    sessionTimeout: parseInt(process.env.IDE_SESSION_TIMEOUT || '3600000', 10),
    maxStackDepth: parseInt(process.env.IDE_MAX_STACK_DEPTH || '1000', 10),
    maxActors: parseInt(process.env.IDE_MAX_ACTORS || '500', 10)
  },

  // Security
  security: {
    enableSecurityHeaders: process.env.ENABLE_SECURITY_HEADERS === 'true',
    enableMasking: process.env.ENABLE_MASKING === 'true',
    enableRbac: process.env.ENABLE_RBAC === 'true',
