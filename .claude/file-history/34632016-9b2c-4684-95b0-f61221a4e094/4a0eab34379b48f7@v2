    enableLogging: process.env.ENABLE_LOGGING === 'true',
    logFormat: process.env.LOG_FORMAT || 'json'
  }
};

/**
 * Gogs API Helper
 */
export class GogsAPIHelper {
  private baseUrl: string;
  private token: string;

  constructor() {
    this.baseUrl = config.gogs.url;
    this.token = config.gogs.apiToken;
  }

  /**
   * Get repository information
   */
  async getRepository(): Promise<any> {
    const url = `${this.baseUrl}/api/v1/repos/${config.gogs.repoFull}`;
    const headers = {
      'Authorization': `token ${this.token}`,
      'Content-Type': 'application/json'
    };

    try {
      const response = await fetch(url, { headers });
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      return await response.json();
    } catch (error) {
      console.error('Gogs API Error (getRepository):', error);
      throw error;
    }
  }

  /**
   * Get commit information
   */
  async getCommit(sha: string): Promise<any> {
    const url = `${this.baseUrl}/api/v1/repos/${config.gogs.repoFull}/git/commits/${sha}`;
    const headers = {
      'Authorization': `token ${this.token}`,
      'Content-Type': 'application/json'
    };

    try {
      const response = await fetch(url, { headers });
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      return await response.json();
    } catch (error) {
      console.error('Gogs API Error (getCommit):', error);
      throw error;
    }
  }

  /**
   * List branches
   */
  async getBranches(): Promise<any> {
    const url = `${this.baseUrl}/api/v1/repos/${config.gogs.repoFull}/branches`;
    const headers = {
      'Authorization': `token ${this.token}`,
      'Content-Type': 'application/json'
    };

    try {
      const response = await fetch(url, { headers });
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      return await response.json();
    } catch (error) {
      console.error('Gogs API Error (getBranches):', error);
      throw error;
    }
  }
}

export default config;
