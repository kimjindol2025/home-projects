// tmux Phase 1: 기본 세션 관리 시스템
// 목표: 세션 생성, 연결, 분리, 목록 조회의 핵심 기능 구현

// === 타입 정의 ===

type SessionID = u64
type SessionName = string
type Timestamp = u64

enum SessionState {
    Active(Timestamp)      // 활성화 상태
    Detached(Timestamp)   // 분리된 상태 (마지막 분리 시간)
    Terminated            // 종료됨
}

type Session {
    id: SessionID
    name: SessionName
    state: SessionState
    created_at: Timestamp
    panes: Vec<PaneID>
}

type PaneID = u64
type PaneContent = string

// === 세션 관리자 ===

type SessionManager {
    sessions: Vec<Session>
    next_id: SessionID
    next_pane_id: PaneID
    counter: u64
}

// SessionManager 구현
impl SessionManager {

    // 새 SessionManager 생성
    fn new() -> SessionManager {
        SessionManager {
            sessions: Vec::new(),
            next_id: 1000u64,
            next_pane_id: 100000u64,
            counter: 0u64
        }
    }

    // 새 세션 생성
    fn create_session(mut self, name: SessionName) -> (SessionManager, SessionID) {
        let session_id = self.next_id
        self.next_id = self.next_id + 1u64

        let pane_id = self.next_pane_id
        self.next_pane_id = self.next_pane_id + 1u64

        let now = get_timestamp()
        let mut panes = Vec::new()
        panes.push(pane_id)

        let session = Session {
            id: session_id,
            name: name,
            state: SessionState::Active(now),
            created_at: now,
            panes: panes
        }

        self.sessions.push(session)
        (self, session_id)
    }

    // 세션 연결 (상태 업데이트)
    fn attach_session(mut self, session_id: SessionID) -> (SessionManager, bool) {
        let now = get_timestamp()
        let mut found = false
        let mut i = 0u64

        while i < self.sessions.len() {
            let sess = self.sessions.get(i)

            match sess {
                Some(s) => {
                    if s.id == session_id {
                        match s.state {
                            SessionState::Detached(_) => {
                                let updated = Session {
                                    id: s.id,
                                    name: s.name,
                                    state: SessionState::Active(now),
                                    created_at: s.created_at,
                                    panes: s.panes
                                }
                                self.sessions.set(i, updated)
                                found = true
                            }
                            SessionState::Active(_) => {
                                // 이미 활성화됨
                                found = true
                            }
                            SessionState::Terminated => {
                                // 종료된 세션
                                found = false
                            }
                        }
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        (self, found)
    }

    // 세션 분리 (detach)
    fn detach_session(mut self, session_id: SessionID) -> (SessionManager, bool) {
        let now = get_timestamp()
        let mut found = false
        let mut i = 0u64

        while i < self.sessions.len() {
            let sess = self.sessions.get(i)

            match sess {
                Some(s) => {
                    if s.id == session_id {
                        match s.state {
                            SessionState::Active(_) => {
                                let updated = Session {
                                    id: s.id,
                                    name: s.name,
                                    state: SessionState::Detached(now),
                                    created_at: s.created_at,
                                    panes: s.panes
                                }
                                self.sessions.set(i, updated)
                                found = true
                            }
                            _ => {
                                found = false
                            }
                        }
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        (self, found)
    }

    // 세션 종료 (kill)
    fn kill_session(mut self, session_id: SessionID) -> (SessionManager, bool) {
        let mut found = false
        let mut i = 0u64

        while i < self.sessions.len() {
            let sess = self.sessions.get(i)

            match sess {
                Some(s) => {
                    if s.id == session_id {
                        let updated = Session {
                            id: s.id,
                            name: s.name,
                            state: SessionState::Terminated,
                            created_at: s.created_at,
                            panes: s.panes
                        }
                        self.sessions.set(i, updated)
                        found = true
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        (self, found)
    }

    // 세션 목록 조회
    fn list_sessions(ref self) -> Vec<(SessionID, SessionName, bool)> {
        let mut result = Vec::new()
        let mut i = 0u64

        while i < self.sessions.len() {
            let sess = self.sessions.get(i)

            match sess {
                Some(s) => {
                    match s.state {
                        SessionState::Terminated => {
                            // 종료된 세션은 제외
                        }
                        _ => {
                            let is_active = match s.state {
                                SessionState::Active(_) => true
                                _ => false
                            }
                            result.push((s.id, s.name, is_active))
                        }
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        result
    }

    // 세션 정보 조회
    fn get_session(ref self, session_id: SessionID) -> Option<(SessionID, SessionName, bool, u64)> {
        let mut i = 0u64

        while i < self.sessions.len() {
            let sess = self.sessions.get(i)

            match sess {
                Some(s) => {
                    if s.id == session_id {
                        let is_active = match s.state {
                            SessionState::Active(_) => true
                            _ => false
                        }
                        return Some((s.id, s.name, is_active, s.panes.len()))
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        None
    }

    // 활성 세션 수 반환
    fn active_session_count(ref self) -> u64 {
        let mut count = 0u64
        let mut i = 0u64

        while i < self.sessions.len() {
            let sess = self.sessions.get(i)

            match sess {
                Some(s) => {
                    match s.state {
                        SessionState::Active(_) => {
                            count = count + 1u64
                        }
                        _ => {}
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        count
    }
}

// === 유틸리티 ===

fn get_timestamp() -> Timestamp {
    // 현재 타임스탬프 반환 (placeholder)
    12345678u64
}

// === 테스트 ===

fn main() {
    println!("=== tmux Phase 1: 세션 관리 ===")

    // 세션 매니저 생성
    let mut mgr = SessionManager::new()

    // 첫 번째 세션 생성
    let (mgr2, sess1_id) = mgr.create_session("dev")
    mgr = mgr2
    println!("✅ 세션 생성: dev (ID: " ++ sess1_id.to_string() ++ ")")

    // 두 번째 세션 생성
    let (mgr2, sess2_id) = mgr.create_session("work")
    mgr = mgr2
    println!("✅ 세션 생성: work (ID: " ++ sess2_id.to_string() ++ ")")

    // 세션 목록 조회
    let sessions = mgr.list_sessions()
    println!("\n📋 세션 목록:")
    let mut i = 0u64
    while i < sessions.len() {
        let (id, name, active) = sessions.get(i).unwrap()
        let status = if active { "활성화" } else { "분리됨" }
        println!("  - " ++ name ++ " (ID: " ++ id.to_string() ++ ") [" ++ status ++ "]")
        i = i + 1u64
    }

    // 세션 분리
    let (mgr2, success) = mgr.detach_session(sess1_id)
    mgr = mgr2
    println!("\n🔌 세션 분리: dev - " ++ (if success { "성공" } else { "실패" }))

    // 세션 정보 조회
    let info = mgr.get_session(sess1_id)
    match info {
        Some((id, name, active, pane_count)) => {
            let status = if active { "활성화" } else { "분리됨" }
            println!("ℹ️  세션 정보: " ++ name ++ " (상태: " ++ status ++ ", 패인: " ++ pane_count.to_string() ++ ")")
        }
        None => {
            println!("❌ 세션을 찾을 수 없음")
        }
    }

    // 활성 세션 수
    let active_count = mgr.active_session_count()
    println!("\n📊 활성 세션 수: " ++ active_count.to_string())

    // 세션 종료
    let (mgr2, success) = mgr.kill_session(sess2_id)
    mgr = mgr2
    println!("🔚 세션 종료: work - " ++ (if success { "성공" } else { "실패" }))

    // 최종 세션 목록
    let sessions = mgr.list_sessions()
    println!("\n📋 최종 세션 목록 (크기: " ++ sessions.len().to_string() ++ ")")
}
