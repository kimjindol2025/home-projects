## 사용 예제

### 예제 1: 사용자 등록

```freelang
fn register(username: string, email: string, password: string) -> Result<User, string> {
    // 1. 입력 검증
    if !validate_email(email) {
        return Err("Invalid email")
    }
    if !validate_password(password) {
        return Err("Password too weak")
    }

    // 2. 패스워드 해싱
    let hash = hash_password(password)

    // 3. 사용자 생성
    User::create({
        username: username,
        email: email,
        password_hash: hash
    })
}
```

### 예제 2: 로그인 및 인증

```freelang
fn login(email: string, password: string) -> Result<string, string> {
    let user = User::find_by_email(email)
        .ok_or("User not found")?

    if !verify_password(password, user.password_hash) {
        Audit::log_auth_failure(email, get_client_ip()).unwrap()
        return Err("Invalid password")
    }

    let token = generate_token(user.id)
    Audit::log_auth_success(user.id, get_client_ip()).unwrap()
    Ok(token)
}
```

### 예제 3: 역할 기반 접근 제어

```freelang
fn delete_user(admin: User, target_id: u64) -> Result<bool, string> {
    // 권한 확인
    if !admin.has_permission("users.delete") {
        return Err("Unauthorized")
    }

    // 감시 로깅
    Audit::log_access(admin.id, "users", "delete").unwrap()

    // 실행
    User::delete(target_id)
}
```

### 예제 4: 레이트 제한

```freelang
let api_limiter = RateLimiter::new(1000u64, 3600u64)

fn api_endpoint(user_id: u64) -> Result<Object, string> {
    let key = "user:" ++ user_id.to_string()

    if !api_limiter.allow(key) {
        let remaining = api_limiter.get_remaining(key)
        return Err("Rate limit exceeded. Reset in 1 hour.")
    }

    // API 처리
    Ok(process_request())
}
```

