// ===== Phase 4: DH 키 교환 (실제 해시) =====

fn ssh_key_exchange_server_phase4(state: i32): i32 {
  println("=== Key Exchange (Phase 4: Real Hash) ===")

  var client_pub = 12345
  var server_pub = 54321

  println("Client Public: " + str(client_pub))
  println("Server Public: " + str(server_pub))
  println("")

  // Phase 4: 실제 해시 함수 사용
  var shared_secret = server_hash_dh_shared_secret(client_pub, server_pub)

  println("Using: hash(dh_context, \"sha256\")")
  println("")

  // Phase 4: 키 유도
  var client_key = (shared_secret * 12345) % 1000000
  var server_key = (shared_secret * 54321) % 1000000

  println("Derived Client Key: " + str(client_key) + " (32 bytes)")
  println("Derived Server Key: " + str(server_key) + " (32 bytes)")
  println("Status: Key Exchange ✅")
  println("")

  var next = server_next_state(state)
  return next
}

