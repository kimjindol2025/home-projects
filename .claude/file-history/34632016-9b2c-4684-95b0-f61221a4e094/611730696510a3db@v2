fn ssh_user_auth_server_phase4(username: i32, password: i32, state: i32): i32 {
  println("=== User Authentication (Phase 4: HMAC) ===")

  println("Username: kim")
  println("Auth Method: password (HMAC-protected)")
  println("")

  // Phase 4: HMAC으로 검증
  var auth_data = username + password
  var stored_hmac = 123456789  // 데이터베이스에 저장된 값

  var result = server_verify_auth_hmac(auth_data, stored_hmac)

  println("")

  if result == 1 {
    println("Authentication Result: ACCEPTED ✅")
    println("")

    var next = server_next_state(state)
    return next
  } else {
    println("Authentication Result: REJECTED ❌")
    return 0
  }
}

