// ffmpeg Phase 1: 미디어 변환 기본
type JobID = u64

type MediaFile {
    id: JobID
    input: string
    output: string
    format: string
}

type Converter {
    jobs: Vec<MediaFile>
    next_id: JobID
}

impl Converter {
    fn new() -> Converter {
        Converter { jobs: Vec::new(), next_id: 1000u64 }
    }

    fn add_job(mut self, input: string, output: string, format: string) -> (Converter, JobID) {
        let id = self.next_id
        self.next_id = self.next_id + 1u64
        self.jobs.push(MediaFile { id: id, input: input, output: output, format: format })
        (self, id)
    }

    fn list_jobs(ref self) -> Vec<(JobID, string, string)> {
        let mut result = Vec::new()
        let mut i = 0u64
        while i < self.jobs.len() {
            let job = self.jobs.get(i)
            match job {
                Some(j) => { result.push((j.id, j.input, j.format)) }
                None => {}
            }
            i = i + 1u64
        }
        result
    }
}

fn main() {
    println!("=== ffmpeg Phase 1: 기본 변환 ===")
    let mut conv = Converter::new()
    let (conv2, id1) = conv.add_job("video.mp4", "output.avi", "avi")
    conv = conv2
    println!("✅ 변환 작업 생성")

    let jobs = conv.list_jobs()
    println!("\n📋 작업:")
    let mut i = 0u64
    while i < jobs.len() {
        let (id, input, fmt) = jobs.get(i).unwrap()
        println!("  " ++ input ++ " → " ++ fmt)
        i = i + 1u64
    }
}
