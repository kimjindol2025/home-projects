// neovim Phase 1: 기본 에디터 기능
type BufferID = u64
type Timestamp = u64
type FileName = string
type LineNumber = u64

enum EditorMode {
    Normal
    Insert
    Visual
    Command
}

type Buffer {
    id: BufferID
    filename: FileName
    lines: Vec<string>
    modified: bool
    created_at: Timestamp
}

type Editor {
    buffers: Vec<Buffer>
    current_buffer: BufferID
    current_mode: EditorMode
    next_buffer_id: BufferID
}

impl Editor {
    fn new() -> Editor {
        Editor {
            buffers: Vec::new(),
            current_buffer: 0u64,
            current_mode: EditorMode::Normal,
            next_buffer_id: 1000u64
        }
    }

    fn open_file(mut self, filename: FileName) -> (Editor, BufferID) {
        let buffer_id = self.next_buffer_id
        self.next_buffer_id = self.next_buffer_id + 1u64

        let buffer = Buffer {
            id: buffer_id,
            filename: filename,
            lines: Vec::new(),
            modified: false,
            created_at: get_timestamp()
        }

        self.buffers.push(buffer)
        (self, buffer_id)
    }

    fn insert_line(mut self, buffer_id: BufferID, line_num: LineNumber, content: string) -> Editor {
        let mut i = 0u64

        while i < self.buffers.len() {
            let buffer = self.buffers.get(i)

            match buffer {
                Some(b) => {
                    if b.id == buffer_id {
                        let mut updated = Buffer {
                            id: b.id,
                            filename: b.filename,
                            lines: b.lines,
                            modified: true,
                            created_at: b.created_at
                        }
                        updated.lines.push(content)
                        self.buffers.set(i, updated)
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        self
    }

    fn get_line(ref self, buffer_id: BufferID, line_num: LineNumber) -> Option<string> {
        let mut i = 0u64

        while i < self.buffers.len() {
            let buffer = self.buffers.get(i)

            match buffer {
                Some(b) => {
                    if b.id == buffer_id && line_num < b.lines.len() {
                        return b.lines.get(line_num)
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        None
    }

    fn change_mode(mut self, mode: EditorMode) -> Editor {
        self.current_mode = mode
        self
    }

    fn list_buffers(ref self) -> Vec<(BufferID, FileName, u64)> {
        let mut result = Vec::new()
        let mut i = 0u64

        while i < self.buffers.len() {
            let buffer = self.buffers.get(i)

            match buffer {
                Some(b) => {
                    result.push((b.id, b.filename, b.lines.len()))
                }
                None => {}
            }

            i = i + 1u64
        }

        result
    }
}

type Option<T> {
    Some(T)
    None
}

fn get_timestamp() -> Timestamp { 12345678u64 }

fn main() {
    println!("=== neovim Phase 1: 기본 에디터 ===")

    let mut editor = Editor::new()
    println!("📝 에디터 초기화")

    let (editor2, buf1) = editor.open_file("main.fl")
    editor = editor2
    println!("✅ main.fl 열기")

    let (editor2, buf2) = editor.open_file("config.fl")
    editor = editor2
    println!("✅ config.fl 열기")

    editor = editor.insert_line(buf1, 0u64, "fn main() {")
    editor = editor.insert_line(buf1, 1u64, "    println!(\"Hello\")")
    editor = editor.insert_line(buf1, 2u64, "}")
    println!("✅ main.fl에 3줄 작성")

    let buffers = editor.list_buffers()
    println!("\n📋 버퍼 목록:")
    let mut i = 0u64
    while i < buffers.len() {
        let (id, name, lines) = buffers.get(i).unwrap()
        println!("  " ++ name ++ " (" ++ lines.to_string() ++ " 줄)")
        i = i + 1u64
    }
}
