// curl Phase 2: 고급 요청 (헤더, 쿠키, 인증)
// 목표: 커스텀 헤더, 쿠키 관리, Basic/Bearer 인증

type RequestID = u64
type CookieID = u64
type Timestamp = u64
type URL = string
type Header = string
type Body = string
type StatusCode = u64
type CookieName = string
type CookieValue = string

enum HttpMethod {
    Get
    Post
    Put
    Delete
    Head
    Patch
}

enum AuthType {
    None
    Basic(string, string)     // username, password
    Bearer(string)             // token
    ApiKey(string, string)     // header name, key
}

type Cookie {
    id: CookieID
    name: CookieName
    value: CookieValue
    domain: string
    path: string
    expires: Timestamp
}

type HttpRequest {
    id: RequestID
    method: HttpMethod
    url: URL
    headers: Vec<Header>
    cookies: Vec<CookieID>
    body: Option<Body>
    auth: AuthType
    timestamp: Timestamp
}

type HttpResponse {
    request_id: RequestID
    status_code: StatusCode
    headers: Vec<Header>
    cookies: Vec<CookieName>
    body: Body
    timestamp: Timestamp
}

type HttpClient {
    requests: Vec<HttpRequest>
    responses: Vec<HttpResponse>
    cookies: Vec<Cookie>
    next_request_id: RequestID
    next_cookie_id: CookieID
    user_agent: string
}

impl HttpClient {

    fn new() -> HttpClient {
        HttpClient {
            requests: Vec::new(),
            responses: Vec::new(),
            cookies: Vec::new(),
            next_request_id: 1000u64,
            next_cookie_id: 100000u64,
            user_agent: "curl/2.0 FreeLang"
        }
    }

    // GET 요청
    fn get(mut self, url: URL) -> (HttpClient, RequestID) {
        let request_id = self.next_request_id
        self.next_request_id = self.next_request_id + 1u64

        let mut headers = Vec::new()
        headers.push("User-Agent: " ++ self.user_agent)

        let request = HttpRequest {
            id: request_id,
            method: HttpMethod::Get,
            url: url,
            headers: headers,
            cookies: Vec::new(),
            body: None,
            auth: AuthType::None,
            timestamp: get_timestamp()
        }

        self.requests.push(request)
        (self, request_id)
    }

    // POST 요청
    fn post(mut self, url: URL, body: Body) -> (HttpClient, RequestID) {
        let request_id = self.next_request_id
        self.next_request_id = self.next_request_id + 1u64

        let mut headers = Vec::new()
        headers.push("User-Agent: " ++ self.user_agent)
        headers.push("Content-Type: application/json")

        let request = HttpRequest {
            id: request_id,
            method: HttpMethod::Post,
            url: url,
            headers: headers,
            cookies: Vec::new(),
            body: Some(body),
            auth: AuthType::None,
            timestamp: get_timestamp()
        }

        self.requests.push(request)
        (self, request_id)
    }

    // Basic 인증 설정
    fn set_basic_auth(mut self, request_id: RequestID, username: string, password: string) -> HttpClient {
        let mut i = 0u64

        while i < self.requests.len() {
            let request = self.requests.get(i)

            match request {
                Some(r) => {
                    if r.id == request_id {
                        let mut updated = HttpRequest {
                            id: r.id,
                            method: r.method,
                            url: r.url,
                            headers: r.headers,
                            cookies: r.cookies,
                            body: r.body,
                            auth: AuthType::Basic(username, password),
                            timestamp: r.timestamp
                        }

                        // Authorization 헤더 추가
                        updated.headers.push("Authorization: Basic " ++ username ++ ":" ++ password)
                        self.requests.set(i, updated)
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        self
    }

    // Bearer 토큰 설정
    fn set_bearer_token(mut self, request_id: RequestID, token: string) -> HttpClient {
        let mut i = 0u64

        while i < self.requests.len() {
            let request = self.requests.get(i)

            match request {
                Some(r) => {
                    if r.id == request_id {
                        let mut updated = HttpRequest {
                            id: r.id,
                            method: r.method,
                            url: r.url,
                            headers: r.headers,
                            cookies: r.cookies,
                            body: r.body,
                            auth: AuthType::Bearer(token),
                            timestamp: r.timestamp
                        }

                        updated.headers.push("Authorization: Bearer " ++ token)
                        self.requests.set(i, updated)
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        self
    }

    // API 키 설정
    fn set_api_key(mut self, request_id: RequestID, header_name: string, key: string) -> HttpClient {
        let mut i = 0u64

        while i < self.requests.len() {
            let request = self.requests.get(i)

            match request {
                Some(r) => {
                    if r.id == request_id {
                        let mut updated = HttpRequest {
                            id: r.id,
                            method: r.method,
                            url: r.url,
                            headers: r.headers,
                            cookies: r.cookies,
                            body: r.body,
                            auth: AuthType::ApiKey(header_name, key),
                            timestamp: r.timestamp
                        }

                        updated.headers.push(header_name ++ ": " ++ key)
                        self.requests.set(i, updated)
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        self
    }

    // 커스텀 헤더 추가
    fn add_header(mut self, request_id: RequestID, header: Header) -> HttpClient {
        let mut i = 0u64

        while i < self.requests.len() {
            let request = self.requests.get(i)

            match request {
                Some(r) => {
                    if r.id == request_id {
                        let mut updated = HttpRequest {
                            id: r.id,
                            method: r.method,
                            url: r.url,
                            headers: r.headers,
                            cookies: r.cookies,
                            body: r.body,
                            auth: r.auth,
                            timestamp: r.timestamp
                        }

                        updated.headers.push(header)
                        self.requests.set(i, updated)
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        self
    }

    // 쿠키 추가
    fn set_cookie(mut self, name: CookieName, value: CookieValue, domain: string) -> (HttpClient, CookieID) {
        let cookie_id = self.next_cookie_id
        self.next_cookie_id = self.next_cookie_id + 1u64

        let cookie = Cookie {
            id: cookie_id,
            name: name,
            value: value,
            domain: domain,
            path: "/",
            expires: 999999999u64
        }

        self.cookies.push(cookie)
        (self, cookie_id)
    }

    // 요청에 쿠키 추가
    fn add_cookie_to_request(mut self, request_id: RequestID, cookie_id: CookieID) -> HttpClient {
        let mut i = 0u64

        while i < self.requests.len() {
            let request = self.requests.get(i)

            match request {
                Some(r) => {
                    if r.id == request_id {
                        let mut updated = HttpRequest {
                            id: r.id,
                            method: r.method,
                            url: r.url,
                            headers: r.headers,
                            cookies: r.cookies,
                            body: r.body,
                            auth: r.auth,
                            timestamp: r.timestamp
                        }

                        updated.cookies.push(cookie_id)
                        self.requests.set(i, updated)
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        self
    }

    // 쿠키 목록
    fn list_cookies(ref self) -> Vec<(CookieID, CookieName, CookieValue)> {
        let mut result = Vec::new()
        let mut i = 0u64

        while i < self.cookies.len() {
            let cookie = self.cookies.get(i)

            match cookie {
                Some(c) => {
                    result.push((c.id, c.name, c.value))
                }
                None => {}
            }

            i = i + 1u64
        }

        result
    }

    // 요청의 헤더 조회
    fn get_request_headers(ref self, request_id: RequestID) -> Vec<Header> {
        let mut i = 0u64

        while i < self.requests.len() {
            let request = self.requests.get(i)

            match request {
                Some(r) => {
                    if r.id == request_id {
                        return r.headers
                    }
                }
                None => {}
            }

            i = i + 1u64
        }

        Vec::new()
    }

    // 응답 시뮬레이션 (헤더 포함)
    fn simulate_response(mut self, request_id: RequestID, status_code: StatusCode, headers: Vec<Header>, body: Body) -> HttpClient {
        let response = HttpResponse {
            request_id: request_id,
            status_code: status_code,
            headers: headers,
            cookies: Vec::new(),
            body: body,
            timestamp: get_timestamp()
        }

        self.responses.push(response)
        self
    }

    // 통계
    fn get_stats(ref self) -> (u64, u64, u64) {
        (self.requests.len(), self.responses.len(), self.cookies.len())
    }
}

// === AuthType 표시 ===

fn format_auth(auth: AuthType) -> string {
    match auth {
        AuthType::None => "None",
        AuthType::Basic(_, _) => "Basic Auth",
        AuthType::Bearer(_) => "Bearer Token",
        AuthType::ApiKey(_, _) => "API Key"
    }
}

// === 유틸리티 ===

fn get_timestamp() -> Timestamp {
    12345678u64
}

// === 테스트 ===

fn main() {
    println!("=== curl Phase 2: 고급 요청 (인증, 쿠키) ===")

    let mut client = HttpClient::new()
    println!("🔌 HTTP 클라이언트 초기화")

    // 쿠키 생성
    println!("\n🍪 쿠키 설정:")
    let (client2, cookie1_id) = client.set_cookie("session_id", "abc123xyz", "api.example.com")
    client = client2
    println!("✅ session_id 쿠키 생성")

    let (client2, cookie2_id) = client.set_cookie("user_token", "token456", "api.example.com")
    client = client2
    println!("✅ user_token 쿠키 생성")

    // GET 요청 + Basic Auth
    println!("\n📤 GET 요청 + Basic Auth:")
    let (client2, req1_id) = client.get("https://api.example.com/protected")
    client = client2
    client = client.set_basic_auth(req1_id, "user", "password")
    println!("✅ Basic Auth 설정")

    // GET 요청 + Bearer Token
    println!("\n📤 GET 요청 + Bearer Token:")
    let (client2, req2_id) = client.get("https://api.example.com/data")
    client = client2
    client = client.set_bearer_token(req2_id, "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...")
    println!("✅ Bearer Token 설정")

    // POST 요청 + API Key
    println!("\n📤 POST 요청 + API Key:")
    let (client2, req3_id) = client.post("https://api.example.com/submit", "{\"data\":\"test\"}")
    client = client2
    client = client.set_api_key(req3_id, "X-API-Key", "sk_live_abc123def456")
    println!("✅ API Key 설정")

    // 요청에 쿠키 추가
    println!("\n🍪 요청에 쿠키 추가:")
    client = client.add_cookie_to_request(req1_id, cookie1_id)
    println!("✅ session_id 쿠키 추가")

    client = client.add_cookie_to_request(req2_id, cookie2_id)
    println!("✅ user_token 쿠키 추가")

    // 커스텀 헤더 추가
    println!("\n📋 커스텀 헤더 추가:")
    client = client.add_header(req1_id, "X-Custom-Header: custom-value")
    println!("✅ 커스텀 헤더 추가")

    client = client.add_header(req2_id, "Accept-Language: ko-KR")
    println!("✅ Accept-Language 헤더 추가")

    // 요청의 헤더 조회
    println!("\n📋 요청 헤더 조회 (요청 1):")
    let headers = client.get_request_headers(req1_id)
    let mut i = 0u64
    while i < headers.len() {
        let header = headers.get(i).unwrap()
        println!("  " ++ header)
        i = i + 1u64
    }

    // 쿠키 목록
    println!("\n🍪 쿠키 목록:")
    let cookies = client.list_cookies()
    let mut i = 0u64
    while i < cookies.len() {
        let (id, name, value) = cookies.get(i).unwrap()
        println!("  " ++ name ++ " = " ++ value)
        i = i + 1u64
    }

    // 응답 시뮬레이션
    println!("\n📥 응답 수신:")
    let mut resp_headers = Vec::new()
    resp_headers.push("Content-Type: application/json")
    resp_headers.push("Set-Cookie: session_id=new123; Path=/")

    let client2 = client.simulate_response(req1_id, 200u64, resp_headers, "{\"status\":\"success\"}")
    client = client2
    println!("✅ 응답 1 수신 (200 OK)")

    let resp_headers = Vec::new()
    let client2 = client.simulate_response(req2_id, 401u64, resp_headers, "{\"error\":\"Unauthorized\"}")
    client = client2
    println!("✅ 응답 2 수신 (401 Unauthorized)")

    // 통계
    println!("\n📊 통계:")
    let (req_count, resp_count, cookie_count) = client.get_stats()
    println!("  요청: " ++ req_count.to_string())
    println!("  응답: " ++ resp_count.to_string())
    println!("  쿠키: " ++ cookie_count.to_string())
}
