    def assess_framework(self,
                        framework: ComplianceFramework,
                        evidence: Dict[str, bool]) -> FrameworkAssessment:
        """
        Assess compliance against a framework

        Args:
            framework: Compliance framework to assess
            evidence: Dict of control ID to compliance status

        Returns:
            FrameworkAssessment with control statuses
        """
        assessment_id = hashlib.md5(f"{time.time()}".encode()).hexdigest()[:8]
        assessment = FrameworkAssessment(
            framework=framework,
            assessment_id=assessment_id,
            timestamp=time.time()
        )

        controls = self.control_mappings.get(framework, [])

        for control_def in controls:
            control_id = control_def["id"]
            is_compliant = evidence.get(control_id, random.random() > 0.3)

            status = ComplianceStatus.COMPLIANT if is_compliant else \
                     ComplianceStatus.PARTIAL if random.random() > 0.5 else \
                     ComplianceStatus.NON_COMPLIANT

            control = ComplianceControl(
                control_id=control_id,
                control_name=control_def["name"],
                description=control_def["description"],
                category=ControlCategory[control_def["category"].value],
                requirement=control_def["requirement"],
                status=status,
                evidence=self._generate_evidence(control_id, status),
                remediation_steps=self._generate_remediation(status)
            )
            assessment.controls.append(control)

        # Calculate compliance metrics
        assessment.total_controls = len(assessment.controls)
        assessment.compliant_controls = sum(1 for c in assessment.controls if c.status == ComplianceStatus.COMPLIANT)
        assessment.partial_controls = sum(1 for c in assessment.controls if c.status == ComplianceStatus.PARTIAL)
        assessment.non_compliant_controls = sum(1 for c in assessment.controls if c.status == ComplianceStatus.NON_COMPLIANT)

        if assessment.total_controls > 0:
            assessment.compliance_percentage = (assessment.compliant_controls + assessment.partial_controls * 0.5) / assessment.total_controls * 100

        # Determine risk level
        if assessment.compliance_percentage >= 90:
            assessment.risk_level = "🟢 LOW"
        elif assessment.compliance_percentage >= 75:
            assessment.risk_level = "🟡 MEDIUM"
        elif assessment.compliance_percentage >= 60:
            assessment.risk_level = "🟠 HIGH"
        else:
            assessment.risk_level = "🔴 CRITICAL"

        return assessment

    def _generate_evidence(self, control_id: str, status: ComplianceStatus) -> List[str]:
        """Generate evidence items"""
        if status == ComplianceStatus.COMPLIANT:
            return [
                f"Control {control_id} implemented and tested",
                f"Documented in policy #{control_id}-POL",
                "Verified by audit team",
            ]
        elif status == ComplianceStatus.PARTIAL:
            return [
                f"Control {control_id} partially implemented",
                "Awaiting full deployment",
            ]
        else:
            return [
                "Control not yet implemented",
                "In planning phase",
            ]

    def _generate_remediation(self, status: ComplianceStatus) -> List[str]:
        """Generate remediation steps"""
        if status == ComplianceStatus.COMPLIANT:
            return ["Maintain current implementation", "Schedule annual re-assessment"]
        elif status == ComplianceStatus.PARTIAL:
            return [
                "Complete implementation within 30 days",
                "Conduct testing",
                "Document in compliance system",
            ]
        else:
            return [
                "Develop implementation plan",
                "Allocate resources",
                "Begin implementation",
                "Conduct testing and validation",
                "Document completion",
            ]

    def create_compliance_report(self,
                                frameworks: List[ComplianceFramework],
                                evidence: Dict[ComplianceFramework, Dict[str, bool]]) -> ComplianceReport:
        """
        Create comprehensive compliance report

        Args:
            frameworks: List of frameworks to assess
            evidence: Dict mapping framework to control evidence

        Returns:
            ComplianceReport with all assessments
        """
        report_id = hashlib.md5(f"{time.time()}".encode()).hexdigest()[:8]
        report = ComplianceReport(report_id=report_id, timestamp=time.time())

        for framework in frameworks:
            evidence_dict = evidence.get(framework, {})
            assessment = self.assess_framework(framework, evidence_dict)
            report.frameworks[framework] = assessment

        # Calculate overall compliance
        total_compliant = sum(a.compliant_controls for a in report.frameworks.values())
        total_controls = sum(a.total_controls for a in report.frameworks.values())

        if total_controls > 0:
            report.overall_compliance_score = (total_compliant / total_controls) * 100
        else:
            report.overall_compliance_score = 0

        # Schedule audits
        report.next_audit_schedule = {
            framework: self._schedule_audit(framework)
            for framework in frameworks
        }

        # Priority recommendations
        report.remediation_priority = self._generate_priority_items(report)

        self.compliance_reports[report_id] = report
        return report

    def _schedule_audit(self, framework: ComplianceFramework) -> str:
        """Schedule next audit date"""
        fw_info = self.compliance_frameworks.get(framework, {})
        frequency = fw_info.get("audit_frequency", "Annually")

        if "Annually" in frequency:
            return "365 days from last audit"
        elif "Every 2 years" in frequency:
            return "730 days from last audit"
        else:
            return "As needed"

    def _generate_priority_items(self, report: ComplianceReport) -> List[str]:
        """Generate priority remediation items"""
        priorities = []

        for framework, assessment in report.frameworks.items():
            if assessment.compliance_percentage < 60:
                priorities.append(f"🔴 {framework.value}: {assessment.compliance_percentage:.0f}% compliant - URGENT")
            elif assessment.compliance_percentage < 75:
                priorities.append(f"🟠 {framework.value}: {assessment.compliance_percentage:.0f}% compliant - HIGH PRIORITY")

        return priorities

    def generate_compliance_report(self, report_id: str) -> str:
        """Generate detailed compliance report"""
        report = self.compliance_reports.get(report_id)
        if not report:
            return f"❌ Report {report_id} not found"

        output = f"""
╔════════════════════════════════════════════════════════════════════════════╗
║                       COMPLIANCE ASSESSMENT REPORT                         ║
║                       Report ID: {report_id}                              ║
╚════════════════════════════════════════════════════════════════════════════╝

📊 OVERALL COMPLIANCE SCORE: {report.overall_compliance_score:.1f}%

🔍 FRAMEWORK ASSESSMENTS:
"""

        for framework, assessment in report.frameworks.items():
            output += f"\n{assessment.risk_level} {framework.value}\n"
            output += f"  Compliance: {assessment.compliance_percentage:.1f}% "
            output += f"({assessment.compliant_controls}/{assessment.total_controls} controls)\n"
            output += f"  • Compliant: {assessment.compliant_controls}\n"
            output += f"  • Partial: {assessment.partial_controls}\n"
            output += f"  • Non-Compliant: {assessment.non_compliant_controls}\n"

            # Show top non-compliant controls
            non_compliant = [c for c in assessment.controls if c.status == ComplianceStatus.NON_COMPLIANT]
            if non_compliant:
                output += f"  ⚠️  Non-Compliant Controls:\n"
                for control in non_compliant[:3]:
                    output += f"    • {control.control_id}: {control.control_name}\n"

        output += f"\n⏰ NEXT AUDIT SCHEDULE:\n"
        for framework, date in report.next_audit_schedule.items():
            output += f"  • {framework.value}: {date}\n"

        if report.remediation_priority:
            output += f"\n🎯 PRIORITY ACTIONS:\n"
            for priority in report.remediation_priority:
                output += f"  {priority}\n"

        return output

    def export_report(self, report_id: str) -> str:
        """Export report to JSON"""
        report = self.compliance_reports.get(report_id)
        if not report:
            return "{}"

        export_data = {
            "report_id": report.report_id,
            "timestamp": report.timestamp,
            "overall_compliance_score": report.overall_compliance_score,
            "frameworks": {
                framework.value: {
                    "compliance_percentage": assessment.compliance_percentage,
                    "risk_level": assessment.risk_level,
                    "controls": {
                        "total": assessment.total_controls,
                        "compliant": assessment.compliant_controls,
                        "partial": assessment.partial_controls,
                        "non_compliant": assessment.non_compliant_controls,
                    },
                }
                for framework, assessment in report.frameworks.items()
            },
            "remediation_priority": report.remediation_priority,
        }
        return json.dumps(export_data, indent=2)


