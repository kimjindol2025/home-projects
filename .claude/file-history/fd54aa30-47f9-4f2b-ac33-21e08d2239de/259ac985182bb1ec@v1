# Long-running Monitor Example (Monitoring with Metrics & Health Check)
$(BUILDDIR)/examples/long_running_monitor: $(BUILDDIR)/examples $(CORE_OBJS) $(MONITORING_OBJS)
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) \
		$(EXAMPLEDIR)/long_running_monitor.c \
		$(CORE_OBJS) \
		$(MONITORING_OBJS) \
		$(LDFLAGS) \
		-o $@

# Clean
clean:
	@rm -rf $(BUILDDIR)
	@echo "Cleaned build artifacts"

# Help
help:
	@echo "Mini-hiredis Build System"
	@echo "========================="
	@echo ""
	@echo "Targets:"
	@echo "  all       - Build and run tests (default)"
	@echo "  test      - Build and run RESP parser tests"
	@echo "  examples  - Build example programs"
	@echo "  rebuild   - Clean and rebuild"
	@echo "  clean     - Remove build artifacts"
	@echo "  help      - Show this message"
