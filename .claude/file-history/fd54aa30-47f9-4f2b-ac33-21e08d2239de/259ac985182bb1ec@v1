# Mini-hiredis Makefile
# Async Redis Client Library using libuv

CC := gcc
CFLAGS := -Wall -Wextra -O2 -std=c11 -fPIC -I/usr/include/node -pthread -D_GNU_SOURCE
CFLAGS_DEBUG := -Wall -Wextra -g -std=c11 -DDEBUG -I/usr/include/node -pthread -D_GNU_SOURCE
LDFLAGS := /lib/x86_64-linux-gnu/libuv.so.1 -pthread

SRCDIR := src
TESTDIR := tests
EXAMPLEDIR := examples
BUILDDIR := build
INCLUDEDIR := include

# Core objects
CORE_OBJS := $(BUILDDIR)/resp_parser.o $(BUILDDIR)/resp_builder.o $(BUILDDIR)/mini_redis.o

# Phase 20 objects
PHASE20_OBJS := $(BUILDDIR)/load_balancer.o $(BUILDDIR)/pipelining_optimizer.o $(BUILDDIR)/mmap_buffer.o

# Phase 21 objects (Distributed Locks, Transactions, Streams)
PHASE21_OBJS := $(BUILDDIR)/distributed_lock.o $(BUILDDIR)/transaction.o $(BUILDDIR)/stream.o

# Monitoring objects (Metrics, Health Monitor)
MONITORING_OBJS := $(BUILDDIR)/metrics.o $(BUILDDIR)/health_monitor.o

# Test targets
TEST_TARGETS := $(BUILDDIR)/tests/test_resp_parser $(BUILDDIR)/tests/test_resp_builder $(BUILDDIR)/tests/test_async_logic $(BUILDDIR)/tests/test_integration $(BUILDDIR)/tests/test_load_balancer $(BUILDDIR)/tests/test_pipelining_optimizer $(BUILDDIR)/tests/test_mmap_buffer $(BUILDDIR)/tests/test_distributed_lock $(BUILDDIR)/tests/test_transaction $(BUILDDIR)/tests/test_lock_transaction_conflict $(BUILDDIR)/tests/test_stream $(BUILDDIR)/tests/test_resilience_redis_kill $(BUILDDIR)/tests/test_metrics

# Benchmark targets
BENCH_TARGETS := $(BUILDDIR)/tests/bench_phase_20

# Example targets
EXAMPLE_TARGETS := $(BUILDDIR)/examples/simple_get $(BUILDDIR)/examples/pipeline $(BUILDDIR)/examples/async_stress $(BUILDDIR)/examples/lock_demo $(BUILDDIR)/examples/transaction_demo $(BUILDDIR)/examples/stream_demo $(BUILDDIR)/examples/long_running_monitor

# Targets
TARGETS := $(TEST_TARGETS) $(BENCH_TARGETS) $(EXAMPLE_TARGETS)

# Phony targets
.PHONY: all test examples clean rebuild help

# Default target
all: test

# Test target
test: $(TEST_TARGETS)
	@echo "Running Day 1 tests..."
	@$(BUILDDIR)/tests/test_resp_parser
	@echo ""
	@echo "Running Day 2 tests..."
	@$(BUILDDIR)/tests/test_resp_builder
	@echo ""
	@echo "Running Day 3-4 tests..."
	@$(BUILDDIR)/tests/test_async_logic
	@echo ""
	@echo "Running Day 5 integration tests..."
	@$(BUILDDIR)/tests/test_integration
	@echo ""
	@echo "Running Phase 20-1 Load Balancer tests..."
	@$(BUILDDIR)/tests/test_load_balancer
	@echo ""
	@echo "Running Phase 20-2 Pipelining Optimizer tests..."
	@$(BUILDDIR)/tests/test_pipelining_optimizer
	@echo ""
	@echo "Running Phase 20-3 Memory-mapped Buffer tests..."
	@$(BUILDDIR)/tests/test_mmap_buffer
	@echo ""
	@echo "Running Phase 21-1 Distributed Lock tests..."
	@$(BUILDDIR)/tests/test_distributed_lock
	@echo ""
	@echo "Running Phase 21-2 Transaction tests..."
	@$(BUILDDIR)/tests/test_transaction
	@echo ""
	@echo "Running Phase 21 Verification (Lock + Transaction Conflict tests)..."
	@$(BUILDDIR)/tests/test_lock_transaction_conflict
	@echo ""
	@echo "Running Phase 21-3 Streams tests..."
	@$(BUILDDIR)/tests/test_stream
	@echo ""
	@echo "Running Production Readiness: Redis Kill -9 Resilience Test..."
	@$(BUILDDIR)/tests/test_resilience_redis_kill
	@echo ""
	@echo "Running Metrics System Tests..."
	@$(BUILDDIR)/tests/test_metrics

# Benchmarks target
benchmarks: $(BENCH_TARGETS)
	@echo "Running Phase 20-4 Benchmarks..."
	@$(BUILDDIR)/tests/bench_phase_20

# Examples target
examples: $(EXAMPLE_TARGETS)
	@echo "Built examples:"
	@echo "  $(BUILDDIR)/examples/simple_get"
	@echo "  $(BUILDDIR)/examples/pipeline"
	@echo "  $(BUILDDIR)/examples/async_stress"
	@echo "  $(BUILDDIR)/examples/lock_demo (requires Redis)"
	@echo "  $(BUILDDIR)/examples/transaction_demo (requires Redis)"
	@echo "  $(BUILDDIR)/examples/stream_demo (requires Redis)"
	@echo "  $(BUILDDIR)/examples/long_running_monitor (long-term monitoring)"

# Rebuild
rebuild: clean all

# Directories
$(BUILDDIR) $(BUILDDIR)/src $(BUILDDIR)/tests $(BUILDDIR)/examples:
	@mkdir -p $@

# Object files
$(BUILDDIR)/resp_parser.o: $(SRCDIR)/resp_parser.c $(INCLUDEDIR)/resp_protocol.h | $(BUILDDIR)
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) -c $< -o $@

$(BUILDDIR)/resp_builder.o: $(SRCDIR)/resp_builder.c | $(BUILDDIR)
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) -c $< -o $@

$(BUILDDIR)/mini_redis.o: $(SRCDIR)/mini_redis.c $(INCLUDEDIR)/mini_redis.h $(INCLUDEDIR)/resp_protocol.h | $(BUILDDIR)
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) -c $< -o $@

# Load Balancer (Phase 20)
$(BUILDDIR)/load_balancer.o: $(SRCDIR)/load_balancer.c $(INCLUDEDIR)/load_balancer.h | $(BUILDDIR)
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) -c $< -o $@

# Pipelining Optimizer (Phase 20-2)
$(BUILDDIR)/pipelining_optimizer.o: $(SRCDIR)/pipelining_optimizer.c $(INCLUDEDIR)/pipelining_optimizer.h | $(BUILDDIR)
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) -c $< -o $@

# Memory-mapped Buffers (Phase 20-3)
$(BUILDDIR)/mmap_buffer.o: $(SRCDIR)/mmap_buffer.c $(INCLUDEDIR)/mmap_buffer.h | $(BUILDDIR)
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) -c $< -o $@

# Distributed Locks (Phase 21-1)
$(BUILDDIR)/distributed_lock.o: $(SRCDIR)/distributed_lock.c $(INCLUDEDIR)/distributed_lock.h | $(BUILDDIR)
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) -c $< -o $@

# Transactions (Phase 21-2)
$(BUILDDIR)/transaction.o: $(SRCDIR)/transaction.c $(INCLUDEDIR)/transaction.h | $(BUILDDIR)
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) -c $< -o $@

# Streams (Phase 21-3)
$(BUILDDIR)/stream.o: $(SRCDIR)/stream.c $(INCLUDEDIR)/stream.h | $(BUILDDIR)
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) -c $< -o $@

# Metrics (Long-running Monitoring)
$(BUILDDIR)/metrics.o: $(SRCDIR)/metrics.c $(INCLUDEDIR)/metrics.h | $(BUILDDIR)
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) -c $< -o $@

# Health Monitor (Long-running Monitoring)
$(BUILDDIR)/health_monitor.o: $(SRCDIR)/health_monitor.c $(INCLUDEDIR)/health_monitor.h | $(BUILDDIR)
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) -c $< -o $@

# RESP Parser Test
$(BUILDDIR)/tests/test_resp_parser: $(BUILDDIR)/tests $(BUILDDIR)/resp_parser.o
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) \
		$(TESTDIR)/test_resp_parser.c \
		$(BUILDDIR)/resp_parser.o \
		-o $@

# RESP Builder Test (Day 2)
$(BUILDDIR)/tests/test_resp_builder: $(BUILDDIR)/tests $(BUILDDIR)/resp_builder.o
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) \
		$(TESTDIR)/test_resp_builder.c \
		$(BUILDDIR)/resp_builder.o \
		-o $@

# Async Logic Test (RESP Builder + Parsing)
$(BUILDDIR)/tests/test_async_logic: $(BUILDDIR)/tests $(BUILDDIR)/resp_parser.o $(BUILDDIR)/resp_builder.o
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) \
		$(TESTDIR)/test_async_logic.c \
		$(BUILDDIR)/resp_parser.o \
		$(BUILDDIR)/resp_builder.o \
		-o $@

# Integration Test (Full async patterns)
$(BUILDDIR)/tests/test_integration: $(BUILDDIR)/tests $(BUILDDIR)/resp_parser.o $(BUILDDIR)/resp_builder.o
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) \
		$(TESTDIR)/test_integration.c \
		$(BUILDDIR)/resp_parser.o \
		$(BUILDDIR)/resp_builder.o \
		-o $@

# Load Balancer Test (Phase 20-1)
$(BUILDDIR)/tests/test_load_balancer: $(BUILDDIR)/tests $(BUILDDIR)/load_balancer.o $(CORE_OBJS)
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) \
		$(TESTDIR)/test_load_balancer.c \
		$(BUILDDIR)/load_balancer.o \
		$(CORE_OBJS) \
		$(LDFLAGS) \
		-o $@

# Pipelining Optimizer Test (Phase 20-2)
$(BUILDDIR)/tests/test_pipelining_optimizer: $(BUILDDIR)/tests $(BUILDDIR)/pipelining_optimizer.o
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) \
		$(TESTDIR)/test_pipelining_optimizer.c \
		$(BUILDDIR)/pipelining_optimizer.o \
		-o $@

# Memory-mapped Buffer Test (Phase 20-3)
$(BUILDDIR)/tests/test_mmap_buffer: $(BUILDDIR)/tests $(BUILDDIR)/mmap_buffer.o
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) \
		$(TESTDIR)/test_mmap_buffer.c \
		$(BUILDDIR)/mmap_buffer.o \
		-o $@

# Distributed Lock Test (Phase 21-1)
$(BUILDDIR)/tests/test_distributed_lock: $(BUILDDIR)/tests $(BUILDDIR)/distributed_lock.o $(CORE_OBJS)
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) \
		$(TESTDIR)/test_distributed_lock.c \
		$(BUILDDIR)/distributed_lock.o \
		$(CORE_OBJS) \
		$(LDFLAGS) \
		-o $@

# Transaction Test (Phase 21-2)
$(BUILDDIR)/tests/test_transaction: $(BUILDDIR)/tests $(BUILDDIR)/transaction.o $(CORE_OBJS)
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) \
		$(TESTDIR)/test_transaction.c \
		$(BUILDDIR)/transaction.o \
		$(CORE_OBJS) \
		$(LDFLAGS) \
		-o $@

# Lock + Transaction Conflict Test (Phase 21 Verification)
$(BUILDDIR)/tests/test_lock_transaction_conflict: $(BUILDDIR)/tests $(BUILDDIR)/distributed_lock.o $(BUILDDIR)/transaction.o $(CORE_OBJS)
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) \
		$(TESTDIR)/test_lock_transaction_conflict.c \
		$(BUILDDIR)/distributed_lock.o \
		$(BUILDDIR)/transaction.o \
		$(CORE_OBJS) \
		$(LDFLAGS) \
		-o $@

# Streams Test (Phase 21-3)
$(BUILDDIR)/tests/test_stream: $(BUILDDIR)/tests $(BUILDDIR)/stream.o $(CORE_OBJS)
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) \
		$(TESTDIR)/test_stream.c \
		$(BUILDDIR)/stream.o \
		$(CORE_OBJS) \
		$(LDFLAGS) \
		-o $@

# Resilience Test: Redis Kill -9 (Production Readiness)
$(BUILDDIR)/tests/test_resilience_redis_kill: $(BUILDDIR)/tests $(PHASE21_OBJS) $(CORE_OBJS)
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) \
		$(TESTDIR)/test_resilience_redis_kill.c \
		$(PHASE21_OBJS) \
		$(CORE_OBJS) \
		$(LDFLAGS) \
		-o $@

# Metrics System Test
$(BUILDDIR)/tests/test_metrics: $(BUILDDIR)/tests $(MONITORING_OBJS)
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) \
		$(TESTDIR)/test_metrics.c \
		$(MONITORING_OBJS) \
		$(LDFLAGS) \
		-o $@

# Phase 20-4: Benchmarking
$(BUILDDIR)/tests/bench_phase_20: $(BUILDDIR)/tests $(BUILDDIR)/pipelining_optimizer.o $(BUILDDIR)/mmap_buffer.o
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) \
		$(TESTDIR)/bench_phase_20.c \
		$(BUILDDIR)/pipelining_optimizer.o \
		$(BUILDDIR)/mmap_buffer.o \
		-o $@

# Simple GET Example
$(BUILDDIR)/examples/simple_get: $(BUILDDIR)/examples $(CORE_OBJS)
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) \
		$(EXAMPLEDIR)/simple_get.c \
		$(CORE_OBJS) \
		$(LDFLAGS) \
		-o $@

# Pipeline Example
$(BUILDDIR)/examples/pipeline: $(BUILDDIR)/examples $(CORE_OBJS)
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) \
		$(EXAMPLEDIR)/pipeline.c \
		$(CORE_OBJS) \
		$(LDFLAGS) \
		-o $@

# Async Stress Test Example
$(BUILDDIR)/examples/async_stress: $(BUILDDIR)/examples $(CORE_OBJS)
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) \
		$(EXAMPLEDIR)/async_stress.c \
		$(CORE_OBJS) \
		$(LDFLAGS) \
		-o $@

# Lock Demo Example (Phase 21-1)
$(BUILDDIR)/examples/lock_demo: $(BUILDDIR)/examples $(CORE_OBJS) $(BUILDDIR)/distributed_lock.o
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) \
		$(EXAMPLEDIR)/lock_demo.c \
		$(CORE_OBJS) \
		$(BUILDDIR)/distributed_lock.o \
		$(LDFLAGS) \
		-o $@

# Transaction Demo Example (Phase 21-2)
$(BUILDDIR)/examples/transaction_demo: $(BUILDDIR)/examples $(CORE_OBJS) $(BUILDDIR)/transaction.o
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) \
		$(EXAMPLEDIR)/transaction_demo.c \
		$(CORE_OBJS) \
		$(BUILDDIR)/transaction.o \
		$(LDFLAGS) \
