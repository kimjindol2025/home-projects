# Stream Demo Example (Phase 21-3)
$(BUILDDIR)/examples/stream_demo: $(BUILDDIR)/examples $(CORE_OBJS) $(BUILDDIR)/stream.o
	$(CC) $(CFLAGS) -I$(INCLUDEDIR) \
