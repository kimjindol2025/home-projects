const std = @import("std");
const testing = std.testing;

// ============================================================================
// 1️⃣ 타입 정의 (Type Definitions)
// ============================================================================

/// 작업 상태를 나타내는 열거형입니다.
pub const TaskStatus = enum {
    pending,
    in_progress,
    completed,
    failed,

    /// 상태를 문자열로 변환합니다.
    pub fn toString(self: TaskStatus) []const u8 {
        return switch (self) {
            .pending => "pending",
            .in_progress => "in_progress",
            .completed => "completed",
            .failed => "failed",
        };
    }
};

/// 작업 결과를 나타내는 구조체입니다.
pub const TaskResult = struct {
    /// 작업 ID
    task_id: []const u8,
    /// 작업 상태
    status: TaskStatus,
    /// 작업 결과 (바이트 배열)
    result: ?[]u8 = null,
    /// 오류 메시지 (실패 시)
    error_msg: ?[]const u8 = null,
    /// 실행 시간 (밀리초)
    duration_ms: u64 = 0,

    /// TaskResult를 초기화합니다.
    pub fn init(
        allocator: std.mem.Allocator,
        task_id: []const u8,
        status: TaskStatus,
    ) !TaskResult {
        const id_copy = try allocator.dupe(u8, task_id);
        return TaskResult{
            .task_id = id_copy,
            .status = status,
        };
    }

    /// TaskResult의 메모리를 해제합니다.
    pub fn deinit(self: *TaskResult, allocator: std.mem.Allocator) void {
        allocator.free(self.task_id);
        if (self.result) |result| {
            allocator.free(result);
        }
        if (self.error_msg) |error_msg| {
            allocator.free(error_msg);
        }
    }
};

// ============================================================================
// 2️⃣ 에러 집합 (Error Sets)
// ============================================================================

/// 처리 관련 에러 집합입니다.
pub const ProcessingError = error{
    InvalidInput,
    AllocationFailed,
    ProcessingFailed,
    InvalidState,
    EmptyData,
    InvalidTaskId,
};

/// 입력 데이터를 검증합니다.
pub fn validateInput(data: []const u8) ProcessingError!void {
    if (data.len == 0) {
        return ProcessingError.InvalidInput;
    }
    if (data.len > 10000) {
        return ProcessingError.InvalidInput;
    }
}

// ============================================================================
// 3️⃣ 기본 프로세서 구조체 (Default Processor)
// ============================================================================

/// 기본 작업 프로세서입니다.
pub const DefaultProcessor = struct {
    /// 최대 동시 작업 수
    max_concurrent: u32 = 4,
    /// 작업 타임아웃 (밀리초)
    timeout_ms: u64 = 5000,

    const Self = @This();

    /// DefaultProcessor를 생성합니다.
    pub fn init(max_concurrent: u32) Self {
        return Self{
            .max_concurrent = max_concurrent,
        };
    }

    /// 작업을 처리합니다.
    pub fn process(
        self: Self,
        allocator: std.mem.Allocator,
        task_id: []const u8,
        data: []const u8,
    ) ProcessingError!TaskResult {
        // 입력 검증
        try validateInput(data);

        if (task_id.len == 0) {
            return ProcessingError.InvalidTaskId;
        }

        // 결과 생성
        var result = try TaskResult.init(allocator, task_id, .in_progress);
        defer result.deinit(allocator);

        result.status = .completed;

        // 결과 데이터 복사
        result.result = try allocator.dupe(u8, data);
        result.duration_ms = 100; // 시뮬레이션

        return TaskResult{
            .task_id = try allocator.dupe(u8, task_id),
            .status = .completed,
            .result = result.result,
            .duration_ms = result.duration_ms,
        };
    }

    /// 프로세서 정보를 출력합니다.
    pub fn printInfo(self: Self) void {
        std.debug.print("Processor: max_concurrent={}, timeout={}\n", .{
            self.max_concurrent,
            self.timeout_ms,
        });
    }
};

// ============================================================================
// 4️⃣ 제네릭 큐 (Generic Queue)
// ============================================================================

/// 제네릭 작업 큐입니다.
pub fn TaskQueue(comptime T: type) type {
    return struct {
        /// 내부 작업 배열
        items: std.ArrayList(T),
        /// 큐 용량
        capacity: usize,

        const Self = @This();

        /// TaskQueue를 초기화합니다.
        pub fn init(allocator: std.mem.Allocator, capacity: usize) Self {
            return Self{
                .items = std.ArrayList(T).init(allocator),
                .capacity = capacity,
            };
        }

        /// TaskQueue의 메모리를 해제합니다.
        pub fn deinit(self: *Self) void {
            self.items.deinit();
        }

        /// 작업을 큐에 추가합니다.
        pub fn enqueue(self: *Self, task: T) ProcessingError!void {
            if (self.items.items.len >= self.capacity) {
                return ProcessingError.InvalidState;
            }
            try self.items.append(task);
        }

        /// 큐에서 작업을 제거합니다.
        pub fn dequeue(self: *Self) ?T {
            if (self.items.items.len == 0) {
                return null;
            }
            return self.items.orderedRemove(0);
        }

        /// 큐의 크기를 반환합니다.
        pub fn size(self: *const Self) usize {
            return self.items.items.len;
        }

        /// 큐가 비어있는지 확인합니다.
        pub fn isEmpty(self: *const Self) bool {
            return self.items.items.len == 0;
        }
    };
}

// ============================================================================
// 5️⃣ 유틸리티 함수 (Utility Functions)
// ============================================================================

/// 두 수를 더합니다.
pub fn add(a: i32, b: i32) i32 {
    return a + b;
}

/// 배열의 합을 계산합니다.
pub fn sum(arr: []const i32) i32 {
    var total: i32 = 0;
    for (arr) |value| {
        total += value;
    }
    return total;
}

/// 배열을 필터링합니다.
pub fn filter(
    allocator: std.mem.Allocator,
    arr: []const i32,
    predicate: fn (i32) bool,
) !std.ArrayList(i32) {
    var result = std.ArrayList(i32).init(allocator);
    for (arr) |item| {
        if (predicate(item)) {
            try result.append(item);
        }
    }
    return result;
}

/// 데이터를 처리합니다.
pub fn processData(
    allocator: std.mem.Allocator,
    data: []const u8,
) ProcessingError![]u8 {
    try validateInput(data);
    return try allocator.dupe(u8, data);
}

// ============================================================================
// 6️⃣ 단위 테스트 (Unit Tests)
// ============================================================================

test "TaskStatus enum" {
    try testing.expectEqualStrings("pending", TaskStatus.pending.toString());
    try testing.expectEqualStrings("in_progress", TaskStatus.in_progress.toString());
    try testing.expectEqualStrings("completed", TaskStatus.completed.toString());
    try testing.expectEqualStrings("failed", TaskStatus.failed.toString());
}

test "TaskResult initialization" {
    var gpa = std.heap.GeneralPurposeAllocator(.{}){};
    defer _ = gpa.deinit();
    const allocator = gpa.allocator();

    var result = try TaskResult.init(allocator, "task-1", .pending);
    defer result.deinit(allocator);

    try testing.expectEqualStrings("task-1", result.task_id);
    try testing.expectEqual(TaskStatus.pending, result.status);
}

test "add function" {
    try testing.expectEqual(@as(i32, 5), add(2, 3));
    try testing.expectEqual(@as(i32, -1), add(-5, 4));
    try testing.expectEqual(@as(i32, 0), add(0, 0));
}

test "sum function" {
    const arr = [_]i32{ 1, 2, 3, 4, 5 };
    try testing.expectEqual(@as(i32, 15), sum(&arr));
}

test "validateInput with valid data" {
    const valid_data = "test";
    try validateInput(valid_data);
}

test "validateInput with empty data" {
    const empty_data = "";
    try testing.expectError(ProcessingError.InvalidInput, validateInput(empty_data));
}

test "validateInput with large data" {
    var large_data: [10001]u8 = undefined;
    @memset(&large_data, 'a');
    try testing.expectError(ProcessingError.InvalidInput, validateInput(&large_data));
}

test "DefaultProcessor initialization" {
    const processor = DefaultProcessor.init(8);
    try testing.expectEqual(@as(u32, 8), processor.max_concurrent);
    try testing.expectEqual(@as(u64, 5000), processor.timeout_ms);
}

test "DefaultProcessor process" {
    var gpa = std.heap.GeneralPurposeAllocator(.{}){};
    defer _ = gpa.deinit();
    const allocator = gpa.allocator();

    const processor = DefaultProcessor.init(4);
    var result = try processor.process(allocator, "task-1", "data");
    defer result.deinit(allocator);

    try testing.expectEqualStrings("task-1", result.task_id);
    try testing.expectEqual(TaskStatus.completed, result.status);
    if (result.result) |result_data| {
        try testing.expectEqualStrings("data", result_data);
    }
}

test "TaskQueue enqueue and dequeue" {
    var gpa = std.heap.GeneralPurposeAllocator(.{}){};
    defer _ = gpa.deinit();
    const allocator = gpa.allocator();

    var queue = TaskQueue(i32).init(allocator, 10);
    defer queue.deinit();

    try queue.enqueue(1);
    try queue.enqueue(2);
    try queue.enqueue(3);

    try testing.expectEqual(@as(usize, 3), queue.size());
    try testing.expectEqual(@as(i32, 1), queue.dequeue().?);
    try testing.expectEqual(@as(usize, 2), queue.size());
}

test "filter function" {
    var gpa = std.heap.GeneralPurposeAllocator(.{}){};
    defer _ = gpa.deinit();
    const allocator = gpa.allocator();

    const arr = [_]i32{ 1, 2, 3, 4, 5 };
    const is_even = struct {
        fn call(x: i32) bool {
            return x % 2 == 0;
        }
    }.call;

    var result = try filter(allocator, &arr, is_even);
    defer result.deinit();

    try testing.expectEqual(@as(usize, 2), result.items.len);
    try testing.expectEqual(@as(i32, 2), result.items[0]);
    try testing.expectEqual(@as(i32, 4), result.items[1]);
}

test "processData function" {
    var gpa = std.heap.GeneralPurposeAllocator(.{}){};
    defer _ = gpa.deinit();
    const allocator = gpa.allocator();

    const data = "test-data";
    var result = try processData(allocator, data);
    defer allocator.free(result);

    try testing.expectEqualStrings("test-data", result);
}

test "processData with invalid input" {
    var gpa = std.heap.GeneralPurposeAllocator(.{}){};
    defer _ = gpa.deinit();
    const allocator = gpa.allocator();

    const empty_data = "";
    try testing.expectError(
        ProcessingError.InvalidInput,
        processData(allocator, empty_data),
    );
}
