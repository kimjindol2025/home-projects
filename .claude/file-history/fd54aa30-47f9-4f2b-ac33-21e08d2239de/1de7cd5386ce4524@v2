.PHONY: help setup build run test check fmt clean all

# ============================================================================
# Zig Learning Project - Makefile (Zig 1.1 표준화)
#
# 사용법:
#   make help    - 도움말 표시
#   make setup   - 환경 설정
#   make build   - 프로젝트 빌드
#   make run     - 실행
#   make test    - 테스트 실행
#   make fmt     - 코드 포매팅
#   make check   - 전체 검사 (build + test)
#   make clean   - 컴파일된 파일 삭제
# ============================================================================

# 변수 설정
ZIG ?= zig
BUILD_DIR := build
SRC_DIR := src

# ============================================================================
# 1️⃣ help - 도움말 표시
# ============================================================================

help:
	@echo "📘 Zig Learning Project - Makefile"
	@echo ""
	@echo "사용 가능한 명령어:"
	@echo "  make help       - 이 도움말 표시"
	@echo "  make setup      - 환경 설정 (의존성 확인)"
	@echo "  make build      - 프로젝트 빌드"
	@echo "  make run        - 빌드된 바이너리 실행"
	@echo "  make test       - 단위 테스트 실행"
	@echo "  make fmt        - zig fmt로 코드 포매팅"
	@echo "  make check      - 전체 검사 (build + test)"
	@echo "  make clean      - 빌드 결과물 삭제"
	@echo "  make all        - 전체 빌드 및 테스트"
	@echo ""
	@echo "📋 예시:"
	@echo "  make check      - 한 줄로 모든 검사 실행"

# ============================================================================
# 2️⃣ setup - 환경 설정
# ============================================================================

setup:
	@echo "🔧 Zig 환경 설정 중..."
	@$(ZIG) version
	@echo "✅ Zig 버전 확인 완료"
	@mkdir -p $(BUILD_DIR)
	@mkdir -p $(SRC_DIR)
	@echo "✅ 디렉토리 생성 완료"

# ============================================================================
# 3️⃣ build - 빌드
# ============================================================================

build: setup
	@echo "🔨 프로젝트 빌드 중..."
	@$(ZIG) build -Doptimize=ReleaseSafe
	@echo "✅ 빌드 완료"

# ============================================================================
# 4️⃣ run - 실행
# ============================================================================

run: build
	@echo "▶️  프로젝트 실행 중..."
	@$(ZIG) build run

# ============================================================================
# 5️⃣ test - 테스트 실행
# ============================================================================

test: setup
	@echo "🧪 테스트 실행 중..."
	@$(ZIG) build test
	@echo "✅ 모든 테스트 통과"

# ============================================================================
# 6️⃣ fmt - 코드 포매팅
# ============================================================================

fmt:
	@echo "📝 코드 포매팅 중..."
	@$(ZIG) fmt src/
	@echo "✅ 포매팅 완료"

# ============================================================================
# 7️⃣ check - 전체 검사
# ============================================================================

check: fmt
	@echo "🔍 전체 검사 실행 중..."
	@echo ""
	@echo "1️⃣ 빌드 검사..."
	@$(ZIG) build
	@echo "✅ 빌드 성공"
	@echo ""
	@echo "2️⃣ 테스트 실행..."
	@$(ZIG) build test
	@echo "✅ 모든 테스트 통과"
	@echo ""
	@echo "🎉 모든 검사 완료 (100% PASS)"

# ============================================================================
# 8️⃣ clean - 정리
# ============================================================================

clean:
	@echo "🗑️  빌드 결과물 삭제 중..."
	@rm -rf $(BUILD_DIR)
	@rm -rf zig-cache
	@echo "✅ 정리 완료"

# ============================================================================
# all - 전체 빌드 및 테스트
# ============================================================================

all: clean check
	@echo ""
	@echo "🎊 전체 빌드 및 테스트 완료!"

.DEFAULT_GOAL := help
