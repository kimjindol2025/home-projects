// 4️⃣ Trait 정의 (Trait Definitions)
// ============================================================================

/// 작업 처리기 트레이트입니다.
pub trait TaskProcessor: Send + Sync {
    /// 작업을 처리합니다.
    ///
    /// # Arguments
    ///
    /// * `task_id` - 작업 ID
    /// * `data` - 처리할 데이터
    ///
    /// # Returns
    ///
    /// 처리 결과 또는 오류
    fn process(&self, task_id: &str, data: &[u8]) -> Result<Vec<u8>, ProcessorError>;

    /// 작업을 취소합니다.
    fn cancel(&self, task_id: &str) -> Result<(), ProcessorError>;
}

// ============================================================================
// 5️⃣ 구조체 및 구현 (Struct and Implementation)
// ============================================================================

/// 기본 작업 프로세서입니다.
#[derive(Debug, Clone)]
pub struct DefaultProcessor {
    /// 프로세서 이름
    name: String,
    /// 최대 동시 작업 수
    max_concurrent: usize,
}

impl DefaultProcessor {
    /// 새로운 프로세서를 생성합니다.
    ///
    /// # Arguments
    ///
    /// * `name` - 프로세서 이름
    /// * `max_concurrent` - 최대 동시 작업 수
    ///
    /// # Example
    ///
    /// ```
    /// use gogs_project::rust_project_template::DefaultProcessor;
    ///
    /// let processor = DefaultProcessor::new("my_processor".to_string(), 4);
    /// assert_eq!(processor.name(), "my_processor");
    /// ```
    pub fn new(name: String, max_concurrent: usize) -> Self {
        Self {
            name,
            max_concurrent,
        }
    }

    /// 프로세서 이름을 반환합니다.
    pub fn name(&self) -> &str {
        &self.name
    }

    /// 최대 동시 작업 수를 반환합니다.
    pub fn max_concurrent(&self) -> usize {
        self.max_concurrent
    }

    /// 작업을 처리합니다 (내부 메서드).
    fn execute_task(&self, data: &[u8]) -> Result<Vec<u8>, ProcessorError> {
        if data.is_empty() {
            return Err(ProcessorError::InvalidInput("Empty data".to_string()));
        }

        // 처리 로직
        Ok(data.to_vec())
    }
}

impl TaskProcessor for DefaultProcessor {
    fn process(&self, task_id: &str, data: &[u8]) -> Result<Vec<u8>, ProcessorError> {
        if task_id.is_empty() {
            return Err(ProcessorError::InvalidInput("Empty task_id".to_string()));
        }

        log::info!("Processing task: {}", task_id);
        let result = self.execute_task(data)?;
        log::info!("Task {} completed", task_id);
        Ok(result)
    }

    fn cancel(&self, task_id: &str) -> Result<(), ProcessorError> {
        log::warn!("Cancelling task: {}", task_id);
        Ok(())
    }
}

