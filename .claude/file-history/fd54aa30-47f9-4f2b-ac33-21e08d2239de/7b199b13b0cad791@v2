#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_processor_creation() {
        let processor = DefaultProcessor::new("test".to_string(), 4);
        assert_eq!(processor.name(), "test");
        assert_eq!(processor.max_concurrent(), 4);
    }

    #[test]
    fn test_process_valid_data() {
        let processor = DefaultProcessor::new("test".to_string(), 4);
        let data = b"hello world";
        let result = processor.process("task-1", data);
        assert!(result.is_ok());
        assert_eq!(result.unwrap(), data.to_vec());
    }

    #[test]
    fn test_process_empty_data() {
        let processor = DefaultProcessor::new("test".to_string(), 4);
        let result = processor.process("task-1", &[]);
        assert!(result.is_err());
    }

    #[test]
    fn test_process_empty_task_id() {
        let processor = DefaultProcessor::new("test".to_string(), 4);
        let result = processor.process("", b"data");
        assert!(result.is_err());
    }

    #[test]
    fn test_task_queue_enqueue() {
        let mut queue: TaskQueue<i32> = TaskQueue::new("test".to_string(), 5);
        assert!(queue.enqueue(1).is_ok());
        assert!(queue.enqueue(2).is_ok());
        assert_eq!(queue.len(), 2);
    }

    #[test]
    fn test_task_queue_dequeue() {
        let mut queue: TaskQueue<i32> = TaskQueue::new("test".to_string(), 5);
        queue.enqueue(1).unwrap();
        queue.enqueue(2).unwrap();
        assert_eq!(queue.dequeue(), Some(1));
        assert_eq!(queue.dequeue(), Some(2));
        assert_eq!(queue.dequeue(), None);
    }

    #[test]
    fn test_task_queue_full() {
        let mut queue: TaskQueue<i32> = TaskQueue::new("test".to_string(), 2);
        assert!(queue.enqueue(1).is_ok());
        assert!(queue.enqueue(2).is_ok());
        assert!(queue.enqueue(3).is_err());
    }

    #[test]
    fn test_task_status_display() {
        assert_eq!(TaskStatus::Pending.to_string(), "pending");
        assert_eq!(TaskStatus::InProgress.to_string(), "in_progress");
        assert_eq!(TaskStatus::Completed.to_string(), "completed");
        assert_eq!(TaskStatus::Failed.to_string(), "failed");
    }
}

