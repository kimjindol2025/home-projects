#!/usr/bin/env node

/**
 * AI-to-AI Orchestrator
 *
 * 역할:
 * 1. ANALYZER: 현황 분석
 * 2. DESIGNER: 재활용 설계
 * 3. VALIDATOR: 안전성 검증
 * 4. RECORDER: 의사결정 기록
 */

import Anthropic from "@anthropic-ai/sdk";

const client = new Anthropic();

class AIOrchestrator {
  constructor() {
    this.agents = {
      ANALYZER: {
        role: "코드 구조 분석 전문가",
        systemPrompt: `당신은 코드 재사용성을 분석하는 전문가입니다.
주어진 저장소/파일에서:
1. 핵심 기능 (public API)
2. 의존성 (external deps, internal deps)
3. 위험 요소 (unsafe, FFI, global state)
4. 재사용 가능성 평가 (%)

JSON 형식으로 반환하세요.`,
        memory: []
      },
      DESIGNER: {
        role: "아키텍처 설계자",
        systemPrompt: `당신은 소프트웨어 재활용 설계 전문가입니다.
ANALYZER의 분석을 받아서:
1. 재활용 방식 제안 (직접 사용 / wrapper / adapter)
2. 수정 필요 영역 지정
3. 인터페이스 변경 최소화 방안
4. 구현 난이도 평가 (1-5)

구체적인 수정 코드 예시 포함.`,
        memory: []
      },
      VALIDATOR: {
        role: "안전성 검증 전문가",
        systemPrompt: `당신은 Rust unsafe 코드와 FFI 호환성 검증 전문가입니다.
제안된 재활용 방식에 대해:
1. 메모리 안전성 (unsafe 포인터, 수명주기)
2. FFI 호환성 (타입 맞춤, ABI)
3. 성능 영향 (오버헤드)
4. 최종 판정 (SAFE / WARNING / REJECT)

위험 요소는 상세히 설명.`,
        memory: []
      },
      RECORDER: {
        role: "의사결정 기록 전문가",
        systemPrompt: `당신은 AI 협력 과정을 정확하게 기록하는 전문가입니다.
지금까지의 모든 AI 대화를 받아서:
1. 핵심 의사결정 포인트 추출
2. 최종 결론 도출
3. 실행 단계 정리
4. 위험도 평가 (LOW / MEDIUM / HIGH)

최종 JSON 리포트 생성.`,
        memory: []
      }
    };

    this.conversationLog = [];
  }

  /**
   * AI에게 질문하고 응답 받기
   */
  async ask(role, prompt) {
    const agent = this.agents[role];

    const response = await client.messages.create({
      model: "claude-opus-4-6",
      max_tokens: 2000,
      system: agent.systemPrompt,
      messages: [
        ...agent.memory,
        { role: "user", content: prompt }
      ]
    });

    const content = response.content[0].text;

    // 메모리 저장 (최근 10개만 유지)
    agent.memory.push(
      { role: "user", content: prompt },
      { role: "assistant", content: content }
    );

    if (agent.memory.length > 20) {
      agent.memory = agent.memory.slice(-20);
    }

    // 전체 대화 기록
    this.conversationLog.push({
      agent: role,
      timestamp: new Date().toISOString(),
      prompt: prompt.substring(0, 200),
      response: content.substring(0, 500)
    });

    return content;
  }

  /**
   * 코드 재활용 가능성 협의
   */
  async evaluateReuse(sourceRepo, sourceFile, targetRepo, context = {}) {
    console.log(`\n📋 AI 협의 시작: ${sourceRepo} → ${targetRepo}`);
    console.log("=".repeat(60));

    const steps = [];

    // Step 1: ANALYZER - 현황 분석
    console.log("\n🔍 [ANALYZER] 코드 구조 분석 중...");
    const analysisPrompt = `
    소스: ${sourceRepo}/${sourceFile}
    대상: ${targetRepo}

    컨텍스트:
    ${JSON.stringify(context, null, 2)}

    이 코드를 재활용할 수 있을까요?
    분석 항목:
    1. 핵심 기능
    2. 의존성
    3. 위험 요소
    4. 재활용 가능성 (%)
    `;

    const analysis = await this.ask("ANALYZER", analysisPrompt);
    steps.push({ stage: "ANALYZER", result: analysis });
    console.log("✅ 분석 완료");

    // Step 2: DESIGNER - 설계
    console.log("\n🎨 [DESIGNER] 재활용 설계 중...");
    const designPrompt = `
    분석 결과:
    ${analysis}

    이제 구체적인 재활용 방식을 설계해주세요:
    1. 방식 (직접/wrapper/adapter)
    2. 수정 영역
    3. 인터페이스 변경 최소화
    4. 구현 난이도
    `;

    const design = await this.ask("DESIGNER", designPrompt);
    steps.push({ stage: "DESIGNER", result: design });
    console.log("✅ 설계 완료");

    // Step 3: VALIDATOR - 검증
    console.log("\n✅ [VALIDATOR] 안전성 검증 중...");
    const validationPrompt = `
    설계:
    ${design}

    다음을 검증해주세요:
    1. 메모리 안전성
    2. FFI 호환성
    3. 성능 영향
    4. 최종 판정 (SAFE / WARNING / REJECT)
    `;

    const validation = await this.ask("VALIDATOR", validationPrompt);
    steps.push({ stage: "VALIDATOR", result: validation });
    console.log("✅ 검증 완료");

    // Step 4: RECORDER - 기록
    console.log("\n📝 [RECORDER] 의사결정 기록 중...");
    const recordPrompt = `
    전체 협의 결과:
    분석: ${analysis}
    설계: ${design}
    검증: ${validation}

    최종 리포트를 JSON으로 만들어주세요:
    {
      "decision": "PROCEED|MODIFY|REJECT",
      "reasoning": "이유",
      "riskLevel": "LOW|MEDIUM|HIGH",
      "estimatedEffort": "시간",
      "nextSteps": ["단계들"],
      "conditions": ["선행 조건들"]
    }
    `;

    const report = await this.ask("RECORDER", recordPrompt);
    steps.push({ stage: "RECORDER", result: report });
    console.log("✅ 기록 완료");

    console.log("\n" + "=".repeat(60));

    // 최종 결론 추출
    let conclusion;
    try {
      const jsonMatch = report.match(/\{[\s\S]*\}/);
      if (jsonMatch) {
        conclusion = JSON.parse(jsonMatch[0]);
      } else {
        conclusion = { decision: "ANALYSIS", result: report };
      }
    } catch (e) {
      conclusion = { decision: "ANALYSIS", result: report };
    }

    return {
      source: sourceRepo,
      target: targetRepo,
      file: sourceFile,
      steps: steps,
      conclusion: conclusion,
      timestamp: new Date().toISOString()
    };
  }

  /**
   * 기능별 재활용 가능한 코드 찾기
   */
  async findCodeForFeature(feature, availableRepos) {
    console.log(`\n🔎 [AI 검색] "${feature}" 구현 찾기...`);
    console.log("=".repeat(60));

    const prompt = `
    다음 저장소들에서 "${feature}"를 구현한 코드를 찾아줍니다:
    ${availableRepos.join(", ")}

    각 저장소에서:
    1. 해당 기능 있는지 확인
    2. 구현 위치 지정
    3. 재활용 난이도 평가
    4. 추천 순위 매기기

    JSON 배열로 반환:
    [
      {
        "repo": "repo-name",
        "hasFeature": true/false,
        "location": "파일 경로",
        "difficulty": "EASY|MEDIUM|HARD",
        "rank": 1-5
      }
    ]
    `;

    const result = await this.ask("ANALYZER", prompt);

    console.log("\n🎯 검색 결과:");
    console.log(result);
    console.log("=".repeat(60));

    return result;
  }

  /**
   * 전체 협의 내용 저장
   */
  exportConversationLog() {
    return {
      summary: {
        totalInteractions: this.conversationLog.length,
        timestamp: new Date().toISOString(),
        agents: Object.keys(this.agents)
      },
      fullLog: this.conversationLog
    };
  }
}

export default AIOrchestrator;
