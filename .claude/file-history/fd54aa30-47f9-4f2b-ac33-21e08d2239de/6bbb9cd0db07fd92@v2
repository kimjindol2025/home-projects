#!/usr/bin/env node

/**
 * Gemini 기반 AI-to-AI 협의 시작점
 */

import GeminiOrchestrator from "./orchestrator-gemini.js";

async function main() {
  const apiKey = process.env.GOOGLE_API_KEY || process.argv[2];

  if (!apiKey) {
    console.error("❌ Gemini API 키가 필요합니다");
    console.error("\n사용법:");
    console.error("  node main-gemini.js <API_KEY>");
    console.error("  또는");
    console.error("  export GOOGLE_API_KEY=<API_KEY>");
    console.error("  node main-gemini.js");
    process.exit(1);
  }

  console.log("🤖 Gemini AI-to-AI Orchestrator 시작");
  console.log("=".repeat(70));

  const orchestrator = new GeminiOrchestrator(apiKey);

  // 테스트 케이스 1: freelang-v6 → clarity-lang
  try {
    console.log("\n\n📋 테스트 1: freelang-v6 → clarity-lang");
    const result1 = await orchestrator.evaluateReuse(
      "freelang-v6",
      "clarity-lang",
      "VM/인터프리터 통합"
    );
    console.log("\n✅ 협의 완료!");
  } catch (error) {
    console.error("협의 실패:", error.message);
  }

  // 테스트 케이스 2: 저장소 비교
  try {
    console.log("\n\n📋 테스트 2: freelang-v6 vs gogs-chatbot 비교");
    const result2 = await orchestrator.compareRepositories(
      "freelang-v6",
      "gogs-chatbot"
    );
    console.log("\n✅ 비교 완료!");
  } catch (error) {
    console.error("비교 실패:", error.message);
  }

  console.log("\n" + "=".repeat(70));
  console.log("🎊 AI 협의 완료!");
}

main().catch(console.error);
