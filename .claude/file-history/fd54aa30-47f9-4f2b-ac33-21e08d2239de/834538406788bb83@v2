#!/usr/bin/env node

/**
 * AI-to-AI Orchestrator (Gemini 버전)
 */

import { GoogleGenerativeAI } from "@google/generative-ai";

class GeminiOrchestrator {
  constructor(apiKey) {
    this.genAI = new GoogleGenerativeAI(apiKey);
    this.model = this.genAI.getGenerativeModel({ model: "gemini-1.5-flash" });

    this.agents = {
      ANALYZER: "코드 구조 분석 전문가",
      DESIGNER: "아키텍처 설계자",
      VALIDATOR: "안전성 검증 전문가",
      RECORDER: "의사결정 기록 전문가"
    };

    this.conversationLog = [];
  }

  async ask(role, prompt) {
    try {
      const result = await this.model.generateContent(prompt);
      const content = result.response.text();

      this.conversationLog.push({
        agent: role,
        timestamp: new Date().toISOString(),
        response: content.substring(0, 500)
      });

      return content;
    } catch (error) {
      console.error(`❌ ${role} 에러:`, error.message);
      throw error;
    }
  }

  async evaluateReuse(sourceRepo, targetRepo, purpose) {
    console.log(`\n🤝 AI 협의 시작: ${sourceRepo} → ${targetRepo}`);
    console.log("=".repeat(70));

    const steps = [];

    try {
      // Step 1: ANALYZER
      console.log("\n🔍 [ANALYZER] 코드 구조 분석 중...");
      const analysisPrompt = `당신은 코드 재사용성을 분석하는 전문가입니다.

소스: ${sourceRepo}
대상: ${targetRepo}
목적: ${purpose}

이 코드를 재활용할 수 있을까요? 다음을 분석:
1. 핵심 기능
2. 의존성
3. 위험 요소
4. 재활용 가능성 (%)`;

      const analysis = await this.ask("ANALYZER", analysisPrompt);
      steps.push({ stage: "ANALYZER", result: analysis });
      console.log("✅ 분석 완료");
      console.log(analysis.substring(0, 200) + "...\n");

      // Step 2: DESIGNER
      console.log("🎨 [DESIGNER] 재활용 설계 중...");
      const designPrompt = `당신은 소프트웨어 재활용 설계 전문가입니다.

분석 결과:
${analysis}

구체적인 재활용 방식을 설계:
1. 방식 (직접/wrapper/adapter)
2. 수정 영역
3. 난이도
4. 시간 추정`;

      const design = await this.ask("DESIGNER", designPrompt);
      steps.push({ stage: "DESIGNER", result: design });
      console.log("✅ 설계 완료");
      console.log(design.substring(0, 200) + "...\n");

      // Step 3: VALIDATOR
      console.log("✅ [VALIDATOR] 안전성 검증 중...");
      const validationPrompt = `당신은 코드 안전성 검증 전문가입니다.

설계:
${design}

검증:
1. 메모리 안전성
2. 호환성
3. 성능 영향
4. 최종 판정 (SAFE/WARNING/REJECT)`;

      const validation = await this.ask("VALIDATOR", validationPrompt);
      steps.push({ stage: "VALIDATOR", result: validation });
      console.log("✅ 검증 완료");
      console.log(validation.substring(0, 200) + "...\n");

      // Step 4: RECORDER
      console.log("📝 [RECORDER] 의사결정 기록 중...");
      const recordPrompt = `당신은 의사결정을 정확하게 기록하는 전문가입니다.

전체 협의:
분석: ${analysis.substring(0, 300)}
설계: ${design.substring(0, 300)}
검증: ${validation.substring(0, 300)}

최종 요약:
- 결정 (PROCEED/MODIFY/REJECT)
- 이유
- 예상 시간
- 다음 단계`;

      const report = await this.ask("RECORDER", recordPrompt);
      steps.push({ stage: "RECORDER", result: report });
      console.log("✅ 기록 완료");

      console.log("\n" + "=".repeat(70));
      console.log("\n📋 최종 의사결정:");
      console.log(report);

      return {
        source: sourceRepo,
        target: targetRepo,
        purpose,
        steps: steps,
        timestamp: new Date().toISOString()
      };
    } catch (error) {
      console.error("❌ 협의 실패:", error.message);
      throw error;
    }
  }
}

export default GeminiOrchestrator;
