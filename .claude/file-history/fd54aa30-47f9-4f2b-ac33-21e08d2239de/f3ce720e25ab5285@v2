const std = @import("std");

pub fn build(b: *std.Build) void {
    const target = b.standardTargetOptions(.{});
    const optimize = b.standardOptimizeOption(.{});

    // ============================================================================
    // 1️⃣ 메인 라이브러리 구성
    // ============================================================================

    const lib = b.addStaticLibrary(.{
        .name = "zig_learning",
        .root_source_file = b.path("src/lib.zig"),
        .target = target,
        .optimize = optimize,
    });
    b.installArtifact(lib);

    // ============================================================================
    // 2️⃣ 실행 파일 구성
    // ============================================================================

    const exe = b.addExecutable(.{
        .name = "zig-learning",
        .root_source_file = b.path("src/main.zig"),
        .target = target,
        .optimize = optimize,
    });
    b.installArtifact(exe);

    // "run" 단계: 실행 파일 실행
    const run_cmd = b.addRunArtifact(exe);
    run_cmd.step.dependOn(b.getInstallStep());
    if (b.args) |args| {
        run_cmd.addArgs(args);
    }

    const run_step = b.step("run", "Run the application");
    run_step.dependOn(&run_cmd.step);

    // ============================================================================
    // 3️⃣ 테스트 구성
    // ============================================================================

    const tests = b.addTest(.{
        .root_source_file = b.path("src/main.zig"),
        .target = target,
        .optimize = optimize,
    });

    const run_test = b.addRunArtifact(tests);
    const test_step = b.step("test", "Run unit tests");
    test_step.dependOn(&run_test.step);

    // ============================================================================
    // 4️⃣ 포매팅 단계 (zig fmt)
    // ============================================================================

    const fmt_step = b.step("fmt", "Format code with zig fmt");
    const fmt_cmd = b.addSystemCommand(&.{ "zig", "fmt", "src/" });
    fmt_step.dependOn(&fmt_cmd.step);

    // ============================================================================
    // 5️⃣ 검사 단계 (build + test)
    // ============================================================================

    const check_step = b.step("check", "Run all checks (build + test)");
    check_step.dependOn(b.getInstallStep());
    check_step.dependOn(&run_test.step);

    // ============================================================================
    // 6️⃣ 문서화 단계
    // ============================================================================

    const docs = b.addInstallDirectory(.{
        .source_dir = b.addWriteFiles().getDirectory(),
        .install_dir = .prefix,
        .install_subdir = "docs",
    });
    const docs_step = b.step("docs", "Build documentation");
    docs_step.dependOn(&docs.step);

    // ============================================================================
    // 7️⃣ 벤치마크 단계 (bench 바이너리)
    // ============================================================================

    const bench_exe = b.addExecutable(.{
        .name = "benchmark",
        .root_source_file = b.path("src/benchmark.zig"),
        .target = target,
        .optimize = .ReleaseFast,
    });

    const run_bench = b.addRunArtifact(bench_exe);
    const bench_step = b.step("bench", "Run benchmarks");
    bench_step.dependOn(&run_bench.step);

    // ============================================================================
    // 기본값 설정 (zig build)
    // ============================================================================

    // 기본 단계: 빌드 (설치)
    if (b.step_fifo.count == 0) {
        b.default_step.dependOn(b.getInstallStep());
    }
}
