// ============================================================================
// 1️⃣ 타입 정의 (Type Definitions)
// ============================================================================

/**
 * 작업 결과를 나타내는 인터페이스입니다.
 */
export interface TaskResult {
  /** 작업 ID */
  taskId: string;
  /** 작업 상태 */
  status: TaskStatus;
  /** 작업 결과 (성공 시) */
  result?: unknown;
  /** 오류 메시지 (실패 시) */
  error?: string;
  /** 실행 시간 (밀리초) */
  durationMs: number;
}

/**
 * 작업 상태를 나타내는 타입입니다.
 */
export type TaskStatus = "pending" | "in_progress" | "completed" | "failed";

// ============================================================================
// 2️⃣ Custom Error Classes (에러 처리)
// ============================================================================

/**
 * 처리 오류 클래스입니다.
 */
export class ProcessorError extends Error {
  /**
   * ProcessorError를 생성합니다.
   *
   * @param message - 오류 메시지
   * @param code - 오류 코드
   */
  constructor(
    public message: string,
    public code: string
  ) {
    super(`${code}: ${message}`);
    Object.setPrototypeOf(this, ProcessorError.prototype);
  }
}

// ============================================================================
// 3️⃣ 인터페이스 (Interfaces)
// ============================================================================

/**
 * 작업 처리기 인터페이스입니다.
 */
export interface ITaskProcessor {
  /**
   * 작업을 처리합니다.
   *
   * @param taskId - 작업 ID
   * @param data - 처리할 데이터
   * @returns 처리 결과 또는 오류
   * @throws ProcessorError
   */
  process(taskId: string, data: unknown): Promise<TaskResult>;

  /**
   * 작업을 취소합니다.
   *
   * @param taskId - 작업 ID
   */
  cancel(taskId: string): Promise<void>;
}

// ============================================================================
// 4️⃣ 클래스 구현 (Class Implementation)
// ============================================================================

/**
 * 기본 작업 프로세서입니다.
 */
export class DefaultProcessor implements ITaskProcessor {
  private readonly name: string;
  private readonly maxConcurrent: number;

  /**
   * DefaultProcessor를 생성합니다.
   *
   * @param name - 프로세서 이름
   * @param maxConcurrent - 최대 동시 작업 수
   */
  constructor(name: string, maxConcurrent: number = 4) {
    this.name = name;
    this.maxConcurrent = maxConcurrent;
  }

  /**
   * 작업을 처리합니다.
   */
  async process(taskId: string, data: unknown): Promise<TaskResult> {
    if (!taskId) {
      throw new ProcessorError("Task ID is empty", "INVALID_ID");
    }

    const startTime = performance.now();

    try {
      const result = await this.executeTask(data);
      const durationMs = performance.now() - startTime;

      return {
        taskId,
        status: "completed",
        result,
        durationMs,
      };
    } catch (error) {
      const durationMs = performance.now() - startTime;

      return {
        taskId,
        status: "failed",
        error: error instanceof Error ? error.message : "Unknown error",
        durationMs,
      };
    }
  }

  /**
   * 작업을 취소합니다.
   */
  async cancel(taskId: string): Promise<void> {
    if (!taskId) {
      throw new ProcessorError("Task ID is empty", "INVALID_ID");
    }
    // 취소 로직
  }

  /**
   * 작업을 실행합니다 (내부 메서드).
   *
   * @param data - 처리할 데이터
   * @returns 처리 결과
   */
  private async executeTask(data: unknown): Promise<unknown> {
    if (!data) {
      throw new ProcessorError("Data is empty", "EMPTY_DATA");
    }

    // 처리 로직
    return data;
  }

  /**
   * 프로세서 정보를 반환합니다.
   */
  public getInfo(): Record<string, unknown> {
    return {
      name: this.name,
      maxConcurrent: this.maxConcurrent,
    };
  }
}

// ============================================================================
// 5️⃣ 제네릭 클래스 (Generic Classes)
// ============================================================================

/**
 * 제네릭 작업 큐입니다.
 */
export class TaskQueue<T> {
  private tasks: T[] = [];

  constructor(private readonly capacity: number) {}

  /**
   * 작업을 큐에 추가합니다.
   *
   * @param task - 추가할 작업
   * @throws ProcessorError 큐가 가득 찼을 때
   */
  public enqueue(task: T): void {
    if (this.tasks.length >= this.capacity) {
      throw new ProcessorError("Queue is full", "QUEUE_FULL");
    }
    this.tasks.push(task);
  }

  /**
   * 큐에서 작업을 제거합니다.
   *
   * @returns 제거된 작업 또는 undefined
   */
  public dequeue(): T | undefined {
    return this.tasks.shift();
  }

  /**
   * 큐의 크기를 반환합니다.
   */
  public size(): number {
    return this.tasks.length;
  }

  /**
   * 큐가 비어있는지 확인합니다.
   */
  public isEmpty(): boolean {
    return this.tasks.length === 0;
  }
}

// ============================================================================
// 6️⃣ 유틸리티 함수 (Utility Functions)
// ============================================================================

/**
 * 두 수를 더합니다.
 *
 * @param a - 첫 번째 수
 * @param b - 두 번째 수
 * @returns 합
 *
 * @example
 * ```typescript
 * add(2, 3); // 5
 * add(-1, 1); // 0
 * ```
 */
export function add(a: number, b: number): number {
  return a + b;
}

/**
 * 배열을 필터링합니다.
 *
 * @param arr - 배열
 * @param predicate - 필터 함수
 * @returns 필터링된 배열
 */
export function filter<T>(arr: T[], predicate: (item: T) => boolean): T[] {
  return arr.filter(predicate);
}

/**
 * 비동기 작업을 실행합니다.
 *
 * @param fn - 실행할 함수
 * @returns 실행 결과
 */
export async function executeAsync<T>(fn: () => Promise<T>): Promise<T> {
  try {
    return await fn();
  } catch (error) {
    throw new ProcessorError(
      error instanceof Error ? error.message : "Unknown error",
      "ASYNC_ERROR"
    );
  }
}

