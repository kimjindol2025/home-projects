#!/usr/bin/env node

/**
 * 인덱스 재구축
 *
 * 오프라인 인덱서를 사용하여 저장소 데이터베이스를 다시 생성합니다
 */

import CodeIndexerOffline from "./code-indexer-offline.js";

async function main() {
  const baseDir = process.argv[2] || "/data/data/com.termux/files/home";

  console.log("\n🔄 인덱스 재구축 중...");
  console.log("=".repeat(60));
  console.log(`📁 스캔 경로: ${baseDir}\n`);

  const indexer = new CodeIndexerOffline();

  try {
    const repos = indexer.indexAllRepositories(baseDir);

    console.log("\n✅ 인덱스 재구축 완료!");
    console.log(`\n📊 결과:`);
    console.log(`  총 저장소: ${repos.length}개`);

    let totalFiles = 0;
    let totalApis = 0;

    for (const repo of repos) {
      totalFiles += repo.files;
      totalApis += repo.summary.publicAPI.length;
    }

    console.log(`  총 파일: ${totalFiles}개`);
    console.log(`  총 API: ${totalApis}개`);

    console.log(`\n💾 저장 위치: ./db/repos.json`);
    console.log(`\n📚 샘플 저장소:`);

    repos.slice(0, 5).forEach((repo) => {
      console.log(
        `  - ${repo.name}: ${repo.files} 파일, ${
          repo.summary.publicAPI.length
        } API, ` +
          `unsafe=${repo.summary.risks.unsafe ? "O" : "X"}, ` +
          `ffi=${repo.summary.risks.ffi ? "O" : "X"}`
      );
    });

    console.log("\n🎯 다음 단계:");
    console.log("  node main-offline.js find \"기능\"");
    console.log("  node main-offline.js evaluate repo1 repo2 \"목적\"");
  } catch (e) {
    console.error("\n❌ 오류:", e.message);
    if (process.env.DEBUG) console.error(e.stack);
    process.exit(1);
  }
}

main();
