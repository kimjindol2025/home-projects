# gogs_project Rust Makefile
# "기록이 증명이다" - Rust 모범 사례를 실행으로 검증

.PHONY: help setup build test check fmt clippy doc clean

# 기본값
CARGO := cargo
RUSTFLAGS := -D warnings

# 색상 정의
RESET := \033[0m
BOLD := \033[1m
GREEN := \033[32m
BLUE := \033[34m

help:
	@echo "$(BOLD)gogs_project Rust 개발 가이드$(RESET)"
	@echo ""
	@echo "$(GREEN)설치$(RESET)"
	@echo "  make setup        - 개발 환경 설정"
	@echo "  make build        - 디버그 빌드"
	@echo "  make build-release- 릴리스 빌드"
	@echo ""
	@echo "$(GREEN)개발$(RESET)"
	@echo "  make fmt          - 코드 포매팅 (rustfmt)"
	@echo "  make clippy       - Lint 검사 (clippy)"
	@echo "  make test         - 테스트 실행"
	@echo "  make doc          - 문서 생성"
	@echo ""
	@echo "$(GREEN)검증$(RESET)"
	@echo "  make check        - 전체 검사 (fmt + clippy + test)"
	@echo ""
	@echo "$(GREEN)청소$(RESET)"
	@echo "  make clean        - 빌드 캐시 제거"
	@echo ""

setup:
	@echo "$(GREEN)✓ Rust 개발 환경 확인$(RESET)"
	@rustc --version
	@$(CARGO) --version

build:
	@echo "$(BLUE)→ 디버그 빌드 중...$(RESET)"
	$(CARGO) build
	@echo "$(GREEN)✓ 빌드 완료$(RESET)"

build-release:
	@echo "$(BLUE)→ 릴리스 빌드 중...$(RESET)"
	$(CARGO) build --release
	@echo "$(GREEN)✓ 릴리스 빌드 완료$(RESET)"

# 코드 포매팅
fmt:
	@echo "$(BLUE)→ rustfmt으로 코드 포매팅 중...$(RESET)"
	$(CARGO) fmt --all
	@echo "$(GREEN)✓ 포매팅 완료$(RESET)"

# Lint 검사
clippy:
	@echo "$(BLUE)→ clippy로 Lint 검사 중...$(RESET)"
	$(CARGO) clippy --all-targets --all-features -- -D warnings
	@echo "$(GREEN)✓ Lint 검사 통과$(RESET)"

# 테스트 실행
test:
	@echo "$(BLUE)→ 테스트 실행 중...$(RESET)"
	$(CARGO) test --all
	$(CARGO) test --doc
	@echo "$(GREEN)✓ 모든 테스트 통과$(RESET)"

# 문서 생성
doc:
	@echo "$(BLUE)→ 문서 생성 중...$(RESET)"
	$(CARGO) doc --no-deps --open
	@echo "$(GREEN)✓ 문서 생성 완료$(RESET)"

# 모든 검사 실행
check: fmt clippy test
	@echo "$(GREEN)✓ 모든 검사 통과$(RESET)"

# 정리
clean:
	@echo "$(BLUE)→ 빌드 캐시 제거 중...$(RESET)"
	$(CARGO) clean
	@rm -rf target/
	@echo "$(GREEN)✓ 정리 완료$(RESET)"
