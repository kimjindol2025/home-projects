# Kim-AI-OS Ecosystem Integration
# Phase 12: Status Analysis
# Phase 13: MVP Integration Engine
# Phase 14: Full Orchestrator (Complete)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ┌─────────────────────────────────────────────────┐
# │ 표준화된 GCC Makefile (2026-02-26)             │
# │ c11, O2, pthread, fPIC, GNU_SOURCE 통일       │
# └─────────────────────────────────────────────────┘

CC        := gcc
CSTD      := -std=c11
WARNINGS  := -Wall -Wextra -Wpedantic
DEBUG     := -g3 -fno-omit-frame-pointer
PLATFORM  := -fPIC -pthread -D_GNU_SOURCE
OPTIMIZE  := -O2

CFLAGS    := $(CSTD) $(WARNINGS) $(DEBUG) $(OPTIMIZE) $(PLATFORM)
LDFLAGS   := -lm -lpthread

# Source files
SRCS_PHASE13 = src/ecosystem_integration.c
SRCS_PHASE14 = src/orchestrator.c
SRCS_PHASE15 = src/error_handling.c
SRCS_PHASE15_STABLE = src/orchestrator_stable.c
SRCS_PHASE16_CONNECTORS = src/connectors/connectors.h \
                          src/connectors/intent_connector.c \
                          src/connectors/freelang_connector.c \
                          src/connectors/ir_design_connector.c \
                          src/connectors/e2e_pipeline.c
OBJS_PHASE13 = $(SRCS_PHASE13:.c=.o)
OBJS_PHASE14 = $(SRCS_PHASE14:.c=.o)
OBJS_PHASE15 = $(SRCS_PHASE15:.c=.o)
OBJS_PHASE15_STABLE = $(SRCS_PHASE15_STABLE:.c=.o)
OBJS_PHASE16 = src/connectors/intent_connector.o \
               src/connectors/freelang_connector.o \
               src/connectors/ir_design_connector.o \
               src/connectors/e2e_pipeline.o

# Test programs
TEST_INTEGRATION = phase13_integration_test
TEST_ORCHESTRATOR = phase14_orchestrator_test
TEST_STABILITY = phase15_stability_test
TEST_STRESS = phase15_stress_test
TEST_FAILURE = phase16_failure_scenarios_test
TEST_E2E = phase16_e2e_test
TEST_SRC_13      = tests/phase13_integration_test.c
TEST_SRC_14      = tests/phase14_orchestrator_test.c
TEST_SRC_15      = tests/stability_test.c
TEST_SRC_STRESS  = tests/stress_test.c
TEST_SRC_FAILURE = tests/failure_scenarios_test.c
TEST_SRC_E2E     = tests/e2e_test.c

# All targets
all: $(TEST_INTEGRATION) $(TEST_ORCHESTRATOR) $(TEST_STABILITY) $(TEST_STRESS) $(TEST_FAILURE) $(TEST_E2E)

# Build Phase 13 integration test
$(TEST_INTEGRATION): $(OBJS_PHASE13) $(TEST_SRC_13)
	@echo "🔨 Building $(TEST_INTEGRATION)..."
	$(CC) $(CFLAGS) $(TEST_SRC_13) $(OBJS_PHASE13) -o $(TEST_INTEGRATION) $(LDFLAGS)
	@echo "✅ $(TEST_INTEGRATION) created"

# Build Phase 14 orchestrator test
$(TEST_ORCHESTRATOR): $(OBJS_PHASE14) $(TEST_SRC_14)
	@echo "🔨 Building $(TEST_ORCHESTRATOR)..."
	$(CC) $(CFLAGS) $(TEST_SRC_14) $(OBJS_PHASE14) -o $(TEST_ORCHESTRATOR) $(LDFLAGS)
	@echo "✅ $(TEST_ORCHESTRATOR) created"

# Build Phase 15 stability test
$(TEST_STABILITY): $(OBJS_PHASE15) $(TEST_SRC_15)
	@echo "🔨 Building $(TEST_STABILITY)..."
	$(CC) $(CFLAGS) $(TEST_SRC_15) $(OBJS_PHASE15) -o $(TEST_STABILITY) $(LDFLAGS)
	@echo "✅ $(TEST_STABILITY) created"

# Build Phase 15 stress test
$(TEST_STRESS): $(OBJS_PHASE15_STABLE) $(TEST_SRC_STRESS)
	@echo "🔨 Building $(TEST_STRESS)..."
	$(CC) $(CFLAGS) $(TEST_SRC_STRESS) $(OBJS_PHASE15_STABLE) -o $(TEST_STRESS) $(LDFLAGS)
	@echo "✅ $(TEST_STRESS) created"

# Build Phase 16 failure scenarios test
$(TEST_FAILURE): $(OBJS_PHASE16) $(TEST_SRC_FAILURE)
	@echo "🔨 Building $(TEST_FAILURE)..."
	$(CC) $(CFLAGS) $(TEST_SRC_FAILURE) $(OBJS_PHASE16) -o $(TEST_FAILURE) $(LDFLAGS)
	@echo "✅ $(TEST_FAILURE) created"

# Build Phase 16 E2E test
$(TEST_E2E): $(OBJS_PHASE16) $(TEST_SRC_E2E)
	@echo "🔨 Building $(TEST_E2E)..."
	$(CC) $(CFLAGS) $(TEST_SRC_E2E) $(OBJS_PHASE16) -o $(TEST_E2E) $(LDFLAGS)
	@echo "✅ $(TEST_E2E) created"

# Compile object files
%.o: %.c
	@echo "🔨 Compiling $<..."
	$(CC) $(CFLAGS) -c $< -o $@

# Run Phase 13 integration test
test-phase13: $(TEST_INTEGRATION)
	@echo ""
	@echo "🧪 Running Phase 13 Integration Test..."
	@echo ""
	./$(TEST_INTEGRATION)

# Run Phase 14 orchestrator test
test-phase14: $(TEST_ORCHESTRATOR)
	@echo ""
	@echo "🧪 Running Phase 14 Orchestrator Test..."
	@echo ""
	./$(TEST_ORCHESTRATOR)

# Run Phase 15 stability test
test-phase15: $(TEST_STABILITY)
	@echo ""
	@echo "🧪 Running Phase 15 Stability Test..."
	@echo ""
	./$(TEST_STABILITY)

# Run Phase 15 stress test
test-stress: $(TEST_STRESS)
	@echo ""
	@echo "🧪 Running Phase 15 Stress Test..."
	@echo ""
	./$(TEST_STRESS)

# Run Phase 16 failure scenarios test
test-failure: $(TEST_FAILURE)
	@echo ""
	@echo "🧪 Running Phase 16 Failure Scenarios Test..."
	@echo ""
	./$(TEST_FAILURE)

# Run Phase 16 E2E test
test-e2e: $(TEST_E2E)
	@echo ""
	@echo "🧪 Running Phase 16 E2E Integration Test..."
	@echo ""
	./$(TEST_E2E)

# Run all tests (Phase 13, 14, 15, 16)
test: test-phase13 test-phase14 test-phase15 test-stress test-failure test-e2e

# Run with output capture
test-verbose: test-phase13
	@echo ""
	./$(TEST_INTEGRATION) | tee integration_test_results.log
	@echo ""
	./$(TEST_ORCHESTRATOR) | tee orchestrator_test_results.log
	@echo ""
	@echo "📝 Results saved to: integration_test_results.log, orchestrator_test_results.log""

# Run with Valgrind (memory leak detection)
valgrind-check: $(TEST_STRESS)
	@echo ""
	@echo "🔍 Running Valgrind memory check..."
	@echo ""
	valgrind --leak-check=full --show-leak-kinds=all --track-origins=yes ./$(TEST_STRESS)

# Clean
clean:
	@echo "🧹 Cleaning..."
	rm -f src/*.o src/connectors/*.o $(TEST_INTEGRATION) $(TEST_ORCHESTRATOR) $(TEST_STABILITY) $(TEST_STRESS) $(TEST_FAILURE) $(TEST_E2E) *.json *.log
	@echo "✅ Clean complete"

