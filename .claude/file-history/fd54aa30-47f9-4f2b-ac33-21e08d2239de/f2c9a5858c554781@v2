[package]
name = "gogs_project"
version = "31.0.0"
edition = "2021"
authors = ["Gogs Project Team"]
license = "MIT"
description = "Rust 기반 언어 설계 및 양자 컴퓨팅 시뮬레이션"
repository = "https://gogs.dclub.kr/kim/gogs_project.git"
readme = "README.md"
keywords = ["language-design", "quantum", "rust", "distributed-systems"]
categories = ["science", "simulation"]

[dependencies]
tokio = { version = "1.35", features = ["full"] }
serde = { version = "1.0", features = ["derive"] }
serde_json = "1.0"
log = "0.4"
env_logger = "0.11"

[dev-dependencies]
criterion = { version = "0.5", features = ["html_reports"] }
proptest = "1.4"
tempfile = "3.8"

[lib]
name = "gogs_project"
path = "src/lib.rs"

[[bin]]
name = "gogs_project"
path = "src/main.rs"

[profile.release]
opt-level = 3
lto = true
codegen-units = 1
strip = true
debug = false

[profile.bench]
inherits = "release"

[profile.dev]
opt-level = 0
debug = true

[[bench]]
name = "performance"
harness = false
