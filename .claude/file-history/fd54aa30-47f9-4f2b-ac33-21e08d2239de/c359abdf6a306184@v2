#!/usr/bin/env node

/**
 * Gogs AI Code Reuse - Main Orchestrator
 *
 * 사용법:
 * node main.js scan /path/to/repos
 * node main.js find "garbage collection"
 * node main.js evaluate freelang-v6 pulseai-lang "FFI 통합"
 */

import fs from "fs";
import path from "path";
import { fileURLToPath } from "url";
import AIOrchestrator from "./orchestrator.js";
import CodeIndexer from "./code-indexer.js";
import ReuseSuggester from "./reuse-suggester.js";

const __dirname = path.dirname(fileURLToPath(import.meta.url));

async function main() {
  const command = process.argv[2];
  const args = process.argv.slice(3);

  console.log("\n🚀 Gogs AI Code Reuse System");
  console.log("=".repeat(60));

  switch (command) {
    case "scan":
      await handleScan(args[0]);
      break;

    case "find":
      await handleFind(args.join(" "));
      break;

    case "evaluate":
      await handleEvaluate(args[0], args[1], args.slice(2).join(" "));
      break;

    case "list-repos":
      await handleListRepos();
      break;

    default:
      printHelp();
  }
}

/**
 * 저장소 스캔 및 인덱싱
 */
async function handleScan(baseDir) {
  if (!baseDir) {
    console.error("❌ 사용법: node main.js scan /path/to/repos");
    process.exit(1);
  }

  const indexer = new CodeIndexer(
    process.env.GOGS_URL || "https://gogs.dclub.kr",
    process.env.GOGS_TOKEN || ""
  );

  try {
    const repos = await indexer.indexAllRepositories(baseDir);

    console.log("\n✅ 인덱싱 완료!");
    console.log(`\n📊 인덱싱된 저장소:`);

    for (const repo of repos) {
      const sig = {
        name: repo.name,
        apis: repo.summary.publicAPI.length,
        unsafe: repo.summary.risks.unsafe ? "⚠️" : "✓",
        ffi: repo.summary.risks.ffi ? "⚠️" : "✓"
      };
      console.log(`  - ${sig.name}: ${sig.apis}개 API, unsafe=${sig.unsafe}, ffi=${sig.ffi}`);
    }

    console.log("\n💾 인덱스: db/repos.json");
  } catch (e) {
    console.error("❌ 스캔 실패:", e.message);
    process.exit(1);
  }
}

/**
 * 기능 검색
 */
async function handleFind(feature) {
  if (!feature) {
    console.error("❌ 사용법: node main.js find \"garbage collection\"");
    process.exit(1);
  }

  const indexer = new CodeIndexer(
    process.env.GOGS_URL || "https://gogs.dclub.kr",
    process.env.GOGS_TOKEN || ""
  );

  const indexes = indexer.loadAllIndexes();
  if (Object.keys(indexes).length === 0) {
    console.error("❌ 인덱스가 없습니다. 먼저 scan을 실행하세요.");
    process.exit(1);
  }

  const suggester = new ReuseSuggester(indexes);

  try {
    const result = await suggester.suggestForFeature(feature);

    if (result) {
      console.log("\n🎯 제안:");
      for (const rec of result.candidates) {
        console.log(`\n  저장소: ${rec.repo}`);
        console.log(`  재활용성: ${rec.reuseability}`);
        console.log(`  난이도: ${rec.difficulty}`);
        console.log(`  예상 시간: ${rec.effort}`);
        console.log(`  권장: ${rec.recommendation}`);
      }
    }

    // 결과 저장
    saveResult("find", feature, result);
  } catch (e) {
    console.error("❌ 검색 실패:", e.message);
    process.exit(1);
  }
}

/**
 * 두 저장소 간 재활용 평가 (AI 협의)
 */
async function handleEvaluate(sourceRepo, targetRepo, purpose) {
  if (!sourceRepo || !targetRepo || !purpose) {
    console.error(
      "❌ 사용법: node main.js evaluate <source-repo> <target-repo> <purpose>"
    );
    process.exit(1);
  }

  const indexer = new CodeIndexer(
    process.env.GOGS_URL || "https://gogs.dclub.kr",
    process.env.GOGS_TOKEN || ""
  );

  const indexes = indexer.loadAllIndexes();
  if (Object.keys(indexes).length === 0) {
    console.error("❌ 인덱스가 없습니다. 먼저 scan을 실행하세요.");
    process.exit(1);
  }

  const orchestrator = new AIOrchestrator();
  const suggester = new ReuseSuggester(indexes);

  try {
    // Step 1: 두 저장소 비교
    console.log("\n📋 Step 1: 저장소 비교 중...");
    const comparison = await suggester.suggestForRepositories(
      sourceRepo,
      targetRepo,
      purpose
    );

    console.log("\n📊 비교 결과:");
    if (comparison.evaluation) {
      console.log(`  재활용 가능: ${comparison.evaluation.feasible ? "YES ✅" : "NO ❌"}`);
      console.log(`  예상 시간: ${comparison.evaluation.estimatedEffort}`);
      console.log(`  위험도: ${comparison.evaluation.riskAssessment}`);
    }

    // Step 2: AI 협의 (필요시)
    if (comparison.evaluation?.feasible) {
      console.log("\n💬 Step 2: AI 협의 진행 중...");

      const context = {
        source: sourceRepo,
        target: targetRepo,
        purpose,
        sourceAPI: indexes[sourceRepo]?.summary.publicAPI.slice(0, 5),
        targetAPI: indexes[targetRepo]?.summary.publicAPI.slice(0, 5),
        comparison: comparison.evaluation
      };

      const evaluation = await orchestrator.evaluateReuse(
        sourceRepo,
        "src/",
        targetRepo,
        context
      );

      console.log("\n✅ AI 협의 완료");
      console.log("\n📝 최종 의사결정:");
      console.log(`  결정: ${evaluation.conclusion.decision}`);
      console.log(`  위험도: ${evaluation.conclusion.riskLevel}`);
      console.log(`  예상 노력: ${evaluation.conclusion.estimatedEffort}`);

      if (evaluation.conclusion.nextSteps) {
        console.log("\n📌 다음 단계:");
        evaluation.conclusion.nextSteps.forEach((step, i) => {
          console.log(`  ${i + 1}. ${step}`);
        });
      }

      // 결과 저장
      saveResult("evaluate", `${sourceRepo}-to-${targetRepo}`, evaluation);

      // Gogs에 기록 (필요시)
      const shouldCommit = evaluation.conclusion.decision === "PROCEED";
      if (shouldCommit && process.env.GOGS_PUSH === "true") {
        console.log("\n📤 Gogs에 기록 중...");
        await saveToGogs(evaluation);
      }
    }
  } catch (e) {
    console.error("❌ 평가 실패:", e.message);
    process.exit(1);
  }
}

/**
 * 저장소 목록 출력
 */
async function handleListRepos() {
  const indexer = new CodeIndexer(
    process.env.GOGS_URL || "https://gogs.dclub.kr",
    process.env.GOGS_TOKEN || ""
  );

  const indexes = indexer.loadAllIndexes();

  if (Object.keys(indexes).length === 0) {
    console.log("❌ 인덱스가 없습니다. 먼저 scan을 실행하세요.");
    process.exit(1);
  }

  console.log("\n📚 인덱싱된 저장소:");
  console.log("=".repeat(60));

  const suggester = new ReuseSuggester(indexes);
  const signatures = suggester.getAllSignatures();

  for (const [name, sig] of Object.entries(signatures)) {
    console.log(`\n${name}`);
    console.log(`  언어: ${sig.language}`);
    console.log(`  API: ${sig.apis.slice(0, 5).join(", ")}${sig.apis.length > 5 ? "..." : ""}`);
    console.log(`  위험: unsafe=${sig.hasUnsafe ? "O" : "X"}, ffi=${sig.hasFFI ? "O" : "X"}`);
    console.log(`  특징: ${[sig.hasGC && "GC", sig.hasVM && "VM"].filter(Boolean).join(", ") || "N/A"}`);
  }
}

/**
 * 결과 로컬 저장
 */
function saveResult(type, name, data) {
  const logsDir = path.join(__dirname, "logs");
  if (!fs.existsSync(logsDir)) {
    fs.mkdirSync(logsDir, { recursive: true });
  }

  const timestamp = new Date().toISOString().replace(/[:.]/g, "-");
  const fileName = `${timestamp}_${type}_${name}.json`;
  const filePath = path.join(logsDir, fileName);

  fs.writeFileSync(filePath, JSON.stringify(data, null, 2));
  console.log(`\n💾 결과 저장: ${filePath}`);
}

