#!/usr/bin/env node

/**
 * Reuse Suggester (오프라인 버전)
 *
 * API 없이 작동하는 버전:
 * - 모든 분석을 인덱스 기반으로 수행
 * - 즉각적인 결과 제공
 * - 높은 정확도의 휴리스틱 사용
 */

class ReuseSuggesterOffline {
  constructor(indexes) {
    this.indexes = indexes; // {repoName: analysis}
    this.cache = {};
  }

  /**
   * 필요한 기능이 어디에 있는지 찾기
   */
  suggestForFeature(feature) {
    console.log(`\n🔎 검색: "${feature}"`);
    console.log("=".repeat(60));

    // 모든 저장소에서 매칭되는 코드 찾기
    const candidates = [];

    for (const [repoName, analysis] of Object.entries(this.indexes)) {
      const match = this.findMatch(feature, analysis);
      if (match.score > 0) {
        candidates.push({
          repo: repoName,
          ...match,
          analysis
        });
      }
    }

    // 점수 순 정렬
    candidates.sort((a, b) => b.score - a.score);

    if (candidates.length === 0) {
      console.log("❌ 일치하는 코드 없음");
      return null;
    }

    console.log(`✅ ${candidates.length}개 후보 발견\n`);

    // 상위 3개 상세 분석
    const recommendations = [];
    for (const candidate of candidates.slice(0, 3)) {
      const detail = this.analyzeCandidate(feature, candidate);
      recommendations.push(detail);
    }

    return {
      feature,
      candidates: recommendations,
      allCandidates: candidates.length,
      timestamp: new Date().toISOString()
    };
  }

  /**
   * 저장소에서 기능 매칭
   */
  findMatch(feature, analysis) {
    const featureLower = feature.toLowerCase();
    const apis = (analysis.summary.publicAPI || []).map(a => a.toLowerCase());
    const files = (analysis.sourceFiles || []).map(f => f.toLowerCase());

    // 점수 계산
    let score = 0;
    let matchedItems = [];
    let matchType = [];

    const featureWords = featureLower.split(/[\s\-_\,]/);

    // 1. API 매칭 (가중치: 10)
    for (const api of apis) {
      for (const word of featureWords) {
        if (word.length > 2 && api.includes(word)) {
          score += 10;
          matchedItems.push(`api: ${api}`);
          matchType.push("API");
        }
      }
    }

    // 2. 파일명 매칭 (가중치: 5)
    for (const file of files) {
      for (const word of featureWords) {
        if (word.length > 2 && file.includes(word)) {
          score += 5;
          matchedItems.push(`file: ${file}`);
          matchType.push("FILE");
        }
      }
    }

    // 3. 디렉토리명 매칭 (가중치: 3)
    const dirs = [...new Set(files.map(f => f.split("/")[0]))];
    for (const dir of dirs) {
      for (const word of featureWords) {
        if (word.length > 2 && dir.includes(word)) {
          score += 3;
          matchedItems.push(`dir: ${dir}/`);
          matchType.push("DIR");
        }
      }
    }

    return {
      score,
      matchedItems: [...new Set(matchedItems)],
      matchType: [...new Set(matchType)],
      risks: analysis.summary.risks,
      fileCount: (analysis.sourceFiles || []).length
    };
  }

  /**
   * 후보 상세 분석 (오프라인 휴리스틱)
   */
  analyzeCandidate(feature, candidate) {
    const score = candidate.score;
    const risks = candidate.risks || {};
    const fileCount = candidate.fileCount || 0;

    // 재활용성 판정
    let reusability = "LOW";
    let difficulty = "HARD";
    let effort = "5-7일";

    if (score >= 30) {
      reusability = "HIGH";
      difficulty = "EASY";
      effort = "1-2일";
    } else if (score >= 15) {
      reusability = "MEDIUM";
      difficulty = "MEDIUM";
      effort = "2-4일";
    } else if (score >= 5) {
      reusability = "MEDIUM";
      difficulty = "MEDIUM";
      effort = "3-5일";
    }

    // 위험도 조정
    if (risks.unsafe || risks.ffi) {
      if (difficulty === "EASY") difficulty = "MEDIUM";
      if (difficulty === "MEDIUM") difficulty = "HARD";
    }

    // 경고 생성
    const warnings = [];
    if (risks.unsafe) warnings.push("unsafe 코드 포함");
    if (risks.ffi) warnings.push("FFI 의존성 있음");
    if (fileCount < 10) warnings.push("작은 모듈 - 재검증 필요");
    if (fileCount > 500) warnings.push("큰 저장소 - 선별 필요");

    // 재활용 방법
    let howToReuse = "";
    if (candidate.matchType.includes("FILE")) {
      const matchedFiles = candidate.matchedItems.filter(m => m.startsWith("file:"));
      howToReuse = `해당 파일들을 직접 복사: ${matchedFiles.slice(0, 2).join(", ")}`;
    } else if (candidate.matchType.includes("API")) {
      howToReuse = `API/인터페이스를 참고하여 구현`;
    } else {
      howToReuse = `아키텍처 패턴 분석 후 적용`;
    }

    // 권장도
    const recommendation = reusability === "HIGH" ? "강력 권장" :
                         reusability === "MEDIUM" ? "조건부 권장" : "검토 필요";

    return {
      repo: candidate.repo,
      score: candidate.score,
      matched: candidate.matchedItems.slice(0, 5),
      reusability,
      difficulty,
      effort,
      warnings,
      howToReuse,
      recommendation,
      fileCount,
      confidence: Math.min(100, Math.round((score / 30) * 100))
    };
  }

  /**
   * 두 저장소 간의 재활용 제안
   */
  suggestForRepositories(sourceRepo, targetRepo, purpose) {
    console.log(`\n🔄 검토: ${sourceRepo} → ${targetRepo}`);
    console.log(`📌 목적: ${purpose}`);
    console.log("=".repeat(60));

    const source = this.indexes[sourceRepo];
    const target = this.indexes[targetRepo];

    if (!source || !target) {
      console.error("❌ 저장소를 찾을 수 없습니다");
      return null;
    }

    // 공통 기능 찾기
    const sourceApis = new Set((source.summary.publicAPI || []).map(a => a.toLowerCase()));
    const targetApis = new Set((target.summary.publicAPI || []).map(a => a.toLowerCase()));

    const commonApis = [...sourceApis].filter(a => {
      // 유사 API 찾기 (첫 3글자 매칭)
      return [...targetApis].some(b =>
        (a.includes(b.slice(0, 3)) || b.includes(a.slice(0, 3)))
      );
    });

    // 파일 유형 분석
    const sourceFiles = source.sourceFiles || [];
    const targetFiles = target.sourceFiles || [];
    const sourceExts = this.getFileExtensions(sourceFiles);
    const targetExts = this.getFileExtensions(targetFiles);
    const commonExts = [...sourceExts.keys()].filter(e => targetExts.has(e));

    // 호환성 점수
    let compatibility = 0;
    if (commonApis.length > 0) compatibility += 30;
    if (commonExts.length > 0) compatibility += 20;
    if (sourceFiles.length / targetFiles.length > 0.5) compatibility += 15;

    // 위험도 평가
    const risks = [];
    if (source.summary.risks.unsafe) risks.push("소스의 unsafe 코드");
    if (source.summary.risks.ffi) risks.push("소스의 FFI 의존성");
    if (source.summary.risks.external.length > 5) risks.push("많은 외부 의존성");

    // 재활용 가능 모듈
    const reuseableModules = [];
    if (this.hasKeyword(source, "gc", "garbage")) reuseableModules.push("GC/메모리 관리");
    if (this.hasKeyword(source, "vm", "virtual", "interpreter")) reuseableModules.push("VM/인터프리터");
    if (this.hasKeyword(source, "ffi", "binding")) reuseableModules.push("FFI/바인딩");
    if (this.hasKeyword(source, "crypto", "encrypt")) reuseableModules.push("암호화");
    if (this.hasKeyword(source, "http", "server", "client")) reuseableModules.push("HTTP/네트워크");

    // 난이도 및 시간 추정
    let difficulty = "MEDIUM";
    let effort = "3-5일";

    if (compatibility >= 50 && risks.length === 0) {
      difficulty = "EASY";
      effort = "1-2일";
    } else if (compatibility < 20 || risks.length > 2) {
      difficulty = "HARD";
      effort = "5-7일";
    }

    // 최종 결정
    const shouldProceed = compatibility >= 30 && risks.length <= 1;

    return {
      source: sourceRepo,
      target: targetRepo,
      purpose,
      evaluation: {
        feasible: shouldProceed,
        compatibility: compatibility + "%",
        commonApis: commonApis.slice(0, 5),
        commonLanguages: commonExts,
        reuseableModules: reuseableModules,
        risks: risks,
        difficulty,
        effort,
        recommendations: this.getRecommendations(compatibility, risks, commonApis),
        decideToProcceed: shouldProceed
      },
      timestamp: new Date().toISOString()
    };
  }

  /**
   * 구체적 권장사항 생성
   */
  getRecommendations(compatibility, risks, commonApis) {
    const recommendations = [];

    if (compatibility >= 70) {
      recommendations.push("직접 복사 가능한 모듈이 많습니다");
    } else if (compatibility >= 40) {
      recommendations.push("Adapter 패턴으로 통합 가능");
    } else {
      recommendations.push("구조 분석 후 부분적 재활용");
    }

    if (risks.length === 0) {
      recommendations.push("안전 - 즉시 통합 가능");
    } else if (risks.length === 1) {
      recommendations.push(`주의: ${risks[0]} - 검증 필요`);
    } else {
      recommendations.push("고위험 - 신중한 검토 필요");
    }

    if (commonApis.length > 3) {
      recommendations.push("공통 인터페이스가 많음 - 호환성 높음");
    }

    return recommendations;
  }

  /**
   * 저장소의 특징 추출
   */
  getRepositorySignature(repoName) {
    const analysis = this.indexes[repoName];
    if (!analysis) return null;

    return {
      name: repoName,
      hasGC: this.hasKeyword(analysis, "gc", "garbage"),
      hasVM: this.hasKeyword(analysis, "vm", "virtual", "interpreter"),
      hasFFI: this.hasKeyword(analysis, "ffi", "binding", "c\\+\\+"),
      hasUnsafe: analysis.summary.risks.unsafe,
      language: this.detectLanguage(analysis),
      apis: analysis.summary.publicAPI.slice(0, 10),
      fileCount: (analysis.sourceFiles || []).length
    };
  }

  /**
   * 키워드 검색 헬퍼
   */
  hasKeyword(analysis, ...keywords) {
    const allText = JSON.stringify(analysis).toLowerCase();
    return keywords.some(k => allText.includes(k.toLowerCase()));
  }

  /**
   * 언어 감지
   */
  detectLanguage(analysis) {
    const files = (analysis.sourceFiles || []).map(f => f.toLowerCase());
    const counts = {};

    if (files.some(f => f.endsWith(".rs"))) counts["Rust"] = 20;
    if (files.some(f => f.endsWith(".js"))) counts["JavaScript"] = 15;
    if (files.some(f => f.endsWith(".ts"))) counts["TypeScript"] = 15;
    if (files.some(f => f.endsWith(".py"))) counts["Python"] = 10;
    if (files.some(f => f.endsWith(".go"))) counts["Go"] = 10;
    if (files.some(f => f.endsWith(".cpp") || f.endsWith(".cc"))) counts["C++"] = 20;
    if (files.some(f => f.endsWith(".c"))) counts["C"] = 10;

    return Object.entries(counts).sort((a, b) => b[1] - a[1])[0]?.[0] || "Mixed";
  }

  /**
   * 파일 확장자 통계
   */
  getFileExtensions(files) {
    const exts = new Map();
    if (!files) return exts;

    for (const file of files) {
      const ext = file.split(".").pop() || "unknown";
      exts.set(ext, (exts.get(ext) || 0) + 1);
    }
    return exts;
  }

  /**
   * 모든 저장소의 서명 추출 (빠른 비교용)
   */
  getAllSignatures() {
    const signatures = {};
    for (const [repoName] of Object.entries(this.indexes)) {
      signatures[repoName] = this.getRepositorySignature(repoName);
    }
    return signatures;
  }

  /**
   * 저장소들 간의 재활용 그래프 생성
   */
  buildReuseGraph() {
    const graph = {};
    const repos = Object.keys(this.indexes);

    for (let i = 0; i < repos.length; i++) {
      for (let j = i + 1; j < repos.length; j++) {
        const result = this.suggestForRepositories(
          repos[i],
          repos[j],
          "일반적 재활용 평가"
        );

        const compatibility = parseInt(result.evaluation.compatibility);
        if (compatibility >= 30) {
          graph[repos[i]] = graph[repos[i]] || [];
          graph[repos[i]].push({
            target: repos[j],
            compatibility
          });
        }
      }
    }

    return graph;
  }
}

export default ReuseSuggesterOffline;
