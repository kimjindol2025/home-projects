// GRIE 3-A: Zig Build Configuration
// Generates static library (.a) and shared library (.so) for Go FFI
//
// Usage:
//   zig build --prefix=/tmp/grie-kernel -Dtarget=aarch64-linux-android
//   zig build -Doptimize=ReleaseFast
//   zig build test

const std = @import("std");
const builtin = @import("builtin");

pub fn build(b: *std.Build) void {
    // Options
    const target = b.standardTargetOptions(.{});
    const optimize = b.standardOptimizeOption(.{});

    // Static library (for embedding in Go binary)
    const lib_static = b.addStaticLibrary(.{
        .name = "grie_kernel",
        .root_source_file = b.path("src/main.zig"),
        .target = target,
        .optimize = optimize,
    });

    // Shared library (for dynamic linking)
    const lib_shared = b.addSharedLibrary(.{
        .name = "grie_kernel",
        .root_source_file = b.path("src/main.zig"),
        .target = target,
        .optimize = optimize,
    });

    // Install artifacts
    b.installArtifact(lib_static);
    b.installArtifact(lib_shared);

    // Unit tests
    const unit_tests = b.addTest(.{
        .root_source_file = b.path("src/main.zig"),
        .target = target,
        .optimize = optimize,
    });

    const run_unit_tests = b.addRunArtifact(unit_tests);

    // Test step
    const test_step = b.step("test", "Run unit tests");
    test_step.dependOn(&run_unit_tests.step);

    // Default step builds both libraries
    b.default_step.dependOn(b.getInstallStep());
}
