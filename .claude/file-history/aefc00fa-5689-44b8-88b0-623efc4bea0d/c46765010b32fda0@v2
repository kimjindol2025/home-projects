# GRIE Julia Reader
# Usage: julia reader.jl <shm_path>
# Example: julia reader.jl /tmp/grie_shm_123456789

using Mmap

# Constants
const SHM_SIZE = 10 * 1024 * 1024  # 10MB
const HEADER_SIZE = 128
const STATE_IDLE = Int32(0)
const STATE_WRITING = Int32(1)
const STATE_READY = Int32(2)
const STATE_READING = Int32(3)

function read_u64_at(mem, offset)
    return reinterpret(UInt64, mem[offset:offset+7])[1]
end

function read_i32_at(mem, offset)
    return reinterpret(Int32, mem[offset:offset+3])[1]
end

function read_header(mem)
    magic     = read_u64_at(mem, 1)
    version   = reinterpret(UInt32, mem[9:12])[1]
    state     = read_i32_at(mem, 13)
    seq_num   = read_u64_at(mem, 17)
    timestamp = reinterpret(Int64, mem[25:32])[1]
    data_len  = read_u64_at(mem, 33)
    writer_pid = reinterpret(Int64, mem[65:72])[1]
    reader_pid = reinterpret(Int64, mem[73:80])[1]
    total_writes = read_u64_at(mem, 81)
    total_reads = read_u64_at(mem, 89)

    return (
        magic=magic,
        version=version,
        state=state,
        seq_num=seq_num,
        timestamp=timestamp,
        data_len=data_len,
        writer_pid=writer_pid,
        reader_pid=reader_pid,
        total_writes=total_writes,
        total_reads=total_reads
    )
end

function state_name(state::Int32)
    if state == STATE_IDLE
        return "IDLE"
    elseif state == STATE_WRITING
        return "WRITING"
    elseif state == STATE_READY
        return "READY"
    elseif state == STATE_READING
        return "READING"
    else
        return "UNKNOWN"
    end
end

function main()
    if length(ARGS) < 1
        println("Usage: julia reader.jl <shm_path>")
        println("Example: julia reader.jl /tmp/grie_shm_123456789")
        exit(1)
    end

    path = ARGS[1]

    # Verify file exists
    if !isfile(path)
        println("❌ Error: File not found: $path")
        exit(1)
    end

    # Open file
    fd = open(path, "r+")

    # mmap the file
    mem = mmap(fd, Vector{UInt8}, (SHM_SIZE,))

    println("📖 GRIE Julia Reader Started")
    println("📂 Shared Memory: $path")
    println("💾 Size: $(SHM_SIZE ÷ 1024)KB")
    println("\n---\n")

    read_count = 0
    max_reads = 5

    while read_count < max_reads
        hdr = read_header(mem)

        # Check if state is READY
        if hdr.state == STATE_READY
            read_count += 1
            println("[$(read_count)/$(max_reads)] Reading...")

            # Extract data
            data_bytes = mem[HEADER_SIZE + 1 : HEADER_SIZE + Int(hdr.data_len)]
            data_str = String(data_bytes)

            println("  ✅ Data: \"$data_str\"")
            println("  📊 SeqNum: $(hdr.seq_num) | DataLen: $(hdr.data_len) | State: $(state_name(hdr.state))")
            println("  📈 TotalWrites: $(hdr.total_writes) | TotalReads: $(hdr.total_reads)")

            # Transition state READY -> IDLE (simulating reader completion)
            # Note: In a real scenario, this would use proper atomic CAS,
            # but Julia's Mmap doesn't have atomic operations. This is a simple write.
            mem[13:16] = reinterpret(UInt8, [STATE_IDLE])

            println()
        else
            # Wait and poll
            sleep(0.01)  # 10ms sleep
        end
    end

    println("---")
    println("✅ Reader finished successfully! ($read_count messages read)")

    # Cleanup
    close(fd)
end

# Run main
main()
