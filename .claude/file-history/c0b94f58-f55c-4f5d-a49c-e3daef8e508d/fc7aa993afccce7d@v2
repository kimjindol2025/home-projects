version: '3.8'

services:
  # Redis - 캐싱 & 메시지 큐
  redis:
    image: redis:7-alpine
    container_name: pulse-redis
    ports:
      - "6379:6379"
    volumes:
      - redis_data:/data
    command: redis-server --appendonly yes
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 5
    networks:
      - pulse-network

  # Ollama - 로컬 LLM (선택)
  ollama:
    image: ollama/ollama:latest
    container_name: pulse-ollama
    ports:
      - "11434:11434"
    volumes:
      - ollama_data:/root/.ollama
    environment:
      OLLAMA_NUM_PARALLEL: 4
    networks:
      - pulse-network
    # 시작 후 모델 다운로드
    # docker exec pulse-ollama ollama pull qwen2.5:7b

  # Pulse Gateway - FastAPI 서버
  pulse:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: pulse-gateway
    ports:
      - "8000:8000"
    environment:
      - OLLAMA_HOST=http://ollama:11434
      - REDIS_URL=redis://redis:6379/0
      - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-}
      - SLACK_BOT_TOKEN=${SLACK_BOT_TOKEN:-}
      - GITHUB_TOKEN=${GITHUB_TOKEN:-}
      - SENDER_EMAIL=${SENDER_EMAIL:-}
      - SENDER_PASSWORD=${SENDER_PASSWORD:-}
      - LOG_LEVEL=INFO
    depends_on:
      redis:
        condition: service_healthy
      ollama:
        condition: service_started
    volumes:
      - ./src:/app/src
      - ./logs:/app/logs
    networks:
      - pulse-network
    command: uvicorn src.gateway:create_app --host 0.0.0.0 --port 8000 --reload

volumes:
  redis_data:
  ollama_data:

networks:
  pulse-network:
    driver: bridge
