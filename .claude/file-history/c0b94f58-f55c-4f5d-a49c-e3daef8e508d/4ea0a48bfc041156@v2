### 4. WebSocket 연결 (Python)

```python
import asyncio
import websockets
import json

async def test_websocket():
    async with websockets.connect("ws://localhost:8000/ws/session-001") as ws:
        # 지시 전송
        await ws.send(json.dumps({
            "type": "instruction",
            "data": "슬랙 봇 만들어"
        }))

        # 스트리밍 응답 수신
        while True:
            msg = await ws.recv()
            data = json.loads(msg)
            print(data)
            if data["type"] == "done":
                break

asyncio.run(test_websocket())
```

