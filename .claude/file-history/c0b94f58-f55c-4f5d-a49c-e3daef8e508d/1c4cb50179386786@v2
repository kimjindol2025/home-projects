# Fly.io 배포 설정
app = "pulse-ai"
primary_region = "nrt"  # Tokyo

[build]
  image = "pulse-ai:latest"
  builder = "paquet"  # 또는 "docker"

[[services]]
  internal_port = 8000
  processes = ["app"]

  [services.http_checks]
    enabled = true
    uri = "/health"
    interval = 10000  # 10초
    timeout = 5000    # 5초
    grace_period = "30s"

  [[services.ports]]
    port = 80
    handlers = ["http"]
    force_https = true

  [[services.ports]]
    port = 443
    handlers = ["tls", "http"]

[env]
  PYTHONUNBUFFERED = "1"
  LOG_LEVEL = "INFO"

[[mounts]]
  source = "redis_data"
  destination = "/data/redis"

[[mounts]]
  source = "ollama_data"
  destination = "/data/ollama"

[vm]
  memory = "2GB"
  cpus = 1

[metrics]
  port = 9090
  path = "/metrics"

# Secrets (fly secrets set으로 설정)
# fly secrets set ANTHROPIC_API_KEY=your_key
# fly secrets set SLACK_BOT_TOKEN=your_token
# fly secrets set GITHUB_TOKEN=your_token
# fly secrets set SENDER_EMAIL=your_email
# fly secrets set SENDER_PASSWORD=your_password

[deploy]
  release_command = "echo 'Deployment successful'"
  strategy = "rolling"
