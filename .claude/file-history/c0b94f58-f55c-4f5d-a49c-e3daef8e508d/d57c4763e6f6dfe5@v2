"""
캐시 모듈
Redis 기반 다층 캐싱 (NLU, LLM, 웹검색, 에이전트 상태)
"""

import json
import hashlib
from typing import Any, Callable, Optional, TypeVar
from datetime import timedelta
import asyncio
import logging

logger = logging.getLogger(__name__)

T = TypeVar('T')


class PulseCache:
    """Redis 기반 Pulse 캐시"""

    def __init__(self, redis_client=None):
        """
        캐시 초기화

        Args:
            redis_client: Redis 비동기 클라이언트 (aioredis)
        """
        self.redis = redis_client
        self.logger = logger

        # TTL 설정 (초 단위)
        self.ttl_config = {
            "nlu": 3600,  # 1시간
            "llm": 1800,  # 30분
            "web_search": 900,  # 15분
            "agent_status": 60,  # 1분
            "metrics": 300,  # 5분
        }

    def _get_cache_key(self, prefix: str, data: str) -> str:
        """
        캐시 키 생성

        Args:
            prefix: 캐시 타입 접두사 (nlu, llm, search 등)
            data: 캐시 키 기반 데이터

        Returns:
            해시된 캐시 키
        """
        hash_val = hashlib.md5(data.encode()).hexdigest()
        return f"{prefix}:{hash_val}"

    async def get_or_compute(
        self,
        prefix: str,
        key_data: str,
        ttl: Optional[int] = None,
        compute_fn: Optional[Callable] = None,
    ) -> Any:
        """
        캐시-어사이드 패턴: 캐시 조회 → 없으면 계산 → 저장

        Args:
            prefix: 캐시 타입 (nlu, llm, search 등)
            key_data: 캐시 키 기반 데이터
            ttl: TTL (초) - None이면 prefix 기본값 사용
            compute_fn: 캐시 미스 시 실행할 비동기 함수

        Returns:
            캐시된 값 또는 계산 결과
        """
        if not self.redis or not compute_fn:
            # Redis 없으면 바로 계산
            return await compute_fn() if asyncio.iscoroutinefunction(compute_fn) else compute_fn()

        cache_key = self._get_cache_key(prefix, key_data)
        ttl_seconds = ttl or self.ttl_config.get(prefix, 300)

        try:
            # 1. 캐시 조회
            cached_value = await self.redis.get(cache_key)
            if cached_value:
                self.logger.info(f"✅ 캐시 히트: {prefix}")
                return json.loads(cached_value)

        except Exception as e:
            self.logger.warning(f"⚠️ 캐시 조회 실패: {e}")

        # 2. 캐시 미스 → 계산
        self.logger.info(f"🔄 캐시 미스: {prefix} → 계산 중...")

        try:
            result = await compute_fn() if asyncio.iscoroutinefunction(compute_fn) else compute_fn()

            # 3. 캐시 저장
            await self._set_cache(cache_key, result, ttl_seconds)

            return result

        except Exception as e:
            self.logger.error(f"❌ 계산 실패: {e}")
            raise

    async def _set_cache(self, key: str, value: Any, ttl: int):
        """
        캐시에 값 저장

        Args:
            key: 캐시 키
            value: 저장할 값
            ttl: TTL (초)
        """
        try:
            json_value = json.dumps(value, default=str)
            if self.redis:
                await self.redis.setex(key, ttl, json_value)
                self.logger.debug(f"💾 캐시 저장: {key} (TTL {ttl}초)")
        except Exception as e:
            self.logger.warning(f"⚠️ 캐시 저장 실패: {e}")

    async def get(self, prefix: str, key_data: str) -> Optional[Any]:
        """
        캐시에서 직접 조회

        Args:
            prefix: 캐시 타입
            key_data: 캐시 키 기반 데이터

        Returns:
            캐시된 값 또는 None
        """
        if not self.redis:
            return None

        cache_key = self._get_cache_key(prefix, key_data)

        try:
            cached_value = await self.redis.get(cache_key)
            if cached_value:
                return json.loads(cached_value)
        except Exception as e:
            self.logger.warning(f"⚠️ 캐시 조회 실패: {e}")

        return None

    async def set(self, prefix: str, key_data: str, value: Any, ttl: Optional[int] = None):
        """
        캐시에 값 저장

        Args:
            prefix: 캐시 타입
            key_data: 캐시 키 기반 데이터
            value: 저장할 값
            ttl: TTL (초) - None이면 prefix 기본값 사용
        """
        cache_key = self._get_cache_key(prefix, key_data)
        ttl_seconds = ttl or self.ttl_config.get(prefix, 300)
        await self._set_cache(cache_key, value, ttl_seconds)

    async def delete(self, prefix: str, key_data: str) -> bool:
        """
        캐시 삭제

        Args:
            prefix: 캐시 타입
            key_data: 캐시 키 기반 데이터

        Returns:
            삭제 성공 여부
        """
        if not self.redis:
            return False

        cache_key = self._get_cache_key(prefix, key_data)

        try:
            result = await self.redis.delete(cache_key)
            self.logger.info(f"🗑️ 캐시 삭제: {prefix}")
            return result > 0
        except Exception as e:
            self.logger.warning(f"⚠️ 캐시 삭제 실패: {e}")
            return False

    async def increment_cost(self, amount: float) -> float:
        """
        일일 누적 비용 증가

        Args:
            amount: 증가할 금액 (USD)

        Returns:
            현재 누적 비용
        """
        if not self.redis:
            return amount

        key = "daily_cost"

        try:
            current = await self.redis.get(key)
            current_val = float(current) if current else 0.0
            new_val = current_val + amount

            # 자정에 초기화되도록 설정
            await self.redis.setex(key, 86400, str(new_val))  # 24시간

            return new_val

        except Exception as e:
            self.logger.warning(f"⚠️ 비용 기록 실패: {e}")
            return amount

    async def get_daily_cost(self) -> float:
        """
        오늘의 누적 비용 조회

        Returns:
            비용 (USD)
        """
        if not self.redis:
            return 0.0

        try:
            cost = await self.redis.get("daily_cost")
            return float(cost) if cost else 0.0
        except Exception as e:
            self.logger.warning(f"⚠️ 비용 조회 실패: {e}")
            return 0.0

    async def clear_expired(self):
        """
        만료된 캐시 정리 (Redis 자동 관리이므로 수동 호출 불필요)
        """
        self.logger.info("🧹 캐시 정리 (자동 관리)")

    async def get_stats(self) -> dict:
        """
        캐시 통계 조회

        Returns:
            캐시 통계 딕셔너리
        """
        if not self.redis:
            return {"status": "disabled"}

        try:
            info = await self.redis.info()
            return {
                "memory_usage_mb": info.get("used_memory", 0) / (1024 * 1024),
                "keys": info.get("db0", {}).get("keys", 0) if info.get("db0") else 0,
                "ttl_config": self.ttl_config,
            }
        except Exception as e:
            self.logger.warning(f"⚠️ 통계 조회 실패: {e}")
            return {"status": "error"}
