"""
에이전트 레지스트리 테스트
"""

import pytest
from src.registry import AgentRegistry


@pytest.mark.asyncio
async def test_register_agent(registry):
    """에이전트 등록"""
    agent_info = {
        "role": "테스트 에이전트",
        "status": "running",
        "deployment": "slack",
        "tools": ["slack"]
    }

    agent_id = await registry.register("test-001", agent_info)
    assert agent_id == "test-001"


@pytest.mark.asyncio
async def test_get_status(registry):
    """에이전트 상태 조회"""
    agent_info = {
        "role": "테스트 에이전트",
        "status": "running",
        "deployment": "slack",
        "tools": ["slack"]
    }

    await registry.register("test-002", agent_info)
    status = registry.get_status("test-002")

    assert status is not None
    assert status["id"] == "test-002"
    assert status["role"] == "테스트 에이전트"
    assert status["status"] == "running"


@pytest.mark.asyncio
async def test_unregister_agent(registry):
    """에이전트 등록 해제"""
    await registry.register("test-003", {"role": "테스트", "status": "running"})

    success = await registry.unregister("test-003")
    assert success is True

    status = registry.get_status("test-003")
    assert status is None


@pytest.mark.asyncio
async def test_update_status(registry):
    """에이전트 상태 업데이트"""
    await registry.register("test-004", {"role": "테스트", "status": "running"})

    success = registry.update_status("test-004", status="stopped")
    assert success is True

    status = registry.get_status("test-004")
    assert status["status"] == "stopped"


