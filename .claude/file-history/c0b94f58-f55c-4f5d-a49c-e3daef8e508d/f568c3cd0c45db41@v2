#!/bin/bash

# C11 Libraries - Comprehensive Test Suite
# 모든 라이브러리의 테스트를 실행하고 결과를 종합

set -e

echo "🧪 C11 Libraries - Comprehensive Test Suite"
echo "=============================================="
echo ""

LIBRARIES=(
    "uuid-c"
    "express-c"
    "async-c"
    "body-c"
    "chalk-c"
    "commander-c"
    "connect-c"
    "cookie-c"
    "cookie-parser-c"
    "cookie_crypto-c"
    "final-c"
    "fs-c"
    "glob-c"
    "graphql-c"
    "knex-c"
    "lodash-c"
    "mime-c"
    "moment-c"
    "range-c"
)

PASS=0
FAIL=0
SKIP=0

for lib in "${LIBRARIES[@]}"; do
    if [ -d "$lib" ]; then
        echo ""
        echo "📦 Testing: $lib"
        echo "─────────────────────────"

        if [ -f "$lib/Makefile" ]; then
            cd "$lib"

            # 테스트 실행
            if make test 2>/dev/null; then
                echo "✅ $lib: PASS"
                ((PASS++))
            else
                echo "❌ $lib: FAIL"
                ((FAIL++))
            fi

            cd ..
        else
            echo "⏭️  $lib: SKIP (no Makefile)"
            ((SKIP++))
        fi
    fi
done

echo ""
echo "=============================================="
echo "📊 Test Results Summary"
echo "=============================================="
echo "✅ Passed:  $PASS"
echo "❌ Failed:  $FAIL"
echo "⏭️  Skipped: $SKIP"
echo "📈 Total:   $((PASS + FAIL + SKIP))"
echo ""

if [ $FAIL -eq 0 ]; then
    echo "🎉 All tests passed!"
    exit 0
else
    echo "⚠️  Some tests failed"
    exit 1
fi
