"""
레지스트리 모듈
실행 중 에이전트의 중앙 집중식 관리
"""

import json
from typing import Dict, Any, Optional, List
from datetime import datetime
import logging

logger = logging.getLogger(__name__)


class AgentRegistry:
    """에이전트 중앙 관리 레지스트리"""

    def __init__(self, cache=None):
        """
        레지스트리 초기화

        Args:
            cache: PulseCache 인스턴스 (선택)
        """
        self.agents: Dict[str, Dict[str, Any]] = {}
        self.cache = cache
        self.logger = logger

    async def register(self, agent_id: str, agent_info: Dict[str, Any]) -> str:
        """
        에이전트 등록

        Args:
            agent_id: 에이전트 ID
            agent_info: 에이전트 정보

        Returns:
            등록된 에이전트 ID
        """
        self.agents[agent_id] = {
            "id": agent_id,
            "created_at": datetime.now().isoformat(),
            **agent_info
        }

        self.logger.info(f"✅ 에이전트 등록: {agent_id}")

        # 캐시에도 저장
        if self.cache:
            await self.cache.set(
                "agent_status",
                agent_id,
                self.agents[agent_id],
                ttl=3600
            )

        return agent_id

    async def unregister(self, agent_id: str) -> bool:
        """
        에이전트 등록 해제

        Args:
            agent_id: 에이전트 ID

        Returns:
            성공 여부
        """
        if agent_id in self.agents:
            del self.agents[agent_id]
            self.logger.info(f"❌ 에이전트 등록 해제: {agent_id}")

            # 캐시에서도 삭제
            if self.cache:
                await self.cache.delete("agent_status", agent_id)

            return True

        return False

    def get_status(self, agent_id: str) -> Optional[Dict[str, Any]]:
        """
        에이전트 상태 조회

        Args:
            agent_id: 에이전트 ID

        Returns:
            에이전트 정보 또는 None
        """
        agent = self.agents.get(agent_id)
        if agent:
            return {
                "id": agent.get("id"),
                "role": agent.get("role"),
                "status": agent.get("status"),
                "deployment": agent.get("deployment"),
                "tools": agent.get("tools", []),
                "created_at": agent.get("created_at"),
                "started_at": agent.get("started_at"),
                "uptime_seconds": agent.get("uptime_seconds"),
            }
        return None

    def update_status(self, agent_id: str, **updates) -> bool:
        """
        에이전트 상태 업데이트

        Args:
            agent_id: 에이전트 ID
            updates: 업데이트할 필드들

        Returns:
            성공 여부
        """
        if agent_id in self.agents:
            self.agents[agent_id].update(updates)
            self.logger.info(f"🔄 에이전트 상태 업데이트: {agent_id}")
            return True

        return False

    def list_all(self) -> List[Dict[str, Any]]:
        """
        모든 에이전트 목록 조회

        Returns:
            에이전트 정보 리스트
        """
        return list(self.agents.values())

    def list_by_status(self, status: str) -> List[Dict[str, Any]]:
        """
        특정 상태의 에이전트 조회

        Args:
            status: 상태 (running, stopped, failed 등)

        Returns:
            매칭되는 에이전트 정보 리스트
        """
        return [a for a in self.agents.values() if a.get("status") == status]

    def list_by_deployment(self, deployment: str) -> List[Dict[str, Any]]:
        """
        특정 배포 방식의 에이전트 조회

        Args:
            deployment: 배포 방식 (slack, email, scheduled 등)

        Returns:
            매칭되는 에이전트 정보 리스트
        """
        return [a for a in self.agents.values() if a.get("deployment") == deployment]

    def count(self) -> int:
        """에이전트 개수"""
        return len(self.agents)

    def count_by_status(self, status: str) -> int:
        """특정 상태의 에이전트 개수"""
        return len(self.list_by_status(status))

    async def get_metrics(self) -> Dict[str, Any]:
        """
        에이전트 메트릭 조회

        Returns:
            메트릭 정보
        """
        running_agents = self.list_by_status("running")
        total_uptime = sum(
            a.get("uptime_seconds", 0) for a in running_agents
        )

        return {
            "total_agents": self.count(),
            "running": self.count_by_status("running"),
            "stopped": self.count_by_status("stopped"),
            "failed": self.count_by_status("failed"),
            "scheduled": self.count_by_status("scheduled"),
            "by_deployment": {
                "slack": len(self.list_by_deployment("slack")),
                "email": len(self.list_by_deployment("email")),
                "scheduled": len(self.list_by_deployment("scheduled")),
                "immediate": len(self.list_by_deployment("immediate")),
            },
            "total_uptime_seconds": total_uptime,
            "average_uptime_seconds": (
                total_uptime / len(running_agents) if running_agents else 0
            ),
        }

    async def healthcheck(self) -> Dict[str, Any]:
        """
        레지스트리 헬스 체크

        Returns:
            헬스 체크 결과
        """
        return {
            "status": "healthy",
            "timestamp": datetime.now().isoformat(),
            "agents": self.count(),
            "running": self.count_by_status("running"),
        }

    def clear(self):
        """모든 에이전트 등록 해제 (개발/테스트용)"""
        self.agents.clear()
        self.logger.warning("🗑️ 모든 에이전트 등록 해제됨")
