```

#### 20. **final-c** - Error Handling
```c
#include "kfinal.h"

// Try-Catch-Finally
TRY
{
    int *ptr = malloc(sizeof(int));
    if (!ptr) THROW(MEMORY_ERROR);

    *ptr = 42;
    free(ptr);
}
CATCH(MEMORY_ERROR)
{
    printf("Memory allocation failed\n");
}
FINALLY
{
    cleanup_resources();
}
```

