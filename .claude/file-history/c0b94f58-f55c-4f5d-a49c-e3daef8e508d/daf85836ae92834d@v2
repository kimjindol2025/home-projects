#### 18. **knex-c** - SQL Query Builder
```c
#include "kknex.h"

// 쿼리 빌더
knex_t *query = knex_create("sqlite", "database.db");

// SELECT
knex_builder_t *select = knex_select(query, "id", "name", "email")
    ->from(query, "users")
    ->where(query, "age", ">", "18")
    ->limit(query, 10);

char *sql = knex_to_sql(select);
// Output: SELECT id, name, email FROM users WHERE age > 18 LIMIT 10

// INSERT
knex_builder_t *insert = knex_insert(query, "users")
    ->values(query, "name", "John")
    ->values(query, "email", "john@example.com");

// UPDATE
knex_builder_t *update = knex_update(query, "users")
    ->set(query, "name", "Jane")
    ->where(query, "id", "=", "1");
```

