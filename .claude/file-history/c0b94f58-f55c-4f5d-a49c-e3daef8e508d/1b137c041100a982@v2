"""
게이트웨이 API 테스트
"""

import pytest
from fastapi.testclient import TestClient
from src.gateway import create_app


@pytest.fixture
def client():
    """FastAPI 테스트 클라이언트"""
    app = create_app()
    return TestClient(app)


def test_root_endpoint(client):
    """루트 엔드포인트"""
    response = client.get("/")
    assert response.status_code == 200
    data = response.json()
    assert "name" in data
    assert data["name"] == "Pulse AI API"


def test_health_check(client):
    """헬스 체크"""
    response = client.get("/health")
    assert response.status_code == 200
    data = response.json()
    assert "status" in data


def test_metrics_endpoint(client):
    """메트릭 조회"""
    response = client.get("/metrics")
    assert response.status_code == 200
    data = response.json()
    assert "llm" in data
    assert "agents" in data
    assert "cost" in data


def test_list_agents_empty(client):
    """에이전트 목록 (비어있음)"""
    response = client.get("/agents")
    assert response.status_code == 200
    data = response.json()
    assert "agents" in data
    assert data["total_agents"] == 0


def test_create_agent_dry_run(client):
    """에이전트 생성 (dry-run)"""
    response = client.post(
        "/pulse",
        json={
            "instruction": "슬랙 봇 만들어",
            "dry_run": True
        }
    )
    assert response.status_code == 200
    data = response.json()
    assert data["success"] is True
    assert "pulse_code" in data
    assert data["cost_usd"] == 0.0


def test_get_nonexistent_agent(client):
    """존재하지 않는 에이전트 조회"""
    response = client.get("/agents/nonexistent")
    assert response.status_code == 404


@pytest.mark.asyncio
async def test_pulse_api_full_flow(client, sample_instruction):
    """Pulse API 전체 흐름"""
    # 에이전트 생성 요청
    response = client.post(
        "/pulse",
        json={
            "instruction": sample_instruction,
            "dry_run": True
        }
    )

    assert response.status_code == 200
    data = response.json()
    assert data["success"] is True
    assert data["pulse_code"] is not None

    # 메트릭 확인
    response = client.get("/metrics")
    assert response.status_code == 200
    metrics = response.json()
    assert "llm" in metrics


def test_api_error_handling(client):
    """API 에러 처리"""
    # 빈 지시
    response = client.post(
        "/pulse",
        json={"instruction": ""}
    )
    # 에러 처리 확인
    assert response.status_code in [200, 400]


def test_cors_headers(client):
    """CORS 헤더 확인"""
    response = client.options("/pulse")
    assert "access-control-allow-origin" in response.headers or response.status_code == 200


def test_pulse_request_validation(client):
    """Pulse 요청 검증"""
    # instruction 누락
    response = client.post(
        "/pulse",
        json={"dry_run": True}
    )
    # 검증 오류 확인
    assert response.status_code in [200, 422]
