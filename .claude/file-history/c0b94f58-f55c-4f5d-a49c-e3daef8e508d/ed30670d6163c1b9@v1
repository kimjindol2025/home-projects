"""
Pulse 파서 모듈
Intent → Pulse 코드 생성
"""

from typing import List
from nlu import Intent

class PulseParser:
    """Pulse 코드 생성 엔진"""
    
    def generate(self, intent: Intent) -> str:
        """
        Intent 객체를 Pulse 코드로 변환
        
        Pulse 코드 구조:
        로서 [역할]
        사용 [모델] [도구] [제약]
        해야할일 [목표]
        흐름 [단계] (선택)
        실행 [배포]
        """
        
        lines = []
        
        # 1. 로서
        lines.append(f"로서 {intent.role}")
        
        # 2. 사용
        models_str = " + ".join(intent.models)
        tools_str = " ".join(intent.tools)
        constraints_str = " ".join([f"{k}{v}" for k, v in (intent.constraints or {}).items()])
        
        use_line = f"사용 {models_str} {tools_str}"
        if constraints_str:
            use_line += f" {constraints_str}"
        lines.append(use_line)
        
        # 3. 해야할일
        lines.append(f"해야할일 {intent.goal}")
        
        # 4. 흐름 (선택)
        if intent.flow:
            flow_str = " → ".join(intent.flow)
            lines.append(f"흐름 {flow_str}")
        
        # 5. 실행
        if intent.deployment:
            lines.append(f"실행 {intent.deployment} 자동복구 로깅활성화")
        
        pulse_code = "\n".join(lines)
        return pulse_code
