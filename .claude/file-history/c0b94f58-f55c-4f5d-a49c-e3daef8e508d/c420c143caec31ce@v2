### WebSocket 실시간 스트리밍

```python
import asyncio
import websockets
import json

async def stream():
    uri = "ws://localhost:8000/ws/session-001"
    async with websockets.connect(uri) as ws:
        # 요청 전송
        await ws.send(json.dumps({
            "type": "instruction",
            "data": "슬랙 봇 만들어"
        }))

        # 응답 수신
        while True:
            msg = json.loads(await ws.recv())
            print(msg["data"])
            if msg["type"] == "done":
                break

asyncio.run(stream())
```

