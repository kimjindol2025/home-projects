#!/usr/bin/env python3
"""
Pulse CLI 진입점
자연어 입력 → Pulse 자동 처리
"""

import sys
import asyncio
from typing import Optional
from nlu import NLUProcessor
from parser import PulseParser
from runtime import PulseRuntime
from llm_manager import LLMManager

def main():
    """Pulse CLI 메인 함수"""
    
    if len(sys.argv) < 2:
        print("❌ 사용법: python main.py '당신의 자연어 지시'")
        print("예: python main.py '매일 아침 9시에 뉴스 찾아봐서 이메일 발송해 줄래?'")
        return
    
    # 자연어 입력
    user_input = " ".join(sys.argv[1:])
    
    print(f"🔄 처리 중: {user_input[:50]}...")
    
    # Pulse 처리 파이프라인
    try:
        # 1. NLU: 자연어 분석
        nlu = NLUProcessor()
        intent = nlu.analyze(user_input)
        
        # 2. Parser: Pulse 코드 생성
        parser = PulseParser()
        pulse_code = parser.generate(intent)
        
        # 3. Runtime: 실행
        runtime = PulseRuntime()
        result = asyncio.run(runtime.execute(pulse_code))
        
        # 4. 결과 자연어로 반환
        print(f"✅ 완료!\n{result}")
        
    except Exception as e:
        print(f"❌ 오류: {e}")
        sys.exit(1)

if __name__ == "__main__":
    main()
