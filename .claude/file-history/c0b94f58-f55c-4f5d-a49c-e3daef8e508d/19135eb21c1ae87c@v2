    async def export_prometheus_metrics(self) -> str:
        """
        Prometheus 형식으로 메트릭 내보내기

        Returns:
            Prometheus 텍스트 형식
        """
        metrics = await self.get_metrics()

        prometheus = f"""# HELP pulse_llm_total_tokens Total LLM tokens used
# TYPE pulse_llm_total_tokens counter
pulse_llm_total_tokens {metrics.llm_total_tokens}

# HELP pulse_llm_total_cost_usd Total cost in USD
# TYPE pulse_llm_total_cost_usd gauge
pulse_llm_total_cost_usd {metrics.llm_total_cost_usd}

# HELP pulse_agents_total Total number of agents
# TYPE pulse_agents_total gauge
pulse_agents_total {metrics.agents_total}

# HELP pulse_agents_running Number of running agents
# TYPE pulse_agents_running gauge
pulse_agents_running {metrics.agents_running}

# HELP pulse_cache_hits Total cache hits
# TYPE pulse_cache_hits counter
pulse_cache_hits {metrics.cache_hits}

# HELP pulse_cache_misses Total cache misses
# TYPE pulse_cache_misses counter
pulse_cache_misses {metrics.cache_misses}

# HELP pulse_requests_total Total requests
# TYPE pulse_requests_total counter
pulse_requests_total {metrics.requests_total}

# HELP pulse_requests_success Successful requests
# TYPE pulse_requests_success counter
pulse_requests_success {metrics.requests_success}

# HELP pulse_requests_error Failed requests
# TYPE pulse_requests_error counter
pulse_requests_error {metrics.requests_error}

# HELP pulse_average_response_time_ms Average response time in milliseconds
# TYPE pulse_average_response_time_ms gauge
pulse_average_response_time_ms {metrics.average_response_time_ms}
"""
        return prometheus
