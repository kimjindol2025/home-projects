section("2. CRUD — INSERT");

test("자동 ID 시작값 1", () => {
  const orm = userORM();
  const r = orm.insert("users", { name: "A", age: 20, email: "a@t.com", score: 1.0 });
  eq(r.id, 1);
});

test("연속 INSERT ID 증가", () => {
  const orm = userORM();
  const ids = [1, 2, 3, 4, 5].map((i) => {
    return orm.insert("users", { name: `U${i}`, age: 20 + i, email: `u${i}@t.com`, score: i * 1.0 }).id;
  });
  eq(ids, [1, 2, 3, 4, 5]);
});

test("INSERT 후 원본 불변 (immutable copy)", () => {
  const orm = userORM();
  const data = { name: "Alice", age: 30, email: "a@t.com", score: 1.0 };
  const row = orm.insert("users", data);
  data.name = "MUTATED";
  eq(orm.findById("users", row.id)!.name, "Alice");
});

test("INSERT 반환값에 id 포함", () => {
  const orm = userORM();
  const row = orm.insert("users", { name: "X", age: 1, email: "x@t.com", score: 0.0 });
  assert("id" in row && typeof row.id === "number");
});

test("COUNT 정확성", () => {
  const orm = userORM();
  eq(orm.count("users"), 0);
  seedUsers(orm, 10);
  eq(orm.count("users"), 10);
});

test("INSERT 후 findById 즉시 조회", () => {
  const orm = userORM();
  const row = orm.insert("users", { name: "Bob", age: 25, email: "b@t.com", score: 5.5 });
  const found = orm.findById("users", row.id);
  assert(found !== null);
  eq(found!.name, "Bob");
});

test("다른 테이블 ID는 독립적", () => {
  const orm = new ORMEngine();
  orm.define("a", { x: { type: "i32" } });
  orm.define("b", { y: { type: "i32" } });
  const a1 = orm.insert("a", { x: 1 });
  const b1 = orm.insert("b", { y: 1 });
  eq(a1.id, 1);
  eq(b1.id, 1);
});

