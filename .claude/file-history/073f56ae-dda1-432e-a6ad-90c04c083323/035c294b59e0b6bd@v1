section("9. 트랜잭션");

test("begin/commit — 변경 확정", () => {
  const orm = userORM();
  seedUsers(orm, 2);
  orm.begin();
  orm.insert("users", { name: "TxUser", age: 99, email: "tx@t.com", score: 0.0 });
  orm.commit();
  eq(orm.count("users"), 3); // 커밋 후 반영
});

test("begin/rollback — INSERT 취소", () => {
  const orm = userORM();
  seedUsers(orm, 2);
  orm.begin();
  orm.insert("users", { name: "TxUser", age: 99, email: "tx@t.com", score: 0.0 });
  eq(orm.count("users"), 3); // 트랜잭션 중
  orm.rollback();
  eq(orm.count("users"), 2); // 롤백 후 원복
});

test("rollback — UPDATE 취소", () => {
  const orm = userORM();
  seedUsers(orm, 1);
  orm.begin();
  orm.update("users", 1, { name: "CHANGED" });
  orm.rollback();
  eq(orm.findById("users", 1)!.name, "User1");
});

test("rollback — DELETE 취소", () => {
  const orm = userORM();
  seedUsers(orm, 3);
  orm.begin();
  orm.delete("users", 2);
  eq(orm.count("users"), 2);
  orm.rollback();
  eq(orm.count("users"), 3);
  assert(orm.findById("users", 2) !== null);
});

test("commit 후 isInTransaction = false", () => {
  const orm = userORM();
  orm.begin();
  assert(orm.isInTransaction);
  orm.commit();
  assert(!orm.isInTransaction);
});

test("rollback 후 isInTransaction = false", () => {
  const orm = userORM();
  orm.begin();
  orm.rollback();
  assert(!orm.isInTransaction);
});

test("중복 begin 에러", () => {
  const orm = userORM();
  orm.begin();
  let threw = false;
  try { orm.begin(); } catch { threw = true; }
  orm.rollback();
  assert(threw);
});

test("트랜잭션 없이 commit 에러", () => {
  const orm = userORM();
  let threw = false;
  try { orm.commit(); } catch { threw = true; }
  assert(threw);
});

