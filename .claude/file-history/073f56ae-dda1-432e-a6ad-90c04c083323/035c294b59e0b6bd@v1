section("6. Query Builder");

function productORM() {
  const orm = new ORMEngine();
  orm.define("products", {
    name:  { type: "string" },
    price: { type: "i32" },
    cat:   { type: "string" },
    stock: { type: "i32" },
  });
  const data = [
    { name: "Apple",   price: 1200, cat: "fruit",  stock: 100 },
    { name: "Banana",  price: 800,  cat: "fruit",  stock: 50  },
    { name: "Carrot",  price: 500,  cat: "veggie", stock: 200 },
    { name: "Daikon",  price: 300,  cat: "veggie", stock: 80  },
    { name: "Egg",     price: 200,  cat: "dairy",  stock: 500 },
    { name: "Figs",    price: 3000, cat: "fruit",  stock: 20  },
    { name: "Grape",   price: 2500, cat: "fruit",  stock: 30  },
  ];
  orm.bulkInsert("products", data);
  return orm;
}

test("단순 filter (=)", () => {
  const orm = productORM();
  const fruits = orm.where("products", "cat", "=", "fruit");
  eq(fruits.length, 4);
  assert(fruits.every((r) => r.cat === "fruit"));
});

test("filter > 범위", () => {
  const orm = productORM();
  const expensive = orm.where("products", "price", ">", 2000);
  eq(expensive.length, 2);
});

test("filter <= 범위", () => {
  const orm = productORM();
  const cheap = orm.where("products", "price", "<=", 500);
  eq(cheap.length, 3);
});

test("filter != 제외", () => {
  const orm = productORM();
  const notFruit = orm.where("products", "cat", "!=", "fruit");
  eq(notFruit.length, 3);
});

test("filter like 문자열 포함", () => {
  const orm = productORM();
  const rows = orm.where("products", "name", "like", "a"); // Apple, Banana, Daikon, Grape
  assert(rows.length >= 3);
});

test("order asc 정렬", () => {
  const orm = productORM();
  let q = orm.query("products");
  q = orm.orderBy(q, "price", "asc");
  const rows = orm.exec(q);
  for (let i = 1; i < rows.length; i++) {
    assert(rows[i - 1].price <= rows[i].price);
  }
});

test("order desc + limit", () => {
  const orm = productORM();
  let q = orm.query("products");
  q = orm.orderBy(q, "price", "desc");
  q = orm.limit(q, 3);
  const rows = orm.exec(q);
  eq(rows.length, 3);
  eq(rows[0].name, "Figs"); // 가장 비쌈
});

test("offset + limit 페이징", () => {
  const orm = productORM();
  let q = orm.query("products");
  q = orm.orderBy(q, "id", "asc");
  q = orm.offset(q, 2);
  q = orm.limit(q, 3);
  const rows = orm.exec(q);
  eq(rows.length, 3);
  eq(rows[0].id, 3);
});

