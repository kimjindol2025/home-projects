// 10. Bulk Insert + Truncate (3 tests)
// ============================================================
section("10. Bulk Insert / Truncate");

test("bulkInsert 개수 정확성", () => {
  const orm = userORM();
  const records = Array.from({ length: 100 }, (_, i) => ({
    name: `U${i}`, age: 20 + (i % 50), email: `u${i}@t.com`, score: i * 0.1,
  }));
  orm.bulkInsert("users", records);
  eq(orm.count("users"), 100);
});

test("bulkInsert ID 연속성", () => {
  const orm = userORM();
  const records = Array.from({ length: 5 }, (_, i) => ({
    name: `U${i}`, age: 20, email: `u${i}@t.com`, score: 0.0,
  }));
  const rows = orm.bulkInsert("users", records);
  eq(rows.map((r) => r.id), [1, 2, 3, 4, 5]);
});

test("truncate 후 count=0, autoId 재시작", () => {
  const orm = userORM();
  seedUsers(orm, 5);
  orm.truncate("users");
  eq(orm.count("users"), 0);
  const row = orm.insert("users", { name: "Fresh", age: 1, email: "f@t.com", score: 0.0 });
  eq(row.id, 1);
});

