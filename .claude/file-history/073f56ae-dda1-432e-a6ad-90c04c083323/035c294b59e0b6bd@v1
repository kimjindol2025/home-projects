section("7. JOIN");

function joinORM() {
  const orm = new ORMEngine();
  orm.define("users",  { name: { type: "string" } });
  orm.define("orders", { user_id: { type: "i32" }, product: { type: "string" }, amount: { type: "i32" } });
  orm.insert("users",  { name: "Alice" });
  orm.insert("users",  { name: "Bob" });
  orm.insert("users",  { name: "Carol" }); // 주문 없음
  orm.insert("orders", { user_id: 1, product: "A", amount: 5000 });
  orm.insert("orders", { user_id: 1, product: "B", amount: 3000 });
  orm.insert("orders", { user_id: 2, product: "C", amount: 8000 });
  return orm;
}

test("INNER JOIN 행 수", () => {
  const orm = joinORM();
  const rows = orm.join("orders", "users", "user_id", "id");
  eq(rows.length, 3);
});

test("INNER JOIN 필드 병합 prefix", () => {
  const orm = joinORM();
  const rows = orm.join("orders", "users", "user_id", "id");
  assert(rows.every((r) => "users__name" in r));
});

test("INNER JOIN Alice 주문 2건", () => {
  const orm = joinORM();
  const rows = orm.join("orders", "users", "user_id", "id");
  eq(rows.filter((r) => r["users__name"] === "Alice").length, 2);
});

test("LEFT JOIN Carol 포함 (주문 없는 유저)", () => {
  const orm = joinORM();
  const rows = orm.leftJoin("users", "orders", "id", "user_id");
  // Alice 2건, Bob 1건, Carol 1건(null)
  const carols = rows.filter((r) => r.name === "Carol");
  assert(carols.length >= 1);
  // Carol의 orders 필드는 null
  assert(carols[0]["orders__product"] === null || carols[0]["orders__product"] === undefined);
});

test("LEFT JOIN 행 수 >= INNER JOIN", () => {
  const orm = joinORM();
  const inner = orm.join("orders", "users", "user_id", "id");
  const left  = orm.leftJoin("users", "orders", "id", "user_id");
  assert(left.length >= inner.length);
});

