// 1. Model 정의 (5 tests)
// ============================================================
section("1. Model 정의");

test("단일 테이블 정의", () => {
  const orm = new ORMEngine();
  orm.define("items", { name: { type: "string" } });
  assert(orm.tableNames().includes("items"));
});

test("복수 테이블 정의", () => {
  const orm = new ORMEngine();
  orm.define("a", { x: { type: "i32" } });
  orm.define("b", { y: { type: "string" } });
  orm.define("c", { z: { type: "bool" } });
  eq(orm.tableNames().sort(), ["a", "b", "c"]);
});

test("중복 테이블 에러", () => {
  const orm = new ORMEngine();
  orm.define("t", { x: { type: "i32" } });
  let threw = false;
  try { orm.define("t", { x: { type: "i32" } }); } catch { threw = true; }
  assert(threw);
});

test("없는 테이블 접근 에러", () => {
  const orm = new ORMEngine();
  let threw = false;
  try { orm.findAll("ghost"); } catch { threw = true; }
  assert(threw);
});

test("nullable 필드 정의", () => {
  const orm = new ORMEngine();
  orm.define("t", { name: { type: "string" }, bio: { type: "string", nullable: true } });
  const row = orm.insert("t", { name: "Alice", bio: null as any });
  assert("bio" in row);
});

