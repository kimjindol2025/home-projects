// 8. Eager Loading / N+1 방지 (5 tests)
// ============================================================
section("8. Eager Loading / N+1");

function relORM() {
  const orm = new ORMEngine();
  orm.define("authors", { name: { type: "string" } });
  orm.define("books",   { title: { type: "string" }, author_id: { type: "i32" } });
  orm.define("tags",    { book_id: { type: "i32" }, label: { type: "string" } });
  orm.insert("authors", { name: "Alice" });
  orm.insert("authors", { name: "Bob" });
  orm.insert("books",   { title: "Book A", author_id: 1 });
  orm.insert("books",   { title: "Book B", author_id: 1 });
  orm.insert("books",   { title: "Book C", author_id: 2 });
  orm.insert("tags",    { book_id: 1, label: "fiction" });
  orm.insert("tags",    { book_id: 1, label: "scifi" });
  orm.insert("tags",    { book_id: 3, label: "nonfiction" });
  orm.belongsTo("books", "authors", "author_id", "author");
  orm.hasMany("authors", "books", "author_id", "books");
  orm.hasMany("books", "tags", "book_id", "tags");
  return orm;
}

test("belongs_to eager load — author 필드 존재", () => {
  const orm = relORM();
  const loaded = orm.eagerLoad(orm.findAll("books"), "author");
  assert(loaded.every((r) => "author" in r));
});

test("belongs_to — 올바른 저자 매칭", () => {
  const orm = relORM();
  const loaded = orm.eagerLoad(orm.findAll("books"), "author");
  const bookA = loaded.find((r) => r.title === "Book A")!;
  eq(bookA.author.name, "Alice");
});

test("has_many — Alice 책 2권", () => {
  const orm = relORM();
  const loaded = orm.eagerLoad(orm.findAll("authors"), "books");
  const alice = loaded.find((r) => r.name === "Alice")!;
  eq(alice.books.length, 2);
});

test("has_many — 관계 없는 경우 빈 배열", () => {
  const orm = relORM();
  const loaded = orm.eagerLoad(orm.findAll("books"), "tags");
  const bookB = loaded.find((r) => r.title === "Book B")!;
  eq(bookB.tags, []);
});

test("batchLoad — IN 쿼리 정확성", () => {
  const orm = relORM();
  const rows = orm.batchLoad("books", "author_id", [1, 2]);
  eq(rows.length, 3);
});

