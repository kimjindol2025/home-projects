pub fn test_a1_kademlia_distance_calculation() -> bool {
    var id1 = nodeid_new([1, 0, 0, 0, 0, 0, 0, 0])
    var id2 = nodeid_new([2, 0, 0, 0, 0, 0, 0, 0])

    var distance = nodeid_distance(id1, id2)

    // XOR: 1 ^ 2 = 3 (binary: ...011)
    // Distance should be 2 (position of highest bit)
    return distance > 0
}

pub fn test_a2_kbucket_management() -> bool {
    var bucket = KBucket {
        count: 0,
        replacement_count: 0,
        peers: uninitialized(),
        replacement_cache: uninitialized(),
    }

    var peer = Peer {
        node_id: nodeid_new([1, 0, 0, 0, 0, 0, 0, 0]),
        ip: "127.0.0.1",
        port: 8000,
        last_seen: 0,
        reputation: 100,
    }

    var success = kbucket_add_peer(&mut bucket, peer)
    return success && bucket.count == 1
}

