// ============================================================================
// Kademlia Distance & Constants
// ============================================================================

const KADEMLIA_K = 20              // k-bucket 크기
const KADEMLIA_ALPHA = 3            // 병렬 조회 수
const KADEMLIA_ID_BITS = 256        // 256-bit node ID
const NODE_LOOKUP_TIMEOUT = 1000    // 1000ms timeout
const REPLICATION_FACTOR = 3        // 3개 노드에 복제

// ============================================================================
// Data Types
// ============================================================================

pub struct NodeID {
    id: [8]u64  // 256-bit ID (8 x 64-bit)
}

pub struct Peer {
    node_id: NodeID,
    ip: String,
    port: u16,
    last_seen: u64,     // timestamp
    reputation: i32,    // -100 to +100
}

pub struct KBucket {
    peers: [Peer; KADEMLIA_K],  // k closest peers
    count: usize,
    replacement_cache: [Peer; KADEMLIA_K],  // replacement list
    replacement_count: usize,
}

pub struct StoredValue {
    key: String,
    data: String,
    timestamp: u64,
    replication_nodes: [NodeID; REPLICATION_FACTOR],
    version: u64,
}

pub struct DHTNode {
    self_id: NodeID,
    ip: String,
    port: u16,

    // Routing table: 256 k-buckets (one per bit)
    buckets: [KBucket; 256],

    // Local storage
    stored_values: [StoredValue; 1000],
    storage_count: usize,

    // Peer management
    known_peers: [Peer; 10000],
    peer_count: usize,

    // Stats
    lookups_completed: u64,
    data_stored: u64,
    replications_done: u64,

    // Timing
    last_bootstrap: u64,
    last_refresh: u64,
}

// ============================================================================
// NodeID Functions
// ============================================================================

pub fn nodeid_new(id: [8]u64) -> NodeID {
    return NodeID { id: id }
}

pub fn nodeid_xor(a: NodeID, b: NodeID) -> NodeID {
    var result: [8]u64
    var i = 0
    while i < 8 {
        result[i] = a.id[i] ^ b.id[i]
        i = i + 1
    }
    return NodeID { id: result }
}

pub fn nodeid_distance(a: NodeID, b: NodeID) -> u32 {
    var xor_result = nodeid_xor(a, b)
    var distance = 0u32
    var i = 0
    while i < 8 {
        if xor_result.id[i] == 0 {
            distance = distance + 64
        } else {
            // Find highest set bit
            var bit_pos = 63u32
            var mask = 1u64 << 63
            while bit_pos >= 0 && (xor_result.id[i] & mask) == 0 {
                bit_pos = bit_pos - 1
                mask = mask >> 1
            }
            distance = distance + bit_pos
            break
        }
        i = i + 1
    }
    return distance
}

pub fn nodeid_compare(a: NodeID, b: NodeID) -> i32 {
    var i = 0
    while i < 8 {
        if a.id[i] < b.id[i] {
            return -1
        } else if a.id[i] > b.id[i] {
            return 1
        }
        i = i + 1
    }
    return 0
}

// ============================================================================
// DHTNode Functions
// ============================================================================

pub fn dhtnode_new(self_id: NodeID, ip: String, port: u16) -> DHTNode {
    var node = DHTNode {
        self_id: self_id,
        ip: ip,
        port: port,
        buckets: uninitialized(),
        stored_values: uninitialized(),
        known_peers: uninitialized(),
        bucket_count: 0,
        storage_count: 0,
        peer_count: 0,
        lookups_completed: 0,
        data_stored: 0,
        replications_done: 0,
        last_bootstrap: 0,
        last_refresh: 0,
    }

    // Initialize k-buckets
    var i = 0
    while i < 256 {
        node.buckets[i].count = 0
        node.buckets[i].replacement_count = 0
        i = i + 1
    }

    return node
}

pub fn kbucket_add_peer(bucket: &mut KBucket, peer: Peer) -> bool {
    // If bucket is not full, add peer
    if bucket.count < KADEMLIA_K {
        bucket.peers[bucket.count] = peer
        bucket.count = bucket.count + 1
        return true
    }

    // If bucket is full, add to replacement cache
    if bucket.replacement_count < KADEMLIA_K {
        bucket.replacement_cache[bucket.replacement_count] = peer
        bucket.replacement_count = bucket.replacement_count + 1
        return true
    }

    return false
}

pub fn dhtnode_add_peer(node: &mut DHTNode, peer: Peer) {
    // Calculate distance to determine which k-bucket
    var distance = nodeid_distance(node.self_id, peer.node_id)
    if distance >= 256 {
        distance = 255
    }

    // Add peer to appropriate k-bucket
    kbucket_add_peer(&mut node.buckets[distance], peer)

    // Also add to known_peers if space available
    if node.peer_count < 10000 {
        node.known_peers[node.peer_count] = peer
        node.peer_count = node.peer_count + 1
    }
}

pub fn dhtnode_find_nearest_peers(node: &DHTNode, target: NodeID, count: u32) -> [Peer; 20] {
    var result: [Peer; 20]
    var result_count = 0u32
    var i = 0

    // Simple greedy search: find peers closest to target
    while i < node.peer_count && result_count < count {
        var peer = node.known_peers[i]
        var distance = nodeid_distance(target, peer.node_id)

        // Insert in sorted order (simplified)
        if result_count < count {
            result[result_count] = peer
            result_count = result_count + 1
        }
        i = i + 1
    }

    return result
}

pub fn dhtnode_store_value(node: &mut DHTNode, key: String, data: String, replication_nodes: [NodeID; REPLICATION_FACTOR]) -> bool {
    if node.storage_count >= 1000 {
        return false  // Storage full
    }

    var now = 0u64  // Would get current timestamp
    var value = StoredValue {
        key: key,
        data: data,
        timestamp: now,
        replication_nodes: replication_nodes,
        version: 1,
    }

    node.stored_values[node.storage_count] = value
    node.storage_count = node.storage_count + 1
    node.data_stored = node.data_stored + 1

    return true
}

pub fn dhtnode_find_value(node: &DHTNode, key: String) -> String {
    var i = 0
    while i < node.storage_count {
        if node.stored_values[i].key == key {
            return node.stored_values[i].data
        }
        i = i + 1
    }
    return ""  // Not found
}

pub fn dhtnode_lookup(node: &mut DHTNode, target: NodeID) -> [Peer; 20] {
    var result = dhtnode_find_nearest_peers(node, target, KADEMLIA_K)
    node.lookups_completed = node.lookups_completed + 1
    return result
}

pub fn dhtnode_replicate_value(node: &mut DHTNode, key: String, data: String, replication_nodes: [NodeID; REPLICATION_FACTOR]) {
    var success = dhtnode_store_value(node, key, data, replication_nodes)
    if success {
        node.replications_done = node.replications_done + 1
    }
}

