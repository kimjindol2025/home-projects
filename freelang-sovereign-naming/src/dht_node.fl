pub fn test_a5_data_storage_retrieval() -> bool {
    var node_id = nodeid_new([1, 0, 0, 0, 0, 0, 0, 0])
    var node = dhtnode_new(node_id, "127.0.0.1", 8000)

    var replication_nodes: [NodeID; 3]
    replication_nodes[0] = nodeid_new([2, 0, 0, 0, 0, 0, 0, 0])
    replication_nodes[1] = nodeid_new([3, 0, 0, 0, 0, 0, 0, 0])
    replication_nodes[2] = nodeid_new([4, 0, 0, 0, 0, 0, 0, 0])

    var success = dhtnode_store_value(&mut node, "key1", "value1", replication_nodes)
    var retrieved = dhtnode_find_value(&node, "key1")

    return success && retrieved == "value1"
}

pub fn test_a6_automatic_replication() -> bool {
    var node_id = nodeid_new([1, 0, 0, 0, 0, 0, 0, 0])
    var node = dhtnode_new(node_id, "127.0.0.1", 8000)

    var replication_nodes: [NodeID; 3]
    replication_nodes[0] = nodeid_new([2, 0, 0, 0, 0, 0, 0, 0])
    replication_nodes[1] = nodeid_new([3, 0, 0, 0, 0, 0, 0, 0])
    replication_nodes[2] = nodeid_new([4, 0, 0, 0, 0, 0, 0, 0])

    dhtnode_replicate_value(&mut node, "key1", "replicated_value", replication_nodes)

    return node.replications_done == 1
}

