pub fn test_a10_large_network_simulation() -> bool {
    var node_id = nodeid_new([1, 0, 0, 0, 0, 0, 0, 0])
    var node = dhtnode_new(node_id, "127.0.0.1", 8000)

    // Simulate 1000+ node network
    var i = 0
    while i < 100 {  // 100 nodes as sample
        var peer_id_arr: [u64; 8]
        peer_id_arr[0] = i as u64
        var peer_id = nodeid_new(peer_id_arr)

        var peer = Peer {
            node_id: peer_id,
            ip: "127.0.0.1",
            port: 8000 + i as u16,
            last_seen: 0,
            reputation: 100,
        }

        dhtnode_add_peer(&mut node, peer)
        i = i + 1
    }

    return node.peer_count > 0
}
